001394r 2               
001394r 2               ; --- NEXT ---
001394r 2               BasCmdNext:
001394r 2  20 rr rr       jsr BasSkipSpaces
001397r 2  20 rr rr       jsr BasGetTokChar
00139Ar 2               
00139Ar 2                 ; Must be a variable
00139Ar 2  C9 41          cmp #'A'
00139Cr 2  B0 03          bcs @NextVarOk1
00139Er 2  4C rr rr       jmp @NextErr
0013A1r 2               @NextVarOk1:
0013A1r 2  C9 5B          cmp #'Z' + 1
0013A3r 2  90 03          bcc @NextVarOk2
0013A5r 2  4C rr rr       jmp @NextErr
0013A8r 2               @NextVarOk2:
0013A8r 2               
0013A8r 2  38             sec
0013A9r 2  E9 41          sbc #'A'
0013ABr 2  0A             asl
0013ACr 2  85 21          sta BAS_TEMP                   ; Variable offset
0013AEr 2  20 rr rr       jsr BasAdvTxtPtr
0013B1r 2               
0013B1r 2                 ; Search FOR stack from top for matching variable
0013B1r 2  A6 1B          ldx BAS_FORSP
0013B3r 2  D0 03          bne :+
0013B5r 2  4C rr rr       jmp @NextNoFor
0013B8r 2               :
0013B8r 2               
0013B8r 2               @NextSearch:
0013B8r 2  CA             dex                            ; Back up past padding and entries
0013B9r 2  8A             txa
0013BAr 2  38             sec
0013BBr 2  E9 0F          sbc #BAS_FOR_ENTRY - 1         ; Point to start of this entry
0013BDr 2  AA             tax
0013BEr 2  30 78          bmi @NextNoFor
0013C0r 2  BD 80 05       lda BAS_FORSTK,x               ; var_offset
0013C3r 2  C5 21          cmp BAS_TEMP
0013C5r 2  F0 02          beq @NextFound
0013C7r 2                 ; Not this entry — keep searching
0013C7r 2  80 EF          bra @NextSearch
0013C9r 2               
0013C9r 2               @NextFound:
0013C9r 2                 ; Add step to variable
0013C9r 2  BD 83 05       lda BAS_FORSTK + 3,x           ; step lo
0013CCr 2  85 0C          sta BAS_AUX
0013CEr 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
0013D1r 2  85 0D          sta BAS_AUX + 1
0013D3r 2               
0013D3r 2  A4 21          ldy BAS_TEMP                   ; var offset
0013D5r 2  18             clc
0013D6r 2  B9 00 04       lda BAS_VARS,y
0013D9r 2  65 0C          adc BAS_AUX
0013DBr 2  99 00 04       sta BAS_VARS,y
0013DEr 2  85 0A          sta BAS_ACC
0013E0r 2  B9 01 04       lda BAS_VARS + 1,y
0013E3r 2  65 0D          adc BAS_AUX + 1
0013E5r 2  99 01 04       sta BAS_VARS + 1,y
0013E8r 2  85 0B          sta BAS_ACC + 1
0013EAr 2               
0013EAr 2                 ; Load limit into AUX for comparison
0013EAr 2  BD 81 05       lda BAS_FORSTK + 1,x           ; limit lo
0013EDr 2  85 0C          sta BAS_AUX
0013EFr 2  BD 82 05       lda BAS_FORSTK + 2,x           ; limit hi
0013F2r 2  85 0D          sta BAS_AUX + 1
0013F4r 2               
0013F4r 2                 ; Check if loop is done:
0013F4r 2                 ; If step > 0: done when var > limit (AUX)
0013F4r 2                 ; If step < 0: done when var < limit (AUX)
0013F4r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
0013F7r 2  30 07          bmi @NextStepNeg
0013F9r 2               
0013F9r 2                 ; Step positive: compare var (ACC) vs limit (AUX)
0013F9r 2                 ; Done if ACC > AUX (i.e., AUX < ACC)
0013F9r 2  20 rr rr       jsr BasCmpAuxAcc
0013FCr 2  30 37          bmi @NextDone                  ; AUX < ACC means var > limit
0013FEr 2  80 07          bra @NextLoop                  ; Continue loop
001400r 2               
001400r 2               @NextStepNeg:
001400r 2                 ; Step negative: done if var < limit
001400r 2                 ; Done if ACC < AUX (i.e., AUX > ACC)
001400r 2  20 rr rr       jsr BasCmpAuxAcc
001403r 2  F0 02          beq @NextLoop
001405r 2  10 2E          bpl @NextDone                  ; AUX > ACC means var < limit
001407r 2               
001407r 2               @NextLoop:
001407r 2                 ; Continue loop — restore to saved body start
001407r 2                 ; Keep the FOR entry on the stack (FORSP stays where it is)
001407r 2  BD 85 05       lda BAS_FORSTK + 5,x           ; body_line lo
00140Ar 2  85 06          sta BAS_CURLINE
00140Cr 2  BD 86 05       lda BAS_FORSTK + 6,x           ; body_line hi
00140Fr 2  85 07          sta BAS_CURLINE + 1
001411r 2  BD 87 05       lda BAS_FORSTK + 7,x           ; body_txtptr lo
001414r 2  85 04          sta BAS_TXTPTR
001416r 2  BD 88 05       lda BAS_FORSTK + 8,x           ; body_txtptr hi
001419r 2  85 05          sta BAS_TXTPTR + 1
00141Br 2                 ; Skip past ':' separator if present
00141Br 2  20 rr rr       jsr BasSkipSpaces
00141Er 2  20 rr rr       jsr BasGetTokChar
001421r 2  C9 3A          cmp #CH_COLON
001423r 2  D0 03          bne :+
001425r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ':'
001428r 2               : ; Set flag so run loop preserves TXTPTR
001428r 2  A5 17          lda BAS_FLAGS
00142Ar 2  09 04          ora #BAS_FLAG_TXTSET
00142Cr 2  85 17          sta BAS_FLAGS
00142Er 2                 ; Invalidate saved CURLINE so run loop always detects the change
00142Er 2  A9 FF          lda #$FF
001430r 2  85 14          sta BAS_VARPTR
001432r 2  85 15          sta BAS_VARPTR + 1
001434r 2  60             rts
001435r 2               
001435r 2               @NextDone:
001435r 2                 ; Loop complete — remove this FOR entry from stack
001435r 2  86 1B          stx BAS_FORSP                  ; Pop down to this entry (removes it)
001437r 2  60             rts
001438r 2               
001438r 2               @NextNoFor:
001438r 2               @NextErr:
001438r 2  A9 05          lda #ERR_NEXT_NO_FOR
00143Ar 2  4C rr rr       jmp BasError
00143Dr 2               
00143Dr 2               ; --- END ---
00143Dr 2               BasCmdEnd:
00143Dr 2  64 17          stz BAS_FLAGS                  ; Clear run flag
00143Fr 2  60             rts                            ; Returns to BasRunLoop which checks flags
001440r 2               
001440r 2               ; --- SYS ---
001440r 2               ; SYS <address> — Call machine code at 16-bit address, RTS returns to BASIC
001440r 2               BasCmdSys:
001440r 2  20 rr rr       jsr BasExpr                    ; Evaluate address expression → BAS_ACC
001443r 2                 ; Use BAS_TMP2 as the indirect jump target
001443r 2  A5 0A          lda BAS_ACC
001445r 2  85 10          sta BAS_TMP2
001447r 2  A5 0B          lda BAS_ACC + 1
001449r 2  85 11          sta BAS_TMP2 + 1
00144Br 2  6C 10 00       jmp (BAS_TMP2)                 ; JSR-like: callee RTSes back to caller
00144Er 2               
00144Er 2               ; --- LOAD ---
00144Er 2               ; LOAD "filename" — Load from CF filesystem
00144Er 2               ; LOAD (no arg)   — Load via serial ASCII transfer
00144Er 2               BasCmdLoad:
00144Er 2  20 rr rr       jsr BasSkipSpaces
001451r 2  20 rr rr       jsr BasGetTokChar
001454r 2  C9 22          cmp #CH_QUOTE
001456r 2  F0 18          beq @LoadCF
001458r 2               
001458r 2                 ; No filename — serial ASCII load
001458r 2  AD 0D 03       lda HW_PRESENT
00145Br 2  29 10          and #HW_SC
00145Dr 2  F0 0E          beq @LoadNoDev
00145Fr 2  20 rr rr       jsr AsciiLoad
001462r 2  B0 64          bcs @LoadErr
001464r 2                 ; Update BAS_PRGEND from XFER_PTR (points past last byte written)
001464r 2  A5 2A          lda XFER_PTR
001466r 2  85 12          sta BAS_PRGEND
001468r 2  A5 2B          lda XFER_PTR + 1
00146Ar 2  85 13          sta BAS_PRGEND + 1
00146Cr 2  60             rts
00146Dr 2               
00146Dr 2               @LoadNoDev:
00146Dr 2  4C rr rr       jmp BasPrintNoDevice
001470r 2               
001470r 2               @LoadCF:
001470r 2  AD 0D 03       lda HW_PRESENT
001473r 2  29 08          and #HW_CF
001475r 2  F0 F6          beq @LoadNoDev
001477r 2                 ; Parse quoted filename into STR_PTR for FsLoadFile
001477r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00147Ar 2                 ; Point STR_PTR at current position in tokenized text
00147Ar 2  A5 04          lda BAS_TXTPTR
00147Cr 2  85 02          sta STR_PTR
00147Er 2  A5 05          lda BAS_TXTPTR + 1
001480r 2  85 03          sta STR_PTR + 1
001482r 2                 ; Advance TXTPTR past the filename to closing quote
001482r 2               @LoadScanName:
001482r 2  20 rr rr       jsr BasGetTokChar
001485r 2  F0 12          beq @LoadNameDone              ; End of line (unterminated — use what we have)
001487r 2  C9 22          cmp #CH_QUOTE
001489r 2  F0 05          beq @LoadNameEnd
00148Br 2  20 rr rr       jsr BasAdvTxtPtr
00148Er 2  80 F2          bra @LoadScanName
001490r 2               @LoadNameEnd:
001490r 2                 ; Null-terminate the filename in the token buffer (overwrite closing quote)
001490r 2  A0 00          ldy #$00
001492r 2  A9 00          lda #$00
001494r 2  91 04          sta (BAS_TXTPTR),y
001496r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
001499r 2               @LoadNameDone:
001499r 2                 ; Call filesystem load
001499r 2  20 rr rr       jsr FsLoadFile
00149Cr 2  B0 2A          bcs @LoadErr
00149Er 2                 ; Walk next-line pointer chain to find true BAS_PRGEND
00149Er 2                 ; (file may contain machine code after the BASIC program end sentinel)
00149Er 2  A9 00          lda #<BAS_PRG_START
0014A0r 2  85 0E          sta BAS_TMP1
0014A2r 2  A9 08          lda #>BAS_PRG_START
0014A4r 2  85 0F          sta BAS_TMP1 + 1
0014A6r 2               @LoadWalkChain:
0014A6r 2  A0 00          ldy #LINE_NEXT
0014A8r 2  B1 0E          lda (BAS_TMP1),y               ; lo byte of next-line pointer
0014AAr 2  85 10          sta BAS_TMP2
0014ACr 2  C8             iny
0014ADr 2  B1 0E          lda (BAS_TMP1),y               ; hi byte of next-line pointer
0014AFr 2  85 11          sta BAS_TMP2 + 1
0014B1r 2  05 10          ora BAS_TMP2                   ; lo | hi — zero means end sentinel
0014B3r 2  F0 0A          beq @LoadChainEnd
0014B5r 2                 ; Advance to next line
0014B5r 2  A5 10          lda BAS_TMP2
0014B7r 2  85 0E          sta BAS_TMP1
0014B9r 2  A5 11          lda BAS_TMP2 + 1
0014BBr 2  85 0F          sta BAS_TMP1 + 1
0014BDr 2  80 E7          bra @LoadWalkChain
0014BFr 2               @LoadChainEnd:
0014BFr 2                 ; BAS_TMP1 points to the end sentinel — PRGEND = sentinel address
0014BFr 2  A5 0E          lda BAS_TMP1
0014C1r 2  85 12          sta BAS_PRGEND
0014C3r 2  A5 0F          lda BAS_TMP1 + 1
0014C5r 2  85 13          sta BAS_PRGEND + 1
0014C7r 2  60             rts
0014C8r 2               
0014C8r 2               @LoadErr:
0014C8r 2  A9 rr          lda #<BasStrLoadErr
0014CAr 2  85 0E          sta BAS_TMP1
0014CCr 2  A9 rr          lda #>BasStrLoadErr
0014CEr 2  85 0F          sta BAS_TMP1 + 1
0014D0r 2  20 rr rr       jsr BasPrintStr
0014D3r 2  60             rts
0014D4r 2               
0014D4r 2               ; --- SAVE ---
0014D4r 2               ; SAVE "filename" — Save to CF filesystem
0014D4r 2               ; SAVE (no arg)   — Save via serial ASCII transfer
0014D4r 2               BasCmdSave:
0014D4r 2  20 rr rr       jsr BasSkipSpaces
0014D7r 2  20 rr rr       jsr BasGetTokChar
0014DAr 2  C9 22          cmp #CH_QUOTE
0014DCr 2  F0 0E          beq @SaveCF
0014DEr 2               
0014DEr 2                 ; No filename — serial ASCII save
0014DEr 2  AD 0D 03       lda HW_PRESENT
0014E1r 2  29 10          and #HW_SC
0014E3r 2  F0 04          beq @SaveNoDev
0014E5r 2  20 rr rr       jsr AsciiSave
0014E8r 2  60             rts
0014E9r 2               
0014E9r 2               @SaveNoDev:
0014E9r 2  4C rr rr       jmp BasPrintNoDevice
0014ECr 2               
0014ECr 2               @SaveCF:
0014ECr 2  AD 0D 03       lda HW_PRESENT
0014EFr 2  29 08          and #HW_CF
0014F1r 2  F0 F6          beq @SaveNoDev
0014F3r 2                 ; Parse quoted filename into STR_PTR for FsSaveFile
0014F3r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
0014F6r 2  A5 04          lda BAS_TXTPTR
0014F8r 2  85 02          sta STR_PTR
0014FAr 2  A5 05          lda BAS_TXTPTR + 1
0014FCr 2  85 03          sta STR_PTR + 1
0014FEr 2                 ; Advance TXTPTR past the filename to closing quote
0014FEr 2               @SaveScanName:
0014FEr 2  20 rr rr       jsr BasGetTokChar
001501r 2  F0 12          beq @SaveNameDone
001503r 2  C9 22          cmp #CH_QUOTE
001505r 2  F0 05          beq @SaveNameEnd
001507r 2  20 rr rr       jsr BasAdvTxtPtr
00150Ar 2  80 F2          bra @SaveScanName
00150Cr 2               @SaveNameEnd:
00150Cr 2  A0 00          ldy #$00
00150Er 2  A9 00          lda #$00
001510r 2  91 04          sta (BAS_TXTPTR),y
001512r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
001515r 2               @SaveNameDone:
001515r 2                 ; Calculate file size = BAS_PRGEND - PROGRAM_START
001515r 2  A5 12          lda BAS_PRGEND
001517r 2  38             sec
001518r 2  E9 00          sbc #<PROGRAM_START
00151Ar 2  8D 4A 03       sta FS_FILE_SIZE
00151Dr 2  A5 13          lda BAS_PRGEND + 1
00151Fr 2  E9 08          sbc #>PROGRAM_START
001521r 2  8D 4B 03       sta FS_FILE_SIZE + 1
001524r 2                 ; Call filesystem save
001524r 2  20 rr rr       jsr FsSaveFile
001527r 2  B0 01          bcs @SaveErr
001529r 2  60             rts
00152Ar 2               
00152Ar 2               @SaveErr:
00152Ar 2  A9 rr          lda #<BasStrSaveErr
00152Cr 2  85 0E          sta BAS_TMP1
00152Er 2  A9 rr          lda #>BasStrSaveErr
001530r 2  85 0F          sta BAS_TMP1 + 1
001532r 2  20 rr rr       jsr BasPrintStr
001535r 2  60             rts
001536r 2               
001536r 2               ; --- DIR ---
001536r 2               ; DIR — Print directory listing from CF
001536r 2               BasCmdDir:
001536r 2  AD 0D 03       lda HW_PRESENT
001539r 2  29 08          and #HW_CF
00153Br 2  D0 03          bne @DirHasCF
00153Dr 2  4C rr rr       jmp BasPrintNoDevice
001540r 2               @DirHasCF:
001540r 2  20 rr rr       jsr FsDirectory
001543r 2  60             rts
001544r 2               
001544r 2               ; --- DEL ---
001544r 2               ; DEL "filename" — Delete a file from CF
001544r 2               BasCmdDel:
001544r 2  AD 0D 03       lda HW_PRESENT
001547r 2  29 08          and #HW_CF
001549r 2  D0 03          bne @DelHasCF
00154Br 2  4C rr rr       jmp BasPrintNoDevice
00154Er 2               @DelHasCF:
00154Er 2  20 rr rr       jsr BasSkipSpaces
001551r 2  20 rr rr       jsr BasGetTokChar
001554r 2  C9 22          cmp #CH_QUOTE
001556r 2  D0 28          bne @DelErr
001558r 2               
001558r 2                 ; Parse quoted filename into STR_PTR for FsDeleteFile
001558r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00155Br 2  A5 04          lda BAS_TXTPTR
00155Dr 2  85 02          sta STR_PTR
00155Fr 2  A5 05          lda BAS_TXTPTR + 1
001561r 2  85 03          sta STR_PTR + 1
001563r 2                 ; Advance TXTPTR past the filename to closing quote
001563r 2               @DelScanName:
001563r 2  20 rr rr       jsr BasGetTokChar
001566r 2  F0 12          beq @DelNameDone
001568r 2  C9 22          cmp #CH_QUOTE
00156Ar 2  F0 05          beq @DelNameEnd
00156Cr 2  20 rr rr       jsr BasAdvTxtPtr
00156Fr 2  80 F2          bra @DelScanName
001571r 2               @DelNameEnd:
001571r 2  A0 00          ldy #$00
001573r 2  A9 00          lda #$00
001575r 2  91 04          sta (BAS_TXTPTR),y
001577r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
00157Ar 2               @DelNameDone:
00157Ar 2                 ; Call filesystem delete
00157Ar 2  20 rr rr       jsr FsDeleteFile
00157Dr 2  B0 01          bcs @DelErr
00157Fr 2  60             rts
001580r 2               
001580r 2               @DelErr:
001580r 2  A9 rr          lda #<BasStrDelErr
001582r 2  85 0E          sta BAS_TMP1
001584r 2  A9 rr          lda #>BasStrDelErr
001586r 2  85 0F          sta BAS_TMP1 + 1
001588r 2  20 rr rr       jsr BasPrintStr
00158Br 2  60             rts
00158Cr 2               
00158Cr 2               ; --- CLS ---
00158Cr 2               BasCmdCls:
00158Cr 2  20 rr rr       jsr VideoClear
00158Fr 2  60             rts
001590r 2               
001590r 2               ; --- LOCATE row, col ---
001590r 2               BasCmdLocate:
001590r 2  20 rr rr       jsr BasExpr                    ; row -> BAS_ACC
001593r 2  A5 0A          lda BAS_ACC
001595r 2  85 21          sta BAS_TEMP                   ; save row
001597r 2  20 rr rr       jsr BasSkipSpaces
00159Ar 2  A9 2C          lda #CH_COMMA
00159Cr 2  20 rr rr       jsr BasExpectChar
00159Fr 2  20 rr rr       jsr BasExpr                    ; col -> BAS_ACC
0015A2r 2  A5 0A          lda BAS_ACC
0015A4r 2  AA             tax                            ; X = col
0015A5r 2  A4 21          ldy BAS_TEMP                   ; Y = row
0015A7r 2  20 rr rr       jsr VideoSetCursor
0015AAr 2  60             rts
0015ABr 2               
0015ABr 2               ; --- COLOR fg, bg ---
0015ABr 2               BasCmdColor:
0015ABr 2  20 rr rr       jsr BasExpr                    ; fg -> BAS_ACC (0-15)
0015AEr 2  A5 0A          lda BAS_ACC
0015B0r 2  29 0F          and #$0F
0015B2r 2  0A             asl a
0015B3r 2  0A             asl a
0015B4r 2  0A             asl a
0015B5r 2  0A             asl a                          ; shift to high nibble
0015B6r 2  85 21          sta BAS_TEMP
0015B8r 2  20 rr rr       jsr BasSkipSpaces
0015BBr 2  A9 2C          lda #CH_COMMA
0015BDr 2  20 rr rr       jsr BasExpectChar
0015C0r 2  20 rr rr       jsr BasExpr                    ; bg -> BAS_ACC (0-15)
0015C3r 2  A5 0A          lda BAS_ACC
0015C5r 2  29 0F          and #$0F
0015C7r 2  05 21          ora BAS_TEMP                   ; combine fg|bg
0015C9r 2  20 rr rr       jsr VideoSetColor
0015CCr 2  60             rts
0015CDr 2               
0015CDr 2               ; --- SOUND voice, freq, dur ---
0015CDr 2               ; freq is in Hz; converted to SID register via: reg = Hz*16 + Hz - Hz/4
0015CDr 2               ; Approximation of Hz * 2^24 / 1000000 ≈ Hz * 16.75 (0.16% error)
0015CDr 2               BasCmdSound:
0015CDr 2  AD 0D 03       lda HW_PRESENT
0015D0r 2  29 40          and #HW_SID
0015D2r 2  D0 01          bne @SoundStart
0015D4r 2  60             rts
0015D5r 2               @SoundStart:
0015D5r 2  20 rr rr       jsr BasExpr                    ; voice (1-3) -> BAS_ACC
0015D8r 2  A5 0A          lda BAS_ACC
0015DAr 2  3A             dec a                          ; convert to 0-indexed
0015DBr 2  85 21          sta BAS_TEMP                   ; save voice
0015DDr 2  20 rr rr       jsr BasSkipSpaces
0015E0r 2  A9 2C          lda #CH_COMMA
0015E2r 2  20 rr rr       jsr BasExpectChar
0015E5r 2  20 rr rr       jsr BasExpr                    ; freq (Hz) -> BAS_ACC
0015E8r 2                 ; --- Convert Hz to SID register value ---
0015E8r 2  A5 0A          lda BAS_ACC                    ; save Hz in BAS_SCRATCH
0015EAr 2  85 1C          sta BAS_SCRATCH
0015ECr 2  A5 0B          lda BAS_ACC + 1
0015EEr 2  85 1D          sta BAS_SCRATCH + 1
0015F0r 2  06 0A          asl BAS_ACC                    ; BAS_ACC = Hz << 4 (multiply by 16)
0015F2r 2  26 0B          rol BAS_ACC + 1
0015F4r 2  06 0A          asl BAS_ACC
0015F6r 2  26 0B          rol BAS_ACC + 1
0015F8r 2  06 0A          asl BAS_ACC
0015FAr 2  26 0B          rol BAS_ACC + 1
0015FCr 2  06 0A          asl BAS_ACC
0015FEr 2  26 0B          rol BAS_ACC + 1
001600r 2  18             clc                            ; BAS_ACC += Hz (now Hz * 17)
001601r 2  A5 0A          lda BAS_ACC
001603r 2  65 1C          adc BAS_SCRATCH
001605r 2  85 0A          sta BAS_ACC
001607r 2  A5 0B          lda BAS_ACC + 1
001609r 2  65 1D          adc BAS_SCRATCH + 1
00160Br 2  85 0B          sta BAS_ACC + 1
00160Dr 2  46 1D          lsr BAS_SCRATCH + 1            ; BAS_SCRATCH = Hz / 4
00160Fr 2  66 1C          ror BAS_SCRATCH
001611r 2  46 1D          lsr BAS_SCRATCH + 1
001613r 2  66 1C          ror BAS_SCRATCH
001615r 2  38             sec                            ; BAS_ACC -= Hz/4 (now Hz * 16.75)
001616r 2  A5 0A          lda BAS_ACC
001618r 2  E5 1C          sbc BAS_SCRATCH
00161Ar 2  85 0A          sta BAS_ACC
00161Cr 2  A5 0B          lda BAS_ACC + 1
00161Er 2  E5 1D          sbc BAS_SCRATCH + 1
001620r 2  85 0B          sta BAS_ACC + 1
001622r 2                 ; --- SID register value now in BAS_ACC ---
001622r 2  A5 0B          lda BAS_ACC + 1
001624r 2  48             pha                            ; save regHi on stack
001625r 2  A5 0A          lda BAS_ACC
001627r 2  48             pha                            ; save regLo on stack
001628r 2  20 rr rr       jsr BasSkipSpaces
00162Br 2  A9 2C          lda #CH_COMMA
00162Dr 2  20 rr rr       jsr BasExpectChar
001630r 2  20 rr rr       jsr BasExpr                    ; dur (centiseconds) -> BAS_ACC
001633r 2                 ; BAS_ACC holds dur; stack holds freq; BAS_TEMP holds voice
001633r 2  68             pla                            ; freqLo
001634r 2  AA             tax                            ; X = freqLo
001635r 2  68             pla                            ; freqHi
001636r 2  A8             tay                            ; Y = freqHi
001637r 2  A5 21          lda BAS_TEMP                   ; A = voice (0-indexed)
001639r 2  20 rr rr       jsr SidPlayNote
00163Cr 2  A5 0A          lda BAS_ACC                    ; A = dur_lo (BAS_ACC not changed by SidPlayNote)
00163Er 2  A6 0B          ldx BAS_ACC + 1                ; X = dur_hi
001640r 2  20 rr rr       jsr SysDelay
001643r 2  20 rr rr       jsr SidSilence
001646r 2  60             rts
001647r 2               
001647r 2               ; --- VOL n ---
001647r 2               BasCmdVol:
001647r 2  AD 0D 03       lda HW_PRESENT
00164Ar 2  29 40          and #HW_SID
00164Cr 2  D0 01          bne @VolStart
00164Er 2  60             rts
00164Fr 2               @VolStart:
00164Fr 2  20 rr rr       jsr BasExpr
001652r 2  A5 0A          lda BAS_ACC
001654r 2  20 rr rr       jsr SidSetVolume
001657r 2  60             rts
001658r 2               
001658r 2               ; BasPrint2Digit — Print A as a 2-digit decimal with leading zero
001658r 2               ; Input: A = value 0-99
001658r 2               ; Modifies: A, X, Flags
001658r 2               BasPrint2Digit:
001658r 2  A2 00          ldx #0
00165Ar 2               @P2DLoop:
00165Ar 2  C9 0A          cmp #10
00165Cr 2  90 05          bcc @P2DDone
00165Er 2  E9 0A          sbc #10                        ; carry already set from cmp
001660r 2  E8             inx
001661r 2  80 F7          bra @P2DLoop
001663r 2               @P2DDone:
001663r 2  48             pha                            ; save units digit
001664r 2  8A             txa
001665r 2  09 30          ora #'0'                       ; tens digit as ASCII
001667r 2  20 rr rr       jsr Chrout
00166Ar 2  68             pla
00166Br 2  09 30          ora #'0'                       ; units digit as ASCII
00166Dr 2  20 rr rr       jsr Chrout
001670r 2  60             rts
001671r 2               
001671r 2               ; --- TIME ---
001671r 2               BasCmdTime:
001671r 2  AD 0D 03       lda HW_PRESENT
001674r 2  29 04          and #HW_RTC
001676r 2  D0 03          bne @TimeHasRTC
001678r 2  4C rr rr       jmp BasPrintNoDevice
00167Br 2               @TimeHasRTC:
00167Br 2  20 rr rr       jsr RtcReadTime                ; A=hours, X=minutes, Y=seconds
00167Er 2  5A             phy                            ; save seconds
00167Fr 2  DA             phx                            ; save minutes
001680r 2  20 rr rr       jsr BasPrint2Digit             ; print hours
001683r 2  A9 3A          lda #':'
001685r 2  20 rr rr       jsr Chrout
001688r 2  68             pla                            ; restore minutes
001689r 2  20 rr rr       jsr BasPrint2Digit
00168Cr 2  A9 3A          lda #':'
00168Er 2  20 rr rr       jsr Chrout
001691r 2  68             pla                            ; restore seconds
001692r 2  20 rr rr       jsr BasPrint2Digit
001695r 2  20 rr rr       jsr BasPrintCRLF
001698r 2  60             rts
001699r 2               
001699r 2               ; --- DATE ---
001699r 2               BasCmdDate:
001699r 2  AD 0D 03       lda HW_PRESENT
00169Cr 2  29 04          and #HW_RTC
00169Er 2  D0 03          bne @DateHasRTC
0016A0r 2  4C rr rr       jmp BasPrintNoDevice
0016A3r 2               @DateHasRTC:
0016A3r 2  20 rr rr       jsr RtcReadDate                ; A=day, X=month, Y=year; RTC_BUF_CENT=century
0016A6r 2  48             pha                            ; save day
0016A7r 2  DA             phx                            ; save month
0016A8r 2  5A             phy                            ; save year (pushed last, popped first)
0016A9r 2  AD 0B 03       lda RTC_BUF_CENT
0016ACr 2  20 rr rr       jsr BasPrint2Digit             ; print century
0016AFr 2  68             pla                            ; restore year
0016B0r 2  20 rr rr       jsr BasPrint2Digit             ; print year (CCYY together)
0016B3r 2  A9 2D          lda #'-'
0016B5r 2  20 rr rr       jsr Chrout
0016B8r 2  68             pla                            ; restore month
0016B9r 2  20 rr rr       jsr BasPrint2Digit
0016BCr 2  A9 2D          lda #'-'
0016BEr 2  20 rr rr       jsr Chrout
0016C1r 2  68             pla                            ; restore day
0016C2r 2  20 rr rr       jsr BasPrint2Digit
0016C5r 2  20 rr rr       jsr BasPrintCRLF
0016C8r 2  60             rts
0016C9r 2               
0016C9r 2               ; --- WAIT addr, mask ---
0016C9r 2               BasCmdWait:
0016C9r 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
0016CCr 2  A5 0A          lda BAS_ACC
0016CEr 2  85 10          sta BAS_TMP2
0016D0r 2  A5 0B          lda BAS_ACC + 1
0016D2r 2  85 11          sta BAS_TMP2 + 1
0016D4r 2  20 rr rr       jsr BasSkipSpaces
0016D7r 2  A9 2C          lda #CH_COMMA
0016D9r 2  20 rr rr       jsr BasExpectChar
0016DCr 2  20 rr rr       jsr BasExpr                    ; mask -> BAS_ACC
0016DFr 2  A5 0A          lda BAS_ACC
0016E1r 2  85 21          sta BAS_TEMP
0016E3r 2               @WaitPoll:
0016E3r 2  20 rr rr       jsr BasCheckBreak              ; allow Ctrl+C to abort
0016E6r 2  A0 00          ldy #0
0016E8r 2  B1 10          lda (BAS_TMP2),y
0016EAr 2  25 21          and BAS_TEMP
0016ECr 2  F0 F5          beq @WaitPoll
0016EEr 2  60             rts
0016EFr 2               
0016EFr 2               ; --- PAUSE n ---
0016EFr 2               BasCmdPause:
0016EFr 2  20 rr rr       jsr BasExpr
0016F2r 2  A5 0A          lda BAS_ACC
0016F4r 2  A6 0B          ldx BAS_ACC + 1
0016F6r 2  20 rr rr       jsr SysDelay
0016F9r 2  60             rts
0016FAr 2               
0016FAr 2               ; --- BANK n ---
0016FAr 2               BasCmdBank:
0016FAr 2  AD 0D 03       lda HW_PRESENT
0016FDr 2  29 01          and #HW_RAM_L
0016FFr 2  D0 03          bne @BankHasRAM
001701r 2  4C rr rr       jmp BasPrintNoDevice
001704r 2               @BankHasRAM:
001704r 2  20 rr rr       jsr BasExpr
001707r 2  A5 0A          lda BAS_ACC
001709r 2  8D FF 83       sta RAM_BANK_L
00170Cr 2  60             rts
00170Dr 2               
00170Dr 2               ; --- BRK ---
00170Dr 2               BasCmdBrk:
00170Dr 2  64 17          stz BAS_FLAGS                  ; Clear run flag
00170Fr 2  00             brk                            ; Trigger BRK → IRQ vector → Wozmon
001710r 2               
001710r 2               ; --- NEW ---
001710r 2               BasCmdNew:
001710r 2                 ; Set program end to program start (empty program)
001710r 2  A9 00          lda #<BAS_PRG_START
001712r 2  85 12          sta BAS_PRGEND
001714r 2  A9 08          lda #>BAS_PRG_START
001716r 2  85 13          sta BAS_PRGEND + 1
001718r 2                 ; Write end marker
001718r 2  A0 00          ldy #LINE_NEXT
00171Ar 2  A9 00          lda #$00
00171Cr 2  91 12          sta (BAS_PRGEND),y
00171Er 2  C8             iny
00171Fr 2  91 12          sta (BAS_PRGEND),y
001721r 2                 ; Clear variables
001721r 2  20 rr rr       jsr BasCmdClr
001724r 2  64 17          stz BAS_FLAGS
001726r 2  4C rr rr       jmp BasMainLoop
001729r 2               
001729r 2               ; --- LIST ---
001729r 2               BasCmdList:
001729r 2                 ; Start at beginning of program
001729r 2  A9 00          lda #<BAS_PRG_START
00172Br 2  85 0E          sta BAS_TMP1
00172Dr 2  A9 08          lda #>BAS_PRG_START
00172Fr 2  85 0F          sta BAS_TMP1 + 1
001731r 2               
001731r 2               @ListLoop:
