000000r 2               GPIO_PORTA          := $9401
000000r 2               GPIO_DDRB           := $9402
000000r 2               GPIO_DDRA           := $9403
000000r 2               GPIO_T1CL           := $9404
000000r 2               GPIO_T1CH           := $9405
