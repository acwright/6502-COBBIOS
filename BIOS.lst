0021F8r 2  A9 9F                lda     #TOK_THEN
0021FAr 2  20 rr rr             jsr     SynChr
0021FDr 2               @testTrue:
0021FDr 2  A5 0E                lda     FAC
0021FFr 2  D0 1F                bne     @true
002201r 2                       ; FALSE: scan to end-of-line OR a TOK_ELSE; if ELSE found, advance
002201r 2                       ; TXTPTR past it and resume execution there.
002201r 2  A0 00                ldy     #0
002203r 2               @searchElse:
002203r 2  B1 04                lda     (TXTPTR),y
002205r 2  F0 07                beq     @noElse
002207r 2  C9 A4                cmp     #TOK_ELSE
002209r 2  F0 09                beq     @gotElse
00220Br 2  C8                   iny
00220Cr 2  D0 F5                bne     @searchElse
00220Er 2               @noElse:
00220Er 2                       ; Skip remainder of line (no ELSE).
00220Er 2  20 rr rr             jsr     BasRemn
002211r 2  4C rr rr             jmp     BasAddon
002214r 2               @gotElse:
002214r 2                       ; Advance TXTPTR past ELSE token; continue execution.
002214r 2  C8                   iny
002215r 2  98                   tya
002216r 2  18                   clc
002217r 2  65 04                adc     TXTPTR
002219r 2  85 04                sta     TXTPTR
00221Br 2  90 02                bcc     @t1
00221Dr 2  E6 05                inc     TXTPTR+1
00221Fr 2               @t1:
00221Fr 2  60                   rts
002220r 2               @true:
002220r 2                       ; TRUE: if next is a digit, IF expr THEN <linenum> -> implicit GOTO.
002220r 2  20 rr rr             jsr     ChrGot
002223r 2  90 03                bcc     @goto                   ; carry CLEAR -> digit
002225r 2                       ; Otherwise dispatch as a statement (msbasic: jmp EXECUTE_STATEMENT).
002225r 2  4C rr rr             jmp     BasExecuteStatement
002228r 2               @goto:
002228r 2  4C rr rr             jmp     BasCmdGoto
00222Br 2               
00222Br 2               ; ---------------------------------------------------------------------------
00222Br 2               ; Statement: ON expr GOTO/GOSUB linenum,linenum,...
00222Br 2               ; ---------------------------------------------------------------------------
00222Br 2               BasCmdOn:
00222Br 2  20 rr rr             jsr     GetByt                  ; X = expr byte (1..255)
00222Er 2  48                   pha                             ; save GOTO/GOSUB token byte
00222Fr 2  C9 8C                cmp     #TOK_GOSUB
002231r 2  F0 04                beq     @loop
002233r 2  C9 88                cmp     #TOK_GOTO
002235r 2  D0 14                bne     @synErr
002237r 2               @loop:
002237r 2  C6 12                dec     FAC+4
002239r 2  D0 04                bne     @next
00223Br 2  68                   pla
00223Cr 2                       ; Re-dispatch through statement table so trampoline ChrGet skips the
00223Cr 2                       ; current separator (',' or 0) before the GOTO/GOSUB handler runs.
00223Cr 2  4C rr rr             jmp     BasExecuteStatement
00223Fr 2               @next:
00223Fr 2  20 rr rr             jsr     ChrGet
002242r 2  20 rr rr             jsr     LinGet
002245r 2  C9 2C                cmp     #','
002247r 2  F0 EE                beq     @loop
002249r 2  68                   pla
00224Ar 2  60                   rts
00224Br 2               @synErr:
00224Br 2  68                   pla
00224Cr 2  4C rr rr             jmp     SynErr
00224Fr 2               
00224Fr 2               ; ---------------------------------------------------------------------------
00224Fr 2               ; GetByt / GtByteCom -- evaluate expression in TXTPTR to byte 0..255 in X.
00224Fr 2               ;   GetByt: TXTPTR is at first byte of expression.
00224Fr 2               ;   GtByteCom: consume comma first.
00224Fr 2               ; ---------------------------------------------------------------------------
00224Fr 2               GtByteCom:
00224Fr 2  20 rr rr             jsr     ChrGet
002252r 2               GetByt:
002252r 2  20 rr rr             jsr     FrmNum
002255r 2  20 rr rr             jsr     MkInt
002258r 2  A6 11                ldx     FAC+3
00225Ar 2  D0 05                bne     @ovf
00225Cr 2  A6 12                ldx     FAC+4
00225Er 2  4C rr rr             jmp     ChrGot
002261r 2               @ovf:
002261r 2  4C rr rr             jmp     IqErr
002264r 2               
002264r 2               ; ---------------------------------------------------------------------------
002264r 2               ; Statement: RUN [linenum]
002264r 2               ; ---------------------------------------------------------------------------
002264r 2               BasCmdRun:
002264r 2  20 rr rr             jsr     ChrGot
002267r 2  D0 1F                bne     @withLine
002269r 2  20 rr rr             jsr     BasCmdClr
00226Cr 2                       ; Set TXTPTR = TXTTAB - 1 ; ensure that byte = 0.
00226Cr 2  38                   sec
00226Dr 2  AD 5D 03             lda     BAS_TXTTAB
002270r 2  E9 01                sbc     #1
002272r 2  85 04                sta     TXTPTR
002274r 2  AD 5E 03             lda     BAS_TXTTAB+1
002277r 2  E9 00                sbc     #0
002279r 2  85 05                sta     TXTPTR+1
00227Br 2                       ; Force the byte at TXTTAB-1 to be zero so NEWSTT walks the chain.
00227Br 2  A9 00                lda     #0
00227Dr 2  A0 00                ldy     #0
00227Fr 2  91 04                sta     (TXTPTR),y
002281r 2                       ; Leave direct-mode (CURLIN+1=$FF); @loadLine will set real value.
002281r 2  9C 69 03             stz     BAS_CURLIN
002284r 2  9C 6A 03             stz     BAS_CURLIN+1
002287r 2  60                   rts
002288r 2               @withLine:
002288r 2  20 rr rr             jsr     BasCmdClr
00228Br 2  20 rr rr             jsr     ChrGot
00228Er 2  4C rr rr             jmp     BasCmdGoto
002291r 2               
002291r 2               ; ---------------------------------------------------------------------------
002291r 2               ; Statement: END / STOP -- save CONT context and return to REPL.
002291r 2               ; ---------------------------------------------------------------------------
002291r 2               BasCmdEnd:
002291r 2  18                   clc
002292r 2  24                   .byte   $24                     ; BIT zp -> skip next byte (sec)
002293r 2               BasCmdStop:
002293r 2  38                   sec
002294r 2                       ; Save the END/STOP flag (carry) before ChrGot clobbers it.
002294r 2  08                   php
002295r 2  20 rr rr             jsr     ChrGot
002298r 2  D0 57                bne     @synErrPlp
00229Ar 2  28                   plp
00229Br 2                       ; Save CONT state.
00229Br 2  A5 04                lda     TXTPTR
00229Dr 2  8D 6D 03             sta     BAS_OLDTEXT
0022A0r 2  A5 05                lda     TXTPTR+1
0022A2r 2  8D 6E 03             sta     BAS_OLDTEXT+1
