000C3Fr 2  A5 0A          lda BAS_ACC
000C41r 2  48             pha
000C42r 2  A5 0B          lda BAS_ACC + 1
000C44r 2  48             pha
000C45r 2  A9 2C          lda #CH_COMMA
000C47r 2  20 rr rr       jsr BasExpectChar
000C4Ar 2  20 rr rr       jsr BasExpr                    ; exponent -> BAS_ACC
000C4Dr 2  A9 29          lda #CH_RPAREN
000C4Fr 2  20 rr rr       jsr BasExpectChar
000C52r 2                 ; ACC = exponent, stack has base
000C52r 2                 ; Move exponent to AUX, pop base to ACC
000C52r 2  A5 0A          lda BAS_ACC
000C54r 2  85 0C          sta BAS_AUX
000C56r 2  A5 0B          lda BAS_ACC + 1
000C58r 2  85 0D          sta BAS_AUX + 1
000C5Ar 2  68             pla
000C5Br 2  85 0B          sta BAS_ACC + 1
000C5Dr 2  68             pla
000C5Er 2  85 0A          sta BAS_ACC
000C60r 2  4C rr rr       jmp BasFuncPow                 ; ACC=base, AUX=exponent
000C63r 2               @NotPow:
000C63r 2               
000C63r 2                 ; INKEY — non-blocking keyboard read (no parentheses)
000C63r 2  C9 BA          cmp #TOK_INKEY
000C65r 2  D0 22          bne @NotInkey
000C67r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip INKEY token
000C6Ar 2                 ; Check pending key buffer (saved by BasCheckBreak)
000C6Ar 2  AD 0E 03       lda BAS_PENDKEY
000C6Dr 2  F0 08          beq @InkeyChrin                ; No pending key — try Chrin
000C6Fr 2  9C 0E 03       stz BAS_PENDKEY               ; Consume pending key
000C72r 2  85 0A          sta BAS_ACC
000C74r 2  64 0B          stz BAS_ACC + 1
