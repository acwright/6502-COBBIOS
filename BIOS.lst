001888r 2  90 6A          bcc @ReadSyntax
00188Ar 2  C9 5B          cmp #'Z' + 1
00188Cr 2  B0 66          bcs @ReadSyntax
00188Er 2               
00188Er 2                 ; Compute variable offset and advance past variable letter
00188Er 2  38             sec
00188Fr 2  E9 41          sbc #'A'
001891r 2  0A             asl                            ; ×2 for 16-bit vars
001892r 2  48             pha                            ; Save var offset on stack
001893r 2  20 rr rr       jsr BasAdvTxtPtr
001896r 2               
001896r 2                 ; Save current TXTPTR on stack
001896r 2  A5 05          lda BAS_TXTPTR + 1
001898r 2  48             pha
001899r 2  A5 04          lda BAS_TXTPTR
00189Br 2  48             pha
00189Cr 2               
00189Cr 2                 ; Switch TXTPTR to DATA read position
00189Cr 2  AD 1A 03       lda BAS_DATAPTR
00189Fr 2  85 04          sta BAS_TXTPTR
0018A1r 2  AD 1B 03       lda BAS_DATAPTR + 1
0018A4r 2  85 05          sta BAS_TXTPTR + 1
0018A6r 2               
0018A6r 2                 ; Parse the next data value
0018A6r 2  20 rr rr       jsr BasSkipSpaces
0018A9r 2  20 rr rr       jsr BasExpr                    ; → BAS_ACC
0018ACr 2               
0018ACr 2                 ; Check what follows: comma (more data), null/colon (end of DATA)
0018ACr 2  20 rr rr       jsr BasSkipSpaces
0018AFr 2  20 rr rr       jsr BasGetTokChar
0018B2r 2  C9 2C          cmp #CH_COMMA
0018B4r 2  D0 0F          bne @ReadEndOfData
0018B6r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip comma — DATA pointer past it
0018B9r 2               
