0012B6r 2               ; --- IF...THEN ---
0012B6r 2               BasCmdIf:
0012B6r 2  20 rr rr       jsr BasExpr                    ; Evaluate condition
0012B9r 2  20 rr rr       jsr BasSkipSpaces
0012BCr 2               
0012BCr 2                 ; Expect THEN
0012BCr 2  20 rr rr       jsr BasGetTokChar
0012BFr 2  C9 87          cmp #TOK_THEN
0012C1r 2  D0 1E          bne @IfSyntax
0012C3r 2  20 rr rr       jsr BasAdvTxtPtr
