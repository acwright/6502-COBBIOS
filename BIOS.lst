0022A8r 2  8D 6B 03             sta     BAS_OLDLIN
0022ABr 2  AD 6A 03             lda     BAS_CURLIN+1
0022AEr 2  8D 6C 03             sta     BAS_OLDLIN+1
0022B1r 2  A2 FF                ldx     #$FF
0022B3r 2  9A                   txs
0022B4r 2  90 30                bcc     @end
0022B6r 2                       ; STOP path: print "BREAK[ IN nnnn]".
0022B6r 2  20 rr rr             jsr     BasPrintCRLF
0022B9r 2  A9 rr                lda     #<MsgBreak
0022BBr 2  A0 rr                ldy     #>MsgBreak
0022BDr 2  20 rr rr             jsr     BasPrintStr
0022C0r 2  AD 6A 03             lda     BAS_CURLIN+1
0022C3r 2  C9 FF                cmp     #$FF
0022C5r 2  F0 14                beq     @endNoLine
0022C7r 2  A9 rr                lda     #<MsgInWord
0022C9r 2  A0 rr                ldy     #>MsgInWord
0022CBr 2  20 rr rr             jsr     BasPrintStr
0022CEr 2  AD 69 03             lda     BAS_CURLIN
0022D1r 2  85 08                sta     BAS_LINNUM
0022D3r 2  AD 6A 03             lda     BAS_CURLIN+1
0022D6r 2  85 09                sta     BAS_LINNUM+1
0022D8r 2  20 rr rr             jsr     BasPrintLineNum
0022DBr 2               @endNoLine:
0022DBr 2  A9 FF                lda     #$FF
0022DDr 2  8D 69 03             sta     BAS_CURLIN
0022E0r 2  8D 6A 03             sta     BAS_CURLIN+1
