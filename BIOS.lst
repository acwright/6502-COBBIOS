0008B0r 2                 ; Check if MON_ADDR > MON_END
0008B0r 2  A5 31          lda MON_END+1
0008B2r 2  C5 2F          cmp MON_ADDR+1
0008B4r 2  90 08          bcc @DisDone
0008B6r 2  D0 F3          bne @DisRange
