000931r 2  48             pha
000932r 2  A5 0B          lda BAS_ACC + 1
000934r 2  48             pha
000935r 2  20 rr rr       jsr BasExprUnary
000938r 2  68             pla
000939r 2  85 0D          sta BAS_AUX + 1
00093Br 2  68             pla
00093Cr 2  85 0C          sta BAS_AUX
00093Er 2  20 rr rr       jsr BasMathDiv
000941r 2  4C rr rr       jmp @MulLoop
000944r 2               
000944r 2               @DoMod:
000944r 2  20 rr rr       jsr BasAdvTxtPtr
000947r 2  A5 0A          lda BAS_ACC
000949r 2  48             pha
00094Ar 2  A5 0B          lda BAS_ACC + 1
00094Cr 2  48             pha
00094Dr 2  20 rr rr       jsr BasExprUnary
000950r 2  68             pla
000951r 2  85 0D          sta BAS_AUX + 1
000953r 2  68             pla
000954r 2  85 0C          sta BAS_AUX
000956r 2  20 rr rr       jsr BasMathDiv
000959r 2                 ; MOD result is the remainder
000959r 2  A5 1E          lda BAS_SCRATCH2
00095Br 2  85 0A          sta BAS_ACC
00095Dr 2  A5 1F          lda BAS_SCRATCH2 + 1
00095Fr 2  85 0B          sta BAS_ACC + 1
000961r 2  4C rr rr       jmp @MulLoop
000964r 2               
000964r 2               ; BasExprUnary — Handle unary minus
000964r 2               BasExprUnary:
000964r 2  20 rr rr       jsr BasSkipSpaces
000967r 2  20 rr rr       jsr BasGetTokChar
00096Ar 2  C9 2D          cmp #CH_MINUS
00096Cr 2  D0 09          bne @UnaryPos
00096Er 2  20 rr rr       jsr BasAdvTxtPtr
000971r 2  20 rr rr       jsr BasExprPrimary
000974r 2  4C rr rr       jmp BasMathNeg
000977r 2               @UnaryPos:
000977r 2  4C rr rr       jmp BasExprPrimary
00097Ar 2               
00097Ar 2               ; BasExprPrimary — Numbers, variables, parens, functions
00097Ar 2               BasExprPrimary:
00097Ar 2  20 rr rr       jsr BasSkipSpaces
00097Dr 2  20 rr rr       jsr BasGetTokChar
000980r 2               
000980r 2                 ; Number literal?
000980r 2  C9 30          cmp #'0'
000982r 2  90 07          bcc @NotNum
000984r 2  C9 3A          cmp #'9' + 1
000986r 2  B0 03          bcs @NotNum
000988r 2  4C rr rr       jmp @IsNum                     ; Digit found — parse number
00098Br 2               @NotNum:
00098Br 2               
00098Br 2                 ; Variable A-Z?
00098Br 2  C9 41          cmp #'A'
00098Dr 2  90 16          bcc @NotVar
00098Fr 2  C9 5B          cmp #'Z' + 1
000991r 2  B0 12          bcs @NotVar
000993r 2                 ; Variable — compute address: BAS_VARS + (ch - 'A') * 2
000993r 2  38             sec
000994r 2  E9 41          sbc #'A'
000996r 2  0A             asl                            ; ×2 for 16-bit
000997r 2  AA             tax
000998r 2  BD 00 04       lda BAS_VARS,x
00099Br 2  85 0A          sta BAS_ACC
00099Dr 2  BD 01 04       lda BAS_VARS + 1,x
0009A0r 2  85 0B          sta BAS_ACC + 1
0009A2r 2  4C rr rr       jmp BasAdvTxtPtr               ; Skip variable letter
0009A5r 2               @NotVar:
0009A5r 2               
0009A5r 2                 ; Parenthesized expression?
0009A5r 2  C9 28          cmp #CH_LPAREN
0009A7r 2  D0 0B          bne @NotParen
0009A9r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
0009ACr 2  20 rr rr       jsr BasExpr
0009AFr 2  A9 29          lda #CH_RPAREN
0009B1r 2  4C rr rr       jmp BasExpectChar              ; Expect and skip ')'
0009B4r 2               @NotParen:
0009B4r 2               
0009B4r 2                 ; PEEK(expr)?
0009B4r 2  C9 92          cmp #TOK_PEEK
0009B6r 2  D0 21          bne @NotPeek
0009B8r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip PEEK token
0009BBr 2  A9 28          lda #CH_LPAREN
0009BDr 2  20 rr rr       jsr BasExpectChar
0009C0r 2  20 rr rr       jsr BasExpr
0009C3r 2  A9 29          lda #CH_RPAREN
0009C5r 2  20 rr rr       jsr BasExpectChar
0009C8r 2                 ; Load byte from address in ACC
0009C8r 2  A5 0A          lda BAS_ACC
0009CAr 2  85 10          sta BAS_TMP2
0009CCr 2  A5 0B          lda BAS_ACC + 1
0009CEr 2  85 11          sta BAS_TMP2 + 1
0009D0r 2  A0 00          ldy #$00
0009D2r 2  B1 10          lda (BAS_TMP2),y
0009D4r 2  85 0A          sta BAS_ACC
0009D6r 2  64 0B          stz BAS_ACC + 1
0009D8r 2  60             rts
0009D9r 2               @NotPeek:
0009D9r 2               
0009D9r 2                 ; ABS(expr)?
0009D9r 2  C9 94          cmp #TOK_ABS
0009DBr 2  D0 13          bne @NotAbs
0009DDr 2  20 rr rr       jsr BasAdvTxtPtr
0009E0r 2  A9 28          lda #CH_LPAREN
0009E2r 2  20 rr rr       jsr BasExpectChar
0009E5r 2  20 rr rr       jsr BasExpr
0009E8r 2  A9 29          lda #CH_RPAREN
0009EAr 2  20 rr rr       jsr BasExpectChar
0009EDr 2  4C rr rr       jmp BasMathAbs
0009F0r 2               @NotAbs:
0009F0r 2               
0009F0r 2                 ; RND(expr)?
0009F0r 2  C9 95          cmp #TOK_RND
0009F2r 2  D0 50          bne @NotRnd
0009F4r 2  20 rr rr       jsr BasAdvTxtPtr
0009F7r 2  A9 28          lda #CH_LPAREN
0009F9r 2  20 rr rr       jsr BasExpectChar
0009FCr 2  20 rr rr       jsr BasExpr
0009FFr 2  A9 29          lda #CH_RPAREN
000A01r 2  20 rr rr       jsr BasExpectChar
000A04r 2                 ; Save modulus (ACC) and generate random number
000A04r 2  A5 0A          lda BAS_ACC
000A06r 2  48             pha
000A07r 2  A5 0B          lda BAS_ACC + 1
000A09r 2  48             pha
000A0Ar 2                 ; Galois LFSR step
000A0Ar 2  A5 18          lda BAS_RNDSEED
000A0Cr 2  0A             asl
000A0Dr 2  26 19          rol BAS_RNDSEED + 1
000A0Fr 2  90 02          bcc @RndNoTap
000A11r 2  49 2D          eor #$2D                      ; Tap polynomial
000A13r 2               @RndNoTap:
000A13r 2  85 18          sta BAS_RNDSEED
000A15r 2                 ; Use seed as raw random value
000A15r 2  A5 18          lda BAS_RNDSEED
000A17r 2  85 0C          sta BAS_AUX
000A19r 2  A5 19          lda BAS_RNDSEED + 1
000A1Br 2                 ; Make positive
000A1Br 2  29 7F          and #$7F
000A1Dr 2  85 0D          sta BAS_AUX + 1
000A1Fr 2                 ; Restore modulus
000A1Fr 2  68             pla
000A20r 2  85 0B          sta BAS_ACC + 1
000A22r 2  68             pla
000A23r 2  85 0A          sta BAS_ACC
000A25r 2                 ; If modulus <= 0, just return raw number
000A25r 2  A5 0A          lda BAS_ACC
000A27r 2  05 0B          ora BAS_ACC + 1
000A29r 2  F0 10          beq @RndRaw
000A2Br 2  A5 0B          lda BAS_ACC + 1
000A2Dr 2  30 0C          bmi @RndRaw
000A2Fr 2                 ; ACC = AUX MOD ACC
000A2Fr 2  20 rr rr       jsr BasMathDiv
000A32r 2  A5 1E          lda BAS_SCRATCH2
000A34r 2  85 0A          sta BAS_ACC
000A36r 2  A5 1F          lda BAS_SCRATCH2 + 1
000A38r 2  85 0B          sta BAS_ACC + 1
000A3Ar 2  60             rts
000A3Br 2               @RndRaw:
000A3Br 2  A5 0C          lda BAS_AUX
000A3Dr 2  85 0A          sta BAS_ACC
000A3Fr 2  A5 0D          lda BAS_AUX + 1
000A41r 2  85 0B          sta BAS_ACC + 1
000A43r 2  60             rts
000A44r 2               @NotRnd:
000A44r 2               
000A44r 2                 ; JOY(n) — read joystick port
000A44r 2  C9 A6          cmp #TOK_JOY
000A46r 2  D0 23          bne @NotJoy
000A48r 2  20 rr rr       jsr BasAdvTxtPtr               ; skip TOK_JOY
000A4Br 2  A9 28          lda #CH_LPAREN
000A4Dr 2  20 rr rr       jsr BasExpectChar
000A50r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
000A53r 2  A9 29          lda #CH_RPAREN
000A55r 2  20 rr rr       jsr BasExpectChar
000A58r 2  A5 0A          lda BAS_ACC
000A5Ar 2  C9 02          cmp #2
000A5Cr 2  D0 05          bne @JoyPort1
000A5Er 2  20 rr rr       jsr ReadJoystick2
000A61r 2  80 03          bra @JoyDone
000A63r 2               @JoyPort1:
000A63r 2  20 rr rr       jsr ReadJoystick1
000A66r 2               @JoyDone:
000A66r 2  85 0A          sta BAS_ACC
000A68r 2  64 0B          stz BAS_ACC + 1
000A6Ar 2  60             rts
000A6Br 2               @NotJoy:
000A6Br 2               
000A6Br 2                 ; SGN(x) — return sign of value
000A6Br 2  C9 AE          cmp #TOK_SGN
000A6Dr 2  D0 2D          bne @NotSgn
000A6Fr 2  20 rr rr       jsr BasAdvTxtPtr               ; skip TOK_SGN
000A72r 2  A9 28          lda #CH_LPAREN
000A74r 2  20 rr rr       jsr BasExpectChar
000A77r 2  20 rr rr       jsr BasExpr                    ; x -> BAS_ACC
000A7Ar 2  A9 29          lda #CH_RPAREN
000A7Cr 2  20 rr rr       jsr BasExpectChar
000A7Fr 2  A5 0A          lda BAS_ACC
000A81r 2  05 0B          ora BAS_ACC + 1
000A83r 2  F0 12          beq @SgnZero
000A85r 2  A5 0B          lda BAS_ACC + 1
000A87r 2  30 07          bmi @SgnNeg
000A89r 2  A9 01          lda #$01
000A8Br 2  85 0A          sta BAS_ACC
000A8Dr 2  64 0B          stz BAS_ACC + 1
000A8Fr 2  60             rts
000A90r 2               @SgnNeg:
000A90r 2  A9 FF          lda #$FF
000A92r 2  85 0A          sta BAS_ACC
000A94r 2  85 0B          sta BAS_ACC + 1                ; $FFFF = -1 (signed)
000A96r 2  60             rts
000A97r 2               @SgnZero:
000A97r 2  64 0A          stz BAS_ACC
000A99r 2  64 0B          stz BAS_ACC + 1
000A9Br 2  60             rts
000A9Cr 2               @NotSgn:
000A9Cr 2               
000A9Cr 2                 ; Hex literal $xxxx
000A9Cr 2  C9 24          cmp #'$'
000A9Er 2  D0 2A          bne @NotHex
000AA0r 2  20 rr rr       jsr BasAdvTxtPtr               ; skip '$'
000AA3r 2  64 22          stz BAS_NUMTMP
000AA5r 2  64 23          stz BAS_NUMTMP + 1
000AA7r 2               @HexLoop:
000AA7r 2  20 rr rr       jsr BasGetTokChar
000AAAr 2  20 rr rr       jsr BasNibble                  ; A -> nibble (0-15), carry set if not a hex char
000AADr 2  B0 12          bcs @HexDone
000AAFr 2                 ; Shift NUMTMP left 4 bits
000AAFr 2  A0 04          ldy #4
000AB1r 2               @HexShift:
000AB1r 2  06 22          asl BAS_NUMTMP
000AB3r 2  26 23          rol BAS_NUMTMP + 1
000AB5r 2  88             dey
000AB6r 2  D0 F9          bne @HexShift
000AB8r 2  05 22          ora BAS_NUMTMP
000ABAr 2  85 22          sta BAS_NUMTMP
000ABCr 2  20 rr rr       jsr BasAdvTxtPtr
000ABFr 2  80 E6          bra @HexLoop
000AC1r 2               @HexDone:
000AC1r 2  A5 22          lda BAS_NUMTMP
000AC3r 2  85 0A          sta BAS_ACC
000AC5r 2  A5 23          lda BAS_NUMTMP + 1
000AC7r 2  85 0B          sta BAS_ACC + 1
000AC9r 2  60             rts
