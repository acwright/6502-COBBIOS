0009D8r 2  20 rr rr       jsr Chrout
0009DBr 2  A9 59          lda #'Y'
0009DDr 2  4C rr rr       jmp Chrout
0009E0r 2               
0009E0r 2               DisOpAbs:
0009E0r 2  A9 24          lda #'$'
0009E2r 2  20 rr rr       jsr Chrout
