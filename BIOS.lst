000A1Er 2  48             pha
000A1Fr 2  A5 0B          lda BAS_ACC + 1
000A21r 2  48             pha
000A22r 2  20 rr rr       jsr BasExprUnary
000A25r 2  68             pla
000A26r 2  85 0D          sta BAS_AUX + 1
000A28r 2  68             pla
000A29r 2  85 0C          sta BAS_AUX
000A2Br 2  20 rr rr       jsr BasMathDiv
000A2Er 2  4C rr rr       jmp @MulLoop
000A31r 2               
000A31r 2               @DoMod:
000A31r 2  20 rr rr       jsr BasAdvTxtPtr
000A34r 2  A5 0A          lda BAS_ACC
000A36r 2  48             pha
000A37r 2  A5 0B          lda BAS_ACC + 1
000A39r 2  48             pha
000A3Ar 2  20 rr rr       jsr BasExprUnary
000A3Dr 2  68             pla
000A3Er 2  85 0D          sta BAS_AUX + 1
000A40r 2  68             pla
000A41r 2  85 0C          sta BAS_AUX
000A43r 2  20 rr rr       jsr BasMathDiv
000A46r 2                 ; MOD result is the remainder
000A46r 2  A5 1E          lda BAS_SCRATCH2
000A48r 2  85 0A          sta BAS_ACC
000A4Ar 2  A5 1F          lda BAS_SCRATCH2 + 1
000A4Cr 2  85 0B          sta BAS_ACC + 1
000A4Er 2  4C rr rr       jmp @MulLoop
000A51r 2               
000A51r 2               ; BasExprUnary — Handle unary minus
000A51r 2               BasExprUnary:
000A51r 2  20 rr rr       jsr BasSkipSpaces
000A54r 2  20 rr rr       jsr BasGetTokChar
000A57r 2  C9 2D          cmp #CH_MINUS
000A59r 2  D0 09          bne @UnaryPos
000A5Br 2  20 rr rr       jsr BasAdvTxtPtr
000A5Er 2  20 rr rr       jsr BasExprPrimary
000A61r 2  4C rr rr       jmp BasMathNeg
000A64r 2               @UnaryPos:
000A64r 2  4C rr rr       jmp BasExprPrimary
000A67r 2               
000A67r 2               ; BasExprPrimary — Numbers, variables, parens, functions
000A67r 2               BasExprPrimary:
000A67r 2  20 rr rr       jsr BasSkipSpaces
000A6Ar 2  20 rr rr       jsr BasGetTokChar
000A6Dr 2               
000A6Dr 2                 ; Number literal?
000A6Dr 2  C9 30          cmp #'0'
000A6Fr 2  90 07          bcc @NotNum
000A71r 2  C9 3A          cmp #'9' + 1
000A73r 2  B0 03          bcs @NotNum
000A75r 2  4C rr rr       jmp @IsNum                     ; Digit found — parse number
000A78r 2               @NotNum:
000A78r 2               
000A78r 2                 ; Variable A-Z?
000A78r 2  C9 41          cmp #'A'
000A7Ar 2  90 21          bcc @NotVar
000A7Cr 2  C9 5B          cmp #'Z' + 1
000A7Er 2  B0 1D          bcs @NotVar
000A80r 2                 ; Variable — compute index: (ch - 'A') * 2
000A80r 2  38             sec
000A81r 2  E9 41          sbc #'A'
000A83r 2  0A             asl                            ; ×2 for 16-bit
000A84r 2  AA             tax
000A85r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000A88r 2                 ; Check for '(' → array access
000A88r 2  20 rr rr       jsr BasGetTokChar
000A8Br 2  C9 28          cmp #CH_LPAREN
000A8Dr 2  F0 0B          beq @AryRead
000A8Fr 2                 ; Scalar variable read
000A8Fr 2  BD 00 04       lda BAS_VARS,x
000A92r 2  85 0A          sta BAS_ACC
000A94r 2  BD 01 04       lda BAS_VARS + 1,x
000A97r 2  85 0B          sta BAS_ACC + 1
000A99r 2  60             rts
000A9Ar 2               @AryRead:
000A9Ar 2  4C rr rr       jmp BasArrayRead               ; X = var_offset, will return with BAS_ACC set
000A9Dr 2               @NotVar:
000A9Dr 2               
000A9Dr 2                 ; Parenthesized expression?
000A9Dr 2  C9 28          cmp #CH_LPAREN
000A9Fr 2  D0 0B          bne @NotParen
000AA1r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
000AA4r 2  20 rr rr       jsr BasExpr
000AA7r 2  A9 29          lda #CH_RPAREN
000AA9r 2  4C rr rr       jmp BasExpectChar              ; Expect and skip ')'
000AACr 2               @NotParen:
000AACr 2               
000AACr 2                 ; PEEK(expr)?
000AACr 2  C9 92          cmp #TOK_PEEK
000AAEr 2  D0 21          bne @NotPeek
000AB0r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip PEEK token
000AB3r 2  A9 28          lda #CH_LPAREN
000AB5r 2  20 rr rr       jsr BasExpectChar
000AB8r 2  20 rr rr       jsr BasExpr
000ABBr 2  A9 29          lda #CH_RPAREN
000ABDr 2  20 rr rr       jsr BasExpectChar
000AC0r 2                 ; Load byte from address in ACC
000AC0r 2  A5 0A          lda BAS_ACC
000AC2r 2  85 10          sta BAS_TMP2
000AC4r 2  A5 0B          lda BAS_ACC + 1
000AC6r 2  85 11          sta BAS_TMP2 + 1
000AC8r 2  A0 00          ldy #$00
000ACAr 2  B1 10          lda (BAS_TMP2),y
000ACCr 2  85 0A          sta BAS_ACC
000ACEr 2  64 0B          stz BAS_ACC + 1
000AD0r 2  60             rts
000AD1r 2               @NotPeek:
000AD1r 2               
000AD1r 2                 ; ABS(expr)?
000AD1r 2  C9 94          cmp #TOK_ABS
000AD3r 2  D0 13          bne @NotAbs
000AD5r 2  20 rr rr       jsr BasAdvTxtPtr
000AD8r 2  A9 28          lda #CH_LPAREN
000ADAr 2  20 rr rr       jsr BasExpectChar
000ADDr 2  20 rr rr       jsr BasExpr
000AE0r 2  A9 29          lda #CH_RPAREN
000AE2r 2  20 rr rr       jsr BasExpectChar
000AE5r 2  4C rr rr       jmp BasMathAbs
000AE8r 2               @NotAbs:
000AE8r 2               
000AE8r 2                 ; RND(expr)?
000AE8r 2  C9 95          cmp #TOK_RND
000AEAr 2  D0 50          bne @NotRnd
000AECr 2  20 rr rr       jsr BasAdvTxtPtr
000AEFr 2  A9 28          lda #CH_LPAREN
000AF1r 2  20 rr rr       jsr BasExpectChar
000AF4r 2  20 rr rr       jsr BasExpr
000AF7r 2  A9 29          lda #CH_RPAREN
000AF9r 2  20 rr rr       jsr BasExpectChar
000AFCr 2                 ; Save modulus (ACC) and generate random number
000AFCr 2  A5 0A          lda BAS_ACC
000AFEr 2  48             pha
000AFFr 2  A5 0B          lda BAS_ACC + 1
000B01r 2  48             pha
000B02r 2                 ; Galois LFSR step
000B02r 2  A5 18          lda BAS_RNDSEED
000B04r 2  0A             asl
000B05r 2  26 19          rol BAS_RNDSEED + 1
000B07r 2  90 02          bcc @RndNoTap
000B09r 2  49 2D          eor #$2D                      ; Tap polynomial
000B0Br 2               @RndNoTap:
000B0Br 2  85 18          sta BAS_RNDSEED
000B0Dr 2                 ; Use seed as raw random value
000B0Dr 2  A5 18          lda BAS_RNDSEED
000B0Fr 2  85 0C          sta BAS_AUX
000B11r 2  A5 19          lda BAS_RNDSEED + 1
000B13r 2                 ; Make positive
000B13r 2  29 7F          and #$7F
000B15r 2  85 0D          sta BAS_AUX + 1
000B17r 2                 ; Restore modulus
000B17r 2  68             pla
000B18r 2  85 0B          sta BAS_ACC + 1
000B1Ar 2  68             pla
000B1Br 2  85 0A          sta BAS_ACC
000B1Dr 2                 ; If modulus <= 0, just return raw number
000B1Dr 2  A5 0A          lda BAS_ACC
000B1Fr 2  05 0B          ora BAS_ACC + 1
000B21r 2  F0 10          beq @RndRaw
000B23r 2  A5 0B          lda BAS_ACC + 1
000B25r 2  30 0C          bmi @RndRaw
000B27r 2                 ; ACC = AUX MOD ACC
000B27r 2  20 rr rr       jsr BasMathDiv
000B2Ar 2  A5 1E          lda BAS_SCRATCH2
000B2Cr 2  85 0A          sta BAS_ACC
000B2Er 2  A5 1F          lda BAS_SCRATCH2 + 1
000B30r 2  85 0B          sta BAS_ACC + 1
000B32r 2  60             rts
000B33r 2               @RndRaw:
000B33r 2  A5 0C          lda BAS_AUX
000B35r 2  85 0A          sta BAS_ACC
000B37r 2  A5 0D          lda BAS_AUX + 1
000B39r 2  85 0B          sta BAS_ACC + 1
000B3Br 2  60             rts
000B3Cr 2               @NotRnd:
000B3Cr 2               
000B3Cr 2                 ; JOY(n) — read joystick port
000B3Cr 2  C9 A6          cmp #TOK_JOY
000B3Er 2  D0 23          bne @NotJoy
