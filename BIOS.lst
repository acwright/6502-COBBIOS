00086Cr 2               ; ============================================================================
00086Cr 2               ; MonCmdD — Disassemble 65C02 instructions
00086Cr 2               ; Syntax: D [addr] [addr]
00086Cr 2               ; Default: 20 lines. Remembers position for continuation.
00086Cr 2               ; ============================================================================
00086Cr 2               
00086Cr 2               MonCmdD:
00086Cr 2  20 rr rr       jsr MonSkipSpaces
00086Fr 2  20 rr rr       jsr MonParseHex4
000872r 2  90 2A          bcc @UseDefault
000874r 2                 ; Got first address
000874r 2  A5 2E          lda MON_ADDR
000876r 2  85 32          sta MON_TMP
000878r 2  A5 2F          lda MON_ADDR+1
00087Ar 2  85 33          sta MON_TMP+1
00087Cr 2  20 rr rr       jsr MonSkipSpaces
00087Fr 2  20 rr rr       jsr MonParseHex4
000882r 2  90 12          bcc @StartOnly
000884r 2                 ; Got end address
000884r 2  A5 2E          lda MON_ADDR
000886r 2  85 30          sta MON_END
000888r 2  A5 2F          lda MON_ADDR+1
00088Ar 2  85 31          sta MON_END+1
00088Cr 2  A5 32          lda MON_TMP
00088Er 2  85 2E          sta MON_ADDR
000890r 2  A5 33          lda MON_TMP+1
000892r 2  85 2F          sta MON_ADDR+1
000894r 2  80 15          bra @DisRange
000896r 2               @StartOnly:
000896r 2  A5 32          lda MON_TMP
000898r 2  85 2E          sta MON_ADDR
00089Ar 2  A5 33          lda MON_TMP+1
00089Cr 2  85 2F          sta MON_ADDR+1
00089Er 2               @UseDefault:
00089Er 2                 ; Disassemble 20 lines
00089Er 2  A2 14          ldx #20
0008A0r 2               @DisCountLoop:
0008A0r 2  DA             phx
0008A1r 2  20 rr rr       jsr DisOneLine
0008A4r 2  FA             plx
0008A5r 2  B0 17          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
0008A7r 2  CA             dex
0008A8r 2  D0 F6          bne @DisCountLoop
0008AAr 2  60             rts
0008ABr 2               @DisRange:
0008ABr 2  20 rr rr       jsr DisOneLine
