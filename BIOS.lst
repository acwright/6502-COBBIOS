00075Cr 2  A5 0B          lda BAS_ACC + 1
00075Er 2  48             pha
00075Fr 2  20 rr rr       jsr BasExprAnd
000762r 2                 ; Pop left operand into AUX
000762r 2  68             pla
000763r 2  85 0D          sta BAS_AUX + 1
000765r 2  68             pla
000766r 2  85 0C          sta BAS_AUX
000768r 2                 ; OR: result = (AUX != 0) || (ACC != 0) ? 1 : 0
000768r 2  A5 0C          lda BAS_AUX
00076Ar 2  05 0D          ora BAS_AUX + 1
00076Cr 2  F0 04          beq @OrRight
00076Er 2  A9 01          lda #$01
000770r 2  80 0C          bra @OrStore
000772r 2               @OrRight:
000772r 2  A5 0A          lda BAS_ACC
000774r 2  05 0B          ora BAS_ACC + 1
