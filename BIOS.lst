00297Br 2  4C rr rr             jmp     RtcWriteNVRAM
00297Er 2               
00297Er 2               ; WAIT addr, mask
00297Er 2               BasCmdWait:
00297Er 2  20 rr rr             jsr     EvalAddrU16
002981r 2  A5 12                lda     FAC+4
002983r 2  85 3A                sta     BAS_TMP1
002985r 2  A5 11                lda     FAC+3
002987r 2  85 3B                sta     BAS_TMP1+1
002989r 2  20 rr rr             jsr     ChkCom
00298Cr 2  20 rr rr             jsr     GetByt                  ; X = mask
00298Fr 2  86 3C                stx     BAS_TMP2
002991r 2               @poll:
002991r 2  20 rr rr             jsr     BasCheckBreak
002994r 2  A0 00                ldy     #0
002996r 2  B1 3A                lda     (BAS_TMP1),y
002998r 2  25 3C                and     BAS_TMP2
00299Ar 2  F0 F5                beq     @poll
00299Cr 2  60                   rts
00299Dr 2               
00299Dr 2               ; PAUSE n (centiseconds)
00299Dr 2               BasCmdPause:
00299Dr 2  20 rr rr             jsr     EvalU16
