00141Fr 2  20 rr rr       jsr BasSkipSpaces
001422r 2  20 rr rr       jsr BasGetTokChar
001425r 2  C9 3A          cmp #CH_COLON
001427r 2  D0 03          bne :+
001429r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ':'
00142Cr 2               : ; Set flag so run loop preserves TXTPTR
00142Cr 2  A5 17          lda BAS_FLAGS
00142Er 2  09 04          ora #BAS_FLAG_TXTSET
001430r 2  85 17          sta BAS_FLAGS
001432r 2                 ; Invalidate saved CURLINE so run loop always detects the change
001432r 2  A9 FF          lda #$FF
001434r 2  85 14          sta BAS_VARPTR
001436r 2  85 15          sta BAS_VARPTR + 1
001438r 2  60             rts
001439r 2               
001439r 2               @NextDone:
001439r 2                 ; Loop complete — remove this FOR entry from stack
001439r 2  86 1B          stx BAS_FORSP                  ; Pop down to this entry (removes it)
00143Br 2  60             rts
00143Cr 2               
00143Cr 2               @NextNoFor:
00143Cr 2               @NextErr:
00143Cr 2  A9 05          lda #ERR_NEXT_NO_FOR
00143Er 2  4C rr rr       jmp BasError
001441r 2               
001441r 2               ; --- END ---
001441r 2               BasCmdEnd:
001441r 2  64 17          stz BAS_FLAGS                  ; Clear run flag
001443r 2  60             rts                            ; Returns to BasRunLoop which checks flags
001444r 2               
001444r 2               ; --- SYS ---
001444r 2               ; SYS <address> — Call machine code at 16-bit address, RTS returns to BASIC
001444r 2               BasCmdSys:
001444r 2  20 rr rr       jsr BasExpr                    ; Evaluate address expression → BAS_ACC
001447r 2                 ; Use BAS_TMP2 as the indirect jump target
001447r 2  A5 0A          lda BAS_ACC
001449r 2  85 10          sta BAS_TMP2
00144Br 2  A5 0B          lda BAS_ACC + 1
00144Dr 2  85 11          sta BAS_TMP2 + 1
00144Fr 2  6C 10 00       jmp (BAS_TMP2)                 ; JSR-like: callee RTSes back to caller
001452r 2               
001452r 2               ; --- LOAD ---
001452r 2               ; LOAD "filename" — Load from CF filesystem
001452r 2               ; LOAD (no arg)   — Load via serial ASCII transfer
001452r 2               BasCmdLoad:
001452r 2  20 rr rr       jsr BasSkipSpaces
001455r 2  20 rr rr       jsr BasGetTokChar
001458r 2  C9 22          cmp #CH_QUOTE
00145Ar 2  F0 18          beq @LoadCF
00145Cr 2               
00145Cr 2                 ; No filename — serial ASCII load
00145Cr 2  AD 0D 03       lda HW_PRESENT
00145Fr 2  29 10          and #HW_SC
001461r 2  F0 0E          beq @LoadNoDev
001463r 2  20 rr rr       jsr AsciiLoad
001466r 2  B0 64          bcs @LoadErr
001468r 2                 ; Update BAS_PRGEND from XFER_PTR (points past last byte written)
001468r 2  A5 2A          lda XFER_PTR
00146Ar 2  85 12          sta BAS_PRGEND
00146Cr 2  A5 2B          lda XFER_PTR + 1
00146Er 2  85 13          sta BAS_PRGEND + 1
001470r 2  60             rts
001471r 2               
001471r 2               @LoadNoDev:
001471r 2  4C rr rr       jmp BasPrintNoDevice
001474r 2               
001474r 2               @LoadCF:
001474r 2  AD 0D 03       lda HW_PRESENT
001477r 2  29 08          and #HW_CF
001479r 2  F0 F6          beq @LoadNoDev
00147Br 2                 ; Parse quoted filename into STR_PTR for FsLoadFile
00147Br 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00147Er 2                 ; Point STR_PTR at current position in tokenized text
00147Er 2  A5 04          lda BAS_TXTPTR
001480r 2  85 02          sta STR_PTR
001482r 2  A5 05          lda BAS_TXTPTR + 1
001484r 2  85 03          sta STR_PTR + 1
001486r 2                 ; Advance TXTPTR past the filename to closing quote
001486r 2               @LoadScanName:
001486r 2  20 rr rr       jsr BasGetTokChar
001489r 2  F0 12          beq @LoadNameDone              ; End of line (unterminated — use what we have)
00148Br 2  C9 22          cmp #CH_QUOTE
00148Dr 2  F0 05          beq @LoadNameEnd
00148Fr 2  20 rr rr       jsr BasAdvTxtPtr
001492r 2  80 F2          bra @LoadScanName
001494r 2               @LoadNameEnd:
001494r 2                 ; Null-terminate the filename in the token buffer (overwrite closing quote)
001494r 2  A0 00          ldy #$00
001496r 2  A9 00          lda #$00
001498r 2  91 04          sta (BAS_TXTPTR),y
00149Ar 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
00149Dr 2               @LoadNameDone:
00149Dr 2                 ; Call filesystem load
00149Dr 2  20 rr rr       jsr FsLoadFile
0014A0r 2  B0 2A          bcs @LoadErr
0014A2r 2                 ; Walk next-line pointer chain to find true BAS_PRGEND
0014A2r 2                 ; (file may contain machine code after the BASIC program end sentinel)
0014A2r 2  A9 00          lda #<BAS_PRG_START
0014A4r 2  85 0E          sta BAS_TMP1
0014A6r 2  A9 08          lda #>BAS_PRG_START
0014A8r 2  85 0F          sta BAS_TMP1 + 1
0014AAr 2               @LoadWalkChain:
0014AAr 2  A0 00          ldy #LINE_NEXT
0014ACr 2  B1 0E          lda (BAS_TMP1),y               ; lo byte of next-line pointer
0014AEr 2  85 10          sta BAS_TMP2
0014B0r 2  C8             iny
0014B1r 2  B1 0E          lda (BAS_TMP1),y               ; hi byte of next-line pointer
0014B3r 2  85 11          sta BAS_TMP2 + 1
0014B5r 2  05 10          ora BAS_TMP2                   ; lo | hi — zero means end sentinel
0014B7r 2  F0 0A          beq @LoadChainEnd
0014B9r 2                 ; Advance to next line
0014B9r 2  A5 10          lda BAS_TMP2
0014BBr 2  85 0E          sta BAS_TMP1
0014BDr 2  A5 11          lda BAS_TMP2 + 1
0014BFr 2  85 0F          sta BAS_TMP1 + 1
0014C1r 2  80 E7          bra @LoadWalkChain
0014C3r 2               @LoadChainEnd:
0014C3r 2                 ; BAS_TMP1 points to the end sentinel — PRGEND = sentinel address
0014C3r 2  A5 0E          lda BAS_TMP1
0014C5r 2  85 12          sta BAS_PRGEND
0014C7r 2  A5 0F          lda BAS_TMP1 + 1
0014C9r 2  85 13          sta BAS_PRGEND + 1
0014CBr 2  60             rts
0014CCr 2               
0014CCr 2               @LoadErr:
0014CCr 2  A9 rr          lda #<BasStrLoadErr
0014CEr 2  85 0E          sta BAS_TMP1
0014D0r 2  A9 rr          lda #>BasStrLoadErr
0014D2r 2  85 0F          sta BAS_TMP1 + 1
0014D4r 2  20 rr rr       jsr BasPrintStr
0014D7r 2  60             rts
0014D8r 2               
0014D8r 2               ; --- SAVE ---
0014D8r 2               ; SAVE "filename" — Save to CF filesystem
0014D8r 2               ; SAVE (no arg)   — Save via serial ASCII transfer
0014D8r 2               BasCmdSave:
0014D8r 2  20 rr rr       jsr BasSkipSpaces
0014DBr 2  20 rr rr       jsr BasGetTokChar
0014DEr 2  C9 22          cmp #CH_QUOTE
0014E0r 2  F0 0E          beq @SaveCF
0014E2r 2               
0014E2r 2                 ; No filename — serial ASCII save
0014E2r 2  AD 0D 03       lda HW_PRESENT
0014E5r 2  29 10          and #HW_SC
0014E7r 2  F0 04          beq @SaveNoDev
0014E9r 2  20 rr rr       jsr AsciiSave
0014ECr 2  60             rts
0014EDr 2               
0014EDr 2               @SaveNoDev:
0014EDr 2  4C rr rr       jmp BasPrintNoDevice
0014F0r 2               
0014F0r 2               @SaveCF:
0014F0r 2  AD 0D 03       lda HW_PRESENT
0014F3r 2  29 08          and #HW_CF
0014F5r 2  F0 F6          beq @SaveNoDev
0014F7r 2                 ; Parse quoted filename into STR_PTR for FsSaveFile
0014F7r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
0014FAr 2  A5 04          lda BAS_TXTPTR
0014FCr 2  85 02          sta STR_PTR
0014FEr 2  A5 05          lda BAS_TXTPTR + 1
001500r 2  85 03          sta STR_PTR + 1
001502r 2                 ; Advance TXTPTR past the filename to closing quote
001502r 2               @SaveScanName:
001502r 2  20 rr rr       jsr BasGetTokChar
001505r 2  F0 12          beq @SaveNameDone
001507r 2  C9 22          cmp #CH_QUOTE
001509r 2  F0 05          beq @SaveNameEnd
00150Br 2  20 rr rr       jsr BasAdvTxtPtr
00150Er 2  80 F2          bra @SaveScanName
001510r 2               @SaveNameEnd:
001510r 2  A0 00          ldy #$00
001512r 2  A9 00          lda #$00
001514r 2  91 04          sta (BAS_TXTPTR),y
001516r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
001519r 2               @SaveNameDone:
001519r 2                 ; Calculate file size = BAS_PRGEND - PROGRAM_START
001519r 2  A5 12          lda BAS_PRGEND
00151Br 2  38             sec
00151Cr 2  E9 00          sbc #<PROGRAM_START
00151Er 2  8D 4A 03       sta FS_FILE_SIZE
001521r 2  A5 13          lda BAS_PRGEND + 1
001523r 2  E9 08          sbc #>PROGRAM_START
001525r 2  8D 4B 03       sta FS_FILE_SIZE + 1
001528r 2                 ; Call filesystem save
001528r 2  20 rr rr       jsr FsSaveFile
00152Br 2  B0 01          bcs @SaveErr
00152Dr 2  60             rts
00152Er 2               
00152Er 2               @SaveErr:
00152Er 2  A9 rr          lda #<BasStrSaveErr
001530r 2  85 0E          sta BAS_TMP1
001532r 2  A9 rr          lda #>BasStrSaveErr
001534r 2  85 0F          sta BAS_TMP1 + 1
001536r 2  20 rr rr       jsr BasPrintStr
001539r 2  60             rts
00153Ar 2               
00153Ar 2               ; --- DIR ---
00153Ar 2               ; DIR — Print directory listing from CF
00153Ar 2               BasCmdDir:
00153Ar 2  AD 0D 03       lda HW_PRESENT
00153Dr 2  29 08          and #HW_CF
00153Fr 2  D0 03          bne @DirHasCF
001541r 2  4C rr rr       jmp BasPrintNoDevice
001544r 2               @DirHasCF:
001544r 2  20 rr rr       jsr FsDirectory
001547r 2  60             rts
001548r 2               
001548r 2               ; --- DEL ---
001548r 2               ; DEL "filename" — Delete a file from CF
001548r 2               BasCmdDel:
001548r 2  AD 0D 03       lda HW_PRESENT
00154Br 2  29 08          and #HW_CF
00154Dr 2  D0 03          bne @DelHasCF
00154Fr 2  4C rr rr       jmp BasPrintNoDevice
001552r 2               @DelHasCF:
001552r 2  20 rr rr       jsr BasSkipSpaces
001555r 2  20 rr rr       jsr BasGetTokChar
001558r 2  C9 22          cmp #CH_QUOTE
00155Ar 2  D0 28          bne @DelErr
00155Cr 2               
00155Cr 2                 ; Parse quoted filename into STR_PTR for FsDeleteFile
00155Cr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00155Fr 2  A5 04          lda BAS_TXTPTR
001561r 2  85 02          sta STR_PTR
001563r 2  A5 05          lda BAS_TXTPTR + 1
001565r 2  85 03          sta STR_PTR + 1
001567r 2                 ; Advance TXTPTR past the filename to closing quote
001567r 2               @DelScanName:
001567r 2  20 rr rr       jsr BasGetTokChar
00156Ar 2  F0 12          beq @DelNameDone
00156Cr 2  C9 22          cmp #CH_QUOTE
00156Er 2  F0 05          beq @DelNameEnd
001570r 2  20 rr rr       jsr BasAdvTxtPtr
001573r 2  80 F2          bra @DelScanName
001575r 2               @DelNameEnd:
001575r 2  A0 00          ldy #$00
001577r 2  A9 00          lda #$00
001579r 2  91 04          sta (BAS_TXTPTR),y
00157Br 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
00157Er 2               @DelNameDone:
00157Er 2                 ; Call filesystem delete
00157Er 2  20 rr rr       jsr FsDeleteFile
001581r 2  B0 01          bcs @DelErr
001583r 2  60             rts
001584r 2               
001584r 2               @DelErr:
001584r 2  A9 rr          lda #<BasStrDelErr
001586r 2  85 0E          sta BAS_TMP1
001588r 2  A9 rr          lda #>BasStrDelErr
00158Ar 2  85 0F          sta BAS_TMP1 + 1
00158Cr 2  20 rr rr       jsr BasPrintStr
00158Fr 2  60             rts
001590r 2               
001590r 2               ; --- CLS ---
001590r 2               BasCmdCls:
001590r 2  20 rr rr       jsr VideoClear
001593r 2  60             rts
001594r 2               
001594r 2               ; --- LOCATE row, col ---
001594r 2               BasCmdLocate:
001594r 2  20 rr rr       jsr BasExpr                    ; row -> BAS_ACC
001597r 2  A5 0A          lda BAS_ACC
001599r 2  85 21          sta BAS_TEMP                   ; save row
00159Br 2  20 rr rr       jsr BasSkipSpaces
00159Er 2  A9 2C          lda #CH_COMMA
0015A0r 2  20 rr rr       jsr BasExpectChar
0015A3r 2  20 rr rr       jsr BasExpr                    ; col -> BAS_ACC
0015A6r 2  A5 0A          lda BAS_ACC
0015A8r 2  AA             tax                            ; X = col
0015A9r 2  A4 21          ldy BAS_TEMP                   ; Y = row
0015ABr 2  20 rr rr       jsr VideoSetCursor
0015AEr 2  60             rts
0015AFr 2               
0015AFr 2               ; --- COLOR fg, bg ---
0015AFr 2               BasCmdColor:
0015AFr 2  20 rr rr       jsr BasExpr                    ; fg -> BAS_ACC (0-15)
0015B2r 2  A5 0A          lda BAS_ACC
0015B4r 2  29 0F          and #$0F
0015B6r 2  0A             asl a
0015B7r 2  0A             asl a
0015B8r 2  0A             asl a
0015B9r 2  0A             asl a                          ; shift to high nibble
0015BAr 2  85 21          sta BAS_TEMP
0015BCr 2  20 rr rr       jsr BasSkipSpaces
0015BFr 2  A9 2C          lda #CH_COMMA
0015C1r 2  20 rr rr       jsr BasExpectChar
0015C4r 2  20 rr rr       jsr BasExpr                    ; bg -> BAS_ACC (0-15)
0015C7r 2  A5 0A          lda BAS_ACC
0015C9r 2  29 0F          and #$0F
0015CBr 2  05 21          ora BAS_TEMP                   ; combine fg|bg
0015CDr 2  20 rr rr       jsr VideoSetColor
0015D0r 2  60             rts
0015D1r 2               
0015D1r 2               ; --- SOUND voice, freq, dur ---
0015D1r 2               ; freq is in Hz; converted to SID register via: reg = Hz*16 + Hz - Hz/4
0015D1r 2               ; Approximation of Hz * 2^24 / 1000000 ≈ Hz * 16.75 (0.16% error)
0015D1r 2               BasCmdSound:
0015D1r 2  AD 0D 03       lda HW_PRESENT
0015D4r 2  29 40          and #HW_SID
0015D6r 2  D0 01          bne @SoundStart
0015D8r 2  60             rts
0015D9r 2               @SoundStart:
0015D9r 2  20 rr rr       jsr BasExpr                    ; voice (1-3) -> BAS_ACC
0015DCr 2  A5 0A          lda BAS_ACC
0015DEr 2  3A             dec a                          ; convert to 0-indexed
0015DFr 2  85 21          sta BAS_TEMP                   ; save voice
0015E1r 2  20 rr rr       jsr BasSkipSpaces
0015E4r 2  A9 2C          lda #CH_COMMA
0015E6r 2  20 rr rr       jsr BasExpectChar
0015E9r 2  20 rr rr       jsr BasExpr                    ; freq (Hz) -> BAS_ACC
0015ECr 2                 ; --- Convert Hz to SID register value ---
0015ECr 2  A5 0A          lda BAS_ACC                    ; save Hz in BAS_SCRATCH
0015EEr 2  85 1C          sta BAS_SCRATCH
0015F0r 2  A5 0B          lda BAS_ACC + 1
0015F2r 2  85 1D          sta BAS_SCRATCH + 1
0015F4r 2  06 0A          asl BAS_ACC                    ; BAS_ACC = Hz << 4 (multiply by 16)
0015F6r 2  26 0B          rol BAS_ACC + 1
0015F8r 2  06 0A          asl BAS_ACC
0015FAr 2  26 0B          rol BAS_ACC + 1
0015FCr 2  06 0A          asl BAS_ACC
0015FEr 2  26 0B          rol BAS_ACC + 1
001600r 2  06 0A          asl BAS_ACC
001602r 2  26 0B          rol BAS_ACC + 1
001604r 2  18             clc                            ; BAS_ACC += Hz (now Hz * 17)
001605r 2  A5 0A          lda BAS_ACC
001607r 2  65 1C          adc BAS_SCRATCH
001609r 2  85 0A          sta BAS_ACC
00160Br 2  A5 0B          lda BAS_ACC + 1
00160Dr 2  65 1D          adc BAS_SCRATCH + 1
00160Fr 2  85 0B          sta BAS_ACC + 1
001611r 2  46 1D          lsr BAS_SCRATCH + 1            ; BAS_SCRATCH = Hz / 4
001613r 2  66 1C          ror BAS_SCRATCH
001615r 2  46 1D          lsr BAS_SCRATCH + 1
001617r 2  66 1C          ror BAS_SCRATCH
001619r 2  38             sec                            ; BAS_ACC -= Hz/4 (now Hz * 16.75)
00161Ar 2  A5 0A          lda BAS_ACC
00161Cr 2  E5 1C          sbc BAS_SCRATCH
00161Er 2  85 0A          sta BAS_ACC
001620r 2  A5 0B          lda BAS_ACC + 1
001622r 2  E5 1D          sbc BAS_SCRATCH + 1
001624r 2  85 0B          sta BAS_ACC + 1
001626r 2                 ; --- SID register value now in BAS_ACC ---
001626r 2  A5 0B          lda BAS_ACC + 1
001628r 2  48             pha                            ; save regHi on stack
001629r 2  A5 0A          lda BAS_ACC
00162Br 2  48             pha                            ; save regLo on stack
00162Cr 2  20 rr rr       jsr BasSkipSpaces
00162Fr 2  A9 2C          lda #CH_COMMA
001631r 2  20 rr rr       jsr BasExpectChar
001634r 2  20 rr rr       jsr BasExpr                    ; dur (centiseconds) -> BAS_ACC
001637r 2                 ; BAS_ACC holds dur; stack holds freq; BAS_TEMP holds voice
001637r 2  68             pla                            ; freqLo
001638r 2  AA             tax                            ; X = freqLo
001639r 2  68             pla                            ; freqHi
00163Ar 2  A8             tay                            ; Y = freqHi
00163Br 2  A5 21          lda BAS_TEMP                   ; A = voice (0-indexed)
00163Dr 2  20 rr rr       jsr SidPlayNote
001640r 2  A5 0A          lda BAS_ACC                    ; A = dur_lo (BAS_ACC not changed by SidPlayNote)
001642r 2  A6 0B          ldx BAS_ACC + 1                ; X = dur_hi
001644r 2  20 rr rr       jsr SysDelay
001647r 2  20 rr rr       jsr SidSilence
00164Ar 2  60             rts
00164Br 2               
00164Br 2               ; --- VOL n ---
00164Br 2               BasCmdVol:
00164Br 2  AD 0D 03       lda HW_PRESENT
00164Er 2  29 40          and #HW_SID
001650r 2  D0 01          bne @VolStart
001652r 2  60             rts
001653r 2               @VolStart:
001653r 2  20 rr rr       jsr BasExpr
001656r 2  A5 0A          lda BAS_ACC
001658r 2  20 rr rr       jsr SidSetVolume
00165Br 2  60             rts
00165Cr 2               
00165Cr 2               ; BasPrint2Digit — Print A as a 2-digit decimal with leading zero
00165Cr 2               ; Input: A = value 0-99
00165Cr 2               ; Modifies: A, X, Flags
00165Cr 2               BasPrint2Digit:
00165Cr 2  A2 00          ldx #0
00165Er 2               @P2DLoop:
00165Er 2  C9 0A          cmp #10
001660r 2  90 05          bcc @P2DDone
001662r 2  E9 0A          sbc #10                        ; carry already set from cmp
001664r 2  E8             inx
001665r 2  80 F7          bra @P2DLoop
001667r 2               @P2DDone:
001667r 2  48             pha                            ; save units digit
001668r 2  8A             txa
001669r 2  09 30          ora #'0'                       ; tens digit as ASCII
00166Br 2  20 rr rr       jsr Chrout
00166Er 2  68             pla
00166Fr 2  09 30          ora #'0'                       ; units digit as ASCII
001671r 2  20 rr rr       jsr Chrout
001674r 2  60             rts
001675r 2               
001675r 2               ; --- TIME ---
001675r 2               BasCmdTime:
001675r 2  AD 0D 03       lda HW_PRESENT
001678r 2  29 04          and #HW_RTC
00167Ar 2  D0 03          bne @TimeHasRTC
00167Cr 2  4C rr rr       jmp BasPrintNoDevice
00167Fr 2               @TimeHasRTC:
00167Fr 2  20 rr rr       jsr RtcReadTime                ; A=hours, X=minutes, Y=seconds
001682r 2  5A             phy                            ; save seconds
001683r 2  DA             phx                            ; save minutes
001684r 2  20 rr rr       jsr BasPrint2Digit             ; print hours
001687r 2  A9 3A          lda #':'
001689r 2  20 rr rr       jsr Chrout
00168Cr 2  68             pla                            ; restore minutes
00168Dr 2  20 rr rr       jsr BasPrint2Digit
001690r 2  A9 3A          lda #':'
001692r 2  20 rr rr       jsr Chrout
001695r 2  68             pla                            ; restore seconds
001696r 2  20 rr rr       jsr BasPrint2Digit
001699r 2  20 rr rr       jsr BasPrintCRLF
00169Cr 2  60             rts
00169Dr 2               
00169Dr 2               ; --- DATE ---
00169Dr 2               BasCmdDate:
00169Dr 2  AD 0D 03       lda HW_PRESENT
0016A0r 2  29 04          and #HW_RTC
0016A2r 2  D0 03          bne @DateHasRTC
0016A4r 2  4C rr rr       jmp BasPrintNoDevice
0016A7r 2               @DateHasRTC:
0016A7r 2  20 rr rr       jsr RtcReadDate                ; A=day, X=month, Y=year; RTC_BUF_CENT=century
0016AAr 2  48             pha                            ; save day
0016ABr 2  DA             phx                            ; save month
0016ACr 2  5A             phy                            ; save year (pushed last, popped first)
0016ADr 2  AD 0B 03       lda RTC_BUF_CENT
0016B0r 2  20 rr rr       jsr BasPrint2Digit             ; print century
0016B3r 2  68             pla                            ; restore year
0016B4r 2  20 rr rr       jsr BasPrint2Digit             ; print year (CCYY together)
0016B7r 2  A9 2D          lda #'-'
0016B9r 2  20 rr rr       jsr Chrout
0016BCr 2  68             pla                            ; restore month
0016BDr 2  20 rr rr       jsr BasPrint2Digit
0016C0r 2  A9 2D          lda #'-'
0016C2r 2  20 rr rr       jsr Chrout
0016C5r 2  68             pla                            ; restore day
0016C6r 2  20 rr rr       jsr BasPrint2Digit
0016C9r 2  20 rr rr       jsr BasPrintCRLF
0016CCr 2  60             rts
0016CDr 2               
0016CDr 2               ; --- WAIT addr, mask ---
0016CDr 2               BasCmdWait:
0016CDr 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
0016D0r 2  A5 0A          lda BAS_ACC
0016D2r 2  85 10          sta BAS_TMP2
0016D4r 2  A5 0B          lda BAS_ACC + 1
0016D6r 2  85 11          sta BAS_TMP2 + 1
0016D8r 2  20 rr rr       jsr BasSkipSpaces
0016DBr 2  A9 2C          lda #CH_COMMA
0016DDr 2  20 rr rr       jsr BasExpectChar
0016E0r 2  20 rr rr       jsr BasExpr                    ; mask -> BAS_ACC
0016E3r 2  A5 0A          lda BAS_ACC
0016E5r 2  85 21          sta BAS_TEMP
0016E7r 2               @WaitPoll:
0016E7r 2  20 rr rr       jsr BasCheckBreak              ; allow Ctrl+C to abort
0016EAr 2  A0 00          ldy #0
0016ECr 2  B1 10          lda (BAS_TMP2),y
0016EEr 2  25 21          and BAS_TEMP
0016F0r 2  F0 F5          beq @WaitPoll
0016F2r 2  60             rts
0016F3r 2               
0016F3r 2               ; --- PAUSE n ---
0016F3r 2               BasCmdPause:
0016F3r 2  20 rr rr       jsr BasExpr
0016F6r 2  A5 0A          lda BAS_ACC
0016F8r 2  A6 0B          ldx BAS_ACC + 1
0016FAr 2  20 rr rr       jsr SysDelay
0016FDr 2  60             rts
0016FEr 2               
0016FEr 2               ; --- BANK n ---
0016FEr 2               BasCmdBank:
0016FEr 2  AD 0D 03       lda HW_PRESENT
001701r 2  29 01          and #HW_RAM_L
001703r 2  D0 03          bne @BankHasRAM
001705r 2  4C rr rr       jmp BasPrintNoDevice
001708r 2               @BankHasRAM:
001708r 2  20 rr rr       jsr BasExpr
00170Br 2  A5 0A          lda BAS_ACC
00170Dr 2  8D FF 83       sta RAM_BANK_L
001710r 2  60             rts
001711r 2               
001711r 2               ; --- BRK ---
001711r 2               BasCmdBrk:
001711r 2  64 17          stz BAS_FLAGS                  ; Clear run flag
001713r 2  00             brk                            ; Trigger BRK → IRQ vector → Wozmon
001714r 2               
001714r 2               ; --- NEW ---
001714r 2               BasCmdNew:
001714r 2                 ; Set program end to program start (empty program)
001714r 2  A9 00          lda #<BAS_PRG_START
001716r 2  85 12          sta BAS_PRGEND
001718r 2  A9 08          lda #>BAS_PRG_START
00171Ar 2  85 13          sta BAS_PRGEND + 1
00171Cr 2                 ; Write end marker
00171Cr 2  A0 00          ldy #LINE_NEXT
00171Er 2  A9 00          lda #$00
001720r 2  91 12          sta (BAS_PRGEND),y
001722r 2  C8             iny
001723r 2  91 12          sta (BAS_PRGEND),y
001725r 2                 ; Clear variables
001725r 2  20 rr rr       jsr BasCmdClr
001728r 2  64 17          stz BAS_FLAGS
00172Ar 2  4C rr rr       jmp BasMainLoop
00172Dr 2               
00172Dr 2               ; --- LIST ---
00172Dr 2               BasCmdList:
00172Dr 2                 ; Start at beginning of program
00172Dr 2  A9 00          lda #<BAS_PRG_START
00172Fr 2  85 0E          sta BAS_TMP1
001731r 2  A9 08          lda #>BAS_PRG_START
001733r 2  85 0F          sta BAS_TMP1 + 1
001735r 2               
001735r 2               @ListLoop:
001735r 2                 ; Check if at end of program (TMP1 == PRGEND)
001735r 2  A5 0E          lda BAS_TMP1
001737r 2  C5 12          cmp BAS_PRGEND
001739r 2  D0 06          bne @ListNotEnd
00173Br 2  A5 0F          lda BAS_TMP1 + 1
00173Dr 2  C5 13          cmp BAS_PRGEND + 1
00173Fr 2  F0 42          beq @ListDone
001741r 2               @ListNotEnd:
001741r 2               
001741r 2                 ; Check for Ctrl+C break
