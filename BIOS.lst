001340r 2                 ; Build FOR stack entry (16 bytes per entry):
001340r 2                 ;  +0: var_offset (1)
001340r 2                 ;  +1: limit_lo (1)
001340r 2                 ;  +2: limit_hi (1)
001340r 2                 ;  +3: step_lo (1)
001340r 2                 ;  +4: step_hi (1)
001340r 2                 ;  +5: body_start_lo (1) — first line of loop body (next line after FOR)
001340r 2                 ;  +6: body_start_hi (1)
001340r 2                 ; +7..+15: unused padding
001340r 2               
