000748r 2  60 90 90 F0      .byte $60, $90, $90, $F0, $90, $90, $60, $00
00074Cr 2  90 90 60 00  
000750r 2                   ; Character $EA - Ω
000750r 2  00 70 88 88      .byte $00, $70, $88, $88, $50, $50, $D8, $00
000754r 2  50 50 D8 00  
000758r 2                   ; Character $EB - δ
000758r 2  60 80 40 20      .byte $60, $80, $40, $20, $70, $90, $60, $00
00075Cr 2  70 90 60 00  
000760r 2                   ; Character $EC - ∞
000760r 2  00 00 50 A8      .byte $00, $00, $50, $A8, $A8, $50, $00, $00
000764r 2  A8 50 00 00  
000768r 2                   ; Character $ED - φ
000768r 2  00 20 70 A8      .byte $00, $20, $70, $A8, $A8, $70, $20, $00
00076Cr 2  A8 70 20 00  
000770r 2                   ; Character $EE - ε
000770r 2  00 70 80 F0      .byte $00, $70, $80, $F0, $80, $70, $00, $00
000774r 2  80 70 00 00  
000778r 2                   ; Character $EF - ∩
000778r 2  00 60 90 90      .byte $00, $60, $90, $90, $90, $90, $00, $00
00077Cr 2  90 90 00 00  
000780r 2                   ; Character $F0 - ≡
000780r 2  00 F0 00 F0      .byte $00, $F0, $00, $F0, $00, $F0, $00, $00
000784r 2  00 F0 00 00  
000788r 2                   ; Character $F1 - ±
000788r 2  00 20 70 20      .byte $00, $20, $70, $20, $00, $70, $00, $00
00078Cr 2  00 70 00 00  
000790r 2                   ; Character $F2 - ≥
000790r 2  80 60 10 60      .byte $80, $60, $10, $60, $80, $00, $F0, $00
000794r 2  80 00 F0 00  
000798r 2                   ; Character $F3 - ≤
000798r 2  10 60 80 60      .byte $10, $60, $80, $60, $10, $00, $F0, $00
00079Cr 2  10 00 F0 00  
0007A0r 2                   ; Character $F4 - ⌠ (top half integral)
0007A0r 2  00 10 28 20      .byte $00, $10, $28, $20, $20, $20, $20, $20
0007A4r 2  20 20 20 20  
0007A8r 2                   ; Character $F5 - ⌡ (bottom half integral)
0007A8r 2  20 20 20 20      .byte $20, $20, $20, $20, $20, $A0, $40, $00
0007ACr 2  20 A0 40 00  
0007B0r 2                   ; Character $F6 - ÷
0007B0r 2  00 20 00 F8      .byte $00, $20, $00, $F8, $00, $20, $00, $00
0007B4r 2  00 20 00 00  
0007B8r 2                   ; Character $F7 - ≈
0007B8r 2  00 50 A0 00      .byte $00, $50, $A0, $00, $50, $A0, $00, $00
0007BCr 2  50 A0 00 00  
0007C0r 2                   ; Character $F8 - °
0007C0r 2  60 90 90 60      .byte $60, $90, $90, $60, $00, $00, $00, $00
0007C4r 2  00 00 00 00  
0007C8r 2                   ; Character $F9 - ∙
0007C8r 2  00 00 00 60      .byte $00, $00, $00, $60, $60, $00, $00, $00
0007CCr 2  60 00 00 00  
0007D0r 2                   ; Character $FA - · (middle dot)
0007D0r 2  00 00 00 40      .byte $00, $00, $00, $40, $00, $00, $00, $00
0007D4r 2  00 00 00 00  
0007D8r 2                   ; Character $FB - √
0007D8r 2  00 38 20 20      .byte $00, $38, $20, $20, $A0, $A0, $40, $00
0007DCr 2  A0 A0 40 00  
0007E0r 2                   ; Character $FC - ⁿ
0007E0r 2  A0 50 50 50      .byte $A0, $50, $50, $50, $00, $00, $00, $00
0007E4r 2  00 00 00 00  
0007E8r 2                   ; Character $FD - ²
0007E8r 2  C0 20 40 E0      .byte $C0, $20, $40, $E0, $00, $00, $00, $00
0007ECr 2  00 00 00 00  
0007F0r 2                   ; Character $FE - ■ (black square)
0007F0r 2  00 00 78 78      .byte $00, $00, $78, $78, $78, $78, $00, $00
0007F4r 2  78 78 00 00  
0007F8r 2                   ; Character $FF - nbsp (non-breaking space, displayed as blank)
0007F8r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $00, $00, $00
0007FCr 2  00 00 00 00  
000800r 2               
000800r 1               .segment "BASIC"
000000r 1               .include "BASIC.asm"
000000r 2               ; ***                         ***
000000r 2               ; ***   Integer BASIC v1.0    ***
000000r 2               ; ***     for 6502-BIOS       ***
000000r 2               ; ***   $C000-$E7FF (10240B)  ***
000000r 2               ; ***                         ***
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Zero Page — BASIC Interpreter Workspace ($04-$23)
000000r 2               ; ============================================================================
000000r 2               ; $00-$03 reserved by Kernal (READ_PTR, WRITE_PTR, STR_PTR)
000000r 2               
000000r 2               BAS_TXTPTR          := $04               ; $04-$05 - Current parse/exec pointer
000000r 2               BAS_CURLINE         := $06               ; $06-$07 - Pointer to current line start
000000r 2               BAS_LINENUM         := $08               ; $08-$09 - Current line number (16-bit)
000000r 2               BAS_ACC             := $0A               ; $0A-$0B - Expression accumulator (16-bit)
000000r 2               BAS_AUX             := $0C               ; $0C-$0D - Auxiliary register (right operand)
000000r 2               BAS_TMP1            := $0E               ; $0E-$0F - General-purpose temp / pointer
000000r 2               BAS_TMP2            := $10               ; $10-$11 - General-purpose temp / pointer
000000r 2               BAS_PRGEND          := $12               ; $12-$13 - First byte past end of program
000000r 2               BAS_VARPTR          := $14               ; $14-$15 - Variable address pointer
000000r 2               BAS_TOKIDX          := $16               ; $16     - Tokenizer index / scratch
000000r 2               BAS_FLAGS           := $17               ; $17     - Runtime flags
000000r 2               BAS_RNDSEED         := $18               ; $18-$19 - PRNG state (16-bit)
000000r 2               BAS_GOSUBSP         := $1A               ; $1A     - GOSUB stack pointer (byte index)
000000r 2               BAS_FORSP           := $1B               ; $1B     - FOR stack pointer (byte index)
000000r 2               BAS_SCRATCH         := $1C               ; $1C-$1D - Scratch / division workspace
000000r 2               BAS_SCRATCH2        := $1E               ; $1E-$1F - Scratch / division workspace
000000r 2               BAS_SIGN            := $20               ; $20     - Sign tracking for mul/div
000000r 2               BAS_TEMP            := $21               ; $21     - General temp byte
000000r 2               BAS_NUMTMP          := $22               ; $22-$23 - Number parsing accumulator
000000r 2               
000000r 2               ; BAS_FLAGS bit definitions
000000r 2               BAS_FLAG_RUN        = %00000001          ; Bit 0: program is running
000000r 2               BAS_FLAG_NOSEP      = %00000010          ; Bit 1: suppress CRLF after PRINT
000000r 2               BAS_FLAG_TXTSET     = %00000100          ; Bit 2: TXTPTR already set (NEXT loop-back)
000000r 2               BAS_FLAG_GOTO       = %00001000          ; Bit 3: GOTO/GOSUB executed (force re-enter run loop)
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; RAM Layout — USER_VARS ($0400-$07FF)
000000r 2               ; ============================================================================
000000r 2               
000000r 2               BAS_VARS            := $0400             ; $0400-$0433 - 26 vars A-Z (2 bytes each)
000000r 2               BAS_LINBUF          := $0434             ; $0434-$04FF - Input line buffer (204 bytes)
000000r 2               BAS_GOSUBSTK        := $0500             ; $0500-$057F - GOSUB stack (128 bytes, 32 levels)
000000r 2               BAS_FORSTK          := $0580             ; $0580-$05FF - FOR/NEXT stack (128 bytes, 8 levels)
000000r 2               BAS_TOKBUF          := $0600             ; $0600-$06FF - Tokenized line buffer (256 bytes)
000000r 2               BAS_STRBUF          := $0700             ; $0700-$07FF - Scratch / number-to-string (256 bytes)
000000r 2               
000000r 2               ; Derived constants
000000r 2               BAS_LINBUF_SIZE     = 200                ; Max input line length
000000r 2               BAS_GOSUBSTK_SIZE   = 128               ; GOSUB stack capacity
000000r 2               BAS_FORSTK_SIZE     = 128               ; FOR stack capacity
000000r 2               BAS_GOSUB_ENTRY     = 2                  ; Bytes per GOSUB entry (CURLINE)
000000r 2               BAS_FOR_ENTRY       = 16                 ; Bytes per FOR entry
000000r 2               BAS_GOSUB_MAX       = BAS_GOSUBSTK_SIZE / BAS_GOSUB_ENTRY  ; 64 levels
000000r 2               BAS_FOR_MAX         = BAS_FORSTK_SIZE / BAS_FOR_ENTRY       ; 8 levels
000000r 2               
000000r 2               ; Array support — stored in Kernal vars area ($035B+)
000000r 2               BAS_ARYDESC         := $035B             ; $035B-$038E - 26 × 2-byte array base pointers (0=not DIM'd)
000000r 2               BAS_ARYTOP          := $038F             ; $038F-$0390 - Bottom of array space (grows down from $8000)
000000r 2               
000000r 2               ; Program space
000000r 2               BAS_PRG_START       = PROGRAM_START      ; $0800 - Start of BASIC program storage
000000r 2               BAS_PRG_END         = $7FFF              ; Last usable byte for programs
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Program Line Format (in memory at $0800-$7FFF)
000000r 2               ; ============================================================================
000000r 2               ; Each stored line:
000000r 2               ;   [2 bytes] Next-line pointer (little-endian; $0000 = end of program)
000000r 2               ;   [2 bytes] Line number (little-endian; 0-65535)
000000r 2               ;   [N bytes] Tokenized payload
000000r 2               ;   [1 byte]  $00 terminator
000000r 2               ;
000000r 2               ; Offsets within a line:
000000r 2               LINE_NEXT           = 0                  ; Offset to next-line pointer
000000r 2               LINE_NUM            = 2                  ; Offset to line number
000000r 2               LINE_PAYLOAD        = 4                  ; Offset to tokenized data
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Token Definitions ($80+)
000000r 2               ; ============================================================================
000000r 2               ; Tokens >= $80 represent keywords; raw ASCII is stored as-is.
000000r 2               
000000r 2               ; Statement tokens
000000r 2               TOK_PRINT           = $80
000000r 2               TOK_INPUT           = $81
000000r 2               TOK_LET             = $82
000000r 2               TOK_GOTO            = $83
000000r 2               TOK_GOSUB           = $84
000000r 2               TOK_RETURN          = $85
000000r 2               TOK_IF              = $86
000000r 2               TOK_THEN            = $87
000000r 2               TOK_FOR             = $88
000000r 2               TOK_TO              = $89
000000r 2               TOK_STEP            = $8A
000000r 2               TOK_NEXT            = $8B
000000r 2               TOK_REM             = $8C
000000r 2               TOK_END             = $8D
000000r 2               TOK_LIST            = $8E
000000r 2               TOK_RUN             = $8F
000000r 2               TOK_NEW             = $90
000000r 2               TOK_CLR             = $91
000000r 2               TOK_PEEK            = $92
000000r 2               TOK_POKE            = $93
000000r 2               TOK_ABS             = $94
000000r 2               TOK_RND             = $95
000000r 2               TOK_NOT             = $96
000000r 2               TOK_AND             = $97
000000r 2               TOK_OR              = $98
000000r 2               TOK_MOD             = $99
000000r 2               
000000r 2               TOK_BRK             = $9D
000000r 2               TOK_SYS             = $9E
000000r 2               TOK_LOAD            = $9F
000000r 2               TOK_SAVE            = $A0
000000r 2               TOK_DIR             = $A1
000000r 2               TOK_DEL             = $A2
000000r 2               TOK_CLS             = $A3
000000r 2               TOK_LOCATE          = $A4
000000r 2               TOK_COLOR           = $A5
000000r 2               TOK_JOY             = $A6
000000r 2               TOK_SOUND           = $A7
000000r 2               TOK_VOL             = $A8
000000r 2               TOK_TIME            = $A9
000000r 2               TOK_DATE            = $AA
000000r 2               TOK_WAIT            = $AB
000000r 2               TOK_PAUSE           = $AC
000000r 2               TOK_BANK            = $AD
000000r 2               TOK_SGN             = $AE
000000r 2               TOK_CHR             = $AF
000000r 2               
000000r 2               ; New command/function tokens (Phase 1)
000000r 2               TOK_STOP            = $B0
000000r 2               TOK_CONT            = $B1
000000r 2               TOK_ON              = $B2
000000r 2               TOK_DATA            = $B3
000000r 2               TOK_READ            = $B4
000000r 2               TOK_RESTORE         = $B5
000000r 2               TOK_SQR             = $B6
000000r 2               TOK_MIN             = $B7
000000r 2               TOK_MAX             = $B8
000000r 2               TOK_POW             = $B9
000000r 2               TOK_INKEY           = $BA
000000r 2               TOK_TAB             = $BB
000000r 2               TOK_HEX             = $BC
000000r 2               TOK_ASC             = $BD
000000r 2               
000000r 2               ; Phase 2 tokens
000000r 2               TOK_FREE            = $BE
000000r 2               TOK_SETTIME         = $BF
000000r 2               TOK_SETDATE         = $C0
000000r 2               TOK_NVRAM           = $C1
000000r 2               TOK_MEM             = $C2
000000r 2               TOK_DIM             = $C3
000000r 2               
000000r 2               ; Multi-char operator tokens
000000r 2               TOK_GE              = $9A               ; >=
000000r 2               TOK_LE              = $9B               ; <=
000000r 2               TOK_NE              = $9C               ; <>
000000r 2               
000000r 2               ; ASCII characters used in parsing (for readability)
000000r 2               CH_CR               = $0D               ; Carriage return
000000r 2               CH_LF               = $0A               ; Line feed
000000r 2               CH_SPACE            = $20               ; Space
000000r 2               CH_QUOTE            = $22               ; Double-quote
000000r 2               CH_COMMA            = $2C               ; Comma
000000r 2               CH_MINUS            = $2D               ; Minus / dash
000000r 2               CH_COLON            = $3A               ; Colon (statement separator)
000000r 2               CH_SEMICOL          = $3B               ; Semicolon
000000r 2               CH_EQUALS           = $3D               ; Equals sign
000000r 2               CH_LPAREN           = $28               ; (
000000r 2               CH_RPAREN           = $29               ; )
000000r 2               CH_LESS             = $3C               ; <
000000r 2               CH_GREATER          = $3E               ; >
000000r 2               CH_PLUS             = $2B               ; +
000000r 2               CH_STAR             = $2A               ; *
000000r 2               CH_SLASH            = $2F               ; /
000000r 2               CH_BKSP             = $08               ; Backspace
000000r 2               CH_ESC              = $1B               ; Escape
000000r 2               CH_CTRLC            = $03               ; Ctrl+C (break)
000000r 2               
000000r 2               ; Error codes
000000r 2               ERR_SYNTAX          = 0
000000r 2               ERR_UNDEF_LINE      = 1
000000r 2               ERR_TYPE_MISMATCH   = 2
000000r 2               ERR_OUT_OF_MEM      = 3
000000r 2               ERR_RET_NO_GOSUB    = 4
000000r 2               ERR_NEXT_NO_FOR     = 5
000000r 2               ERR_DIV_ZERO        = 6
000000r 2               ERR_OVERFLOW        = 7
000000r 2               ERR_ILLEGAL_QTY     = 8
000000r 2               ERR_BREAK           = 9
000000r 2               ERR_OUT_OF_DATA     = 10
000000r 2               ERR_CANT_CONT       = 11
000000r 2               ERR_REDIM           = 12
000000r 2               ERR_BAD_SUBSCRIPT   = 13
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Entry Point
000000r 2               ; ============================================================================
000000r 2               
000000r 2               BasEntry:
000000r 2  4C rr rr       jmp BasColdStart               ; Jump to cold start initialization
000003r 2               
000003r 2               ; ============================================================================
000003r 2               ; Cold Start — Initialize interpreter and enter REPL
000003r 2               ; ============================================================================
000003r 2               
000003r 2               BasColdStart:
000003r 2                 ; --- Auto-detect a pre-loaded program at BAS_PRG_START ---
000003r 2                 ; A valid program has a next-line pointer whose high byte is in program
000003r 2                 ; space ($08-$7F).  If detected, walk the chain to find BAS_PRGEND and
000003r 2                 ; skip overwriting the sentinel.  Otherwise initialize fresh.
000003r 2  AD 01 08       lda BAS_PRG_START + 1          ; High byte of first next-line pointer
000006r 2  F0 4B          beq @NoPrg                     ; $00 → sentinel or below program space
000008r 2  C9 08          cmp #>BAS_PRG_START            ; Must be >= $08 (low bound of program space)
00000Ar 2  90 47          bcc @NoPrg
00000Cr 2  C9 80          cmp #$80                       ; Must be <  $80 (below I/O area)
00000Er 2  B0 43          bcs @NoPrg
000010r 2               
000010r 2                 ; Pointer looks valid — walk the chain to locate the end sentinel
000010r 2  A9 00          lda #<BAS_PRG_START
000012r 2  85 0E          sta BAS_TMP1
000014r 2  A9 08          lda #>BAS_PRG_START
000016r 2  85 0F          sta BAS_TMP1 + 1
000018r 2               
000018r 2               @WalkChain:
000018r 2  A0 00          ldy #LINE_NEXT
00001Ar 2  B1 0E          lda (BAS_TMP1),y               ; lo byte of next-line pointer
00001Cr 2  85 10          sta BAS_TMP2
00001Er 2  C8             iny
00001Fr 2  B1 0E          lda (BAS_TMP1),y               ; hi byte of next-line pointer
000021r 2  85 11          sta BAS_TMP2 + 1
000023r 2  05 10          ora BAS_TMP2                   ; lo | hi — zero means end sentinel
000025r 2  F0 22          beq @ChainEnd
000027r 2                 ; Validate: next ptr must be within program space
000027r 2  A5 11          lda BAS_TMP2 + 1
000029r 2  C9 08          cmp #>BAS_PRG_START
00002Br 2  90 26          bcc @NoPrg                     ; < $08 → corrupt
00002Dr 2  C9 80          cmp #$80
00002Fr 2  B0 22          bcs @NoPrg                     ; >= $80 → corrupt
000031r 2                 ; Validate: next ptr must be strictly greater than current (forward progress)
000031r 2  C5 0F          cmp BAS_TMP1 + 1
000033r 2  90 1E          bcc @NoPrg
000035r 2  D0 08          bne @DoAdvance
000037r 2  A5 10          lda BAS_TMP2
000039r 2  C5 0E          cmp BAS_TMP1
00003Br 2  90 16          bcc @NoPrg
00003Dr 2  F0 14          beq @NoPrg                     ; same address → zero-length loop → corrupt
00003Fr 2               @DoAdvance:
00003Fr 2  A5 10          lda BAS_TMP2
000041r 2  85 0E          sta BAS_TMP1
000043r 2  A5 11          lda BAS_TMP2 + 1
000045r 2  85 0F          sta BAS_TMP1 + 1
000047r 2  80 CF          bra @WalkChain
000049r 2               
000049r 2               @ChainEnd:
000049r 2                 ; BAS_TMP1 points to the end sentinel ($00 $00).
000049r 2                 ; PRGEND = sentinel address (matches @NoPrg convention).
000049r 2  A5 0E          lda BAS_TMP1
00004Br 2  85 12          sta BAS_PRGEND
00004Dr 2  A5 0F          lda BAS_TMP1 + 1
00004Fr 2  85 13          sta BAS_PRGEND + 1
000051r 2  80 10          bra @PrgDone
000053r 2               
000053r 2               @NoPrg:
000053r 2                 ; No valid program detected — initialize fresh
000053r 2  A9 00          lda #<BAS_PRG_START
000055r 2  85 12          sta BAS_PRGEND
000057r 2  A9 08          lda #>BAS_PRG_START
000059r 2  85 13          sta BAS_PRGEND + 1
00005Br 2  A9 00          lda #$00
00005Dr 2  8D 00 08       sta BAS_PRG_START
000060r 2  8D 01 08       sta BAS_PRG_START + 1
000063r 2               
000063r 2               @PrgDone:
000063r 2                 ; Clear variables and stacks
000063r 2  20 rr rr       jsr BasCmdClr
000066r 2               
000066r 2                 ; Seed PRNG with a nonzero value
000066r 2  A9 A5          lda #$A5
000068r 2  85 18          sta BAS_RNDSEED
00006Ar 2  A9 37          lda #$37
00006Cr 2  85 19          sta BAS_RNDSEED + 1
00006Er 2               
00006Er 2                 ; Print welcome banner
00006Er 2  A9 rr          lda #<BasStrWelcome
000070r 2  85 0E          sta BAS_TMP1
000072r 2  A9 rr          lda #>BasStrWelcome
000074r 2  85 0F          sta BAS_TMP1 + 1
000076r 2  20 rr rr       jsr BasPrintStr
000079r 2               
000079r 2                 ; Print free memory
000079r 2  20 rr rr       jsr BasPrintFree
00007Cr 2               
00007Cr 2                 ; Fall through to main REPL loop
00007Cr 2               
00007Cr 2               ; ============================================================================
00007Cr 2               ; Main REPL Loop
00007Cr 2               ; ============================================================================
00007Cr 2               
00007Cr 2               BasMainLoop:
00007Cr 2                 ; Reset flags for immediate mode
00007Cr 2  64 17          stz BAS_FLAGS
00007Er 2               
00007Er 2                 ; Print OK prompt
00007Er 2  A9 rr          lda #<BasStrOK
000080r 2  85 0E          sta BAS_TMP1
000082r 2  A9 rr          lda #>BasStrOK
000084r 2  85 0F          sta BAS_TMP1 + 1
000086r 2  20 rr rr       jsr BasPrintStr
000089r 2               
000089r 2                 ; Read a line of input
000089r 2  20 rr rr       jsr BasReadLine
00008Cr 2               
00008Cr 2                 ; Tokenize the input line
00008Cr 2  20 rr rr       jsr BasTokenize
00008Fr 2               
00008Fr 2                 ; Check if line has a line number (first 2 bytes of TOKBUF)
00008Fr 2  AD 00 06       lda BAS_TOKBUF
000092r 2  0D 01 06       ora BAS_TOKBUF + 1
000095r 2  F0 06          beq @Immediate                 ; No line number — execute immediately
000097r 2               
000097r 2                 ; Has line number — insert/replace in program
000097r 2  20 rr rr       jsr BasInsertLine
00009Ar 2  4C rr rr       jmp BasMainLoop
00009Dr 2               
00009Dr 2               @Immediate:
00009Dr 2                 ; Set TXTPTR to the tokenized payload (skip 2-byte line number slot)
00009Dr 2  A9 02          lda #<(BAS_TOKBUF + 2)
00009Fr 2  85 04          sta BAS_TXTPTR
0000A1r 2  A9 06          lda #>(BAS_TOKBUF + 2)
0000A3r 2  85 05          sta BAS_TXTPTR + 1
0000A5r 2               
0000A5r 2                 ; Execute the immediate line
0000A5r 2  20 rr rr       jsr BasExecLine
0000A8r 2  4C rr rr       jmp BasMainLoop
0000ABr 2               
0000ABr 2               ; ============================================================================
0000ABr 2               ; CLR — Clear all variables and reset stacks
0000ABr 2               ; ============================================================================
0000ABr 2               
0000ABr 2               BasCmdClr:
0000ABr 2                 ; Zero 26 variables (52 bytes at BAS_VARS)
0000ABr 2  A2 33          ldx #51
0000ADr 2  A9 00          lda #$00
0000AFr 2               @ClrLoop:
0000AFr 2  9D 00 04       sta BAS_VARS,x
0000B2r 2  CA             dex
0000B3r 2  10 FA          bpl @ClrLoop
0000B5r 2               
0000B5r 2                 ; Zero 26 array descriptors (52 bytes at BAS_ARYDESC)
0000B5r 2  A2 33          ldx #51
0000B7r 2               @ClrAryLoop:
0000B7r 2  9D 5B 03       sta BAS_ARYDESC,x
0000BAr 2  CA             dex
0000BBr 2  10 FA          bpl @ClrAryLoop
0000BDr 2               
0000BDr 2                 ; Reset array top to $8000 (no arrays allocated)
0000BDr 2  A9 00          lda #$00
0000BFr 2  8D 8F 03       sta BAS_ARYTOP
0000C2r 2  A9 80          lda #$80
0000C4r 2  8D 90 03       sta BAS_ARYTOP + 1
0000C7r 2               
0000C7r 2                 ; Reset GOSUB and FOR stack pointers
0000C7r 2  64 1A          stz BAS_GOSUBSP
0000C9r 2  64 1B          stz BAS_FORSP
0000CBr 2               
0000CBr 2                 ; Clear DATA/STOP/CONT state
0000CBr 2  9C 1A 03       stz BAS_DATAPTR
0000CEr 2  9C 1B 03       stz BAS_DATAPTR + 1
0000D1r 2  9C 1C 03       stz BAS_STOPLINE
0000D4r 2  9C 1D 03       stz BAS_STOPLINE + 1
0000D7r 2  9C 1E 03       stz BAS_STOPTXT
0000DAr 2  9C 1F 03       stz BAS_STOPTXT + 1
0000DDr 2  9C 0E 03       stz BAS_PENDKEY
0000E0r 2  60             rts
0000E1r 2               
0000E1r 2               ; ============================================================================
0000E1r 2               ; Print Helpers
0000E1r 2               ; ============================================================================
0000E1r 2               
0000E1r 2               ; Print null-terminated string at (BAS_TMP1)
0000E1r 2               ; Modifies: A, Y, Flags
0000E1r 2               BasPrintStr:
0000E1r 2  A0 00          ldy #$00
0000E3r 2               @Loop:
0000E3r 2  B1 0E          lda (BAS_TMP1),y
0000E5r 2  F0 06          beq @Done
0000E7r 2  20 rr rr       jsr Chrout
0000EAr 2  C8             iny
0000EBr 2  D0 F6          bne @Loop
0000EDr 2               @Done:
0000EDr 2  60             rts
0000EEr 2               
0000EEr 2               ; Print CR + LF
0000EEr 2               ; Modifies: A, Flags
0000EEr 2               BasPrintCRLF:
0000EEr 2  A9 0D          lda #CH_CR
0000F0r 2  20 rr rr       jsr Chrout
0000F3r 2  A9 0A          lda #CH_LF
0000F5r 2  20 rr rr       jsr Chrout
0000F8r 2  60             rts
0000F9r 2               
0000F9r 2               ; Print free bytes message: "XXXXX BYTES FREE" + CRLF
0000F9r 2               ; Modifies: A, X, Y, Flags
0000F9r 2               BasPrintFree:
0000F9r 2                 ; Calculate free = (BAS_ARYTOP - 1) - BAS_PRGEND
0000F9r 2  38             sec
0000FAr 2  AD 8F 03       lda BAS_ARYTOP
0000FDr 2  E9 01          sbc #$01
0000FFr 2  85 0A          sta BAS_ACC
000101r 2  AD 90 03       lda BAS_ARYTOP + 1
000104r 2  E9 00          sbc #$00
000106r 2  85 0B          sta BAS_ACC + 1
000108r 2  38             sec
000109r 2  A5 0A          lda BAS_ACC
00010Br 2  E5 12          sbc BAS_PRGEND
00010Dr 2  85 0A          sta BAS_ACC
00010Fr 2  A5 0B          lda BAS_ACC + 1
000111r 2  E5 13          sbc BAS_PRGEND + 1
000113r 2  85 0B          sta BAS_ACC + 1
000115r 2               
000115r 2  20 rr rr       jsr BasPrintInt
000118r 2               
000118r 2  A9 rr          lda #<BasStrFree
00011Ar 2  85 0E          sta BAS_TMP1
00011Cr 2  A9 rr          lda #>BasStrFree
00011Er 2  85 0F          sta BAS_TMP1 + 1
000120r 2  20 rr rr       jsr BasPrintStr
000123r 2  4C rr rr       jmp BasPrintCRLF
000126r 2               
000126r 2               ; ============================================================================
000126r 2               ; Print signed 16-bit integer in BAS_ACC
000126r 2               ; Modifies: A, X, Y, Flags
000126r 2               ; ============================================================================
000126r 2               
000126r 2               BasPrintInt:
000126r 2                 ; Check if negative (bit 15 set)
000126r 2  A5 0B          lda BAS_ACC + 1
000128r 2  10 12          bpl @Positive
00012Ar 2               
00012Ar 2                 ; Print minus sign
00012Ar 2  A9 2D          lda #CH_MINUS
00012Cr 2  20 rr rr       jsr Chrout
00012Fr 2               
00012Fr 2                 ; Negate: ACC = 0 - ACC
00012Fr 2  38             sec
000130r 2  A9 00          lda #$00
000132r 2  E5 0A          sbc BAS_ACC
000134r 2  85 0A          sta BAS_ACC
000136r 2  A9 00          lda #$00
000138r 2  E5 0B          sbc BAS_ACC + 1
00013Ar 2  85 0B          sta BAS_ACC + 1
00013Cr 2               
00013Cr 2               @Positive:
00013Cr 2                 ; Push digits onto CPU stack (divide by 10 repeatedly)
00013Cr 2  A2 00          ldx #$00                       ; Digit counter on stack
00013Er 2               
00013Er 2               @DivLoop:
00013Er 2                 ; Divide BAS_ACC by 10, remainder is next digit (least significant first)
00013Er 2  A9 00          lda #$00
000140r 2  85 1C          sta BAS_SCRATCH               ; Remainder
000142r 2  A0 10          ldy #16                        ; 16-bit division
000144r 2               
000144r 2               @DivBit:
000144r 2  06 0A          asl BAS_ACC
000146r 2  26 0B          rol BAS_ACC + 1
000148r 2  26 1C          rol BAS_SCRATCH
00014Ar 2  38             sec
00014Br 2  A5 1C          lda BAS_SCRATCH
00014Dr 2  E9 0A          sbc #10
00014Fr 2  90 04          bcc @DivNoSub
000151r 2  85 1C          sta BAS_SCRATCH
000153r 2  E6 0A          inc BAS_ACC                    ; Set quotient bit
000155r 2               
000155r 2               @DivNoSub:
000155r 2  88             dey
000156r 2  D0 EC          bne @DivBit
000158r 2               
000158r 2                 ; Push remainder digit (ASCII)
000158r 2  A5 1C          lda BAS_SCRATCH
00015Ar 2  09 30          ora #$30                       ; Convert to ASCII '0'-'9'
00015Cr 2  48             pha
00015Dr 2  E8             inx                            ; Count digits
00015Er 2               
00015Er 2                 ; Check if quotient is zero
00015Er 2  A5 0A          lda BAS_ACC
000160r 2  05 0B          ora BAS_ACC + 1
000162r 2  D0 DA          bne @DivLoop
000164r 2               
000164r 2                 ; Pop and print digits (most significant first)
000164r 2               @PrintDigits:
000164r 2  68             pla
000165r 2  20 rr rr       jsr Chrout
000168r 2  CA             dex
000169r 2  D0 F9          bne @PrintDigits
00016Br 2  60             rts
00016Cr 2               
00016Cr 2               ; ============================================================================
00016Cr 2               ; Read a line of input into BAS_LINBUF
00016Cr 2               ; Blocks until CR received. Handles backspace.
00016Cr 2               ; Modifies: A, X, Y, Flags
00016Cr 2               ; ============================================================================
00016Cr 2               
00016Cr 2               BasReadLine:
00016Cr 2  A0 00          ldy #$00                       ; Index into BAS_LINBUF
00016Er 2               
00016Er 2               @WaitChar:
00016Er 2  20 rr rr       jsr Chrin                      ; Non-blocking read (carry=1 if char available)
000171r 2  90 FB          bcc @WaitChar                  ; Loop until character available
000173r 2               
000173r 2                 ; Check for backspace
000173r 2  C9 08          cmp #CH_BKSP
000175r 2  F0 24          beq @Backspace
000177r 2               
000177r 2                 ; Check for CR (end of line)
000177r 2  C9 0D          cmp #CH_CR
000179r 2  F0 2E          beq @Done
00017Br 2               
00017Br 2                 ; Check for Ctrl+C (cancel line)
00017Br 2  C9 03          cmp #CH_CTRLC
00017Dr 2  F0 23          beq @Cancel
00017Fr 2               
00017Fr 2                 ; Skip non-printable control characters (LF, NUL, ESC, etc.)
00017Fr 2  C9 20          cmp #CH_SPACE
000181r 2  90 EB          bcc @WaitChar
000183r 2               
000183r 2                 ; Skip DEL ($7F)
000183r 2  C9 7F          cmp #$7F
000185r 2  F0 E7          beq @WaitChar
000187r 2               
000187r 2                 ; Ignore if buffer full
000187r 2  C0 C8          cpy #BAS_LINBUF_SIZE
000189r 2  B0 E3          bcs @WaitChar
00018Br 2               
00018Br 2                 ; Convert lowercase to uppercase
00018Br 2  C9 61          cmp #'a'
00018Dr 2  90 06          bcc @Store
00018Fr 2  C9 7B          cmp #'z' + 1
000191r 2  B0 02          bcs @Store
000193r 2  29 DF          and #$DF                       ; Clear bit 5 → uppercase
000195r 2               @Store:
000195r 2                 ; Store character and advance
000195r 2  99 34 04       sta BAS_LINBUF,y
000198r 2  C8             iny
000199r 2  80 D3          bra @WaitChar
00019Br 2               
00019Br 2               @Backspace:
00019Br 2  C0 00          cpy #$00
00019Dr 2  F0 CF          beq @WaitChar                  ; Nothing to delete
00019Fr 2  88             dey
0001A0r 2  80 CC          bra @WaitChar
0001A2r 2               
0001A2r 2               @Cancel:
0001A2r 2  A0 00          ldy #$00                       ; Reset buffer
0001A4r 2  20 rr rr       jsr BasPrintCRLF
0001A7r 2  80 C5          bra @WaitChar
0001A9r 2               
0001A9r 2               @Done:
0001A9r 2  A9 00          lda #$00
0001ABr 2  99 34 04       sta BAS_LINBUF,y               ; Null-terminate
0001AEr 2  20 rr rr       jsr BasPrintCRLF               ; Echo newline (Chrin echoed the CR)
0001B1r 2  60             rts
0001B2r 2               
0001B2r 2               ; ============================================================================
0001B2r 2               ; Tokenizer — Convert BAS_LINBUF ASCII text into BAS_TOKBUF tokenized form
0001B2r 2               ; ============================================================================
0001B2r 2               ; Input:  BAS_LINBUF contains null-terminated ASCII line
0001B2r 2               ; Output: BAS_TOKBUF contains:
0001B2r 2               ;           [2 bytes] line number (0 if no line number)
0001B2r 2               ;           [N bytes] tokenized payload
0001B2r 2               ;           [$00]     terminator
0001B2r 2               ; Modifies: A, X, Y, Flags, BAS_TMP1, BAS_TMP2, BAS_TOKIDX, BAS_NUMTMP
0001B2r 2               
0001B2r 2               BasTokenize:
0001B2r 2  A2 00          ldx #$00                       ; X = source index into BAS_LINBUF
0001B4r 2  64 16          stz BAS_TOKIDX                 ; Output index into BAS_TOKBUF
0001B6r 2               
0001B6r 2                 ; --- Parse optional line number ---
0001B6r 2  64 22          stz BAS_NUMTMP                 ; Clear 16-bit accumulator
0001B8r 2  64 23          stz BAS_NUMTMP + 1
0001BAr 2  A0 00          ldy #$00                       ; Flag: any digit found?
0001BCr 2               
0001BCr 2               @TokNumLoop:
0001BCr 2  BD 34 04       lda BAS_LINBUF,x
0001BFr 2  38             sec
0001C0r 2  E9 30          sbc #'0'
0001C2r 2  90 3E          bcc @TokNumDone                ; < '0'
0001C4r 2  C9 0A          cmp #10
0001C6r 2  B0 3A          bcs @TokNumDone                ; > '9'
0001C8r 2               
0001C8r 2                 ; Accumulate: NUMTMP = NUMTMP * 10 + digit
0001C8r 2  48             pha                            ; Save digit
0001C9r 2                 ; Multiply NUMTMP by 10: (val<<3) + (val<<1)
0001C9r 2  A5 22          lda BAS_NUMTMP
0001CBr 2  85 1C          sta BAS_SCRATCH
0001CDr 2  A5 23          lda BAS_NUMTMP + 1
0001CFr 2  85 1D          sta BAS_SCRATCH + 1
0001D1r 2                 ; Shift left 1 (×2)
0001D1r 2  06 22          asl BAS_NUMTMP
0001D3r 2  26 23          rol BAS_NUMTMP + 1
0001D5r 2                 ; Shift left 3 more (×8 total from original)
0001D5r 2  A5 1C          lda BAS_SCRATCH
0001D7r 2  0A             asl
0001D8r 2  85 1C          sta BAS_SCRATCH
0001DAr 2  A5 1D          lda BAS_SCRATCH + 1
0001DCr 2  2A             rol
0001DDr 2  85 1D          sta BAS_SCRATCH + 1
0001DFr 2  06 1C          asl BAS_SCRATCH
0001E1r 2  26 1D          rol BAS_SCRATCH + 1
0001E3r 2  06 1C          asl BAS_SCRATCH
0001E5r 2  26 1D          rol BAS_SCRATCH + 1
0001E7r 2                 ; Add ×2 + ×8 = ×10
0001E7r 2  18             clc
0001E8r 2  A5 22          lda BAS_NUMTMP
0001EAr 2  65 1C          adc BAS_SCRATCH
0001ECr 2  85 22          sta BAS_NUMTMP
0001EEr 2  A5 23          lda BAS_NUMTMP + 1
0001F0r 2  65 1D          adc BAS_SCRATCH + 1
0001F2r 2  85 23          sta BAS_NUMTMP + 1
0001F4r 2                 ; Add the digit
0001F4r 2  68             pla
0001F5r 2  18             clc
0001F6r 2  65 22          adc BAS_NUMTMP
0001F8r 2  85 22          sta BAS_NUMTMP
0001FAr 2  90 02          bcc @TokNumNoCarry
0001FCr 2  E6 23          inc BAS_NUMTMP + 1
0001FEr 2               @TokNumNoCarry:
0001FEr 2  C8             iny                            ; Mark digit found
0001FFr 2  E8             inx                            ; Advance source
000200r 2  80 BA          bra @TokNumLoop
000202r 2               
000202r 2               @TokNumDone:
000202r 2                 ; Store line number (0 if none found)
000202r 2  A5 22          lda BAS_NUMTMP
000204r 2  8D 00 06       sta BAS_TOKBUF
000207r 2  A5 23          lda BAS_NUMTMP + 1
000209r 2  8D 01 06       sta BAS_TOKBUF + 1
00020Cr 2  A9 02          lda #2
00020Er 2  85 16          sta BAS_TOKIDX                 ; Output starts after 2-byte line number
000210r 2               
000210r 2                 ; Skip spaces after line number
000210r 2  20 rr rr       jsr @TokSkipSpaces
000213r 2               
000213r 2                 ; --- Main tokenize loop ---
000213r 2               @TokLoop:
000213r 2  BD 34 04       lda BAS_LINBUF,x
000216r 2  F0 25          beq @TokEnd                   ; Null terminator — done
000218r 2               
000218r 2                 ; Check for string literal (copy verbatim including quotes)
000218r 2  C9 22          cmp #CH_QUOTE
00021Ar 2  F0 79          beq @TokString
00021Cr 2               
00021Cr 2                 ; Check for multi-char operators: >=, <=, <>
00021Cr 2  C9 3E          cmp #CH_GREATER
00021Er 2  F0 25          beq @TokCheckGE
000220r 2  C9 3C          cmp #CH_LESS
000222r 2  F0 39          beq @TokCheckLE
000224r 2               
000224r 2                 ; Check if uppercase letter — possible keyword
000224r 2  C9 41          cmp #'A'
000226r 2  90 0B          bcc @TokCopyChar               ; Below 'A' — just copy
000228r 2  C9 5B          cmp #'Z' + 1
00022Ar 2  B0 07          bcs @TokCopyChar               ; Above 'Z' — just copy
00022Cr 2               
00022Cr 2                 ; Try to match a keyword
00022Cr 2  48             pha                            ; Save char in case match fails
00022Dr 2  20 rr rr       jsr BasMatchKeyword
000230r 2  B0 54          bcs @TokGotKeywordPop         ; Carry set = matched
000232r 2  68             pla                            ; Restore original character
000233r 2               
000233r 2                 ; Not a keyword — copy single character as-is
000233r 2               @TokCopyChar:
000233r 2  A4 16          ldy BAS_TOKIDX
000235r 2  99 00 06       sta BAS_TOKBUF,y
000238r 2  E6 16          inc BAS_TOKIDX
00023Ar 2  E8             inx                            ; Advance source
00023Br 2  80 D6          bra @TokLoop
00023Dr 2               
00023Dr 2               @TokEnd:
00023Dr 2                 ; Null-terminate tokenized output
00023Dr 2  A4 16          ldy BAS_TOKIDX
00023Fr 2  A9 00          lda #$00
000241r 2  99 00 06       sta BAS_TOKBUF,y
000244r 2  60             rts
000245r 2               
000245r 2               @TokCheckGE:
000245r 2                 ; Current char is '>', check next for '='
000245r 2  BD 35 04       lda BAS_LINBUF+1,x
000248r 2  C9 3D          cmp #CH_EQUALS
00024Ar 2  D0 0D          bne @TokCopyGT
00024Cr 2  A9 9A          lda #TOK_GE
00024Er 2  A4 16          ldy BAS_TOKIDX
000250r 2  99 00 06       sta BAS_TOKBUF,y
000253r 2  E6 16          inc BAS_TOKIDX
000255r 2  E8             inx                            ; Skip '>'
000256r 2  E8             inx                            ; Skip '='
000257r 2  80 BA          bra @TokLoop
000259r 2               @TokCopyGT:
000259r 2  A9 3E          lda #CH_GREATER
00025Br 2  80 D6          bra @TokCopyChar
00025Dr 2               
00025Dr 2               @TokCheckLE:
00025Dr 2                 ; Current char is '<', check next
00025Dr 2  BD 35 04       lda BAS_LINBUF+1,x
000260r 2  C9 3D          cmp #CH_EQUALS
000262r 2  F0 08          beq @TokEmitLE
000264r 2  C9 3E          cmp #CH_GREATER
000266r 2  F0 11          beq @TokEmitNE
000268r 2  A9 3C          lda #CH_LESS
00026Ar 2  80 C7          bra @TokCopyChar
00026Cr 2               @TokEmitLE:
00026Cr 2  A9 9B          lda #TOK_LE
00026Er 2  A4 16          ldy BAS_TOKIDX
000270r 2  99 00 06       sta BAS_TOKBUF,y
000273r 2  E6 16          inc BAS_TOKIDX
000275r 2  E8             inx
000276r 2  E8             inx
000277r 2  80 9A          bra @TokLoop
000279r 2               @TokEmitNE:
000279r 2  A9 9C          lda #TOK_NE
00027Br 2  A4 16          ldy BAS_TOKIDX
00027Dr 2  99 00 06       sta BAS_TOKBUF,y
000280r 2  E6 16          inc BAS_TOKIDX
000282r 2  E8             inx
000283r 2  E8             inx
000284r 2  80 8D          bra @TokLoop
000286r 2               
000286r 2               @TokGotKeywordPop:
000286r 2  7A             ply                            ; Discard saved char (preserves A = token)
000287r 2               @TokGotKeyword:
000287r 2                 ; A = token byte, X already advanced past keyword
000287r 2  A4 16          ldy BAS_TOKIDX
000289r 2  99 00 06       sta BAS_TOKBUF,y
00028Cr 2  E6 16          inc BAS_TOKIDX
00028Er 2               
00028Er 2                 ; If REM token, copy rest of line verbatim
00028Er 2  C9 8C          cmp #TOK_REM
000290r 2  F0 22          beq @TokRem
000292r 2  4C rr rr       jmp @TokLoop
000295r 2               
000295r 2               @TokString:
000295r 2                 ; Copy opening quote
000295r 2  A4 16          ldy BAS_TOKIDX
000297r 2  99 00 06       sta BAS_TOKBUF,y
00029Ar 2  E6 16          inc BAS_TOKIDX
00029Cr 2  E8             inx
00029Dr 2               @TokStrLoop:
00029Dr 2  BD 34 04       lda BAS_LINBUF,x
0002A0r 2  F0 0F          beq @TokEndJ                   ; Unterminated string — end of line
0002A2r 2  A4 16          ldy BAS_TOKIDX
0002A4r 2  99 00 06       sta BAS_TOKBUF,y
0002A7r 2  E6 16          inc BAS_TOKIDX
0002A9r 2  E8             inx
0002AAr 2  C9 22          cmp #CH_QUOTE                  ; Closing quote?
0002ACr 2  D0 EF          bne @TokStrLoop
0002AEr 2  4C rr rr       jmp @TokLoop                   ; Continue after closing quote
0002B1r 2               @TokEndJ:
0002B1r 2  4C rr rr       jmp @TokEnd
0002B4r 2               
0002B4r 2               @TokRem:
0002B4r 2                 ; Copy everything remaining verbatim
0002B4r 2               @TokRemLoop:
0002B4r 2  BD 34 04       lda BAS_LINBUF,x
0002B7r 2  F0 0A          beq @TokEndJ2
0002B9r 2  A4 16          ldy BAS_TOKIDX
0002BBr 2  99 00 06       sta BAS_TOKBUF,y
0002BEr 2  E6 16          inc BAS_TOKIDX
0002C0r 2  E8             inx
0002C1r 2  80 F1          bra @TokRemLoop
0002C3r 2               @TokEndJ2:
0002C3r 2  4C rr rr       jmp @TokEnd
0002C6r 2               
0002C6r 2               ; Skip spaces in BAS_LINBUF at position X
0002C6r 2               @TokSkipSpaces:
0002C6r 2  BD 34 04       lda BAS_LINBUF,x
0002C9r 2  C9 20          cmp #CH_SPACE
0002CBr 2  D0 03          bne @TokSkipDone
0002CDr 2  E8             inx
0002CEr 2  80 F6          bra @TokSkipSpaces
0002D0r 2               @TokSkipDone:
0002D0r 2  60             rts
0002D1r 2               
0002D1r 2               ; ============================================================================
0002D1r 2               ; Keyword Matching — Try to match a keyword at BAS_LINBUF+X
0002D1r 2               ; ============================================================================
0002D1r 2               ; Input:  X = current source index in BAS_LINBUF
0002D1r 2               ; Output: Carry set if matched, A = token, X advanced past keyword
0002D1r 2               ;         Carry clear if no match, X unchanged
0002D1r 2               ; Modifies: A, Y, BAS_TMP1, BAS_TMP2
0002D1r 2               
0002D1r 2               BasMatchKeyword:
0002D1r 2  DA             phx                            ; Save source position for rollback
0002D2r 2               
0002D2r 2                 ; Set BAS_TMP1 to start of keyword table
0002D2r 2  A9 rr          lda #<BasKeywordTable
0002D4r 2  85 0E          sta BAS_TMP1
0002D6r 2  A9 rr          lda #>BasKeywordTable
0002D8r 2  85 0F          sta BAS_TMP1 + 1
0002DAr 2               
0002DAr 2               @KwOuter:
0002DAr 2                 ; Load first byte of keyword entry — $00 = end of table
0002DAr 2  A0 00          ldy #$00
0002DCr 2  B1 0E          lda (BAS_TMP1),y
0002DEr 2  F0 3B          beq @KwNoMatch                 ; End of table — no match
0002E0r 2               
0002E0r 2                 ; Restore original X (source position)
0002E0r 2  FA             plx
0002E1r 2  DA             phx                            ; Re-save it for next attempt
0002E2r 2               
0002E2r 2               @KwCompare:
0002E2r 2  B1 0E          lda (BAS_TMP1),y
0002E4r 2  F0 09          beq @KwMatched                 ; Null terminator in keyword = full match
0002E6r 2  DD 34 04       cmp BAS_LINBUF,x
0002E9r 2  D0 1A          bne @KwSkip                    ; Mismatch — skip to next keyword
0002EBr 2  C8             iny
0002ECr 2  E8             inx
0002EDr 2  80 F3          bra @KwCompare
0002EFr 2               
0002EFr 2               @KwMatched:
0002EFr 2                 ; Keyword matched. The token byte follows the null terminator.
0002EFr 2  C8             iny                            ; Advance past the null
0002F0r 2  B1 0E          lda (BAS_TMP1),y               ; Read token byte
0002F2r 2               
0002F2r 2                 ; Check that the next source char is not a letter (prevent partial match)
0002F2r 2                 ; e.g. "TORE" should not match "TO"
0002F2r 2  48             pha                            ; Save token
0002F3r 2  BD 34 04       lda BAS_LINBUF,x
0002F6r 2  C9 41          cmp #'A'
0002F8r 2  90 07          bcc @KwConfirmed               ; Not a letter — confirmed
0002FAr 2  C9 5B          cmp #'Z' + 1
0002FCr 2  B0 03          bcs @KwConfirmed               ; Not a letter — confirmed
0002FEr 2                 ; Next char is a letter — this is a partial match, skip it
0002FEr 2  68             pla
0002FFr 2  80 04          bra @KwSkip
000301r 2               
000301r 2               @KwConfirmed:
000301r 2  68             pla                            ; Recover token
000302r 2  7A             ply                            ; Discard saved source position (PLY not PLX — X holds the advanced position)
000303r 2                 ; X is already advanced past the keyword
000303r 2  38             sec
000304r 2  60             rts
000305r 2               
000305r 2               @KwSkip:
000305r 2                 ; Advance BAS_TMP1 past current keyword string + null + token byte
000305r 2  A0 00          ldy #$00
000307r 2               @KwSkipStr:
000307r 2  B1 0E          lda (BAS_TMP1),y
000309r 2  C8             iny
00030Ar 2  C9 00          cmp #$00                       ; Found null terminator?
00030Cr 2  D0 F9          bne @KwSkipStr
00030Er 2  C8             iny                            ; Skip token byte too
00030Fr 2                 ; Advance BAS_TMP1 by Y to point to next keyword entry
00030Fr 2  98             tya
000310r 2  18             clc
000311r 2  65 0E          adc BAS_TMP1
000313r 2  85 0E          sta BAS_TMP1
000315r 2  90 C3          bcc @KwOuter
000317r 2  E6 0F          inc BAS_TMP1 + 1
000319r 2  80 BF          bra @KwOuter                   ; Try next keyword
00031Br 2               
00031Br 2               @KwNoMatch:
00031Br 2  FA             plx                            ; Restore original source position
00031Cr 2  18             clc
00031Dr 2  60             rts
00031Er 2               
00031Er 2               ; ============================================================================
00031Er 2               ; Detokenizer — Convert tokenized line to printable ASCII
00031Er 2               ; ============================================================================
00031Er 2               ; Input:  BAS_TMP1 points to tokenized payload (past line number)
00031Er 2               ; Output: Characters sent to Chrout
00031Er 2               ; Input:  BAS_TXTPTR points to tokenized payload
00031Er 2               ; Output: Characters sent to Chrout
00031Er 2               ; Modifies: A, X, Y, Flags, BAS_TMP2
00031Er 2               
00031Er 2               BasDetokenize:
00031Er 2  A0 00          ldy #$00
000320r 2               
000320r 2               @DetokLoop:
000320r 2  B1 04          lda (BAS_TXTPTR),y
000322r 2  F0 4C          beq @DetokDone                 ; Null terminator — done
000324r 2               
000324r 2                 ; Check if token (>= $80)
000324r 2  30 06          bmi @DetokKeyword
000326r 2               
000326r 2                 ; Regular ASCII character — output it
000326r 2  20 rr rr       jsr Chrout
000329r 2  C8             iny
00032Ar 2  80 F4          bra @DetokLoop
00032Cr 2               
00032Cr 2               @DetokKeyword:
00032Cr 2                 ; Look up keyword string for this token
00032Cr 2  5A             phy                            ; Save source index
00032Dr 2  85 21          sta BAS_TEMP                   ; Save target token
00032Fr 2               
00032Fr 2                 ; Walk the keyword table looking for matching token
00032Fr 2  A9 rr          lda #<BasKeywordTable
000331r 2  85 10          sta BAS_TMP2
000333r 2  A9 rr          lda #>BasKeywordTable
000335r 2  85 11          sta BAS_TMP2 + 1
000337r 2               
000337r 2               @DetokSearch:
000337r 2  A0 00          ldy #$00
000339r 2  B1 10          lda (BAS_TMP2),y
00033Br 2  F0 2A          beq @DetokNotFound             ; End of table — token not found
00033Dr 2               @DetokScanStr:
00033Dr 2  B1 10          lda (BAS_TMP2),y
00033Fr 2  C8             iny
000340r 2  C9 00          cmp #$00                       ; End of keyword string?
000342r 2  D0 F9          bne @DetokScanStr
000344r 2                 ; Y now points to the token byte
000344r 2  B1 10          lda (BAS_TMP2),y
000346r 2  C8             iny                            ; Advance past token byte
000347r 2               
000347r 2                 ; Compare to our target token
000347r 2  C5 21          cmp BAS_TEMP
000349r 2  F0 0C          beq @DetokFound
00034Br 2                 ; Not this one — advance BAS_TMP2 to next entry
00034Br 2  98             tya
00034Cr 2  18             clc
00034Dr 2  65 10          adc BAS_TMP2
00034Fr 2  85 10          sta BAS_TMP2
000351r 2  90 E4          bcc @DetokSearch
000353r 2  E6 11          inc BAS_TMP2 + 1
000355r 2  80 E0          bra @DetokSearch
000357r 2               
000357r 2               @DetokFound:
000357r 2                 ; Print the keyword string from start of BAS_TMP2
000357r 2  A0 00          ldy #$00
000359r 2               @DetokPrintKw:
000359r 2  B1 10          lda (BAS_TMP2),y
00035Br 2  F0 06          beq @DetokKwDone               ; Null = end of keyword string
00035Dr 2  20 rr rr       jsr Chrout
000360r 2  C8             iny
000361r 2  80 F6          bra @DetokPrintKw
000363r 2               
000363r 2               @DetokKwDone:
000363r 2  7A             ply                            ; Restore source index
000364r 2  C8             iny                            ; Advance past the token byte in source
000365r 2  80 B9          bra @DetokLoop
000367r 2               
000367r 2               @DetokNotFound:
000367r 2                 ; Token not in table (shouldn't happen) — print '?' and continue
000367r 2  A9 3F          lda #'?'
000369r 2  20 rr rr       jsr Chrout
00036Cr 2  7A             ply
00036Dr 2  C8             iny
00036Er 2  80 B0          bra @DetokLoop
000370r 2               
000370r 2               @DetokDone:
000370r 2  60             rts
000371r 2               
000371r 2               ; ============================================================================
000371r 2               ; Line Editor — Program Storage Management
000371r 2               ; ============================================================================
000371r 2               
000371r 2               ; ----------------------------------------------------------------------------
000371r 2               ; BasInsertLine — Insert or replace a program line
000371r 2               ; ----------------------------------------------------------------------------
000371r 2               ; Input:  BAS_TOKBUF contains tokenized line:
000371r 2               ;           [2 bytes] line number
000371r 2               ;           [N bytes] tokenized payload
000371r 2               ;           [$00]     terminator
000371r 2               ; If payload is empty (just null after line number), deletes existing line.
000371r 2               ; Modifies: A, X, Y, Flags, BAS_TMP1, BAS_TMP2, BAS_SCRATCH, BAS_SCRATCH2
000371r 2               
000371r 2               BasInsertLine:
000371r 2                 ; Load line number from TOKBUF
000371r 2  AD 00 06       lda BAS_TOKBUF
000374r 2  85 08          sta BAS_LINENUM
000376r 2  AD 01 06       lda BAS_TOKBUF + 1
000379r 2  85 09          sta BAS_LINENUM + 1
00037Br 2               
00037Br 2                 ; Calculate new line size: scan TOKBUF payload for null terminator
00037Br 2  A2 02          ldx #2                         ; Start past line number in TOKBUF
00037Dr 2               @SizeLoop:
00037Dr 2  BD 00 06       lda BAS_TOKBUF,x
000380r 2  F0 03          beq @SizeDone
000382r 2  E8             inx
000383r 2  80 F8          bra @SizeLoop
000385r 2               @SizeDone:
000385r 2                 ; X = offset of null terminator (payload length = X - 2)
000385r 2                 ; Total line in memory: 2 (next ptr) + 2 (line num) + (X-2) payload + 1 (null) = X + 3
000385r 2  E8             inx                            ; Include the null terminator
000386r 2  E8             inx                            ; +2 for next-line pointer
000387r 2  E8             inx                            ; +2 for line number (but X already includes 2 from tokbuf offset)
000388r 2                 ; X now = new line byte count including header
000388r 2                 ; Actually: payload starts at TOKBUF+2, null at TOKBUF+X (original)
000388r 2                 ; Memory line = 4 header + (origX - 2) payload + 1 null = origX + 3
000388r 2                 ; But we already incremented X by 3, so X = origX + 3. Correct.
000388r 2  86 1E          stx BAS_SCRATCH2               ; Save new line size
00038Ar 2               
00038Ar 2                 ; Check if payload is empty (just the null after line number = delete only)
00038Ar 2  AD 02 06       lda BAS_TOKBUF + 2
00038Dr 2  85 21          sta BAS_TEMP                   ; $00 if empty, nonzero if has content
00038Fr 2               
00038Fr 2                 ; --- Try to find existing line with this number ---
00038Fr 2  20 rr rr       jsr BasFindLine                ; Sets BAS_TMP1 if found, carry set/clear
000392r 2               
000392r 2  90 45          bcc @NoExisting
000394r 2               
000394r 2                 ; --- Delete existing line ---
000394r 2                 ; BAS_TMP1 = address of existing line
000394r 2                 ; Calculate old line's size by scanning for null terminator
000394r 2  A0 04          ldy #LINE_PAYLOAD
000396r 2               @DelSizeLoop:
000396r 2  B1 0E          lda (BAS_TMP1),y
000398r 2  F0 03          beq @DelSizeDone
00039Ar 2  C8             iny
00039Br 2  80 F9          bra @DelSizeLoop
00039Dr 2               @DelSizeDone:
00039Dr 2  C8             iny                            ; Include null byte; Y = total line size
00039Er 2  84 0C          sty BAS_AUX                   ; Old line size low
0003A0r 2  64 0D          stz BAS_AUX + 1               ; High byte = 0 (lines < 256 bytes)
0003A2r 2               
0003A2r 2                 ; Compute source (next line address) = BAS_TMP1 + Y
0003A2r 2  98             tya
0003A3r 2  18             clc
0003A4r 2  65 0E          adc BAS_TMP1
0003A6r 2  85 1C          sta BAS_SCRATCH                ; Next-line address low
0003A8r 2  A9 00          lda #$00
0003AAr 2  65 0F          adc BAS_TMP1 + 1
0003ACr 2  85 1D          sta BAS_SCRATCH + 1            ; Next-line address high
0003AEr 2               
0003AEr 2                 ; Shift bytes down: copy from BAS_SCRATCH to BAS_TMP1, up to BAS_PRGEND
0003AEr 2                 ; Source = BAS_SCRATCH (next line), Dest = BAS_TMP1 (current line)
0003AEr 2                 ; Count = BAS_PRGEND - BAS_SCRATCH
0003AEr 2  A0 00          ldy #$00
0003B0r 2               @DeleteLoop:
0003B0r 2  A5 1C          lda BAS_SCRATCH
0003B2r 2  C5 12          cmp BAS_PRGEND
0003B4r 2  A5 1D          lda BAS_SCRATCH + 1
0003B6r 2  E5 13          sbc BAS_PRGEND + 1
0003B8r 2  B0 12          bcs @DeleteDone                ; Source >= PRGEND, done copying
0003BAr 2               
0003BAr 2  B1 1C          lda (BAS_SCRATCH),y
0003BCr 2  91 0E          sta (BAS_TMP1),y
0003BEr 2               
0003BEr 2                 ; Increment source pointer
0003BEr 2  E6 1C          inc BAS_SCRATCH
0003C0r 2  D0 02          bne @DelSrcOk
0003C2r 2  E6 1D          inc BAS_SCRATCH + 1
0003C4r 2               @DelSrcOk:
0003C4r 2                 ; Increment dest pointer
0003C4r 2  E6 0E          inc BAS_TMP1
0003C6r 2  D0 02          bne @DelDstOk
0003C8r 2  E6 0F          inc BAS_TMP1 + 1
0003CAr 2               @DelDstOk:
0003CAr 2  80 E4          bra @DeleteLoop
0003CCr 2               
0003CCr 2               @DeleteDone:
0003CCr 2                 ; Update PRGEND: subtract old line size
0003CCr 2  38             sec
0003CDr 2  A5 12          lda BAS_PRGEND
0003CFr 2  E5 0C          sbc BAS_AUX
0003D1r 2  85 12          sta BAS_PRGEND
0003D3r 2  A5 13          lda BAS_PRGEND + 1
0003D5r 2  E5 0D          sbc BAS_AUX + 1
0003D7r 2  85 13          sta BAS_PRGEND + 1
0003D9r 2               
0003D9r 2               @NoExisting:
0003D9r 2                 ; If payload was empty, we're done (delete only)
0003D9r 2  A5 21          lda BAS_TEMP
0003DBr 2  D0 01          bne @DoInsert
0003DDr 2  60             rts                            ; Empty payload — delete only, done
0003DEr 2               
0003DEr 2               @DoInsert:
0003DEr 2               
0003DEr 2                 ; --- Find insertion point (keep lines sorted by number) ---
0003DEr 2  A9 00          lda #<BAS_PRG_START
0003E0r 2  85 0E          sta BAS_TMP1
0003E2r 2  A9 08          lda #>BAS_PRG_START
0003E4r 2  85 0F          sta BAS_TMP1 + 1
0003E6r 2               
0003E6r 2               @FindInsPos:
0003E6r 2                 ; Check if we've reached end of program (TMP1 == PRGEND)
0003E6r 2  A5 0E          lda BAS_TMP1
0003E8r 2  C5 12          cmp BAS_PRGEND
0003EAr 2  D0 06          bne @FindNotEnd
0003ECr 2  A5 0F          lda BAS_TMP1 + 1
0003EEr 2  C5 13          cmp BAS_PRGEND + 1
0003F0r 2  F0 2F          beq @InsertHere                ; At PRGEND — insert here
0003F2r 2               @FindNotEnd:
0003F2r 2               
0003F2r 2                 ; Compare this line's number with target
0003F2r 2  A0 02          ldy #LINE_NUM
0003F4r 2  B1 0E          lda (BAS_TMP1),y
0003F6r 2  85 0C          sta BAS_AUX
0003F8r 2  C8             iny
0003F9r 2  B1 0E          lda (BAS_TMP1),y
0003FBr 2  85 0D          sta BAS_AUX + 1
0003FDr 2               
0003FDr 2                 ; If this line number >= target, insert before it
0003FDr 2  A5 08          lda BAS_LINENUM
0003FFr 2  C5 0C          cmp BAS_AUX
000401r 2  A5 09          lda BAS_LINENUM + 1
000403r 2  E5 0D          sbc BAS_AUX + 1
000405r 2  90 1A          bcc @InsertHere                ; Target < this line — insert here
000407r 2               
000407r 2                 ; Advance to next line via next-ptr; if $0000, advance to PRGEND
000407r 2  A0 00          ldy #LINE_NEXT
000409r 2  B1 0E          lda (BAS_TMP1),y
00040Br 2  AA             tax
00040Cr 2  C8             iny
00040Dr 2  B1 0E          lda (BAS_TMP1),y
00040Fr 2  85 0F          sta BAS_TMP1 + 1
000411r 2  86 0E          stx BAS_TMP1
000413r 2                 ; If next-ptr was $0000, use PRGEND instead
000413r 2  05 0E          ora BAS_TMP1
000415r 2  D0 CF          bne @FindInsPos
000417r 2  A5 12          lda BAS_PRGEND
000419r 2  85 0E          sta BAS_TMP1
00041Br 2  A5 13          lda BAS_PRGEND + 1
00041Dr 2  85 0F          sta BAS_TMP1 + 1
00041Fr 2  80 C5          bra @FindInsPos
000421r 2               
000421r 2               @InsertHere:
000421r 2                 ; BAS_TMP1 = insertion point
000421r 2                 ; BAS_SCRATCH2 = new line size
000421r 2                 ; Check if there's room
000421r 2  18             clc
000422r 2  A5 12          lda BAS_PRGEND
000424r 2  65 1E          adc BAS_SCRATCH2
000426r 2  85 1C          sta BAS_SCRATCH                ; Tentative new PRGEND low
000428r 2  A5 13          lda BAS_PRGEND + 1
00042Ar 2  69 00          adc #$00
00042Cr 2  85 1D          sta BAS_SCRATCH + 1            ; Tentative new PRGEND high
00042Er 2               
00042Er 2                 ; Check if new PRGEND > BAS_PRG_END ($7FFF)
00042Er 2  A5 1D          lda BAS_SCRATCH + 1
000430r 2  C9 7F          cmp #>BAS_PRG_END
000432r 2  90 0F          bcc @HasRoom
000434r 2  D0 08          bne @OutOfMem
000436r 2  A5 1C          lda BAS_SCRATCH
000438r 2  C9 FF          cmp #<BAS_PRG_END
00043Ar 2  90 07          bcc @HasRoom
00043Cr 2  F0 05          beq @HasRoom
00043Er 2               @OutOfMem:
00043Er 2  A9 03          lda #ERR_OUT_OF_MEM
000440r 2  4C rr rr       jmp BasError
000443r 2               
000443r 2               @HasRoom:
000443r 2                 ; Shift bytes up: move from PRGEND-1 down to TMP1, shifting by SCRATCH2 bytes
000443r 2                 ; Work backwards from PRGEND to TMP1
000443r 2               
000443r 2                 ; Source end = PRGEND - 1
000443r 2  38             sec
000444r 2  A5 12          lda BAS_PRGEND
000446r 2  E9 01          sbc #$01
000448r 2  85 1C          sta BAS_SCRATCH
00044Ar 2  A5 13          lda BAS_PRGEND + 1
00044Cr 2  E9 00          sbc #$00
00044Er 2  85 1D          sta BAS_SCRATCH + 1
000450r 2               
000450r 2                 ; Dest end = source end + new line size
000450r 2  18             clc
000451r 2  A5 1C          lda BAS_SCRATCH
000453r 2  65 1E          adc BAS_SCRATCH2
000455r 2  85 0C          sta BAS_AUX
000457r 2  A5 1D          lda BAS_SCRATCH + 1
000459r 2  69 00          adc #$00
00045Br 2  85 0D          sta BAS_AUX + 1
00045Dr 2               
00045Dr 2               @ShiftUpLoop:
00045Dr 2                 ; Check if source < insertion point (done)
00045Dr 2  A5 1C          lda BAS_SCRATCH
00045Fr 2  C5 0E          cmp BAS_TMP1
000461r 2  A5 1D          lda BAS_SCRATCH + 1
000463r 2  E5 0F          sbc BAS_TMP1 + 1
000465r 2  90 18          bcc @ShiftUpDone
000467r 2               
000467r 2                 ; Copy byte from source to dest
000467r 2  A0 00          ldy #$00
000469r 2  B1 1C          lda (BAS_SCRATCH),y
00046Br 2  91 0C          sta (BAS_AUX),y
00046Dr 2               
00046Dr 2                 ; Decrement source
00046Dr 2  A5 1C          lda BAS_SCRATCH
00046Fr 2  D0 02          bne @ShiftSrcOk
000471r 2  C6 1D          dec BAS_SCRATCH + 1
000473r 2               @ShiftSrcOk:
000473r 2  C6 1C          dec BAS_SCRATCH
000475r 2               
000475r 2                 ; Decrement dest
000475r 2  A5 0C          lda BAS_AUX
000477r 2  D0 02          bne @ShiftDstOk
000479r 2  C6 0D          dec BAS_AUX + 1
00047Br 2               @ShiftDstOk:
00047Br 2  C6 0C          dec BAS_AUX
00047Dr 2  80 DE          bra @ShiftUpLoop
00047Fr 2               
00047Fr 2               @ShiftUpDone:
00047Fr 2                 ; Update PRGEND
00047Fr 2  18             clc
000480r 2  A5 12          lda BAS_PRGEND
000482r 2  65 1E          adc BAS_SCRATCH2
000484r 2  85 12          sta BAS_PRGEND
000486r 2  A5 13          lda BAS_PRGEND + 1
000488r 2  69 00          adc #$00
00048Ar 2  85 13          sta BAS_PRGEND + 1
00048Cr 2               
00048Cr 2                 ; Write the new line at BAS_TMP1
00048Cr 2                 ; Bytes 0-1: next-line pointer (filled by relink)
00048Cr 2                 ; Bytes 2-3: line number
00048Cr 2  A0 02          ldy #LINE_NUM
00048Er 2  A5 08          lda BAS_LINENUM
000490r 2  91 0E          sta (BAS_TMP1),y
000492r 2  C8             iny
000493r 2  A5 09          lda BAS_LINENUM + 1
000495r 2  91 0E          sta (BAS_TMP1),y
000497r 2               
000497r 2                 ; Copy tokenized payload from BAS_TOKBUF+2 to line+4
000497r 2  A2 00          ldx #$00                       ; Source index into TOKBUF+2
000499r 2  A0 04          ldy #LINE_PAYLOAD              ; Dest offset in line
00049Br 2               @CopyPayload:
00049Br 2  BD 02 06       lda BAS_TOKBUF + 2,x
00049Er 2  91 0E          sta (BAS_TMP1),y
0004A0r 2  F0 04          beq @CopyDone                  ; Copied the null terminator — done
0004A2r 2  E8             inx
0004A3r 2  C8             iny
0004A4r 2  80 F5          bra @CopyPayload
0004A6r 2               
0004A6r 2               @CopyDone:
0004A6r 2                 ; Relink all lines
0004A6r 2  20 rr rr       jsr BasRelink
0004A9r 2               
0004A9r 2               @InsertDone:
0004A9r 2  60             rts
0004AAr 2               
0004AAr 2               ; ----------------------------------------------------------------------------
0004AAr 2               ; BasFindLine — Find a program line by line number
0004AAr 2               ; ----------------------------------------------------------------------------
0004AAr 2               ; Input:  BAS_LINENUM = target line number (16-bit)
0004AAr 2               ; Output: Carry set if found, clear if not found
0004AAr 2               ;         BAS_TMP1 = pointer to line (if found) or insertion point (if not)
0004AAr 2               ; Modifies: A, Y, Flags, BAS_TMP1
0004AAr 2               
0004AAr 2               BasFindLine:
0004AAr 2  A9 00          lda #<BAS_PRG_START
0004ACr 2  85 0E          sta BAS_TMP1
0004AEr 2  A9 08          lda #>BAS_PRG_START
0004B0r 2  85 0F          sta BAS_TMP1 + 1
0004B2r 2               
0004B2r 2               @FindLoop:
0004B2r 2                 ; Check if at end of program (TMP1 == PRGEND)
0004B2r 2  A5 0E          lda BAS_TMP1
0004B4r 2  C5 12          cmp BAS_PRGEND
0004B6r 2  D0 06          bne @FindNotEnd
0004B8r 2  A5 0F          lda BAS_TMP1 + 1
0004BAr 2  C5 13          cmp BAS_PRGEND + 1
0004BCr 2  F0 3A          beq @FindNotFound              ; End of program
0004BEr 2               @FindNotEnd:
0004BEr 2               
0004BEr 2                 ; Compare this line's number with target
0004BEr 2  A0 02          ldy #LINE_NUM
0004C0r 2  B1 0E          lda (BAS_TMP1),y
0004C2r 2  C5 08          cmp BAS_LINENUM
0004C4r 2  D0 07          bne @FindNotEqual
0004C6r 2  C8             iny
0004C7r 2  B1 0E          lda (BAS_TMP1),y
0004C9r 2  C5 09          cmp BAS_LINENUM + 1
0004CBr 2  F0 29          beq @FindFound                 ; Exact match
0004CDr 2               
0004CDr 2               @FindNotEqual:
0004CDr 2                 ; Check if this line number > target (past where it would be)
0004CDr 2  A0 03          ldy #LINE_NUM + 1
0004CFr 2  A5 09          lda BAS_LINENUM + 1
0004D1r 2  D1 0E          cmp (BAS_TMP1),y
0004D3r 2  90 23          bcc @FindNotFound              ; Target high < line high — not found
0004D5r 2  D0 07          bne @FindAdvance               ; Target high > line high — keep looking
0004D7r 2  88             dey
0004D8r 2  A5 08          lda BAS_LINENUM
0004DAr 2  D1 0E          cmp (BAS_TMP1),y
0004DCr 2  90 1A          bcc @FindNotFound              ; Target < line — not found
0004DEr 2               
0004DEr 2               @FindAdvance:
0004DEr 2                 ; Move to next line by scanning for null terminator
0004DEr 2  A0 04          ldy #LINE_PAYLOAD
0004E0r 2               @FindScan:
0004E0r 2  B1 0E          lda (BAS_TMP1),y
0004E2r 2  F0 03          beq @FindScanDone
0004E4r 2  C8             iny
0004E5r 2  80 F9          bra @FindScan
0004E7r 2               @FindScanDone:
0004E7r 2  C8             iny                            ; Past null
0004E8r 2  98             tya
0004E9r 2  18             clc
0004EAr 2  65 0E          adc BAS_TMP1
0004ECr 2  85 0E          sta BAS_TMP1
0004EEr 2  A9 00          lda #$00
0004F0r 2  65 0F          adc BAS_TMP1 + 1
0004F2r 2  85 0F          sta BAS_TMP1 + 1
0004F4r 2  80 BC          bra @FindLoop
0004F6r 2               
0004F6r 2               @FindFound:
0004F6r 2  38             sec
0004F7r 2  60             rts
0004F8r 2               
0004F8r 2               @FindNotFound:
0004F8r 2  18             clc
0004F9r 2  60             rts
0004FAr 2               
0004FAr 2               ; ----------------------------------------------------------------------------
0004FAr 2               ; BasRelink — Rebuild all next-line pointers from PROGRAM_START
0004FAr 2               ; ----------------------------------------------------------------------------
0004FAr 2               ; Walks program lines, computes each line's length, sets next-pointer.
0004FAr 2               ; Modifies: A, X, Y, Flags, BAS_TMP2
0004FAr 2               
0004FAr 2               BasRelink:
0004FAr 2  A9 00          lda #<BAS_PRG_START
0004FCr 2  85 10          sta BAS_TMP2
0004FEr 2  A9 08          lda #>BAS_PRG_START
000500r 2  85 11          sta BAS_TMP2 + 1
000502r 2               
000502r 2               @RelinkLoop:
000502r 2                 ; Check if at PRGEND
000502r 2  A5 10          lda BAS_TMP2
000504r 2  C5 12          cmp BAS_PRGEND
000506r 2  D0 06          bne @RelinkNotEnd
000508r 2  A5 11          lda BAS_TMP2 + 1
00050Ar 2  C5 13          cmp BAS_PRGEND + 1
00050Cr 2  F0 42          beq @RelinkDone
00050Er 2               
00050Er 2               @RelinkNotEnd:
00050Er 2                 ; Find length of this line by scanning for null terminator in payload
00050Er 2  A0 04          ldy #LINE_PAYLOAD
000510r 2               @RelinkScan:
000510r 2  B1 10          lda (BAS_TMP2),y
000512r 2  F0 03          beq @RelinkFoundNull
000514r 2  C8             iny
000515r 2  80 F9          bra @RelinkScan
000517r 2               
000517r 2               @RelinkFoundNull:
000517r 2                 ; Y = offset of null terminator. Line length = Y + 1.
000517r 2  C8             iny                            ; Include the null byte
000518r 2                 ; Next line address = BAS_TMP2 + Y
000518r 2  98             tya
000519r 2  18             clc
00051Ar 2  65 10          adc BAS_TMP2
00051Cr 2  85 1C          sta BAS_SCRATCH
00051Er 2  A9 00          lda #$00
000520r 2  65 11          adc BAS_TMP2 + 1
000522r 2  85 1D          sta BAS_SCRATCH + 1
000524r 2               
000524r 2                 ; Check if next line is at or past PRGEND — if so, write $0000
000524r 2  A5 1C          lda BAS_SCRATCH
000526r 2  C5 12          cmp BAS_PRGEND
000528r 2  D0 11          bne @RelinkWrite
00052Ar 2  A5 1D          lda BAS_SCRATCH + 1
00052Cr 2  C5 13          cmp BAS_PRGEND + 1
00052Er 2  D0 0B          bne @RelinkWrite
000530r 2                 ; At PRGEND — write end-of-program sentinel
000530r 2  A0 00          ldy #LINE_NEXT
000532r 2  A9 00          lda #$00
000534r 2  91 10          sta (BAS_TMP2),y
000536r 2  C8             iny
000537r 2  91 10          sta (BAS_TMP2),y
000539r 2  80 15          bra @RelinkDone
00053Br 2               
00053Br 2               @RelinkWrite:
00053Br 2                 ; Write next-line pointer
00053Br 2  A0 00          ldy #LINE_NEXT
00053Dr 2  A5 1C          lda BAS_SCRATCH
00053Fr 2  91 10          sta (BAS_TMP2),y
000541r 2  C8             iny
000542r 2  A5 1D          lda BAS_SCRATCH + 1
000544r 2  91 10          sta (BAS_TMP2),y
000546r 2               
000546r 2                 ; Advance to next line
000546r 2  A5 1C          lda BAS_SCRATCH
000548r 2  85 10          sta BAS_TMP2
00054Ar 2  A5 1D          lda BAS_SCRATCH + 1
00054Cr 2  85 11          sta BAS_TMP2 + 1
00054Er 2  80 B2          bra @RelinkLoop
000550r 2               
000550r 2               @RelinkDone:
000550r 2                 ; Write end sentinel at PRGEND
000550r 2  A0 00          ldy #$00
000552r 2  A9 00          lda #$00
000554r 2  91 12          sta (BAS_PRGEND),y
000556r 2  C8             iny
000557r 2  91 12          sta (BAS_PRGEND),y
000559r 2  60             rts
00055Ar 2               
00055Ar 2               ; ============================================================================
00055Ar 2               ; BasParseInt — Parse decimal integer from tokenized text at TXTPTR
00055Ar 2               ; ============================================================================
00055Ar 2               ; Input:  BAS_TXTPTR points at text
00055Ar 2               ; Output: BAS_ACC = parsed 16-bit value, BAS_TXTPTR advanced
00055Ar 2               ;         Carry set on error (no digits found)
00055Ar 2               ; Modifies: A, X, Y, Flags, BAS_NUMTMP, BAS_SCRATCH
00055Ar 2               
00055Ar 2               BasParseInt:
00055Ar 2  64 22          stz BAS_NUMTMP
00055Cr 2  64 23          stz BAS_NUMTMP + 1
00055Er 2  A2 00          ldx #$00                       ; Digit count
000560r 2               
000560r 2  A0 00          ldy #$00
000562r 2               
000562r 2               @ParseLoop:
000562r 2  B1 04          lda (BAS_TXTPTR),y
000564r 2  38             sec
000565r 2  E9 30          sbc #'0'
000567r 2  90 38          bcc @ParseDone                 ; Not a digit
000569r 2  C9 0A          cmp #10
00056Br 2  B0 34          bcs @ParseDone                 ; Not a digit
00056Dr 2               
00056Dr 2                 ; Have a digit — multiply accumulator by 10 and add
00056Dr 2  48             pha                            ; Save digit
00056Er 2               
00056Er 2                 ; NUMTMP × 10 = (NUMTMP × 8) + (NUMTMP × 2)
00056Er 2  A5 22          lda BAS_NUMTMP
000570r 2  85 1C          sta BAS_SCRATCH
000572r 2  A5 23          lda BAS_NUMTMP + 1
000574r 2  85 1D          sta BAS_SCRATCH + 1
000576r 2               
000576r 2                 ; ×2
000576r 2  06 22          asl BAS_NUMTMP
000578r 2  26 23          rol BAS_NUMTMP + 1
00057Ar 2                 ; ×8 from original (3 shifts)
00057Ar 2  06 1C          asl BAS_SCRATCH
00057Cr 2  26 1D          rol BAS_SCRATCH + 1
00057Er 2  06 1C          asl BAS_SCRATCH
000580r 2  26 1D          rol BAS_SCRATCH + 1
000582r 2  06 1C          asl BAS_SCRATCH
000584r 2  26 1D          rol BAS_SCRATCH + 1
000586r 2               
000586r 2                 ; ×2 + ×8 = ×10
000586r 2  18             clc
000587r 2  A5 22          lda BAS_NUMTMP
000589r 2  65 1C          adc BAS_SCRATCH
00058Br 2  85 22          sta BAS_NUMTMP
00058Dr 2  A5 23          lda BAS_NUMTMP + 1
00058Fr 2  65 1D          adc BAS_SCRATCH + 1
000591r 2  85 23          sta BAS_NUMTMP + 1
000593r 2               
000593r 2                 ; Add digit
000593r 2  68             pla
000594r 2  18             clc
000595r 2  65 22          adc BAS_NUMTMP
000597r 2  85 22          sta BAS_NUMTMP
000599r 2  90 02          bcc @ParseNoCarry
00059Br 2  E6 23          inc BAS_NUMTMP + 1
00059Dr 2               @ParseNoCarry:
00059Dr 2  E8             inx                            ; Count digit
00059Er 2  C8             iny                            ; Advance past digit
00059Fr 2  80 C1          bra @ParseLoop
0005A1r 2               
0005A1r 2               @ParseDone:
0005A1r 2                 ; Advance TXTPTR by Y
0005A1r 2  98             tya
0005A2r 2  18             clc
0005A3r 2  65 04          adc BAS_TXTPTR
0005A5r 2  85 04          sta BAS_TXTPTR
0005A7r 2  A9 00          lda #$00
0005A9r 2  65 05          adc BAS_TXTPTR + 1
0005ABr 2  85 05          sta BAS_TXTPTR + 1
0005ADr 2               
0005ADr 2                 ; Copy result to ACC
0005ADr 2  A5 22          lda BAS_NUMTMP
0005AFr 2  85 0A          sta BAS_ACC
0005B1r 2  A5 23          lda BAS_NUMTMP + 1
0005B3r 2  85 0B          sta BAS_ACC + 1
0005B5r 2               
0005B5r 2                 ; Set carry if no digits found
0005B5r 2  E0 00          cpx #$00
0005B7r 2  F0 02          beq @ParseError
0005B9r 2  18             clc
0005BAr 2  60             rts
0005BBr 2               
0005BBr 2               @ParseError:
0005BBr 2  38             sec
0005BCr 2  60             rts
0005BDr 2               
0005BDr 2               ; BasNibble — Convert ASCII hex character in A to nibble value (0-15)
0005BDr 2               ; Input:  A = ASCII character ('0'-'9', 'A'-'F')
0005BDr 2               ; Output: A = nibble value 0-15, carry clear on success
0005BDr 2               ;         Carry set if character is not a valid hex digit
0005BDr 2               ; Modifies: Flags, A
0005BDr 2               BasNibble:
0005BDr 2  C9 30          cmp #'0'
0005BFr 2  90 16          bcc @NibbleInvalid
0005C1r 2  C9 3A          cmp #'9' + 1
0005C3r 2  B0 05          bcs @NibbleTryAlpha
0005C5r 2  38             sec
0005C6r 2  E9 30          sbc #'0'
0005C8r 2  18             clc
0005C9r 2  60             rts
0005CAr 2               @NibbleTryAlpha:
0005CAr 2  C9 41          cmp #'A'
0005CCr 2  90 09          bcc @NibbleInvalid
0005CEr 2  C9 47          cmp #'F' + 1
0005D0r 2  B0 05          bcs @NibbleInvalid
0005D2r 2  38             sec
0005D3r 2  E9 37          sbc #'A' - 10
0005D5r 2  18             clc
0005D6r 2  60             rts
0005D7r 2               @NibbleInvalid:
0005D7r 2  38             sec
0005D8r 2  60             rts
0005D9r 2               
0005D9r 2               ; ============================================================================
0005D9r 2               ; BasSkipSpaces — Advance TXTPTR past spaces
0005D9r 2               ; ============================================================================
0005D9r 2               ; Modifies: A, Y, Flags
0005D9r 2               
0005D9r 2               BasSkipSpaces:
0005D9r 2  A0 00          ldy #$00
0005DBr 2               @SkipLoop:
0005DBr 2  B1 04          lda (BAS_TXTPTR),y
0005DDr 2  C9 20          cmp #CH_SPACE
0005DFr 2  D0 03          bne @SkipDone
0005E1r 2  C8             iny
0005E2r 2  80 F7          bra @SkipLoop
0005E4r 2               @SkipDone:
0005E4r 2                 ; Advance TXTPTR by Y
0005E4r 2  98             tya
0005E5r 2  18             clc
0005E6r 2  65 04          adc BAS_TXTPTR
0005E8r 2  85 04          sta BAS_TXTPTR
0005EAr 2  A9 00          lda #$00
0005ECr 2  65 05          adc BAS_TXTPTR + 1
0005EEr 2  85 05          sta BAS_TXTPTR + 1
0005F0r 2  60             rts
0005F1r 2               
0005F1r 2               ; ============================================================================
0005F1r 2               ; BasGetTokChar — Get current token byte at TXTPTR without advancing
0005F1r 2               ; ============================================================================
0005F1r 2               ; Output: A = byte at TXTPTR, Z flag set if null
0005F1r 2               ; Modifies: A, Y, Flags
0005F1r 2               
0005F1r 2               BasGetTokChar:
0005F1r 2  A0 00          ldy #$00
0005F3r 2  B1 04          lda (BAS_TXTPTR),y
0005F5r 2  60             rts
0005F6r 2               
0005F6r 2               ; ============================================================================
0005F6r 2               ; BasAdvTxtPtr — Advance TXTPTR by 1
0005F6r 2               ; ============================================================================
0005F6r 2               ; Modifies: Flags
0005F6r 2               
0005F6r 2               BasAdvTxtPtr:
0005F6r 2  E6 04          inc BAS_TXTPTR
0005F8r 2  D0 02          bne @Done
0005FAr 2  E6 05          inc BAS_TXTPTR + 1
0005FCr 2               @Done:
0005FCr 2  60             rts
0005FDr 2               
0005FDr 2               ; ============================================================================
0005FDr 2               ; BasExpectChar — Expect a specific character at TXTPTR, error if not found
0005FDr 2               ; ============================================================================
0005FDr 2               ; Input: A = expected character
0005FDr 2               ; Modifies: A, Y, Flags
0005FDr 2               
0005FDr 2               BasExpectChar:
0005FDr 2  A0 00          ldy #$00
0005FFr 2  D1 04          cmp (BAS_TXTPTR),y             ; Compare expected (A) with actual
000601r 2  D0 04          bne @SyntaxErr
000603r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip the character
000606r 2  60             rts
000607r 2               @SyntaxErr:
000607r 2  A9 00          lda #ERR_SYNTAX
000609r 2  4C rr rr       jmp BasError
00060Cr 2               
00060Cr 2               ; ============================================================================
00060Cr 2               ; BasCheckBreak — Check for Ctrl+C during program execution
00060Cr 2               ; ============================================================================
00060Cr 2               ; Call at the top of each line in RUN mode.
00060Cr 2               ; Modifies: A, Flags
00060Cr 2               
00060Cr 2               BasCheckBreak:
00060Cr 2  A5 17          lda BAS_FLAGS
00060Er 2  29 01          and #BAS_FLAG_RUN
000610r 2  F0 13          beq @NoBrk                    ; Not running — skip check
000612r 2  20 rr rr       jsr BufferSize                 ; Non-echoing buffer check
000615r 2  F0 0E          beq @NoBrk                    ; No character available
000617r 2  20 rr rr       jsr ReadBuffer                 ; Read without echo
00061Ar 2  C9 03          cmp #CH_CTRLC
00061Cr 2  F0 08          beq @Break
00061Er 2  C9 1B          cmp #CH_ESC
000620r 2  F0 04          beq @Break
000622r 2  8D 0E 03       sta BAS_PENDKEY               ; Save non-break char for INKEY
000625r 2               @NoBrk:
000625r 2  60             rts
000626r 2               @Break:
000626r 2                 ; Save continuation state so CONT works after Ctrl+C
000626r 2  A5 06          lda BAS_CURLINE
000628r 2  8D 1C 03       sta BAS_STOPLINE
00062Br 2  A5 07          lda BAS_CURLINE + 1
00062Dr 2  8D 1D 03       sta BAS_STOPLINE + 1
000630r 2  A5 04          lda BAS_TXTPTR
000632r 2  8D 1E 03       sta BAS_STOPTXT
000635r 2  A5 05          lda BAS_TXTPTR + 1
000637r 2  8D 1F 03       sta BAS_STOPTXT + 1
00063Ar 2  A9 09          lda #ERR_BREAK
00063Cr 2  4C rr rr       jmp BasError
00063Fr 2               
00063Fr 2               ; ============================================================================
00063Fr 2               ; Error Handling
00063Fr 2               ; ============================================================================
00063Fr 2               
00063Fr 2               ; BasError — Print error message and return to REPL
00063Fr 2               ; Input: A = error code (ERR_* constant)
00063Fr 2               ; Never returns — jumps to BasMainLoop
00063Fr 2               
00063Fr 2               BasError:
00063Fr 2  48             pha                            ; Save error code
000640r 2               
000640r 2  20 rr rr       jsr BasPrintCRLF
000643r 2               
000643r 2  A9 3F          lda #'?'
000645r 2  20 rr rr       jsr Chrout
000648r 2               
000648r 2                 ; Look up error message pointer
000648r 2  68             pla
000649r 2  0A             asl                            ; ×2 for word-sized table index
00064Ar 2  AA             tax
00064Br 2  BD rr rr       lda BasErrTable,x
00064Er 2  85 0E          sta BAS_TMP1
000650r 2  BD rr rr       lda BasErrTable+1,x
000653r 2  85 0F          sta BAS_TMP1 + 1
000655r 2               
000655r 2                 ; Print error message
000655r 2  20 rr rr       jsr BasPrintStr
000658r 2               
000658r 2                 ; Print " ERROR" (skip for BREAK)
000658r 2  E0 12          cpx #(ERR_BREAK * 2)
00065Ar 2  F0 0B          beq @SkipErrorWord
00065Cr 2  A9 rr          lda #<BasStrError
00065Er 2  85 0E          sta BAS_TMP1
000660r 2  A9 rr          lda #>BasStrError
000662r 2  85 0F          sta BAS_TMP1 + 1
000664r 2  20 rr rr       jsr BasPrintStr
000667r 2               @SkipErrorWord:
000667r 2               
000667r 2                 ; If running, print " IN " + line number
000667r 2  A5 17          lda BAS_FLAGS
000669r 2  29 01          and #BAS_FLAG_RUN
00066Br 2  F0 16          beq @ErrDone
00066Dr 2               
00066Dr 2  A9 rr          lda #<BasStrIn
00066Fr 2  85 0E          sta BAS_TMP1
000671r 2  A9 rr          lda #>BasStrIn
000673r 2  85 0F          sta BAS_TMP1 + 1
000675r 2  20 rr rr       jsr BasPrintStr
000678r 2               
000678r 2                 ; Print current line number
000678r 2  A5 08          lda BAS_LINENUM
00067Ar 2  85 0A          sta BAS_ACC
00067Cr 2  A5 09          lda BAS_LINENUM + 1
00067Er 2  85 0B          sta BAS_ACC + 1
000680r 2  20 rr rr       jsr BasPrintInt
000683r 2               
000683r 2               @ErrDone:
000683r 2  20 rr rr       jsr BasPrintCRLF
000686r 2               
000686r 2                 ; Reset state and return to REPL
000686r 2  64 17          stz BAS_FLAGS
000688r 2  64 1A          stz BAS_GOSUBSP
00068Ar 2  64 1B          stz BAS_FORSP
00068Cr 2               
00068Cr 2                 ; Reset stack pointer to avoid stack corruption from nested calls
00068Cr 2  A2 FF          ldx #$FF
00068Er 2  9A             txs
00068Fr 2               
00068Fr 2  4C rr rr       jmp BasMainLoop
000692r 2               
000692r 2               ; Error message pointer table
000692r 2               BasErrTable:
000692r 2  rr rr          .word BasErrSyntax             ; 0 - SYNTAX
000694r 2  rr rr          .word BasErrUndef              ; 1 - UNDEF'D LINE
000696r 2  rr rr          .word BasErrType               ; 2 - TYPE MISMATCH
000698r 2  rr rr          .word BasErrMem                ; 3 - OUT OF MEMORY
00069Ar 2  rr rr          .word BasErrRetGosub           ; 4 - RETURN W/O GOSUB
00069Cr 2  rr rr          .word BasErrNextFor            ; 5 - NEXT W/O FOR
00069Er 2  rr rr          .word BasErrDivZero            ; 6 - DIVISION BY ZERO
0006A0r 2  rr rr          .word BasErrOverflow           ; 7 - OVERFLOW
0006A2r 2  rr rr          .word BasErrIllegal            ; 8 - ILLEGAL QUANTITY
0006A4r 2  rr rr          .word BasErrBreak              ; 9 - BREAK
0006A6r 2  rr rr          .word BasErrOutOfData           ; 10 - OUT OF DATA
0006A8r 2  rr rr          .word BasErrCantCont            ; 11 - CAN'T CONTINUE
0006AAr 2  rr rr          .word BasErrRedim               ; 12 - REDIM'D ARRAY
0006ACr 2  rr rr          .word BasErrBadSub              ; 13 - BAD SUBSCRIPT
0006AEr 2               
0006AEr 2               ; Error message strings
0006AEr 2  53 59 4E 54  BasErrSyntax:    .byte "SYNTAX", $00
0006B2r 2  41 58 00     
0006B5r 2  55 4E 44 45  BasErrUndef:     .byte "UNDEF'D LINE", $00
0006B9r 2  46 27 44 20  
0006BDr 2  4C 49 4E 45  
0006C2r 2  54 59 50 45  BasErrType:      .byte "TYPE MISMATCH", $00
0006C6r 2  20 4D 49 53  
0006CAr 2  4D 41 54 43  
0006D0r 2  4F 55 54 20  BasErrMem:       .byte "OUT OF MEMORY", $00
0006D4r 2  4F 46 20 4D  
0006D8r 2  45 4D 4F 52  
0006DEr 2  52 45 54 55  BasErrRetGosub:  .byte "RETURN W/O GOSUB", $00
0006E2r 2  52 4E 20 57  
0006E6r 2  2F 4F 20 47  
0006EFr 2  4E 45 58 54  BasErrNextFor:   .byte "NEXT W/O FOR", $00
0006F3r 2  20 57 2F 4F  
0006F7r 2  20 46 4F 52  
0006FCr 2  44 49 56 49  BasErrDivZero:   .byte "DIVISION BY ZERO", $00
000700r 2  53 49 4F 4E  
000704r 2  20 42 59 20  
00070Dr 2  4F 56 45 52  BasErrOverflow:  .byte "OVERFLOW", $00
000711r 2  46 4C 4F 57  
000715r 2  00           
000716r 2  49 4C 4C 45  BasErrIllegal:   .byte "ILLEGAL QUANTITY", $00
00071Ar 2  47 41 4C 20  
00071Er 2  51 55 41 4E  
000727r 2  42 52 45 41  BasErrBreak:     .byte "BREAK", $00
00072Br 2  4B 00        
00072Dr 2  4F 55 54 20  BasErrOutOfData: .byte "OUT OF DATA", $00
000731r 2  4F 46 20 44  
000735r 2  41 54 41 00  
000739r 2  43 41 4E 27  BasErrCantCont:  .byte "CAN'T CONTINUE", $00
00073Dr 2  54 20 43 4F  
000741r 2  4E 54 49 4E  
000748r 2  52 45 44 49  BasErrRedim:     .byte "REDIM'D ARRAY", $00
00074Cr 2  4D 27 44 20  
000750r 2  41 52 52 41  
000756r 2  42 41 44 20  BasErrBadSub:    .byte "BAD SUBSCRIPT", $00
00075Ar 2  53 55 42 53  
00075Er 2  43 52 49 50  
000764r 2               
000764r 2               ; ============================================================================
000764r 2               ; 16-Bit Math Routines
000764r 2               ; ============================================================================
000764r 2               
000764r 2               ; BasMathAdd — ACC = AUX + ACC
000764r 2               BasMathAdd:
000764r 2  18             clc
000765r 2  A5 0C          lda BAS_AUX
000767r 2  65 0A          adc BAS_ACC
000769r 2  85 0A          sta BAS_ACC
00076Br 2  A5 0D          lda BAS_AUX + 1
00076Dr 2  65 0B          adc BAS_ACC + 1
00076Fr 2  85 0B          sta BAS_ACC + 1
000771r 2  60             rts
000772r 2               
000772r 2               ; BasMathSub — ACC = AUX - ACC
000772r 2               BasMathSub:
000772r 2  38             sec
000773r 2  A5 0C          lda BAS_AUX
000775r 2  E5 0A          sbc BAS_ACC
000777r 2  85 0A          sta BAS_ACC
000779r 2  A5 0D          lda BAS_AUX + 1
00077Br 2  E5 0B          sbc BAS_ACC + 1
00077Dr 2  85 0B          sta BAS_ACC + 1
00077Fr 2  60             rts
000780r 2               
000780r 2               ; BasMathNeg — ACC = -ACC (two's complement)
000780r 2               BasMathNeg:
000780r 2  38             sec
000781r 2  A9 00          lda #$00
000783r 2  E5 0A          sbc BAS_ACC
000785r 2  85 0A          sta BAS_ACC
000787r 2  A9 00          lda #$00
000789r 2  E5 0B          sbc BAS_ACC + 1
00078Br 2  85 0B          sta BAS_ACC + 1
00078Dr 2  60             rts
00078Er 2               
00078Er 2               ; BasMathAbs — ACC = |ACC|
00078Er 2               BasMathAbs:
00078Er 2  A5 0B          lda BAS_ACC + 1
000790r 2  10 03          bpl @Done
000792r 2  4C rr rr       jmp BasMathNeg
000795r 2               @Done:
000795r 2  60             rts
000796r 2               
000796r 2               ; BasMathMul — ACC = AUX * ACC (16-bit signed)
000796r 2               ; Uses shift-and-add on magnitudes, applies sign separately
000796r 2               BasMathMul:
000796r 2                 ; Determine result sign
000796r 2  A5 0D          lda BAS_AUX + 1
000798r 2  45 0B          eor BAS_ACC + 1
00079Ar 2  85 20          sta BAS_SIGN                   ; Bit 7 = result sign
00079Cr 2               
00079Cr 2                 ; Make both operands positive
00079Cr 2  A5 0D          lda BAS_AUX + 1
00079Er 2  10 0D          bpl @AuxPos
0007A0r 2  38             sec
0007A1r 2  A9 00          lda #$00
0007A3r 2  E5 0C          sbc BAS_AUX
0007A5r 2  85 0C          sta BAS_AUX
0007A7r 2  A9 00          lda #$00
0007A9r 2  E5 0D          sbc BAS_AUX + 1
0007ABr 2  85 0D          sta BAS_AUX + 1
0007ADr 2               @AuxPos:
0007ADr 2  A5 0B          lda BAS_ACC + 1
0007AFr 2  10 03          bpl @AccPos
0007B1r 2  20 rr rr       jsr BasMathNeg
0007B4r 2               @AccPos:
0007B4r 2                 ; ACC = multiplier, AUX = multiplicand
0007B4r 2                 ; Result accumulates in SCRATCH:SCRATCH+1
0007B4r 2  64 1C          stz BAS_SCRATCH
0007B6r 2  64 1D          stz BAS_SCRATCH + 1
0007B8r 2  A2 10          ldx #16                        ; 16 bits
0007BAr 2               
0007BAr 2               @MulLoop:
0007BAr 2                 ; Shift multiplier (ACC) right
0007BAr 2  46 0B          lsr BAS_ACC + 1
0007BCr 2  66 0A          ror BAS_ACC
0007BEr 2  90 0D          bcc @MulNoAdd
0007C0r 2               
0007C0r 2                 ; Add multiplicand to result
0007C0r 2  18             clc
0007C1r 2  A5 1C          lda BAS_SCRATCH
0007C3r 2  65 0C          adc BAS_AUX
0007C5r 2  85 1C          sta BAS_SCRATCH
0007C7r 2  A5 1D          lda BAS_SCRATCH + 1
0007C9r 2  65 0D          adc BAS_AUX + 1
0007CBr 2  85 1D          sta BAS_SCRATCH + 1
0007CDr 2               
0007CDr 2               @MulNoAdd:
0007CDr 2                 ; Shift multiplicand left
0007CDr 2  06 0C          asl BAS_AUX
0007CFr 2  26 0D          rol BAS_AUX + 1
0007D1r 2  CA             dex
0007D2r 2  D0 E6          bne @MulLoop
0007D4r 2               
0007D4r 2                 ; Copy result
0007D4r 2  A5 1C          lda BAS_SCRATCH
0007D6r 2  85 0A          sta BAS_ACC
0007D8r 2  A5 1D          lda BAS_SCRATCH + 1
0007DAr 2  85 0B          sta BAS_ACC + 1
0007DCr 2               
0007DCr 2                 ; Apply sign
0007DCr 2  A5 20          lda BAS_SIGN
0007DEr 2  10 03          bpl @MulDone
0007E0r 2  4C rr rr       jmp BasMathNeg
0007E3r 2               @MulDone:
0007E3r 2  60             rts
0007E4r 2               
0007E4r 2               ; BasMathDiv — ACC = AUX / ACC, remainder in BAS_SCRATCH2
0007E4r 2               ; 16-bit signed division
0007E4r 2               BasMathDiv:
0007E4r 2                 ; Check for division by zero
0007E4r 2  A5 0A          lda BAS_ACC
0007E6r 2  05 0B          ora BAS_ACC + 1
0007E8r 2  D0 05          bne @DivNotZero
0007EAr 2  A9 06          lda #ERR_DIV_ZERO
0007ECr 2  4C rr rr       jmp BasError
0007EFr 2               
0007EFr 2               @DivNotZero:
0007EFr 2                 ; Determine result sign
0007EFr 2  A5 0D          lda BAS_AUX + 1
0007F1r 2  45 0B          eor BAS_ACC + 1
0007F3r 2  85 20          sta BAS_SIGN
0007F5r 2               
0007F5r 2                 ; Save remainder sign (same as dividend) on CPU stack
0007F5r 2  A5 0D          lda BAS_AUX + 1
0007F7r 2  48             pha
0007F8r 2               
0007F8r 2                 ; Make both positive
0007F8r 2  A5 0D          lda BAS_AUX + 1
0007FAr 2  10 0D          bpl @DivAuxPos
0007FCr 2  38             sec
0007FDr 2  A9 00          lda #$00
0007FFr 2  E5 0C          sbc BAS_AUX
000801r 2  85 0C          sta BAS_AUX
000803r 2  A9 00          lda #$00
000805r 2  E5 0D          sbc BAS_AUX + 1
000807r 2  85 0D          sta BAS_AUX + 1
000809r 2               @DivAuxPos:
000809r 2  A5 0B          lda BAS_ACC + 1
00080Br 2  10 03          bpl @DivAccPos
00080Dr 2  20 rr rr       jsr BasMathNeg
000810r 2               @DivAccPos:
000810r 2                 ; AUX = dividend, ACC = divisor
000810r 2                 ; Remainder in SCRATCH2
000810r 2  64 1E          stz BAS_SCRATCH2
000812r 2  64 1F          stz BAS_SCRATCH2 + 1
000814r 2               
000814r 2  A2 10          ldx #16
000816r 2               
000816r 2               @DivLoop:
000816r 2                 ; Shift dividend left into remainder
000816r 2  06 0C          asl BAS_AUX
000818r 2  26 0D          rol BAS_AUX + 1
00081Ar 2  26 1E          rol BAS_SCRATCH2
00081Cr 2  26 1F          rol BAS_SCRATCH2 + 1
00081Er 2               
00081Er 2                 ; Try subtract divisor from remainder
00081Er 2  38             sec
00081Fr 2  A5 1E          lda BAS_SCRATCH2
000821r 2  E5 0A          sbc BAS_ACC
000823r 2  85 1C          sta BAS_SCRATCH
000825r 2  A5 1F          lda BAS_SCRATCH2 + 1
000827r 2  E5 0B          sbc BAS_ACC + 1
000829r 2               
000829r 2  90 08          bcc @DivNoSub
00082Br 2               
00082Br 2                 ; Subtraction succeeded — set quotient bit
00082Br 2  85 1F          sta BAS_SCRATCH2 + 1
00082Dr 2  A5 1C          lda BAS_SCRATCH
00082Fr 2  85 1E          sta BAS_SCRATCH2
000831r 2  E6 0C          inc BAS_AUX                    ; Set low bit of quotient
000833r 2               
000833r 2               @DivNoSub:
000833r 2  CA             dex
000834r 2  D0 E0          bne @DivLoop
000836r 2               
000836r 2                 ; Quotient is in AUX, remainder in SCRATCH2
000836r 2  A5 0C          lda BAS_AUX
000838r 2  85 0A          sta BAS_ACC
00083Ar 2  A5 0D          lda BAS_AUX + 1
00083Cr 2  85 0B          sta BAS_ACC + 1
00083Er 2               
00083Er 2                 ; Apply sign to quotient
00083Er 2  A5 20          lda BAS_SIGN
000840r 2  10 03          bpl @DivQuotPos
000842r 2  20 rr rr       jsr BasMathNeg
000845r 2               @DivQuotPos:
000845r 2                 ; Apply sign to remainder (same sign as dividend)
000845r 2  68             pla                            ; Remainder sign (was dividend's high byte)
000846r 2  10 0D          bpl @DivDone
000848r 2                 ; Negate remainder
000848r 2  38             sec
000849r 2  A9 00          lda #$00
00084Br 2  E5 1E          sbc BAS_SCRATCH2
00084Dr 2  85 1E          sta BAS_SCRATCH2
00084Fr 2  A9 00          lda #$00
000851r 2  E5 1F          sbc BAS_SCRATCH2 + 1
000853r 2  85 1F          sta BAS_SCRATCH2 + 1
000855r 2               @DivDone:
000855r 2  60             rts
000856r 2               
000856r 2               ; ============================================================================
000856r 2               ; Expression Evaluator — Recursive Descent
000856r 2               ; ============================================================================
000856r 2               ; Result always in BAS_ACC (16-bit signed).
000856r 2               ; TXTPTR is advanced past consumed tokens.
000856r 2               
000856r 2               ; BasExpr — Top level: handle OR
000856r 2               BasExpr:
000856r 2  20 rr rr       jsr BasExprAnd
000859r 2               @OrLoop:
000859r 2  20 rr rr       jsr BasSkipSpaces
00085Cr 2  20 rr rr       jsr BasGetTokChar
00085Fr 2  C9 98          cmp #TOK_OR
000861r 2  D0 2E          bne @OrDone
000863r 2  20 rr rr       jsr BasAdvTxtPtr
000866r 2  A5 0A          lda BAS_ACC
000868r 2  48             pha
000869r 2  A5 0B          lda BAS_ACC + 1
00086Br 2  48             pha
00086Cr 2  20 rr rr       jsr BasExprAnd
00086Fr 2                 ; Pop left operand into AUX
00086Fr 2  68             pla
000870r 2  85 0D          sta BAS_AUX + 1
000872r 2  68             pla
000873r 2  85 0C          sta BAS_AUX
000875r 2                 ; OR: result = (AUX != 0) || (ACC != 0) ? 1 : 0
000875r 2  A5 0C          lda BAS_AUX
000877r 2  05 0D          ora BAS_AUX + 1
000879r 2  F0 04          beq @OrRight
00087Br 2  A9 01          lda #$01
00087Dr 2  80 0C          bra @OrStore
00087Fr 2               @OrRight:
00087Fr 2  A5 0A          lda BAS_ACC
000881r 2  05 0B          ora BAS_ACC + 1
000883r 2  F0 04          beq @OrFalse
000885r 2  A9 01          lda #$01
000887r 2  80 02          bra @OrStore
000889r 2               @OrFalse:
000889r 2  A9 00          lda #$00
00088Br 2               @OrStore:
00088Br 2  85 0A          sta BAS_ACC
00088Dr 2  64 0B          stz BAS_ACC + 1
00088Fr 2  80 C8          bra @OrLoop
000891r 2               @OrDone:
000891r 2  60             rts
000892r 2               
000892r 2               ; BasExprAnd — Handle AND
000892r 2               BasExprAnd:
000892r 2  20 rr rr       jsr BasExprNot
000895r 2               @AndLoop:
000895r 2  20 rr rr       jsr BasSkipSpaces
000898r 2  20 rr rr       jsr BasGetTokChar
00089Br 2  C9 97          cmp #TOK_AND
00089Dr 2  D0 2C          bne @AndDone
00089Fr 2  20 rr rr       jsr BasAdvTxtPtr
0008A2r 2  A5 0A          lda BAS_ACC
0008A4r 2  48             pha
0008A5r 2  A5 0B          lda BAS_ACC + 1
0008A7r 2  48             pha
0008A8r 2  20 rr rr       jsr BasExprNot
0008ABr 2  68             pla
0008ACr 2  85 0D          sta BAS_AUX + 1
0008AEr 2  68             pla
0008AFr 2  85 0C          sta BAS_AUX
0008B1r 2                 ; AND: both nonzero = 1, else 0
0008B1r 2  A5 0C          lda BAS_AUX
0008B3r 2  05 0D          ora BAS_AUX + 1
0008B5r 2  F0 0E          beq @AndFalse
0008B7r 2  A5 0A          lda BAS_ACC
0008B9r 2  05 0B          ora BAS_ACC + 1
0008BBr 2  F0 08          beq @AndFalse
0008BDr 2  A9 01          lda #$01
0008BFr 2  64 0B          stz BAS_ACC + 1
0008C1r 2  85 0A          sta BAS_ACC
0008C3r 2  80 D0          bra @AndLoop
0008C5r 2               @AndFalse:
0008C5r 2  64 0A          stz BAS_ACC
0008C7r 2  64 0B          stz BAS_ACC + 1
0008C9r 2  80 CA          bra @AndLoop
0008CBr 2               @AndDone:
0008CBr 2  60             rts
0008CCr 2               
0008CCr 2               ; BasExprNot — Handle NOT (unary prefix)
0008CCr 2               BasExprNot:
0008CCr 2  20 rr rr       jsr BasSkipSpaces
0008CFr 2  20 rr rr       jsr BasGetTokChar
0008D2r 2  C9 96          cmp #TOK_NOT
0008D4r 2  D0 18          bne @NotSkip
0008D6r 2  20 rr rr       jsr BasAdvTxtPtr
0008D9r 2  20 rr rr       jsr BasExprCmp
0008DCr 2                 ; NOT: 0 -> 1, nonzero -> 0
0008DCr 2  A5 0A          lda BAS_ACC
0008DEr 2  05 0B          ora BAS_ACC + 1
0008E0r 2  F0 05          beq @NotTrue
0008E2r 2  64 0A          stz BAS_ACC
0008E4r 2  64 0B          stz BAS_ACC + 1
0008E6r 2  60             rts
0008E7r 2               @NotTrue:
0008E7r 2  A9 01          lda #$01
0008E9r 2  85 0A          sta BAS_ACC
0008EBr 2  64 0B          stz BAS_ACC + 1
0008EDr 2  60             rts
0008EEr 2               @NotSkip:
0008EEr 2  4C rr rr       jmp BasExprCmp
0008F1r 2               
0008F1r 2               ; BasExprCmp — Handle comparison: =, <>, <, >, <=, >=
0008F1r 2               BasExprCmp:
0008F1r 2  20 rr rr       jsr BasExprAdd
0008F4r 2  20 rr rr       jsr BasSkipSpaces
0008F7r 2  20 rr rr       jsr BasGetTokChar
0008FAr 2               
0008FAr 2                 ; Check each comparison operator
0008FAr 2  C9 3D          cmp #CH_EQUALS
0008FCr 2  F0 15          beq @CmpEQ
0008FEr 2  C9 3C          cmp #CH_LESS
000900r 2  F0 39          beq @CmpLT
000902r 2  C9 3E          cmp #CH_GREATER
000904r 2  F0 42          beq @CmpGT
000906r 2  C9 9C          cmp #TOK_NE
000908r 2  F0 1D          beq @CmpNE
00090Ar 2  C9 9B          cmp #TOK_LE
00090Cr 2  F0 49          beq @CmpLE
00090Er 2  C9 9A          cmp #TOK_GE
000910r 2  F0 54          beq @CmpGE
000912r 2  60             rts                            ; No comparison operator
000913r 2               
000913r 2               @CmpEQ:
000913r 2  20 rr rr       jsr BasAdvTxtPtr
000916r 2  20 rr rr       jsr @CmpPushEvalRight
000919r 2                 ; Equal: ACC == AUX
000919r 2  A5 0A          lda BAS_ACC
00091Br 2  C5 0C          cmp BAS_AUX
00091Dr 2  D0 5B          bne @CmpSetFalse
00091Fr 2  A5 0B          lda BAS_ACC + 1
000921r 2  C5 0D          cmp BAS_AUX + 1
000923r 2  D0 55          bne @CmpSetFalse
000925r 2  80 4C          bra @CmpSetTrue
000927r 2               
000927r 2               @CmpNE:
000927r 2  20 rr rr       jsr BasAdvTxtPtr
00092Ar 2  20 rr rr       jsr @CmpPushEvalRight
00092Dr 2  A5 0A          lda BAS_ACC
00092Fr 2  C5 0C          cmp BAS_AUX
000931r 2  D0 40          bne @CmpSetTrue
000933r 2  A5 0B          lda BAS_ACC + 1
000935r 2  C5 0D          cmp BAS_AUX + 1
000937r 2  D0 3A          bne @CmpSetTrue
000939r 2  80 3F          bra @CmpSetFalse
00093Br 2               
00093Br 2               @CmpLT:
00093Br 2  20 rr rr       jsr BasAdvTxtPtr
00093Er 2  20 rr rr       jsr @CmpPushEvalRight
000941r 2  20 rr rr       jsr BasCmpAuxAcc
000944r 2  30 2D          bmi @CmpSetTrue
000946r 2  80 32          bra @CmpSetFalse
000948r 2               
000948r 2               @CmpGT:
000948r 2  20 rr rr       jsr BasAdvTxtPtr
00094Br 2  20 rr rr       jsr @CmpPushEvalRight
00094Er 2  20 rr rr       jsr BasCmpAuxAcc
000951r 2  F0 27          beq @CmpSetFalse
000953r 2  10 1E          bpl @CmpSetTrue
000955r 2  80 23          bra @CmpSetFalse
000957r 2               
000957r 2               @CmpLE:
000957r 2  20 rr rr       jsr BasAdvTxtPtr
00095Ar 2  20 rr rr       jsr @CmpPushEvalRight
00095Dr 2  20 rr rr       jsr BasCmpAuxAcc
000960r 2  30 11          bmi @CmpSetTrue
000962r 2  F0 0F          beq @CmpSetTrue
000964r 2  80 14          bra @CmpSetFalse
000966r 2               
000966r 2               @CmpGE:
000966r 2  20 rr rr       jsr BasAdvTxtPtr
000969r 2  20 rr rr       jsr @CmpPushEvalRight
00096Cr 2  20 rr rr       jsr BasCmpAuxAcc
00096Fr 2  10 02          bpl @CmpSetTrue
000971r 2  80 07          bra @CmpSetFalse
000973r 2               
000973r 2               @CmpSetTrue:
000973r 2  A9 01          lda #$01
000975r 2  85 0A          sta BAS_ACC
000977r 2  64 0B          stz BAS_ACC + 1
000979r 2  60             rts
00097Ar 2               @CmpSetFalse:
00097Ar 2  64 0A          stz BAS_ACC
00097Cr 2  64 0B          stz BAS_ACC + 1
00097Er 2  60             rts
00097Fr 2               
00097Fr 2               ; Helper: push left, evaluate right into ACC, pop left into AUX
00097Fr 2               @CmpPushEvalRight:
00097Fr 2  A5 0A          lda BAS_ACC
000981r 2  48             pha
000982r 2  A5 0B          lda BAS_ACC + 1
000984r 2  48             pha
000985r 2  20 rr rr       jsr BasExprAdd
000988r 2  68             pla
000989r 2  85 0D          sta BAS_AUX + 1
00098Br 2  68             pla
00098Cr 2  85 0C          sta BAS_AUX
00098Er 2  60             rts
00098Fr 2               
00098Fr 2               ; BasCmpAuxAcc — Signed compare AUX vs ACC
00098Fr 2               ; Returns: N flag set if AUX < ACC, Z if equal, N clear & Z clear if AUX > ACC
00098Fr 2               BasCmpAuxAcc:
00098Fr 2                 ; Compare high bytes first (signed)
00098Fr 2  A5 0D          lda BAS_AUX + 1
000991r 2  38             sec
000992r 2  E5 0B          sbc BAS_ACC + 1
000994r 2  50 02          bvc @CmpNoOvf
000996r 2  49 80          eor #$80                       ; Fix sign on overflow
000998r 2               @CmpNoOvf:
000998r 2  30 0D          bmi @CmpLess
00099Ar 2  D0 08          bne @CmpGreater
00099Cr 2                 ; High bytes equal — compare low bytes (unsigned)
00099Cr 2  A5 0C          lda BAS_AUX
00099Er 2  C5 0A          cmp BAS_ACC
0009A0r 2  F0 08          beq @CmpEqual
0009A2r 2  90 03          bcc @CmpLess
0009A4r 2               @CmpGreater:
0009A4r 2  A9 01          lda #$01                       ; Positive, non-zero
0009A6r 2  60             rts
0009A7r 2               @CmpLess:
0009A7r 2  A9 FF          lda #$FF                       ; Negative
0009A9r 2  60             rts
0009AAr 2               @CmpEqual:
0009AAr 2  A9 00          lda #$00                       ; Zero
0009ACr 2  60             rts
0009ADr 2               
0009ADr 2               ; BasExprAdd — Handle + and -
0009ADr 2               BasExprAdd:
0009ADr 2  20 rr rr       jsr BasExprMul
0009B0r 2               @AddLoop:
0009B0r 2  20 rr rr       jsr BasSkipSpaces
0009B3r 2  20 rr rr       jsr BasGetTokChar
0009B6r 2  C9 2B          cmp #CH_PLUS
0009B8r 2  F0 05          beq @DoAdd
0009BAr 2  C9 2D          cmp #CH_MINUS
0009BCr 2  F0 19          beq @DoSub
0009BEr 2  60             rts
0009BFr 2               
0009BFr 2               @DoAdd:
0009BFr 2  20 rr rr       jsr BasAdvTxtPtr
0009C2r 2  A5 0A          lda BAS_ACC
0009C4r 2  48             pha
0009C5r 2  A5 0B          lda BAS_ACC + 1
0009C7r 2  48             pha
0009C8r 2  20 rr rr       jsr BasExprMul
0009CBr 2  68             pla
0009CCr 2  85 0D          sta BAS_AUX + 1
0009CEr 2  68             pla
0009CFr 2  85 0C          sta BAS_AUX
0009D1r 2  20 rr rr       jsr BasMathAdd
0009D4r 2  4C rr rr       jmp @AddLoop
0009D7r 2               
0009D7r 2               @DoSub:
0009D7r 2  20 rr rr       jsr BasAdvTxtPtr
0009DAr 2  A5 0A          lda BAS_ACC
0009DCr 2  48             pha
0009DDr 2  A5 0B          lda BAS_ACC + 1
0009DFr 2  48             pha
0009E0r 2  20 rr rr       jsr BasExprMul
0009E3r 2  68             pla
0009E4r 2  85 0D          sta BAS_AUX + 1
0009E6r 2  68             pla
0009E7r 2  85 0C          sta BAS_AUX
0009E9r 2  20 rr rr       jsr BasMathSub
0009ECr 2  4C rr rr       jmp @AddLoop
0009EFr 2               
0009EFr 2               ; BasExprMul — Handle *, /, MOD
0009EFr 2               BasExprMul:
0009EFr 2  20 rr rr       jsr BasExprUnary
0009F2r 2               @MulLoop:
0009F2r 2  20 rr rr       jsr BasSkipSpaces
0009F5r 2  20 rr rr       jsr BasGetTokChar
0009F8r 2  C9 2A          cmp #CH_STAR
0009FAr 2  F0 09          beq @DoMul
0009FCr 2  C9 2F          cmp #CH_SLASH
0009FEr 2  F0 1D          beq @DoDiv
000A00r 2  C9 99          cmp #TOK_MOD
000A02r 2  F0 31          beq @DoMod
000A04r 2  60             rts
000A05r 2               
000A05r 2               @DoMul:
000A05r 2  20 rr rr       jsr BasAdvTxtPtr
000A08r 2  A5 0A          lda BAS_ACC
000A0Ar 2  48             pha
000A0Br 2  A5 0B          lda BAS_ACC + 1
000A0Dr 2  48             pha
000A0Er 2  20 rr rr       jsr BasExprUnary
000A11r 2  68             pla
000A12r 2  85 0D          sta BAS_AUX + 1
000A14r 2  68             pla
000A15r 2  85 0C          sta BAS_AUX
000A17r 2  20 rr rr       jsr BasMathMul
000A1Ar 2  4C rr rr       jmp @MulLoop
000A1Dr 2               
000A1Dr 2               @DoDiv:
000A1Dr 2  20 rr rr       jsr BasAdvTxtPtr
000A20r 2  A5 0A          lda BAS_ACC
000A22r 2  48             pha
000A23r 2  A5 0B          lda BAS_ACC + 1
000A25r 2  48             pha
000A26r 2  20 rr rr       jsr BasExprUnary
000A29r 2  68             pla
000A2Ar 2  85 0D          sta BAS_AUX + 1
000A2Cr 2  68             pla
000A2Dr 2  85 0C          sta BAS_AUX
000A2Fr 2  20 rr rr       jsr BasMathDiv
000A32r 2  4C rr rr       jmp @MulLoop
000A35r 2               
000A35r 2               @DoMod:
000A35r 2  20 rr rr       jsr BasAdvTxtPtr
000A38r 2  A5 0A          lda BAS_ACC
000A3Ar 2  48             pha
000A3Br 2  A5 0B          lda BAS_ACC + 1
000A3Dr 2  48             pha
000A3Er 2  20 rr rr       jsr BasExprUnary
000A41r 2  68             pla
000A42r 2  85 0D          sta BAS_AUX + 1
000A44r 2  68             pla
000A45r 2  85 0C          sta BAS_AUX
000A47r 2  20 rr rr       jsr BasMathDiv
000A4Ar 2                 ; MOD result is the remainder
000A4Ar 2  A5 1E          lda BAS_SCRATCH2
000A4Cr 2  85 0A          sta BAS_ACC
000A4Er 2  A5 1F          lda BAS_SCRATCH2 + 1
000A50r 2  85 0B          sta BAS_ACC + 1
000A52r 2  4C rr rr       jmp @MulLoop
000A55r 2               
000A55r 2               ; BasExprUnary — Handle unary minus
000A55r 2               BasExprUnary:
000A55r 2  20 rr rr       jsr BasSkipSpaces
000A58r 2  20 rr rr       jsr BasGetTokChar
000A5Br 2  C9 2D          cmp #CH_MINUS
000A5Dr 2  D0 09          bne @UnaryPos
000A5Fr 2  20 rr rr       jsr BasAdvTxtPtr
000A62r 2  20 rr rr       jsr BasExprPrimary
000A65r 2  4C rr rr       jmp BasMathNeg
000A68r 2               @UnaryPos:
000A68r 2  4C rr rr       jmp BasExprPrimary
000A6Br 2               
000A6Br 2               ; BasExprPrimary — Numbers, variables, parens, functions
000A6Br 2               BasExprPrimary:
000A6Br 2  20 rr rr       jsr BasSkipSpaces
000A6Er 2  20 rr rr       jsr BasGetTokChar
000A71r 2               
000A71r 2                 ; Number literal?
000A71r 2  C9 30          cmp #'0'
000A73r 2  90 07          bcc @NotNum
000A75r 2  C9 3A          cmp #'9' + 1
000A77r 2  B0 03          bcs @NotNum
000A79r 2  4C rr rr       jmp @IsNum                     ; Digit found — parse number
000A7Cr 2               @NotNum:
000A7Cr 2               
000A7Cr 2                 ; Variable A-Z?
000A7Cr 2  C9 41          cmp #'A'
000A7Er 2  90 21          bcc @NotVar
000A80r 2  C9 5B          cmp #'Z' + 1
000A82r 2  B0 1D          bcs @NotVar
000A84r 2                 ; Variable — compute index: (ch - 'A') * 2
000A84r 2  38             sec
000A85r 2  E9 41          sbc #'A'
000A87r 2  0A             asl                            ; ×2 for 16-bit
000A88r 2  AA             tax
000A89r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000A8Cr 2                 ; Check for '(' → array access
000A8Cr 2  20 rr rr       jsr BasGetTokChar
000A8Fr 2  C9 28          cmp #CH_LPAREN
000A91r 2  F0 0B          beq @AryRead
000A93r 2                 ; Scalar variable read
000A93r 2  BD 00 04       lda BAS_VARS,x
000A96r 2  85 0A          sta BAS_ACC
000A98r 2  BD 01 04       lda BAS_VARS + 1,x
000A9Br 2  85 0B          sta BAS_ACC + 1
000A9Dr 2  60             rts
000A9Er 2               @AryRead:
000A9Er 2  4C rr rr       jmp BasArrayRead               ; X = var_offset, will return with BAS_ACC set
000AA1r 2               @NotVar:
000AA1r 2               
000AA1r 2                 ; Parenthesized expression?
000AA1r 2  C9 28          cmp #CH_LPAREN
000AA3r 2  D0 0B          bne @NotParen
000AA5r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
000AA8r 2  20 rr rr       jsr BasExpr
000AABr 2  A9 29          lda #CH_RPAREN
000AADr 2  4C rr rr       jmp BasExpectChar              ; Expect and skip ')'
000AB0r 2               @NotParen:
000AB0r 2               
000AB0r 2                 ; PEEK(expr)?
000AB0r 2  C9 92          cmp #TOK_PEEK
000AB2r 2  D0 21          bne @NotPeek
000AB4r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip PEEK token
000AB7r 2  A9 28          lda #CH_LPAREN
000AB9r 2  20 rr rr       jsr BasExpectChar
000ABCr 2  20 rr rr       jsr BasExpr
000ABFr 2  A9 29          lda #CH_RPAREN
000AC1r 2  20 rr rr       jsr BasExpectChar
000AC4r 2                 ; Load byte from address in ACC
000AC4r 2  A5 0A          lda BAS_ACC
000AC6r 2  85 10          sta BAS_TMP2
000AC8r 2  A5 0B          lda BAS_ACC + 1
000ACAr 2  85 11          sta BAS_TMP2 + 1
000ACCr 2  A0 00          ldy #$00
000ACEr 2  B1 10          lda (BAS_TMP2),y
000AD0r 2  85 0A          sta BAS_ACC
000AD2r 2  64 0B          stz BAS_ACC + 1
000AD4r 2  60             rts
000AD5r 2               @NotPeek:
000AD5r 2               
000AD5r 2                 ; ABS(expr)?
000AD5r 2  C9 94          cmp #TOK_ABS
000AD7r 2  D0 13          bne @NotAbs
000AD9r 2  20 rr rr       jsr BasAdvTxtPtr
000ADCr 2  A9 28          lda #CH_LPAREN
000ADEr 2  20 rr rr       jsr BasExpectChar
000AE1r 2  20 rr rr       jsr BasExpr
000AE4r 2  A9 29          lda #CH_RPAREN
000AE6r 2  20 rr rr       jsr BasExpectChar
000AE9r 2  4C rr rr       jmp BasMathAbs
000AECr 2               @NotAbs:
000AECr 2               
000AECr 2                 ; RND(expr)?
000AECr 2  C9 95          cmp #TOK_RND
000AEEr 2  D0 50          bne @NotRnd
000AF0r 2  20 rr rr       jsr BasAdvTxtPtr
000AF3r 2  A9 28          lda #CH_LPAREN
000AF5r 2  20 rr rr       jsr BasExpectChar
000AF8r 2  20 rr rr       jsr BasExpr
000AFBr 2  A9 29          lda #CH_RPAREN
000AFDr 2  20 rr rr       jsr BasExpectChar
000B00r 2                 ; Save modulus (ACC) and generate random number
000B00r 2  A5 0A          lda BAS_ACC
000B02r 2  48             pha
000B03r 2  A5 0B          lda BAS_ACC + 1
000B05r 2  48             pha
000B06r 2                 ; Galois LFSR step
000B06r 2  A5 18          lda BAS_RNDSEED
000B08r 2  0A             asl
000B09r 2  26 19          rol BAS_RNDSEED + 1
000B0Br 2  90 02          bcc @RndNoTap
000B0Dr 2  49 2D          eor #$2D                      ; Tap polynomial
000B0Fr 2               @RndNoTap:
000B0Fr 2  85 18          sta BAS_RNDSEED
000B11r 2                 ; Use seed as raw random value
000B11r 2  A5 18          lda BAS_RNDSEED
000B13r 2  85 0C          sta BAS_AUX
000B15r 2  A5 19          lda BAS_RNDSEED + 1
000B17r 2                 ; Make positive
000B17r 2  29 7F          and #$7F
000B19r 2  85 0D          sta BAS_AUX + 1
000B1Br 2                 ; Restore modulus
000B1Br 2  68             pla
000B1Cr 2  85 0B          sta BAS_ACC + 1
000B1Er 2  68             pla
000B1Fr 2  85 0A          sta BAS_ACC
000B21r 2                 ; If modulus <= 0, just return raw number
000B21r 2  A5 0A          lda BAS_ACC
000B23r 2  05 0B          ora BAS_ACC + 1
000B25r 2  F0 10          beq @RndRaw
000B27r 2  A5 0B          lda BAS_ACC + 1
000B29r 2  30 0C          bmi @RndRaw
000B2Br 2                 ; ACC = AUX MOD ACC
000B2Br 2  20 rr rr       jsr BasMathDiv
000B2Er 2  A5 1E          lda BAS_SCRATCH2
000B30r 2  85 0A          sta BAS_ACC
000B32r 2  A5 1F          lda BAS_SCRATCH2 + 1
000B34r 2  85 0B          sta BAS_ACC + 1
000B36r 2  60             rts
000B37r 2               @RndRaw:
000B37r 2  A5 0C          lda BAS_AUX
000B39r 2  85 0A          sta BAS_ACC
000B3Br 2  A5 0D          lda BAS_AUX + 1
000B3Dr 2  85 0B          sta BAS_ACC + 1
000B3Fr 2  60             rts
000B40r 2               @NotRnd:
000B40r 2               
000B40r 2                 ; JOY(n) — read joystick port
000B40r 2  C9 A6          cmp #TOK_JOY
000B42r 2  D0 23          bne @NotJoy
000B44r 2  20 rr rr       jsr BasAdvTxtPtr               ; skip TOK_JOY
000B47r 2  A9 28          lda #CH_LPAREN
000B49r 2  20 rr rr       jsr BasExpectChar
000B4Cr 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
000B4Fr 2  A9 29          lda #CH_RPAREN
000B51r 2  20 rr rr       jsr BasExpectChar
000B54r 2  A5 0A          lda BAS_ACC
000B56r 2  C9 02          cmp #2
