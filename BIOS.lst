000F81r 2  02 07 03 0E  
000F85r 2                 ; --- $2x ---
000F85r 2  1F 06 01 0A    .byte MN_JSR,AM_ABS, MN_AND,AM_IZX, MN_UND,AM_IMP, MN_UND,AM_IMP  ; $20-$23
