000000r 2               RTC_ALARM_HR        := $880A
000000r 2               RTC_ALARM_DATE      := $880B
000000r 2               RTC_WD_L            := $880C
000000r 2               RTC_WD_H            := $880D
000000r 2               RTC_CTRL_A          := $880E
000000r 2               RTC_CTRL_B          := $880F
000000r 2               RTC_RAM_ADDR        := $8810
000000r 2               RTC_RAM_DATA        := $8813
000000r 2               ; DS1511Y Control Register B Bits
000000r 2               RTC_CTRL_B_TE       := %10000000         ; Transfer Enable — set to inhibit updates during write
000000r 2               ; DS1511Y Month Register (05H) — upper 3 bits are control bits, low 5 are month
000000r 2               RTC_MON_MASK        := %00011111         ; Month value occupies the low 5 bits
000000r 2               RTC_MON_EOSC        := %10000000         ; Oscillator Start/Stop (0 = oscillator running)
000000r 2               RTC_MON_E32K        := %01000000         ; 32kHz square-wave enable (1 = SQW output disabled)
000000r 2               RTC_MON_BB32        := %00100000         ; Battery-backup 32kHz SQW enable (1 = enabled in backup)
000000r 2               
