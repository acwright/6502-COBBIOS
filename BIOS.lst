000A06r 2  48             pha
000A07r 2  A5 0B          lda BAS_ACC + 1
000A09r 2  48             pha
000A0Ar 2  20 rr rr       jsr BasExprUnary
000A0Dr 2  68             pla
000A0Er 2  85 0D          sta BAS_AUX + 1
000A10r 2  68             pla
000A11r 2  85 0C          sta BAS_AUX
000A13r 2  20 rr rr       jsr BasMathMul
000A16r 2  4C rr rr       jmp @MulLoop
000A19r 2               
000A19r 2               @DoDiv:
000A19r 2  20 rr rr       jsr BasAdvTxtPtr
