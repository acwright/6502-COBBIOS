000000r 2               
000000r 2               ; Zero Page
000000r 2               ZP                  := $00
000000r 2               READ_PTR            := $00
000000r 2               WRITE_PTR           := $01
000000r 2               STR_PTR             := $02               ; $02-$03 - String pointer (2 bytes)
000000r 2               ; $04-$23 reserved by BASIC interpreter
000000r 2               CF_BUF_PTR          := $24               ; $24-$25 - CF sector data buffer pointer (2 bytes)
000000r 2               CF_LBA              := $26               ; $26-$29 - CF 28-bit LBA address (4 bytes, little-endian)
000000r 2               XFER_PTR            := $2A               ; $2A-$2B - Serial transfer data pointer (2 bytes)
000000r 2               DELAY_CNT           := $2C               ; $2C-$2D - SysDelay 16-bit centisecond counter
000000r 2               ; Monitor ZP variables ($2E-$35)
000000r 2               MON_ADDR            := $2E               ; $2E-$2F - Monitor current address (2 bytes)
000000r 2               MON_END             := $30               ; $30-$31 - Monitor end address (2 bytes)
000000r 2               MON_TMP             := $32               ; $32-$33 - Monitor temp pointer (2 bytes)
000000r 2               MON_BYTE            := $34               ; $34     - Monitor parsed byte scratch
000000r 2               MON_IDX             := $35               ; $35     - Monitor input line index
000000r 2               
000000r 2               ; Stack
000000r 2               STACK               := $0100             ; $0100-$01FF
000000r 2               
000000r 2               ; Input Buffer
000000r 2               INPUT_BUFFER        := $0200             ; $0200-$02FF
000000r 2               
000000r 2               ; Kernal Vars
000000r 2               KERNAL_VARS         := $0300             ; $0300-$03FF
000000r 2               IRQ_PTR             := $0300             ; $0300-$0301
000000r 2               BRK_PTR             := $0302             ; $0302-$0303
000000r 2               NMI_PTR             := $0304             ; $0304-$0305
000000r 2               IO_MODE             := $0306             ; Bit 0: 0=video, 1=serial output
000000r 2               VID_CURSOR_X        := $0307             ; Video cursor column (0-39)
000000r 2               VID_CURSOR_Y        := $0308             ; Video cursor row (0-23)
000000r 2               VID_CURSOR_ADDR     := $0309             ; Video cursor VRAM address ($0309-$030A)
000000r 2               RTC_BUF_CENT        := $030B             ; Century value from last RtcReadDate / for RtcWriteDate
000000r 2               RTC_TMP             := $030C             ; Scratch byte for BCD conversion
000000r 2               HW_PRESENT          := $030D             ; Hardware present bitmask (set during Reset probe)
000000r 2               ; HW_PRESENT bit definitions (bit order matches IO slot numbers)
000000r 2               HW_RAM_L            = %00000001          ; Bit 0: RAM card low  (IO 1, $8000-$83FF)
000000r 2               HW_RAM_H            = %00000010          ; Bit 1: RAM card high (IO 2, $8400-$87FF)
000000r 2               HW_RTC              = %00000100          ; Bit 2: RTC card (IO 3, DS1511Y)
000000r 2               HW_CF               = %00001000          ; Bit 3: Storage card (IO 4, CompactFlash)
000000r 2               HW_SC               = %00010000          ; Bit 4: Serial card (IO 5, R65C51)
000000r 2               HW_GPIO             = %00100000          ; Bit 5: GPIO card (IO 6, 65C22 VIA — keyboard/joysticks)
000000r 2               HW_SID              = %01000000          ; Bit 6: Sound card (IO 7, SID/ARMSID)
000000r 2               HW_VID              = %10000000          ; Bit 7: Video card (IO 8, TMS9918/pico9918)
000000r 2               BAS_PENDKEY         := $030E             ; Pending key from BasCheckBreak (1 byte)
000000r 2                                                        ; $030F Reserved
000000r 2               BRK_P               := $0310             ; Saved P at time of BRK
000000r 2               BRK_PCL             := $0311             ; Saved PCL at time of BRK (points to BRK+2)
000000r 2               BRK_PCH             := $0312             ; Saved PCH at time of BRK
000000r 2               BRK_A               := $0313             ; Saved A at time of BRK
000000r 2               BRK_X               := $0314             ; Saved X at time of BRK
000000r 2               BRK_Y               := $0315             ; Saved Y at time of BRK
000000r 2               BRK_SP              := $0316             ; Saved SP at time of BRK
000000r 2               XFER_REMAIN         := $0317             ; $0317-$0318 - Remaining bytes to transfer (2 bytes)
000000r 2               XFER_IO_SAVE        := $0319             ; Saved IO_MODE before switching to serial
000000r 2               BAS_DATAPTR         := $031A             ; $031A-$031B - DATA read position (2 bytes)
000000r 2               BAS_STOPLINE        := $031C             ; $031C-$031D - Saved BAS_CURLINE for CONT (2 bytes)
000000r 2               BAS_STOPTXT         := $031E             ; $031E-$031F - Saved BAS_TXTPTR for CONT (2 bytes)
000000r 2               SCROLL_BUF          := $0320             ; $0320-$0347 - 40-byte scroll temp buffer
000000r 2               ; Filesystem temp vars ($0348+)
000000r 2               FS_START_SEC        := $0348             ; $0348-$0349 - File start sector (2 bytes)
000000r 2               FS_FILE_SIZE        := $034A             ; $034A-$034B - File size in bytes (2 bytes)
000000r 2               FS_SEC_COUNT        := $034C             ; Number of sectors to read/write
000000r 2               FS_DIR_IDX          := $034D             ; Directory entry index (0-15)
000000r 2               FS_NEXT_SEC         := $034E             ; $034E-$034F - Next free sector for allocation (2 bytes)
000000r 2               FS_FNAME_BUF        := $0350             ; $0350-$035A - 11-byte filename buffer (8 name + 3 ext)
000000r 2               BOOT_VECTOR         := $035B             ; $035B-$035C - Cart/boot redirect vector (2 bytes, 0=normal boot)
000000r 2               FS_SECTOR_BUF       := $0600             ; $0600-$07FF - 512-byte sector buffer (overlaps BAS_TOKBUF/BAS_STRBUF)
