000000r 2               MN_BRK = 13
000000r 2               MN_BVC = 14
000000r 2               MN_BVS = 15
000000r 2               MN_CLC = 16
000000r 2               MN_CLD = 17
000000r 2               MN_CLI = 18
000000r 2               MN_CLV = 19
000000r 2               MN_CMP = 20
000000r 2               MN_CPX = 21
000000r 2               MN_CPY = 22
000000r 2               MN_DEC = 23
000000r 2               MN_DEX = 24
000000r 2               MN_DEY = 25
000000r 2               MN_EOR = 26
000000r 2               MN_INC = 27
000000r 2               MN_INX = 28
000000r 2               MN_INY = 29
000000r 2               MN_JMP = 30
000000r 2               MN_JSR = 31
000000r 2               MN_LDA = 32
000000r 2               MN_LDX = 33
