0017DBr 2               VT_SetTxt:
0017DBr 2                       ; Set TXTPTR = VT_TXTPTR_TMP - 1 then ChrGet to load first char.
0017DBr 2                       ; Actually simpler: caller passes (Y,A) = pointer; we set TXTPTR =
0017DBr 2                       ; (Y,A) - 1 and call ChrGet to land on (Y,A).
0017DBr 2                       sta     TXTPTR
