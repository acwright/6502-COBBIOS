000FC7r 2               ; ODD Polynomial SUBROUTINE
000FC7r 2               ;
000FC7r 2               ; F(X) = X * P(X^2)
000FC7r 2               ;
000FC7r 2               ; WHERE:  X IS VALUE IN FAC
000FC7r 2               ;	Y,A POINTS AT COEFFICIENT TABLE
000FC7r 2               ;	FIRST BYTE OF COEFF. TABLE IS N
000FC7r 2               ;	COEFFICIENTS FOLLOW, HIGHEST POWER FIRST
000FC7r 2               ;
000FC7r 2               ; P(X^2) COMPUTED USING NORMAL Polynomial SUBROUTINE
