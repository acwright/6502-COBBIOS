000ADAr 2  A9 28          lda #'('
000ADCr 2  20 rr rr       jsr Chrout
000ADFr 2  20 rr rr       jsr DisOpAbs
000AE2r 2  A9 2C          lda #','
000AE4r 2  20 rr rr       jsr Chrout
000AE7r 2  A9 58          lda #'X'
000AE9r 2  20 rr rr       jsr Chrout
000AECr 2  A9 29          lda #')'
000AEEr 2  4C rr rr       jmp Chrout
000AF1r 2               
000AF1r 2               ; ============================================================================
000AF1r 2               ; MonShowRegs — Print saved register state
000AF1r 2               ; Format: PC=xxxx A=xx X=xx Y=xx SP=xx NV-BDIZC
000AF1r 2               ; ============================================================================
000AF1r 2               
000AF1r 2               MonShowRegs:
000AF1r 2                 ; "PC="
000AF1r 2  A9 50          lda #'P'
000AF3r 2  20 rr rr       jsr Chrout
000AF6r 2  A9 43          lda #'C'
000AF8r 2  20 rr rr       jsr Chrout
000AFBr 2  A9 3D          lda #'='
000AFDr 2  20 rr rr       jsr Chrout
000B00r 2                 ; Print PC (adjusted: BRK_PC - 2)
000B00r 2  38             sec
000B01r 2  AD 11 03       lda BRK_PCL
000B04r 2  E9 02          sbc #2
000B06r 2  85 2E          sta MON_ADDR
000B08r 2  AD 12 03       lda BRK_PCH
000B0Br 2  E9 00          sbc #0
000B0Dr 2  85 2F          sta MON_ADDR + 1
000B0Fr 2  20 rr rr       jsr MonPrintHex4
000B12r 2  A9 20          lda #' '
000B14r 2  20 rr rr       jsr Chrout
000B17r 2               
000B17r 2                 ; "A="
000B17r 2  A9 41          lda #'A'
000B19r 2  20 rr rr       jsr Chrout
000B1Cr 2  A9 3D          lda #'='
000B1Er 2  20 rr rr       jsr Chrout
000B21r 2  AD 13 03       lda BRK_A
000B24r 2  20 rr rr       jsr MonPrintHex2
000B27r 2  A9 20          lda #' '
000B29r 2  20 rr rr       jsr Chrout
000B2Cr 2               
000B2Cr 2                 ; "X="
000B2Cr 2  A9 58          lda #'X'
000B2Er 2  20 rr rr       jsr Chrout
000B31r 2  A9 3D          lda #'='
000B33r 2  20 rr rr       jsr Chrout
000B36r 2  AD 14 03       lda BRK_X
000B39r 2  20 rr rr       jsr MonPrintHex2
000B3Cr 2  A9 20          lda #' '
000B3Er 2  20 rr rr       jsr Chrout
000B41r 2               
000B41r 2                 ; "Y="
000B41r 2  A9 59          lda #'Y'
000B43r 2  20 rr rr       jsr Chrout
000B46r 2  A9 3D          lda #'='
000B48r 2  20 rr rr       jsr Chrout
000B4Br 2  AD 15 03       lda BRK_Y
000B4Er 2  20 rr rr       jsr MonPrintHex2
000B51r 2  A9 20          lda #' '
000B53r 2  20 rr rr       jsr Chrout
000B56r 2               
000B56r 2                 ; "SP="
000B56r 2  A9 53          lda #'S'
000B58r 2  20 rr rr       jsr Chrout
000B5Br 2  A9 50          lda #'P'
000B5Dr 2  20 rr rr       jsr Chrout
000B60r 2  A9 3D          lda #'='
000B62r 2  20 rr rr       jsr Chrout
000B65r 2  AD 16 03       lda BRK_SP
000B68r 2  20 rr rr       jsr MonPrintHex2
000B6Br 2  A9 20          lda #' '
000B6Dr 2  20 rr rr       jsr Chrout
000B70r 2               
000B70r 2                 ; Flags: NV-BDIZC
000B70r 2  AD 10 03       lda BRK_P
000B73r 2  85 34          sta MON_BYTE                  ; Save flags for bit testing
000B75r 2  A2 00          ldx #0
000B77r 2               @FlagLoop:
000B77r 2  BD rr rr       lda MonFlagChars,x
000B7Ar 2  F0 11          beq @FlagsDone
000B7Cr 2  06 34          asl MON_BYTE                  ; Shift next flag bit into carry
000B7Er 2  B0 04          bcs @FlagSet
000B80r 2  A9 2D          lda #'-'                      ; Flag clear — print dash
000B82r 2  80 03          bra @FlagPrint
000B84r 2               @FlagSet:
000B84r 2                 ; A already has the flag character
000B84r 2  BD rr rr       lda MonFlagChars,x
000B87r 2               @FlagPrint:
000B87r 2  20 rr rr       jsr Chrout
000B8Ar 2  E8             inx
000B8Br 2  80 EA          bra @FlagLoop
000B8Dr 2               @FlagsDone:
000B8Dr 2  20 rr rr       jsr MonPrintCRLF
000B90r 2  60             rts
000B91r 2               
000B91r 2               MonFlagChars:
000B91r 2  4E 56 2D 42    .byte "NV-BDIZC", 0
000B95r 2  44 49 5A 43  
000B99r 2  00           
000B9Ar 2               
000B9Ar 2               ; ============================================================================
000B9Ar 2               ; Hex Parsing Utilities
000B9Ar 2               ; ============================================================================
000B9Ar 2               
000B9Ar 2               ; MonParseHex4 — Parse up to 4 hex digits from MON_LINBUF into MON_ADDR
000B9Ar 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B9Ar 2               ; Output: MON_ADDR/MON_ADDR+1 = parsed 16-bit value, carry set if valid
000B9Ar 2               ;         MON_IDX advanced past parsed digits
000B9Ar 2               
000B9Ar 2               MonParseHex4:
000B9Ar 2  64 2E          stz MON_ADDR
000B9Cr 2  64 2F          stz MON_ADDR + 1
000B9Er 2  A2 00          ldx #0                        ; Digit count
000BA0r 2               @ParseLoop:
000BA0r 2  A4 35          ldy MON_IDX
000BA2r 2  B9 34 04       lda MON_LINBUF,y
000BA5r 2  20 rr rr       jsr MonCharToNibble           ; Convert ASCII to 0-15, carry clear if valid
000BA8r 2  B0 1B          bcs @ParseDone                ; Not a hex digit — stop
000BAAr 2                 ; Shift result left 4 bits and OR in new nibble
000BAAr 2  06 2E          asl MON_ADDR
000BACr 2  26 2F          rol MON_ADDR + 1
000BAEr 2  06 2E          asl MON_ADDR
000BB0r 2  26 2F          rol MON_ADDR + 1
000BB2r 2  06 2E          asl MON_ADDR
000BB4r 2  26 2F          rol MON_ADDR + 1
000BB6r 2  06 2E          asl MON_ADDR
000BB8r 2  26 2F          rol MON_ADDR + 1
000BBAr 2  05 2E          ora MON_ADDR
000BBCr 2  85 2E          sta MON_ADDR
000BBEr 2  E6 35          inc MON_IDX
000BC0r 2  E8             inx
000BC1r 2  E0 04          cpx #4                        ; Max 4 digits
000BC3r 2  90 DB          bcc @ParseLoop
000BC5r 2               @ParseDone:
000BC5r 2  E0 00          cpx #0                        ; Did we parse at least one digit?
000BC7r 2  F0 02          beq @ParseFail
000BC9r 2  38             sec                           ; Success
000BCAr 2  60             rts
000BCBr 2               @ParseFail:
000BCBr 2  18             clc                           ; Failure — no digits parsed
000BCCr 2  60             rts
000BCDr 2               
000BCDr 2               ; MonParseHex2 — Parse up to 2 hex digits from MON_LINBUF into A
000BCDr 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000BCDr 2               ; Output: A = parsed 8-bit value, carry set if valid
000BCDr 2               ;         MON_IDX advanced past parsed digits
000BCDr 2               
000BCDr 2               MonParseHex2:
000BCDr 2  64 34          stz MON_BYTE
000BCFr 2  A2 00          ldx #0                        ; Digit count
000BD1r 2               @ParseLoop:
000BD1r 2  A4 35          ldy MON_IDX
000BD3r 2  B9 34 04       lda MON_LINBUF,y
000BD6r 2  20 rr rr       jsr MonCharToNibble
000BD9r 2  B0 13          bcs @ParseDone
000BDBr 2  06 34          asl MON_BYTE
000BDDr 2  06 34          asl MON_BYTE
000BDFr 2  06 34          asl MON_BYTE
000BE1r 2  06 34          asl MON_BYTE
000BE3r 2  05 34          ora MON_BYTE
000BE5r 2  85 34          sta MON_BYTE
000BE7r 2  E6 35          inc MON_IDX
000BE9r 2  E8             inx
000BEAr 2  E0 02          cpx #2
000BECr 2  90 E3          bcc @ParseLoop
000BEEr 2               @ParseDone:
000BEEr 2  E0 00          cpx #0
000BF0r 2  F0 04          beq @ParseFail
000BF2r 2  A5 34          lda MON_BYTE
000BF4r 2  38             sec
000BF5r 2  60             rts
000BF6r 2               @ParseFail:
000BF6r 2  18             clc
000BF7r 2  60             rts
000BF8r 2               
000BF8r 2               ; MonCharToNibble — Convert ASCII hex char in A to nibble value 0-15
000BF8r 2               ; Input:  A = ASCII character
000BF8r 2               ; Output: A = 0-15 if valid hex digit, carry clear
000BF8r 2               ;         carry set if not a valid hex digit (A preserved)
000BF8r 2               
000BF8r 2               MonCharToNibble:
000BF8r 2  C9 30          cmp #'0'
000BFAr 2  90 23          bcc @NotHex
000BFCr 2  C9 3A          cmp #'9'+1
000BFEr 2  90 15          bcc @IsDigit
000C00r 2  C9 41          cmp #'A'
000C02r 2  90 04          bcc @CheckLower
000C04r 2  C9 47          cmp #'F'+1
000C06r 2  90 12          bcc @IsUpper
000C08r 2               @CheckLower:
000C08r 2  C9 61          cmp #'a'
000C0Ar 2  90 13          bcc @NotHex
000C0Cr 2  C9 67          cmp #'f'+1
000C0Er 2  B0 0F          bcs @NotHex
000C10r 2                 ; Lowercase a-f
000C10r 2  38             sec
000C11r 2  E9 57          sbc #('a' - 10)
000C13r 2  18             clc
000C14r 2  60             rts
000C15r 2               @IsDigit:
000C15r 2  38             sec
000C16r 2  E9 30          sbc #'0'
000C18r 2  18             clc
000C19r 2  60             rts
000C1Ar 2               @IsUpper:
000C1Ar 2  38             sec
000C1Br 2  E9 37          sbc #('A' - 10)
000C1Dr 2  18             clc
000C1Er 2  60             rts
000C1Fr 2               @NotHex:
000C1Fr 2  38             sec
000C20r 2  60             rts
000C21r 2               
000C21r 2               ; MonSkipSpaces — Advance MON_IDX past whitespace in MON_LINBUF
000C21r 2               
000C21r 2               MonSkipSpaces:
000C21r 2  A4 35          ldy MON_IDX
000C23r 2  B9 34 04       lda MON_LINBUF,y
000C26r 2  C9 20          cmp #' '
000C28r 2  D0 04          bne @Done
000C2Ar 2  E6 35          inc MON_IDX
000C2Cr 2  80 F3          bra MonSkipSpaces
000C2Er 2               @Done:
000C2Er 2  60             rts
000C2Fr 2               
000C2Fr 2               ; ============================================================================
000C2Fr 2               ; Decimal & Binary Parsing Utilities
000C2Fr 2               ; ============================================================================
000C2Fr 2               
000C2Fr 2               ; MonParseDec16 — Parse decimal digits from MON_LINBUF into MON_ADDR
000C2Fr 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000C2Fr 2               ; Output: MON_ADDR = parsed 16-bit value, carry set if valid
000C2Fr 2               ;         MON_IDX advanced past parsed digits
000C2Fr 2               ; Modifies: A, X, Y, MON_ADDR, MON_TMP
000C2Fr 2               
000C2Fr 2               MonParseDec16:
000C2Fr 2  64 2E          stz MON_ADDR
000C31r 2  64 2F          stz MON_ADDR+1
000C33r 2  A2 00          ldx #0                        ; Digit count
000C35r 2               @DecLoop:
000C35r 2  A4 35          ldy MON_IDX
000C37r 2  B9 34 04       lda MON_LINBUF,y
000C3Ar 2  C9 30          cmp #'0'
000C3Cr 2  90 3A          bcc @DecDone
000C3Er 2  C9 3A          cmp #'9'+1
000C40r 2  B0 36          bcs @DecDone
000C42r 2  38             sec
000C43r 2  E9 30          sbc #'0'                      ; A = digit 0-9
000C45r 2  48             pha                           ; Save digit
000C46r 2                 ; MON_ADDR = MON_ADDR * 10 + digit
000C46r 2                 ; *10 = (*2 + *8): save *2, then *8, add
000C46r 2  06 2E          asl MON_ADDR
000C48r 2  26 2F          rol MON_ADDR+1
000C4Ar 2  A5 2E          lda MON_ADDR
000C4Cr 2  85 32          sta MON_TMP
000C4Er 2  A5 2F          lda MON_ADDR+1
000C50r 2  85 33          sta MON_TMP+1                 ; MON_TMP = *2
000C52r 2  06 2E          asl MON_ADDR
000C54r 2  26 2F          rol MON_ADDR+1                ; *4
000C56r 2  06 2E          asl MON_ADDR
000C58r 2  26 2F          rol MON_ADDR+1                ; *8
000C5Ar 2  18             clc
000C5Br 2  A5 2E          lda MON_ADDR
000C5Dr 2  65 32          adc MON_TMP
000C5Fr 2  85 2E          sta MON_ADDR
000C61r 2  A5 2F          lda MON_ADDR+1
000C63r 2  65 33          adc MON_TMP+1
000C65r 2  85 2F          sta MON_ADDR+1                ; *10
000C67r 2                 ; + digit
000C67r 2  68             pla
000C68r 2  18             clc
000C69r 2  65 2E          adc MON_ADDR
000C6Br 2  85 2E          sta MON_ADDR
000C6Dr 2  90 02          bcc @DecNoCarry
000C6Fr 2  E6 2F          inc MON_ADDR+1
000C71r 2               @DecNoCarry:
000C71r 2  E6 35          inc MON_IDX
000C73r 2  E8             inx
000C74r 2  E0 05          cpx #5                        ; Max 5 digits (65535)
000C76r 2  90 BD          bcc @DecLoop
000C78r 2               @DecDone:
000C78r 2  E0 00          cpx #0
000C7Ar 2  F0 02          beq @DecFail
000C7Cr 2  38             sec                           ; Success
000C7Dr 2  60             rts
000C7Er 2               @DecFail:
000C7Er 2  18             clc                           ; Failure
000C7Fr 2  60             rts
000C80r 2               
000C80r 2               ; MonParseBin16 — Parse binary digits from MON_LINBUF into MON_ADDR
000C80r 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000C80r 2               ; Output: MON_ADDR = parsed 16-bit value, carry set if valid
000C80r 2               ;         MON_IDX advanced past parsed digits
000C80r 2               ; Modifies: A, X, Y, MON_ADDR
000C80r 2               
000C80r 2               MonParseBin16:
000C80r 2  64 2E          stz MON_ADDR
000C82r 2  64 2F          stz MON_ADDR+1
000C84r 2  A2 00          ldx #0                        ; Digit count
000C86r 2               @BinLoop:
000C86r 2  A4 35          ldy MON_IDX
000C88r 2  B9 34 04       lda MON_LINBUF,y
000C8Br 2  C9 30          cmp #'0'
000C8Dr 2  F0 06          beq @BinGot
000C8Fr 2  C9 31          cmp #'1'
000C91r 2  F0 02          beq @BinGot
000C93r 2  80 0F          bra @BinDone
000C95r 2               @BinGot:
000C95r 2  38             sec
000C96r 2  E9 30          sbc #'0'                      ; A = 0 or 1
000C98r 2  4A             lsr a                         ; Bit into carry
000C99r 2  26 2E          rol MON_ADDR
000C9Br 2  26 2F          rol MON_ADDR+1
000C9Dr 2  E6 35          inc MON_IDX
000C9Fr 2  E8             inx
000CA0r 2  E0 10          cpx #16                       ; Max 16 bits
000CA2r 2  90 E2          bcc @BinLoop
000CA4r 2               @BinDone:
000CA4r 2  E0 00          cpx #0
000CA6r 2  F0 02          beq @BinFail
000CA8r 2  38             sec                           ; Success
000CA9r 2  60             rts
000CAAr 2               @BinFail:
000CAAr 2  18             clc                           ; Failure
000CABr 2  60             rts
000CACr 2               
000CACr 2               ; ============================================================================
000CACr 2               ; Decimal & Binary Output Utilities
000CACr 2               ; ============================================================================
000CACr 2               
000CACr 2               ; MonPrintDec16 — Print MON_ADDR as up to 5 decimal digits
000CACr 2               ; Uses successive subtraction of powers of 10
000CACr 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000CACr 2               
000CACr 2               MonPrintDec16:
000CACr 2                 ; Copy value to MON_TMP so we don't destroy MON_ADDR
000CACr 2  A5 2E          lda MON_ADDR
000CAEr 2  85 32          sta MON_TMP
000CB0r 2  A5 2F          lda MON_ADDR+1
000CB2r 2  85 33          sta MON_TMP+1
000CB4r 2  A2 00          ldx #0                        ; Leading zero suppression flag
000CB6r 2  A0 00          ldy #0                        ; Power-of-10 index
000CB8r 2               @Dec16Loop:
000CB8r 2  A9 2F          lda #'0'-1
000CBAr 2  85 34          sta MON_BYTE                  ; Digit scratch
000CBCr 2               @Dec16Sub:
000CBCr 2  E6 34          inc MON_BYTE
000CBEr 2  A5 32          lda MON_TMP
000CC0r 2  38             sec
000CC1r 2  F9 rr rr       sbc @Dec16Pow10Lo,y
000CC4r 2  48             pha
000CC5r 2  A5 33          lda MON_TMP+1
000CC7r 2  F9 rr rr       sbc @Dec16Pow10Hi,y
000CCAr 2  90 07          bcc @Dec16Digit               ; Underflow — digit done
000CCCr 2  85 33          sta MON_TMP+1
000CCEr 2  68             pla
000CCFr 2  85 32          sta MON_TMP
000CD1r 2  80 E9          bra @Dec16Sub
000CD3r 2               @Dec16Digit:
000CD3r 2  68             pla                           ; Discard underflowed low byte
000CD4r 2  A5 34          lda MON_BYTE
000CD6r 2  C9 30          cmp #'0'
000CD8r 2  D0 04          bne @Dec16Print               ; Non-zero → print
000CDAr 2  E0 00          cpx #0
000CDCr 2  F0 08          beq @Dec16Skip                ; Leading zero → skip
000CDEr 2               @Dec16Print:
000CDEr 2  DA             phx
000CDFr 2  5A             phy
000CE0r 2  20 rr rr       jsr Chrout
000CE3r 2  7A             ply
000CE4r 2  FA             plx
000CE5r 2  E8             inx                           ; Mark we've printed a digit
000CE6r 2               @Dec16Skip:
000CE6r 2  C8             iny
000CE7r 2  C0 04          cpy #4                        ; 4 powers: 10000, 1000, 100, 10
000CE9r 2  D0 CD          bne @Dec16Loop
000CEBr 2                 ; Always print ones digit
000CEBr 2  A5 32          lda MON_TMP
000CEDr 2  09 30          ora #'0'
000CEFr 2  20 rr rr       jsr Chrout
000CF2r 2  60             rts
000CF3r 2  10 E8 64 0A  @Dec16Pow10Lo: .byte <10000, <1000, <100, <10
000CF7r 2  27 03 00 00  @Dec16Pow10Hi: .byte >10000, >1000, >100, >10
000CFBr 2               
000CFBr 2               ; MonPrintBin16 — Print MON_ADDR as 16 binary digits (MSB first)
000CFBr 2               ; Modifies: A, X
000CFBr 2               
000CFBr 2               MonPrintBin16:
000CFBr 2  A5 2F          lda MON_ADDR+1                ; High byte first
000CFDr 2  20 rr rr       jsr @PrintBin8
000D00r 2  A5 2E          lda MON_ADDR                  ; Then low byte
000D02r 2               @PrintBin8:
000D02r 2  A2 08          ldx #8
000D04r 2               @BinBitLoop:
000D04r 2  0A             asl a                         ; Shift MSB into carry
000D05r 2  48             pha
000D06r 2  A9 30          lda #'0'
000D08r 2  69 00          adc #0                        ; +1 if carry → '1'
000D0Ar 2  20 rr rr       jsr Chrout
000D0Dr 2  68             pla
000D0Er 2  CA             dex
000D0Fr 2  D0 F3          bne @BinBitLoop
000D11r 2  60             rts
000D12r 2               
000D12r 2               ; ============================================================================
000D12r 2               ; Message Print Helpers (Phase 5)
000D12r 2               ; ============================================================================
000D12r 2               
000D12r 2               ; MonPrintLoaded — Print "LOADED nnnn BYTES AT $xxxx"
000D12r 2               ; Input: MON_ADDR = byte count, MON_END = load address
000D12r 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000D12r 2               
000D12r 2               MonPrintLoaded:
000D12r 2  A2 00          ldx #0
000D14r 2               @PLoop1:
000D14r 2  BD rr rr       lda MonStrLoadPfx,x
000D17r 2  F0 06          beq @PDone1
000D19r 2  20 rr rr       jsr Chrout
000D1Cr 2  E8             inx
000D1Dr 2  80 F5          bra @PLoop1
000D1Fr 2               @PDone1:
000D1Fr 2  20 rr rr       jsr MonPrintDec16             ; Print byte count from MON_ADDR
000D22r 2  A2 00          ldx #0
000D24r 2               @PLoop2:
000D24r 2  BD rr rr       lda MonStrBytesAt,x
000D27r 2  F0 06          beq @PDone2
000D29r 2  20 rr rr       jsr Chrout
000D2Cr 2  E8             inx
000D2Dr 2  80 F5          bra @PLoop2
000D2Fr 2               @PDone2:
000D2Fr 2                 ; Print address from MON_END
000D2Fr 2  A5 30          lda MON_END
000D31r 2  85 2E          sta MON_ADDR
000D33r 2  A5 31          lda MON_END+1
000D35r 2  85 2F          sta MON_ADDR+1
000D37r 2  20 rr rr       jsr MonPrintHex4
000D3Ar 2  4C rr rr       jmp MonPrintCRLF
000D3Dr 2               
000D3Dr 2               ; MonPrintSaved — Print "SAVED nnnn BYTES"
000D3Dr 2               ; Input: MON_ADDR = byte count
000D3Dr 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000D3Dr 2               
000D3Dr 2               MonPrintSaved:
000D3Dr 2  A2 00          ldx #0
000D3Fr 2               @SLoop1:
000D3Fr 2  BD rr rr       lda MonStrSavePfx,x
000D42r 2  F0 06          beq @SDone1
000D44r 2  20 rr rr       jsr Chrout
000D47r 2  E8             inx
000D48r 2  80 F5          bra @SLoop1
000D4Ar 2               @SDone1:
000D4Ar 2  20 rr rr       jsr MonPrintDec16             ; Print byte count from MON_ADDR
000D4Dr 2  A2 00          ldx #0
000D4Fr 2               @SLoop2:
000D4Fr 2  BD rr rr       lda MonStrBytes,x
000D52r 2  F0 06          beq @SDone2
000D54r 2  20 rr rr       jsr Chrout
000D57r 2  E8             inx
000D58r 2  80 F5          bra @SLoop2
000D5Ar 2               @SDone2:
000D5Ar 2  4C rr rr       jmp MonPrintCRLF
000D5Dr 2               
000D5Dr 2               ; MonPrintIOErr — Print "I/O ERROR"
000D5Dr 2               ; Modifies: A, X
000D5Dr 2               
000D5Dr 2               MonPrintIOErr:
000D5Dr 2  A2 00          ldx #0
000D5Fr 2               @ELoop:
000D5Fr 2  BD rr rr       lda MonStrIOErr,x
000D62r 2  F0 06          beq @EDone
000D64r 2  20 rr rr       jsr Chrout
000D67r 2  E8             inx
000D68r 2  80 F5          bra @ELoop
000D6Ar 2               @EDone:
000D6Ar 2  4C rr rr       jmp MonPrintCRLF
000D6Dr 2               
000D6Dr 2               ; MonSerialPrintStr — Print null-terminated string at STR_PTR via serial
000D6Dr 2               ; Input: STR_PTR points to string
000D6Dr 2               ; Modifies: A, Y
000D6Dr 2               
000D6Dr 2               MonSerialPrintStr:
000D6Dr 2  A0 00          ldy #0
000D6Fr 2               @SrLoop:
000D6Fr 2  B1 02          lda (STR_PTR),y
000D71r 2  F0 06          beq @SrDone
000D73r 2  20 rr rr       jsr SerialChrout
000D76r 2  C8             iny
000D77r 2  D0 F6          bne @SrLoop
000D79r 2               @SrDone:
000D79r 2  60             rts
000D7Ar 2               
000D7Ar 2               ; ============================================================================
000D7Ar 2               ; Hex Output Utilities
000D7Ar 2               ; ============================================================================
000D7Ar 2               
000D7Ar 2               ; MonPrintHex2 — Print A as two hex digits
000D7Ar 2               ; Input:  A = byte to print
000D7Ar 2               ; Modifies: A, flags
000D7Ar 2               
000D7Ar 2               MonPrintHex2:
000D7Ar 2  48             pha                           ; Save original byte
000D7Br 2  4A             lsr                           ; Shift high nibble down
000D7Cr 2  4A             lsr
000D7Dr 2  4A             lsr
000D7Er 2  4A             lsr
000D7Fr 2  20 rr rr       jsr @PrintNibble              ; Print high nibble
000D82r 2  68             pla                           ; Restore original byte
000D83r 2  29 0F          and #$0F                      ; Isolate low nibble
000D85r 2               @PrintNibble:
000D85r 2  C9 0A          cmp #10
000D87r 2  90 06          bcc @IsDigit
000D89r 2  18             clc
000D8Ar 2  69 37          adc #('A' - 10)
000D8Cr 2  4C rr rr       jmp Chrout
000D8Fr 2               @IsDigit:
000D8Fr 2  18             clc
000D90r 2  69 30          adc #'0'
000D92r 2  4C rr rr       jmp Chrout
000D95r 2               
000D95r 2               ; MonPrintHex4 — Print MON_ADDR as four hex digits
000D95r 2               ; Input:  MON_ADDR, MON_ADDR+1 = 16-bit value
000D95r 2               ; Modifies: A, flags
000D95r 2               
000D95r 2               MonPrintHex4:
000D95r 2  A5 2F          lda MON_ADDR + 1              ; High byte first
000D97r 2  20 rr rr       jsr MonPrintHex2
000D9Ar 2  A5 2E          lda MON_ADDR                  ; Then low byte
000D9Cr 2  4C rr rr       jmp MonPrintHex2
000D9Fr 2               
000D9Fr 2               ; MonPrintSpace — Print a space character
000D9Fr 2               
000D9Fr 2               MonPrintSpace:
000D9Fr 2  A9 20          lda #' '
000DA1r 2  4C rr rr       jmp Chrout
000DA4r 2               
000DA4r 2               ; MonPrintCRLF — Print carriage return + line feed
000DA4r 2               
000DA4r 2               MonPrintCRLF:
000DA4r 2  A9 0D          lda #$0D
000DA6r 2  20 rr rr       jsr Chrout
000DA9r 2  A9 0A          lda #$0A
000DABr 2  4C rr rr       jmp Chrout
000DAEr 2               
000DAEr 2               ; MonPrintError — Print "?" for unrecognized command
000DAEr 2               
000DAEr 2               MonPrintError:
000DAEr 2  A9 3F          lda #'?'
000DB0r 2  20 rr rr       jsr Chrout
000DB3r 2  4C rr rr       jmp MonPrintCRLF
000DB6r 2               
000DB6r 2               ; MonPrintBanner — Print the monitor banner string
000DB6r 2               
000DB6r 2               MonPrintBanner:
000DB6r 2  A2 00          ldx #0
000DB8r 2               @Loop:
000DB8r 2  BD rr rr       lda MonStrBanner,x
000DBBr 2  F0 06          beq @Done
000DBDr 2  20 rr rr       jsr Chrout
000DC0r 2  E8             inx
000DC1r 2  80 F5          bra @Loop
000DC3r 2               @Done:
000DC3r 2  60             rts
000DC4r 2               
000DC4r 2               ; ============================================================================
000DC4r 2               ; String Data
000DC4r 2               ; ============================================================================
000DC4r 2               
000DC4r 2               MonStrBanner:
000DC4r 2  36 35 30 32    .byte "6502 MONITOR v1.0", $0D, $0A, 0
000DC8r 2  20 4D 4F 4E  
000DCCr 2  49 54 4F 52  
000DD8r 2               MonStrBrk:
000DD8r 2  42 52 4B 20    .byte "BRK AT $", 0
000DDCr 2  41 54 20 24  
000DE0r 2  00           
000DE1r 2               MonStrReady:
000DE1r 2  0D 0A 52 45    .byte $0D, $0A, "READY TO RECEIVE", $0D, $0A, 0
000DE5r 2  41 44 59 20  
000DE9r 2  54 4F 20 52  
000DF6r 2               MonStrNotFound:
000DF6r 2  46 49 4C 45    .byte "FILE NOT FOUND", 0
000DFAr 2  20 4E 4F 54  
000DFEr 2  20 46 4F 55  
000E05r 2               MonStrDirFull:
000E05r 2  44 49 52 45    .byte "DIRECTORY FULL", 0
000E09r 2  43 54 4F 52  
000E0Dr 2  59 20 46 55  
000E14r 2               MonStrLoadPfx:
000E14r 2  4C 4F 41 44    .byte "LOADED ", 0
000E18r 2  45 44 20 00  
000E1Cr 2               MonStrSavePfx:
000E1Cr 2  53 41 56 45    .byte "SAVED ", 0
000E20r 2  44 20 00     
000E23r 2               MonStrBytesAt:
000E23r 2  20 42 59 54    .byte " BYTES AT $", 0
000E27r 2  45 53 20 41  
000E2Br 2  54 20 24 00  
000E2Fr 2               MonStrBytes:
000E2Fr 2  20 42 59 54    .byte " BYTES", 0
000E33r 2  45 53 00     
000E36r 2               MonStrIOErr:
000E36r 2  49 2F 4F 20    .byte "I/O ERROR", 0
000E3Ar 2  45 52 52 4F  
000E3Er 2  52 00        
