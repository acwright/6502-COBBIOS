0022AEr 2  A9 rr                lda     #<MsgInWord
0022B0r 2  A0 rr                ldy     #>MsgInWord
0022B2r 2  20 rr rr             jsr     BasPrintStr
0022B5r 2  AD 69 03             lda     BAS_CURLIN
0022B8r 2  85 08                sta     BAS_LINNUM
0022BAr 2  AD 6A 03             lda     BAS_CURLIN+1
0022BDr 2  85 09                sta     BAS_LINNUM+1
0022BFr 2  20 rr rr             jsr     BasPrintLineNum
