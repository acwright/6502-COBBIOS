00186Br 2               ; READ var[,var,...] — Read values from DATA statements
00186Br 2               ; ============================================================================
00186Br 2               
00186Br 2               BasCmdRead:
00186Br 2               @ReadLoop:
00186Br 2                 ; Ensure DATA pointer is initialized
00186Br 2  AD 1A 03       lda BAS_DATAPTR
