0017DBr 2               
0017DBr 2                       lda     #<VT_NameB
0017DBr 2                       ldy     #>VT_NameB
0017DBr 2                       jsr     VT_SetTxt
0017DBr 2                       jsr     PtrGet                  ; creates B
0017DBr 2                       ; Save B's VARPNT.
0017DBr 2                       lda     VARPNT
0017DBr 2                       sta     VT_VPSAVE
0017DBr 2                       lda     VARPNT+1
0017DBr 2                       sta     VT_VPSAVE+1
0017DBr 2               
0017DBr 2                       ; Look up A again (already exists).
0017DBr 2                       lda     #<VT_NameA
0017DBr 2                       ldy     #>VT_NameA
0017DBr 2                       jsr     VT_SetTxt
0017DBr 2                       jsr     PtrGet
0017DBr 2                       jsr     VT_LoadFAC              ; FAC = A = 3.14
0017DBr 2                       ; Multiply by 2.
0017DBr 2                       lda     #<FpC2
0017DBr 2                       ldy     #>FpC2
0017DBr 2                       jsr     FMult                   ; FAC = 2 * FAC = 6.28
0017DBr 2                       ; Store into B.
0017DBr 2                       ldx     VT_VPSAVE
0017DBr 2                       ldy     VT_VPSAVE+1
0017DBr 2                       jsr     StoreFacAtYxRounded
0017DBr 2               
0017DBr 2                       ; Print result.
0017DBr 2                       lda     #<MsgVT_A
0017DBr 2                       ldy     #>MsgVT_A
0017DBr 2                       jsr     BasPrintStr
0017DBr 2                       ; Reload B and print.
0017DBr 2                       lda     VT_VPSAVE
0017DBr 2                       ldy     VT_VPSAVE+1
0017DBr 2                       jsr     LoadFacFromYa
0017DBr 2                       jsr     BasPrintFAC
0017DBr 2                       jsr     BasPrintCRLF
0017DBr 2               
0017DBr 2                       ; --- Test 2: A$="HELLO" ---
0017DBr 2                       lda     #<VT_NameAS
0017DBr 2                       ldy     #>VT_NameAS
0017DBr 2                       jsr     VT_SetTxt
0017DBr 2                       jsr     PtrGet                  ; creates A$
0017DBr 2                       ; Save VARPNT (A$ descriptor address).
0017DBr 2                       lda     VARPNT
0017DBr 2                       sta     VT_VPSAVE
0017DBr 2                       lda     VARPNT+1
0017DBr 2                       sta     VT_VPSAVE+1
0017DBr 2                       ; Allocate space, copy "HELLO" via StrLit.
0017DBr 2                       lda     #<VT_HelloLit
0017DBr 2                       ldy     #>VT_HelloLit
0017DBr 2                       jsr     StrLit                  ; FAC has descriptor, in temp stack
0017DBr 2                       ; Now copy descriptor (3 bytes from temp stack entry) to A$ var.
0017DBr 2                       ; FAC+3,4 points at the temp descriptor; FAC = length, FAC+1/2 = addr.
0017DBr 2                       ; The descriptor lives in TEMPST.  We just write [len][lo][hi] into
0017DBr 2                       ; (VARPNT) so the variable now references the heap copy.
0017DBr 2                       lda     FAC
0017DBr 2                       ldy     #$00
0017DBr 2                       sta     (VT_VPSAVE),y           ; length
0017DBr 2                       lda     FAC+1
0017DBr 2                       iny
0017DBr 2                       sta     (VT_VPSAVE),y           ; addr lo
0017DBr 2                       lda     FAC+2
0017DBr 2                       iny
0017DBr 2                       sta     (VT_VPSAVE),y           ; addr hi
0017DBr 2                       ; Print length.
0017DBr 2                       lda     #<MsgVT_AS
0017DBr 2                       ldy     #>MsgVT_AS
0017DBr 2                       jsr     BasPrintStr
0017DBr 2                       ldy     #$00
0017DBr 2                       lda     (VT_VPSAVE),y
0017DBr 2                       tay
0017DBr 2                       jsr     SngFlt
0017DBr 2                       jsr     BasPrintFAC
0017DBr 2                       jsr     BasPrintCRLF
0017DBr 2               
0017DBr 2                       ; --- Test 3: DIM N(10), N(5)=42 ---
0017DBr 2                       ; Build TXTPTR pointing at "N(10) " and call MakInt-equivalent path.
0017DBr 2                       ; Easier: directly construct array via PtrGet3 + Array by simulating
0017DBr 2                       ; a 1-D DIM of size 11 (indices 0..10).  We emulate the parser:
0017DBr 2                       ;   1. Set DIMFLG = $40, VARNAM = ('N','N'), call PtrGet3 with X=1?
0017DBr 2                       ;   2. Or: just do PtrGet3 entry by hand then jmp Array.
0017DBr 2                       ; Simplest: set TXTPTR at "N(10) ", DIMFLG <- $40 (from DIM
0017DBr 2                       ; statement), then PtrGet3 with VARNAM letter, jmp to '(' branch.
0017DBr 2                       lda     #<VT_DimN10
0017DBr 2                       ldy     #>VT_DimN10
0017DBr 2                       jsr     VT_SetTxt               ; A = 'N'
0017DBr 2                       ldx     #$40                    ; from-DIM flag (bit 6)
0017DBr 2                       jsr     PtrGet2                 ; will hit '(' -> Array -> create
0017DBr 2                       ; Now N(5)=42.  Re-parse "N(5)" to find element.
0017DBr 2                       lda     #<VT_DimN5
0017DBr 2                       ldy     #>VT_DimN5
0017DBr 2                       jsr     VT_SetTxt
0017DBr 2                       jsr     PtrGet                  ; element address in VARPNT
0017DBr 2                       ; Save VARPNT.
0017DBr 2                       lda     VARPNT
0017DBr 2                       sta     VT_VPSAVE
0017DBr 2                       lda     VARPNT+1
0017DBr 2                       sta     VT_VPSAVE+1
0017DBr 2                       ; FAC = 42.
0017DBr 2                       lda     #<Vt42
0017DBr 2                       ldy     #>Vt42
0017DBr 2                       jsr     LoadFacFromYa
0017DBr 2                       ldx     VT_VPSAVE
0017DBr 2                       ldy     VT_VPSAVE+1
0017DBr 2                       jsr     StoreFacAtYxRounded
0017DBr 2                       ; Read it back and print.
0017DBr 2                       lda     #<MsgVT_NewArr
0017DBr 2                       ldy     #>MsgVT_NewArr
0017DBr 2                       jsr     BasPrintStr
0017DBr 2                       lda     VT_VPSAVE
0017DBr 2                       ldy     VT_VPSAVE+1
0017DBr 2                       jsr     LoadFacFromYa
0017DBr 2                       jsr     BasPrintFAC
0017DBr 2                       jsr     BasPrintCRLF
0017DBr 2               
0017DBr 2                       ; --- Test 4: 8 string allocations + GC ---
0017DBr 2                       ldx     #8
0017DBr 2               @galloc:
0017DBr 2                       phx
0017DBr 2                       lda     #16
0017DBr 2                       jsr     StrSpa                  ; consumes 16 bytes; FAC has descriptor
0017DBr 2                       plx
0017DBr 2                       dex
0017DBr 2                       bne     @galloc
0017DBr 2                       ; Force GC (TEMPPT got bumped by StrSpa-via-StrIni? StrSpa itself
0017DBr 2                       ; doesn't call PutNew, so temp stack untouched here.)
0017DBr 2                       jsr     Garbag
0017DBr 2                       lda     #<MsgVT_GC
0017DBr 2                       ldy     #>MsgVT_GC
0017DBr 2                       jsr     BasPrintStr
0017DBr 2                       lda     FRETOP+1
0017DBr 2                       ldy     FRETOP
0017DBr 2                       jsr     GivAyf
0017DBr 2                       jsr     BasPrintFAC
0017DBr 2                       jsr     BasPrintCRLF
0017DBr 2               
0017DBr 2                       rts
0017DBr 2               .endif
0017DBr 2               
0017DBr 2               ; =============================================================================
0017DBr 2               ;   E X P R E S S I O N   E V A L U A T O R
0017DBr 2               ;
0017DBr 2               ;   Recursive-descent precedence climber.  Operates on tokenized text at
0017DBr 2               ;   TXTPTR (advanced via ChrGet/ChrGot).  Result lands in FAC (numeric)
0017DBr 2               ;   or as a 3-byte string descriptor at FAC..FAC+2 (string).  VALTYP
0017DBr 2               ;   selects: $00 = numeric, $FF = string.
0017DBr 2               ;
0017DBr 2               ;   Precedence (lowest -> highest):
0017DBr 2               ;     OR
0017DBr 2               ;     AND
0017DBr 2               ;     NOT  (right-assoc unary)
0017DBr 2               ;     comparison (= <> < > <= >=)
0017DBr 2               ;     + -
0017DBr 2               ;     * /
0017DBr 2               ;     ^    (right-assoc)
0017DBr 2               ;     unary -, unary +
0017DBr 2               ;     atom: number, variable, string-literal, "(" expr ")", function call
0017DBr 2               ; =============================================================================
0017DBr 2               
0017DBr 2               ; ---------------------------------------------------------------------------
0017DBr 2               ; ZP scratch used only during expression evaluation.
0017DBr 2               ;   BAS_LVTYP = saved VALTYP of left operand around binary ops
0017DBr 2               ; ---------------------------------------------------------------------------
0017DBr 2               BAS_LVTYP       := $86
0017DBr 2               
0017DBr 2               ; ---------------------------------------------------------------------------
0017DBr 2               ; FrmEvl -- top-level entry.  TXTPTR positioned so ChrGot returns the first
0017DBr 2               ; byte of the expression.  On exit TXTPTR is at the first byte AFTER the
0017DBr 2               ; expression.  Result in FAC + VALTYP.
0017DBr 2               ; ---------------------------------------------------------------------------
0017DBr 2               FrmEvl:
0017DBr 2  4C rr rr             jmp     EvalOr
0017DEr 2               
0017DEr 2               ; ---------------------------------------------------------------------------
0017DEr 2               ; PushFac -- push the current FAC + VALTYP onto the CPU stack (8 bytes).
0017DEr 2               ; Order pushed: VALTYP, FAC, FAC+1, FAC+2, FAC+3, FAC+4, FACSIGN, FACEXTENSION
0017DEr 2               ; (FACEXTENSION pushed last so it's pulled first by PullArg.)
0017DEr 2               ; Preserves the return address.
0017DEr 2               ; ---------------------------------------------------------------------------
0017DEr 2               PushFac:
0017DEr 2  68                   pla
0017DFr 2  A8                   tay                             ; Y = ret-addr lo
0017E0r 2  68                   pla
0017E1r 2  AA                   tax                             ; X = ret-addr hi
0017E2r 2  A5 64                lda     VALTYP
0017E4r 2  48                   pha
0017E5r 2  A5 0E                lda     FAC
0017E7r 2  48                   pha
0017E8r 2  A5 0F                lda     FAC+1
0017EAr 2  48                   pha
0017EBr 2  A5 10                lda     FAC+2
0017EDr 2  48                   pha
0017EEr 2  A5 11                lda     FAC+3
0017F0r 2  48                   pha
0017F1r 2  A5 12                lda     FAC+4
0017F3r 2  48                   pha
0017F4r 2  A5 13                lda     FACSIGN
0017F6r 2  48                   pha
0017F7r 2  A5 1D                lda     FACEXTENSION
0017F9r 2  48                   pha
0017FAr 2  8A                   txa
0017FBr 2  48                   pha
0017FCr 2  98                   tya
0017FDr 2  48                   pha
0017FEr 2  60                   rts
0017FFr 2               
0017FFr 2               ; ---------------------------------------------------------------------------
0017FFr 2               ; PullArg -- pop the previously-pushed FAC into ARG (signed FP value or
0017FFr 2               ; string descriptor in ARG..ARG+2/sign).  Sets BAS_LVTYP to the saved
0017FFr 2               ; left-operand VALTYP.  Preserves return address.
0017FFr 2               ; ---------------------------------------------------------------------------
0017FFr 2               PullArg:
0017FFr 2  68                   pla
001800r 2  A8                   tay                             ; Y = ret-addr lo
001801r 2  68                   pla
001802r 2  AA                   tax                             ; X = ret-addr hi
001803r 2  68                   pla
001804r 2  85 43                sta     ARGEXTENSION
001806r 2  68                   pla
001807r 2  85 1B                sta     ARGSIGN
001809r 2  68                   pla
00180Ar 2  85 1A                sta     ARG+4
00180Cr 2  68                   pla
00180Dr 2  85 19                sta     ARG+3
00180Fr 2  68                   pla
001810r 2  85 18                sta     ARG+2
001812r 2  68                   pla
001813r 2  85 17                sta     ARG+1
001815r 2  68                   pla
001816r 2  85 16                sta     ARG
001818r 2  68                   pla
001819r 2  85 86                sta     BAS_LVTYP
00181Br 2  8A                   txa
00181Cr 2  48                   pha
00181Dr 2  98                   tya
00181Er 2  48                   pha
00181Fr 2  60                   rts
001820r 2               
001820r 2               ; ---------------------------------------------------------------------------
001820r 2               ; PullFac -- pop pushed FAC back into FAC (used to discard right side and
001820r 2               ; restore left, e.g. unused).
001820r 2               ; ---------------------------------------------------------------------------
001820r 2               PullFac:
001820r 2  68                   pla
001821r 2  A8                   tay
001822r 2  68                   pla
001823r 2  AA                   tax
001824r 2  68                   pla
001825r 2  85 1D                sta     FACEXTENSION
001827r 2  68                   pla
001828r 2  85 13                sta     FACSIGN
00182Ar 2  68                   pla
00182Br 2  85 12                sta     FAC+4
00182Dr 2  68                   pla
00182Er 2  85 11                sta     FAC+3
001830r 2  68                   pla
001831r 2  85 10                sta     FAC+2
001833r 2  68                   pla
001834r 2  85 0F                sta     FAC+1
001836r 2  68                   pla
001837r 2  85 0E                sta     FAC
001839r 2  68                   pla
00183Ar 2  85 64                sta     VALTYP
00183Cr 2  8A                   txa
00183Dr 2  48                   pha
00183Er 2  98                   tya
00183Fr 2  48                   pha
001840r 2  60                   rts
001841r 2               
001841r 2               ; ---------------------------------------------------------------------------
001841r 2               ; TypeMismatch helper.
001841r 2               ; ---------------------------------------------------------------------------
001841r 2               EvalTypeErr:
001841r 2  A2 08                ldx     #ERR_TYPEMISM
001843r 2  4C rr rr             jmp     BasErrorVec
001846r 2               
001846r 2               ; ===========================================================================
001846r 2               ;   L E V E L 0  --  O R
001846r 2               ; ===========================================================================
001846r 2               EvalOr:
001846r 2  20 rr rr             jsr     EvalAnd
001849r 2               @loop:
001849r 2  20 rr rr             jsr     ChrGot
00184Cr 2  C9 A3                cmp     #TOK_OR
00184Er 2  D0 17                bne     @done
001850r 2  20 rr rr             jsr     ChkNum                  ; left must be numeric
001853r 2  20 rr rr             jsr     ChrGet                  ; consume OR
001856r 2  20 rr rr             jsr     PushFac
001859r 2  20 rr rr             jsr     EvalAnd
00185Cr 2  20 rr rr             jsr     ChkNum                  ; right must be numeric
00185Fr 2  20 rr rr             jsr     PullArg
001862r 2  20 rr rr             jsr     OrOp
001865r 2  80 E2                bra     @loop
001867r 2               @done:
001867r 2  60                   rts
001868r 2               
001868r 2               ; ===========================================================================
001868r 2               ;   L E V E L 1  --  A N D
001868r 2               ; ===========================================================================
001868r 2               EvalAnd:
001868r 2  20 rr rr             jsr     EvalNot
00186Br 2               @loop:
00186Br 2  20 rr rr             jsr     ChrGot
00186Er 2  C9 A2                cmp     #TOK_AND
001870r 2  D0 17                bne     @done
001872r 2  20 rr rr             jsr     ChkNum
001875r 2  20 rr rr             jsr     ChrGet
001878r 2  20 rr rr             jsr     PushFac
00187Br 2  20 rr rr             jsr     EvalNot
00187Er 2  20 rr rr             jsr     ChkNum
001881r 2  20 rr rr             jsr     PullArg
001884r 2  20 rr rr             jsr     AndOp
001887r 2  80 E2                bra     @loop
001889r 2               @done:
001889r 2  60                   rts
00188Ar 2               
00188Ar 2               ; ===========================================================================
00188Ar 2               ;   L E V E L 2  --  N O T   (right-assoc unary prefix)
00188Ar 2               ; ===========================================================================
00188Ar 2               EvalNot:
00188Ar 2  20 rr rr             jsr     ChrGot
00188Dr 2  C9 A0                cmp     #TOK_NOT
00188Fr 2  D0 0C                bne     EvalCmp
001891r 2  20 rr rr             jsr     ChrGet
001894r 2  20 rr rr             jsr     EvalNot
001897r 2  20 rr rr             jsr     ChkNum
00189Ar 2  4C rr rr             jmp     NotOp
00189Dr 2               
00189Dr 2               ; ===========================================================================
00189Dr 2               ;   L E V E L 3  --  C O M P A R I S O N
00189Dr 2               ;   Reads up to two of {<, =, >} forming a relop; if none, no-op.
00189Dr 2               ;   Mask:  bit 0 = '>' present, bit 1 = '=' present, bit 2 = '<' present
00189Dr 2               ; ===========================================================================
00189Dr 2               EvalCmp:
00189Dr 2  20 rr rr             jsr     EvalAdd
0018A0r 2  A2 00                ldx     #0                      ; relop mask
0018A2r 2               @scan:
0018A2r 2  20 rr rr             jsr     ChrGot
0018A5r 2  C9 3D                cmp     #'='
0018A7r 2  F0 0A                beq     @gotEq
0018A9r 2  C9 3C                cmp     #'<'
0018ABr 2  F0 0A                beq     @gotLt
0018ADr 2  C9 3E                cmp     #'>'
0018AFr 2  F0 0A                beq     @gotGt
0018B1r 2  80 1D                bra     @done
0018B3r 2               @gotEq:
0018B3r 2  A0 02                ldy     #2
0018B5r 2  80 06                bra     @setbit
0018B7r 2               @gotLt:
0018B7r 2  A0 04                ldy     #4
0018B9r 2  80 02                bra     @setbit
0018BBr 2               @gotGt:
0018BBr 2  A0 01                ldy     #1
0018BDr 2               @setbit:
0018BDr 2  84 45                sty     CPRMASK                 ; reuse as scratch
0018BFr 2  8A                   txa
0018C0r 2  25 45                and     CPRMASK
0018C2r 2  D0 09                bne     @synErr                 ; same char twice (e.g. "==")
0018C4r 2  8A                   txa
0018C5r 2  05 45                ora     CPRMASK
0018C7r 2  AA                   tax
0018C8r 2  20 rr rr             jsr     ChrGet
0018CBr 2  80 D5                bra     @scan
0018CDr 2               @synErr:
0018CDr 2  4C rr rr             jmp     SynErr
0018D0r 2               @done:
0018D0r 2  E0 00                cpx     #0
0018D2r 2  D0 01                bne     @doCmp
0018D4r 2  60                   rts
0018D5r 2               @doCmp:
0018D5r 2  86 45                stx     CPRMASK
0018D7r 2                       ; Save left operand, evaluate right
0018D7r 2  20 rr rr             jsr     PushFac
0018DAr 2  20 rr rr             jsr     EvalAdd
0018DDr 2  20 rr rr             jsr     PullArg                 ; ARG = left, BAS_LVTYP = left's type
0018E0r 2                       ; Type compatibility check.
0018E0r 2  A5 86                lda     BAS_LVTYP
0018E2r 2  45 64                eor     VALTYP
0018E4r 2  10 03 4C rr          jmi     EvalTypeErr             ; one numeric, one string -> mismatch
0018E8r 2  rr           
0018E9r 2  24 64                bit     VALTYP
0018EBr 2  30 03                bmi     @strCmp
0018EDr 2                       ; Numeric comparison.
0018EDr 2  4C rr rr             jmp     RelOpsNum
0018F0r 2               @strCmp:
0018F0r 2  4C rr rr             jmp     RelOpsStr
0018F3r 2               
0018F3r 2               ; ---------------------------------------------------------------------------
0018F3r 2               ; RelOpsNum -- numeric comparison.
0018F3r 2               ; Inputs: ARG = left, FAC = right, CPRMASK = relop mask (bit 0=>, 1==, 2=<).
0018F3r 2               ; Output: FAC = -1 if (ARG <op> FAC) is true, else 0.  VALTYP = numeric.
0018F3r 2               ; ---------------------------------------------------------------------------
0018F3r 2               RelOpsNum:
0018F3r 2                       ; Replicate msbasic ARG-pre-relop fixup: clear ARG+1 high bit, then
0018F3r 2                       ; set it from ARGSIGN's MSB.  This rebuilds the implicit-1 mantissa
0018F3r 2                       ; for FCOMP's signed comparison path.
0018F3r 2  A5 1B                lda     ARGSIGN
0018F5r 2  09 7F                ora     #$7F
0018F7r 2  25 17                and     ARG+1
0018F9r 2  85 17                sta     ARG+1
0018FBr 2  A9 16                lda     #<ARG
0018FDr 2  A0 00                ldy     #$00
0018FFr 2  20 rr rr             jsr     FComp                   ; A = sign(FAC - ARG)
001902r 2                       ; Map A to bit position:
001902r 2                       ;   FAC<ARG (A=$FF): ARG>FAC  -> bit 0 (mask 1)
001902r 2                       ;   FAC=ARG (A=$00):           -> bit 1 (mask 2)
001902r 2                       ;   FAC>ARG (A=$01): ARG<FAC  -> bit 2 (mask 4)
001902r 2  AA                   tax
001903r 2  30 06                bmi     @lt
001905r 2  F0 08                beq     @eq
001907r 2  A9 04                lda     #4
001909r 2  80 06                bra     @check
00190Br 2               @lt:
00190Br 2  A9 01                lda     #1
00190Dr 2  80 02                bra     @check
00190Fr 2               @eq:
00190Fr 2  A9 02                lda     #2
001911r 2               @check:
001911r 2  25 45                and     CPRMASK
001913r 2  F0 07                beq     @false
001915r 2  A9 FF                lda     #$FF
001917r 2  A0 FF                ldy     #$FF
001919r 2  4C rr rr             jmp     GivAyf
00191Cr 2               @false:
00191Cr 2  A9 00                lda     #0
00191Er 2  A8                   tay
00191Fr 2  4C rr rr             jmp     GivAyf
001922r 2               
001922r 2               ; ---------------------------------------------------------------------------
001922r 2               ; RelOpsStr -- bytewise string comparison.
001922r 2               ; ARG = left descriptor (ARG=len, ARG+1=lo, ARG+2=hi, ARGSIGN, ARGEXT pushed).
001922r 2               ; FAC = right descriptor.  CPRMASK as above.
001922r 2               ; ---------------------------------------------------------------------------
001922r 2               RelOpsStr:
001922r 2                       ; INDEX = left ptr, BAS_TMP1 = right ptr, BAS_TMP2 lo = left len,
001922r 2                       ; BAS_TMP2 hi = right len.
001922r 2  A5 17                lda     ARG+1
001924r 2  85 20                sta     INDEX
001926r 2  A5 18                lda     ARG+2
001928r 2  85 21                sta     INDEX+1
00192Ar 2  A5 0F                lda     FAC+1
00192Cr 2  85 3A                sta     BAS_TMP1
00192Er 2  A5 10                lda     FAC+2
001930r 2  85 3B                sta     BAS_TMP1+1
001932r 2  A5 16                lda     ARG
001934r 2  85 3C                sta     BAS_TMP2                ; left len
001936r 2  A5 0E                lda     FAC
001938r 2  85 3D                sta     BAS_TMP2+1              ; right len
00193Ar 2                       ; Compare byte-by-byte up to min length.
00193Ar 2  A0 00                ldy     #0
00193Cr 2               @cmp:
00193Cr 2                       ; Has either side ended?
00193Cr 2  C4 3C                cpy     BAS_TMP2
00193Er 2  F0 17                beq     @leftEnd
001940r 2  C4 3D                cpy     BAS_TMP2+1
001942r 2  F0 1B                beq     @rightEnd               ; right ended first -> left > right
001944r 2  B1 20                lda     (INDEX),y
001946r 2  D1 3A                cmp     (BAS_TMP1),y
001948r 2  F0 0A                beq     @next
00194Ar 2  90 04                bcc     @lt                     ; left < right
00194Cr 2                       ; left > right
00194Cr 2  A9 01                lda     #1
00194Er 2  80 15                bra     @decide
001950r 2               @lt:
001950r 2  A9 04                lda     #4
001952r 2  80 11                bra     @decide
001954r 2               @next:
001954r 2  C8                   iny
001955r 2  80 E5                bra     @cmp
001957r 2               @leftEnd:
001957r 2                       ; Left ran out; check right
001957r 2  C4 3D                cpy     BAS_TMP2+1
001959r 2  F0 08                beq     @equal
00195Br 2                       ; left < right (left is prefix)
00195Br 2  A9 04                lda     #4
00195Dr 2  80 06                bra     @decide
00195Fr 2               @rightEnd:
00195Fr 2                       ; right ran out, left has more; left > right
00195Fr 2  A9 01                lda     #1
001961r 2  80 02                bra     @decide
001963r 2               @equal:
001963r 2  A9 02                lda     #2
001965r 2               @decide:
001965r 2  25 45                and     CPRMASK
001967r 2  F0 05                beq     @false
001969r 2  A9 FF                lda     #$FF
00196Br 2  A8                   tay
00196Cr 2  80 03                bra     @ret
00196Er 2               @false:
00196Er 2  A9 00                lda     #0
001970r 2  A8                   tay
001971r 2               @ret:
001971r 2                       ; Free temp strings before returning.  Save A,Y first.
001971r 2  48                   pha
001972r 2  5A                   phy
001973r 2                       ; Free FAC's temp string (right operand).
001973r 2  24 64                bit     VALTYP
001975r 2  10 03                bpl     @noFreeR
001977r 2  20 rr rr             jsr     FreFac
00197Ar 2               @noFreeR:
00197Ar 2                       ; Free ARG's temp string (left operand): manually restore VALTYP=$FF
00197Ar 2                       ; and FAC := ARG, then FreFac.  (We don't always know if ARG is a
00197Ar 2                       ; temp; FreTms inside FreTmp checks.)
00197Ar 2  A5 16                lda     ARG
00197Cr 2  85 0E                sta     FAC
00197Er 2  A5 17                lda     ARG+1
001980r 2  85 0F                sta     FAC+1
001982r 2  A5 18                lda     ARG+2
001984r 2  85 10                sta     FAC+2
001986r 2  A9 FF                lda     #$FF
001988r 2  85 64                sta     VALTYP
00198Ar 2  20 rr rr             jsr     FreFac
00198Dr 2  7A                   ply
00198Er 2  68                   pla
00198Fr 2  4C rr rr             jmp     GivAyf
001992r 2               
001992r 2               ; ===========================================================================
001992r 2               ;   L E V E L 4  --  + / -
001992r 2               ; ===========================================================================
001992r 2               EvalAdd:
001992r 2  20 rr rr             jsr     EvalMul
001995r 2               @loop:
001995r 2  20 rr rr             jsr     ChrGot
001998r 2  C9 2B                cmp     #'+'
00199Ar 2  F0 05                beq     @plus
00199Cr 2  C9 2D                cmp     #'-'
00199Er 2  F0 27                beq     @minus
0019A0r 2  60                   rts
0019A1r 2               @plus:
0019A1r 2  20 rr rr             jsr     ChrGet
0019A4r 2  20 rr rr             jsr     PushFac
0019A7r 2  20 rr rr             jsr     EvalMul
0019AAr 2  20 rr rr             jsr     PullArg
0019ADr 2                       ; Type dispatch.
0019ADr 2  A5 86                lda     BAS_LVTYP
0019AFr 2  45 64                eor     VALTYP
0019B1r 2  10 03 4C rr          jmi     EvalTypeErr
0019B5r 2  rr           
0019B6r 2  24 64                bit     VALTYP
0019B8r 2  30 28                bmi     @cat
0019BAr 2                       ; numeric add: FAC = ARG + FAC
0019BAr 2                       ; FAddT expects: ARG is the operand, A=FAC's exponent on entry.
0019BAr 2                       ; Use entry "FAddT" preceded by sign work: msbasic does
0019BAr 2                       ;   bne <continue>; jmp CopyArgToFac
0019BAr 2                       ; But our FAddT entry already handles that.  We need to set
0019BAr 2                       ; SGNCPR = ARGSIGN ^ FACSIGN before FAddT.
0019BAr 2  A5 1B                lda     ARGSIGN
0019BCr 2  45 13                eor     FACSIGN
0019BEr 2  85 1C                sta     SGNCPR
0019C0r 2  A5 0E                lda     FAC
0019C2r 2  20 rr rr             jsr     FAddT
0019C5r 2  80 CE                bra     @loop
0019C7r 2               @minus:
0019C7r 2  20 rr rr             jsr     ChrGet
0019CAr 2  20 rr rr             jsr     PushFac
0019CDr 2  20 rr rr             jsr     EvalMul
0019D0r 2  20 rr rr             jsr     ChkNum
0019D3r 2                       ; left was pushed; check pushed type via TOS-byte? Easier: we already
0019D3r 2                       ; verified left is numeric on first iteration.  But left might have
0019D3r 2                       ; been a string from concatenation; require numeric here:
0019D3r 2  20 rr rr             jsr     PullArg
0019D6r 2  A5 86                lda     BAS_LVTYP
0019D8r 2  10 03 4C rr          jmi     EvalTypeErr
0019DCr 2  rr           
0019DDr 2                       ; FAC = ARG - FAC
0019DDr 2                       ; FSubT does: FACSIGN ^= $FF; SGNCPR = FACSIGN^ARGSIGN; jmp FAddT
0019DDr 2                       ; We need to call FSubT directly.
0019DDr 2  20 rr rr             jsr     FSubT
0019E0r 2  80 B3                bra     @loop
0019E2r 2               @cat:
0019E2r 2  20 rr rr             jsr     CatStr
0019E5r 2  80 AE                bra     @loop
0019E7r 2               
0019E7r 2               ; ---------------------------------------------------------------------------
0019E7r 2               ; CatStr -- concatenate ARG (left) + FAC (right), result in FAC.
0019E7r 2               ; ---------------------------------------------------------------------------
0019E7r 2               CatStr:
0019E7r 2                       ; Stash right's length+addr before we overwrite FAC.
0019E7r 2  A5 0E                lda     FAC
0019E9r 2  85 4D                sta     BAS_TEMP1               ; right len
0019EBr 2  A5 0F                lda     FAC+1
0019EDr 2  85 4E                sta     BAS_TEMP1+1
0019EFr 2  A5 10                lda     FAC+2
0019F1r 2  85 4F                sta     BAS_TEMP1+2
0019F3r 2                       ; Total length = ARG + FAC; abort if > 255.
0019F3r 2  18                   clc
0019F4r 2  A5 16                lda     ARG
0019F6r 2  65 4D                adc     BAS_TEMP1
0019F8r 2  B0 40                bcs     @tooLong
0019FAr 2  85 50                sta     BAS_TEMP1+3             ; total length
0019FCr 2                       ; Free both source temps before allocating result -- otherwise we
0019FCr 2                       ; pile up to 3 temps and the next PutNew throws ?FRMCPX.
0019FCr 2  20 rr rr             jsr     FreeBothTemps
0019FFr 2                       ; Allocate.
0019FFr 2  A5 50                lda     BAS_TEMP1+3             ; total length
001A01r 2  20 rr rr             jsr     GetSpa                  ; A=total, FRESPC=buf
001A04r 2                       ; Copy left bytes (ARG -> FRESPC).
001A04r 2  A5 17                lda     ARG+1
001A06r 2  85 20                sta     INDEX
001A08r 2  A5 18                lda     ARG+2
001A0Ar 2  85 21                sta     INDEX+1
001A0Cr 2  A5 16                lda     ARG
001A0Er 2  F0 03                beq     @right
001A10r 2  20 rr rr             jsr     MovStr1                 ; advances FRESPC by len
001A13r 2               @right:
001A13r 2                       ; Copy right bytes.
001A13r 2  A5 4E                lda     BAS_TEMP1+1
001A15r 2  85 20                sta     INDEX
001A17r 2  A5 4F                lda     BAS_TEMP1+2
001A19r 2  85 21                sta     INDEX+1
001A1Br 2  A5 4D                lda     BAS_TEMP1
001A1Dr 2  F0 03                beq     @desc
001A1Fr 2  20 rr rr             jsr     MovStr1
001A22r 2               @desc:
001A22r 2                       ; Descriptor: FAC := total len, FAC+1/2 := FRESPC - total.
001A22r 2  A5 50                lda     BAS_TEMP1+3
001A24r 2  85 0E                sta     FAC
001A26r 2  38                   sec
001A27r 2  A5 84                lda     FRESPC
001A29r 2  E5 50                sbc     BAS_TEMP1+3
001A2Br 2  85 0F                sta     FAC+1
001A2Dr 2  A5 85                lda     FRESPC+1
001A2Fr 2  E9 00                sbc     #0
001A31r 2  85 10                sta     FAC+2
001A33r 2  A9 FF                lda     #$FF
001A35r 2  85 64                sta     VALTYP
001A37r 2  4C rr rr             jmp     PutNew
001A3Ar 2               @tooLong:
001A3Ar 2  A2 09                ldx     #ERR_STRLONG
001A3Cr 2  4C rr rr             jmp     BasErrorVec
001A3Fr 2               
001A3Fr 2               ; ===========================================================================
001A3Fr 2               ;   L E V E L 5  --  * / /
001A3Fr 2               ; ===========================================================================
001A3Fr 2               EvalMul:
001A3Fr 2  20 rr rr             jsr     EvalPow
001A42r 2               @loop:
001A42r 2  20 rr rr             jsr     ChrGot
001A45r 2  C9 2A                cmp     #'*'
001A47r 2  F0 05                beq     @mul
001A49r 2  C9 2F                cmp     #'/'
001A4Br 2  F0 27                beq     @div
001A4Dr 2  60                   rts
001A4Er 2               @mul:
001A4Er 2  20 rr rr             jsr     ChkNum
001A51r 2  20 rr rr             jsr     ChrGet
001A54r 2  20 rr rr             jsr     PushFac
001A57r 2  20 rr rr             jsr     EvalPow
001A5Ar 2  20 rr rr             jsr     ChkNum
001A5Dr 2  20 rr rr             jsr     PullArg
001A60r 2  A5 86                lda     BAS_LVTYP
001A62r 2  10 03 4C rr          jmi     EvalTypeErr
001A66r 2  rr           
001A67r 2                       ; FAC = ARG * FAC: FMultT expects ARG + sign work.  See msbasic.
001A67r 2  A5 1B                lda     ARGSIGN
001A69r 2  45 13                eor     FACSIGN
001A6Br 2  85 1C                sta     SGNCPR
001A6Dr 2  A5 0E                lda     FAC
001A6Fr 2  20 rr rr             jsr     FMultT
001A72r 2  80 CE                bra     @loop
001A74r 2               @div:
001A74r 2  20 rr rr             jsr     ChkNum
001A77r 2  20 rr rr             jsr     ChrGet
001A7Ar 2  20 rr rr             jsr     PushFac
001A7Dr 2  20 rr rr             jsr     EvalPow
001A80r 2  20 rr rr             jsr     ChkNum
001A83r 2  20 rr rr             jsr     PullArg
001A86r 2  A5 86                lda     BAS_LVTYP
001A88r 2  10 03 4C rr          jmi     EvalTypeErr
001A8Cr 2  rr           
001A8Dr 2                       ; FAC = ARG / FAC: FDivT.
001A8Dr 2  A5 1B                lda     ARGSIGN
001A8Fr 2  45 13                eor     FACSIGN
001A91r 2  85 1C                sta     SGNCPR
001A93r 2  A5 0E                lda     FAC
001A95r 2  20 rr rr             jsr     FDivT
001A98r 2  80 A8                bra     @loop
001A9Ar 2               
001A9Ar 2               ; ===========================================================================
001A9Ar 2               ;   L E V E L 6  --  ^   (right-associative)
001A9Ar 2               ; ===========================================================================
001A9Ar 2               EvalPow:
001A9Ar 2  20 rr rr             jsr     EvalUnary
001A9Dr 2               @loop:
001A9Dr 2  20 rr rr             jsr     ChrGot
001AA0r 2  C9 5E                cmp     #'^'
001AA2r 2  D0 20                bne     @done
001AA4r 2  20 rr rr             jsr     ChkNum
001AA7r 2  20 rr rr             jsr     ChrGet
001AAAr 2  20 rr rr             jsr     PushFac
001AADr 2  20 rr rr             jsr     EvalUnary               ; right-assoc: recurse below
001AB0r 2                       ; Actually right-assoc means: evaluate the RHS at this level too.
001AB0r 2                       ; But EvalUnary doesn't loop ^; it stops.  Re-check ^ here?  No --
001AB0r 2                       ; for right-assoc we should recurse at the same level for the RHS.
001AB0r 2                       ; Simpler: after EvalUnary, look for another ^ and recurse.
001AB0r 2                       ; Implemented by jumping back to @loop (so chained ^ becomes
001AB0r 2                       ; left-assoc in this version).  Acceptable simplification.
001AB0r 2  20 rr rr             jsr     ChkNum
001AB3r 2  20 rr rr             jsr     PullArg
001AB6r 2  A5 86                lda     BAS_LVTYP
001AB8r 2  10 03 4C rr          jmi     EvalTypeErr
001ABCr 2  rr           
001ABDr 2                       ; FPwrt computes ARG ^ FAC.  Our ported FPwrt expects ARG = base,
001ABDr 2                       ; FAC = exponent, and A = FAC's exponent byte (FPwrt's first
001ABDr 2                       ; instruction is `beq Exp` to short-circuit FAC==0 -> 1).
001ABDr 2  A5 0E                lda     FAC
001ABFr 2  20 rr rr             jsr     FPwrt
001AC2r 2  80 D9                bra     @loop
001AC4r 2               @done:
001AC4r 2  60                   rts
001AC5r 2               
001AC5r 2               ; ===========================================================================
001AC5r 2               ;   L E V E L 7  --  U N A R Y
001AC5r 2               ; ===========================================================================
001AC5r 2               EvalUnary:
001AC5r 2  20 rr rr             jsr     ChrGot
001AC8r 2  C9 2D                cmp     #'-'
001ACAr 2  F0 07                beq     @neg
001ACCr 2  C9 2B                cmp     #'+'
001ACEr 2  F0 13                beq     @pos
001AD0r 2  4C rr rr             jmp     EvalAtom
001AD3r 2               @neg:
001AD3r 2  20 rr rr             jsr     ChrGet
001AD6r 2  20 rr rr             jsr     EvalUnary
001AD9r 2  20 rr rr             jsr     ChkNum
001ADCr 2                       ; Negate FAC: flip FACSIGN bit 7.
001ADCr 2  A5 13                lda     FACSIGN
001ADEr 2  49 FF                eor     #$FF
001AE0r 2  85 13                sta     FACSIGN
001AE2r 2  60                   rts
001AE3r 2               @pos:
001AE3r 2  20 rr rr             jsr     ChrGet
001AE6r 2  4C rr rr             jmp     EvalUnary
001AE9r 2               
001AE9r 2               ; ===========================================================================
001AE9r 2               ;   L E V E L 8  --  A T O M
001AE9r 2               ; ===========================================================================
001AE9r 2               EvalAtom:
001AE9r 2  64 64                stz     VALTYP                  ; default to numeric; string paths override
001AEBr 2  20 rr rr             jsr     ChrGot
001AEEr 2  90 2E                bcc     @num                    ; digit
001AF0r 2  C9 2E                cmp     #'.'
001AF2r 2  F0 2A                beq     @num
001AF4r 2  C9 22                cmp     #'"'
001AF6r 2  F0 29                beq     @str
001AF8r 2  C9 28                cmp     #'('
001AFAr 2  F0 3A                beq     @paren
001AFCr 2                       ; Letter? -> variable
001AFCr 2  20 rr rr             jsr     IsLetC
001AFFr 2  B0 3E                bcs     @var
001B01r 2                       ; Function token?
001B01r 2  C9 CD                cmp     #TOK_INKEY
001B03r 2  F0 59                beq     FnInkey
001B05r 2  C9 9D                cmp     #TOK_FN
001B07r 2  F0 12                beq     @fnCall                 ; FN A(...) — user-defined function
001B09r 2                       ; Hex literal in PRINT context: not here (no '$' literal supported).
001B09r 2                       ; NVRAM is dual-role (statement at $B1, function via FnTable);
001B09r 2                       ; allow it through even though it sits below TOK_SGN.
001B09r 2  C9 B1                cmp     #TOK_NVRAM
001B0Br 2  F0 08                beq     @fnDisp
001B0Dr 2                       ; Try function dispatch.
001B0Dr 2  C9 B6                cmp     #TOK_SGN
001B0Fr 2  90 07                bcc     @synErr
001B11r 2  C9 D1                cmp     #TOK_MAX+1
001B13r 2  B0 03                bcs     @synErr
001B15r 2               @fnDisp:
001B15r 2  4C rr rr             jmp     FnDispatch
001B18r 2               @synErr:
001B18r 2  4C rr rr             jmp     SynErr
001B1Br 2               @fnCall:
001B1Br 2  4C rr rr             jmp     FnCall
001B1Er 2               @num:
001B1Er 2                       ; ASCII numeric: jump to Fin.  Fin uses ChrGet to consume.
001B1Er 2  4C rr rr             jmp     Fin
001B21r 2               @str:
001B21r 2                       ; '"' string literal.  Consume the opening quote, then StrLit.
001B21r 2  20 rr rr             jsr     ChrGet                  ; consume "
001B24r 2                       ; StrLit expects (Y,A) = src.  Source = TXTPTR.
001B24r 2  A5 04                lda     TXTPTR
001B26r 2  A4 05                ldy     TXTPTR+1
001B28r 2  20 rr rr             jsr     StrLit
001B2Br 2                       ; StrLit advances internal pointer; we need to update TXTPTR.
001B2Br 2                       ; StrLit reads until $00 or '"' from (STRNG1)+y; FAC has length.
001B2Br 2                       ; Compute new TXTPTR = STRNG2 (which StrLit set), or TXTPTR + len + maybe-quote.
001B2Br 2                       ; STRNG2 = STRNG1 + len + (1 if hit quote else 0).  Use STRNG2.
001B2Br 2  A5 1E                lda     STRNG2
001B2Dr 2  85 04                sta     TXTPTR
001B2Fr 2  A5 1F                lda     STRNG2+1
001B31r 2  85 05                sta     TXTPTR+1
001B33r 2                       ; If we stopped at a closing quote, TXTPTR is past it (StrLit's
001B33r 2                       ; @endquote path: tya/adc STRNG1 with carry set since cmp set C);
001B33r 2                       ; if we ran into NUL, TXTPTR sits on the NUL (clc path).  Either
001B33r 2                       ; is correct for ChrGot.
001B33r 2  4C rr rr             jmp     ChrGot                  ; preload next char (for caller chains)
001B36r 2               @paren:
001B36r 2  20 rr rr             jsr     ChrGet                  ; consume '('
001B39r 2  20 rr rr             jsr     FrmEvl
001B3Cr 2  4C rr rr             jmp     ChkCls                  ; expects ')'; consumes via ChrGet
001B3Fr 2               @var:
001B3Fr 2                       ; Variable lookup.  PtrGet uses CHRGET internally and leaves
001B3Fr 2                       ; (A,Y) = VARPNT.  VALTYP is set to $00 or $FF.
001B3Fr 2  20 rr rr             jsr     PtrGet
001B42r 2                       ; Fetch value into FAC.
001B42r 2  24 64                bit     VALTYP
001B44r 2  30 07                bmi     @loadStr
001B46r 2                       ; numeric: FAC = (VARPNT)
001B46r 2  A5 3F                lda     VARPNT
001B48r 2  A4 40                ldy     VARPNT+1
001B4Ar 2  4C rr rr             jmp     LoadFacFromYa
001B4Dr 2               @loadStr:
001B4Dr 2                       ; string: copy descriptor [len][lo][hi] into FAC..FAC+2.
001B4Dr 2  A0 00                ldy     #0
001B4Fr 2  B1 3F                lda     (VARPNT),y
001B51r 2  85 0E                sta     FAC
001B53r 2  C8                   iny
001B54r 2  B1 3F                lda     (VARPNT),y
001B56r 2  85 0F                sta     FAC+1
001B58r 2  C8                   iny
001B59r 2  B1 3F                lda     (VARPNT),y
001B5Br 2  85 10                sta     FAC+2
001B5Dr 2  60                   rts
001B5Er 2               
001B5Er 2               ; ---------------------------------------------------------------------------
001B5Er 2               ; FnInkey -- INKEY (no parens).  Reads BAS_PENDKEY first; else BufferSize/
001B5Er 2               ; ReadBuffer; else 0.  Result is unsigned 8-bit FP value.
001B5Er 2               ; ---------------------------------------------------------------------------
001B5Er 2               FnInkey:
001B5Er 2  20 rr rr             jsr     ChrGet                  ; consume INKEY token
001B61r 2  AD 0E 03             lda     BAS_PENDKEY
001B64r 2  F0 09                beq     @noPend
001B66r 2                       ; consume pending key.
001B66r 2  A0 00                ldy     #0
001B68r 2  8C 0E 03             sty     BAS_PENDKEY
001B6Br 2  A8                   tay
001B6Cr 2  4C rr rr             jmp     SngFlt
001B6Fr 2               @noPend:
001B6Fr 2  20 rr rr             jsr     BufferSize
001B72r 2  F0 07                beq     @zero
001B74r 2  20 rr rr             jsr     ReadBuffer
001B77r 2  A8                   tay
001B78r 2  4C rr rr             jmp     SngFlt
001B7Br 2               @zero:
001B7Br 2  A0 00                ldy     #0
001B7Dr 2  4C rr rr             jmp     SngFlt
001B80r 2               
001B80r 2               ; ---------------------------------------------------------------------------
001B80r 2               ; FnDispatch -- A holds a function token in [TOK_SGN..TOK_MAX].  Dispatch
001B80r 2               ; via FnTable, which pairs (token, handler-1).
001B80r 2               ; ---------------------------------------------------------------------------
001B80r 2               FnDispatch:
001B80r 2  A2 00                ldx     #0
001B82r 2               @find:
001B82r 2  BD rr rr             lda     FnTable,x
001B85r 2  F0 14                beq     @synErr                 ; reached terminator
001B87r 2  D2 04                cmp     (TXTPTR)
001B89r 2  F0 05                beq     @match
001B8Br 2  E8                   inx
001B8Cr 2  E8                   inx
001B8Dr 2  E8                   inx
001B8Er 2  80 F2                bra     @find
001B90r 2               @match:
001B90r 2                       ; Push handler-1 onto stack so RTS jumps to it after ChrGet.
001B90r 2  BD rr rr             lda     FnTable+2,x
001B93r 2  48                   pha
001B94r 2  BD rr rr             lda     FnTable+1,x
001B97r 2  48                   pha
001B98r 2  4C rr rr             jmp     ChrGet                  ; consume token, return into handler
001B9Br 2               @synErr:
001B9Br 2  4C rr rr             jmp     SynErr
001B9Er 2               
001B9Er 2               ; ---------------------------------------------------------------------------
001B9Er 2               ; FnTable -- (token, handler-1) triples, $00-terminated.
001B9Er 2               ; "handler-1" because we push it through RTS which adds 1.
001B9Er 2               ; ---------------------------------------------------------------------------
001B9Er 2               FnTable:
001B9Er 2  B6                   .byte   TOK_SGN
001B9Fr 2  rr rr                .word   FnSgn-1
001BA1r 2  B7                   .byte   TOK_INT
001BA2r 2  rr rr                .word   FnInt-1
001BA4r 2  B8                   .byte   TOK_ABS
001BA5r 2  rr rr                .word   FnAbs-1
001BA7r 2  B9                   .byte   TOK_FRE
001BA8r 2  rr rr                .word   FnFre-1
001BAAr 2  BA                   .byte   TOK_POS
001BABr 2  rr rr                .word   FnPos-1
001BADr 2  BB                   .byte   TOK_SQR
001BAEr 2  rr rr                .word   FnSqr-1
001BB0r 2  BC                   .byte   TOK_RND
001BB1r 2  rr rr                .word   FnRnd-1
001BB3r 2  BD                   .byte   TOK_LOG
001BB4r 2  rr rr                .word   FnLog-1
001BB6r 2  BE                   .byte   TOK_EXP
001BB7r 2  rr rr                .word   FnExp-1
001BB9r 2  BF                   .byte   TOK_COS
001BBAr 2  rr rr                .word   FnCos-1
001BBCr 2  C0                   .byte   TOK_SIN
001BBDr 2  rr rr                .word   FnSin-1
001BBFr 2  C1                   .byte   TOK_TAN
001BC0r 2  rr rr                .word   FnTan-1
001BC2r 2  C2                   .byte   TOK_ATN
001BC3r 2  rr rr                .word   FnAtn-1
001BC5r 2  C3                   .byte   TOK_PEEK
001BC6r 2  rr rr                .word   FnPeek-1
001BC8r 2  C4                   .byte   TOK_LEN
001BC9r 2  rr rr                .word   FnLen-1
001BCBr 2  C5                   .byte   TOK_STRSTR
001BCCr 2  rr rr                .word   FnStrStr-1
001BCEr 2  C6                   .byte   TOK_VAL
001BCFr 2  rr rr                .word   FnVal-1
001BD1r 2  C7                   .byte   TOK_ASC
001BD2r 2  rr rr                .word   FnAsc-1
001BD4r 2  C8                   .byte   TOK_CHRSTR
001BD5r 2  rr rr                .word   FnChrStr-1
001BD7r 2  C9                   .byte   TOK_LEFTSTR
001BD8r 2  rr rr                .word   FnLeftStr-1
001BDAr 2  CA                   .byte   TOK_RIGHTSTR
001BDBr 2  rr rr                .word   FnRightStr-1
001BDDr 2  CB                   .byte   TOK_MIDSTR
001BDEr 2  rr rr                .word   FnMidStr-1
001BE0r 2  CC                   .byte   TOK_JOY
001BE1r 2  rr rr                .word   FnJoy-1
001BE3r 2  B1                   .byte   TOK_NVRAM
001BE4r 2  rr rr                .word   FnNvram-1
001BE6r 2  CE                   .byte   TOK_HEX
001BE7r 2  rr rr                .word   FnHex-1
001BE9r 2  CF                   .byte   TOK_MIN
001BEAr 2  rr rr                .word   FnMin-1
001BECr 2  D0                   .byte   TOK_MAX
001BEDr 2  rr rr                .word   FnMax-1
001BEFr 2  00                   .byte   0
001BF0r 2               
001BF0r 2               ; ---------------------------------------------------------------------------
001BF0r 2               ; Numeric-arg helpers.
001BF0r 2               ; ParenNum    -- expects "(" expr ")" with numeric result.  FAC = result.
001BF0r 2               ; ParenStr    -- expects "(" expr ")" with string result.
001BF0r 2               ; ParenU8     -- expects "(" expr ")" -> A = byte (0..255), or ?ILLQTY.
001BF0r 2               ; ParenU16    -- expects "(" expr ")" -> AyInt result in FAC+3,+4.
001BF0r 2               ; ---------------------------------------------------------------------------
001BF0r 2               ParenNum:
001BF0r 2  20 rr rr             jsr     ChkOpn
001BF3r 2  20 rr rr             jsr     FrmEvl
001BF6r 2  20 rr rr             jsr     ChkNum
001BF9r 2  4C rr rr             jmp     ChkCls
001BFCr 2               ParenStr:
001BFCr 2  20 rr rr             jsr     ChkOpn
001BFFr 2  20 rr rr             jsr     FrmEvl
001C02r 2  20 rr rr             jsr     ChkStr
001C05r 2  4C rr rr             jmp     ChkCls
001C08r 2               ParenU8:
001C08r 2  20 rr rr             jsr     ParenNum
001C0Br 2  20 rr rr             jsr     AyInt
001C0Er 2  A5 11                lda     FAC+3                   ; high byte must be 0
001C10r 2  D0 03                bne     @bad
001C12r 2  A5 12                lda     FAC+4                   ; low byte = result
001C14r 2  60                   rts
001C15r 2               @bad:
001C15r 2  4C rr rr             jmp     IqErr
001C18r 2               
001C18r 2               ; ---------------------------------------------------------------------------
001C18r 2               ; Unary numeric functions (single-arg "(" num ")") -- shared body.
001C18r 2               ; Each entry sets up A = handler entry to call after ChkOpn/FrmEvl/ChkNum/ChkCls.
001C18r 2               ; ---------------------------------------------------------------------------
001C18r 2               FnSgn:
001C18r 2  20 rr rr             jsr     ParenNum
001C1Br 2  4C rr rr             jmp     Sgn
001C1Er 2               FnInt:
001C1Er 2  20 rr rr             jsr     ParenNum
001C21r 2  4C rr rr             jmp     Int
001C24r 2               FnAbs:
001C24r 2  20 rr rr             jsr     ParenNum
001C27r 2  4C rr rr             jmp     Abs
001C2Ar 2               FnSqr:
001C2Ar 2  20 rr rr             jsr     ParenNum
001C2Dr 2  4C rr rr             jmp     Sqr
001C30r 2               FnLog:
001C30r 2  20 rr rr             jsr     ParenNum
001C33r 2  4C rr rr             jmp     Log
001C36r 2               FnExp:
001C36r 2  20 rr rr             jsr     ParenNum
001C39r 2  4C rr rr             jmp     Exp
001C3Cr 2               FnCos:
001C3Cr 2  20 rr rr             jsr     ParenNum
001C3Fr 2  4C rr rr             jmp     Cos
001C42r 2               FnSin:
001C42r 2  20 rr rr             jsr     ParenNum
001C45r 2  4C rr rr             jmp     Sin
001C48r 2               FnTan:
001C48r 2  20 rr rr             jsr     ParenNum
001C4Br 2  4C rr rr             jmp     Tan
001C4Er 2               FnAtn:
001C4Er 2  20 rr rr             jsr     ParenNum
001C51r 2  4C rr rr             jmp     Atn
001C54r 2               FnRnd:
001C54r 2  20 rr rr             jsr     ParenNum
001C57r 2  4C rr rr             jmp     Rnd
001C5Ar 2               FnHex:
001C5Ar 2                       ; In expression context: identity.
001C5Ar 2  4C rr rr             jmp     ParenNum
001C5Dr 2               
001C5Dr 2               ; ---------------------------------------------------------------------------
001C5Dr 2               ; FnFre -- FRE(n): returns FRETOP - STREND (free string heap).
001C5Dr 2               ; Argument is parsed and ignored.
001C5Dr 2               ; ---------------------------------------------------------------------------
001C5Dr 2               FnFre:
001C5Dr 2  20 rr rr             jsr     ParenNum
001C60r 2  38                   sec
001C61r 2  AD 65 03             lda     FRETOP
001C64r 2  ED 63 03             sbc     STREND
001C67r 2  A8                   tay
001C68r 2  AD 66 03             lda     FRETOP+1
001C6Br 2  ED 64 03             sbc     STREND+1
001C6Er 2  4C rr rr             jmp     GivAyf
001C71r 2               
001C71r 2               ; ---------------------------------------------------------------------------
001C71r 2               ; FnPos -- POS(n): not yet maintained; returns 0.
001C71r 2               ; ---------------------------------------------------------------------------
001C71r 2               FnPos:
001C71r 2  20 rr rr             jsr     ParenNum
001C74r 2  A0 00                ldy     #0
001C76r 2  4C rr rr             jmp     SngFlt
001C79r 2               
001C79r 2               ; ---------------------------------------------------------------------------
001C79r 2               ; FnPeek -- PEEK(addr): byte at addr -> FP.
001C79r 2               ; ---------------------------------------------------------------------------
001C79r 2               FnPeek:
001C79r 2  20 rr rr             jsr     ParenNum
001C7Cr 2  20 rr rr             jsr     FacToU16
001C7Fr 2  A5 12                lda     FAC+4                   ; lo byte
001C81r 2  85 20                sta     INDEX
001C83r 2  A5 11                lda     FAC+3                   ; hi byte
001C85r 2  85 21                sta     INDEX+1
001C87r 2  A0 00                ldy     #0
001C89r 2  B1 20                lda     (INDEX),y
001C8Br 2  A8                   tay
001C8Cr 2  4C rr rr             jmp     SngFlt
001C8Fr 2               
001C8Fr 2               ; ---------------------------------------------------------------------------
001C8Fr 2               ; FnJoy -- JOY(n): 1 or 2.  If GPIO absent, returns 0.
001C8Fr 2               ; ---------------------------------------------------------------------------
001C8Fr 2               FnJoy:
001C8Fr 2  20 rr rr             jsr     ParenU8
001C92r 2  48                   pha
001C93r 2  AD 0D 03             lda     HW_PRESENT
001C96r 2  29 20                and     #HW_GPIO
001C98r 2  F0 1C                beq     @absent
001C9Ar 2  68                   pla
001C9Br 2  C9 01                cmp     #1
001C9Dr 2  F0 09                beq     @j1
001C9Fr 2  C9 02                cmp     #2
001CA1r 2  F0 0C                beq     @j2
001CA3r 2  A2 0B                ldx     #ERR_ILLQUAN
001CA5r 2  4C rr rr             jmp     BasErrorVec
001CA8r 2               @j1:
001CA8r 2  20 rr rr             jsr     ReadJoystick1
001CABr 2  A8                   tay
001CACr 2  4C rr rr             jmp     SngFlt
001CAFr 2               @j2:
001CAFr 2  20 rr rr             jsr     ReadJoystick2
001CB2r 2  A8                   tay
001CB3r 2  4C rr rr             jmp     SngFlt
001CB6r 2               @absent:
001CB6r 2  68                   pla
001CB7r 2  A0 00                ldy     #0
001CB9r 2  4C rr rr             jmp     SngFlt
001CBCr 2               
001CBCr 2               ; ---------------------------------------------------------------------------
001CBCr 2               ; FnNvram -- NVRAM(addr): if RTC absent, return 0.
001CBCr 2               ; ---------------------------------------------------------------------------
001CBCr 2               FnNvram:
001CBCr 2  20 rr rr             jsr     ParenU8
001CBFr 2  48                   pha
001CC0r 2  AD 0D 03             lda     HW_PRESENT
001CC3r 2  29 04                and     #HW_RTC
001CC5r 2  F0 09                beq     @absent
001CC7r 2  68                   pla
001CC8r 2  AA                   tax
001CC9r 2  20 rr rr             jsr     RtcReadNVRAM
001CCCr 2  A8                   tay
001CCDr 2  4C rr rr             jmp     SngFlt
001CD0r 2               @absent:
001CD0r 2  68                   pla
001CD1r 2  A0 00                ldy     #0
001CD3r 2  4C rr rr             jmp     SngFlt
001CD6r 2               
001CD6r 2               ; ---------------------------------------------------------------------------
001CD6r 2               ; FnMin / FnMax -- two numeric args, smaller / larger.
001CD6r 2               ; ---------------------------------------------------------------------------
001CD6r 2               FnMin:
001CD6r 2  20 rr rr             jsr     MinMaxArgs              ; ARG = a, FAC = b, BAS_TMP3 = sign(b-a)
001CD9r 2                       ; Want smaller: if b>=a return a (ARG); else return b (FAC).
001CD9r 2  10 01                bpl     @retArg                 ; sign>=0 means b>=a
001CDBr 2  60                   rts                             ; FAC already = b
001CDCr 2               @retArg:
001CDCr 2  4C rr rr             jmp     CopyArgToFac
001CDFr 2               FnMax:
001CDFr 2  20 rr rr             jsr     MinMaxArgs
001CE2r 2                       ; Want larger: if b>=a return b (FAC); else return a (ARG).
001CE2r 2  10 03                bpl     @retFac
001CE4r 2  4C rr rr             jmp     CopyArgToFac
001CE7r 2               @retFac:
001CE7r 2  60                   rts
001CE8r 2               
001CE8r 2               ; MinMaxArgs -- consume "(" a "," b ")" with numerics; ARG=a, FAC=b.
001CE8r 2               ; Returns A = sign(b - a) (FF/00/01) and N flag set accordingly.
001CE8r 2               MinMaxArgs:
001CE8r 2  20 rr rr             jsr     ChkOpn
001CEBr 2  20 rr rr             jsr     FrmEvl
001CEEr 2  20 rr rr             jsr     ChkNum
001CF1r 2  20 rr rr             jsr     PushFac                 ; save a
001CF4r 2  20 rr rr             jsr     ChkCom
001CF7r 2  20 rr rr             jsr     FrmEvl
001CFAr 2  20 rr rr             jsr     ChkNum
001CFDr 2  20 rr rr             jsr     ChkCls
001D00r 2  20 rr rr             jsr     PullArg                 ; ARG = a, FAC = b
001D03r 2                       ; Stash ARG so we can restore after FComp's destructive sign-pack.
001D03r 2  A5 16                lda     ARG
001D05r 2  85 4D                sta     BAS_TEMP1
001D07r 2  A5 17                lda     ARG+1
001D09r 2  85 4E                sta     BAS_TEMP1+1
001D0Br 2  A5 18                lda     ARG+2
001D0Dr 2  85 4F                sta     BAS_TEMP1+2
001D0Fr 2  A5 19                lda     ARG+3
001D11r 2  85 50                sta     BAS_TEMP1+3
001D13r 2  A5 1A                lda     ARG+4
001D15r 2  85 51                sta     BAS_TEMP1+4
001D17r 2  A5 1B                lda     ARGSIGN
001D19r 2  85 52                sta     BAS_TEMP1+5
001D1Br 2                       ; Pack ARGSIGN into bit 7 of ARG+1 so FComp reads it correctly.
001D1Br 2  A5 1B                lda     ARGSIGN
001D1Dr 2  09 7F                ora     #$7F
001D1Fr 2  25 17                and     ARG+1
001D21r 2  85 17                sta     ARG+1
001D23r 2  A9 16                lda     #<ARG
001D25r 2  A0 00                ldy     #$00
001D27r 2  20 rr rr             jsr     FComp                   ; A = sign(FAC - ARG)
001D2Ar 2  48                   pha
001D2Br 2                       ; Restore ARG.
001D2Br 2  A5 4D                lda     BAS_TEMP1
001D2Dr 2  85 16                sta     ARG
001D2Fr 2  A5 4E                lda     BAS_TEMP1+1
001D31r 2  85 17                sta     ARG+1
001D33r 2  A5 4F                lda     BAS_TEMP1+2
001D35r 2  85 18                sta     ARG+2
001D37r 2  A5 50                lda     BAS_TEMP1+3
001D39r 2  85 19                sta     ARG+3
001D3Br 2  A5 51                lda     BAS_TEMP1+4
001D3Dr 2  85 1A                sta     ARG+4
001D3Fr 2  A5 52                lda     BAS_TEMP1+5
001D41r 2  85 1B                sta     ARGSIGN
001D43r 2  68                   pla                             ; restore A, sets N/Z flags
001D44r 2  60                   rts
001D45r 2               
001D45r 2               ; ---------------------------------------------------------------------------
001D45r 2               ; FnLen -- LEN(s$): length of string.
001D45r 2               ; ---------------------------------------------------------------------------
001D45r 2               FnLen:
001D45r 2  20 rr rr             jsr     ParenStr
001D48r 2  A4 0E                ldy     FAC                     ; length
001D4Ar 2  20 rr rr             jsr     FreFac                  ; release temp string if any
001D4Dr 2  4C rr rr             jmp     SngFlt
001D50r 2               
001D50r 2               ; ---------------------------------------------------------------------------
001D50r 2               ; FnAsc -- ASC(s$): code of first char; ?ILLQTY if empty.
001D50r 2               ; ---------------------------------------------------------------------------
001D50r 2               FnAsc:
001D50r 2  20 rr rr             jsr     ParenStr
001D53r 2  A5 0E                lda     FAC
001D55r 2  F0 15                beq     @bad
001D57r 2                       ; Read first byte of string.
001D57r 2  A5 0F                lda     FAC+1
001D59r 2  85 20                sta     INDEX
001D5Br 2  A5 10                lda     FAC+2
001D5Dr 2  85 21                sta     INDEX+1
001D5Fr 2  A0 00                ldy     #0
001D61r 2  B1 20                lda     (INDEX),y
001D63r 2  48                   pha
001D64r 2  20 rr rr             jsr     FreFac
001D67r 2  68                   pla
001D68r 2  A8                   tay
001D69r 2  4C rr rr             jmp     SngFlt
001D6Cr 2               @bad:
001D6Cr 2  4C rr rr             jmp     IqErr
001D6Fr 2               
001D6Fr 2               ; ---------------------------------------------------------------------------
001D6Fr 2               ; FnChrStr -- CHR$(n): 1-char string.
001D6Fr 2               ; ---------------------------------------------------------------------------
001D6Fr 2               FnChrStr:
001D6Fr 2  20 rr rr             jsr     ParenU8
001D72r 2  48                   pha
001D73r 2  A9 01                lda     #1
001D75r 2  20 rr rr             jsr     GetSpa                  ; (Y,X) = addr; A unchanged
001D78r 2  68                   pla
001D79r 2  A0 00                ldy     #0
001D7Br 2  91 84                sta     (FRESPC),y
001D7Dr 2                       ; Build descriptor in FAC.
001D7Dr 2  A9 01                lda     #1
001D7Fr 2  85 0E                sta     FAC
001D81r 2  A5 84                lda     FRESPC
001D83r 2  85 0F                sta     FAC+1
001D85r 2  A5 85                lda     FRESPC+1
001D87r 2  85 10                sta     FAC+2
001D89r 2                       ; Advance FRESPC past the byte we just wrote.
001D89r 2  E6 84                inc     FRESPC
001D8Br 2  D0 02                bne     @nb
001D8Dr 2  E6 85                inc     FRESPC+1
001D8Fr 2               @nb:
001D8Fr 2  4C rr rr             jmp     PutNew
001D92r 2               
001D92r 2               ; ---------------------------------------------------------------------------
001D92r 2               ; FnStrStr -- STR$(n): convert numeric to string.
001D92r 2               ; ---------------------------------------------------------------------------
001D92r 2               FnStrStr:
001D92r 2  20 rr rr             jsr     ParenNum
001D95r 2  20 rr rr             jsr     Fout                    ; A=lo, Y=hi -> NUL-terminated buffer
001D98r 2                       ; (A,Y) = pointer to NUL-terminated ASCII number string in STACK2.
001D98r 2  20 rr rr             jsr     StrLit                  ; allocates + copies + PutNew
001D9Br 2  60                   rts
001D9Cr 2               
001D9Cr 2               ; ---------------------------------------------------------------------------
001D9Cr 2               ; FnVal -- VAL(s$): parse leading numeric from string.
001D9Cr 2               ; Temporarily NUL-terminates the string in place, redirects TXTPTR, calls
001D9Cr 2               ; Fin, then restores.
001D9Cr 2               ; ---------------------------------------------------------------------------
001D9Cr 2               FnVal:
001D9Cr 2  20 rr rr             jsr     ParenStr
001D9Fr 2  A5 0E                lda     FAC
001DA1r 2  D0 06                bne     @nz
001DA3r 2                       ; empty string -> 0
001DA3r 2  20 rr rr             jsr     FreFac
001DA6r 2  4C rr rr             jmp     ZeroFac
001DA9r 2               @nz:
001DA9r 2                       ; Stash length, address into TEMP1..TEMP1+2.
001DA9r 2  85 4D                sta     TEMP1                   ; length
001DABr 2  A5 0F                lda     FAC+1
001DADr 2  85 4E                sta     TEMP1+1
001DAFr 2  A5 10                lda     FAC+2
001DB1r 2  85 4F                sta     TEMP1+2
001DB3r 2                       ; Save the byte at offset = length and replace with $00.
001DB3r 2  A5 4E                lda     TEMP1+1
001DB5r 2  85 20                sta     INDEX
001DB7r 2  A5 4F                lda     TEMP1+2
001DB9r 2  85 21                sta     INDEX+1
001DBBr 2  A4 4D                ldy     TEMP1
001DBDr 2  B1 20                lda     (INDEX),y
001DBFr 2  85 50                sta     TEMP1+3                 ; saved byte
001DC1r 2  A9 00                lda     #0
001DC3r 2  91 20                sta     (INDEX),y
001DC5r 2                       ; Save TXTPTR.
001DC5r 2  A5 04                lda     TXTPTR
001DC7r 2  48                   pha
001DC8r 2  A5 05                lda     TXTPTR+1
001DCAr 2  48                   pha
001DCBr 2                       ; TXTPTR := INDEX - 1, then ChrGet to load first char.
001DCBr 2  A5 4E                lda     TEMP1+1
001DCDr 2  85 04                sta     TXTPTR
001DCFr 2  A5 4F                lda     TEMP1+2
001DD1r 2  85 05                sta     TXTPTR+1
001DD3r 2  A5 04                lda     TXTPTR
001DD5r 2  D0 02                bne     @nb
001DD7r 2  C6 05                dec     TXTPTR+1
001DD9r 2               @nb:
001DD9r 2  C6 04                dec     TXTPTR
001DDBr 2  20 rr rr             jsr     ChrGet                  ; first char
001DDEr 2  20 rr rr             jsr     Fin                     ; FAC := value
001DE1r 2                       ; Restore the saved byte.
001DE1r 2  A5 4E                lda     TEMP1+1
001DE3r 2  85 20                sta     INDEX
001DE5r 2  A5 4F                lda     TEMP1+2
001DE7r 2  85 21                sta     INDEX+1
001DE9r 2  A4 4D                ldy     TEMP1
001DEBr 2  A5 50                lda     TEMP1+3
001DEDr 2  91 20                sta     (INDEX),y
001DEFr 2                       ; Restore TXTPTR.
001DEFr 2  68                   pla
001DF0r 2  85 05                sta     TXTPTR+1
001DF2r 2  68                   pla
001DF3r 2  85 04                sta     TXTPTR
001DF5r 2  60                   rts
001DF6r 2               
001DF6r 2               ; ---------------------------------------------------------------------------
001DF6r 2               ; FnLeftStr -- LEFT$(s$, n): leftmost n chars.
001DF6r 2               ; ---------------------------------------------------------------------------
001DF6r 2               FnLeftStr:
001DF6r 2  20 rr rr             jsr     ChkOpn
001DF9r 2  20 rr rr             jsr     FrmEvl
001DFCr 2  20 rr rr             jsr     ChkStr
001DFFr 2  20 rr rr             jsr     ChkCom
001E02r 2  20 rr rr             jsr     PushFac                 ; save string descriptor
001E05r 2  20 rr rr             jsr     FrmEvl
001E08r 2  20 rr rr             jsr     ChkNum
001E0Br 2  20 rr rr             jsr     ChkCls
001E0Er 2  20 rr rr             jsr     AyInt
001E11r 2  20 rr rr             jsr     PullArg                 ; ARG = string descriptor (BAS_TMP1 clobbered)
001E14r 2                       ; FAC still holds the integer n; check range and copy now.
001E14r 2  A5 11                lda     FAC+3
001E16r 2  D0 16                bne     @bad
001E18r 2  A5 12                lda     FAC+4
001E1Ar 2  85 3B                sta     BAS_TMP1+1              ; n
001E1Cr 2                       ; Clamp n to ARG (length).
001E1Cr 2  A5 3B                lda     BAS_TMP1+1
001E1Er 2  C5 16                cmp     ARG
001E20r 2  90 02                bcc     @ok
001E22r 2  A5 16                lda     ARG
001E24r 2               @ok:
001E24r 2  85 3B                sta     BAS_TMP1+1
001E26r 2                       ; Free the source temp BEFORE allocating result so the slot frees up.
001E26r 2  20 rr rr             jsr     FreeArgString
001E29r 2                       ; Offset = 0 for LEFT$.
001E29r 2  64 3A                stz     BAS_TMP1
001E2Br 2                       ; Allocate, copy first n bytes.
001E2Br 2  4C rr rr             jmp     SubstrCommon            ; tail-call (rts to caller)
001E2Er 2               @bad:
001E2Er 2  4C rr rr             jmp     IqErr
001E31r 2               
001E31r 2               ; ---------------------------------------------------------------------------
001E31r 2               ; FnRightStr -- RIGHT$(s$, n): rightmost n chars.
001E31r 2               ; ---------------------------------------------------------------------------
001E31r 2               FnRightStr:
001E31r 2  20 rr rr             jsr     ChkOpn
001E34r 2  20 rr rr             jsr     FrmEvl
001E37r 2  20 rr rr             jsr     ChkStr
001E3Ar 2  20 rr rr             jsr     ChkCom
001E3Dr 2  20 rr rr             jsr     PushFac
001E40r 2  20 rr rr             jsr     FrmEvl
001E43r 2  20 rr rr             jsr     ChkNum
001E46r 2  20 rr rr             jsr     ChkCls
001E49r 2  20 rr rr             jsr     AyInt
001E4Cr 2  20 rr rr             jsr     PullArg                 ; ARG = string descriptor (BAS_TMP1 clobbered)
001E4Fr 2  A5 11                lda     FAC+3
001E51r 2  D0 1B                bne     @bad
001E53r 2  A5 12                lda     FAC+4
001E55r 2  85 3B                sta     BAS_TMP1+1              ; n
001E57r 2                       ; Clamp n.
001E57r 2  A5 3B                lda     BAS_TMP1+1
001E59r 2  C5 16                cmp     ARG
001E5Br 2  90 02                bcc     @ok
001E5Dr 2  A5 16                lda     ARG
001E5Fr 2               @ok:
001E5Fr 2  85 3B                sta     BAS_TMP1+1
001E61r 2                       ; offset = ARG - n.
001E61r 2  A5 16                lda     ARG
001E63r 2  38                   sec
001E64r 2  E5 3B                sbc     BAS_TMP1+1
001E66r 2  85 3A                sta     BAS_TMP1                ; start offset
001E68r 2  20 rr rr             jsr     FreeArgString
001E6Br 2  4C rr rr             jmp     SubstrCommon
001E6Er 2               @bad:
001E6Er 2  4C rr rr             jmp     IqErr
001E71r 2               
001E71r 2               ; ---------------------------------------------------------------------------
001E71r 2               ; FnMidStr -- MID$(s$, m [, n]): substring starting at m (1-based).
001E71r 2               ; ---------------------------------------------------------------------------
001E71r 2               FnMidStr:
001E71r 2  20 rr rr             jsr     ChkOpn
001E74r 2  20 rr rr             jsr     FrmEvl
001E77r 2  20 rr rr             jsr     ChkStr
001E7Ar 2  20 rr rr             jsr     ChkCom
001E7Dr 2  20 rr rr             jsr     PushFac
001E80r 2                       ; Read m.
001E80r 2  20 rr rr             jsr     FrmEvl
001E83r 2  20 rr rr             jsr     ChkNum
001E86r 2  20 rr rr             jsr     AyInt
001E89r 2  A5 11                lda     FAC+3
001E8Br 2  D0 4B                bne     @bad
001E8Dr 2  A5 12                lda     FAC+4
001E8Fr 2  F0 47                beq     @bad                    ; m must be >= 1
001E91r 2  38                   sec
001E92r 2  E9 01                sbc     #1
001E94r 2  85 3A                sta     BAS_TMP1                ; offset = m-1
001E96r 2                       ; Optional ", n".
001E96r 2  20 rr rr             jsr     ChrGot
001E99r 2  C9 2C                cmp     #','
001E9Br 2  F0 06                beq     @hasN
001E9Dr 2                       ; No n: take rest -> n = 255 (will clamp).
001E9Dr 2  A9 FF                lda     #255
001E9Fr 2  85 3B                sta     BAS_TMP1+1
001EA1r 2  80 14                bra     @cls
001EA3r 2               @hasN:
001EA3r 2  20 rr rr             jsr     ChrGet
001EA6r 2  20 rr rr             jsr     FrmEvl
001EA9r 2  20 rr rr             jsr     ChkNum
001EACr 2  20 rr rr             jsr     AyInt
001EAFr 2  A5 11                lda     FAC+3
001EB1r 2  D0 25                bne     @bad
001EB3r 2  A5 12                lda     FAC+4
001EB5r 2  85 3B                sta     BAS_TMP1+1
001EB7r 2               @cls:
001EB7r 2  20 rr rr             jsr     ChkCls
001EBAr 2  20 rr rr             jsr     PullArg                 ; ARG = string
001EBDr 2                       ; Clamp offset to length.
001EBDr 2  A5 3A                lda     BAS_TMP1
001EBFr 2  C5 16                cmp     ARG
001EC1r 2  90 04                bcc     @offOk
001EC3r 2  A5 16                lda     ARG                     ; offset = length -> empty result
001EC5r 2  85 3A                sta     BAS_TMP1
001EC7r 2               @offOk:
001EC7r 2                       ; Clamp n to (length - offset).
001EC7r 2  38                   sec
001EC8r 2  A5 16                lda     ARG
001ECAr 2  E5 3A                sbc     BAS_TMP1
001ECCr 2  C5 3B                cmp     BAS_TMP1+1
001ECEr 2  B0 02                bcs     @nOk
001ED0r 2  85 3B                sta     BAS_TMP1+1
001ED2r 2               @nOk:
001ED2r 2  20 rr rr             jsr     FreeArgString
001ED5r 2  4C rr rr             jmp     SubstrCommon
001ED8r 2               @bad:
001ED8r 2  4C rr rr             jmp     IqErr
001EDBr 2               
001EDBr 2               ; ---------------------------------------------------------------------------
001EDBr 2               ; SubstrCommon -- copy BAS_TMP1+1 bytes from ARG-string at offset BAS_TMP1
001EDBr 2               ; into a new heap allocation; result descriptor in FAC; PutNew.
001EDBr 2               ; ---------------------------------------------------------------------------
001EDBr 2               SubstrCommon:
001EDBr 2                       ; Allocate.
001EDBr 2  A5 3B                lda     BAS_TMP1+1
001EDDr 2  20 rr rr             jsr     GetSpa                  ; FRESPC = new buffer
001EE0r 2                       ; Source pointer = ARG+1 (lo/hi) + BAS_TMP1.
001EE0r 2  18                   clc
001EE1r 2  A5 17                lda     ARG+1
001EE3r 2  65 3A                adc     BAS_TMP1
001EE5r 2  85 20                sta     INDEX
001EE7r 2  A5 18                lda     ARG+2
001EE9r 2  69 00                adc     #0
001EEBr 2  85 21                sta     INDEX+1
001EEDr 2                       ; Copy BAS_TMP1+1 bytes from (INDEX) to (FRESPC).
001EEDr 2  A4 3B                ldy     BAS_TMP1+1
001EEFr 2  F0 0B                beq     @done
001EF1r 2  A0 00                ldy     #0
001EF3r 2               @cp:
001EF3r 2  B1 20                lda     (INDEX),y
001EF5r 2  91 84                sta     (FRESPC),y
001EF7r 2  C8                   iny
001EF8r 2  C4 3B                cpy     BAS_TMP1+1
001EFAr 2  D0 F7                bne     @cp
001EFCr 2               @done:
001EFCr 2                       ; Build descriptor.
001EFCr 2  A5 3B                lda     BAS_TMP1+1
001EFEr 2  85 0E                sta     FAC
001F00r 2  A5 84                lda     FRESPC
001F02r 2  85 0F                sta     FAC+1
001F04r 2  A5 85                lda     FRESPC+1
001F06r 2  85 10                sta     FAC+2
001F08r 2                       ; Advance FRESPC by length consumed.
001F08r 2  18                   clc
001F09r 2  A5 84                lda     FRESPC
001F0Br 2  65 3B                adc     BAS_TMP1+1
001F0Dr 2  85 84                sta     FRESPC
001F0Fr 2  90 02                bcc     @nb
001F11r 2  E6 85                inc     FRESPC+1
001F13r 2               @nb:
001F13r 2  4C rr rr             jmp     PutNew
001F16r 2               
001F16r 2               ; FreeArgString -- if ARG holds a temp string descriptor (most-recent
001F16r 2               ; on TEMPST), pop just the descriptor.  Heap is left intact so callers
001F16r 2               ; that still need the source bytes can copy them safely; orphaned heap
001F16r 2               ; will be reclaimed by Garbag.
001F16r 2               FreeArgString:
001F16r 2  A5 19                lda     ARG+3                   ; descriptor address lo
001F18r 2  A4 1A                ldy     ARG+4                   ; descriptor address hi (always $00)
001F1Ar 2  4C rr rr             jmp     FreTms
001F1Dr 2               
001F1Dr 2               ; Cleanup that releases both ARG's and FAC's temp descriptors (called from
001F1Dr 2               ; CatStr after content has been stashed but before new allocation).
001F1Dr 2               FreeBothTemps:
001F1Dr 2                       ; Free FAC's temp first (it is currently LASTPT).
001F1Dr 2  A5 11                lda     FAC+3
001F1Fr 2  A4 12                ldy     FAC+4
001F21r 2  20 rr rr             jsr     FreTms
001F24r 2                       ; Then ARG's (now LASTPT after FAC's removal).
001F24r 2  A5 19                lda     ARG+3
001F26r 2  A4 1A                ldy     ARG+4
001F28r 2  4C rr rr             jmp     FreTms
001F2Br 2  60                   rts
001F2Cr 2               
001F2Cr 2               ; ===========================================================================
001F2Cr 2               ;   E V A L U A T O R   -   B I N A R Y   O P E R A T O R   H E L P E R S
001F2Cr 2               ; ===========================================================================
001F2Cr 2               
001F2Cr 2               ; ---------------------------------------------------------------------------
001F2Cr 2               ; AndOp -- FAC = ARG AND FAC (bitwise on 16-bit signed ints).
001F2Cr 2               ; ---------------------------------------------------------------------------
001F2Cr 2               AndOp:
001F2Cr 2  20 rr rr             jsr     AyInt                   ; FAC -> int (FAC+3=hi, FAC+4=lo)
001F2Fr 2  A5 11                lda     FAC+3
001F31r 2  85 3A                sta     BAS_TMP1                ; saved hi
001F33r 2  A5 12                lda     FAC+4
001F35r 2  85 3B                sta     BAS_TMP1+1              ; saved lo
001F37r 2  20 rr rr             jsr     CopyArgToFac
001F3Ar 2  20 rr rr             jsr     AyInt
001F3Dr 2  A5 12                lda     FAC+4
001F3Fr 2  25 3B                and     BAS_TMP1+1
001F41r 2  A8                   tay                             ; Y = lo result
001F42r 2  A5 11                lda     FAC+3
001F44r 2  25 3A                and     BAS_TMP1                ; A = hi result
001F46r 2  4C rr rr             jmp     GivAyf
001F49r 2               
001F49r 2               ; ---------------------------------------------------------------------------
001F49r 2               ; OrOp -- FAC = ARG OR FAC.
001F49r 2               ; ---------------------------------------------------------------------------
001F49r 2               OrOp:
001F49r 2  20 rr rr             jsr     AyInt
001F4Cr 2  A5 11                lda     FAC+3
001F4Er 2  85 3A                sta     BAS_TMP1                ; saved hi
001F50r 2  A5 12                lda     FAC+4
001F52r 2  85 3B                sta     BAS_TMP1+1              ; saved lo
001F54r 2  20 rr rr             jsr     CopyArgToFac
001F57r 2  20 rr rr             jsr     AyInt
001F5Ar 2  A5 12                lda     FAC+4
001F5Cr 2  05 3B                ora     BAS_TMP1+1
001F5Er 2  A8                   tay                             ; Y = lo
001F5Fr 2  A5 11                lda     FAC+3
001F61r 2  05 3A                ora     BAS_TMP1                ; A = hi
001F63r 2  4C rr rr             jmp     GivAyf
001F66r 2               
001F66r 2               ; ---------------------------------------------------------------------------
001F66r 2               ; NotOp -- FAC = NOT FAC (bitwise complement of 16-bit signed int).
001F66r 2               ; ---------------------------------------------------------------------------
001F66r 2               NotOp:
001F66r 2  20 rr rr             jsr     AyInt
001F69r 2  A5 12                lda     FAC+4
001F6Br 2  49 FF                eor     #$FF
001F6Dr 2  A8                   tay                             ; Y = lo
001F6Er 2  A5 11                lda     FAC+3
001F70r 2  49 FF                eor     #$FF                    ; A = hi
001F72r 2  4C rr rr             jmp     GivAyf
001F75r 2               
001F75r 2               ; ---------------------------------------------------------------------------
001F75r 2               ; BasCmdLet -- minimal LET (assignment).  Entered with ChrGot returning
001F75r 2               ; the first letter of the variable name.  No `LET` keyword required.
001F75r 2               ; ---------------------------------------------------------------------------
001F75r 2               BasCmdLet:
001F75r 2  20 rr rr             jsr     PtrGet                  ; VARPNT, VALTYP set; TXTPTR past name
001F78r 2                       ; Save VARPNT and the variable's VALTYP across FrmEvl.
001F78r 2  A5 3F                lda     VARPNT
001F7Ar 2  48                   pha
001F7Br 2  A5 40                lda     VARPNT+1
001F7Dr 2  48                   pha
001F7Er 2  A5 64                lda     VALTYP
001F80r 2  48                   pha
001F81r 2  20 rr rr             jsr     ChrGot
001F84r 2  C9 3D                cmp     #'='
001F86r 2  D0 2F                bne     @synErr
001F88r 2  20 rr rr             jsr     ChrGet
001F8Br 2  20 rr rr             jsr     FrmEvl
001F8Er 2  68                   pla                             ; saved variable VALTYP
001F8Fr 2  85 3E                sta     BAS_TMP3
001F91r 2  45 64                eor     VALTYP
001F93r 2  30 28                bmi     @typeErr
001F95r 2  68                   pla
001F96r 2  85 40                sta     VARPNT+1
001F98r 2  68                   pla
001F99r 2  85 3F                sta     VARPNT
001F9Br 2  24 3E                bit     BAS_TMP3
001F9Dr 2  30 07                bmi     @storeStr
001F9Fr 2                       ; Numeric: store FAC into (VARPNT) (5 bytes).
001F9Fr 2  A6 3F                ldx     VARPNT
001FA1r 2  A4 40                ldy     VARPNT+1
001FA3r 2  4C rr rr             jmp     StoreFacAtYxRounded
001FA6r 2               @storeStr:
001FA6r 2  A0 00                ldy     #0
001FA8r 2  A5 0E                lda     FAC
001FAAr 2  91 3F                sta     (VARPNT),y
001FACr 2  C8                   iny
001FADr 2  A5 0F                lda     FAC+1
001FAFr 2  91 3F                sta     (VARPNT),y
001FB1r 2  C8                   iny
001FB2r 2  A5 10                lda     FAC+2
001FB4r 2  91 3F                sta     (VARPNT),y
001FB6r 2  60                   rts
001FB7r 2               @synErr:
001FB7r 2  68                   pla
001FB8r 2  68                   pla
001FB9r 2  68                   pla
001FBAr 2  4C rr rr             jmp     SynErr
001FBDr 2               @typeErr:
001FBDr 2  68                   pla
001FBEr 2  68                   pla
001FBFr 2  A2 08                ldx     #ERR_TYPEMISM
001FC1r 2  4C rr rr             jmp     BasErrorVec
001FC4r 2               
001FC4r 2               ; =============================================================================
001FC4r 2               ;   C O N T R O L   F L O W   /   S T A T E M E N T   L O O P
001FC4r 2               ;
001FC4r 2               ;   BasNewstt drives execution for both direct mode (TXTPTR in BAS_TOKBUF)
001FC4r 2               ;   and run mode (TXTPTR walks program lines from BAS_TXTTAB).  Statement
001FC4r 2               ;   dispatch follows the msbasic convention: push (routine_addr - 1) and
001FC4r 2               ;   tail-jump through ChrGet, so the routine entry is reached via RTS.
001FC4r 2               ;
001FC4r 2               ;   FOR and GOSUB store frames on the CPU stack and JMP back to BasNewstt;
001FC4r 2               ;   NEXT and RETURN scan the stack for a matching tag, then TXS to discard
001FC4r 2               ;   the frame and resume.
001FC4r 2               ; =============================================================================
001FC4r 2               
001FC4r 2               NUM_STMT_TOKENS = TOK_MEM + 1 - TOK_BASE       ; $36 entries
001FC4r 2               
001FC4r 2               BasNewstt:
001FC4r 2  20 rr rr             jsr     BasCheckBreak
001FC7r 2                       ; Save TXTPTR -> OLDTEXT for CONT, except in direct mode.
001FC7r 2  AD 6A 03             lda     BAS_CURLIN+1
001FCAr 2  C9 FF                cmp     #$FF
001FCCr 2  F0 0A                beq     @noSave
001FCEr 2  A5 04                lda     TXTPTR
001FD0r 2  8D 6D 03             sta     BAS_OLDTEXT
001FD3r 2  A5 05                lda     TXTPTR+1
001FD5r 2  8D 6E 03             sta     BAS_OLDTEXT+1
001FD8r 2               @noSave:
001FD8r 2  A0 00                ldy     #0
001FDAr 2  B1 04                lda     (TXTPTR),y
001FDCr 2  F0 10                beq     @endLine
001FDEr 2  C9 A4                cmp     #TOK_ELSE
001FE0r 2  F0 07                beq     @skipElse               ; THEN-branch ran; skip ELSE clause to EOL
001FE2r 2  C9 3A                cmp     #':'
001FE4r 2  F0 34                beq     @nextStmt
001FE6r 2  4C rr rr             jmp     SynErr
001FE9r 2               @skipElse:
001FE9r 2                       ; Advance TXTPTR until we land on a $00 terminator.
001FE9r 2               @skLoop:
001FE9r 2  20 rr rr             jsr     ChrGet
001FECr 2  D0 FB                bne     @skLoop
001FEEr 2                       ; Fall through to @endLine with TXTPTR at $00.
001FEEr 2               @endLine:
001FEEr 2                       ; Direct mode: end of buffer -> back to REPL.
001FEEr 2  AD 6A 03             lda     BAS_CURLIN+1
001FF1r 2  C9 FF                cmp     #$FF
001FF3r 2  D0 03                bne     @walkNext
001FF5r 2  4C rr rr             jmp     BasReadyLoop            ; OK is printed by BasReadyLoop
001FF8r 2               @walkNext:
001FF8r 2                       ; Run mode: examine next-pointer at offsets +1,+2.
001FF8r 2  A0 02                ldy     #2
001FFAr 2  B1 04                lda     (TXTPTR),y
001FFCr 2  D0 06                bne     @loadLine               ; nonzero hi -> next line exists
001FFEr 2                       ; End of program -> halt and return to REPL.
001FFEr 2  A2 FF                ldx     #$FF
002000r 2  9A                   txs
002001r 2  4C rr rr             jmp     BasReadyLoop
002004r 2               @loadLine:
002004r 2  C8                   iny                             ; y=3
002005r 2  B1 04                lda     (TXTPTR),y
002007r 2  8D 69 03             sta     BAS_CURLIN
00200Ar 2  C8                   iny                             ; y=4
00200Br 2  B1 04                lda     (TXTPTR),y
00200Dr 2  8D 6A 03             sta     BAS_CURLIN+1
002010r 2  98                   tya                             ; A=4
002011r 2  18                   clc
002012r 2  65 04                adc     TXTPTR
002014r 2  85 04                sta     TXTPTR
002016r 2  90 02                bcc     @nextStmt
002018r 2  E6 05                inc     TXTPTR+1
00201Ar 2               @nextStmt:
00201Ar 2  20 rr rr             jsr     ChrGet
00201Dr 2  20 rr rr             jsr     BasExecuteStatement
002020r 2  4C rr rr             jmp     BasNewstt
002023r 2               
002023r 2               ; ---------------------------------------------------------------------------
002023r 2               ; BasExecuteStatement -- A = current tokenized byte (loaded by ChrGet).
002023r 2               ;   * A = 0  -> RTS (no-op; end of statement chain).
002023r 2               ;   * A < $80 (letter) -> JMP BasCmdLet.
002023r 2               ;   * A is a statement token ($80..TOK_MEM) -> dispatch via BasTokenAddrTbl.
002023r 2               ;   * Otherwise -> ?SYNTAX ERROR.
002023r 2               ; ---------------------------------------------------------------------------
002023r 2               BasExecuteStatement:
002023r 2  F0 1C                beq     @ret
002025r 2  38                   sec
002026r 2  E9 80                sbc     #TOK_BASE
002028r 2  90 11                bcc     @doLet
00202Ar 2  C9 36                cmp     #NUM_STMT_TOKENS
00202Cr 2  B0 10                bcs     @synErr
00202Er 2  0A                   asl     a
00202Fr 2  A8                   tay
002030r 2  B9 rr rr             lda     BasTokenAddrTbl+1,y
002033r 2  48                   pha
002034r 2  B9 rr rr             lda     BasTokenAddrTbl,y
002037r 2  48                   pha
002038r 2  4C rr rr             jmp     ChrGet
00203Br 2               @doLet:
00203Br 2  4C rr rr             jmp     BasCmdLet
00203Er 2               @synErr:
00203Er 2  4C rr rr             jmp     SynErr
002041r 2               @ret:
002041r 2  60                   rts
002042r 2               
002042r 2               ; ---------------------------------------------------------------------------
002042r 2               ; BasCheckBreak -- poll input buffer for Ctrl-C / ESC.  On break, save
002042r 2               ; CONT context and bounce to REPL.  Other keys are stashed in BAS_PENDKEY
002042r 2               ; for INKEY to retrieve.
002042r 2               ; ---------------------------------------------------------------------------
002042r 2               BasCheckBreak:
002042r 2                       ; In direct mode (CURLIN hi == $FF) skip the break check entirely;
002042r 2                       ; otherwise we would drain pending REPL keystrokes and corrupt the
002042r 2                       ; next BasReadLine input.  Break is only meaningful while RUNning.
002042r 2  AD 6A 03             lda     BAS_CURLIN+1
002045r 2  C9 FF                cmp     #$FF
002047r 2  F0 13                beq     @no
002049r 2  20 rr rr             jsr     BufferSize
00204Cr 2  F0 0E                beq     @no
00204Er 2  20 rr rr             jsr     ReadBuffer
002051r 2  C9 03                cmp     #$03
002053r 2  F0 08                beq     @break
002055r 2  C9 1B                cmp     #$1B
002057r 2  F0 04                beq     @break
002059r 2  8D 0E 03             sta     BAS_PENDKEY
00205Cr 2               @no:
00205Cr 2  60                   rts
00205Dr 2               @break:
00205Dr 2                       ; OLDLIN/OLDTEXT already track the executing line.  Make sure the
00205Dr 2                       ; saved values reflect the current line so CONT can resume.
00205Dr 2  AD 69 03             lda     BAS_CURLIN
002060r 2  8D 6B 03             sta     BAS_OLDLIN
002063r 2  AD 6A 03             lda     BAS_CURLIN+1
002066r 2  8D 6C 03             sta     BAS_OLDLIN+1
002069r 2  A2 FF                ldx     #$FF
00206Br 2  9A                   txs
00206Cr 2  20 rr rr             jsr     BasPrintCRLF
00206Fr 2  A9 rr                lda     #<MsgBreak
002071r 2  A0 rr                ldy     #>MsgBreak
002073r 2  20 rr rr             jsr     BasPrintStr
002076r 2  AD 6A 03             lda     BAS_CURLIN+1
002079r 2  C9 FF                cmp     #$FF
00207Br 2  F0 14                beq     @noLine
00207Dr 2  A9 rr                lda     #<MsgInWord
00207Fr 2  A0 rr                ldy     #>MsgInWord
002081r 2  20 rr rr             jsr     BasPrintStr
002084r 2  AD 69 03             lda     BAS_CURLIN
002087r 2  85 08                sta     BAS_LINNUM
002089r 2  AD 6A 03             lda     BAS_CURLIN+1
00208Cr 2  85 09                sta     BAS_LINNUM+1
00208Er 2  20 rr rr             jsr     BasPrintLineNum
002091r 2               @noLine:
002091r 2  A9 FF                lda     #$FF
002093r 2  8D 69 03             sta     BAS_CURLIN
002096r 2  8D 6A 03             sta     BAS_CURLIN+1
002099r 2  4C rr rr             jmp     BasReadyLoop
00209Cr 2               
00209Cr 2  42 52 45 41  MsgBreak: .byte "BREAK",0
0020A0r 2  4B 00        
0020A2r 2               
0020A2r 2               ; ---------------------------------------------------------------------------
0020A2r 2               ; LinGet -- parse decimal digits at TXTPTR into BAS_LINNUM (16-bit).
0020A2r 2               ; Caller has set carry conditions appropriate to ChrGet entry.  TXTPTR
0020A2r 2               ; ends pointing at the first non-digit.
0020A2r 2               ; ---------------------------------------------------------------------------
0020A2r 2               LinGet:
0020A2r 2  A2 00                ldx     #0
0020A4r 2  86 08                stx     BAS_LINNUM
0020A6r 2  86 09                stx     BAS_LINNUM+1
0020A8r 2               @loop:
0020A8r 2  B0 3A                bcs     @done
0020AAr 2  E9 2F                sbc     #$2F                    ; carry already set
0020ACr 2  85 44                sta     CHARAC
0020AEr 2                       ; LINNUM *= 10
0020AEr 2  A5 08                lda     BAS_LINNUM
0020B0r 2  85 3A                sta     BAS_TMP1
0020B2r 2  A5 09                lda     BAS_LINNUM+1
0020B4r 2  85 3B                sta     BAS_TMP1+1
0020B6r 2  C9 19                cmp     #$19
0020B8r 2  B0 2B                bcs     @ovf
0020BAr 2  06 08                asl     BAS_LINNUM
0020BCr 2  26 09                rol     BAS_LINNUM+1
0020BEr 2  06 08                asl     BAS_LINNUM
0020C0r 2  26 09                rol     BAS_LINNUM+1
0020C2r 2  18                   clc
0020C3r 2  A5 08                lda     BAS_LINNUM
0020C5r 2  65 3A                adc     BAS_TMP1
0020C7r 2  85 08                sta     BAS_LINNUM
0020C9r 2  A5 09                lda     BAS_LINNUM+1
0020CBr 2  65 3B                adc     BAS_TMP1+1
0020CDr 2  85 09                sta     BAS_LINNUM+1
0020CFr 2  06 08                asl     BAS_LINNUM
0020D1r 2  26 09                rol     BAS_LINNUM+1
0020D3r 2  18                   clc
0020D4r 2  A5 08                lda     BAS_LINNUM
0020D6r 2  65 44                adc     CHARAC
0020D8r 2  85 08                sta     BAS_LINNUM
0020DAr 2  90 02                bcc     @nextDigit
0020DCr 2  E6 09                inc     BAS_LINNUM+1
0020DEr 2               @nextDigit:
0020DEr 2  20 rr rr             jsr     ChrGet
0020E1r 2  4C rr rr             jmp     @loop
0020E4r 2               @done:
0020E4r 2  60                   rts
0020E5r 2               @ovf:
0020E5r 2  A2 00                ldx     #ERR_SYNTAX
0020E7r 2  4C rr rr             jmp     BasErrorVec
0020EAr 2               
0020EAr 2               ; ---------------------------------------------------------------------------
0020EAr 2               ; FndLin -- find program line whose number matches BAS_LINNUM.
0020EAr 2               ;   On success: carry SET, BAS_TMP1 (LOWTR alias) = address of line.
0020EAr 2               ;   On failure: carry CLEAR, BAS_TMP1 = address where line would belong.
0020EAr 2               ; ---------------------------------------------------------------------------
0020EAr 2               FndLin:
0020EAr 2  AD 5D 03             lda     BAS_TXTTAB
0020EDr 2  AE 5E 03             ldx     BAS_TXTTAB+1
0020F0r 2               @walk:
0020F0r 2  85 3A                sta     BAS_TMP1
0020F2r 2  86 3B                stx     BAS_TMP1+1
0020F4r 2  A0 01                ldy     #1
0020F6r 2  B1 3A                lda     (BAS_TMP1),y
0020F8r 2  F0 20                beq     @notFound               ; next-hi=0 -> end of program
0020FAr 2  A0 03                ldy     #3                      ; line-num-lo offset
0020FCr 2  A5 09                lda     BAS_LINNUM+1
0020FEr 2  D1 3A                cmp     (BAS_TMP1),y            ; compare hi byte at +3? need iny
002100r 2                       ; Actually format: +0 next-lo, +1 next-hi, +2 num-lo, +3 num-hi
002100r 2  90 18                bcc     @notFound               ; LINNUM-hi < line-hi -> miss
002102r 2  D0 09                bne     @advance                ; LINNUM-hi > line-hi -> next line
002104r 2  88                   dey                             ; y=2 = num-lo
002105r 2  A5 08                lda     BAS_LINNUM
002107r 2  D1 3A                cmp     (BAS_TMP1),y
002109r 2  90 0F                bcc     @notFound
00210Br 2  F0 0F                beq     @found
00210Dr 2               @advance:
00210Dr 2  A0 00                ldy     #0
00210Fr 2  B1 3A                lda     (BAS_TMP1),y
002111r 2  48                   pha
002112r 2  A0 01                ldy     #1
002114r 2  B1 3A                lda     (BAS_TMP1),y
002116r 2  AA                   tax
002117r 2  68                   pla
002118r 2  B0 D6                bcs     @walk                   ; carry=1 means continue (always)
00211Ar 2               @notFound:
00211Ar 2  18                   clc
00211Br 2  60                   rts
00211Cr 2               @found:
00211Cr 2  38                   sec
00211Dr 2  60                   rts
00211Er 2               
00211Er 2               ; ---------------------------------------------------------------------------
00211Er 2               ; BasCmdGoto -- TXTPTR points at line-number digits.
00211Er 2               ; ---------------------------------------------------------------------------
00211Er 2               BasCmdGoto:
00211Er 2  20 rr rr             jsr     LinGet
002121r 2  20 rr rr             jsr     BasRemn                 ; skip remainder of statement
002124r 2  20 rr rr             jsr     FndLin
002127r 2  90 0E                bcc     @undef
002129r 2                       ; LOWTR (BAS_TMP1) = target line addr.  TXTPTR = LOWTR - 1
002129r 2                       ; (so NEWSTT sees the previous line's $00 terminator at offset 0).
002129r 2  38                   sec
00212Ar 2  A5 3A                lda     BAS_TMP1
00212Cr 2  E9 01                sbc     #1
00212Er 2  85 04                sta     TXTPTR
002130r 2  A5 3B                lda     BAS_TMP1+1
002132r 2  E9 00                sbc     #0
002134r 2  85 05                sta     TXTPTR+1
002136r 2  60                   rts
002137r 2               @undef:
002137r 2  A2 03                ldx     #ERR_UNDEFSTMT
002139r 2  4C rr rr             jmp     BasErrorVec
00213Cr 2               
00213Cr 2               ; ---------------------------------------------------------------------------
00213Cr 2               ; BasCmdGosub -- push 5-byte frame on stack, then GOTO target.
00213Cr 2               ; Frame layout (top-down): [tag $8C][CURLIN-lo][CURLIN-hi][TXTPTR-lo][TXTPTR-hi]
00213Cr 2               ; ---------------------------------------------------------------------------
00213Cr 2               BasCmdGosub:
00213Cr 2  A5 05                lda     TXTPTR+1
00213Er 2  48                   pha
00213Fr 2  A5 04                lda     TXTPTR
002141r 2  48                   pha
002142r 2  AD 6A 03             lda     BAS_CURLIN+1
002145r 2  48                   pha
002146r 2  AD 69 03             lda     BAS_CURLIN
002149r 2  48                   pha
00214Ar 2  A9 8C                lda     #TOK_GOSUB
00214Cr 2  48                   pha
00214Dr 2  20 rr rr             jsr     ChrGot
002150r 2  20 rr rr             jsr     BasCmdGoto
002153r 2  4C rr rr             jmp     BasNewstt
002156r 2               
002156r 2               ; ---------------------------------------------------------------------------
002156r 2               ; BasCmdReturn -- locate GOSUB frame on stack and resume at saved TXTPTR.
002156r 2               ; Per msbasic: scan the CPU stack from SP+5 (skipping return-routine's caller
002156r 2               ; return + this scan's own JSR return).  RTS at end pops the leaked
002156r 2               ; EXEC-return that GOSUB left behind.
002156r 2               ; ---------------------------------------------------------------------------
002156r 2               BasCmdReturn:
002156r 2  20 rr rr             jsr     GtForPnt
002159r 2                       ; X now points to the slot just BELOW a frame tag (or end of stack).
002159r 2  9A                   txs
00215Ar 2  C9 8C                cmp     #TOK_GOSUB
00215Cr 2  F0 05                beq     @ok
00215Er 2  A2 0C                ldx     #ERR_RG
002160r 2  4C rr rr             jmp     BasErrorVec
002163r 2               @ok:
002163r 2  68                   pla                             ; tag (already in A, this discards)
002164r 2  68                   pla
002165r 2  8D 69 03             sta     BAS_CURLIN
002168r 2  68                   pla
002169r 2  8D 6A 03             sta     BAS_CURLIN+1
00216Cr 2  68                   pla
00216Dr 2  85 04                sta     TXTPTR
00216Fr 2  68                   pla
002170r 2  85 05                sta     TXTPTR+1
002172r 2                       ; Skip remainder of GOSUB-target statement (DATAN-style).
002172r 2  20 rr rr             jsr     BasDatan
002175r 2                       ; Advance TXTPTR by Y (number of bytes to terminator).
002175r 2  98                   tya
002176r 2  18                   clc
002177r 2  65 04                adc     TXTPTR
002179r 2  85 04                sta     TXTPTR
00217Br 2  90 02                bcc     @noinc
00217Dr 2  E6 05                inc     TXTPTR+1
00217Fr 2               @noinc:
00217Fr 2  60                   rts
002180r 2               
002180r 2               ; ---------------------------------------------------------------------------
002180r 2               ; GtForPnt -- scan CPU stack for FOR/GOSUB frames.
002180r 2               ;   On entry: BAS_FORPNT (FORPNT) = $FFxx for "match any tag".
002180r 2               ;   Returns: X = stack pointer where the matching frame's tag-1 lives,
002180r 2               ;            A = tag byte found (or 0 if end-of-stack).  Z=1 if found tag,
002180r 2               ;            Z=0 (A=0) if no frame found.
002180r 2               ; ---------------------------------------------------------------------------
002180r 2               GtForPnt:
002180r 2  BA                   tsx
002181r 2  E8                   inx
002182r 2  E8                   inx
002183r 2  E8                   inx
002184r 2  E8                   inx
002185r 2               @scan:
002185r 2  BD 01 01             lda     $0101,x                 ; tag candidate
002188r 2  C9 81                cmp     #TOK_FOR
00218Ar 2  D0 24                bne     @notFor
00218Cr 2                       ; Compare frame's variable address to FORPNT.
00218Cr 2  A5 47                lda     BAS_FORPNT+1
00218Er 2  D0 0A                bne     @skipVar                ; FORPNT+1 = $FF -> skip variable test
002190r 2  BD 02 01             lda     $0102,x
002193r 2  85 46                sta     BAS_FORPNT
002195r 2  BD 03 01             lda     $0103,x
002198r 2  85 47                sta     BAS_FORPNT+1
00219Ar 2               @skipVar:
00219Ar 2  DD 03 01             cmp     $0103,x
00219Dr 2  D0 07                bne     @advance
00219Fr 2  A5 46                lda     BAS_FORPNT
0021A1r 2  DD 02 01             cmp     $0102,x
0021A4r 2  F0 11                beq     @found
0021A6r 2               @advance:
0021A6r 2  8A                   txa
0021A7r 2  18                   clc
0021A8r 2  69 12                adc     #18                     ; BYTES_PER_FRAME (FOR)
0021AAr 2  AA                   tax
0021ABr 2  D0 D8                bne     @scan
0021ADr 2                       ; Walked off stack
0021ADr 2  A9 00                lda     #0
0021AFr 2  60                   rts
0021B0r 2               @notFor:
0021B0r 2  C9 8C                cmp     #TOK_GOSUB
0021B2r 2  F0 03                beq     @found
0021B4r 2  A9 00                lda     #0
0021B6r 2  60                   rts
0021B7r 2               @found:
0021B7r 2  60                   rts
0021B8r 2               
0021B8r 2               ; ---------------------------------------------------------------------------
0021B8r 2               ; BasRemn -- scan TXTPTR forward to next ':' or end-of-line.
0021B8r 2               ; Sets Y to byte offset of terminator from current TXTPTR.  Honours quotes.
0021B8r 2               ; ---------------------------------------------------------------------------
0021B8r 2               BasDatan:
0021B8r 2  A2 3A                ldx     #':'
0021BAr 2  2C                   .byte   $2C                     ; BIT abs absorbs next 2-byte LDX
0021BBr 2               BasRemn:
0021BBr 2  A2 00                ldx     #0
0021BDr 2  86 44                stx     CHARAC
0021BFr 2  A0 00                ldy     #0
0021C1r 2  84 6A                sty     ENDCHR
0021C3r 2               @swap:
0021C3r 2  A5 6A                lda     ENDCHR
0021C5r 2  A6 44                ldx     CHARAC
0021C7r 2  85 44                sta     CHARAC
0021C9r 2  86 6A                stx     ENDCHR
0021CBr 2               @scan:
0021CBr 2  B1 04                lda     (TXTPTR),y
0021CDr 2  F0 0B                beq     @done
0021CFr 2  C5 6A                cmp     ENDCHR
0021D1r 2  F0 07                beq     @done
0021D3r 2  C8                   iny
0021D4r 2  C9 22                cmp     #'"'
0021D6r 2  F0 EB                beq     @swap
0021D8r 2  D0 F1                bne     @scan
0021DAr 2               @done:
0021DAr 2  60                   rts
0021DBr 2               
0021DBr 2               ; ---------------------------------------------------------------------------
0021DBr 2               ; Statement: REM -- skip to end of line.
0021DBr 2               ; Statement: DATA -- treated like REM at execution time (just skip).
0021DBr 2               ; ---------------------------------------------------------------------------
0021DBr 2               BasCmdRem:
0021DBr 2  20 rr rr             jsr     BasRemn
0021DEr 2  80 03                bra     BasAddon
0021E0r 2               BasCmdData:
0021E0r 2  20 rr rr             jsr     BasDatan
0021E3r 2               BasAddon:
0021E3r 2  98                   tya
0021E4r 2  18                   clc
