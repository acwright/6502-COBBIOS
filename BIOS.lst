001765r 2               ; BasCmdClr -- implement CLR (clear vars/arrays/strings without erasing program).
001765r 2               ;   VARTAB := PRGEND (already correct in our model)
001765r 2               ;   ARYTAB := STREND := VARTAB
001765r 2               ;   FRETOP := MEMSIZ
001765r 2               ;   TEMPPT := TEMPST, DATAPTR := TXTTAB-1, stacks emptied
001765r 2               ; ---------------------------------------------------------------------------
001765r 2               BasCmdClr:
001765r 2                       ; ARYTAB = STREND = VARTAB
001765r 2  AD 5F 03             lda     VARTAB
