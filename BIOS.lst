001198r 2               ;   V A R I A B L E S ,   A R R A Y S ,   S T R I N G   H E A P
001198r 2               ;
001198r 2               ;   Inline-ported from msbasic-master/{var,array,string,memory}.s and
001198r 2               ;   misc2.s (GivAyf/SngFlt).  All MSBASIC externals are resolved here:
001198r 2               ;
001198r 2               ;     SynErr / MemErr / IqErr / Gme / SubErr        - error trampolines
001198r 2               ;     ChkCom / ChkCls / ChkNum / ChkStr             - parser predicates
001198r 2               ;     MakInt / FrmNum / FrmEvl                      - minimal stubs (only
001198r 2               ;                                                     handle literal unsigned
001198r 2               ;                                                     decimals via Fin; full
001198r 2               ;                                                     evaluator wired in a
001198r 2               ;                                                     later phase)
001198r 2               ;     IsLetC                                        - ASCII letter test
001198r 2               ;     PtrGet / Array / GetAry                       - variable lookup
001198r 2               ;     StrIni / StrSpa / GetSpa / PutNew / MovStr    - string allocation
001198r 2               ;     Garbag (and helpers)                          - string GC
001198r 2               ;     Bltu / Reason                                 - block-up-move helpers
001198r 2               ;     AyInt / GivAyf / SngFlt                       - FP <-> 16-bit int
001198r 2               ;     BasCmdClr                                     - implements CLR / NEW core
001198r 2               ; =============================================================================
001198r 2               
001198r 2               ; ---------------------------------------------------------------------------
001198r 2               ; SynErr / MemErr / IqErr / SubErr / Gme -- error trampolines.
001198r 2               ; The msbasic convention is "ldx #code; jmp ERROR".  Our BasError takes the
001198r 2               ; code in A, so translate; BasErrorVec (defined earlier) does that translation.
001198r 2               ; ---------------------------------------------------------------------------
001198r 2               SynErr:
001198r 2  A2 00                ldx     #ERR_SYNTAX
00119Ar 2  4C rr rr             jmp     BasErrorVec
00119Dr 2               
00119Dr 2               MemErr:
00119Dr 2  A2 02                ldx     #ERR_MEMFULL
00119Fr 2  4C rr rr             jmp     BasErrorVec
0011A2r 2               
0011A2r 2               SubErr:
0011A2r 2  A2 04                ldx     #ERR_BADSUBS
0011A4r 2  4C rr rr             jmp     BasErrorVec
0011A7r 2               
0011A7r 2               Gse:
0011A7r 2  4C rr rr             jmp     SubErr
0011AAr 2               
0011AAr 2               Gme:
0011AAr 2  4C rr rr             jmp     MemErr
0011ADr 2               
0011ADr 2               ; ---------------------------------------------------------------------------
0011ADr 2               ; Parser predicates (operate on byte at TXTPTR; advance via ChrGet).
0011ADr 2               ; ---------------------------------------------------------------------------
0011ADr 2               ChkCom:
0011ADr 2  A9 2C                lda     #','
0011AFr 2  2C                   .byte   $2C                     ; BIT abs -> skip next 2 bytes
0011B0r 2               SynChr:
0011B0r 2                       ; Used by code that wants a specific char.  A on entry = required char.
0011B0r 2  A0 00                ldy     #0
0011B2r 2  D2 04                cmp     (TXTPTR)
0011B4r 2  D0 E2                bne     SynErr
0011B6r 2  4C rr rr             jmp     ChrGet
0011B9r 2               
0011B9r 2               ChkCls:
0011B9r 2  A9 29                lda     #')'
0011BBr 2  80 F3                bra     SynChr
0011BDr 2               
0011BDr 2               ChkOpn:
0011BDr 2  A9 28                lda     #'('
0011BFr 2  80 EF                bra     SynChr
0011C1r 2               
0011C1r 2               ChkNum:
0011C1r 2  18                   clc
0011C2r 2  24                   .byte   $24                     ; BIT zp -> skip next byte
0011C3r 2               ChkStr:
0011C3r 2  38                   sec
0011C4r 2               ChkVal:
0011C4r 2  24 64                bit     VALTYP
