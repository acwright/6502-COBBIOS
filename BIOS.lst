000000r 1               
000000r 1               .segment "KERNAL"
000000r 1               .include "Kernal.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   KERNAL    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; === Kernal Jump Table ($A000-$A0FF) ===
000000r 2               ; 85 slots of 3-byte JMP instructions plus 1 padding byte
000000r 2               ; Provides stable entry points for external code and cartridges
000000r 2               
000000r 2               ; --- Character I/O ---
000000r 2  4C rr rr     Chrout:         jmp ChroutDispatch      ; $A000 - Output char (dispatched by IO_MODE)
000003r 2  4C rr rr     Chrin:          jmp ChrinImpl           ; $A003 - Input char from buffer
000006r 2  4C rr rr     WriteBuffer:    jmp WriteBufferImpl     ; $A006 - Write byte to input buffer
000009r 2  4C rr rr     ReadBuffer:     jmp ReadBufferImpl      ; $A009 - Read byte from input buffer
00000Cr 2  4C rr rr     BufferSize:     jmp BufferSizeImpl      ; $A00C - Get buffer count
00000Fr 2               ; --- IO Mode ---
00000Fr 2  4C rr rr     SetIOMode:      jmp SetIOModeImpl       ; $A00F - Set IO_MODE
000012r 2  4C rr rr     GetIOMode:      jmp GetIOModeImpl       ; $A012 - Get IO_MODE
000015r 2               ; --- Video (TMS9918) ---
000015r 2  4C rr rr     InitVideo:      jmp InitVideoImpl       ; $A015 - Initialize TMS9918
000018r 2  4C rr rr     VideoClear:     jmp VideoClearImpl      ; $A018 - Clear video screen
00001Br 2  4C rr rr     VideoPutChar:   jmp VideoPutCharImpl    ; $A01B - Write char at cursor
00001Er 2  4C rr rr     VideoSetCursor: jmp VideoSetCursorImpl  ; $A01E - Set cursor (X=col, Y=row)
000021r 2  4C rr rr     VideoGetCursor: jmp VideoGetCursorImpl  ; $A021 - Get cursor position
000024r 2  4C rr rr     VideoScroll:    jmp VideoScrollImpl     ; $A024 - Scroll screen up one line
000027r 2  4C rr rr     VideoSetColor:  jmp VideoSetColorImpl   ; $A027 - Set TMS9918 text color (A=reg7 byte: hi=fg, lo=bg)
00002Ar 2  4C rr rr     VideoChroutRaw: jmp VideoChroutRawImpl  ; $A02A - Output char to video (raw, no control-code handling)
00002Dr 2               ; --- Sound (SID) ---
00002Dr 2  4C rr rr     InitSID:        jmp InitSIDImpl         ; $A02D - Initialize SID
000030r 2  4C rr rr     Beep:           jmp BeepImpl            ; $A030 - Play beep tone
000033r 2  4C rr rr     SidPlayNote:    jmp SidPlayNoteImpl     ; $A033 - Play note (A=voice, X=freqLo, Y=freqHi)
000036r 2  4C rr rr     SidSilence:     jmp SidSilenceImpl      ; $A036 - Silence all voices
000039r 2  4C rr rr     SidSetVolume:   jmp SidSetVolumeImpl    ; $A039 - Set SID master volume (A=0-15)
00003Cr 2               ; --- Filesystem ---
00003Cr 2  4C rr rr     FsLoadFile:     jmp FsLoadFileImpl      ; $A03C - Load file from CF
00003Fr 2  4C rr rr     FsSaveFile:     jmp FsSaveFileImpl      ; $A03F - Save file to CF
000042r 2  4C rr rr     FsDeleteFile:   jmp FsDeleteFileImpl    ; $A042 - Delete file from CF
000045r 2               ; --- Keyboard / GPIO ---
000045r 2  4C rr rr     InitKB:         jmp InitKBImpl          ; $A045 - Initialize GPIO/VIA keyboard
000048r 2  4C rr rr     ReadJoystick1:  jmp ReadJoystick1Impl   ; $A048 - Read joystick 1
00004Br 2  4C rr rr     ReadJoystick2:  jmp ReadJoystick2Impl   ; $A04B - Read joystick 2
00004Er 2               ; --- Serial (6551) ---
00004Er 2  4C rr rr     InitSC:         jmp InitSCImpl          ; $A04E - Initialize serial 6551
000051r 2  4C rr rr     SerialChrout:   jmp SerialChroutImpl    ; $A051 - Direct serial output (bypass IO_MODE)
000054r 2  4C rr rr     XModemLoad:     jmp XModemLoadImpl      ; $A054 - Receive binary via XModem
000057r 2  4C rr rr     XModemSave:     jmp XModemSaveImpl      ; $A057 - Send binary via XModem
00005Ar 2               ; --- RTC (DS1511Y) ---
00005Ar 2  4C rr rr     RtcReadTime:    jmp RtcReadTimeImpl     ; $A05A - Read RTC time
00005Dr 2  4C rr rr     RtcReadDate:    jmp RtcReadDateImpl     ; $A05D - Read RTC date
000060r 2  4C rr rr     RtcWriteTime:   jmp RtcWriteTimeImpl    ; $A060 - Set RTC time
000063r 2  4C rr rr     RtcWriteDate:   jmp RtcWriteDateImpl    ; $A063 - Set RTC date
000066r 2  4C rr rr     RtcReadNVRAM:   jmp RtcReadNVRAMImpl    ; $A066 - Read NVRAM byte
000069r 2  4C rr rr     RtcWriteNVRAM:  jmp RtcWriteNVRAMImpl   ; $A069 - Write NVRAM byte
00006Cr 2               ; --- CompactFlash Storage ---
00006Cr 2  4C rr rr     StReadSector:   jmp StReadSectorImpl    ; $A06C - Read CF sector
00006Fr 2  4C rr rr     StWriteSector:  jmp StWriteSectorImpl   ; $A06F - Write CF sector
000072r 2  4C rr rr     StWaitReady:    jmp StWaitReadyImpl     ; $A072 - Wait CF ready
000075r 2               ; --- System ---
000075r 2  4C rr rr     SysDelay:       jmp SysDelayImpl        ; $A075 - Delay A=cnt_lo, X=cnt_hi centiseconds
000078r 2  4C rr rr     KernalInit:     jmp KernalInitImpl      ; $A078 - Initialize all hardware (caller must reset SP; no cli, no splash); rts when done
00007Br 2  4C rr rr     KernalVersion:  jmp KernalVersionImpl   ; $A07B - Get BIOS version (A=major, X=minor)
00007Er 2               
00007Er 2               ; Reserved entries ($A07E-$A0FE)
00007Er 2  4C rr rr 4C  .repeat 43
000082r 2  rr rr 4C rr  
000086r 2  rr 4C rr rr  
0000FFr 2                               jmp UnimplementedStub
0000FFr 2               .endrepeat
0000FFr 2  00           .byte $00                             ; Pad to 256 bytes ($A0FF)
000100r 2               
000100r 2               ; === Kernal Implementation ===
000100r 2               
000100r 2               ; Stub for unimplemented jump table entries
000100r 2               UnimplementedStub:
000100r 2  60             rts
000101r 2               
000101r 2               ; Chrout dispatcher — routes output based on IO_MODE
000101r 2               ; Input: A = character to output
000101r 2               ; Modifies: Flags
000101r 2               ChroutDispatch:
000101r 2  48             pha
000102r 2  AD 06 03       lda IO_MODE
000105r 2  29 01          and #$01                      ; Bit 0: 0=video, 1=serial
000107r 2  D0 04          bne @Serial
000109r 2  68             pla
00010Ar 2  4C rr rr       jmp VideoChroutImpl
00010Dr 2               @Serial:
00010Dr 2  68             pla
00010Er 2  4C rr rr       jmp SerialChroutImpl
000111r 2               
000111r 2               ; Set IO_MODE
000111r 2               ; Input: A = mode (bit 0: 0=video, 1=serial)
000111r 2               SetIOModeImpl:
000111r 2  8D 06 03       sta IO_MODE
000114r 2  60             rts
000115r 2               
000115r 2               ; Get IO_MODE
000115r 2               ; Output: A = current IO_MODE
000115r 2               GetIOModeImpl:
000115r 2  AD 06 03       lda IO_MODE
000118r 2  60             rts
000119r 2               
000119r 2               ; === TMS9918 Video Driver ===
000119r 2               
000119r 2               ; VideoClear — Fill name table (960 bytes at VRAM $0000) with spaces, reset cursor to (0,0)
000119r 2               ; Modifies: Flags, A, X, Y
000119r 2               VideoClearImpl:
000119r 2                 ; Set VRAM write address to $0000 (name table base)
000119r 2  A9 00          lda #$00
00011Br 2  8D 01 9C       sta VC_REG
00011Er 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
000120r 2  8D 01 9C       sta VC_REG
000123r 2                 ; Fill 960 bytes with space ($20) — 3 full pages + 192 bytes
000123r 2  A9 20          lda #$20
000125r 2  A0 00          ldy #$00
000127r 2  A2 03          ldx #$03                      ; 3 full pages (768 bytes)
000129r 2               @VideoClearPage:
000129r 2  8D 00 9C       sta VC_DATA
00012Cr 2  C8             iny
00012Dr 2  D0 FA          bne @VideoClearPage
00012Fr 2  CA             dex
000130r 2  D0 F7          bne @VideoClearPage
000132r 2                 ; Remaining 192 bytes (960 - 768)
000132r 2  A0 C0          ldy #192
000134r 2               @VideoClearRem:
000134r 2  8D 00 9C       sta VC_DATA
000137r 2  88             dey
000138r 2  D0 FA          bne @VideoClearRem
00013Ar 2                 ; Reset cursor to (0,0)
00013Ar 2  9C 07 03       stz VID_CURSOR_X
00013Dr 2  9C 08 03       stz VID_CURSOR_Y
000140r 2  9C 09 03       stz VID_CURSOR_ADDR
000143r 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
000146r 2  60             rts
000147r 2               
000147r 2               ; VideoSetCursor — Set cursor position
000147r 2               ; Input: X = column (0-39), Y = row (0-23)
000147r 2               ; Calculates VRAM address = Y * 40 + X and stores in VID_CURSOR_ADDR
000147r 2               ; Modifies: Flags, A
000147r 2               VideoSetCursorImpl:
000147r 2  8E 07 03       stx VID_CURSOR_X
00014Ar 2  8C 08 03       sty VID_CURSOR_Y
00014Dr 2                 ; Calculate VRAM address = Y * 40 + X
00014Dr 2                 ; Y * 40 = Y * 32 + Y * 8
00014Dr 2  A9 00          lda #$00
00014Fr 2  8D 0A 03       sta VID_CURSOR_ADDR + 1       ; Clear high byte
000152r 2  98             tya                           ; A = row
000153r 2                 ; Multiply by 8: shift left 3
000153r 2  0A             asl a
000154r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000157r 2  0A             asl a
000158r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Br 2  0A             asl a
00015Cr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Fr 2  8D 09 03       sta VID_CURSOR_ADDR           ; Store Y*8 low byte
000162r 2                 ; Save Y*8 for later addition
000162r 2  48             pha
000163r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
000166r 2  48             pha
000167r 2                 ; Multiply original row by 32: shift left 5 total (Y*8 << 2)
000167r 2  AD 09 03       lda VID_CURSOR_ADDR
00016Ar 2  0A             asl a
00016Br 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00016Er 2  0A             asl a
00016Fr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000172r 2  8D 09 03       sta VID_CURSOR_ADDR           ; Now holds Y*32 low byte
000175r 2                 ; Add Y*8 + Y*32
000175r 2  68             pla                           ; Restore Y*8 high byte
000176r 2  6D 0A 03       adc VID_CURSOR_ADDR + 1       ; Carry still valid from last rol
000179r 2  8D 0A 03       sta VID_CURSOR_ADDR + 1
00017Cr 2  68             pla                           ; Restore Y*8 low byte
00017Dr 2  18             clc
00017Er 2  6D 09 03       adc VID_CURSOR_ADDR
000181r 2  8D 09 03       sta VID_CURSOR_ADDR
000184r 2  90 03          bcc @NoCarry
000186r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000189r 2               @NoCarry:
000189r 2                 ; Add X (column)
000189r 2  8A             txa
00018Ar 2  18             clc
00018Br 2  6D 09 03       adc VID_CURSOR_ADDR
00018Er 2  8D 09 03       sta VID_CURSOR_ADDR
000191r 2  90 03          bcc @SetCursorDone
000193r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000196r 2               @SetCursorDone:
000196r 2  60             rts
000197r 2               
000197r 2               ; VideoGetCursor — Get cursor position
000197r 2               ; Output: X = column (0-39), Y = row (0-23)
000197r 2               ; Modifies: Flags
000197r 2               VideoGetCursorImpl:
000197r 2  AE 07 03       ldx VID_CURSOR_X
00019Ar 2  AC 08 03       ldy VID_CURSOR_Y
00019Dr 2  60             rts
00019Er 2               
00019Er 2               ; VideoPutChar — Write a single character to VRAM at VID_CURSOR_ADDR
00019Er 2               ; Input: A = character to write
00019Er 2               ; Modifies: Flags
00019Er 2               VideoPutCharImpl:
00019Er 2  48             pha
00019Fr 2                 ; Set VRAM write address from VID_CURSOR_ADDR
00019Fr 2  AD 09 03       lda VID_CURSOR_ADDR
0001A2r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
0001A5r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
0001A8r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001AAr 2  8D 01 9C       sta VC_REG                    ; High byte with write flag
0001ADr 2  68             pla
0001AEr 2  8D 00 9C       sta VC_DATA                   ; Write character to VRAM
0001B1r 2  60             rts
0001B2r 2               
0001B2r 2               ; VideoScroll — Scroll screen up one line
0001B2r 2               ; Copies VRAM rows 1-23 to rows 0-22 (920 bytes), clears row 23 with spaces
0001B2r 2               ; Uses SCROLL_BUF ($0320, 40 bytes) as temporary storage
0001B2r 2               ; Modifies: Flags, A, X, Y
0001B2r 2               VideoScrollImpl:
0001B2r 2                 ; Save STR_PTR (may be in use by caller, e.g. VideoPrintStr)
0001B2r 2  A5 02          lda STR_PTR
0001B4r 2  48             pha
0001B5r 2  A5 03          lda STR_PTR + 1
0001B7r 2  48             pha
0001B8r 2                 ; Source starts at row 1 (VRAM offset 40=$28), dest at row 0 (offset 0)
0001B8r 2                 ; We process 23 rows, copying each row up by one
0001B8r 2  A9 28          lda #<40                      ; Source address low = 40 (row 1)
0001BAr 2  85 02          sta STR_PTR
0001BCr 2  A9 00          lda #>40
0001BEr 2  85 03          sta STR_PTR + 1
0001C0r 2               
0001C0r 2  A2 17          ldx #23                       ; 23 rows to copy
0001C2r 2               @ScrollRowLoop:
0001C2r 2  DA             phx                           ; Save row counter
0001C3r 2               
0001C3r 2                 ; Set VRAM read address (source row)
0001C3r 2  A5 02          lda STR_PTR
0001C5r 2  8D 01 9C       sta VC_REG
0001C8r 2  A5 03          lda STR_PTR + 1
0001CAr 2  8D 01 9C       sta VC_REG                    ; Bit 6 clear = read mode
0001CDr 2                 ; Read 40 bytes into SCROLL_BUF
0001CDr 2  A0 00          ldy #$00
0001CFr 2               @ScrollRead:
0001CFr 2  AD 00 9C       lda VC_DATA
0001D2r 2  99 20 03       sta SCROLL_BUF,y
0001D5r 2  C8             iny
0001D6r 2  C0 28          cpy #40
0001D8r 2  D0 F5          bne @ScrollRead
0001DAr 2               
0001DAr 2                 ; Set VRAM write address (dest = source - 40)
0001DAr 2  A5 02          lda STR_PTR
0001DCr 2  38             sec
0001DDr 2  E9 28          sbc #40
0001DFr 2  8D 01 9C       sta VC_REG                    ; Dest address low
0001E2r 2  A5 03          lda STR_PTR + 1
0001E4r 2  E9 00          sbc #$00
0001E6r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001E8r 2  8D 01 9C       sta VC_REG                    ; Dest address high
0001EBr 2               
0001EBr 2                 ; Write 40 bytes from SCROLL_BUF
0001EBr 2  A0 00          ldy #$00
0001EDr 2               @ScrollWrite:
0001EDr 2  B9 20 03       lda SCROLL_BUF,y
0001F0r 2  8D 00 9C       sta VC_DATA
0001F3r 2  C8             iny
0001F4r 2  C0 28          cpy #40
0001F6r 2  D0 F5          bne @ScrollWrite
0001F8r 2               
0001F8r 2                 ; Advance source pointer by 40 for next row
0001F8r 2  A5 02          lda STR_PTR
0001FAr 2  18             clc
0001FBr 2  69 28          adc #40
0001FDr 2  85 02          sta STR_PTR
0001FFr 2  90 02          bcc @ScrollNoCarry
000201r 2  E6 03          inc STR_PTR + 1
000203r 2               @ScrollNoCarry:
000203r 2  FA             plx                           ; Restore row counter
000204r 2  CA             dex
000205r 2  D0 BB          bne @ScrollRowLoop
000207r 2               
000207r 2                 ; Clear bottom row (row 23) with spaces
000207r 2                 ; Row 23 address = 23 * 40 = 920 = $0398
000207r 2  A9 98          lda #$98                      ; Low byte of $0398
000209r 2  8D 01 9C       sta VC_REG
00020Cr 2  A9 03          lda #$03
00020Er 2  09 40          ora #$40                      ; Write mode
000210r 2  8D 01 9C       sta VC_REG
000213r 2  A9 20          lda #$20                      ; Space character
000215r 2  A0 28          ldy #40
000217r 2               @ScrollClearBottom:
000217r 2  8D 00 9C       sta VC_DATA
00021Ar 2  88             dey
00021Br 2  D0 FA          bne @ScrollClearBottom
00021Dr 2                 ; Restore STR_PTR
00021Dr 2  68             pla
00021Er 2  85 03          sta STR_PTR + 1
000220r 2  68             pla
000221r 2  85 02          sta STR_PTR
000223r 2  60             rts
000224r 2               
000224r 2               ; VideoChrout — Output character to video display
000224r 2               ; Handles control characters: CR ($0D), LF ($0A), BS ($08), BEL ($07)
000224r 2               ; Printable ASCII ($20-$7E) written to VRAM; all other codes silently discarded
000224r 2               ; Auto-wraps at column 40, auto-scrolls at row 24
000224r 2               ; Input: A = character to output
000224r 2               ; Preserves: A, X, Y (callers like ChrinImpl, BasPrintStr and Wozmon depend on this)
000224r 2               ; Modifies: Flags
000224r 2               VideoChroutImpl:
000224r 2  48             pha
000225r 2  DA             phx
000226r 2  5A             phy
000227r 2                 ; Fast path: printable ASCII ($20-$7E) — most common case
000227r 2  C9 20          cmp #$20
000229r 2  90 06          bcc @Control                  ; < $20 → check control codes
00022Br 2  C9 7F          cmp #$7F
00022Dr 2  90 14          bcc @PrintChar                ; $20-$7E → printable character
00022Fr 2                 ; >= $7F (DEL and above) — discard
00022Fr 2                 ; User programs wanting raw glyph output should use VideoChroutRaw.
00022Fr 2  80 45          bra @VideoChroutDone
000231r 2               @Control:
000231r 2  C9 0D          cmp #$0D                      ; Carriage Return?
000233r 2  F0 45          beq @VideoCR
000235r 2  C9 0A          cmp #$0A                      ; Line Feed?
000237r 2  F0 4E          beq @VideoLF
000239r 2  C9 08          cmp #$08                      ; Backspace?
00023Br 2  F0 67          beq @VideoBS
00023Dr 2  C9 07          cmp #$07                      ; Bell?
00023Fr 2  F0 7B          beq @VideoBEL
000241r 2                 ; Unrecognized control code — discard
000241r 2  80 33          bra @VideoChroutDone
000243r 2               @PrintChar:
000243r 2                 ; Regular printable character — write at cursor and advance
000243r 2  20 rr rr       jsr VideoPutChar              ; Write char to VRAM at cursor
000246r 2                 ; Advance cursor
000246r 2  EE 07 03       inc VID_CURSOR_X
000249r 2                 ; Increment VRAM address
000249r 2  EE 09 03       inc VID_CURSOR_ADDR
00024Cr 2  D0 03          bne @CheckWrap
00024Er 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000251r 2               @CheckWrap:
000251r 2  AD 07 03       lda VID_CURSOR_X
000254r 2  C9 28          cmp #40                       ; Past last column?
000256r 2  90 1E          bcc @VideoChroutDone          ; No, done
000258r 2                 ; Auto-wrap: CR + LF
000258r 2  9C 07 03       stz VID_CURSOR_X
00025Br 2  EE 08 03       inc VID_CURSOR_Y
00025Er 2  AD 08 03       lda VID_CURSOR_Y
000261r 2  C9 18          cmp #24                       ; Past last row?
000263r 2  90 08          bcc @WrapRecalc
000265r 2                 ; Need to scroll
000265r 2  20 rr rr       jsr VideoScroll
000268r 2  A9 17          lda #23
00026Ar 2  8D 08 03       sta VID_CURSOR_Y
00026Dr 2               @WrapRecalc:
00026Dr 2  AE 07 03       ldx VID_CURSOR_X
000270r 2  AC 08 03       ldy VID_CURSOR_Y
000273r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
000276r 2               @VideoChroutDone:
000276r 2  7A             ply
000277r 2  FA             plx
000278r 2  68             pla
000279r 2  60             rts
00027Ar 2               
00027Ar 2               @VideoCR:
00027Ar 2  9C 07 03       stz VID_CURSOR_X              ; Column = 0
00027Dr 2  A2 00          ldx #$00
00027Fr 2  AC 08 03       ldy VID_CURSOR_Y
000282r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
000285r 2  80 EF          bra @VideoChroutDone
000287r 2               
000287r 2               @VideoLF:
000287r 2  EE 08 03       inc VID_CURSOR_Y
00028Ar 2  AD 08 03       lda VID_CURSOR_Y
00028Dr 2  C9 18          cmp #24                       ; Past last row?
00028Fr 2  90 08          bcc @LFRecalc
000291r 2  20 rr rr       jsr VideoScroll
000294r 2  A9 17          lda #23
000296r 2  8D 08 03       sta VID_CURSOR_Y
000299r 2               @LFRecalc:
000299r 2  AE 07 03       ldx VID_CURSOR_X
00029Cr 2  AC 08 03       ldy VID_CURSOR_Y
00029Fr 2  20 rr rr       jsr VideoSetCursor
0002A2r 2  80 D2          bra @VideoChroutDone
0002A4r 2               
0002A4r 2               @VideoBS:
0002A4r 2  AD 07 03       lda VID_CURSOR_X
0002A7r 2  F0 CD          beq @VideoChroutDone          ; Already at column 0, ignore
0002A9r 2  CE 07 03       dec VID_CURSOR_X
0002ACr 2  AE 07 03       ldx VID_CURSOR_X
0002AFr 2  AC 08 03       ldy VID_CURSOR_Y
0002B2r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
0002B5r 2  A9 20          lda #$20                      ; Write space to erase character
0002B7r 2  20 rr rr       jsr VideoPutChar
0002BAr 2  80 BA          bra @VideoChroutDone
0002BCr 2               
0002BCr 2               @VideoBEL:
0002BCr 2  20 rr rr       jsr Beep
0002BFr 2  80 B5          bra @VideoChroutDone
0002C1r 2               
0002C1r 2               ; VideoChroutRaw — Output character to video (raw, no control-code handling)
0002C1r 2               ; Always writes the character glyph at the cursor position and advances.
0002C1r 2               ; Input: A = character code (0-255)
0002C1r 2               ; Preserves: A, X, Y
0002C1r 2               ; Modifies: Flags
0002C1r 2               VideoChroutRawImpl:
0002C1r 2  48             pha
0002C2r 2  DA             phx
0002C3r 2  5A             phy
0002C4r 2  20 rr rr       jsr VideoPutChar              ; Write char to VRAM at cursor
0002C7r 2  EE 07 03       inc VID_CURSOR_X
0002CAr 2  EE 09 03       inc VID_CURSOR_ADDR
0002CDr 2  D0 03          bne @RawCheckWrap
0002CFr 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
0002D2r 2               @RawCheckWrap:
0002D2r 2  AD 07 03       lda VID_CURSOR_X
0002D5r 2  C9 28          cmp #40                       ; Past last column?
0002D7r 2  90 1E          bcc @RawDone
0002D9r 2  9C 07 03       stz VID_CURSOR_X
0002DCr 2  EE 08 03       inc VID_CURSOR_Y
0002DFr 2  AD 08 03       lda VID_CURSOR_Y
0002E2r 2  C9 18          cmp #24                       ; Past last row?
0002E4r 2  90 08          bcc @RawRecalc
0002E6r 2  20 rr rr       jsr VideoScroll
0002E9r 2  A9 17          lda #23
0002EBr 2  8D 08 03       sta VID_CURSOR_Y
0002EEr 2               @RawRecalc:
0002EEr 2  AE 07 03       ldx VID_CURSOR_X
0002F1r 2  AC 08 03       ldy VID_CURSOR_Y
0002F4r 2  20 rr rr       jsr VideoSetCursor
0002F7r 2               @RawDone:
0002F7r 2  7A             ply
0002F8r 2  FA             plx
0002F9r 2  68             pla
0002FAr 2  60             rts
0002FBr 2               
0002FBr 2               ; VideoPrintStr — Print null-terminated string to video
0002FBr 2               ; Input: STR_PTR ($02-$03) points to string
0002FBr 2               ; Modifies: Flags, A, X, Y
0002FBr 2               VideoPrintStrImpl:
0002FBr 2  A0 00          ldy #$00
0002FDr 2               @VideoPrintStrLoop:
0002FDr 2  B1 02          lda (STR_PTR),y
0002FFr 2  F0 08          beq @VideoPrintStrDone        ; Exit on null terminator
000301r 2  5A             phy
000302r 2  20 rr rr       jsr VideoChroutImpl           ; Output character via video
000305r 2  7A             ply
000306r 2  C8             iny
000307r 2  D0 F4          bne @VideoPrintStrLoop        ; Max 256 chars per string
000309r 2               @VideoPrintStrDone:
000309r 2  60             rts
00030Ar 2               
00030Ar 2               ; KernalInit — Initialize RAM variables, probe & init all hardware
00030Ar 2               ; Sets HW_PRESENT, IO_MODE, IRQ/BRK/NMI pointers, BOOT_VECTOR=0
00030Ar 2               ; Does NOT enable interrupts (caller must cli)
00030Ar 2               ; Does NOT reset the stack pointer (caller should do this before JSR)
00030Ar 2               ; Does NOT display splash or enter boot menu
00030Ar 2               ; Modifies: All registers, flags
00030Ar 2               KernalInitImpl:
00030Ar 2  D8             cld                           ; Clear decimal mode
00030Br 2  78             sei                           ; Disable interrupts
00030Cr 2               
00030Cr 2  A9 rr          lda #<Irq                     ; Initialize the IRQ pointer
00030Er 2  8D 00 03       sta IRQ_PTR
000311r 2  A9 rr          lda #>Irq
000313r 2  8D 01 03       sta IRQ_PTR + 1
000316r 2               
000316r 2  A9 rr          lda #<Break                   ; Initialize the BRK pointer
000318r 2  8D 02 03       sta BRK_PTR
00031Br 2  A9 rr          lda #>Break
00031Dr 2  8D 03 03       sta BRK_PTR + 1
000320r 2               
000320r 2  A9 rr          lda #<Nmi                     ; Initialize the NMI pointer
000322r 2  8D 04 03       sta NMI_PTR
000325r 2  A9 rr          lda #>Nmi
000327r 2  8D 05 03       sta NMI_PTR + 1
00032Ar 2               
00032Ar 2  9C 0D 03       stz HW_PRESENT                ; Clear all hardware flags
00032Dr 2  9C 5B 03       stz BOOT_VECTOR               ; Clear boot redirect vector
000330r 2  9C 5C 03       stz BOOT_VECTOR + 1
000333r 2               
000333r 2  20 rr rr       jsr InitBuffer                ; Initialize the input buffer (RAM-only, no hardware)
000336r 2               
000336r 2  20 rr rr       jsr ProbeRAM                  ; Sets HW_RAM_L / HW_RAM_H if present (no init needed)
000339r 2               
000339r 2  20 rr rr       jsr ProbeRTC                  ; Sets HW_RTC if present (no init needed)
00033Cr 2               
00033Cr 2  20 rr rr       jsr StInit                    ; CF: timeout will handle absent card in Phase 3, sets HW_CF on success
00033Fr 2               
00033Fr 2  20 rr rr       jsr ProbeSerial               ; Sets HW_SC if present
000342r 2  AD 0D 03       lda HW_PRESENT
000345r 2  29 10          and #HW_SC
000347r 2  F0 03          beq @SkipSerial
000349r 2  20 rr rr       jsr InitSCImpl
00034Cr 2               @SkipSerial:
00034Cr 2               
00034Cr 2  20 rr rr       jsr ProbeGPIO                 ; Sets HW_GPIO if present
00034Fr 2  AD 0D 03       lda HW_PRESENT
000352r 2  29 20          and #HW_GPIO
000354r 2  F0 03          beq @SkipGPIO
000356r 2  20 rr rr       jsr InitKBImpl
000359r 2               @SkipGPIO:
000359r 2               
000359r 2  20 rr rr       jsr ProbeSID                  ; Sets HW_SID if present
00035Cr 2  AD 0D 03       lda HW_PRESENT
00035Fr 2  29 40          and #HW_SID
000361r 2  F0 03          beq @SkipSID
000363r 2  20 rr rr       jsr InitSIDImpl
000366r 2               @SkipSID:
000366r 2               
000366r 2  20 rr rr       jsr ProbeVideo                ; Sets HW_VID if present
000369r 2  AD 0D 03       lda HW_PRESENT
00036Cr 2  29 80          and #HW_VID
00036Er 2  F0 06          beq @SkipVideo
000370r 2  20 rr rr       jsr InitVideoImpl
000373r 2  20 rr rr       jsr InitCharacters
000376r 2               @SkipVideo:
000376r 2               
000376r 2                 ; Console auto-detection — determine IO_MODE from available hardware
000376r 2  AD 0D 03       lda HW_PRESENT
000379r 2  29 80          and #HW_VID
00037Br 2  D0 09          bne @ConsoleVideo             ; Video present — use it
00037Dr 2  AD 0D 03       lda HW_PRESENT
000380r 2  29 10          and #HW_SC
000382r 2  D0 15          bne @ConsoleSerial            ; Serial present — use it
000384r 2                 ; Neither video nor serial — IO_MODE left as-is (no console)
000384r 2  80 18          bra @ConsoleDone
000386r 2               
000386r 2               @ConsoleVideo:
000386r 2  A9 00          lda #$00                      ; IO_MODE = video
000388r 2  8D 06 03       sta IO_MODE
00038Br 2  9C 07 03       stz VID_CURSOR_X
00038Er 2  9C 08 03       stz VID_CURSOR_Y
000391r 2  9C 09 03       stz VID_CURSOR_ADDR
000394r 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
000397r 2  80 05          bra @ConsoleDone
000399r 2               
000399r 2               @ConsoleSerial:
000399r 2  A9 01          lda #$01                      ; IO_MODE = serial
00039Br 2  8D 06 03       sta IO_MODE
00039Er 2               
00039Er 2               @ConsoleDone:
00039Er 2  60             rts
00039Fr 2               
00039Fr 2               ; KernalVersion — Return BIOS version in registers
00039Fr 2               ; Output: A = major version, X = minor version
00039Fr 2               ; Modifies: A, X
00039Fr 2               KernalVersionImpl:
00039Fr 2  A9 01          lda #BIOS_VERSION_MAJOR
0003A1r 2  A2 00          ldx #BIOS_VERSION_MINOR
0003A3r 2  60             rts
0003A4r 2               
0003A4r 2               ; Reset — Full system startup: init hardware, beep, check boot vector, splash, boot menu
0003A4r 2               Reset:
0003A4r 2  A2 FF          ldx #$ff
0003A6r 2  9A             txs                           ; Reset the stack pointer
0003A7r 2  20 rr rr       jsr KernalInitImpl            ; Initialize all hardware (leaves interrupts disabled)
0003AAr 2               
0003AAr 2  20 rr rr       jsr Beep                      ; Play the startup beep (guarded — skips if no SID)
0003ADr 2               
0003ADr 2                 ; Check boot redirect vector — cartridges set this before jumping to Reset
0003ADr 2  AD 5B 03       lda BOOT_VECTOR
0003B0r 2  0D 5C 03       ora BOOT_VECTOR + 1
0003B3r 2  F0 03          beq @NormalBoot               ; Zero — continue normal boot
0003B5r 2  6C 5B 03       jmp (BOOT_VECTOR)             ; Non-zero — jump to cartridge/external program
0003B8r 2               
0003B8r 2               @NormalBoot:
0003B8r 2                 ; Verify console is available for interactive boot
0003B8r 2  AD 0D 03       lda HW_PRESENT
0003BBr 2  29 90          and #(HW_VID | HW_SC)
0003BDr 2  D0 02          bne @HasConsole
0003BFr 2                 ; Neither video nor serial — halt (no console for interactive boot)
0003BFr 2               @Halt:
0003BFr 2  80 FE          bra @Halt
0003C1r 2               
0003C1r 2               @HasConsole:
0003C1r 2  20 rr rr       jsr Splash                    ; Draw the splash screen (guarded — skips if no video)
0003C4r 2               
0003C4r 2  58             cli                           ; Enable interrupts
0003C5r 2               
0003C5r 2                 ; Boot menu — wait for keypress with ~5-second timeout
0003C5r 2                 ; Each iteration delays 100ms then checks for a key. 50 iterations = 5 seconds.
0003C5r 2  A2 32          ldx #50                       ; Timeout counter: 50 × 100ms = 5 seconds
0003C7r 2               @BootWait:
0003C7r 2  DA             phx                           ; Save timeout counter
0003C8r 2  A9 0A          lda #10                       ; 10 centiseconds (100ms)
0003CAr 2  A2 00          ldx #$00                      ; High byte = 0
0003CCr 2  20 rr rr       jsr SysDelay
0003CFr 2  20 rr rr       jsr BufferSize                ; A = bytes in buffer
0003D2r 2  FA             plx                           ; Restore timeout counter (clobbers Z flag)
0003D3r 2  C9 00          cmp #$00                      ; Re-test buffer size — plx overwrote Z
0003D5r 2  D0 05          bne @BootGotKey               ; Key available — process it
0003D7r 2  CA             dex
0003D8r 2  D0 ED          bne @BootWait                 ; No key yet — keep waiting
0003DAr 2  80 10          bra @BootBASIC                ; Timeout — auto-boot BASIC
0003DCr 2               
0003DCr 2               @BootGotKey:
0003DCr 2  20 rr rr       jsr ReadBuffer                ; Read the keypress
0003DFr 2  C9 0D          cmp #$0D                      ; ENTER?
0003E1r 2  F0 09          beq @BootBASIC
0003E3r 2  C9 1B          cmp #$1B                      ; ESC?
0003E5r 2  F0 0B          beq @BootMonitor
0003E7r 2  CA             dex                           ; Consumed a non-menu key — decrement counter
0003E8r 2  D0 DD          bne @BootWait                 ; Keep waiting if time remains
0003EAr 2  80 00          bra @BootBASIC                ; Timeout — auto-boot BASIC
0003ECr 2               
0003ECr 2               @BootBASIC:
0003ECr 2  20 rr rr       jsr VideoClear                ; Clear screen (harmless if no video)
0003EFr 2  4C rr rr       jmp BasEntry
0003F2r 2               @BootMonitor:
0003F2r 2  00             brk                           ; Enter monitor through BRK vector (saves/displays registers)
0003F3r 2               
0003F3r 2               ; Initialize the Keyboard via VIA (IO 6)
0003F3r 2               ; Configures Port B (matrix) and Port A (PS/2) as inputs
0003F3r 2               ; CB2 low (enable matrix encoder), CA2 low (enable PS/2 encoder)
0003F3r 2               ; CB1 and CA1 falling-edge IRQs enabled
0003F3r 2               ; Modifies: Flags, A
0003F3r 2               InitKBImpl:
0003F3r 2  A9 00          lda #$00                      ; Port B all inputs (matrix keyboard data bus)
0003F5r 2  8D 02 94       sta GPIO_DDRB
0003F8r 2  A9 00          lda #$00                      ; Port A all inputs (PS/2 keyboard data bus)
0003FAr 2  8D 03 94       sta GPIO_DDRA
0003FDr 2                 ; PCR: CB2 low + CB1 neg + CA2 low + CA1 neg
0003FDr 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0003FFr 2  8D 0C 94       sta GPIO_PCR
000402r 2                 ; Enable both CB1 and CA1 interrupts
000402r 2  A9 92          lda #(GPIO_IER_SET | GPIO_INT_CB1 | GPIO_INT_CA1)
000404r 2  8D 0E 94       sta GPIO_IER
000407r 2  60             rts
000408r 2               
000408r 2               ; Initialize the Serial Card (6551)
000408r 2               ; Modifies: Flags, A
000408r 2               InitSCImpl:
000408r 2  A9 1F          lda     #$1F                  ; 8-N-1, 19200 baud
00040Ar 2  8D 03 90       sta     SC_CTRL
00040Dr 2  A9 09          lda     #$09                  ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
00040Fr 2  8D 02 90       sta     SC_CMD
000412r 2  60             rts
000413r 2               
000413r 2               ; Initialze the Sound Card (6581)
000413r 2               ; Modifies: Flags, A, X
000413r 2               InitSIDImpl:
000413r 2  A9 00          lda #$00
000415r 2  A2 1D          ldx #$1D                      ; Clear all 29 SID registers
000417r 2               @InitSIDLoop:
000417r 2  9D 00 98       sta SID_V1_FREQ_LO,x          ; Clear register
00041Ar 2  CA             dex
00041Br 2  10 FA          bpl @InitSIDLoop              ; Loop until all registers cleared
00041Dr 2  A9 0F          lda #$0F                      ; Set volume to maximum
00041Fr 2  8D 18 98       sta SID_MODE_VOL
000422r 2  60             rts
000423r 2               
000423r 2               ; Initialize the Video Card (TMS9918)
000423r 2               ; Modifies: Flags, A, X
000423r 2               InitVideoImpl:
000423r 2  A2 00          ldx #$00                      ; Start with register 0
000425r 2               @InitVideoLoop:
000425r 2  BD rr rr       lda @InitVideoRegData,x       ; Load register value
000428r 2  8D 01 9C       sta VC_REG                    ; Write data byte
00042Br 2  8A             txa
00042Cr 2  09 80          ora #$80                      ; Set bit 7 to indicate register write
00042Er 2  8D 01 9C       sta VC_REG                    ; Write register number
000431r 2  E8             inx
000432r 2  E0 08          cpx #$08                      ; Check if all 8 registers written
000434r 2  D0 EF          bne @InitVideoLoop            ; Continue until done
000436r 2  60             rts
000437r 2               @InitVideoRegData:
000437r 2  00             .byte $00                     ; R0: Mode control (no external video)
000438r 2  D0             .byte $D0                     ; R1: 16K, display on, interrupt off, text mode M1
000439r 2  00             .byte $00                     ; R2: Name table at $0000 (0x00 * 0x400)
00043Ar 2  00             .byte $00                     ; R3: Color table (not used in text mode)
00043Br 2  01             .byte $01                     ; R4: Pattern table at $0800 (0x01 * 0x800)
00043Cr 2  00             .byte $00                     ; R5: Sprite attribute table (not used in text mode)
00043Dr 2  00             .byte $00                     ; R6: Sprite pattern table (not used in text mode)
00043Er 2  1F             .byte $1F                     ; R7: Black text on white background
00043Fr 2               
00043Fr 2               ; Initialize the character set
00043Fr 2               ; Modifies: Flags, A, X, Y
00043Fr 2               InitCharacters:
00043Fr 2                 ; Set VRAM write address to $0800 (pattern table base)
00043Fr 2  A9 00          lda #$00                      ; Low byte of address
000441r 2  8D 01 9C       sta VC_REG
000444r 2  A9 48          lda #$48                      ; High byte ($08) OR $40 for write mode
000446r 2  8D 01 9C       sta VC_REG
000449r 2                 ; Set up source pointer
000449r 2  A9 rr          lda #<CharacterSet
00044Br 2  85 02          sta STR_PTR                   ; Use STR_PTR ($02-$03) for character set pointer
00044Dr 2  A9 rr          lda #>CharacterSet
00044Fr 2  85 03          sta STR_PTR + 1
000451r 2                 ; Copy 2048 bytes (8 pages of 256 bytes each)
000451r 2  A2 08          ldx #$08                      ; 8 pages to copy
000453r 2  A0 00          ldy #$00                      ; Byte counter within page
000455r 2               @InitCharPageLoop:
000455r 2  B1 02          lda (STR_PTR),y               ; Load from character set
000457r 2  8D 00 9C       sta VC_DATA                   ; Write to VRAM
00045Ar 2  C8             iny
00045Br 2  D0 F8          bne @InitCharPageLoop         ; Loop until page complete (256 bytes)
00045Dr 2  E6 03          inc STR_PTR + 1               ; Move to next page
00045Fr 2  CA             dex
000460r 2  D0 F3          bne @InitCharPageLoop         ; Loop for all 8 pages
000462r 2  60             rts
000463r 2               
000463r 2               ; Initialize the INPUT_BUFFER
000463r 2               ; Modifies: Flags, A
000463r 2               InitBuffer:
000463r 2  A9 00          lda #$00
000465r 2  85 00          sta READ_PTR                  ; Init read and write pointers
000467r 2  85 01          sta WRITE_PTR
000469r 2  60             rts
00046Ar 2               
00046Ar 2               ; Write a character from the A register to the INPUT_BUFFER
00046Ar 2               ; Modifies: Flags, X
00046Ar 2               WriteBufferImpl:
00046Ar 2  A6 01          ldx WRITE_PTR
00046Cr 2  9D 00 02       sta INPUT_BUFFER,x
00046Fr 2  E6 01          inc WRITE_PTR
000471r 2  60             rts
000472r 2               
000472r 2               ; Read a character from the INPUT_BUFFER and store it in A register
000472r 2               ; Modifies: Flags, X, A
000472r 2               ReadBufferImpl:
000472r 2  A6 00          ldx READ_PTR
000474r 2  BD 00 02       lda INPUT_BUFFER,x
000477r 2  E6 00          inc READ_PTR
000479r 2  60             rts
00047Ar 2               
00047Ar 2               ; Return in A register the number of unread bytes in the INPUT_BUFFER
00047Ar 2               ; Modifies: Flags, A
00047Ar 2               BufferSizeImpl:
00047Ar 2  A5 01          lda WRITE_PTR
00047Cr 2  38             sec
00047Dr 2  E5 00          sbc READ_PTR
00047Fr 2  60             rts
000480r 2               
000480r 2               ; Get a character from the INPUT_BUFFER if available
000480r 2               ; On return, carry flag indicates whether a character was available
000480r 2               ; If character available the character will be in the A register
000480r 2               ; Modifies: Flags, A
000480r 2               ChrinImpl:
000480r 2  DA             phx
000481r 2  20 rr rr       jsr BufferSize                ; Check for character available
000484r 2  F0 2C          beq @ChrinNoChar              ; Branch if no character available
000486r 2  20 rr rr       jsr ReadBuffer                ; Read the character from the buffer
000489r 2  20 rr rr       jsr Chrout                    ; Echo
00048Cr 2  48             pha
00048Dr 2  20 rr rr       jsr BufferSize
000490r 2  C9 B0          cmp #$B0                      ; Check if buffer is mostly full
000492r 2  90 0E          bcc @ChrinNotFull             ; Branch if buffer size < $B0
000494r 2                 ; Only touch SC_CMD if serial is present
000494r 2  AD 0D 03       lda HW_PRESENT
000497r 2  29 10          and #HW_SC
000499r 2  F0 13          beq @ChrinExit
00049Br 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
00049Dr 2  8D 02 90       sta SC_CMD
0004A0r 2  80 0C          bra @ChrinExit
0004A2r 2               @ChrinNotFull:
0004A2r 2  AD 0D 03       lda HW_PRESENT
0004A5r 2  29 10          and #HW_SC
0004A7r 2  F0 05          beq @ChrinExit
0004A9r 2  A9 09          lda #$09                      ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
0004ABr 2  8D 02 90       sta SC_CMD
0004AEr 2               @ChrinExit:
0004AEr 2  68             pla
0004AFr 2  FA             plx
0004B0r 2  38             sec
0004B1r 2  60             rts
0004B2r 2               @ChrinNoChar:
0004B2r 2  FA             plx
0004B3r 2  18             clc
0004B4r 2  60             rts
0004B5r 2               
0004B5r 2               ; Output a character from the A register to the Serial Card
0004B5r 2               ; Modifies: Flags
0004B5r 2               SerialChroutImpl:
0004B5r 2  8D 00 90       sta SC_DATA
0004B8r 2  48             pha
0004B9r 2               @ChroutWait:
0004B9r 2  AD 01 90       lda SC_STATUS
0004BCr 2  29 10          and #SC_STATUS_TDRE           ; Check if TX buffer not empty
0004BEr 2  F0 F9          beq @ChroutWait               ; Loop if TX buffer not empty
0004C0r 2  68             pla
0004C1r 2  60             rts
0004C2r 2               
0004C2r 2               ; SidPlayNote — Play a note on a SID voice
0004C2r 2               ; Input: A = voice (0-2), X = frequency low byte, Y = frequency high byte
0004C2r 2               ; Uses triangle waveform with standard ADSR (Attack=0, Decay=9, Sustain=A, Release=2)
0004C2r 2               ; Modifies: Flags, A
0004C2r 2               SidPlayNoteImpl:
0004C2r 2  C9 01          cmp #$01
0004C4r 2  F0 1A          beq @Voice2
0004C6r 2  C9 02          cmp #$02
0004C8r 2  F0 2C          beq @Voice3
0004CAr 2                 ; Voice 0
0004CAr 2  8E 00 98       stx SID_V1_FREQ_LO
0004CDr 2  8C 01 98       sty SID_V1_FREQ_HI
0004D0r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
0004D2r 2  8D 05 98       sta SID_V1_AD
0004D5r 2  A9 A2          lda #$A2                      ; Sustain = A, Release = 2
0004D7r 2  8D 06 98       sta SID_V1_SR
0004DAr 2  A9 11          lda #$11                      ; Triangle wave + Gate on
0004DCr 2  8D 04 98       sta SID_V1_CTRL
0004DFr 2  60             rts
0004E0r 2               @Voice2:
0004E0r 2  8E 07 98       stx SID_V2_FREQ_LO
0004E3r 2  8C 08 98       sty SID_V2_FREQ_HI
0004E6r 2  A9 09          lda #$09
0004E8r 2  8D 0C 98       sta SID_V2_AD
0004EBr 2  A9 A2          lda #$A2
0004EDr 2  8D 0D 98       sta SID_V2_SR
0004F0r 2  A9 11          lda #$11
0004F2r 2  8D 0B 98       sta SID_V2_CTRL
0004F5r 2  60             rts
0004F6r 2               @Voice3:
0004F6r 2  8E 0E 98       stx SID_V3_FREQ_LO
0004F9r 2  8C 0F 98       sty SID_V3_FREQ_HI
0004FCr 2  A9 09          lda #$09
0004FEr 2  8D 13 98       sta SID_V3_AD
000501r 2  A9 A2          lda #$A2
000503r 2  8D 14 98       sta SID_V3_SR
000506r 2  A9 11          lda #$11
000508r 2  8D 12 98       sta SID_V3_CTRL
00050Br 2  60             rts
00050Cr 2               
00050Cr 2               ; SidSilence — Silence all 3 SID voices
00050Cr 2               ; Gates off all voices and zeros their frequencies
00050Cr 2               ; Modifies: Flags, A
00050Cr 2               SidSilenceImpl:
00050Cr 2  A9 10          lda #$10                      ; Triangle wave, Gate off
00050Er 2  8D 04 98       sta SID_V1_CTRL
000511r 2  8D 0B 98       sta SID_V2_CTRL
000514r 2  8D 12 98       sta SID_V3_CTRL
000517r 2  A9 00          lda #$00
000519r 2  8D 00 98       sta SID_V1_FREQ_LO
00051Cr 2  8D 01 98       sta SID_V1_FREQ_HI
00051Fr 2  8D 07 98       sta SID_V2_FREQ_LO
000522r 2  8D 08 98       sta SID_V2_FREQ_HI
000525r 2  8D 0E 98       sta SID_V3_FREQ_LO
000528r 2  8D 0F 98       sta SID_V3_FREQ_HI
00052Br 2  60             rts
00052Cr 2               
00052Cr 2               ; Play a short beep sound
00052Cr 2               ; Uses SidPlayNote on voice 0 with ~475 Hz tone, then silences
00052Cr 2               ; Skips silently if SID is absent
00052Cr 2               ; Modifies: Flags, A, X, Y
00052Cr 2               BeepImpl:
00052Cr 2  AD 0D 03       lda HW_PRESENT
00052Fr 2  29 40          and #HW_SID
000531r 2  D0 01          bne @BeepStart
000533r 2  60             rts                           ; No SID — skip silently
000534r 2               @BeepStart:
000534r 2  A9 00          lda #$00                      ; Voice 0
000536r 2  A2 20          ldx #$20                      ; Frequency low byte (~475 Hz)
000538r 2  A0 1F          ldy #$1F                      ; Frequency high byte
00053Ar 2  20 rr rr       jsr SidPlayNote
00053Dr 2                 ; Override ADSR for beep: fast decay, no sustain
00053Dr 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
00053Fr 2  8D 05 98       sta SID_V1_AD
000542r 2  A9 00          lda #$00                      ; Sustain = 0, Release = 0
000544r 2  8D 06 98       sta SID_V1_SR
000547r 2                 ; Delay for beep duration
000547r 2  A2 F0          ldx #$F0                      ; Outer loop counter
000549r 2               @BeepDelay1:
000549r 2  A0 FF          ldy #$FF                      ; Inner loop counter
00054Br 2               @BeepDelay2:
00054Br 2  88             dey
00054Cr 2  D0 FD          bne @BeepDelay2
00054Er 2  CA             dex
00054Fr 2  D0 F8          bne @BeepDelay1
000551r 2  20 rr rr       jsr SidSilence                ; Gate off all voices
000554r 2  60             rts
000555r 2               
000555r 2               ; SysDelay — Delay for a specified number of centiseconds
000555r 2               ; Input: A = count low byte, X = count high byte
000555r 2               ; Uses VIA T1 in one-shot mode. 9999 cycles @ 1MHz = ~10ms per tick.
000555r 2               ; Modifies: Flags, A
000555r 2               SysDelayImpl:
000555r 2  85 2C          sta DELAY_CNT
000557r 2  86 2D          stx DELAY_CNT + 1
000559r 2                 ; Return immediately if count is zero
000559r 2  05 2D          ora DELAY_CNT + 1
00055Br 2  F0 4F          beq @DelayDone
00055Dr 2                 ; Check if VIA is present for hardware timer
00055Dr 2  AD 0D 03       lda HW_PRESENT
000560r 2  29 20          and #HW_GPIO
000562r 2  D0 19          bne @DelayHardware
000564r 2                 ; Software fallback — calibrated busy loop (~10ms per centisecond at 1MHz)
000564r 2                 ; Inner loop: 5 cycles × 256 iterations × 8 = ~10240 cycles ≈ 10ms
000564r 2               @DelaySoftLoop:
000564r 2  A0 00          ldy #$00                      ; 256 outer iterations
000566r 2  A2 08          ldx #8
000568r 2               @DelaySoftInner:
000568r 2  88             dey
000569r 2  D0 FD          bne @DelaySoftInner
00056Br 2  CA             dex
00056Cr 2  D0 FA          bne @DelaySoftInner
00056Er 2                 ; 16-bit decrement of DELAY_CNT
00056Er 2  A5 2C          lda DELAY_CNT
000570r 2  D0 02          bne @SoftDecLo
000572r 2  C6 2D          dec DELAY_CNT + 1
000574r 2               @SoftDecLo:
000574r 2  C6 2C          dec DELAY_CNT
000576r 2  A5 2C          lda DELAY_CNT
000578r 2  05 2D          ora DELAY_CNT + 1
00057Ar 2  D0 E8          bne @DelaySoftLoop
00057Cr 2  60             rts
00057Dr 2               @DelayHardware:
00057Dr 2                 ; Configure T1 one-shot mode: clear ACR bit 6
00057Dr 2  AD 0B 94       lda GPIO_ACR
000580r 2  29 BF          and #%10111111
000582r 2  8D 0B 94       sta GPIO_ACR
000585r 2               @DelayLoop:
000585r 2                 ; Load T1 latch: 9999 = $270F
000585r 2  A9 0F          lda #$0F
000587r 2  8D 06 94       sta GPIO_T1LL
00058Ar 2  A9 27          lda #$27
00058Cr 2  8D 07 94       sta GPIO_T1LH
00058Fr 2                 ; Write T1CH to start countdown (also clears IFR T1 flag)
00058Fr 2  A9 27          lda #$27
000591r 2  8D 05 94       sta GPIO_T1CH
000594r 2               @DelayPoll:
000594r 2  AD 0D 94       lda GPIO_IFR
000597r 2  29 40          and #%01000000                ; T1 timeout flag
000599r 2  F0 F9          beq @DelayPoll
00059Br 2                 ; Clear flag by reading T1CL
00059Br 2  AD 04 94       lda GPIO_T1CL
00059Er 2                 ; 16-bit decrement
00059Er 2  A5 2C          lda DELAY_CNT
0005A0r 2  D0 02          bne @DelayDecLo
0005A2r 2  C6 2D          dec DELAY_CNT + 1
0005A4r 2               @DelayDecLo:
0005A4r 2  C6 2C          dec DELAY_CNT
0005A6r 2                 ; Loop until both bytes zero
0005A6r 2  A5 2C          lda DELAY_CNT
0005A8r 2  05 2D          ora DELAY_CNT + 1
0005AAr 2  D0 D9          bne @DelayLoop
0005ACr 2               @DelayDone:
0005ACr 2  60             rts
0005ADr 2               
0005ADr 2               ; SidSetVolume — Set SID master volume
0005ADr 2               ; Input: A = volume (0-15); upper nibble of SID_MODE_VOL is cleared (no filter)
0005ADr 2               ; Modifies: Flags, A
0005ADr 2               SidSetVolumeImpl:
0005ADr 2  29 0F          and #$0F
0005AFr 2  8D 18 98       sta SID_MODE_VOL
0005B2r 2  60             rts
0005B3r 2               
0005B3r 2               ; VideoSetColor — Set TMS9918 text color register
0005B3r 2               ; Input: A = color byte (high nibble = fg color, low nibble = bg color)
0005B3r 2               ; Modifies: Flags, A
0005B3r 2               VideoSetColorImpl:
0005B3r 2  8D 01 9C       sta VC_REG                    ; Data byte
0005B6r 2  A9 87          lda #$87                      ; Register 7 | $80 (write mode flag)
0005B8r 2  8D 01 9C       sta VC_REG
0005BBr 2  60             rts
0005BCr 2               
0005BCr 2               ; KBDisable — Disable both keyboard encoders for raw port access
0005BCr 2               ; Sets CB2 high (disable matrix encoder) and CA2 high (disable PS/2 encoder)
0005BCr 2               ; Modifies: Flags, A
0005BCr 2               KBDisable:
0005BCr 2  A9 EE          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0005BEr 2  8D 0C 94       sta GPIO_PCR
0005C1r 2  60             rts
0005C2r 2               
0005C2r 2               ; KBEnable — Re-enable both keyboard encoders
0005C2r 2               ; Sets CB2 low (enable matrix encoder) and CA2 low (enable PS/2 encoder)
0005C2r 2               ; Modifies: Flags, A
0005C2r 2               KBEnable:
0005C2r 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0005C4r 2  8D 0C 94       sta GPIO_PCR
0005C7r 2  60             rts
0005C8r 2               
0005C8r 2               ; ReadJoystick1 — Read joystick 1 on Port B
0005C8r 2               ; Temporarily disables matrix keyboard encoder (CB2 high) to read raw port data
0005C8r 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
0005C8r 2               ; Modifies: Flags, A
0005C8r 2               ReadJoystick1Impl:
0005C8r 2  78             sei                           ; Disable interrupts during raw port read
0005C9r 2  AD 0C 94       lda GPIO_PCR
0005CCr 2  48             pha                           ; Save current PCR state
0005CDr 2                 ; Set CB2 high to disable matrix encoder, preserve CA2 state
0005CDr 2  A9 EC          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0005CFr 2  8D 0C 94       sta GPIO_PCR
0005D2r 2  AD 00 94       lda GPIO_PORTB                ; Read raw joystick data from Port B
0005D5r 2  AA             tax                           ; Save result in X
0005D6r 2  68             pla                           ; Restore original PCR state
0005D7r 2  8D 0C 94       sta GPIO_PCR
0005DAr 2  8A             txa                           ; Return result in A
0005DBr 2  58             cli                           ; Re-enable interrupts
0005DCr 2  60             rts
0005DDr 2               
0005DDr 2               ; ReadJoystick2 — Read joystick 2 on Port A
0005DDr 2               ; Temporarily disables PS/2 keyboard encoder (CA2 high) to read raw port data
0005DDr 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
0005DDr 2               ; Modifies: Flags, A
0005DDr 2               ReadJoystick2Impl:
0005DDr 2  78             sei                           ; Disable interrupts during raw port read
0005DEr 2  AD 0C 94       lda GPIO_PCR
0005E1r 2  48             pha                           ; Save current PCR state
0005E2r 2                 ; Set CA2 high to disable PS/2 encoder, preserve CB2 state
0005E2r 2  A9 CE          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0005E4r 2  8D 0C 94       sta GPIO_PCR
0005E7r 2  AD 01 94       lda GPIO_PORTA                ; Read raw joystick data from Port A
0005EAr 2  AA             tax                           ; Save result in X
0005EBr 2  68             pla                           ; Restore original PCR state
0005ECr 2  8D 0C 94       sta GPIO_PCR
0005EFr 2  8A             txa                           ; Return result in A
0005F0r 2  58             cli                           ; Re-enable interrupts
0005F1r 2  60             rts
0005F2r 2               
0005F2r 2               ; === BCD Conversion Helpers ===
0005F2r 2               
0005F2r 2               ; BcdToBin — Convert BCD byte to binary
0005F2r 2               ; Input: A = BCD value (e.g. $35 represents 35)
0005F2r 2               ; Output: A = binary value (e.g. 35 = $23)
0005F2r 2               ; Modifies: Flags
0005F2r 2               BcdToBin:
0005F2r 2  48             pha
0005F3r 2  4A             lsr a                         ; Shift tens digit to low nibble
0005F4r 2  4A             lsr a
0005F5r 2  4A             lsr a
0005F6r 2  4A             lsr a                         ; A = tens digit (0-9)
0005F7r 2  0A             asl a                         ; A = tens * 2
0005F8r 2  8D 0C 03       sta RTC_TMP
0005FBr 2  0A             asl a                         ; A = tens * 4
0005FCr 2  0A             asl a                         ; A = tens * 8
0005FDr 2  18             clc
0005FEr 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 (8 + 2)
000601r 2  8D 0C 03       sta RTC_TMP
000604r 2  68             pla
000605r 2  29 0F          and #$0F                      ; A = ones digit
000607r 2  18             clc
000608r 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 + ones = binary
00060Br 2  60             rts
00060Cr 2               
00060Cr 2               ; BinToBcd — Convert binary byte to BCD
00060Cr 2               ; Input: A = binary value (0-99)
00060Cr 2               ; Output: A = BCD value
00060Cr 2               ; Modifies: Flags, X
00060Cr 2               BinToBcd:
00060Cr 2  A2 FF          ldx #$FF                      ; Tens counter (starts at -1)
00060Er 2               @BinToBcdLoop:
00060Er 2  E8             inx
00060Fr 2  38             sec
000610r 2  E9 0A          sbc #10
000612r 2  B0 FA          bcs @BinToBcdLoop             ; Count tens
000614r 2  69 0A          adc #10                       ; Restore ones (carry clear, so adds 10 + 0)
000616r 2  8D 0C 03       sta RTC_TMP                   ; Save ones digit
000619r 2  8A             txa                           ; A = tens digit
00061Ar 2  0A             asl a
00061Br 2  0A             asl a
00061Cr 2  0A             asl a
00061Dr 2  0A             asl a                         ; Shift tens to high nibble
00061Er 2  0D 0C 03       ora RTC_TMP                   ; Combine with ones
000621r 2  60             rts
000622r 2               
000622r 2               ; === DS1511Y RTC Routines ===
000622r 2               
000622r 2               ; RtcReadTime — Read current time from DS1511Y
000622r 2               ; Output: A = hours (binary), X = minutes (binary), Y = seconds (binary)
000622r 2               ; Modifies: Flags
000622r 2               RtcReadTimeImpl:
000622r 2  AD 02 88       lda RTC_HR
000625r 2  20 rr rr       jsr BcdToBin
000628r 2  48             pha                           ; Save hours
000629r 2  AD 01 88       lda RTC_MIN
00062Cr 2  20 rr rr       jsr BcdToBin
00062Fr 2  AA             tax                           ; X = minutes
000630r 2  AD 00 88       lda RTC_SEC
000633r 2  20 rr rr       jsr BcdToBin
000636r 2  A8             tay                           ; Y = seconds
000637r 2  68             pla                           ; A = hours
000638r 2  60             rts
000639r 2               
000639r 2               ; RtcReadDate — Read current date from DS1511Y
000639r 2               ; Output: A = day of month (binary), X = month (binary), Y = year (binary)
000639r 2               ;         RTC_BUF_CENT = century (binary)
000639r 2               ; Modifies: Flags
000639r 2               RtcReadDateImpl:
000639r 2  AD 07 88       lda RTC_CENT
00063Cr 2  20 rr rr       jsr BcdToBin
00063Fr 2  8D 0B 03       sta RTC_BUF_CENT              ; Store century in buffer
000642r 2  AD 05 88       lda RTC_MON
000645r 2  29 1F          and #RTC_MON_MASK             ; Strip control bits (EOSC/E32K/BB32) before BCD decode
000647r 2  20 rr rr       jsr BcdToBin
00064Ar 2  AA             tax                           ; X = month
00064Br 2  AD 06 88       lda RTC_YR
00064Er 2  20 rr rr       jsr BcdToBin
000651r 2  A8             tay                           ; Y = year
000652r 2  AD 04 88       lda RTC_DATE
000655r 2  20 rr rr       jsr BcdToBin                  ; A = day of month
000658r 2  60             rts
000659r 2               
000659r 2               ; RtcWriteTime — Set DS1511Y time
000659r 2               ; Input: A = hours (binary), X = minutes (binary), Y = seconds (binary)
000659r 2               ; Modifies: Flags, A, X
000659r 2               RtcWriteTimeImpl:
000659r 2  48             pha                           ; Save hours
00065Ar 2  DA             phx                           ; Save minutes
00065Br 2  5A             phy                           ; Save seconds
00065Cr 2                 ; Set TE bit to inhibit update transfers
00065Cr 2  AD 0F 88       lda RTC_CTRL_B
00065Fr 2  09 80          ora #RTC_CTRL_B_TE
000661r 2  8D 0F 88       sta RTC_CTRL_B
000664r 2                 ; Write seconds
000664r 2  68             pla                           ; A = seconds
000665r 2  20 rr rr       jsr BinToBcd
000668r 2  8D 00 88       sta RTC_SEC
00066Br 2                 ; Write minutes
00066Br 2  68             pla                           ; A = minutes
00066Cr 2  20 rr rr       jsr BinToBcd
00066Fr 2  8D 01 88       sta RTC_MIN
000672r 2                 ; Write hours
000672r 2  68             pla                           ; A = hours
000673r 2  20 rr rr       jsr BinToBcd
000676r 2  8D 02 88       sta RTC_HR
000679r 2                 ; Clear TE bit to resume updates
000679r 2  AD 0F 88       lda RTC_CTRL_B
00067Cr 2  29 7F          and #<~RTC_CTRL_B_TE
00067Er 2  8D 0F 88       sta RTC_CTRL_B
000681r 2  60             rts
000682r 2               
000682r 2               ; RtcWriteDate — Set DS1511Y date
000682r 2               ; Input: A = day of month (binary), X = month (binary), Y = year (binary)
000682r 2               ;        RTC_BUF_CENT = century (binary)
000682r 2               ; Modifies: Flags, A, X
000682r 2               RtcWriteDateImpl:
000682r 2  48             pha                           ; Save day
000683r 2  DA             phx                           ; Save month
000684r 2  5A             phy                           ; Save year
000685r 2                 ; Set TE bit to inhibit update transfers
000685r 2  AD 0F 88       lda RTC_CTRL_B
000688r 2  09 80          ora #RTC_CTRL_B_TE
00068Ar 2  8D 0F 88       sta RTC_CTRL_B
00068Dr 2                 ; Write century
00068Dr 2  AD 0B 03       lda RTC_BUF_CENT
000690r 2  20 rr rr       jsr BinToBcd
000693r 2  8D 07 88       sta RTC_CENT
000696r 2                 ; Write year
000696r 2  68             pla                           ; A = year
000697r 2  20 rr rr       jsr BinToBcd
00069Ar 2  8D 06 88       sta RTC_YR
00069Dr 2                 ; Write month
00069Dr 2  68             pla                           ; A = month
00069Er 2  20 rr rr       jsr BinToBcd
0006A1r 2  29 1F          and #RTC_MON_MASK             ; Keep only the month value bits
0006A3r 2  8D 0C 03       sta RTC_TMP
0006A6r 2  AD 05 88       lda RTC_MON
0006A9r 2  29 E0          and #<~RTC_MON_MASK           ; Preserve control bits (EOSC/E32K/BB32)
0006ABr 2  0D 0C 03       ora RTC_TMP
0006AEr 2  8D 05 88       sta RTC_MON
0006B1r 2                 ; Write day
0006B1r 2  68             pla                           ; A = day
0006B2r 2  20 rr rr       jsr BinToBcd
0006B5r 2  8D 04 88       sta RTC_DATE
0006B8r 2                 ; Clear TE bit to resume updates
0006B8r 2  AD 0F 88       lda RTC_CTRL_B
0006BBr 2  29 7F          and #<~RTC_CTRL_B_TE
0006BDr 2  8D 0F 88       sta RTC_CTRL_B
0006C0r 2  60             rts
0006C1r 2               
0006C1r 2               ; RtcReadNVRAM — Read a byte from DS1511Y NVRAM
0006C1r 2               ; Input: X = NVRAM address ($00-$FF)
0006C1r 2               ; Output: A = data byte
0006C1r 2               ; Modifies: Flags
0006C1r 2               RtcReadNVRAMImpl:
0006C1r 2  8E 10 88       stx RTC_RAM_ADDR
0006C4r 2  AD 13 88       lda RTC_RAM_DATA
0006C7r 2  60             rts
0006C8r 2               
0006C8r 2               ; RtcWriteNVRAM — Write a byte to DS1511Y NVRAM
0006C8r 2               ; Input: X = NVRAM address ($00-$FF), A = data byte
0006C8r 2               ; Modifies: Flags
0006C8r 2               RtcWriteNVRAMImpl:
0006C8r 2  8E 10 88       stx RTC_RAM_ADDR
0006CBr 2  8D 13 88       sta RTC_RAM_DATA
0006CEr 2  60             rts
0006CFr 2               
0006CFr 2               ; === Hardware Probes ===
0006CFr 2               
0006CFr 2               ; ProbeRAM — Test for banked SRAM on IO 1 and IO 2
0006CFr 2               ; Two-pattern read-back test ($A5 then $5A) on bank 0 data byte
0006CFr 2               ; Sets HW_RAM_L / HW_RAM_H in HW_PRESENT on success
0006CFr 2               ; Modifies: Flags, A
0006CFr 2               ProbeRAM:
0006CFr 2                 ; --- Probe RAM Low (IO 1) ---
0006CFr 2  9C FF 83       stz RAM_BANK_L                ; Select bank 0
0006D2r 2  AD 00 80       lda RAM_DATA_L                ; Save existing value
0006D5r 2  48             pha
0006D6r 2  A9 A5          lda #$A5
0006D8r 2  8D 00 80       sta RAM_DATA_L
0006DBr 2  CD 00 80       cmp RAM_DATA_L
0006DEr 2  D0 12          bne @RAMLDone                 ; First pattern failed
0006E0r 2  A9 5A          lda #$5A
0006E2r 2  8D 00 80       sta RAM_DATA_L
0006E5r 2  CD 00 80       cmp RAM_DATA_L
0006E8r 2  D0 08          bne @RAMLDone                 ; Second pattern failed
0006EAr 2  AD 0D 03       lda HW_PRESENT
0006EDr 2  09 01          ora #HW_RAM_L
0006EFr 2  8D 0D 03       sta HW_PRESENT
0006F2r 2               @RAMLDone:
0006F2r 2  68             pla
0006F3r 2  8D 00 80       sta RAM_DATA_L                ; Restore original value
0006F6r 2                 ; --- Probe RAM High (IO 2) ---
0006F6r 2  9C FF 87       stz RAM_BANK_H                ; Select bank 0
0006F9r 2  AD 00 84       lda RAM_DATA_H                ; Save existing value
0006FCr 2  48             pha
0006FDr 2  A9 A5          lda #$A5
0006FFr 2  8D 00 84       sta RAM_DATA_H
000702r 2  CD 00 84       cmp RAM_DATA_H
000705r 2  D0 12          bne @RAMHDone                 ; First pattern failed
000707r 2  A9 5A          lda #$5A
000709r 2  8D 00 84       sta RAM_DATA_H
00070Cr 2  CD 00 84       cmp RAM_DATA_H
00070Fr 2  D0 08          bne @RAMHDone                 ; Second pattern failed
000711r 2  AD 0D 03       lda HW_PRESENT
000714r 2  09 02          ora #HW_RAM_H
000716r 2  8D 0D 03       sta HW_PRESENT
000719r 2               @RAMHDone:
000719r 2  68             pla
00071Ar 2  8D 00 84       sta RAM_DATA_H                ; Restore original value
00071Dr 2  60             rts
00071Er 2               
00071Er 2               ; ProbeVideo — TMS9918 VRAM read-back test
00071Er 2               ; Writes $A5 to VRAM address $0000, reads it back
00071Er 2               ; Sets HW_VID in HW_PRESENT on success
00071Er 2               ; Modifies: Flags, A
00071Er 2               ProbeVideo:
00071Er 2                 ; Write $A5 to VRAM $0000
00071Er 2  A9 00          lda #$00
000720r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
000723r 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
000725r 2  8D 01 9C       sta VC_REG
000728r 2  A9 A5          lda #$A5
00072Ar 2  8D 00 9C       sta VC_DATA                   ; Write data byte
00072Dr 2                 ; Read back from VRAM $0000
00072Dr 2  A9 00          lda #$00
00072Fr 2  8D 01 9C       sta VC_REG                    ; Low byte of address
000732r 2  A9 00          lda #$00                      ; High byte $00, bit 6 clear for read mode
000734r 2  8D 01 9C       sta VC_REG
000737r 2  AD 00 9C       lda VC_DATA                   ; Read data byte
00073Ar 2  C9 A5          cmp #$A5
00073Cr 2  D0 17          bne @ProbeVideoDone
00073Er 2  AD 0D 03       lda HW_PRESENT
000741r 2  09 80          ora #HW_VID
000743r 2  8D 0D 03       sta HW_PRESENT
000746r 2                 ; Clean up probe byte — write $00 back to VRAM $0000
000746r 2  A9 00          lda #$00
000748r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
00074Br 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
00074Dr 2  8D 01 9C       sta VC_REG
000750r 2  A9 00          lda #$00
000752r 2  8D 00 9C       sta VC_DATA
000755r 2               @ProbeVideoDone:
000755r 2  60             rts
000756r 2               
000756r 2               ; ProbeGPIO — VIA DDR register read-back test
000756r 2               ; Writes $AA to GPIO_DDRB, reads it back
000756r 2               ; Sets HW_GPIO in HW_PRESENT on success
000756r 2               ; Restores GPIO_DDRB to $00 afterward
000756r 2               ; Modifies: Flags, A
000756r 2               ProbeGPIO:
000756r 2  A9 AA          lda #$AA
000758r 2  8D 02 94       sta GPIO_DDRB
00075Br 2  CD 02 94       cmp GPIO_DDRB
00075Er 2  D0 08          bne @ProbeGPIODone
000760r 2  AD 0D 03       lda HW_PRESENT
000763r 2  09 20          ora #HW_GPIO
000765r 2  8D 0D 03       sta HW_PRESENT
000768r 2               @ProbeGPIODone:
000768r 2  9C 02 94       stz GPIO_DDRB                 ; Restore to inputs (InitKBImpl will configure properly)
00076Br 2  60             rts
00076Cr 2               
00076Cr 2               ; ProbeSerial — R65C51 CMD register write/read-back test
00076Cr 2               ; Issues programmatic reset, writes test value to CMD, reads back
00076Cr 2               ; Open bus will not match — prevents false detection
00076Cr 2               ; Sets HW_SC in HW_PRESENT on success
00076Cr 2               ; Modifies: Flags, A
00076Cr 2               ProbeSerial:
00076Cr 2  9C 01 90       stz SC_RESET                  ; Programmatic reset (write any value)
00076Fr 2  A9 0A          lda #$0A                      ; Test value (bits within CMD writable range)
000771r 2  8D 02 90       sta SC_CMD                    ; Write to Command Register
000774r 2  CD 02 90       cmp SC_CMD                    ; Read back — should match if real hardware
000777r 2  D0 08          bne @ProbeSerialDone          ; Mismatch = open bus, no card present
000779r 2  AD 0D 03       lda HW_PRESENT
00077Cr 2  09 10          ora #HW_SC
00077Er 2  8D 0D 03       sta HW_PRESENT
000781r 2               @ProbeSerialDone:
000781r 2  60             rts
000782r 2               
000782r 2               ; ProbeSID — Active oscillator test using voice 3
000782r 2               ; Configures voice 3 noise waveform, brief delay, reads SID_OSC3
000782r 2               ; Non-zero and non-$FF result indicates SID present
000782r 2               ; Sets HW_SID in HW_PRESENT on success
000782r 2               ; Modifies: Flags, A, X, Y
000782r 2               ProbeSID:
000782r 2                 ; Set voice 3 frequency to a fast value
000782r 2  A9 FF          lda #$FF
000784r 2  8D 0E 98       sta SID_V3_FREQ_LO
000787r 2  8D 0F 98       sta SID_V3_FREQ_HI
00078Ar 2                 ; Gate on + noise waveform
00078Ar 2  A9 81          lda #(SID_CTRL_GATE | SID_CTRL_NOISE)
00078Cr 2  8D 12 98       sta SID_V3_CTRL
00078Fr 2                 ; Brief software delay for oscillator to run
00078Fr 2  A0 00          ldy #$00
000791r 2               @ProbeSIDDelay:
000791r 2  88             dey
000792r 2  D0 FD          bne @ProbeSIDDelay            ; ~1280 cycles
000794r 2                 ; Read oscillator 3 output
000794r 2  AD 1B 98       lda SID_OSC3
000797r 2  F0 0E          beq @ProbeSIDCleanup          ; Zero → no SID
000799r 2  C9 FF          cmp #$FF
00079Br 2  F0 0A          beq @ProbeSIDCleanup          ; $FF → likely floating bus
00079Dr 2                 ; SID detected
00079Dr 2  48             pha
00079Er 2  AD 0D 03       lda HW_PRESENT
0007A1r 2  09 40          ora #HW_SID
0007A3r 2  8D 0D 03       sta HW_PRESENT
0007A6r 2  68             pla
0007A7r 2               @ProbeSIDCleanup:
0007A7r 2                 ; Silence voice 3
0007A7r 2  9C 12 98       stz SID_V3_CTRL
0007AAr 2  9C 0E 98       stz SID_V3_FREQ_LO
0007ADr 2  9C 0F 98       stz SID_V3_FREQ_HI
0007B0r 2  60             rts
0007B1r 2               
0007B1r 2               ; ProbeRTC — DS1511Y NVRAM read-back test
0007B1r 2               ; Writes test pattern to NVRAM address 0, reads it back
0007B1r 2               ; Sets HW_RTC in HW_PRESENT on success
0007B1r 2               ; Restores original NVRAM value afterward
0007B1r 2               ; Modifies: Flags, A
0007B1r 2               ProbeRTC:
0007B1r 2  9C 10 88       stz RTC_RAM_ADDR              ; Select NVRAM address 0
0007B4r 2  AD 13 88       lda RTC_RAM_DATA              ; Save existing value
0007B7r 2  48             pha
0007B8r 2  A9 A5          lda #$A5
0007BAr 2  8D 13 88       sta RTC_RAM_DATA              ; Write test pattern
0007BDr 2  CD 13 88       cmp RTC_RAM_DATA              ; Read back
0007C0r 2  D0 12          bne @ProbeRTCDone
0007C2r 2  AD 0D 03       lda HW_PRESENT
0007C5r 2  09 04          ora #HW_RTC
0007C7r 2  8D 0D 03       sta HW_PRESENT
0007CAr 2                 ; The DS1511Y SQW pin feeds the AB Controller, which turns every SQW edge into
0007CAr 2                 ; a 6502 NMI. Its control bits power up undefined and are battery-backed, so
0007CAr 2                 ; explicitly disable the square-wave output here. E32K/BB32/EOSC live in the
0007CAr 2                 ; upper 3 bits of the month register (05H); keep the month value and leave the
0007CAr 2                 ; oscillator running.
0007CAr 2  AD 05 88       lda RTC_MON
0007CDr 2  29 1F          and #RTC_MON_MASK             ; Keep month value (low 5 bits)
0007CFr 2  09 40          ora #RTC_MON_E32K             ; E32K=1 → SQW disabled; BB32=0, EOSC=0
0007D1r 2  8D 05 88       sta RTC_MON
0007D4r 2               @ProbeRTCDone:
0007D4r 2  68             pla
0007D5r 2  8D 13 88       sta RTC_RAM_DATA              ; Restore original value
0007D8r 2  60             rts
0007D9r 2               
0007D9r 2               ; === CompactFlash Storage Driver (True 8-bit IDE Mode) ===
0007D9r 2               
0007D9r 2               ; StWaitReady — Wait for CompactFlash to become ready
0007D9r 2               ; Polls ST_STATUS until BSY=0 and RDY=1, with X/Y timeout (~65536 iterations)
0007D9r 2               ; Output: Carry clear = ready, Carry set = error or timeout
0007D9r 2               ; Modifies: Flags, A, X, Y
0007D9r 2               StWaitReadyImpl:
0007D9r 2  A2 00          ldx #$00                      ; Outer timeout counter (256 × 256 = 65536 iterations)
0007DBr 2  A0 00          ldy #$00
0007DDr 2               @StWaitBsy:
0007DDr 2  AD 07 8C       lda ST_STATUS
0007E0r 2  29 80          and #ST_STATUS_BSY            ; Check BSY bit
0007E2r 2  F0 08          beq @StCheckRdy               ; BSY clear — check RDY
0007E4r 2  88             dey
0007E5r 2  D0 F6          bne @StWaitBsy
0007E7r 2  CA             dex
0007E8r 2  D0 F3          bne @StWaitBsy
0007EAr 2  38             sec                           ; Timed out — no device
0007EBr 2  60             rts
0007ECr 2               @StCheckRdy:
0007ECr 2  AD 07 8C       lda ST_STATUS
0007EFr 2  29 40          and #ST_STATUS_RDY            ; Check RDY bit
0007F1r 2  D0 08          bne @StCheckErr               ; RDY set — check for errors
0007F3r 2  88             dey
0007F4r 2  D0 E7          bne @StWaitBsy
0007F6r 2  CA             dex
0007F7r 2  D0 E4          bne @StWaitBsy
0007F9r 2  38             sec                           ; Timed out
0007FAr 2  60             rts
0007FBr 2               @StCheckErr:
0007FBr 2  AD 07 8C       lda ST_STATUS
0007FEr 2  29 01          and #ST_STATUS_ERR            ; Check ERR bit
000800r 2  D0 02          bne @StWaitErr
000802r 2  18             clc                           ; Ready, no error
000803r 2  60             rts
000804r 2               @StWaitErr:
000804r 2  38             sec                           ; Error condition
000805r 2  60             rts
000806r 2               
000806r 2               ; StWaitDrq — Wait for CompactFlash data request
000806r 2               ; Polls ST_STATUS until BSY=0 and DRQ=1, with X/Y timeout (~65536 iterations)
000806r 2               ; Output: Carry clear = DRQ active, Carry set = error or timeout
000806r 2               ; Modifies: Flags, A, X, Y
000806r 2               StWaitDrq:
000806r 2  A2 00          ldx #$00                      ; Outer timeout counter (256 × 256 = 65536 iterations)
000808r 2  A0 00          ldy #$00
00080Ar 2               @StDrqBsy:
00080Ar 2  AD 07 8C       lda ST_STATUS
00080Dr 2  29 80          and #ST_STATUS_BSY
00080Fr 2  F0 08          beq @StDrqCheckDrq            ; BSY clear — check DRQ
000811r 2  88             dey
000812r 2  D0 F6          bne @StDrqBsy
000814r 2  CA             dex
000815r 2  D0 F3          bne @StDrqBsy
000817r 2  38             sec                           ; Timed out — no device
000818r 2  60             rts
000819r 2               @StDrqCheckDrq:
000819r 2  AD 07 8C       lda ST_STATUS
00081Cr 2  29 01          and #ST_STATUS_ERR
00081Er 2  D0 11          bne @StDrqErr
000820r 2  AD 07 8C       lda ST_STATUS
000823r 2  29 08          and #ST_STATUS_DRQ
000825r 2  D0 08          bne @StDrqOk                  ; DRQ set — ready for data
000827r 2  88             dey
000828r 2  D0 E0          bne @StDrqBsy
00082Ar 2  CA             dex
00082Br 2  D0 DD          bne @StDrqBsy
00082Dr 2  38             sec                           ; Timed out
00082Er 2  60             rts
00082Fr 2               @StDrqOk:
00082Fr 2  18             clc
000830r 2  60             rts
000831r 2               @StDrqErr:
000831r 2  38             sec
000832r 2  60             rts
000833r 2               
000833r 2               ; StInit — Initialize CompactFlash for 8-bit data transfers
000833r 2               ; Issues Set Features command with subcommand $01 (enable 8-bit I/O)
000833r 2               ; Output: Carry clear = success, Carry set = error
000833r 2               ; Modifies: Flags, A
000833r 2               StInit:
000833r 2  20 rr rr       jsr StWaitReady
000836r 2  B0 15          bcs @StInitDone               ; Timeout or error — CF not present
000838r 2                 ; CF responded — set presence flag
000838r 2  AD 0D 03       lda HW_PRESENT
00083Br 2  09 08          ora #HW_CF
00083Dr 2  8D 0D 03       sta HW_PRESENT
000840r 2  A9 01          lda #ST_FEAT_8BIT             ; Feature: enable 8-bit data I/O
000842r 2  8D 01 8C       sta ST_FEATURE
000845r 2  A9 EF          lda #ST_CMD_SET_FEAT          ; Set Features command
000847r 2  8D 07 8C       sta ST_CMD
00084Ar 2  20 rr rr       jsr StWaitReady               ; Wait for command completion
00084Dr 2               @StInitDone:
00084Dr 2  60             rts
00084Er 2               
00084Er 2               ; StSetupLba — Set up LBA registers from CF_LBA zero page variables
00084Er 2               ; Also sets sector count to 1 and selects master drive in LBA mode
00084Er 2               ; Modifies: Flags, A
00084Er 2               StSetupLba:
00084Er 2  A9 01          lda #$01
000850r 2  8D 02 8C       sta ST_SECT_CNT               ; Always 1 sector
000853r 2  A5 26          lda CF_LBA
000855r 2  8D 03 8C       sta ST_LBA_0                  ; LBA bits 0-7
000858r 2  A5 27          lda CF_LBA + 1
00085Ar 2  8D 04 8C       sta ST_LBA_1                  ; LBA bits 8-15
00085Dr 2  A5 28          lda CF_LBA + 2
00085Fr 2  8D 05 8C       sta ST_LBA_2                  ; LBA bits 16-23
000862r 2  A5 29          lda CF_LBA + 3
000864r 2  29 0F          and #$0F                      ; Mask to 4 bits (LBA 24-27)
000866r 2  09 E0          ora #ST_LBA3_MASTER           ; LBA mode, master drive
000868r 2  8D 06 8C       sta ST_LBA_3
00086Br 2  60             rts
00086Cr 2               
00086Cr 2               ; StReadSector — Read one 512-byte sector from CompactFlash
00086Cr 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = destination pointer
00086Cr 2               ; Output: Carry clear = success, Carry set = error
00086Cr 2               ;         CF_BUF_PTR advanced by 512 bytes on success
00086Cr 2               ; Modifies: Flags, A, X, Y
00086Cr 2               StReadSectorImpl:
00086Cr 2  20 rr rr       jsr StWaitReady
00086Fr 2  B0 1F          bcs @StReadDone
000871r 2  20 rr rr       jsr StSetupLba
000874r 2  A9 20          lda #ST_CMD_READ              ; Issue read command
000876r 2  8D 07 8C       sta ST_CMD
000879r 2  20 rr rr       jsr StWaitDrq                 ; Wait for data ready
00087Cr 2  B0 12          bcs @StReadDone
00087Er 2                 ; Read 512 bytes: 2 pages of 256 bytes
00087Er 2  A0 00          ldy #$00
000880r 2  A2 02          ldx #$02                      ; 2 pages
000882r 2               @StReadPage:
000882r 2  AD 00 8C       lda ST_DATA                   ; Read byte from CF
000885r 2  91 24          sta (CF_BUF_PTR),y            ; Store to destination
000887r 2  C8             iny
000888r 2  D0 F8          bne @StReadPage               ; Loop for 256 bytes
00088Ar 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
00088Cr 2  CA             dex
00088Dr 2  D0 F3          bne @StReadPage
00088Fr 2  18             clc                           ; Success
000890r 2               @StReadDone:
000890r 2  60             rts
000891r 2               
000891r 2               ; StWriteSector — Write one 512-byte sector to CompactFlash
000891r 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = source pointer
000891r 2               ; Output: Carry clear = success, Carry set = error
000891r 2               ;         CF_BUF_PTR advanced by 512 bytes on success
000891r 2               ; Modifies: Flags, A, X, Y
000891r 2               StWriteSectorImpl:
000891r 2  20 rr rr       jsr StWaitReady
000894r 2  B0 21          bcs @StWriteDone
000896r 2  20 rr rr       jsr StSetupLba
000899r 2  A9 30          lda #ST_CMD_WRITE             ; Issue write command
00089Br 2  8D 07 8C       sta ST_CMD
00089Er 2  20 rr rr       jsr StWaitDrq                 ; Wait for data request
0008A1r 2  B0 14          bcs @StWriteDone
0008A3r 2                 ; Write 512 bytes: 2 pages of 256 bytes
0008A3r 2  A0 00          ldy #$00
0008A5r 2  A2 02          ldx #$02                      ; 2 pages
0008A7r 2               @StWritePage:
0008A7r 2  B1 24          lda (CF_BUF_PTR),y            ; Load from source
0008A9r 2  8D 00 8C       sta ST_DATA                   ; Write byte to CF
0008ACr 2  C8             iny
0008ADr 2  D0 F8          bne @StWritePage              ; Loop for 256 bytes
0008AFr 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
0008B1r 2  CA             dex
0008B2r 2  D0 F3          bne @StWritePage
0008B4r 2  20 rr rr       jsr StWaitReady               ; Wait for write to complete
0008B7r 2               @StWriteDone:
0008B7r 2  60             rts
0008B8r 2               
0008B8r 2               ; === Simple Custom Filesystem ===
0008B8r 2               ; Directory at LBA 0: 16 entries x 32 bytes = 512 bytes
0008B8r 2               ; Entry format:
0008B8r 2               ;   $00-$07: 8-byte filename (space-padded)
0008B8r 2               ;   $08-$0A: 3-byte extension (space-padded)
0008B8r 2               ;   $0B:     flags (bit 0 = in use)
0008B8r 2               ;   $0C-$0D: start sector (little-endian)
0008B8r 2               ;   $0E-$0F: file size in bytes (little-endian)
0008B8r 2               ;   $10-$1F: reserved (16 bytes)
0008B8r 2               
0008B8r 2               ; FsParseName — Parse null-terminated filename at STR_PTR into FS_FNAME_BUF
0008B8r 2               ; Converts "NAME.EXT" into 8+3 space-padded format
0008B8r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
0008B8r 2               ; Output: FS_FNAME_BUF filled with padded 8+3 name
0008B8r 2               ; Modifies: Flags, A, X, Y
0008B8r 2               FsParseName:
0008B8r 2                 ; Fill FS_FNAME_BUF with spaces
0008B8r 2  A9 20          lda #$20
0008BAr 2  A2 0A          ldx #10
0008BCr 2               @FsParseClr:
0008BCr 2  9D 50 03       sta FS_FNAME_BUF,x
0008BFr 2  CA             dex
0008C0r 2  10 FA          bpl @FsParseClr
0008C2r 2                 ; Copy name part (up to 8 chars, stop at '.' or null)
0008C2r 2  A0 00          ldy #$00                      ; Source index
0008C4r 2  A2 00          ldx #$00                      ; Dest index (name portion)
0008C6r 2               @FsParseName:
0008C6r 2  B1 02          lda (STR_PTR),y
0008C8r 2  F0 35          beq @FsParseDone              ; Null terminator — no extension
0008CAr 2  C9 2E          cmp #'.'
0008CCr 2  F0 15          beq @FsParseExt               ; Found dot — start extension
0008CEr 2  E0 08          cpx #$08
0008D0r 2  B0 0E          bcs @FsParseSkipName          ; Already 8 chars, skip extras
0008D2r 2                 ; Convert lowercase to uppercase
0008D2r 2  C9 61          cmp #'a'
0008D4r 2  90 06          bcc @FsStoreNameChar
0008D6r 2  C9 7B          cmp #'z' + 1
0008D8r 2  B0 02          bcs @FsStoreNameChar
0008DAr 2  29 DF          and #$DF                      ; Clear bit 5 to uppercase
0008DCr 2               @FsStoreNameChar:
0008DCr 2  9D 50 03       sta FS_FNAME_BUF,x
0008DFr 2  E8             inx
0008E0r 2               @FsParseSkipName:
0008E0r 2  C8             iny
0008E1r 2  80 E3          bra @FsParseName
0008E3r 2               @FsParseExt:
0008E3r 2  C8             iny                           ; Skip the dot
0008E4r 2  A2 08          ldx #$08                      ; Extension starts at offset 8
0008E6r 2               @FsParseExtLoop:
0008E6r 2  B1 02          lda (STR_PTR),y
0008E8r 2  F0 15          beq @FsParseDone              ; Null terminator
0008EAr 2  E0 0B          cpx #$0B
0008ECr 2  B0 11          bcs @FsParseDone              ; Max 3 ext chars
0008EEr 2                 ; Convert lowercase to uppercase
0008EEr 2  C9 61          cmp #'a'
0008F0r 2  90 06          bcc @FsStoreExtChar
0008F2r 2  C9 7B          cmp #'z' + 1
0008F4r 2  B0 02          bcs @FsStoreExtChar
0008F6r 2  29 DF          and #$DF
0008F8r 2               @FsStoreExtChar:
0008F8r 2  9D 50 03       sta FS_FNAME_BUF,x
0008FBr 2  E8             inx
0008FCr 2  C8             iny
0008FDr 2  80 E7          bra @FsParseExtLoop
0008FFr 2               @FsParseDone:
0008FFr 2  60             rts
000900r 2               
000900r 2               ; FsReadDir — Read directory sector (LBA 0) into FS_SECTOR_BUF
000900r 2               ; Output: Carry clear = success, Carry set = error
000900r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000900r 2               FsReadDir:
000900r 2  64 26          stz CF_LBA                    ; LBA = 0 (directory sector)
000902r 2  64 27          stz CF_LBA + 1
000904r 2  64 28          stz CF_LBA + 2
000906r 2  64 29          stz CF_LBA + 3
000908r 2  A9 00          lda #<FS_SECTOR_BUF
00090Ar 2  85 24          sta CF_BUF_PTR
00090Cr 2  A9 06          lda #>FS_SECTOR_BUF
00090Er 2  85 25          sta CF_BUF_PTR + 1
000910r 2  4C rr rr       jmp StReadSector
000913r 2               
000913r 2               ; FsWriteDir — Write directory sector from FS_SECTOR_BUF to LBA 0
000913r 2               ; Output: Carry clear = success, Carry set = error
000913r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000913r 2               FsWriteDir:
000913r 2  64 26          stz CF_LBA
000915r 2  64 27          stz CF_LBA + 1
000917r 2  64 28          stz CF_LBA + 2
000919r 2  64 29          stz CF_LBA + 3
00091Br 2  A9 00          lda #<FS_SECTOR_BUF
00091Dr 2  85 24          sta CF_BUF_PTR
00091Fr 2  A9 06          lda #>FS_SECTOR_BUF
000921r 2  85 25          sta CF_BUF_PTR + 1
000923r 2  4C rr rr       jmp StWriteSector
000926r 2               
000926r 2               ; FsFindFile — Search directory for filename in FS_FNAME_BUF
000926r 2               ; Must call FsReadDir first to load directory into FS_SECTOR_BUF
000926r 2               ; Output: Carry clear = found, X = entry index (0-15), CF_BUF_PTR points to entry
000926r 2               ;         Carry set = not found
000926r 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
000926r 2               FsFindFile:
000926r 2  A9 00          lda #<FS_SECTOR_BUF
000928r 2  85 24          sta CF_BUF_PTR
00092Ar 2  A9 06          lda #>FS_SECTOR_BUF
00092Cr 2  85 25          sta CF_BUF_PTR + 1
00092Er 2  A2 00          ldx #$00                      ; Entry index
000930r 2               @FsFindLoop:
000930r 2                 ; Check if entry is in use
000930r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000932r 2  B1 24          lda (CF_BUF_PTR),y
000934r 2  29 01          and #FS_FLAG_USED
000936r 2  F0 13          beq @FsFindNext               ; Skip unused entries
000938r 2                 ; Compare 11-byte filename
000938r 2  A0 00          ldy #$00
00093Ar 2               @FsFindCmp:
00093Ar 2  B1 24          lda (CF_BUF_PTR),y
00093Cr 2  D9 50 03       cmp FS_FNAME_BUF,y
00093Fr 2  D0 0A          bne @FsFindNext               ; Mismatch
000941r 2  C8             iny
000942r 2  C0 0B          cpy #11
000944r 2  D0 F4          bne @FsFindCmp
000946r 2                 ; Match found
000946r 2  8E 4D 03       stx FS_DIR_IDX
000949r 2  18             clc
00094Ar 2  60             rts
00094Br 2               @FsFindNext:
00094Br 2                 ; Advance CF_BUF_PTR by 32 (FS_ENTRY_SIZE)
00094Br 2  A5 24          lda CF_BUF_PTR
00094Dr 2  18             clc
00094Er 2  69 20          adc #FS_ENTRY_SIZE
000950r 2  85 24          sta CF_BUF_PTR
000952r 2  90 02          bcc @FsFindNoCarry
000954r 2  E6 25          inc CF_BUF_PTR + 1
000956r 2               @FsFindNoCarry:
000956r 2  E8             inx
000957r 2  E0 10          cpx #FS_MAX_FILES
000959r 2  D0 D5          bne @FsFindLoop
00095Br 2  38             sec                           ; Not found
00095Cr 2  60             rts
00095Dr 2               
00095Dr 2               ; FsFindFree — Find first free directory entry
00095Dr 2               ; Must call FsReadDir first
00095Dr 2               ; Output: Carry clear = found, X = entry index, CF_BUF_PTR points to entry
00095Dr 2               ;         Carry set = directory full
00095Dr 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
00095Dr 2               FsFindFree:
00095Dr 2  A9 00          lda #<FS_SECTOR_BUF
00095Fr 2  85 24          sta CF_BUF_PTR
000961r 2  A9 06          lda #>FS_SECTOR_BUF
000963r 2  85 25          sta CF_BUF_PTR + 1
000965r 2  A2 00          ldx #$00
000967r 2               @FsFreeLoop:
000967r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000969r 2  B1 24          lda (CF_BUF_PTR),y
00096Br 2  29 01          and #FS_FLAG_USED
00096Dr 2  F0 12          beq @FsFreeFound              ; Found unused entry
00096Fr 2                 ; Advance by 32
00096Fr 2  A5 24          lda CF_BUF_PTR
000971r 2  18             clc
000972r 2  69 20          adc #FS_ENTRY_SIZE
000974r 2  85 24          sta CF_BUF_PTR
000976r 2  90 02          bcc @FsFreeNoCarry
000978r 2  E6 25          inc CF_BUF_PTR + 1
00097Ar 2               @FsFreeNoCarry:
00097Ar 2  E8             inx
00097Br 2  E0 10          cpx #FS_MAX_FILES
00097Dr 2  D0 E8          bne @FsFreeLoop
00097Fr 2  38             sec                           ; Directory full
000980r 2  60             rts
000981r 2               @FsFreeFound:
000981r 2  8E 4D 03       stx FS_DIR_IDX
000984r 2  18             clc
000985r 2  60             rts
000986r 2               
000986r 2               ; FsCalcNextSec — Calculate next free sector by scanning all directory entries
000986r 2               ; Must call FsReadDir first
000986r 2               ; Output: FS_NEXT_SEC = first free sector after all used files
000986r 2               ; Modifies: Flags, A, X, Y
000986r 2               FsCalcNextSec:
000986r 2  A9 01          lda #<FS_DATA_START           ; Start with first data sector
000988r 2  8D 4E 03       sta FS_NEXT_SEC
00098Br 2  A9 00          lda #>FS_DATA_START
00098Dr 2  8D 4F 03       sta FS_NEXT_SEC + 1
000990r 2                 ; Scan all entries to find highest used sector + file sector count
000990r 2  A9 00          lda #<FS_SECTOR_BUF
000992r 2  85 24          sta CF_BUF_PTR
000994r 2  A9 06          lda #>FS_SECTOR_BUF
000996r 2  85 25          sta CF_BUF_PTR + 1
000998r 2  A2 00          ldx #$00
00099Ar 2               @FsCalcLoop:
00099Ar 2  A0 0B          ldy #FS_ENTRY_FLAGS
00099Cr 2  B1 24          lda (CF_BUF_PTR),y
00099Er 2  29 01          and #FS_FLAG_USED
0009A0r 2  F0 51          beq @FsCalcNext               ; Skip unused
0009A2r 2                 ; Get start sector + ceil(size/512)
0009A2r 2  A0 0C          ldy #FS_ENTRY_START
0009A4r 2  B1 24          lda (CF_BUF_PTR),y
0009A6r 2  8D 48 03       sta FS_START_SEC
0009A9r 2  C8             iny
0009AAr 2  B1 24          lda (CF_BUF_PTR),y
0009ACr 2  8D 49 03       sta FS_START_SEC + 1
0009AFr 2                 ; Get file size
0009AFr 2  A0 0E          ldy #FS_ENTRY_FSIZE
0009B1r 2  B1 24          lda (CF_BUF_PTR),y
0009B3r 2  8D 4A 03       sta FS_FILE_SIZE
0009B6r 2  C8             iny
0009B7r 2  B1 24          lda (CF_BUF_PTR),y
0009B9r 2  8D 4B 03       sta FS_FILE_SIZE + 1
0009BCr 2                 ; Calculate sectors used = (size + 511) / 512 = (size + 511) >> 9
0009BCr 2                 ; = (size_hi + 1) if size_lo > 0, else size_hi / 2... simplify:
0009BCr 2                 ; sectors = (size >> 9) rounded up = high_byte >> 1, plus 1 if any remainder
0009BCr 2  AD 4B 03       lda FS_FILE_SIZE + 1          ; High byte of size
0009BFr 2  4A             lsr a                         ; Divide by 2 (each sector = 512 = 2 pages)
0009C0r 2  8D 4C 03       sta FS_SEC_COUNT
0009C3r 2                 ; Check if there's a remainder (low byte != 0 or high byte bit 0 was set)
0009C3r 2  AD 4B 03       lda FS_FILE_SIZE + 1
0009C6r 2  29 01          and #$01                      ; Was high byte odd?
0009C8r 2  D0 05          bne @FsCalcRound
0009CAr 2  AD 4A 03       lda FS_FILE_SIZE              ; Low byte non-zero?
0009CDr 2  F0 03          beq @FsCalcNoRound
0009CFr 2               @FsCalcRound:
0009CFr 2  EE 4C 03       inc FS_SEC_COUNT              ; Round up
0009D2r 2               @FsCalcNoRound:
0009D2r 2                 ; End sector = start + sector count
0009D2r 2  AD 48 03       lda FS_START_SEC
0009D5r 2  18             clc
0009D6r 2  6D 4C 03       adc FS_SEC_COUNT
0009D9r 2  48             pha
0009DAr 2  AD 49 03       lda FS_START_SEC + 1
0009DDr 2  69 00          adc #$00
0009DFr 2  AA             tax                           ; X = end sector high
0009E0r 2  68             pla                           ; A = end sector low
0009E1r 2                 ; Compare with FS_NEXT_SEC — keep the larger value
0009E1r 2  EC 4F 03       cpx FS_NEXT_SEC + 1
0009E4r 2  90 0D          bcc @FsCalcNext               ; End < FS_NEXT_SEC, skip
0009E6r 2  D0 05          bne @FsCalcUpdate             ; End high > FS_NEXT_SEC high, update
0009E8r 2  CD 4E 03       cmp FS_NEXT_SEC
0009EBr 2  90 06          bcc @FsCalcNext               ; End low < FS_NEXT_SEC low
0009EDr 2               @FsCalcUpdate:
0009EDr 2  8D 4E 03       sta FS_NEXT_SEC
0009F0r 2  8E 4F 03       stx FS_NEXT_SEC + 1
0009F3r 2               @FsCalcNext:
0009F3r 2                 ; Advance CF_BUF_PTR by 32
0009F3r 2  A5 24          lda CF_BUF_PTR
0009F5r 2  18             clc
0009F6r 2  69 20          adc #FS_ENTRY_SIZE
0009F8r 2  85 24          sta CF_BUF_PTR
0009FAr 2  90 02          bcc @FsCalcNoCarry
0009FCr 2  E6 25          inc CF_BUF_PTR + 1
0009FEr 2               @FsCalcNoCarry:
0009FEr 2  E8             inx
0009FFr 2  E0 10          cpx #FS_MAX_FILES
000A01r 2  D0 97          bne @FsCalcLoop
000A03r 2  60             rts
000A04r 2               
000A04r 2               ; FsDirectory — Print directory listing of all used entries
000A04r 2               ; Output via Chrout (respects current IO_MODE)
000A04r 2               ; Modifies: Flags, A, X, Y
000A04r 2               FsDirectory:
000A04r 2  20 rr rr       jsr FsReadDir                 ; Load directory sector
000A07r 2  90 01          bcc @FsDirStart
000A09r 2  60             rts                           ; Error reading directory
000A0Ar 2               @FsDirStart:
000A0Ar 2  A9 00          lda #<FS_SECTOR_BUF
000A0Cr 2  85 24          sta CF_BUF_PTR
000A0Er 2  A9 06          lda #>FS_SECTOR_BUF
000A10r 2  85 25          sta CF_BUF_PTR + 1
000A12r 2  A2 00          ldx #$00                      ; Entry counter
000A14r 2               @FsDirLoop:
000A14r 2  DA             phx
000A15r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000A17r 2  B1 24          lda (CF_BUF_PTR),y
000A19r 2  29 01          and #FS_FLAG_USED
000A1Br 2  F0 3A          beq @FsDirNext                ; Skip unused entries
000A1Dr 2                 ; Print filename (8 chars)
000A1Dr 2  A0 00          ldy #$00
000A1Fr 2               @FsDirName:
000A1Fr 2  B1 24          lda (CF_BUF_PTR),y
000A21r 2  20 rr rr       jsr Chrout
000A24r 2  C8             iny
000A25r 2  C0 08          cpy #$08
000A27r 2  D0 F6          bne @FsDirName
000A29r 2                 ; Print dot separator
000A29r 2  A9 2E          lda #'.'
000A2Br 2  20 rr rr       jsr Chrout
000A2Er 2                 ; Print extension (3 chars)
000A2Er 2               @FsDirExt:
000A2Er 2  B1 24          lda (CF_BUF_PTR),y
000A30r 2  20 rr rr       jsr Chrout
000A33r 2  C8             iny
000A34r 2  C0 0B          cpy #$0B
000A36r 2  D0 F6          bne @FsDirExt
000A38r 2                 ; Print space
000A38r 2  A9 20          lda #' '
000A3Ar 2  20 rr rr       jsr Chrout
000A3Dr 2                 ; Print file size in decimal
000A3Dr 2  A0 0E          ldy #FS_ENTRY_FSIZE
000A3Fr 2  B1 24          lda (CF_BUF_PTR),y
000A41r 2  8D 4A 03       sta FS_FILE_SIZE
000A44r 2  C8             iny
000A45r 2  B1 24          lda (CF_BUF_PTR),y
000A47r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000A4Ar 2  20 rr rr       jsr FsPrintSize
000A4Dr 2                 ; Print newline
000A4Dr 2  A9 0D          lda #$0D
000A4Fr 2  20 rr rr       jsr Chrout
000A52r 2  A9 0A          lda #$0A
000A54r 2  20 rr rr       jsr Chrout
000A57r 2               @FsDirNext:
000A57r 2                 ; Advance CF_BUF_PTR by 32
000A57r 2  A5 24          lda CF_BUF_PTR
000A59r 2  18             clc
000A5Ar 2  69 20          adc #FS_ENTRY_SIZE
000A5Cr 2  85 24          sta CF_BUF_PTR
000A5Er 2  90 02          bcc @FsDirNoCarry
000A60r 2  E6 25          inc CF_BUF_PTR + 1
000A62r 2               @FsDirNoCarry:
000A62r 2  FA             plx
000A63r 2  E8             inx
000A64r 2  E0 10          cpx #FS_MAX_FILES
000A66r 2  D0 AC          bne @FsDirLoop
000A68r 2  60             rts
000A69r 2               
000A69r 2               ; FsPrintSize — Print 16-bit value in FS_FILE_SIZE as decimal
000A69r 2               ; Modifies: Flags, A, X, Y
000A69r 2               FsPrintSize:
000A69r 2                 ; Convert 16-bit value to decimal digits (up to 5 digits for 0-65535)
000A69r 2                 ; Use successive subtraction of powers of 10
000A69r 2  A2 00          ldx #$00                      ; Digit index / leading zero suppression
000A6Br 2  A0 00          ldy #$00                      ; Power-of-10 table index
000A6Dr 2               @FsPrintSizeLoop:
000A6Dr 2  A9 2F          lda #'0' - 1                  ; Start character below '0'
000A6Fr 2  8D 4D 03       sta FS_DIR_IDX                ; Reuse as digit scratch
000A72r 2               @FsPrintSub:
000A72r 2  EE 4D 03       inc FS_DIR_IDX
000A75r 2  AD 4A 03       lda FS_FILE_SIZE
000A78r 2  38             sec
000A79r 2  F9 rr rr       sbc @FsPow10Lo,y
000A7Cr 2  48             pha
000A7Dr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000A80r 2  F9 rr rr       sbc @FsPow10Hi,y
000A83r 2  90 09          bcc @FsPrintSizeDig           ; Underflow — done subtracting
000A85r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000A88r 2  68             pla
000A89r 2  8D 4A 03       sta FS_FILE_SIZE
000A8Cr 2  80 E4          bra @FsPrintSub
000A8Er 2               @FsPrintSizeDig:
000A8Er 2  68             pla                           ; Discard underflowed low byte
000A8Fr 2  AD 4D 03       lda FS_DIR_IDX
000A92r 2  C9 30          cmp #'0'
000A94r 2  D0 04          bne @FsPrintSizeOut           ; Non-zero digit
000A96r 2  E0 00          cpx #$00
000A98r 2  F0 04          beq @FsPrintSizeSkip          ; Suppress leading zeros
000A9Ar 2               @FsPrintSizeOut:
000A9Ar 2  20 rr rr       jsr Chrout
000A9Dr 2  E8             inx                           ; Mark that we've printed a digit
000A9Er 2               @FsPrintSizeSkip:
000A9Er 2  C8             iny
000A9Fr 2  C0 04          cpy #$04                      ; 4 powers of 10 (10000, 1000, 100, 10)
000AA1r 2  D0 CA          bne @FsPrintSizeLoop
000AA3r 2                 ; Always print ones digit
000AA3r 2  AD 4A 03       lda FS_FILE_SIZE
000AA6r 2  09 30          ora #'0'                      ; Low byte is 0-9 at this point
000AA8r 2  20 rr rr       jsr Chrout
000AABr 2  60             rts
000AACr 2  10 E8 64 0A  @FsPow10Lo: .byte <10000, <1000, <100, <10
000AB0r 2  27 03 00 00  @FsPow10Hi: .byte >10000, >1000, >100, >10
000AB4r 2               
000AB4r 2               ; FsLoadFileImpl — Load file from CF into PROGRAM_START ($0800)
000AB4r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000AB4r 2               ; Output: Carry clear = success, FS_FILE_SIZE = bytes loaded
000AB4r 2               ;         Carry set = file not found or read error
000AB4r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000AB4r 2               FsLoadFileImpl:
000AB4r 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000AB7r 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000ABAr 2  B0 63          bcs @FsLoadErr
000ABCr 2  20 rr rr       jsr FsFindFile                ; Search for filename
000ABFr 2  B0 5E          bcs @FsLoadErr                ; Not found
000AC1r 2                 ; Read file metadata from entry
000AC1r 2  A0 0C          ldy #FS_ENTRY_START
000AC3r 2  B1 24          lda (CF_BUF_PTR),y
000AC5r 2  8D 48 03       sta FS_START_SEC
000AC8r 2  C8             iny
000AC9r 2  B1 24          lda (CF_BUF_PTR),y
000ACBr 2  8D 49 03       sta FS_START_SEC + 1
000ACEr 2  A0 0E          ldy #FS_ENTRY_FSIZE
000AD0r 2  B1 24          lda (CF_BUF_PTR),y
000AD2r 2  8D 4A 03       sta FS_FILE_SIZE
000AD5r 2  C8             iny
000AD6r 2  B1 24          lda (CF_BUF_PTR),y
000AD8r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000ADBr 2                 ; Calculate number of sectors to read
000ADBr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000ADEr 2  4A             lsr a
000ADFr 2  8D 4C 03       sta FS_SEC_COUNT
000AE2r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000AE5r 2  29 01          and #$01
000AE7r 2  D0 05          bne @FsLoadRound
000AE9r 2  AD 4A 03       lda FS_FILE_SIZE
000AECr 2  F0 03          beq @FsLoadNoRound
000AEEr 2               @FsLoadRound:
000AEEr 2  EE 4C 03       inc FS_SEC_COUNT
000AF1r 2               @FsLoadNoRound:
000AF1r 2                 ; Set up LBA starting at file's start sector
000AF1r 2  AD 48 03       lda FS_START_SEC
000AF4r 2  85 26          sta CF_LBA
000AF6r 2  AD 49 03       lda FS_START_SEC + 1
000AF9r 2  85 27          sta CF_LBA + 1
000AFBr 2  64 28          stz CF_LBA + 2
000AFDr 2  64 29          stz CF_LBA + 3
000AFFr 2                 ; Set destination pointer to PROGRAM_START
000AFFr 2  A9 00          lda #<PROGRAM_START
000B01r 2  85 24          sta CF_BUF_PTR
000B03r 2  A9 08          lda #>PROGRAM_START
000B05r 2  85 25          sta CF_BUF_PTR + 1
000B07r 2                 ; Read sectors
000B07r 2  AE 4C 03       ldx FS_SEC_COUNT
000B0Ar 2  F0 10          beq @FsLoadOk                 ; Zero-size file
000B0Cr 2               @FsLoadSec:
000B0Cr 2  DA             phx
000B0Dr 2  20 rr rr       jsr StReadSector              ; Read sector (advances CF_BUF_PTR by 512)
000B10r 2  B0 0C          bcs @FsLoadSecErr
000B12r 2                 ; Increment LBA
000B12r 2  E6 26          inc CF_LBA
000B14r 2  D0 02          bne @FsLoadSecNext
000B16r 2  E6 27          inc CF_LBA + 1
000B18r 2               @FsLoadSecNext:
000B18r 2  FA             plx
000B19r 2  CA             dex
000B1Ar 2  D0 F0          bne @FsLoadSec
000B1Cr 2               @FsLoadOk:
000B1Cr 2  18             clc
000B1Dr 2  60             rts
000B1Er 2               @FsLoadSecErr:
000B1Er 2  FA             plx                           ; Balance stack
000B1Fr 2               @FsLoadErr:
000B1Fr 2  38             sec
000B20r 2  60             rts
000B21r 2               
000B21r 2               ; FsSaveFileImpl — Save data from PROGRAM_START to CF
000B21r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000B21r 2               ;        FS_FILE_SIZE ($034A-$034B) = number of bytes to save
000B21r 2               ; Output: Carry clear = success, Carry set = error (directory full or write error)
000B21r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000B21r 2               FsSaveFileImpl:
000B21r 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000B24r 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000B27r 2  90 03          bcc @FsSaveReadOk
000B29r 2  4C rr rr       jmp @FsSaveErr
000B2Cr 2               @FsSaveReadOk:
000B2Cr 2                 ; Try to find existing file with same name
000B2Cr 2  20 rr rr       jsr FsFindFile
000B2Fr 2  90 08          bcc @FsSaveOverwrite
000B31r 2                 ; Not found — find a free slot
000B31r 2  20 rr rr       jsr FsFindFree
000B34r 2  90 11          bcc @FsSaveAlloc
000B36r 2  4C rr rr       jmp @FsSaveErr                ; Directory full
000B39r 2               @FsSaveOverwrite:
000B39r 2                 ; CF_BUF_PTR already points to the existing entry — clear old flags
000B39r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000B3Br 2  A9 00          lda #$00
000B3Dr 2  91 24          sta (CF_BUF_PTR),y            ; Mark old entry as free
000B3Fr 2                 ; Find a free slot (could be the one we just freed or another)
000B3Fr 2  20 rr rr       jsr FsFindFree
000B42r 2  90 03          bcc @FsSaveAlloc
000B44r 2  4C rr rr       jmp @FsSaveErr
000B47r 2               @FsSaveAlloc:
000B47r 2                 ; Save CF_BUF_PTR (points to free entry from FsFindFree)
000B47r 2  A5 24          lda CF_BUF_PTR
000B49r 2  48             pha
000B4Ar 2  A5 25          lda CF_BUF_PTR + 1
000B4Cr 2  48             pha
000B4Dr 2                 ; Save FS_FILE_SIZE (FsCalcNextSec clobbers it while scanning entries)
000B4Dr 2  AD 4A 03       lda FS_FILE_SIZE
000B50r 2  48             pha
000B51r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B54r 2  48             pha
000B55r 2                 ; Calculate next free sector (clobbers CF_BUF_PTR and FS_FILE_SIZE)
000B55r 2  20 rr rr       jsr FsCalcNextSec
000B58r 2                 ; Restore FS_FILE_SIZE
000B58r 2  68             pla
000B59r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000B5Cr 2  68             pla
000B5Dr 2  8D 4A 03       sta FS_FILE_SIZE
000B60r 2                 ; Restore CF_BUF_PTR to the free directory entry
000B60r 2  68             pla
000B61r 2  85 25          sta CF_BUF_PTR + 1
000B63r 2  68             pla
000B64r 2  85 24          sta CF_BUF_PTR
000B66r 2                 ; Calculate sectors needed
000B66r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B69r 2  4A             lsr a
000B6Ar 2  8D 4C 03       sta FS_SEC_COUNT
000B6Dr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B70r 2  29 01          and #$01
000B72r 2  D0 05          bne @FsSaveRound
000B74r 2  AD 4A 03       lda FS_FILE_SIZE
000B77r 2  F0 03          beq @FsSaveNoRound
000B79r 2               @FsSaveRound:
000B79r 2  EE 4C 03       inc FS_SEC_COUNT
000B7Cr 2               @FsSaveNoRound:
000B7Cr 2                 ; Fill in directory entry at CF_BUF_PTR
000B7Cr 2                 ; Copy filename (11 bytes)
000B7Cr 2  A0 00          ldy #$00
000B7Er 2               @FsSaveCopyName:
000B7Er 2  B9 50 03       lda FS_FNAME_BUF,y
000B81r 2  91 24          sta (CF_BUF_PTR),y
000B83r 2  C8             iny
000B84r 2  C0 0B          cpy #11
000B86r 2  D0 F6          bne @FsSaveCopyName
000B88r 2                 ; Set flags = in use
000B88r 2  A9 01          lda #FS_FLAG_USED
000B8Ar 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
000B8Cr 2                 ; Set start sector
000B8Cr 2  A0 0C          ldy #FS_ENTRY_START
000B8Er 2  AD 4E 03       lda FS_NEXT_SEC
000B91r 2  91 24          sta (CF_BUF_PTR),y
000B93r 2  8D 48 03       sta FS_START_SEC
000B96r 2  C8             iny
000B97r 2  AD 4F 03       lda FS_NEXT_SEC + 1
000B9Ar 2  91 24          sta (CF_BUF_PTR),y
000B9Cr 2  8D 49 03       sta FS_START_SEC + 1
000B9Fr 2                 ; Set file size
000B9Fr 2  A0 0E          ldy #FS_ENTRY_FSIZE
000BA1r 2  AD 4A 03       lda FS_FILE_SIZE
000BA4r 2  91 24          sta (CF_BUF_PTR),y
000BA6r 2  C8             iny
000BA7r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000BAAr 2  91 24          sta (CF_BUF_PTR),y
000BACr 2                 ; Clear reserved bytes
000BACr 2  A0 10          ldy #$10
000BAEr 2  A9 00          lda #$00
000BB0r 2               @FsSaveClearRsv:
000BB0r 2  91 24          sta (CF_BUF_PTR),y
000BB2r 2  C8             iny
000BB3r 2  C0 20          cpy #FS_ENTRY_SIZE
000BB5r 2  D0 F9          bne @FsSaveClearRsv
000BB7r 2                 ; Write updated directory back to CF
000BB7r 2  20 rr rr       jsr FsWriteDir
000BBAr 2  B0 2E          bcs @FsSaveErr
000BBCr 2                 ; Now write file data sectors
000BBCr 2  AD 48 03       lda FS_START_SEC
000BBFr 2  85 26          sta CF_LBA
000BC1r 2  AD 49 03       lda FS_START_SEC + 1
000BC4r 2  85 27          sta CF_LBA + 1
000BC6r 2  64 28          stz CF_LBA + 2
000BC8r 2  64 29          stz CF_LBA + 3
000BCAr 2                 ; Source = PROGRAM_START
000BCAr 2  A9 00          lda #<PROGRAM_START
000BCCr 2  85 24          sta CF_BUF_PTR
000BCEr 2  A9 08          lda #>PROGRAM_START
000BD0r 2  85 25          sta CF_BUF_PTR + 1
000BD2r 2  AE 4C 03       ldx FS_SEC_COUNT
000BD5r 2  F0 10          beq @FsSaveOk                 ; Zero-size file
000BD7r 2               @FsSaveSec:
000BD7r 2  DA             phx
000BD8r 2  20 rr rr       jsr StWriteSector             ; Write sector (advances CF_BUF_PTR by 512)
000BDBr 2  B0 0C          bcs @FsSaveSecErr
000BDDr 2                 ; Increment LBA
000BDDr 2  E6 26          inc CF_LBA
000BDFr 2  D0 02          bne @FsSaveSecNext
000BE1r 2  E6 27          inc CF_LBA + 1
000BE3r 2               @FsSaveSecNext:
000BE3r 2  FA             plx
000BE4r 2  CA             dex
000BE5r 2  D0 F0          bne @FsSaveSec
000BE7r 2               @FsSaveOk:
000BE7r 2  18             clc
000BE8r 2  60             rts
000BE9r 2               @FsSaveSecErr:
000BE9r 2  FA             plx                           ; Balance stack
000BEAr 2               @FsSaveErr:
000BEAr 2  38             sec
000BEBr 2  60             rts
000BECr 2               
000BECr 2               ; FsDeleteFile — Delete a file from the CompactFlash filesystem
000BECr 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000BECr 2               ; Output: Carry clear = success, Carry set = file not found or error
000BECr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000BECr 2               FsDeleteFileImpl:
000BECr 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000BEFr 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000BF2r 2  B0 0F          bcs @FsDelErr
000BF4r 2  20 rr rr       jsr FsFindFile                ; Search for filename
000BF7r 2  B0 0A          bcs @FsDelErr                 ; Not found
000BF9r 2                 ; Clear the flags byte to mark entry as unused
000BF9r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000BFBr 2  A9 00          lda #$00
000BFDr 2  91 24          sta (CF_BUF_PTR),y
000BFFr 2                 ; Write updated directory back to CF
000BFFr 2  20 rr rr       jsr FsWriteDir
000C02r 2                 ; Carry already set/clear from FsWriteDir
000C02r 2  60             rts
000C03r 2               @FsDelErr:
000C03r 2  38             sec
000C04r 2  60             rts
000C05r 2               
000C05r 2               ; === XModem Serial LOAD/SAVE ===
000C05r 2               ; Standard XModem protocol over serial (128-byte blocks, checksum)
000C05r 2               ; Load: receives blocks into memory at caller-supplied XFER_PTR
000C05r 2               ; Save: sends blocks from memory at caller-supplied XFER_PTR / XFER_REMAIN
000C05r 2               
000C05r 2               ; --- Shared XModem Utilities ---
000C05r 2               
000C05r 2               ; XModemGetByte — Read one byte from serial with timeout
000C05r 2               ; Polls SC_STATUS for RDRF directly (bypasses IRQ-driven buffer).
000C05r 2               ; Caller must disable serial RX IRQ before calling.
000C05r 2               ; Output: A = byte received, Carry clear = got byte
000C05r 2               ;         Carry set = timeout
000C05r 2               ; Preserves: X, Y
000C05r 2               XModemGetByte:
000C05r 2  DA             phx
000C06r 2  5A             phy
000C07r 2  A2 00          ldx #$00                      ; Outer loop: 256 passes
000C09r 2               @Outer:
000C09r 2  A0 00          ldy #$00                      ; Inner loop: 256 polls
000C0Br 2               @Inner:
000C0Br 2  AD 01 90       lda SC_STATUS
000C0Er 2  29 08          and #SC_STATUS_RDRF           ; Received byte waiting?
000C10r 2  D0 0A          bne @Got
000C12r 2  88             dey
000C13r 2  D0 F6          bne @Inner
000C15r 2  CA             dex
000C16r 2  D0 F1          bne @Outer
000C18r 2                 ; Timeout
000C18r 2  7A             ply
000C19r 2  FA             plx
000C1Ar 2  38             sec
000C1Br 2  60             rts
000C1Cr 2               @Got:
000C1Cr 2  AD 00 90       lda SC_DATA                   ; Read received byte (clears RDRF)
000C1Fr 2  7A             ply
000C20r 2  FA             plx
000C21r 2  18             clc
000C22r 2  60             rts
000C23r 2               
000C23r 2               ; XModemPurge — Drain all pending bytes from input buffer and hardware
000C23r 2               ; Modifies: A, X
000C23r 2               XModemPurge:
000C23r 2                 ; Drain software input buffer (bytes captured before IRQ was disabled)
000C23r 2               @DrainBuf:
000C23r 2  20 rr rr       jsr BufferSize
000C26r 2  F0 05          beq @DrainHw
000C28r 2  20 rr rr       jsr ReadBuffer
000C2Br 2  80 F6          bra @DrainBuf
000C2Dr 2               @DrainHw:
000C2Dr 2                 ; Drain hardware RDRF
000C2Dr 2  AD 01 90       lda SC_STATUS
000C30r 2  29 08          and #SC_STATUS_RDRF
000C32r 2  F0 05          beq @Done
000C34r 2  AD 00 90       lda SC_DATA                   ; Read and discard
000C37r 2  80 F4          bra @DrainHw
000C39r 2               @Done:
000C39r 2  60             rts
000C3Ar 2               
000C3Ar 2               ; --- XModem Load (Receive) ---
000C3Ar 2               
000C3Ar 2               ; XModemLoadImpl — Receive data via standard XModem protocol
000C3Ar 2               ; Input: XFER_PTR = destination address (set by caller)
000C3Ar 2               ; Output: Carry clear = success, XFER_PTR past last byte written
000C3Ar 2               ;         XFER_REMAIN = total bytes received
000C3Ar 2               ;         Carry set = transfer failed
000C3Ar 2               ; Modifies: Flags, A, X, Y
000C3Ar 2               XModemLoadImpl:
000C3Ar 2                 ; Save and switch IO_MODE to serial
000C3Ar 2  AD 06 03       lda IO_MODE
000C3Dr 2  8D 19 03       sta XFER_IO_SAVE
000C40r 2  A9 01          lda #$01
000C42r 2  8D 06 03       sta IO_MODE
000C45r 2                 ; Disable serial RX IRQ — XModem polls SC_STATUS directly
000C45r 2  A9 0B          lda #$0B                      ; Bit 1 set = RX IRQ disabled, RTSB low, DTR
000C47r 2  8D 02 90       sta SC_CMD
000C4Ar 2                 ; Initialize
000C4Ar 2  A9 01          lda #$01
000C4Cr 2  85 36          sta XMODEM_BLK                ; First expected block number
000C4Er 2  9C 17 03       stz XFER_REMAIN
000C51r 2  9C 18 03       stz XFER_REMAIN + 1
000C54r 2  A9 3C          lda #XMODEM_STARTRETRY
000C56r 2  85 38          sta XMODEM_RETRY
000C58r 2                 ; Print status message so user can start the terminal send
000C58r 2  A2 00          ldx #0
000C5Ar 2               @PrintMsg:
000C5Ar 2  BD rr rr       lda XModemStrReceive,x
000C5Dr 2  F0 06          beq @PrintDone
000C5Fr 2  20 rr rr       jsr Chrout
000C62r 2  E8             inx
000C63r 2  80 F5          bra @PrintMsg
000C65r 2               @PrintDone:
000C65r 2  20 rr rr       jsr XModemPurge               ; Drain stale bytes
000C68r 2                 ; Send initial NAK to start transfer
000C68r 2  A9 15          lda #XMODEM_NAK
000C6Ar 2  20 rr rr       jsr SerialChrout
000C6Dr 2               @RecvWait:
000C6Dr 2  20 rr rr       jsr XModemGetByte
000C70r 2  B0 0E          bcs @RecvTimeout
000C72r 2  C9 01          cmp #XMODEM_SOH
000C74r 2  F0 3E          beq @RecvBlock
000C76r 2  C9 04          cmp #XMODEM_EOT
000C78r 2  F0 11          beq @RecvEOT
000C7Ar 2  C9 18          cmp #XMODEM_CAN
000C7Cr 2  F0 1F          beq @RecvFail
000C7Er 2  80 ED          bra @RecvWait                 ; Ignore unknown bytes
000C80r 2               
000C80r 2               @RecvTimeout:
000C80r 2  C6 38          dec XMODEM_RETRY
000C82r 2  F0 19          beq @RecvFail
000C84r 2  A9 15          lda #XMODEM_NAK
000C86r 2  20 rr rr       jsr SerialChrout
000C89r 2  80 E2          bra @RecvWait
000C8Br 2               
000C8Br 2               @RecvEOT:
000C8Br 2  A9 06          lda #XMODEM_ACK
000C8Dr 2  20 rr rr       jsr SerialChrout
000C90r 2                 ; Re-enable serial RX IRQ
000C90r 2  A9 09          lda #$09
000C92r 2  8D 02 90       sta SC_CMD
000C95r 2  AD 19 03       lda XFER_IO_SAVE
000C98r 2  8D 06 03       sta IO_MODE
000C9Br 2  18             clc                           ; Success
000C9Cr 2  60             rts
000C9Dr 2               
000C9Dr 2               @RecvFail:
000C9Dr 2  A9 18          lda #XMODEM_CAN
000C9Fr 2  20 rr rr       jsr SerialChrout
000CA2r 2  A9 18          lda #XMODEM_CAN
000CA4r 2  20 rr rr       jsr SerialChrout
000CA7r 2                 ; Re-enable serial RX IRQ
000CA7r 2  A9 09          lda #$09
000CA9r 2  8D 02 90       sta SC_CMD
000CACr 2  AD 19 03       lda XFER_IO_SAVE
000CAFr 2  8D 06 03       sta IO_MODE
000CB2r 2  38             sec                           ; Failure
000CB3r 2  60             rts
000CB4r 2               
000CB4r 2               @RecvBlock:
000CB4r 2                 ; Reset retry counter on SOH received
000CB4r 2  A9 0A          lda #XMODEM_MAXRETRY
000CB6r 2  85 38          sta XMODEM_RETRY
000CB8r 2                 ; Read block number
000CB8r 2  20 rr rr       jsr XModemGetByte
000CBBr 2  B0 6B          bcs @RecvNAK
000CBDr 2  85 39          sta XMODEM_RCVBLK
000CBFr 2                 ; Read complement
000CBFr 2  20 rr rr       jsr XModemGetByte
000CC2r 2  B0 64          bcs @RecvNAK
000CC4r 2                 ; Verify block# + complement = $FF
000CC4r 2  18             clc
000CC5r 2  65 39          adc XMODEM_RCVBLK
000CC7r 2  C9 FF          cmp #$FF
000CC9r 2  D0 5D          bne @RecvNAK
000CCBr 2                 ; Receive 128 data bytes into (XFER_PTR), accumulate checksum
000CCBr 2  64 37          stz XMODEM_CHK
000CCDr 2  A0 00          ldy #$00
000CCFr 2               @RecvData:
000CCFr 2  20 rr rr       jsr XModemGetByte             ; A = byte (X/Y preserved)
000CD2r 2  B0 54          bcs @RecvNAK
000CD4r 2  91 2A          sta (XFER_PTR),y              ; Write to destination at offset Y
000CD6r 2  18             clc
000CD7r 2  65 37          adc XMODEM_CHK
000CD9r 2  85 37          sta XMODEM_CHK
000CDBr 2  C8             iny
000CDCr 2  C0 80          cpy #XMODEM_BLKSZ
000CDEr 2  D0 EF          bne @RecvData
000CE0r 2                 ; Read and verify checksum
000CE0r 2  20 rr rr       jsr XModemGetByte
000CE3r 2  B0 43          bcs @RecvNAK
000CE5r 2  C5 37          cmp XMODEM_CHK
000CE7r 2  D0 3F          bne @RecvNAK
000CE9r 2                 ; Verify block number matches expected
000CE9r 2  A5 39          lda XMODEM_RCVBLK
000CEBr 2  C5 36          cmp XMODEM_BLK
000CEDr 2  D0 28          bne @RecvDupChk
000CEFr 2                 ; Good block — advance pointer by 128
000CEFr 2  18             clc
000CF0r 2  A5 2A          lda XFER_PTR
000CF2r 2  69 80          adc #XMODEM_BLKSZ
000CF4r 2  85 2A          sta XFER_PTR
000CF6r 2  A5 2B          lda XFER_PTR + 1
000CF8r 2  69 00          adc #$00
000CFAr 2  85 2B          sta XFER_PTR + 1
000CFCr 2                 ; Update total bytes received
000CFCr 2  18             clc
000CFDr 2  AD 17 03       lda XFER_REMAIN
000D00r 2  69 80          adc #XMODEM_BLKSZ
000D02r 2  8D 17 03       sta XFER_REMAIN
000D05r 2  AD 18 03       lda XFER_REMAIN + 1
000D08r 2  69 00          adc #$00
000D0Ar 2  8D 18 03       sta XFER_REMAIN + 1
000D0Dr 2                 ; Increment expected block number (wraps 255→0)
000D0Dr 2  E6 36          inc XMODEM_BLK
000D0Fr 2                 ; ACK the block
000D0Fr 2  A9 06          lda #XMODEM_ACK
000D11r 2  20 rr rr       jsr SerialChrout
000D14r 2  4C rr rr       jmp @RecvWait
000D17r 2               
000D17r 2               @RecvDupChk:
000D17r 2                 ; Check if this is a retransmit of the previous block (lost ACK)
000D17r 2  A5 36          lda XMODEM_BLK
000D19r 2  38             sec
000D1Ar 2  E9 01          sbc #$01
000D1Cr 2  C5 39          cmp XMODEM_RCVBLK
000D1Er 2  D0 08          bne @RecvNAK                  ; Not a dup — NAK
000D20r 2                 ; Duplicate — re-ACK without advancing
000D20r 2  A9 06          lda #XMODEM_ACK
000D22r 2  20 rr rr       jsr SerialChrout
000D25r 2  4C rr rr       jmp @RecvWait
000D28r 2               
000D28r 2               @RecvNAK:
000D28r 2  20 rr rr       jsr XModemPurge               ; Drain any remaining bytes
000D2Br 2  A9 15          lda #XMODEM_NAK
000D2Dr 2  20 rr rr       jsr SerialChrout
000D30r 2  4C rr rr       jmp @RecvWait
000D33r 2               
000D33r 2               ; --- XModem Save (Send) ---
000D33r 2               
000D33r 2               ; XModemSaveImpl — Send data via standard XModem protocol
000D33r 2               ; Input: XFER_PTR = source address, XFER_REMAIN = byte count (set by caller)
000D33r 2               ; Output: Carry clear = success, Carry set = transfer failed
000D33r 2               ; Modifies: Flags, A, X, Y
000D33r 2               XModemSaveImpl:
000D33r 2                 ; Save and switch IO_MODE to serial
000D33r 2  AD 06 03       lda IO_MODE
000D36r 2  8D 19 03       sta XFER_IO_SAVE
000D39r 2  A9 01          lda #$01
000D3Br 2  8D 06 03       sta IO_MODE
000D3Er 2                 ; Disable serial RX IRQ — XModem polls SC_STATUS directly
000D3Er 2  A9 0B          lda #$0B                      ; Bit 1 set = RX IRQ disabled, RTSB low, DTR
000D40r 2  8D 02 90       sta SC_CMD
000D43r 2                 ; Initialize
000D43r 2  A9 01          lda #$01
000D45r 2  85 36          sta XMODEM_BLK                ; First block number
000D47r 2  A9 3C          lda #XMODEM_STARTRETRY
000D49r 2  85 38          sta XMODEM_RETRY
000D4Br 2                 ; Print status message so user can start the terminal receive
000D4Br 2  A2 00          ldx #0
000D4Dr 2               @PrintMsg:
000D4Dr 2  BD rr rr       lda XModemStrSend,x
000D50r 2  F0 06          beq @PrintDone
000D52r 2  20 rr rr       jsr Chrout
000D55r 2  E8             inx
000D56r 2  80 F5          bra @PrintMsg
000D58r 2               @PrintDone:
000D58r 2  20 rr rr       jsr XModemPurge               ; Drain stale bytes
000D5Br 2                 ; Wait for initial NAK (or 'C' for CRC mode) from receiver
000D5Br 2               @SendWaitNAK:
000D5Br 2  20 rr rr       jsr XModemGetByte
000D5Er 2  B0 11          bcs @SendInitTO
000D60r 2  C9 15          cmp #XMODEM_NAK
000D62r 2  F0 16          beq @SendLoop
000D64r 2  C9 43          cmp #'C'                      ; CRC mode request — treat as NAK (send checksum packets)
000D66r 2  F0 12          beq @SendLoop
000D68r 2  C9 18          cmp #XMODEM_CAN
000D6Ar 2  D0 03          bne :+
000D6Cr 2  4C rr rr       jmp @SendFail
000D6Fr 2  80 EA        : bra @SendWaitNAK
000D71r 2               
000D71r 2               @SendInitTO:
000D71r 2  C6 38          dec XMODEM_RETRY
000D73r 2  D0 03          bne :+
000D75r 2  4C rr rr       jmp @SendFail
000D78r 2  80 E1        : bra @SendWaitNAK
000D7Ar 2               
000D7Ar 2               @SendLoop:
000D7Ar 2                 ; Check if any data remains to send
000D7Ar 2  AD 17 03       lda XFER_REMAIN
000D7Dr 2  0D 18 03       ora XFER_REMAIN + 1
000D80r 2  D0 03          bne :+
000D82r 2  4C rr rr       jmp @SendEOT                  ; All data sent
000D85r 2               :
000D85r 2                 ; Reset retry counter for this block
000D85r 2  A9 0A          lda #XMODEM_MAXRETRY
000D87r 2  85 38          sta XMODEM_RETRY
000D89r 2               @SendBlock:
000D89r 2                 ; Save XFER_PTR and XFER_REMAIN on stack for retry
000D89r 2  A5 2B          lda XFER_PTR + 1
000D8Br 2  48             pha
000D8Cr 2  A5 2A          lda XFER_PTR
000D8Er 2  48             pha
000D8Fr 2  AD 18 03       lda XFER_REMAIN + 1
000D92r 2  48             pha
000D93r 2  AD 17 03       lda XFER_REMAIN
000D96r 2  48             pha
000D97r 2                 ; Send header: SOH, block#, ~block#
000D97r 2  A9 01          lda #XMODEM_SOH
000D99r 2  20 rr rr       jsr SerialChrout
000D9Cr 2  A5 36          lda XMODEM_BLK
000D9Er 2  20 rr rr       jsr SerialChrout
000DA1r 2  49 FF          eor #$FF
000DA3r 2  20 rr rr       jsr SerialChrout
000DA6r 2                 ; Send 128 data bytes, computing checksum
000DA6r 2  64 37          stz XMODEM_CHK
000DA8r 2  A0 00          ldy #$00                      ; Y=0 for (XFER_PTR),y indirect addressing
000DAAr 2  A2 80          ldx #XMODEM_BLKSZ             ; X = byte counter (128 down to 0)
000DACr 2               @SendData:
000DACr 2  AD 17 03       lda XFER_REMAIN
000DAFr 2  0D 18 03       ora XFER_REMAIN + 1
000DB2r 2  F0 20          beq @SendPad                  ; No more real data — pad remainder
000DB4r 2  B1 2A          lda (XFER_PTR),y              ; Read source byte
000DB6r 2  20 rr rr       jsr SerialChrout              ; Send it (A preserved by SerialChrout)
000DB9r 2  18             clc
000DBAr 2  65 37          adc XMODEM_CHK
000DBCr 2  85 37          sta XMODEM_CHK
000DBEr 2                 ; Advance source pointer
000DBEr 2  E6 2A          inc XFER_PTR
000DC0r 2  D0 02          bne @SendNoPg
000DC2r 2  E6 2B          inc XFER_PTR + 1
000DC4r 2               @SendNoPg:
000DC4r 2                 ; Decrement remaining byte count
000DC4r 2  AD 17 03       lda XFER_REMAIN
000DC7r 2  D0 03          bne @SendDecLo
000DC9r 2  CE 18 03       dec XFER_REMAIN + 1
000DCCr 2               @SendDecLo:
000DCCr 2  CE 17 03       dec XFER_REMAIN
000DCFr 2  CA             dex
000DD0r 2  D0 DA          bne @SendData
000DD2r 2  80 0D          bra @SendChk
000DD4r 2               @SendPad:
000DD4r 2                 ; Pad remaining block bytes with SUB ($1A)
000DD4r 2  A9 1A          lda #XMODEM_SUB
000DD6r 2  20 rr rr       jsr SerialChrout
000DD9r 2  18             clc
000DDAr 2  65 37          adc XMODEM_CHK
000DDCr 2  85 37          sta XMODEM_CHK
000DDEr 2  CA             dex
000DDFr 2  D0 F3          bne @SendPad
000DE1r 2               @SendChk:
000DE1r 2                 ; Send checksum byte
000DE1r 2  A5 37          lda XMODEM_CHK
000DE3r 2  20 rr rr       jsr SerialChrout
000DE6r 2                 ; Wait for ACK/NAK response
000DE6r 2  20 rr rr       jsr XModemGetByte
000DE9r 2  B0 08          bcs @SendRetry                ; Timeout — retry
000DEBr 2  C9 06          cmp #XMODEM_ACK
000DEDr 2  F0 19          beq @SendBlockOK
000DEFr 2  C9 18          cmp #XMODEM_CAN
000DF1r 2  F0 1E          beq @SendCancel
000DF3r 2                 ; NAK or unknown — retry
000DF3r 2               @SendRetry:
000DF3r 2                 ; Restore XFER_PTR and XFER_REMAIN from stack
000DF3r 2  68             pla
000DF4r 2  8D 17 03       sta XFER_REMAIN
000DF7r 2  68             pla
000DF8r 2  8D 18 03       sta XFER_REMAIN + 1
000DFBr 2  68             pla
000DFCr 2  85 2A          sta XFER_PTR
000DFEr 2  68             pla
000DFFr 2  85 2B          sta XFER_PTR + 1
000E01r 2  C6 38          dec XMODEM_RETRY
000E03r 2  F0 10          beq @SendFail
000E05r 2  4C rr rr       jmp @SendBlock
000E08r 2               
000E08r 2               @SendBlockOK:
000E08r 2                 ; Discard saved state from stack (4 bytes)
000E08r 2  68             pla
000E09r 2  68             pla
000E0Ar 2  68             pla
000E0Br 2  68             pla
000E0Cr 2                 ; Advance to next block
000E0Cr 2  E6 36          inc XMODEM_BLK
000E0Er 2  4C rr rr       jmp @SendLoop
000E11r 2               
000E11r 2               @SendCancel:
000E11r 2                 ; Discard saved state from stack
000E11r 2  68             pla
000E12r 2  68             pla
000E13r 2  68             pla
000E14r 2  68             pla
000E15r 2               @SendFail:
000E15r 2                 ; Re-enable serial RX IRQ
000E15r 2  A9 09          lda #$09
000E17r 2  8D 02 90       sta SC_CMD
000E1Ar 2  AD 19 03       lda XFER_IO_SAVE
000E1Dr 2  8D 06 03       sta IO_MODE
000E20r 2  38             sec                           ; Failure
000E21r 2  60             rts
000E22r 2               
000E22r 2               @SendEOT:
000E22r 2                 ; All data sent — send EOT
000E22r 2  A9 04          lda #XMODEM_EOT
000E24r 2  20 rr rr       jsr SerialChrout
000E27r 2                 ; Wait for ACK (best-effort; don't fail if timeout)
000E27r 2  20 rr rr       jsr XModemGetByte
000E2Ar 2                 ; Re-enable serial RX IRQ
000E2Ar 2  A9 09          lda #$09
000E2Cr 2  8D 02 90       sta SC_CMD
000E2Fr 2  AD 19 03       lda XFER_IO_SAVE
000E32r 2  8D 06 03       sta IO_MODE
000E35r 2  18             clc                           ; Success
000E36r 2  60             rts
000E37r 2               
000E37r 2               ; XModem status strings
000E37r 2               XModemStrReceive:
000E37r 2  58 4D 4F 44    .byte "XMODEM RX READY", $0D, $0A, 0
000E3Br 2  45 4D 20 52  
000E3Fr 2  58 20 52 45  
000E49r 2               XModemStrSend:
000E49r 2  58 4D 4F 44    .byte "XMODEM TX READY", $0D, $0A, 0
000E4Dr 2  45 4D 20 54  
000E51r 2  58 20 52 45  
000E5Br 2               
000E5Br 2               ; Draw the splash screen
000E5Br 2               ; Uses video output to display centered title and boot menu
000E5Br 2               ; Skips if video card is absent
000E5Br 2               ; Modifies: Flags, A, X, Y
000E5Br 2               Splash:
000E5Br 2  AD 0D 03       lda HW_PRESENT
000E5Er 2  29 80          and #HW_VID
000E60r 2  D0 01          bne @SplashStart
000E62r 2  60             rts                           ; No video — skip
000E63r 2               @SplashStart:
000E63r 2  20 rr rr       jsr VideoClear                ; Clear the video screen
000E66r 2                 ; Position cursor at row 10, col 10 for title
000E66r 2  A2 0A          ldx #10
000E68r 2  A0 0A          ldy #10
000E6Ar 2  20 rr rr       jsr VideoSetCursor
000E6Dr 2  A9 rr          lda #<@SplashTitle
000E6Fr 2  85 02          sta STR_PTR
000E71r 2  A9 rr          lda #>@SplashTitle
000E73r 2  85 03          sta STR_PTR + 1
000E75r 2  20 rr rr       jsr VideoPrintStrImpl
000E78r 2                 ; Position cursor at row 12, col 8 for boot menu (centered: (40-24)/2 = 8)
000E78r 2  A2 08          ldx #8
000E7Ar 2  A0 0C          ldy #12
000E7Cr 2  20 rr rr       jsr VideoSetCursor
000E7Fr 2  A9 rr          lda #<@SplashMenu
000E81r 2  85 02          sta STR_PTR
000E83r 2  A9 rr          lda #>@SplashMenu
000E85r 2  85 03          sta STR_PTR + 1
000E87r 2  20 rr rr       jsr VideoPrintStrImpl
000E8Ar 2  60             rts
000E8Br 2  2D 2D 20 36  @SplashTitle: .asciiz "-- 6502 BIOS v1.0 --"
000E8Fr 2  35 30 32 20  
000E93r 2  42 49 4F 53  
000EA0r 2  45 4E 54 45  @SplashMenu:  .asciiz "ENTER=BASIC  ESC=MONITOR"
000EA4r 2  52 3D 42 41  
000EA8r 2  53 49 43 20  
000EB9r 2               
000EB9r 2               ; NMI Handler
000EB9r 2               Nmi:
000EB9r 2  40             rti
000EBAr 2               
000EBAr 2               ; BRK Handler — saves full CPU state and enters monitor
000EBAr 2               ; On entry from @IrqBrk: A/X/Y are the user's original values (restored by IRQ handler).
000EBAr 2               ; The CPU's hardware push left P/PCL/PCH on the stack.
000EBAr 2               Break:
000EBAr 2  8D 13 03       sta BRK_A                     ; Save user's A register
000EBDr 2  8E 14 03       stx BRK_X                     ; Save user's X register
000EC0r 2  8C 15 03       sty BRK_Y                     ; Save user's Y register
000EC3r 2  BA             tsx                           ; Get current SP
000EC4r 2  8E 16 03       stx BRK_SP                   ; Save SP (points below P/PCL/PCH on stack)
000EC7r 2  68             pla                           ; Pull saved P
000EC8r 2  8D 10 03       sta BRK_P
000ECBr 2  68             pla                           ; Pull saved PCL (PC+2)
000ECCr 2  8D 11 03       sta BRK_PCL
000ECFr 2  68             pla                           ; Pull saved PCH
000ED0r 2  8D 12 03       sta BRK_PCH
000ED3r 2  4C rr rr       jmp MonitorBrkEntry
000ED6r 2               
000ED6r 2               ; IRQ Handler
000ED6r 2               Irq:
000ED6r 2  48             pha
000ED7r 2  5A             phy
000ED8r 2  DA             phx
000ED9r 2  BA             tsx                           ; Get stack pointer to check saved status register
000EDAr 2  BD 04 01       lda $104,x                    ; Load saved P (SP+4: past X, Y, A we pushed)
000EDDr 2  29 10          and #$10                      ; Test B flag — set by BRK, clear by hardware IRQ
000EDFr 2  D0 47          bne @IrqBrk                   ; Branch if this was a BRK instruction
000EE1r 2               @IrqSc:
000EE1r 2  AD 0D 03       lda HW_PRESENT
000EE4r 2  29 10          and #HW_SC
000EE6r 2  F0 19          beq @IrqCheckKB               ; Serial not present — skip
000EE8r 2  AD 01 90       lda SC_STATUS
000EEBr 2  29 80          and #SC_STATUS_IRQ            ; Check if serial data caused the interrupt
000EEDr 2  F0 12          beq @IrqCheckKB               ; If not, check keyboard
000EEFr 2  AD 00 90       lda SC_DATA                   ; Read the data from serial register
000EF2r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000EF5r 2  20 rr rr       jsr BufferSize
000EF8r 2  C9 F0          cmp #$F0                      ; Is the buffer almost full?
000EFAr 2  90 05          bcc @IrqCheckKB               ; If not, also check keyboard
000EFCr 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
000EFEr 2  8D 02 90       sta SC_CMD                    ; Otherwise, signal not ready for receiving (RTSB high)
000F01r 2                                               ; Fall through to check keyboard — always clear VIA flags
000F01r 2               @IrqCheckKB:
000F01r 2  AD 0D 03       lda HW_PRESENT
000F04r 2  29 20          and #HW_GPIO
000F06r 2  F0 1C          beq @IrqExit                  ; GPIO not present — skip
000F08r 2  AD 0D 94       lda GPIO_IFR
000F0Br 2  29 10          and #GPIO_INT_CB1             ; Check if CB1 (matrix keyboard data ready) caused the interrupt
000F0Dr 2  F0 08          beq @IrqCheckPS2              ; If not, check PS/2 keyboard
000F0Fr 2  AD 00 94       lda GPIO_PORTB                ; Read ASCII byte from matrix keyboard (also clears CB1 IFR flag)
000F12r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000F15r 2  80 0D          bra @IrqExit
000F17r 2               @IrqCheckPS2:
000F17r 2  AD 0D 94       lda GPIO_IFR
000F1Ar 2  29 02          and #GPIO_INT_CA1             ; Check if CA1 (PS/2 keyboard data ready) caused the interrupt
000F1Cr 2  F0 06          beq @IrqExit                  ; If not, exit
000F1Er 2  AD 01 94       lda GPIO_PORTA                ; Read ASCII byte from PS/2 keyboard (also clears CA1 IFR flag)
000F21r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000F24r 2               @IrqExit:
000F24r 2  FA             plx
000F25r 2  7A             ply
000F26r 2  68             pla
000F27r 2  40             rti
000F28r 2               @IrqBrk:
000F28r 2  FA             plx                           ; Restore saved registers
000F29r 2  7A             ply
000F2Ar 2  68             pla
000F2Br 2  58             cli                           ; Re-enable interrupts — abandoning interrupt context
000F2Cr 2  6C 02 03       jmp (BRK_PTR)                 ; BRK — dispatch with P/PCL/PCH still on stack
000F2Fr 2               
000F2Fr 2               ; NMI Vector
000F2Fr 2               NmiVec:
000F2Fr 2  6C 04 03       jmp (NMI_PTR)                 ; Indirect jump through NMI pointer to the NMI handler
000F32r 2               
000F32r 2               ; Reset Vector
000F32r 2               ResetVec:
000F32r 2  4C rr rr       jmp Reset                     ; Initialize the system
000F35r 2               
000F35r 2               ; IRQ Vector
000F35r 2               IrqVec:
000F35r 2  6C 00 03       jmp (IRQ_PTR)                 ; Indirect jump through IRQ pointer to the IRQ handler
000F38r 2               
000F38r 1               .segment "CHARS"
000000r 1               .include "Chars.asm"
000000r 2               ; IBM Code Page 437 Character Set
000000r 2               ; 5x8 pixel font in 8x8 area, 8 bytes per character (256 characters total)
000000r 2               ; Each byte represents one horizontal row of pixels (5 pixels left-aligned in 8-bit space)
000000r 2               
000000r 2               CharacterSet:
000000r 2                   ; Character $00 - NULL (blank)
000000r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $00, $00, $00
000004r 2  00 00 00 00  
000008r 2                   ; Character $01 - ☺ (white smiling face)
000008r 2  70 88 D8 88      .byte $70, $88, $D8, $88, $A8, $88, $70, $00
00000Cr 2  A8 88 70 00  
000010r 2                   ; Character $02 - ☻ (black smiling face)
000010r 2  70 F8 A8 F8      .byte $70, $F8, $A8, $F8, $88, $F8, $70, $00
000014r 2  88 F8 70 00  
000018r 2                   ; Character $03 - ♥ (heart)
000018r 2  00 50 F8 F8      .byte $00, $50, $F8, $F8, $F8, $70, $20, $00
00001Cr 2  F8 70 20 00  
000020r 2                   ; Character $04 - ♦ (diamond)
000020r 2  00 20 70 F8      .byte $00, $20, $70, $F8, $F8, $70, $20, $00
000024r 2  F8 70 20 00  
000028r 2                   ; Character $05 - ♣ (club)
000028r 2  20 70 70 20      .byte $20, $70, $70, $20, $F8, $F8, $20, $00
00002Cr 2  F8 F8 20 00  
000030r 2                   ; Character $06 - ♠ (spade)
000030r 2  00 20 70 F8      .byte $00, $20, $70, $F8, $F8, $20, $70, $00
000034r 2  F8 20 70 00  
000038r 2                   ; Character $07 - • (bullet)
000038r 2  00 00 00 30      .byte $00, $00, $00, $30, $30, $00, $00, $00
00003Cr 2  30 00 00 00  
000040r 2                   ; Character $08 - ◘ (inverse bullet)
000040r 2  FC FC FC CC      .byte $FC, $FC, $FC, $CC, $CC, $FC, $FC, $FC
000044r 2  CC FC FC FC  
000048r 2                   ; Character $09 - ○ (white circle)
000048r 2  00 00 78 48      .byte $00, $00, $78, $48, $48, $78, $00, $00
00004Cr 2  48 78 00 00  
000050r 2                   ; Character $0A - ◙ (inverse white circle)
000050r 2  FC FC 84 B4      .byte $FC, $FC, $84, $B4, $B4, $84, $FC, $FC
000054r 2  B4 84 FC FC  
000058r 2                   ; Character $0B - ♂ (male symbol)
000058r 2  00 38 18 68      .byte $00, $38, $18, $68, $90, $90, $60, $00
00005Cr 2  90 90 60 00  
000060r 2                   ; Character $0C - ♀ (female symbol)
000060r 2  70 88 88 70      .byte $70, $88, $88, $70, $20, $70, $20, $00
000064r 2  20 70 20 00  
000068r 2                   ; Character $0D - ♪ (eighth note)
000068r 2  20 30 28 20      .byte $20, $30, $28, $20, $60, $E0, $C0, $00
00006Cr 2  60 E0 C0 00  
000070r 2                   ; Character $0E - ♫ (beamed eighth notes)
000070r 2  18 68 58 68      .byte $18, $68, $58, $68, $58, $D8, $C0, $00
000074r 2  58 D8 C0 00  
000078r 2                   ; Character $0F - ☼ (sun)
000078r 2  00 A8 70 D8      .byte $00, $A8, $70, $D8, $70, $A8, $00, $00
00007Cr 2  70 A8 00 00  
000080r 2                   ; Character $10 - ► (right-pointing triangle)
000080r 2  40 60 70 78      .byte $40, $60, $70, $78, $70, $60, $40, $00
000084r 2  70 60 40 00  
000088r 2                   ; Character $11 - ◄ (left-pointing triangle)
000088r 2  10 30 70 F0      .byte $10, $30, $70, $F0, $70, $30, $10, $00
00008Cr 2  70 30 10 00  
000090r 2                   ; Character $12 - ↕ (up/down arrow)
000090r 2  20 70 F8 20      .byte $20, $70, $F8, $20, $F8, $70, $20, $00
000094r 2  F8 70 20 00  
000098r 2                   ; Character $13 - ‼ (double exclamation mark)
000098r 2  50 50 50 50      .byte $50, $50, $50, $50, $50, $00, $50, $00
00009Cr 2  50 00 50 00  
0000A0r 2                   ; Character $14 - ¶ (pilcrow)
0000A0r 2  78 A8 A8 68      .byte $78, $A8, $A8, $68, $28, $28, $28, $00
0000A4r 2  28 28 28 00  
0000A8r 2                   ; Character $15 - § (section sign)
0000A8r 2  70 88 60 50      .byte $70, $88, $60, $50, $30, $88, $70, $00
0000ACr 2  30 88 70 00  
0000B0r 2                   ; Character $16 - ▬ (black rectangle)
0000B0r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $F0, $F0, $00
0000B4r 2  00 F0 F0 00  
0000B8r 2                   ; Character $17 - ↨ (up/down arrow with base)
0000B8r 2  20 70 F8 20      .byte $20, $70, $F8, $20, $F8, $70, $20, $70
0000BCr 2  F8 70 20 70  
0000C0r 2                   ; Character $18 - ↑ (up arrow)
0000C0r 2  20 70 F8 20      .byte $20, $70, $F8, $20, $20, $20, $20, $00
0000C4r 2  20 20 20 00  
0000C8r 2                   ; Character $19 - ↓ (down arrow)
0000C8r 2  20 20 20 20      .byte $20, $20, $20, $20, $F8, $70, $20, $00
0000CCr 2  F8 70 20 00  
0000D0r 2                   ; Character $1A - → (right arrow)
0000D0r 2  00 20 30 F8      .byte $00, $20, $30, $F8, $30, $20, $00, $00
0000D4r 2  30 20 00 00  
0000D8r 2                   ; Character $1B - ← (left arrow)
0000D8r 2  00 20 60 F8      .byte $00, $20, $60, $F8, $60, $20, $00, $00
0000DCr 2  60 20 00 00  
0000E0r 2                   ; Character $1C - ∟ (right angle)
0000E0r 2  00 00 00 80      .byte $00, $00, $00, $80, $80, $80, $F8, $00
0000E4r 2  80 80 F8 00  
0000E8r 2                   ; Character $1D - ↔ (left/right arrow)
0000E8r 2  00 50 50 F8      .byte $00, $50, $50, $F8, $50, $50, $00, $00
0000ECr 2  50 50 00 00  
0000F0r 2                   ; Character $1E - ▲ (up-pointing triangle)
0000F0r 2  20 20 70 70      .byte $20, $20, $70, $70, $F8, $F8, $00, $00
