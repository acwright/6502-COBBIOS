002AEDr 2               ; Wrappers so the dispatch table can call existing routines that expect
002AEDr 2               ; TXTPTR positioned already.
002AEDr 2               BasCmdPrintW:
002AEDr 2                       ; We were entered via the dispatch trampoline, so TXTPTR is already
002AEDr 2                       ; past the PRINT token (ChrGet was tail-called).  But BasCmdPrint
002AEDr 2                       ; expects to consume the token itself with its first ChrGet; rewind.
002AEDr 2                       ; Easier: BasCmdPrint reads via ChrGet; here ChrGet was called before
002AEDr 2                       ; routine entry, so TXTPTR currently points at first arg.  Just call
002AEDr 2                       ; an internal entry that skips the leading ChrGet.
002AEDr 2  4C rr rr             jmp     BasPrLoop
002AF0r 2               
002AF0r 2               ; ---------------------------------------------------------------------------
002AF0r 2               ; Token-address dispatch table.  Indexed by (token - $80).  Each entry is
002AF0r 2               ; (routine_address - 1) since the dispatcher PHA-pushes it and uses the
002AF0r 2               ; "JMP ChrGet -> RTS" trick to enter.
002AF0r 2               ; ---------------------------------------------------------------------------
002AF0r 2               BasTokenAddrTbl:
002AF0r 2  rr rr                .word   BasCmdEnd-1             ; $80 END
002AF2r 2  rr rr                .word   BasCmdFor-1             ; $81 FOR
002AF4r 2  rr rr                .word   BasCmdNext-1            ; $82 NEXT
002AF6r 2  rr rr                .word   BasCmdData-1            ; $83 DATA
002AF8r 2  rr rr                .word   BasCmdInput-1           ; $84 INPUT
