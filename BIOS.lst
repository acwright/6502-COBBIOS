000800r 2               
000800r 1               .segment "BASIC"
000000r 1               .include "BASIC.asm"
000000r 2               ; =============================================================================
000000r 2               ; BASIC v2.0  —  5-Byte Floating-Point MSBASIC-Compatible Interpreter
000000r 2               ;                for AC6502 Homebrew Computer
000000r 2               ;
000000r 2               ;   ROM Region  :  $C000-$EDFF  (11,776 bytes / $2E00)
000000r 2               ;   Segment     :  BASIC
000000r 2               ;   Entry point :  BasEntry  (first byte of segment = $C000)
000000r 2               ;   Assembler   :  ca65  (cc65 toolchain)
000000r 2               ;   Linker cfg  :  BIOS.cfg
000000r 2               ;
000000r 2               ;   Coding style :  Match the rest of the BIOS project.
000000r 2               ;                   * Routine / data labels : PascalCase  (e.g. BasEntry,
000000r 2               ;                     FAdd, NormalizeFac1, Lbl367F).
000000r 2               ;                   * Constants / equates    : UPPER_SNAKE_CASE
000000r 2               ;                     (e.g. BAS_TXTPTR, TOK_PRINT, ERR_SYNTAX).
000000r 2               ;                   * Local labels           : @camelCase or @PascalCase.
000000r 2               ;                   * Opcodes are lowercase.
000000r 2               ;
000000r 2               ;   Reference source tree:  msbasic-master/  (read-only; NOT linked).
000000r 2               ; =============================================================================
000000r 2               
000000r 2                       .segment "BASIC"
000000r 2               
000000r 2                       .macpack longbranch     ; jeq/jne/etc. used by ported MSBASIC FP code
000000r 3               .macro  jeq     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                       bne     *+5
000000r 3                       jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               beq     Target
000000r 3                       .else
000000r 3                               bne     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jne     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               beq     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bne     Target
000000r 3                       .else
000000r 3                               beq     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jmi     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               bpl     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bmi     Target
000000r 3                       .else
000000r 3                               bpl     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jpl     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               bmi     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bpl     Target
000000r 3                       .else
000000r 3                               bmi     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jcs     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               bcc     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bcs     Target
000000r 3                       .else
000000r 3                               bcc     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jcc     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               bcs     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bcc     Target
000000r 3                       .else
000000r 3                               bcs     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jvs     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               bvc     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bvs     Target
000000r 3                       .else
000000r 3                               bvc     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               .macro  jvc     Target
000000r 3                       .if     .match(Target, 0)
000000r 3                               bvs     *+5
000000r 3                               jmp     Target
000000r 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
000000r 3                               bvc     Target
000000r 3                       .else
000000r 3                               bvs     *+5
000000r 3                               jmp     Target
000000r 3                       .endif
000000r 3               .endmacro
000000r 3               
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   Z E R O - P A G E   E Q U A T E S
000000r 2               ;
000000r 2               ;   $00-$03   Kernal reserved
000000r 2               ;   $04-$23   BASIC primary workspace
000000r 2               ;   $24-$39   Kernal reserved
000000r 2               ;   $3A-$FF   BASIC spill (FP scratch in later phases)
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BAS_TXTPTR      := $04          ; $04-$05  ChrGet / parse pointer
000000r 2               BAS_CURLINE     := $06          ; $06-$07  Pointer to current executing line
000000r 2               BAS_LINNUM      := $08          ; $08-$09  Parsed line number / scratch (= LINNUM)
000000r 2               
000000r 2               ; ----- Floating-point primary block ($0A-$1B, contiguous) -------------------
000000r 2               ; The MSBASIC float code accesses these via ZP,X with one label as the
000000r 2               ; immediate base (e.g. EXPSGN,X / SHIFTSIGNEXT,X / TMPEXP,X), so this entire
000000r 2               ; block MUST stay contiguous in this exact order.  See msbasic-master/
000000r 2               ; zeropage.s for the reference layout.
000000r 2               BAS_TMPEXP      := $0A          ; $0A      TMPEXP / INDX (alias)
000000r 2               BAS_INDX        := $0A          ; $0A      (alias of TMPEXP per msbasic SMALL)
000000r 2               BAS_EXPON       := $0B          ; $0B      EXPON
000000r 2               BAS_LOWTR       := $0C          ; $0C      LOWTR
000000r 2               BAS_EXPSGN      := $0D          ; $0D      EXPSGN  (== FAC-1 scratch byte)
000000r 2               BAS_FAC         := $0E          ; $0E-$12  FAC  (5 bytes)
000000r 2               BAS_FACSIGN     := $13          ; $13      FACSIGN  (== FAC+5)
000000r 2               BAS_SERLEN      := $14          ; $14      SERLEN
000000r 2               BAS_SHIFTSGN    := $15          ; $15      SHIFTSIGNEXT (== ARG-1 scratch)
000000r 2               BAS_ARG         := $16          ; $16-$1A  ARG  (5 bytes)
000000r 2               BAS_ARGSIGN     := $1B          ; $1B      ARGSIGN  (== ARG+5)
000000r 2               ; ----------------------------------------------------------------------------
000000r 2               
000000r 2               BAS_STRNG1      := $1C          ; $1C-$1D  STRNG1 (= SGNCPR; +1 = FACEXTENSION)
000000r 2               BAS_STRNG2      := $1E          ; $1E-$1F  STRNG2
000000r 2               
000000r 2               BAS_INDEX       := $20          ; $20-$21  General index pointer (line walk + msbasic INDEX)
000000r 2               BAS_DEST        := $22          ; $22-$23  Destination pointer (msbasic DEST)
000000r 2               
000000r 2               ; ----- Spill area: $3A-$67 --------------------------------------------------
000000r 2               BAS_TMP1        := $3A          ; $3A-$3B  General-purpose 16-bit pointer
000000r 2               BAS_TMP2        := $3C          ; $3C-$3D  General-purpose 16-bit pointer
000000r 2               BAS_TMP3        := $3E          ; $3E      Spill scratch byte
000000r 2               BAS_VARPNT      := $3F          ; $3F-$40  Current variable address
000000r 2               BAS_QUOTEFLG    := $41          ; $41      Tokenizer quote-state
000000r 2               BAS_DETOKY      := $42          ; $42      Saved Y across detokenize calls
000000r 2               
000000r 2               ; FP-only scratch registers (single bytes unless noted)
000000r 2               BAS_ARGEXT      := $43          ; ARGEXTENSION
000000r 2               BAS_CHARAC      := $44          ; CHARAC (string-quote/end char tracker)
000000r 2               BAS_CPRMASK     := $45          ; CPRMASK (FComp result mask)
000000r 2               BAS_FORPNT      := $46          ; $46-$47  FORPNT
000000r 2               BAS_RESULT      := $48          ; $48-$4C  RESULT  (5-byte FMult accumulator)
000000r 2               BAS_TEMP1       := $4D          ; $4D-$51  TEMP1  (5-byte FP scratch)
000000r 2               BAS_TEMP2       := $52          ; $52-$56  TEMP2  (5-byte FP scratch)
000000r 2               BAS_TEMP3       := $57          ; $57-$5B  TEMP3  (5-byte FP scratch)
000000r 2               BAS_RNDSEED     := $5C          ; $5C-$60  RNDSEED (5-byte FP value)
000000r 2               BAS_KWPTR       := $61          ; $61-$62  Keyword-table walker pointer
000000r 2               
000000r 2               ; ----- Variable / array / string-heap workspace ($63-$85) -----------------
000000r 2               BAS_DIMFLG      := $63          ; DIM-mode flag (nonzero = called from DIM)
000000r 2               BAS_VALTYP      := $64          ; $64-$65  Value type ($00=numeric, $FF=string)
000000r 2               BAS_EOLPNTR     := $66          ; Array scratch: dim count / pointer
000000r 2               BAS_DATAFLG     := $67          ; GetSpa: GC retry flag
000000r 2               BAS_SUBFLG      := $68          ; PtrGet: $40 from GETARYPT, $80 from DEF FN
000000r 2               BAS_INPUTFLG    := $69          ; INPUT/READ flag
000000r 2               BAS_ENDCHR      := $6A          ; StrLt2 secondary terminator
000000r 2               BAS_TEMPPT      := $6B          ; Top-of-temp-string-stack pointer
000000r 2               BAS_LASTPT      := $6C          ; $6C-$6D  Last temp descriptor allocated
000000r 2               BAS_TEMPST      := $6E          ; $6E-$76  Temp descriptor stack (3 * 3 bytes)
000000r 2               BAS_HIGHDS      := $77          ; $77-$78  Bltu dest end+1
000000r 2               BAS_HIGHTR      := $79          ; $79-$7A  Bltu source end+1
000000r 2               BAS_VARNAM      := $7B          ; $7B-$7C  Variable name pair (with type bits)
000000r 2               BAS_DSCPTR      := $7D          ; $7D-$7E  String descriptor pointer
000000r 2               BAS_DSCLEN      := $7F          ; $7F-$80  String descriptor length / GC scratch
000000r 2               BAS_FNCNAM      := $81          ; $81-$82  GC: highest-string descriptor ptr
000000r 2               BAS_Z52         := $83          ; GC scratch byte
000000r 2               BAS_FRESPC      := $84          ; $84-$85  Free-string-space pointer
000000r 2               ; ----------------------------------------------------------------------------
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Symbol aliases used by the inlined MSBASIC FP code.  These let the ported
000000r 2               ; routines keep their original names without a global rename pass.
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               FAC             := BAS_FAC
000000r 2               FAC_LAST        := BAS_FAC + 4
000000r 2               FACSIGN         := BAS_FACSIGN
000000r 2               ARG             := BAS_ARG
000000r 2               ARG_LAST        := BAS_ARG + 4
000000r 2               ARGSIGN         := BAS_ARGSIGN
000000r 2               INDEX           := BAS_INDEX
000000r 2               DEST            := BAS_DEST
000000r 2               STRNG1          := BAS_STRNG1
000000r 2               STRNG2          := BAS_STRNG2
000000r 2               SGNCPR          := BAS_STRNG1            ; aliased as in msbasic zeropage.s
000000r 2               FACEXTENSION    := BAS_STRNG1 + 1        ; aliased as in msbasic zeropage.s
000000r 2               TXTPTR          := BAS_TXTPTR
000000r 2               LINNUM          := BAS_LINNUM
000000r 2               CURLIN          := BAS_CURLIN            ; non-ZP ($0369) — only used by InPrt
000000r 2               VARPNT          := BAS_VARPNT
000000r 2               ARGEXTENSION    := BAS_ARGEXT
000000r 2               EXPON           := BAS_EXPON
000000r 2               EXPSGN          := BAS_EXPSGN
000000r 2               LOWTR           := BAS_LOWTR
000000r 2               INDX            := BAS_INDX
000000r 2               TMPEXP          := BAS_TMPEXP
000000r 2               SERLEN          := BAS_SERLEN
000000r 2               SHIFTSIGNEXT    := BAS_SHIFTSGN
000000r 2               CHARAC          := BAS_CHARAC
000000r 2               CPRMASK         := BAS_CPRMASK
000000r 2               FORPNT          := BAS_FORPNT
000000r 2               RESULT          := BAS_RESULT
000000r 2               RESULT_LAST     := BAS_RESULT + 4
000000r 2               TEMP1           := BAS_TEMP1
000000r 2               TEMP2           := BAS_TEMP2
000000r 2               TEMP3           := BAS_TEMP3
000000r 2               RNDSEED         := BAS_RNDSEED
000000r 2               
000000r 2               ; ----- Aliases used by ported msbasic var/array/string code ----------------
000000r 2               DIMFLG          := BAS_DIMFLG
000000r 2               VALTYP          := BAS_VALTYP
000000r 2               EOLPNTR         := BAS_EOLPNTR
000000r 2               DATAFLG         := BAS_DATAFLG
000000r 2               SUBFLG          := BAS_SUBFLG
000000r 2               INPUTFLG        := BAS_INPUTFLG
000000r 2               ENDCHR          := BAS_ENDCHR
000000r 2               TEMPPT          := BAS_TEMPPT
000000r 2               LASTPT          := BAS_LASTPT
000000r 2               TEMPST          := BAS_TEMPST
000000r 2               HIGHDS          := BAS_HIGHDS
000000r 2               HIGHTR          := BAS_HIGHTR
000000r 2               VARNAM          := BAS_VARNAM
000000r 2               DSCPTR          := BAS_DSCPTR
000000r 2               DSCLEN          := BAS_DSCLEN
000000r 2               FNCNAM          := BAS_FNCNAM
000000r 2               Z52             := BAS_Z52
000000r 2               FRESPC          := BAS_FRESPC
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Constants required by the ported FP code.
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               BYTES_FP        = 5
000000r 2               MANTISSA_BYTES  = 4
000000r 2               MAX_EXPON       = 10
000000r 2               STACK2          = $0100             ; Fout output buffer base (bottom of stack page)
000000r 2               
000000r 2               ; Variable / array layout constants (CONFIG_2 / CBM2-class equivalents).
000000r 2               BYTES_PER_VARIABLE = 7              ; 2 name + 5 value (numeric or descriptor)
000000r 2               BYTES_PER_ELEMENT  = 5              ; numeric array element size
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Aliases for the runtime pointers that live in $035D+ (defined in BIOS.inc).
000000r 2               ; The msbasic var/array/string code references them by these short names.
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               TXTTAB          := BAS_TXTTAB
000000r 2               VARTAB          := BAS_VARTAB
000000r 2               ARYTAB          := BAS_ARYTAB
000000r 2               STREND          := BAS_STREND
000000r 2               FRETOP          := BAS_FRETOP
000000r 2               MEMSIZ          := BAS_MEMSIZ
000000r 2               
000000r 2               ; ERR_OVERFLOW / ERR_DIVZERO already defined below; alias zerodiv:
000000r 2               ERR_ZERODIV     = 6                 ; matches ERR_DIVZERO
000000r 2               
000000r 2               ; Fin parses these as numeric-prefix tokens.  Final token assignments are
000000r 2               ; wired up when the expression evaluator goes live; until then $00 is fine
000000r 2               ; (will not appear in tokenised input).
000000r 2               TOKEN_PLUS      = $00
000000r 2               TOKEN_MINUS     = $00
000000r 2               
000000r 2               ; Rnd(0) source: 6 stable but variable bytes from kernel vars (IRQ_PTR/BRK_PTR
000000r 2               ; etc.).  Just needs to exist — used only when Rnd is called with arg 0.
000000r 2               ENTROPY         = $0300
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   R A M   L A Y O U T   ( B A S I C   W O R K S P A C E )
000000r 2               ;
000000r 2               ;   $0400-$04FF   Input line buffer (256 bytes)
000000r 2               ;   $0500-$05FF   Tokenized line scratch (256 bytes)
000000r 2               ;
000000r 2               ;   GOSUB / FOR stacks live elsewhere; $0500-$05FF doubles as the
000000r 2               ;   tokenization scratch buffer.  $0600-$07FF overlaps FS_SECTOR_BUF and
000000r 2               ;   is left untouched here.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BAS_LINBUF      := $0400        ; Raw input line  (NUL-terminated)
000000r 2               BAS_TOKBUF      := $0500        ; Tokenized scratch buffer (NUL-terminated)
000000r 2               
000000r 2               BAS_LINBUF_MAX  = 200           ; Max accepted input length (bytes)
000000r 2               BAS_TOKBUF_MAX  = 250           ; Max tokenized payload bytes
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   P R O G R A M   S T O R A G E
000000r 2               ;
000000r 2               ;   Lines at $0800+ : [next-lo][next-hi][num-lo][num-hi][tokens...][$00]
000000r 2               ;   End-of-program  : a "next-pointer" of $0000.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BAS_PRG_START   = $0800
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   T O K E N   E Q U A T E S
000000r 2               ;
000000r 2               ;   Tokens are assigned sequentially starting at $80.  KEEP THE TABLE BELOW
000000r 2               ;   IN SYNC WITH THESE EQUATES.  If you reorder or insert keywords, renumber.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               TOK_BASE        = $80
000000r 2               
000000r 2               TOK_END         = $80
000000r 2               TOK_FOR         = $81
000000r 2               TOK_NEXT        = $82
000000r 2               TOK_DATA        = $83
000000r 2               TOK_INPUT       = $84
000000r 2               TOK_DIM         = $85
000000r 2               TOK_READ        = $86
000000r 2               TOK_LET         = $87
000000r 2               TOK_GOTO        = $88
000000r 2               TOK_RUN         = $89
000000r 2               TOK_IF          = $8A
000000r 2               TOK_RESTORE     = $8B
000000r 2               TOK_GOSUB       = $8C
000000r 2               TOK_RETURN      = $8D
000000r 2               TOK_REM         = $8E
000000r 2               TOK_STOP        = $8F
000000r 2               TOK_ON          = $90
000000r 2               TOK_WAIT        = $91
000000r 2               TOK_LOAD        = $92
000000r 2               TOK_SAVE        = $93
000000r 2               TOK_DEF         = $94
000000r 2               TOK_POKE        = $95
000000r 2               TOK_PRINT       = $96
000000r 2               TOK_CONT        = $97
000000r 2               TOK_LIST        = $98
000000r 2               TOK_CLR         = $99
000000r 2               TOK_NEW         = $9A
000000r 2               TOK_TAB         = $9B
000000r 2               TOK_TO          = $9C
000000r 2               TOK_FN          = $9D
000000r 2               TOK_SPC         = $9E
000000r 2               TOK_THEN        = $9F
000000r 2               TOK_NOT         = $A0
000000r 2               TOK_STEP        = $A1
000000r 2               TOK_AND         = $A2
000000r 2               TOK_OR          = $A3
000000r 2               TOK_ELSE        = $A4
000000r 2               TOK_SYS         = $A5
000000r 2               TOK_DIR         = $A6
000000r 2               TOK_DEL         = $A7
000000r 2               TOK_CLS         = $A8
000000r 2               TOK_LOCATE      = $A9
000000r 2               TOK_COLOR       = $AA
000000r 2               TOK_SOUND       = $AB
000000r 2               TOK_VOL         = $AC
000000r 2               TOK_TIME        = $AD
000000r 2               TOK_DATE        = $AE
000000r 2               TOK_SETTIME     = $AF
000000r 2               TOK_SETDATE     = $B0
000000r 2               TOK_NVRAM       = $B1
000000r 2               TOK_PAUSE       = $B2
000000r 2               TOK_BANK        = $B3
000000r 2               TOK_BRK         = $B4
000000r 2               TOK_MEM         = $B5
000000r 2               TOK_SGN         = $B6
000000r 2               TOK_INT         = $B7
000000r 2               TOK_ABS         = $B8
000000r 2               TOK_FRE         = $B9
000000r 2               TOK_POS         = $BA
000000r 2               TOK_SQR         = $BB
000000r 2               TOK_RND         = $BC
000000r 2               TOK_LOG         = $BD
000000r 2               TOK_EXP         = $BE
000000r 2               TOK_COS         = $BF
000000r 2               TOK_SIN         = $C0
000000r 2               TOK_TAN         = $C1
000000r 2               TOK_ATN         = $C2
000000r 2               TOK_PEEK        = $C3
000000r 2               TOK_LEN         = $C4
000000r 2               TOK_STRSTR      = $C5           ; STR$
000000r 2               TOK_VAL         = $C6
000000r 2               TOK_ASC         = $C7
000000r 2               TOK_CHRSTR      = $C8           ; CHR$
000000r 2               TOK_LEFTSTR     = $C9           ; LEFT$
000000r 2               TOK_RIGHTSTR    = $CA           ; RIGHT$
000000r 2               TOK_MIDSTR      = $CB           ; MID$
000000r 2               TOK_JOY         = $CC
000000r 2               TOK_INKEY       = $CD
000000r 2               TOK_HEX         = $CE
000000r 2               TOK_MIN         = $CF
000000r 2               TOK_MAX         = $D0
000000r 2               TOK_FPTEST      = $D1           ; debug only - removed in final cleanup
000000r 2               TOK_VARTEST     = $D2           ; debug only - removed in final cleanup
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   E R R O R   C O D E S
000000r 2               ; =============================================================================
000000r 2               
000000r 2               ERR_SYNTAX      = 0
000000r 2               ERR_OVERFLOW    = 1
000000r 2               ERR_OUTOFMEM    = 2
000000r 2               ERR_UNDEFSTMT   = 3
000000r 2               ERR_BADSUBSCR   = 4
000000r 2               ERR_REDIM       = 5
000000r 2               ERR_DIVZERO     = 6
000000r 2               ERR_ILLDIRECT   = 7
000000r 2               ERR_TYPEMISM    = 8
000000r 2               ERR_LONGSTR     = 9
000000r 2               ERR_FORMULA     = 10
000000r 2               ERR_ILLQUAN     = 11
000000r 2               ERR_RG          = 12            ; RETURN without GOSUB
000000r 2               ERR_NF          = 13            ; NEXT without FOR
000000r 2               ERR_OD          = 14            ; OUT OF DATA
000000r 2               ERR_NODEV       = 15
000000r 2               ERR_CANTCONT    = 16
000000r 2               
000000r 2               ; Aliases used by ported msbasic code.
000000r 2               ERR_BADSUBS     = ERR_BADSUBSCR
000000r 2               ERR_REDIMD      = ERR_REDIM
000000r 2               ERR_FRMCPX      = ERR_FORMULA
000000r 2               ERR_MEMFULL     = ERR_OUTOFMEM
000000r 2               ERR_STRLONG     = ERR_LONGSTR
000000r 2               ERR_ILLQTY      = ERR_ILLQUAN
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   B A S E N T R Y   -   $C000
000000r 2               ;
000000r 2               ;   First byte of segment.  Reached from:
000000r 2               ;     * Kernal cold-boot path
000000r 2               ;     * Monitor 'X' command (warm re-entry)
000000r 2               ;
000000r 2               ;   Cold-vs-warm detection: BAS_WARM holds $A5 once cold init has run.
000000r 2               ;   Re-entry skips banner and goes straight to the OK prompt.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BasEntry:
000000r 2  A2 FF                ldx     #$FF                    ; reset stack on (re)entry
000002r 2  9A                   txs
000003r 2  D8                   cld
000004r 2               
000004r 2  AD 6F 03             lda     BAS_WARM
000007r 2  C9 A5                cmp     #$A5
000009r 2  F0 08                beq     @Warm
00000Br 2               
00000Br 2  20 rr rr             jsr     BasColdInit
00000Er 2  20 rr rr             jsr     BasBanner
000011r 2  80 00                bra     BasReadyLoop
000013r 2               
000013r 2               @Warm:
000013r 2                       ; Warm restart - skip banner; the OK printer will lead with CRLF.
000013r 2               
000013r 2               ; -----------------------------------------------------------------------------
000013r 2               ; BasReadyLoop - REPL: print OK, read a line, dispatch.
000013r 2               ; -----------------------------------------------------------------------------
000013r 2               BasReadyLoop:
000013r 2  20 rr rr             jsr     BasPrintOK
000016r 2               @nextline:
000016r 2  20 rr rr             jsr     BasReadLine             ; fills BAS_LINBUF, NUL-terminated
000019r 2  20 rr rr             jsr     BasProcessLine
00001Cr 2  80 F8                bra     @nextline
00001Er 2               
00001Er 2               ; =============================================================================
00001Er 2               ;   B a s C o l d I n i t
00001Er 2               ; =============================================================================
00001Er 2               ; Initialise BASIC runtime variables.  Called once on first entry.
00001Er 2               ; =============================================================================
00001Er 2               BasColdInit:
00001Er 2                       ; ---------------------------------------------------------------------
00001Er 2                       ; Zero the BASIC-owned zero-page workspace first.  On a cold boot RAM
00001Er 2                       ; holds random power-up values, and the inlined MSBASIC math/parse code
00001Er 2                       ; treats several scratch cells as invariant-zero (e.g. SHIFTSIGNEXT,
00001Er 2                       ; FACEXTENSION, ARGEXTENSION) — they are only written on certain code
00001Er 2                       ; paths and assumed already 0 otherwise.  A random value in any of them
00001Er 2                       ; corrupts results; this is what produced the bogus "84405.0911 BYTES
00001Er 2                       ; FREE" banner on real hardware.  Clearing the whole region up front
00001Er 2                       ; eliminates this entire class of uninitialised-read bugs.  The two
00001Er 2                       ; ranges are the BASIC primary workspace ($04-$23) and the FP / var /
00001Er 2                       ; array / string spill ($3A-$85); $24-$39 is Kernal-reserved and left
00001Er 2                       ; untouched.  Specific non-zero values (CURLIN, TEMPPT, RND seed, etc.)
00001Er 2                       ; are written further down, after this clear.
00001Er 2  A9 00                lda     #0
000020r 2  A2 04                ldx     #BAS_TXTPTR             ; $04..$23
000022r 2               @ClrZpLo:
000022r 2  95 00                sta     ZP,x
000024r 2  E8                   inx
000025r 2  E0 24                cpx     #BAS_DEST+2
000027r 2  D0 F9                bne     @ClrZpLo
000029r 2  A2 3A                ldx     #BAS_TMP1               ; $3A..$85
00002Br 2               @ClrZpHi:
00002Br 2  95 00                sta     ZP,x
00002Dr 2  E8                   inx
00002Er 2  E0 86                cpx     #BAS_FRESPC+2
000030r 2  D0 F9                bne     @ClrZpHi
000032r 2               
000032r 2                       ; TXTTAB / MEMSIZ are constants for our memory map.
000032r 2  A9 00                lda     #<BAS_PRG_START
000034r 2  8D 5D 03             sta     BAS_TXTTAB
000037r 2  A9 08                lda     #>BAS_PRG_START
000039r 2  8D 5E 03             sta     BAS_TXTTAB+1
00003Cr 2               
00003Cr 2  A9 00                lda     #<$8000
00003Er 2  8D 67 03             sta     BAS_MEMSIZ
000041r 2  A9 80                lda     #>$8000
000043r 2  8D 68 03             sta     BAS_MEMSIZ+1
000046r 2               
000046r 2                       ; Auto-detect a pre-loaded program at $0800: if the first word looks
000046r 2                       ; like a valid next-pointer (high byte in [$08, $80)), walk the chain
000046r 2                       ; to compute end-of-program.  Otherwise install an empty program.
000046r 2  AD 01 08             lda     BAS_PRG_START+1         ; high byte of first next-ptr
000049r 2  C9 08                cmp     #$08
00004Br 2  90 43                bcc     @InstallEmpty
00004Dr 2  C9 80                cmp     #$80
00004Fr 2  B0 3F                bcs     @InstallEmpty
000051r 2               
000051r 2                       ; Walk the chain to find the end-marker (next-ptr = 0).
000051r 2  A9 00                lda     #<BAS_PRG_START
000053r 2  85 3A                sta     BAS_TMP1
000055r 2  A9 08                lda     #>BAS_PRG_START
000057r 2  85 3B                sta     BAS_TMP1+1
000059r 2               @WalkLoop:
000059r 2  A0 01                ldy     #1
00005Br 2  B1 3A                lda     (BAS_TMP1),y            ; next-ptr high byte
00005Dr 2  F0 20                beq     @WalkDone               ; 0 → end-marker reached
00005Fr 2  C9 80                cmp     #>$8000                 ; next-ptr must point below MEMSIZ
000061r 2  B0 2D                bcs     @InstallEmpty           ; out of range → not a real program
000063r 2  85 3D                sta     BAS_TMP2+1              ; stash candidate next-ptr
000065r 2  A0 00                ldy     #0
000067r 2  B1 3A                lda     (BAS_TMP1),y            ; next-ptr low byte
000069r 2  85 3C                sta     BAS_TMP2
00006Br 2                       ; Program lines are stored in strictly ascending address order.  If the
00006Br 2                       ; candidate next-ptr does not advance upward, we are walking random
00006Br 2                       ; power-up RAM (which on a cold boot can otherwise loop forever) — bail
00006Br 2                       ; out and install an empty program instead.
00006Br 2  A5 3A                lda     BAS_TMP1
00006Dr 2  C5 3C                cmp     BAS_TMP2
00006Fr 2  A5 3B                lda     BAS_TMP1+1
000071r 2  E5 3D                sbc     BAS_TMP2+1
000073r 2  B0 1B                bcs     @InstallEmpty           ; current >= candidate → invalid chain
000075r 2  A5 3C                lda     BAS_TMP2                ; advance to the next line
000077r 2  85 3A                sta     BAS_TMP1
000079r 2  A5 3D                lda     BAS_TMP2+1
00007Br 2  85 3B                sta     BAS_TMP1+1
00007Dr 2  80 DA                bra     @WalkLoop
00007Fr 2               @WalkDone:
00007Fr 2                       ; BAS_TMP1 points at the end-marker; VARTAB = TMP1 + 2.
00007Fr 2  18                   clc
000080r 2  A5 3A                lda     BAS_TMP1
000082r 2  69 02                adc     #2
000084r 2  8D 5F 03             sta     BAS_VARTAB
000087r 2  A5 3B                lda     BAS_TMP1+1
000089r 2  69 00                adc     #0
00008Br 2  8D 60 03             sta     BAS_VARTAB+1
00008Er 2  80 12                bra     @InitFinalize
000090r 2               
000090r 2               @InstallEmpty:
000090r 2                       ; Write [00][00] end-marker at $0800; VARTAB = $0802.
000090r 2  A9 00                lda     #0
000092r 2  8D 00 08             sta     BAS_PRG_START
000095r 2  8D 01 08             sta     BAS_PRG_START+1
000098r 2  A9 02                lda     #<(BAS_PRG_START+2)
00009Ar 2  8D 5F 03             sta     BAS_VARTAB
00009Dr 2  A9 08                lda     #>(BAS_PRG_START+2)
00009Fr 2  8D 60 03             sta     BAS_VARTAB+1
0000A2r 2               
0000A2r 2               @InitFinalize:
0000A2r 2                       ; ARYTAB = STREND = VARTAB; FRETOP = MEMSIZ.
0000A2r 2  AD 5F 03             lda     BAS_VARTAB
0000A5r 2  8D 61 03             sta     BAS_ARYTAB
0000A8r 2  8D 63 03             sta     BAS_STREND
0000ABr 2  AD 60 03             lda     BAS_VARTAB+1
0000AEr 2  8D 62 03             sta     BAS_ARYTAB+1
0000B1r 2  8D 64 03             sta     BAS_STREND+1
0000B4r 2  AD 67 03             lda     BAS_MEMSIZ
0000B7r 2  8D 65 03             sta     BAS_FRETOP
0000BAr 2  AD 68 03             lda     BAS_MEMSIZ+1
0000BDr 2  8D 66 03             sta     BAS_FRETOP+1
0000C0r 2               
0000C0r 2                       ; CURLIN = $FFFF (direct mode marker).
0000C0r 2  A9 FF                lda     #$FF
0000C2r 2  8D 69 03             sta     BAS_CURLIN
0000C5r 2  8D 6A 03             sta     BAS_CURLIN+1
0000C8r 2               
0000C8r 2                       ; Clear CONT state and pending-key.
0000C8r 2  9C 6B 03             stz     BAS_OLDLIN
0000CBr 2  9C 6C 03             stz     BAS_OLDLIN+1
0000CEr 2  9C 6D 03             stz     BAS_OLDTEXT
0000D1r 2  9C 6E 03             stz     BAS_OLDTEXT+1
0000D4r 2  9C 1A 03             stz     BAS_DATAPTR
0000D7r 2  9C 1B 03             stz     BAS_DATAPTR+1
0000DAr 2  9C 1C 03             stz     BAS_STOPLINE
0000DDr 2  9C 1D 03             stz     BAS_STOPLINE+1
0000E0r 2  9C 1E 03             stz     BAS_STOPTXT
0000E3r 2  9C 1F 03             stz     BAS_STOPTXT+1
0000E6r 2  9C 0E 03             stz     BAS_PENDKEY
0000E9r 2  9C 70 03             stz     BAS_POSX                ; PRINT column counter (non-ZP)
0000ECr 2               
0000ECr 2                       ; ZP runtime flags (QUOTEFLG, DIMFLG, VALTYP, DATAFLG, SUBFLG,
0000ECr 2                       ; INPUTFLG, SHIFTSIGNEXT, ...) are already zeroed by the cold-init
0000ECr 2                       ; clear loop above; only non-zero / non-ZP state is set here.
0000ECr 2               
0000ECr 2                       ; Temp-string descriptor stack: TEMPPT = TEMPST.
0000ECr 2  A9 6E                lda     #BAS_TEMPST
0000EEr 2  85 6B                sta     BAS_TEMPPT
0000F0r 2               
0000F0r 2                       ; Initialise Rnd seed from the embedded constant.
0000F0r 2  A2 04                ldx     #4
0000F2r 2               @SeedCopy:
0000F2r 2  BD rr rr             lda     RndSeedInit,x
0000F5r 2  95 5C                sta     RNDSEED,x
0000F7r 2  CA                   dex
0000F8r 2  10 F8                bpl     @SeedCopy
0000FAr 2               
0000FAr 2                       ; Mark warm-start magic.
0000FAr 2  A9 A5                lda     #$A5
0000FCr 2  8D 6F 03             sta     BAS_WARM
0000FFr 2  60                   rts
000100r 2               
000100r 2               ; =============================================================================
000100r 2               ;   B a s B a n n e r
000100r 2               ; =============================================================================
000100r 2               BasBanner:
000100r 2  A9 rr                lda     #<MsgBanner
000102r 2  A0 rr                ldy     #>MsgBanner
000104r 2  20 rr rr             jsr     BasPrintStr
000107r 2                       ; Print "<n> BYTES FREE" line.
000107r 2  38                   sec
000108r 2  AD 67 03             lda     BAS_MEMSIZ
00010Br 2  ED 5F 03             sbc     BAS_VARTAB
00010Er 2  A8                   tay
00010Fr 2  AD 68 03             lda     BAS_MEMSIZ+1
000112r 2  ED 60 03             sbc     BAS_VARTAB+1
000115r 2  20 rr rr             jsr     GivAyf
000118r 2                       ; Print the byte count left-aligned: Fout always emits a leading
000118r 2                       ; sign character (' ' for positive, '-' for negative).  For the
000118r 2                       ; banner we skip that leading space so the number lines up with
000118r 2                       ; the left edge of the title above it.
000118r 2  20 rr rr             jsr     Fout                    ; (Y,A) -> NUL-terminated buffer
00011Br 2  85 20                sta     INDEX
00011Dr 2  84 21                sty     INDEX+1
00011Fr 2  A0 00                ldy     #0
000121r 2  B1 20                lda     (INDEX),y
000123r 2  C9 20                cmp     #' '
000125r 2  D0 01                bne     @bnLoop
000127r 2  C8                   iny                             ; skip the positive-sign space
000128r 2               @bnLoop:
000128r 2  B1 20                lda     (INDEX),y
00012Ar 2  F0 06                beq     @bnDone
00012Cr 2  20 rr rr             jsr     PrintCh
00012Fr 2  C8                   iny
000130r 2  D0 F6                bne     @bnLoop
000132r 2               @bnDone:
000132r 2  A9 rr                lda     #<MsgBytesFreeNL
000134r 2  A0 rr                ldy     #>MsgBytesFreeNL
000136r 2  4C rr rr             jmp     BasPrintStr
000139r 2               
000139r 2               ; =============================================================================
000139r 2               ;   B a s P r i n t O K
000139r 2               ; =============================================================================
000139r 2               BasPrintOK:
000139r 2  20 rr rr             jsr     BasPrintCRLF
00013Cr 2  A9 rr                lda     #<MsgOK
00013Er 2  A0 rr                ldy     #>MsgOK
000140r 2  4C rr rr             jmp     BasPrintStr
000143r 2               
000143r 2               ; =============================================================================
000143r 2               ;   B a s P r i n t S t r
000143r 2               ; =============================================================================
000143r 2               ; Print a NUL-terminated string via Chrout.
000143r 2               ; Input  : A=lo, Y=hi  (string address)
000143r 2               ; Clobbers : A, Y  (X preserved)
000143r 2               ; =============================================================================
000143r 2               BasPrintStr:
000143r 2  85 3A                sta     BAS_TMP1
000145r 2  84 3B                sty     BAS_TMP1+1
000147r 2  A0 00                ldy     #0
000149r 2               @Loop:
000149r 2  B1 3A                lda     (BAS_TMP1),y
00014Br 2  F0 06                beq     @Done
00014Dr 2  20 rr rr             jsr     Chrout
000150r 2  C8                   iny
000151r 2  D0 F6                bne     @Loop
000153r 2               @Done:
000153r 2  60                   rts
000154r 2               
000154r 2               ; =============================================================================
000154r 2               ;   B a s P r i n t C R L F
000154r 2               ; =============================================================================
000154r 2               BasPrintCRLF:
000154r 2  A9 0D                lda     #$0D
000156r 2  20 rr rr             jsr     Chrout
000159r 2  A9 0A                lda     #$0A
00015Br 2  4C rr rr             jmp     Chrout
00015Er 2               
00015Er 2               ; =============================================================================
00015Er 2               ;   B a s R e a d L i n e
00015Er 2               ; =============================================================================
00015Er 2               ; Read a line of input into BAS_LINBUF, NUL-terminated.  Echoes characters
00015Er 2               ; manually (does not use Chrin's auto-echo).  Supports CR, BS ($08), ESC
00015Er 2               ; ($1B = cancel and restart line).  Caps stored length at BAS_LINBUF_MAX
00015Er 2               ; (extra characters are silently dropped from the buffer but still echoed
00015Er 2               ; -- acceptable truncation behavior).
00015Er 2               ;
00015Er 2               ; Output : BAS_LINBUF holds the raw line, terminated with $00.
00015Er 2               ; =============================================================================
00015Er 2               BasReadLine:
00015Er 2  A0 00                ldy     #0
000160r 2               @Loop:
000160r 2  20 rr rr             jsr     BasReadKey              ; A = next key, blocking
000163r 2  C9 0D                cmp     #$0D
000165r 2  F0 30                beq     @Done
000167r 2  C9 08                cmp     #$08
000169r 2  F0 19                beq     @Backspace
00016Br 2  C9 1B                cmp     #$1B
00016Dr 2  F0 21                beq     @Cancel
00016Fr 2  C9 20                cmp     #$20                    ; reject control codes below space
000171r 2  90 ED                bcc     @Loop
000173r 2  C9 7F                cmp     #$7F                    ; reject DEL and 8-bit
000175r 2  B0 E9                bcs     @Loop
000177r 2                       ; Printable - store and echo.
000177r 2  C0 C8                cpy     #BAS_LINBUF_MAX
000179r 2  B0 E5                bcs     @Loop                   ; full - drop quietly
00017Br 2  99 00 04             sta     BAS_LINBUF,y
00017Er 2  C8                   iny
00017Fr 2  20 rr rr             jsr     Chrout
000182r 2  80 DC                bra     @Loop
000184r 2               
000184r 2               @Backspace:
000184r 2  C0 00                cpy     #0
000186r 2  F0 D8                beq     @Loop                   ; nothing to erase
000188r 2  88                   dey
000189r 2  A9 08                lda     #$08                    ; video / serial driver erases on BS
00018Br 2  20 rr rr             jsr     Chrout
00018Er 2  80 D0                bra     @Loop
000190r 2               
000190r 2               @Cancel:
000190r 2  20 rr rr             jsr     BasPrintCRLF
000193r 2  A0 00                ldy     #0
000195r 2  80 C9                bra     @Loop
000197r 2               
000197r 2               @Done:
000197r 2  A9 00                lda     #0
000199r 2  99 00 04             sta     BAS_LINBUF,y
00019Cr 2  20 rr rr             jsr     BasPrintCRLF
00019Fr 2  60                   rts
0001A0r 2               
0001A0r 2               ; =============================================================================
0001A0r 2               ;   B a s R e a d K e y
0001A0r 2               ; =============================================================================
0001A0r 2               ; Spin until a key is available in the input buffer; return it in A
0001A0r 2               ; (no echo).
0001A0r 2               ; =============================================================================
0001A0r 2               BasReadKey:
0001A0r 2               @Wait:
0001A0r 2  20 rr rr             jsr     BufferSize
0001A3r 2  F0 FB                beq     @Wait
0001A5r 2  4C rr rr             jmp     ReadBuffer              ; tail-call: returns A=byte
0001A8r 2               
0001A8r 2               ; =============================================================================
0001A8r 2               ;   B a s P r o c e s s L i n e
0001A8r 2               ; =============================================================================
0001A8r 2               ; Triage BAS_LINBUF after reading: empty, numbered (insert/replace/delete),
0001A8r 2               ; or immediate command.
0001A8r 2               ; =============================================================================
0001A8r 2               BasProcessLine:
0001A8r 2  A2 00                ldx     #0
0001AAr 2               @SkipSpaces:
0001AAr 2  BD 00 04             lda     BAS_LINBUF,x
0001ADr 2  F0 07                beq     @Empty
0001AFr 2  C9 20                cmp     #' '
0001B1r 2  D0 04                bne     @HasContent
0001B3r 2  E8                   inx
0001B4r 2  80 F4                bra     @SkipSpaces
0001B6r 2               @Empty:
0001B6r 2  60                   rts                             ; nothing to do; caller will reprompt
0001B7r 2               
0001B7r 2               @HasContent:
0001B7r 2  C9 30                cmp     #'0'
0001B9r 2  90 1A                bcc     @Immediate
0001BBr 2  C9 3A                cmp     #'9'+1
0001BDr 2  B0 16                bcs     @Immediate
0001BFr 2               
0001BFr 2               ; --- Numbered line -----------------------------------------------------------
0001BFr 2  20 rr rr             jsr     BasParseLineNum         ; consumes digits at BAS_LINBUF+X
0001C2r 2                       ; X now points to first non-digit; allow exactly one optional space.
0001C2r 2  BD 00 04             lda     BAS_LINBUF,x
0001C5r 2  C9 20                cmp     #' '
0001C7r 2  D0 01                bne     @TokenizeRest
0001C9r 2  E8                   inx
0001CAr 2               @TokenizeRest:
0001CAr 2  20 rr rr             jsr     BasCrunch               ; tokenize from BAS_LINBUF+X to BAS_TOKBUF
0001CDr 2  B0 03                bcs     @StoreLine              ; carry set = success
0001CFr 2  4C rr rr             jmp     BasErrSyntax
0001D2r 2               
0001D2r 2               @StoreLine:
0001D2r 2  4C rr rr             jmp     BasStoreLine            ; insert/replace/delete by line number
0001D5r 2               
0001D5r 2               @Immediate:
0001D5r 2                       ; Immediate (no line number) - tokenize whole line and dispatch.
0001D5r 2  A2 00                ldx     #0
0001D7r 2  20 rr rr             jsr     BasCrunch
0001DAr 2  B0 03                bcs     @ImmDispatch
0001DCr 2  4C rr rr             jmp     BasErrSyntax
0001DFr 2               @ImmDispatch:
0001DFr 2  20 rr rr             jsr     BasDispatchImmediate
0001E2r 2  4C rr rr             jmp     BasPrintOK              ; MS BASIC: OK only after immediate
0001E5r 2               
0001E5r 2               ; =============================================================================
0001E5r 2               ;   B a s P a r s e L i n e N u m
0001E5r 2               ; =============================================================================
0001E5r 2               ; Parse decimal digits at BAS_LINBUF,X into BAS_LINNUM (16-bit).
0001E5r 2               ; X advances past the digits.  Saturates at $FFFF on overflow.
0001E5r 2               ; =============================================================================
0001E5r 2               BasParseLineNum:
0001E5r 2  64 08                stz     BAS_LINNUM
0001E7r 2  64 09                stz     BAS_LINNUM+1
0001E9r 2               @Loop:
0001E9r 2  BD 00 04             lda     BAS_LINBUF,x
0001ECr 2  C9 30                cmp     #'0'
0001EEr 2  90 35                bcc     @Done
0001F0r 2  C9 3A                cmp     #'9'+1
0001F2r 2  B0 31                bcs     @Done
0001F4r 2                       ; Multiply LINNUM by 10.
0001F4r 2  48                   pha
0001F5r 2  06 08                asl     BAS_LINNUM              ; *2
0001F7r 2  26 09                rol     BAS_LINNUM+1
0001F9r 2  A5 08                lda     BAS_LINNUM
0001FBr 2  85 3A                sta     BAS_TMP1
0001FDr 2  A5 09                lda     BAS_LINNUM+1
0001FFr 2  85 3B                sta     BAS_TMP1+1
000201r 2  06 08                asl     BAS_LINNUM              ; *4
000203r 2  26 09                rol     BAS_LINNUM+1
000205r 2  06 08                asl     BAS_LINNUM              ; *8
000207r 2  26 09                rol     BAS_LINNUM+1
000209r 2  18                   clc                             ; *8 + *2 = *10
00020Ar 2  A5 08                lda     BAS_LINNUM
00020Cr 2  65 3A                adc     BAS_TMP1
00020Er 2  85 08                sta     BAS_LINNUM
000210r 2  A5 09                lda     BAS_LINNUM+1
000212r 2  65 3B                adc     BAS_TMP1+1
000214r 2  85 09                sta     BAS_LINNUM+1
000216r 2                       ; Add digit value.
000216r 2  68                   pla
000217r 2  29 0F                and     #$0F
000219r 2  18                   clc
00021Ar 2  65 08                adc     BAS_LINNUM
00021Cr 2  85 08                sta     BAS_LINNUM
00021Er 2  90 02                bcc     @NoCarry
000220r 2  E6 09                inc     BAS_LINNUM+1
000222r 2               @NoCarry:
000222r 2  E8                   inx
000223r 2  80 C4                bra     @Loop
000225r 2               @Done:
000225r 2  60                   rts
000226r 2               
000226r 2               ; =============================================================================
000226r 2               ;   B a s C r u n c h
000226r 2               ; =============================================================================
000226r 2               ; Tokenize BAS_LINBUF starting at offset X into BAS_TOKBUF.
000226r 2               ;
000226r 2               ; Tokenization rules:
000226r 2               ;   - Outside quoted strings, lowercase a-z are folded to uppercase.
000226r 2               ;   - Outside quoted strings, alphabetic runs are matched against the
000226r 2               ;     keyword table; on a match the token byte is emitted in place of the
000226r 2               ;     keyword characters.
000226r 2               ;   - Inside double quotes, characters are copied verbatim until the
000226r 2               ;     closing quote (or end of line).
000226r 2               ;   - After a REM token, the rest of the line is copied verbatim.
000226r 2               ;   - Disallowed punctuation (@, &, [, ], {, }, |, \, `, ~) raises
000226r 2               ;     ?SYNTAX ERROR via carry-clear return.
000226r 2               ;
000226r 2               ; Output : BAS_TOKBUF holds the tokenized line, NUL-terminated.
000226r 2               ; Returns: carry SET on success, carry CLEAR on syntax error.
000226r 2               ; Clobbers: A, X, Y, BAS_TMP1/TMP2/TMP3.
000226r 2               ; =============================================================================
000226r 2               BasCrunch:
000226r 2                       ; X = src index, Y = dst index
000226r 2  A0 00                ldy     #0
000228r 2  64 41                stz     BAS_QUOTEFLG
00022Ar 2               @Scan:
00022Ar 2  C0 FA                cpy     #BAS_TOKBUF_MAX
00022Cr 2  B0 0A                bcs     @Overflow
00022Er 2  BD 00 04             lda     BAS_LINBUF,x
000231r 2  D0 07                bne     @NotEnd
000233r 2                       ; End of input.
000233r 2  99 00 05             sta     BAS_TOKBUF,y            ; A=0
000236r 2  38                   sec
000237r 2  60                   rts
000238r 2               @Overflow:
000238r 2                       ; Tokenized line too long; treat as syntax error.
000238r 2  18                   clc
000239r 2  60                   rts
00023Ar 2               
00023Ar 2               @NotEnd:
00023Ar 2  C9 22                cmp     #'"'
00023Cr 2  F0 56                beq     @Quote
00023Er 2                       ; Lowercase to uppercase outside quotes.
00023Er 2  C9 61                cmp     #'a'
000240r 2  90 06                bcc     @CheckAlpha
000242r 2  C9 7B                cmp     #'z'+1
000244r 2  B0 02                bcs     @CheckAlpha
000246r 2  29 DF                and     #$DF
000248r 2               @CheckAlpha:
000248r 2                       ; Alphabetic? Try keyword match.
000248r 2  C9 41                cmp     #'A'
00024Ar 2  90 3A                bcc     @NotAlpha
00024Cr 2  C9 5B                cmp     #'Z'+1
00024Er 2  B0 36                bcs     @NotAlpha
000250r 2                       ; Alpha - try matching a keyword starting at BAS_LINBUF,x.
000250r 2  20 rr rr             jsr     BasMatchKeyword         ; returns C set (A=token, X advanced) or C clear
000253r 2  90 1D                bcc     @CopyAlpha
000255r 2                       ; Match: emit token byte.
000255r 2  99 00 05             sta     BAS_TOKBUF,y
000258r 2  C8                   iny
000259r 2  C9 8E                cmp     #TOK_REM
00025Br 2  D0 CD                bne     @Scan
00025Dr 2                       ; After REM: copy the remainder verbatim.
00025Dr 2               @RemCopy:
00025Dr 2  C0 FA                cpy     #BAS_TOKBUF_MAX
00025Fr 2  B0 D7                bcs     @Overflow
000261r 2  BD 00 04             lda     BAS_LINBUF,x
000264r 2  F0 07                beq     @TermAndExit
000266r 2  99 00 05             sta     BAS_TOKBUF,y
000269r 2  C8                   iny
00026Ar 2  E8                   inx
00026Br 2  80 F0                bra     @RemCopy
00026Dr 2               @TermAndExit:
00026Dr 2  99 00 05             sta     BAS_TOKBUF,y            ; A=0
000270r 2  38                   sec
000271r 2  60                   rts
000272r 2               
000272r 2               @CopyAlpha:
000272r 2                       ; No keyword match - copy a single alpha char (re-uppercase here, since
000272r 2                       ; BasMatchKeyword returns the original LINBUF byte).
000272r 2  BD 00 04             lda     BAS_LINBUF,x
000275r 2  C9 61                cmp     #'a'
000277r 2  90 06                bcc     @CASto
000279r 2  C9 7B                cmp     #'z'+1
00027Br 2  B0 02                bcs     @CASto
00027Dr 2  29 DF                and     #$DF
00027Fr 2               @CASto:
00027Fr 2  99 00 05             sta     BAS_TOKBUF,y
000282r 2  C8                   iny
000283r 2  E8                   inx
000284r 2  80 A4                bra     @Scan
000286r 2               
000286r 2               @NotAlpha:
000286r 2                       ; Punctuation / digit / space.  Validate against the disallowed set.
000286r 2  20 rr rr             jsr     BasValidPunct
000289r 2  90 07                bcc     @SyntaxFail
00028Br 2  99 00 05             sta     BAS_TOKBUF,y
00028Er 2  C8                   iny
00028Fr 2  E8                   inx
000290r 2  80 98                bra     @Scan
000292r 2               @SyntaxFail:
000292r 2  18                   clc
000293r 2  60                   rts
000294r 2               
000294r 2               @Quote:
000294r 2                       ; Copy opening quote, then everything up to closing quote (or end).
000294r 2  99 00 05             sta     BAS_TOKBUF,y
000297r 2  C8                   iny
000298r 2  E8                   inx
000299r 2               @QuoteLoop:
000299r 2  C0 FA                cpy     #BAS_TOKBUF_MAX
00029Br 2  B0 9B                bcs     @Overflow
00029Dr 2  BD 00 04             lda     BAS_LINBUF,x
0002A0r 2  F0 CB                beq     @TermAndExit
0002A2r 2  99 00 05             sta     BAS_TOKBUF,y
0002A5r 2  C8                   iny
0002A6r 2  E8                   inx
0002A7r 2  C9 22                cmp     #'"'
0002A9r 2  D0 EE                bne     @QuoteLoop
0002ABr 2  4C rr rr             jmp     @Scan
0002AEr 2               
0002AEr 2               ; =============================================================================
0002AEr 2               ;   B a s V a l i d P u n c t
0002AEr 2               ; =============================================================================
0002AEr 2               ; Verify A is an acceptable non-keyword character.
0002AEr 2               ; Carry SET = OK, carry CLEAR = illegal.
0002AEr 2               ; Allowed: anything in $20-$7E EXCEPT @, &, [, ], {, }, |, \, `, ~.
0002AEr 2               ; =============================================================================
0002AEr 2               BasValidPunct:
0002AEr 2  C9 40                cmp     #'@'
0002B0r 2  F0 26                beq     @Bad
0002B2r 2  C9 26                cmp     #'&'
0002B4r 2  F0 22                beq     @Bad
0002B6r 2  C9 5B                cmp     #'['
0002B8r 2  F0 1E                beq     @Bad
0002BAr 2  C9 5D                cmp     #']'
0002BCr 2  F0 1A                beq     @Bad
0002BEr 2  C9 7B                cmp     #'{'
0002C0r 2  F0 16                beq     @Bad
0002C2r 2  C9 7D                cmp     #'}'
0002C4r 2  F0 12                beq     @Bad
0002C6r 2  C9 7C                cmp     #'|'
0002C8r 2  F0 0E                beq     @Bad
0002CAr 2  C9 5C                cmp     #'\'
0002CCr 2  F0 0A                beq     @Bad
0002CEr 2  C9 60                cmp     #'`'
0002D0r 2  F0 06                beq     @Bad
0002D2r 2  C9 7E                cmp     #'~'
0002D4r 2  F0 02                beq     @Bad
0002D6r 2  38                   sec
0002D7r 2  60                   rts
0002D8r 2               @Bad:
0002D8r 2  18                   clc
0002D9r 2  60                   rts
0002DAr 2               
0002DAr 2               ; =============================================================================
0002DAr 2               ;   B a s M a t c h K e y w o r d
0002DAr 2               ; =============================================================================
0002DAr 2               ; Try to match a keyword from KeywordTbl starting at BAS_LINBUF,X.
0002DAr 2               ;
0002DAr 2               ; On match  : carry SET, A = token byte, X advanced past the matched
0002DAr 2               ;             keyword characters in BAS_LINBUF.
0002DAr 2               ; On miss   : carry CLEAR, X unchanged, A = original character at LINBUF,X.
0002DAr 2               ;
0002DAr 2               ; Match algorithm:
0002DAr 2               ;   - Walk KeywordTbl, comparing characters (folding LINBUF lowercase to
0002DAr 2               ;     uppercase) to each keyword in turn.  A keyword's last byte has bit 7
0002DAr 2               ;     set; the byte after the table's final keyword is $00.
0002DAr 2               ;   - Token value = TOK_BASE + (index of keyword in table).
0002DAr 2               ; =============================================================================
0002DAr 2               BasMatchKeyword:
0002DAr 2                       ; Save initial X for rollback on miss; preserve caller's Y (BasCrunch
0002DAr 2                       ; uses Y as the TOKBUF destination index).
0002DAr 2  86 3E                stx     BAS_TMP3
0002DCr 2  5A                   phy
0002DDr 2                       ; Walk the keyword table via a 16-bit ZP pointer (BAS_KWPTR), since
0002DDr 2                       ; the table is larger than 256 bytes.  Y is held at 0 throughout and
0002DDr 2                       ; we advance BAS_KWPTR byte-by-byte instead of relying on Y.
0002DDr 2  A9 rr                lda     #<KeywordTbl
0002DFr 2  85 61                sta     BAS_KWPTR
0002E1r 2  A9 rr                lda     #>KeywordTbl
0002E3r 2  85 62                sta     BAS_KWPTR+1
0002E5r 2  A9 80                lda     #TOK_BASE
0002E7r 2  85 3A                sta     BAS_TMP1                ; current candidate token
0002E9r 2  A0 00                ldy     #0
0002EBr 2               @KeywordLoop:
0002EBr 2                       ; Restore X to start of input keyword.
0002EBr 2  A6 3E                ldx     BAS_TMP3
0002EDr 2               @CharLoop:
0002EDr 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
0002EFr 2  F0 3B                beq     @NoMatch                ; reached table terminator
0002F1r 2  48                   pha
0002F2r 2  29 7F                and     #$7F
0002F4r 2  85 3C                sta     BAS_TMP2                ; expected char (uppercase)
0002F6r 2                       ; Read input char and uppercase it.
0002F6r 2  BD 00 04             lda     BAS_LINBUF,x
0002F9r 2  C9 61                cmp     #'a'
0002FBr 2  90 06                bcc     @InpCmp
0002FDr 2  C9 7B                cmp     #'z'+1
0002FFr 2  B0 02                bcs     @InpCmp
000301r 2  29 DF                and     #$DF
000303r 2               @InpCmp:
000303r 2  C5 3C                cmp     BAS_TMP2
000305r 2  D0 0C                bne     @CharMismatch
000307r 2  68                   pla                             ; restore raw table byte
000308r 2                       ; Match - is this the last char of the keyword?
000308r 2  30 1C                bmi     @WholeMatch             ; bit 7 set -> full keyword matched
00030Ar 2                       ; Advance both pointers and continue.
00030Ar 2  E6 61                inc     BAS_KWPTR
00030Cr 2  D0 02                bne     @CharNoCarry
00030Er 2  E6 62                inc     BAS_KWPTR+1
000310r 2               @CharNoCarry:
000310r 2  E8                   inx
000311r 2  80 DA                bra     @CharLoop
000313r 2               
000313r 2               @CharMismatch:
000313r 2  68                   pla
000314r 2                       ; Skip ahead to start of next keyword in table.  Walk byte-by-byte
000314r 2                       ; until we consume a byte with bit 7 set (last char of this keyword)
000314r 2                       ; or hit the $00 terminator.
000314r 2               @SkipKeyword:
000314r 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
000316r 2  F0 14                beq     @NoMatch                ; hit table terminator
000318r 2  E6 61                inc     BAS_KWPTR
00031Ar 2  D0 02                bne     @SkipNoCarry
00031Cr 2  E6 62                inc     BAS_KWPTR+1
00031Er 2               @SkipNoCarry:
00031Er 2  C9 80                cmp     #$80                    ; carry set iff loaded byte >= $80
000320r 2  90 F2                bcc     @SkipKeyword
000322r 2                       ; Fall through: byte had bit 7 set => end of keyword.
000322r 2               @AdvanceTok:
000322r 2  E6 3A                inc     BAS_TMP1
000324r 2  80 C5                bra     @KeywordLoop
000326r 2               
000326r 2               @WholeMatch:
000326r 2                       ; X points at the LAST matched char in input; advance past it.
000326r 2  E8                   inx
000327r 2  A5 3A                lda     BAS_TMP1
000329r 2  7A                   ply                             ; restore caller's Y
00032Ar 2  38                   sec
00032Br 2  60                   rts
00032Cr 2               
00032Cr 2               @NoMatch:
00032Cr 2  A6 3E                ldx     BAS_TMP3                ; restore caller's X
00032Er 2  7A                   ply                             ; restore caller's Y
00032Fr 2  BD 00 04             lda     BAS_LINBUF,x
000332r 2  18                   clc
000333r 2  60                   rts
000334r 2               
000334r 2               ; =============================================================================
000334r 2               ;   B a s S t o r e L i n e
000334r 2               ; =============================================================================
000334r 2               ; Insert or replace BAS_LINNUM in the program with the tokenized payload in
000334r 2               ; BAS_TOKBUF.  If BAS_TOKBUF is empty, delete the existing line.
000334r 2               ;
000334r 2               ; Algorithm:
000334r 2               ;   1. Find existing line number (or insertion point).
000334r 2               ;   2. If exact match, delete that line (close the gap, decrement VARTAB).
000334r 2               ;   3. If payload non-empty, splice in [next][num][payload][$00].
000334r 2               ;   4. Relink all next-pointers.
000334r 2               ; =============================================================================
000334r 2               BasStoreLine:
000334r 2                       ; Locate insertion point.  BAS_INDEX <- pointer; carry set = exact match.
000334r 2  20 rr rr             jsr     BasFindLine
000337r 2               
000337r 2  90 03                bcc     @NoExisting
000339r 2                       ; Line exists - delete it first.
000339r 2  20 rr rr             jsr     BasDeleteAtIndex
00033Cr 2               @NoExisting:
00033Cr 2                       ; If tokbuf is empty, we're done (delete-only operation).
00033Cr 2  AD 00 05             lda     BAS_TOKBUF
00033Fr 2  D0 04                bne     @InsertNew
000341r 2  20 rr rr             jsr     BasRelink
000344r 2  60                   rts
000345r 2               
000345r 2               @InsertNew:
000345r 2  20 rr rr             jsr     BasInsertAtIndex
000348r 2  90 04                bcc     @NoMem
00034Ar 2  20 rr rr             jsr     BasRelink
00034Dr 2  60                   rts
00034Er 2               @NoMem:
00034Er 2  A9 02                lda     #ERR_OUTOFMEM
000350r 2  4C rr rr             jmp     BasError
000353r 2               
000353r 2               ; =============================================================================
000353r 2               ;   B a s F i n d L i n e
000353r 2               ; =============================================================================
000353r 2               ; Locate BAS_LINNUM in the program list.
000353r 2               ;
000353r 2               ; On entry : BAS_LINNUM = target line number.
000353r 2               ; On exit  : BAS_INDEX = pointer to start of either the matching line or the
000353r 2               ;            first line whose number > target (or end-marker).
000353r 2               ;            Carry SET if exact match, CLEAR otherwise.
000353r 2               ; =============================================================================
000353r 2               BasFindLine:
000353r 2  AD 5D 03             lda     BAS_TXTTAB
000356r 2  85 20                sta     BAS_INDEX
000358r 2  AD 5E 03             lda     BAS_TXTTAB+1
00035Br 2  85 21                sta     BAS_INDEX+1
00035Dr 2               @Loop:
00035Dr 2  A0 01                ldy     #1
00035Fr 2  B1 20                lda     (BAS_INDEX),y
000361r 2  F0 25                beq     @NotFound               ; end-marker (next-hi = 0)
000363r 2               
000363r 2                       ; Compare line numbers: (INDEX+2/+3) vs LINNUM.
000363r 2  A0 03                ldy     #3
000365r 2  B1 20                lda     (BAS_INDEX),y
000367r 2  C5 09                cmp     BAS_LINNUM+1
000369r 2  90 0D                bcc     @Advance                ; line < target
00036Br 2  D0 1B                bne     @TooHigh                ; line > target -> insertion point
00036Dr 2  88                   dey
00036Er 2  B1 20                lda     (BAS_INDEX),y
000370r 2  C5 08                cmp     BAS_LINNUM
000372r 2  90 04                bcc     @Advance
000374r 2  D0 12                bne     @TooHigh
000376r 2                       ; Exact match.
000376r 2  38                   sec
000377r 2  60                   rts
000378r 2               
000378r 2               @Advance:
000378r 2                       ; Follow next-pointer.
000378r 2  A0 00                ldy     #0
00037Ar 2  B1 20                lda     (BAS_INDEX),y
00037Cr 2  48                   pha
00037Dr 2  A0 01                ldy     #1
00037Fr 2  B1 20                lda     (BAS_INDEX),y
000381r 2  85 21                sta     BAS_INDEX+1
000383r 2  68                   pla
000384r 2  85 20                sta     BAS_INDEX
000386r 2  80 D5                bra     @Loop
000388r 2               
000388r 2               @NotFound:
000388r 2               @TooHigh:
000388r 2  18                   clc
000389r 2  60                   rts
00038Ar 2               
00038Ar 2               ; =============================================================================
00038Ar 2               ;   B a s D e l e t e A t I n d e x
00038Ar 2               ; =============================================================================
00038Ar 2               ; Delete the line whose start is at BAS_INDEX.
00038Ar 2               ; Closes the gap by copying [next-line .. VARTAB-1] down to (BAS_INDEX...)
00038Ar 2               ; and decrements VARTAB by the deleted size.
00038Ar 2               ; =============================================================================
00038Ar 2               BasDeleteAtIndex:
00038Ar 2                       ; BAS_TMP1 = next-line address (read from current line's next ptr).
00038Ar 2  A0 00                ldy     #0
00038Cr 2  B1 20                lda     (BAS_INDEX),y
00038Er 2  85 3A                sta     BAS_TMP1
000390r 2  C8                   iny
000391r 2  B1 20                lda     (BAS_INDEX),y
000393r 2  85 3B                sta     BAS_TMP1+1
000395r 2               
000395r 2                       ; gap-size = TMP1 - INDEX  (positive)
000395r 2                       ; Copy from TMP1 to INDEX, byte by byte, until TMP1 reaches VARTAB.
000395r 2                       ; BAS_DEST = INDEX (write cursor); BAS_TMP2 = src cursor (= TMP1).
000395r 2  A5 20                lda     BAS_INDEX
000397r 2  85 22                sta     BAS_DEST
000399r 2  A5 21                lda     BAS_INDEX+1
00039Br 2  85 23                sta     BAS_DEST+1
00039Dr 2               
00039Dr 2               @CopyLoop:
00039Dr 2                       ; Done when TMP1 == VARTAB.
00039Dr 2  A5 3A                lda     BAS_TMP1
00039Fr 2  CD 5F 03             cmp     BAS_VARTAB
0003A2r 2  A5 3B                lda     BAS_TMP1+1
0003A4r 2  ED 60 03             sbc     BAS_VARTAB+1
0003A7r 2  B0 14                bcs     @CopyDone
0003A9r 2               
0003A9r 2  A0 00                ldy     #0
0003ABr 2  B1 3A                lda     (BAS_TMP1),y
0003ADr 2  91 22                sta     (BAS_DEST),y
0003AFr 2               
0003AFr 2  E6 3A                inc     BAS_TMP1
0003B1r 2  D0 02                bne     @IncDest
0003B3r 2  E6 3B                inc     BAS_TMP1+1
0003B5r 2               @IncDest:
0003B5r 2  E6 22                inc     BAS_DEST
0003B7r 2  D0 E4                bne     @CopyLoop
0003B9r 2  E6 23                inc     BAS_DEST+1
0003BBr 2  80 E0                bra     @CopyLoop
0003BDr 2               
0003BDr 2               @CopyDone:
0003BDr 2                       ; VARTAB = DEST.
0003BDr 2  A5 22                lda     BAS_DEST
0003BFr 2  8D 5F 03             sta     BAS_VARTAB
0003C2r 2  A5 23                lda     BAS_DEST+1
0003C4r 2  8D 60 03             sta     BAS_VARTAB+1
0003C7r 2                       ; Mirror to ARYTAB/STREND (vars/arrays empty after edit; keep them
0003C7r 2                       ; tracking VARTAB).
0003C7r 2  8D 62 03             sta     BAS_ARYTAB+1
0003CAr 2  8D 64 03             sta     BAS_STREND+1
0003CDr 2  AD 5F 03             lda     BAS_VARTAB
0003D0r 2  8D 61 03             sta     BAS_ARYTAB
0003D3r 2  8D 63 03             sta     BAS_STREND
0003D6r 2  60                   rts
0003D7r 2               
0003D7r 2               ; =============================================================================
0003D7r 2               ;   B a s I n s e r t A t I n d e x
0003D7r 2               ; =============================================================================
0003D7r 2               ; Splice a new line ([next-placeholder][num-lo][num-hi][payload][$00]) in
0003D7r 2               ; at BAS_INDEX, shifting following bytes upward.
0003D7r 2               ;
0003D7r 2               ; On entry : BAS_INDEX = insertion address, BAS_LINNUM = line number,
0003D7r 2               ;            BAS_TOKBUF = NUL-terminated payload (non-empty).
0003D7r 2               ; On exit  : Carry SET on success, CLEAR if not enough memory.
0003D7r 2               ;            VARTAB / ARYTAB / STREND advanced to new end-of-program.
0003D7r 2               ; =============================================================================
0003D7r 2               BasInsertAtIndex:
0003D7r 2                       ; Compute payload length L (excluding NUL): scan TOKBUF.
0003D7r 2  A0 00                ldy     #0
0003D9r 2               @LenScan:
0003D9r 2  B9 00 05             lda     BAS_TOKBUF,y
0003DCr 2  F0 03                beq     @LenDone
0003DEr 2  C8                   iny
0003DFr 2  D0 F8                bne     @LenScan
0003E1r 2               @LenDone:
0003E1r 2                       ; Total line size = 4 (header) + L + 1 (terminator) = L + 5.
0003E1r 2                       ; Store size in BAS_TMP3 (assumes <= 250+5 = 255, fits in one byte).
0003E1r 2  98                   tya
0003E2r 2  18                   clc
0003E3r 2  69 05                adc     #5
0003E5r 2  85 3E                sta     BAS_TMP3                ; line size in bytes (<=255)
0003E7r 2               
0003E7r 2                       ; Memory check: VARTAB + size <= MEMSIZ.
0003E7r 2  18                   clc
0003E8r 2  AD 5F 03             lda     BAS_VARTAB
0003EBr 2  65 3E                adc     BAS_TMP3
0003EDr 2  85 3A                sta     BAS_TMP1
0003EFr 2  AD 60 03             lda     BAS_VARTAB+1
0003F2r 2  69 00                adc     #0
0003F4r 2  85 3B                sta     BAS_TMP1+1
0003F6r 2  A5 3A                lda     BAS_TMP1
0003F8r 2  CD 67 03             cmp     BAS_MEMSIZ
0003FBr 2  A5 3B                lda     BAS_TMP1+1
0003FDr 2  ED 68 03             sbc     BAS_MEMSIZ+1
000400r 2  90 02                bcc     @SizeOK
000402r 2  18                   clc                             ; out of memory
000403r 2  60                   rts
000404r 2               @SizeOK:
000404r 2                       ; Shift bytes [INDEX .. VARTAB-1] up by TMP3.
000404r 2                       ; Copy from high-to-low to avoid overlap clobber.
000404r 2                       ; src  = VARTAB-1
000404r 2                       ; dst  = VARTAB-1 + TMP3
000404r 2  AD 5F 03             lda     BAS_VARTAB
000407r 2  38                   sec
000408r 2  E9 01                sbc     #1
00040Ar 2  85 3A                sta     BAS_TMP1                ; src
00040Cr 2  AD 60 03             lda     BAS_VARTAB+1
00040Fr 2  E9 00                sbc     #0
000411r 2  85 3B                sta     BAS_TMP1+1
000413r 2  18                   clc
000414r 2  A5 3A                lda     BAS_TMP1
000416r 2  65 3E                adc     BAS_TMP3
000418r 2  85 22                sta     BAS_DEST                ; dst
00041Ar 2  A5 3B                lda     BAS_TMP1+1
00041Cr 2  69 00                adc     #0
00041Er 2  85 23                sta     BAS_DEST+1
000420r 2               @Shift:
000420r 2                       ; Stop when TMP1 < INDEX (i.e. INDEX-1 reached -> done).
000420r 2  A5 3A                lda     BAS_TMP1
000422r 2  C5 20                cmp     BAS_INDEX
000424r 2  A5 3B                lda     BAS_TMP1+1
000426r 2  E5 21                sbc     BAS_INDEX+1
000428r 2  90 18                bcc     @ShiftDone
00042Ar 2               
00042Ar 2  A0 00                ldy     #0
00042Cr 2  B1 3A                lda     (BAS_TMP1),y
00042Er 2  91 22                sta     (BAS_DEST),y
000430r 2               
000430r 2                       ; dec TMP1
000430r 2  A5 3A                lda     BAS_TMP1
000432r 2  D0 02                bne     @T1NoBorrow
000434r 2  C6 3B                dec     BAS_TMP1+1
000436r 2               @T1NoBorrow:
000436r 2  C6 3A                dec     BAS_TMP1
000438r 2                       ; dec DEST
000438r 2  A5 22                lda     BAS_DEST
00043Ar 2  D0 02                bne     @DNoBorrow
00043Cr 2  C6 23                dec     BAS_DEST+1
00043Er 2               @DNoBorrow:
00043Er 2  C6 22                dec     BAS_DEST
000440r 2  80 DE                bra     @Shift
000442r 2               
000442r 2               @ShiftDone:
000442r 2                       ; Write new line header at BAS_INDEX.
000442r 2  A0 00                ldy     #0
000444r 2  A9 FF                lda     #$FF                    ; placeholder next-ptr (Relink fixes)
000446r 2  91 20                sta     (BAS_INDEX),y
000448r 2  C8                   iny
000449r 2  91 20                sta     (BAS_INDEX),y
00044Br 2  C8                   iny
00044Cr 2  A5 08                lda     BAS_LINNUM
00044Er 2  91 20                sta     (BAS_INDEX),y
000450r 2  C8                   iny
000451r 2  A5 09                lda     BAS_LINNUM+1
000453r 2  91 20                sta     (BAS_INDEX),y
000455r 2  C8                   iny
000456r 2               
000456r 2                       ; Copy payload from BAS_TOKBUF (NUL terminator included).
000456r 2  A2 00                ldx     #0
000458r 2               @PayloadCopy:
000458r 2  BD 00 05             lda     BAS_TOKBUF,x
00045Br 2  91 20                sta     (BAS_INDEX),y
00045Dr 2  F0 04                beq     @PayloadDone
00045Fr 2  E8                   inx
000460r 2  C8                   iny
000461r 2  80 F5                bra     @PayloadCopy
000463r 2               @PayloadDone:
000463r 2                       ; Update VARTAB.
000463r 2  18                   clc
000464r 2  AD 5F 03             lda     BAS_VARTAB
000467r 2  65 3E                adc     BAS_TMP3
000469r 2  8D 5F 03             sta     BAS_VARTAB
00046Cr 2  AD 60 03             lda     BAS_VARTAB+1
00046Fr 2  69 00                adc     #0
000471r 2  8D 60 03             sta     BAS_VARTAB+1
000474r 2                       ; Mirror to ARYTAB/STREND.
000474r 2  AD 5F 03             lda     BAS_VARTAB
000477r 2  8D 61 03             sta     BAS_ARYTAB
00047Ar 2  8D 63 03             sta     BAS_STREND
00047Dr 2  AD 60 03             lda     BAS_VARTAB+1
000480r 2  8D 62 03             sta     BAS_ARYTAB+1
000483r 2  8D 64 03             sta     BAS_STREND+1
000486r 2               
000486r 2  38                   sec
000487r 2  60                   rts
000488r 2               
000488r 2               ; =============================================================================
000488r 2               ;   B a s R e l i n k
000488r 2               ; =============================================================================
000488r 2               ; Walk the program list and rewrite every next-pointer to the address of
000488r 2               ; the following line (computed by scanning forward to the line's NUL
000488r 2               ; terminator).  Stops when a next-pointer's high byte is already 0
000488r 2               ; (the [00][00] end-marker, which is left untouched).
000488r 2               ; =============================================================================
000488r 2               BasRelink:
000488r 2  AD 5D 03             lda     BAS_TXTTAB
00048Br 2  85 20                sta     BAS_INDEX
00048Dr 2  AD 5E 03             lda     BAS_TXTTAB+1
000490r 2  85 21                sta     BAS_INDEX+1
000492r 2               @Loop:
000492r 2  A0 01                ldy     #1
000494r 2  B1 20                lda     (BAS_INDEX),y
000496r 2  F0 2B                beq     @Done                   ; end-marker reached
000498r 2               
000498r 2                       ; Find the NUL terminator at INDEX + Y for some Y >= 4.
000498r 2  A0 04                ldy     #4
00049Ar 2               @Scan:
00049Ar 2  B1 20                lda     (BAS_INDEX),y
00049Cr 2  F0 03                beq     @Found
00049Er 2  C8                   iny
00049Fr 2  D0 F9                bne     @Scan
0004A1r 2               @Found:
0004A1r 2  C8                   iny                             ; one past NUL = next line address
0004A2r 2                       ; next = INDEX + Y
0004A2r 2  98                   tya
0004A3r 2  18                   clc
0004A4r 2  65 20                adc     BAS_INDEX
0004A6r 2  85 3A                sta     BAS_TMP1
0004A8r 2  A5 21                lda     BAS_INDEX+1
0004AAr 2  69 00                adc     #0
0004ACr 2  85 3B                sta     BAS_TMP1+1
0004AEr 2               
0004AEr 2                       ; Write new next-pointer at (INDEX),0/1.
0004AEr 2  A0 00                ldy     #0
0004B0r 2  A5 3A                lda     BAS_TMP1
0004B2r 2  91 20                sta     (BAS_INDEX),y
0004B4r 2  C8                   iny
0004B5r 2  A5 3B                lda     BAS_TMP1+1
0004B7r 2  91 20                sta     (BAS_INDEX),y
0004B9r 2               
0004B9r 2                       ; Advance INDEX = TMP1.
0004B9r 2  A5 3A                lda     BAS_TMP1
0004BBr 2  85 20                sta     BAS_INDEX
0004BDr 2  A5 3B                lda     BAS_TMP1+1
0004BFr 2  85 21                sta     BAS_INDEX+1
0004C1r 2  80 CF                bra     @Loop
0004C3r 2               @Done:
0004C3r 2  60                   rts
0004C4r 2               
0004C4r 2               ; =============================================================================
0004C4r 2               ;   B a s D i s p a t c h I m m e d i a t e
0004C4r 2               ; =============================================================================
0004C4r 2               ; Execute a tokenized line (BAS_TOKBUF) in immediate mode by entering the
0004C4r 2               ; statement loop (BasNewstt) with TXTPTR pointing one byte before the first
0004C4r 2               ; tokenized byte.  Re-anchors the CPU stack so that FOR / GOSUB frames
0004C4r 2               ; stored on the stack can be located by the scanners.
0004C4r 2               ; =============================================================================
0004C4r 2               BasDispatchImmediate:
0004C4r 2                       ; Write a ':' sentinel just before BAS_TOKBUF so NEWSTT's initial
0004C4r 2                       ; (TXTPTR),y read takes the @nextStmt path and CHRGETs the first token.
0004C4r 2  A9 3A                lda     #':'
0004C6r 2  8D FF 04             sta     BAS_TOKBUF-1
0004C9r 2  A9 FF                lda     #<(BAS_TOKBUF-1)
0004CBr 2  85 04                sta     TXTPTR
0004CDr 2  A9 04                lda     #>(BAS_TOKBUF-1)
0004CFr 2  85 05                sta     TXTPTR+1
0004D1r 2  9C 70 03             stz     BAS_POSX
0004D4r 2                       ; Direct mode: CURLIN = $FFFF (msbasic convention).
0004D4r 2  A9 FF                lda     #$FF
0004D6r 2  8D 69 03             sta     BAS_CURLIN
0004D9r 2  8D 6A 03             sta     BAS_CURLIN+1
0004DCr 2                       ; Reset CPU stack so FOR / GOSUB frame scanners have a clean baseline.
0004DCr 2  A2 FF                ldx     #$FF
0004DEr 2  9A                   txs
0004DFr 2  4C rr rr             jmp     BasNewstt
0004E2r 2               
0004E2r 2               ; =============================================================================
0004E2r 2               ;   B a s C m d N e w
0004E2r 2               ; =============================================================================
0004E2r 2               ; Reset program storage to empty: write [00][00] at $0800 and reset the
0004E2r 2               ; runtime pointers.
0004E2r 2               ; =============================================================================
0004E2r 2               BasCmdNew:
0004E2r 2  9C 00 08             stz     BAS_PRG_START
0004E5r 2  9C 01 08             stz     BAS_PRG_START+1
0004E8r 2  A9 02                lda     #<(BAS_PRG_START+2)
0004EAr 2  8D 5F 03             sta     BAS_VARTAB
0004EDr 2  8D 61 03             sta     BAS_ARYTAB
0004F0r 2  8D 63 03             sta     BAS_STREND
0004F3r 2  A9 08                lda     #>(BAS_PRG_START+2)
0004F5r 2  8D 60 03             sta     BAS_VARTAB+1
0004F8r 2  8D 62 03             sta     BAS_ARYTAB+1
0004FBr 2  8D 64 03             sta     BAS_STREND+1
0004FEr 2  AD 67 03             lda     BAS_MEMSIZ
000501r 2  8D 65 03             sta     BAS_FRETOP
000504r 2  AD 68 03             lda     BAS_MEMSIZ+1
000507r 2  8D 66 03             sta     BAS_FRETOP+1
00050Ar 2  60                   rts
00050Br 2               
00050Br 2               ; =============================================================================
00050Br 2               ;   B a s C m d L i s t
00050Br 2               ; =============================================================================
00050Br 2               ; Print every stored line in order.  Each line: decimal line number, single
00050Br 2               ; space, detokenized payload, CRLF.
00050Br 2               ; =============================================================================
00050Br 2               BasCmdList:
00050Br 2  AD 5D 03             lda     BAS_TXTTAB
00050Er 2  85 20                sta     BAS_INDEX
000510r 2  AD 5E 03             lda     BAS_TXTTAB+1
000513r 2  85 21                sta     BAS_INDEX+1
000515r 2               @LineLoop:
000515r 2  A0 01                ldy     #1
000517r 2  B1 20                lda     (BAS_INDEX),y
000519r 2  F0 3D                beq     @Done                   ; end-marker
00051Br 2                       ; Print line number.
00051Br 2  A0 02                ldy     #2
00051Dr 2  B1 20                lda     (BAS_INDEX),y
00051Fr 2  85 08                sta     BAS_LINNUM
000521r 2  C8                   iny
000522r 2  B1 20                lda     (BAS_INDEX),y
000524r 2  85 09                sta     BAS_LINNUM+1
000526r 2  20 rr rr             jsr     BasPrintLineNum
000529r 2  A9 20                lda     #' '
00052Br 2  20 rr rr             jsr     Chrout
00052Er 2               
00052Er 2                       ; Detokenize from offset 4 to the NUL terminator.
00052Er 2  A0 04                ldy     #4
000530r 2               @DetokLoop:
000530r 2  B1 20                lda     (BAS_INDEX),y
000532r 2  F0 12                beq     @LineEnd
000534r 2  30 06                bmi     @Token
000536r 2  20 rr rr             jsr     Chrout
000539r 2  C8                   iny
00053Ar 2  80 F4                bra     @DetokLoop
00053Cr 2               @Token:
00053Cr 2  84 42                sty     BAS_DETOKY
00053Er 2  20 rr rr             jsr     BasPrintKeyword         ; preserves nothing useful
000541r 2  A4 42                ldy     BAS_DETOKY
000543r 2  C8                   iny
000544r 2  80 EA                bra     @DetokLoop
000546r 2               @LineEnd:
000546r 2  20 rr rr             jsr     BasPrintCRLF
000549r 2                       ; Advance INDEX via next-pointer.
000549r 2  A0 00                ldy     #0
00054Br 2  B1 20                lda     (BAS_INDEX),y
00054Dr 2  48                   pha
00054Er 2  C8                   iny
00054Fr 2  B1 20                lda     (BAS_INDEX),y
000551r 2  85 21                sta     BAS_INDEX+1
000553r 2  68                   pla
000554r 2  85 20                sta     BAS_INDEX
000556r 2  80 BD                bra     @LineLoop
000558r 2               @Done:
000558r 2  60                   rts
000559r 2               
000559r 2               ; =============================================================================
000559r 2               ;   B a s P r i n t L i n e N u m
000559r 2               ; =============================================================================
000559r 2               ; Print BAS_LINNUM (16-bit unsigned) as decimal (no leading zeros, no sign).
000559r 2               ; Clobbers : A, X, Y, BAS_TMP1.
000559r 2               ; =============================================================================
000559r 2               BasPrintLineNum:
000559r 2                       ; Repeated-subtraction divide by powers of ten.
000559r 2                       ; Suppress leading zeros via flag in BAS_TMP3.
000559r 2  64 3E                stz     BAS_TMP3                ; printed-something flag
00055Br 2  64 3C                stz     BAS_TMP2                ; current-digit accumulator
00055Dr 2               
00055Dr 2  A5 08                lda     BAS_LINNUM
00055Fr 2  85 3A                sta     BAS_TMP1
000561r 2  A5 09                lda     BAS_LINNUM+1
000563r 2  85 3B                sta     BAS_TMP1+1
000565r 2               
000565r 2  A2 00                ldx     #0
000567r 2               @PowerLoop:
000567r 2                       ; Subtract powers[X], counting iterations to get digit.
000567r 2  A0 00                ldy     #0                      ; digit counter
000569r 2               @Sub:
000569r 2  38                   sec
00056Ar 2  A5 3A                lda     BAS_TMP1
00056Cr 2  FD rr rr             sbc     PowersOfTenLo,x
00056Fr 2  A8                   tay                             ; temp save
000570r 2  A5 3B                lda     BAS_TMP1+1
000572r 2  FD rr rr             sbc     PowersOfTenHi,x
000575r 2  90 08                bcc     @SubDone
000577r 2  85 3B                sta     BAS_TMP1+1
000579r 2  84 3A                sty     BAS_TMP1
00057Br 2                       ; reuse Y for digit count via a scratch?  Use BAS_TMP2.
00057Br 2  E6 3C                inc     BAS_TMP2
00057Dr 2  80 EA                bra     @Sub
00057Fr 2               @SubDone:
00057Fr 2                       ; Digit is in BAS_TMP2.
00057Fr 2  A5 3C                lda     BAS_TMP2
000581r 2  05 3E                ora     BAS_TMP3                ; if any prior digit OR this digit nonzero, print
000583r 2  F0 0B                beq     @SkipDigit
000585r 2  A5 3C                lda     BAS_TMP2
000587r 2  09 30                ora     #'0'
000589r 2  20 rr rr             jsr     Chrout
00058Cr 2  A9 01                lda     #1
00058Er 2  85 3E                sta     BAS_TMP3
000590r 2               @SkipDigit:
000590r 2  64 3C                stz     BAS_TMP2
000592r 2  E8                   inx
000593r 2  E0 04                cpx     #4                      ; ten-thousands, thousands, hundreds, tens
000595r 2  D0 08                bne     @ResetAndLoop
000597r 2                       ; Final ones digit is in TMP1 (0-9).
000597r 2  A5 3A                lda     BAS_TMP1
000599r 2  09 30                ora     #'0'
00059Br 2  20 rr rr             jsr     Chrout
00059Er 2  60                   rts
00059Fr 2               @ResetAndLoop:
00059Fr 2  80 C6                bra     @PowerLoop
0005A1r 2               
0005A1r 2               PowersOfTenLo:
0005A1r 2  10 E8 64 0A          .byte   <10000, <1000, <100, <10
0005A5r 2               PowersOfTenHi:
0005A5r 2  27 03 00 00          .byte   >10000, >1000, >100, >10
0005A9r 2               
0005A9r 2               ; =============================================================================
0005A9r 2               ;   B a s C m d P r i n t
0005A9r 2               ; =============================================================================
0005A9r 2               ; Immediate-mode PRINT.  X on entry = offset into BAS_TOKBUF where the
0005A9r 2               ; PRINT token sits.  Items separated by ';' (no separator) or ',' (advance
0005A9r 2               ; to next 14-column print zone).  Trailing ';' or ',' suppresses CRLF.
0005A9r 2               ;
0005A9r 2               ; Special-cased token: HEX(n) -> emit "$XXXX" hex form (does not call
0005A9r 2               ; FrmEvl; consumes the token + parens here).
0005A9r 2               ; =============================================================================
0005A9r 2               BasCmdPrint:
0005A9r 2                       ; TXTPTR is positioned with ChrGot returning TOK_PRINT.  Advance
0005A9r 2                       ; past the token; col counter is reset by the dispatcher's outer loop.
0005A9r 2  20 rr rr             jsr     ChrGet                  ; consume PRINT token
0005ACr 2               
0005ACr 2               BasPrLoop:
0005ACr 2  20 rr rr             jsr     ChrGot
0005AFr 2  D0 03 4C rr          jeq     BasPrEndNl
0005B3r 2  rr           
0005B4r 2  C9 3A                cmp     #':'
0005B6r 2  D0 03 4C rr          jeq     BasPrEndNl
0005BAr 2  rr           
0005BBr 2  C9 A4                cmp     #TOK_ELSE
0005BDr 2  D0 03 4C rr          jeq     BasPrEndNl
0005C1r 2  rr           
0005C2r 2  C9 3B                cmp     #';'
0005C4r 2  D0 03 4C rr          jeq     BasPrSep
0005C8r 2  rr           
0005C9r 2  C9 2C                cmp     #','
0005CBr 2  D0 03 4C rr          jeq     BasPrComma
0005CFr 2  rr           
0005D0r 2  C9 CE                cmp     #TOK_HEX
0005D2r 2  D0 17                bne     @chkTab
0005D4r 2                       ; HEX(n) in PRINT context: emit "$XXXX".
0005D4r 2  20 rr rr             jsr     ChrGet                  ; consume HEX
0005D7r 2  20 rr rr             jsr     ChkOpn
0005DAr 2  20 rr rr             jsr     FrmEvl
0005DDr 2  20 rr rr             jsr     ChkNum
0005E0r 2  20 rr rr             jsr     ChkCls
0005E3r 2  20 rr rr             jsr     AyInt
0005E6r 2  20 rr rr             jsr     PrintHex16
0005E9r 2  80 6A                bra     BasPrAfter
0005EBr 2               @chkTab:
0005EBr 2  C9 9B                cmp     #TOK_TAB
0005EDr 2  D0 2D                bne     @chkSpc
0005EFr 2  20 rr rr             jsr     ChrGet                  ; consume TAB
0005F2r 2  20 rr rr             jsr     ChkOpn
0005F5r 2  20 rr rr             jsr     FrmNum
0005F8r 2  20 rr rr             jsr     ChkCls
0005FBr 2  20 rr rr             jsr     AyInt
0005FEr 2  A5 11                lda     FAC+3                   ; column count must fit in a byte
000600r 2  D0 53                bne     BasPrAfter
000602r 2  A5 12                lda     FAC+4
000604r 2  CD 70 03             cmp     BAS_POSX
000607r 2  90 4C                bcc     BasPrAfter              ; already at/past target column
000609r 2  38                   sec
00060Ar 2  ED 70 03             sbc     BAS_POSX
00060Dr 2  A8                   tay
00060Er 2  F0 45                beq     BasPrAfter
000610r 2               @tabLoop:
000610r 2  5A                   phy
000611r 2  A9 20                lda     #' '
000613r 2  20 rr rr             jsr     PrintCh
000616r 2  7A                   ply
000617r 2  88                   dey
000618r 2  D0 F6                bne     @tabLoop
00061Ar 2  80 39                bra     BasPrAfter
00061Cr 2               @chkSpc:
00061Cr 2  C9 9E                cmp     #TOK_SPC
00061Er 2  D0 23                bne     @expr
000620r 2  20 rr rr             jsr     ChrGet                  ; consume SPC
000623r 2  20 rr rr             jsr     ChkOpn
000626r 2  20 rr rr             jsr     FrmNum
000629r 2  20 rr rr             jsr     ChkCls
00062Cr 2  20 rr rr             jsr     AyInt
00062Fr 2  A5 11                lda     FAC+3
000631r 2  D0 22                bne     BasPrAfter
000633r 2  A4 12                ldy     FAC+4
000635r 2  F0 1E                beq     BasPrAfter
000637r 2               @spcLoop:
000637r 2  5A                   phy
000638r 2  A9 20                lda     #' '
00063Ar 2  20 rr rr             jsr     PrintCh
00063Dr 2  7A                   ply
00063Er 2  88                   dey
00063Fr 2  D0 F6                bne     @spcLoop
000641r 2  80 12                bra     BasPrAfter
000643r 2               @expr:
000643r 2  20 rr rr             jsr     FrmEvl
000646r 2  24 64                bit     VALTYP
000648r 2  30 05                bmi     @prStr
00064Ar 2  20 rr rr             jsr     PrintNum
00064Dr 2  80 06                bra     BasPrAfter
00064Fr 2               @prStr:
00064Fr 2  20 rr rr             jsr     PrintStrFAC
000652r 2  20 rr rr             jsr     FreFac
000655r 2               BasPrAfter:
000655r 2  20 rr rr             jsr     ChrGot
000658r 2  D0 03 4C rr          jeq     BasPrEndNl
00065Cr 2  rr           
00065Dr 2  C9 3A                cmp     #':'
00065Fr 2  D0 03 4C rr          jeq     BasPrEndNl
000663r 2  rr           
000664r 2  C9 A4                cmp     #TOK_ELSE
000666r 2  D0 03 4C rr          jeq     BasPrEndNl
00066Ar 2  rr           
00066Br 2  C9 3B                cmp     #';'
00066Dr 2  D0 03 4C rr          jeq     BasPrSep
000671r 2  rr           
000672r 2  C9 2C                cmp     #','
000674r 2  D0 03 4C rr          jeq     BasPrComma
000678r 2  rr           
000679r 2  4C rr rr             jmp     SynErr
00067Cr 2               BasPrSep:
00067Cr 2  20 rr rr             jsr     ChrGet                  ; consume ;
00067Fr 2  20 rr rr             jsr     ChrGot
000682r 2  F0 40                beq     BasPrEndNoNl            ; trailing ; -> no CRLF
000684r 2  C9 3A                cmp     #':'
000686r 2  F0 3C                beq     BasPrEndNoNl
000688r 2  4C rr rr             jmp     BasPrLoop
00068Br 2               BasPrComma:
00068Br 2  20 rr rr             jsr     ChrGet
00068Er 2                       ; Pad to next multiple of 14 (MS-BASIC 14-column zone).
00068Er 2                       ; col_mod = BAS_POSX mod 14; if 0 already at zone, else emit (14-col_mod) spaces.
00068Er 2  AD 70 03             lda     BAS_POSX
000691r 2  85 3A                sta     BAS_TMP1
000693r 2               @modA:
000693r 2  A5 3A                lda     BAS_TMP1
000695r 2  C9 0E                cmp     #14
000697r 2  90 07                bcc     @modB
000699r 2  38                   sec
00069Ar 2  E9 0E                sbc     #14
00069Cr 2  85 3A                sta     BAS_TMP1
00069Er 2  80 F3                bra     @modA
0006A0r 2               @modB:
0006A0r 2  C9 00                cmp     #0
0006A2r 2  F0 0D                beq     @padDone
0006A4r 2               @padSp:
0006A4r 2  A9 20                lda     #' '
0006A6r 2  20 rr rr             jsr     PrintCh
0006A9r 2  E6 3A                inc     BAS_TMP1
0006ABr 2  A5 3A                lda     BAS_TMP1
0006ADr 2  C9 0E                cmp     #14
0006AFr 2  D0 F3                bne     @padSp
0006B1r 2               @padDone:
0006B1r 2  20 rr rr             jsr     ChrGot
0006B4r 2  F0 0E                beq     BasPrEndNoNl
0006B6r 2  C9 3A                cmp     #':'
0006B8r 2  F0 0A                beq     BasPrEndNoNl
0006BAr 2  4C rr rr             jmp     BasPrLoop
0006BDr 2               BasPrEndNl:
0006BDr 2  20 rr rr             jsr     BasPrintCRLF
0006C0r 2  9C 70 03             stz     BAS_POSX
0006C3r 2  60                   rts
0006C4r 2               BasPrEndNoNl:
0006C4r 2  60                   rts
0006C5r 2               
0006C5r 2               ; ---------------------------------------------------------------------------
0006C5r 2               ; PrintCh -- emit A through Chrout, maintaining BAS_POSX (CR resets it).
0006C5r 2               ; ---------------------------------------------------------------------------
0006C5r 2               PrintCh:
0006C5r 2  C9 0D                cmp     #$0D
0006C7r 2  F0 0C                beq     @cr
0006C9r 2  C9 0A                cmp     #$0A
0006CBr 2  F0 08                beq     @cr
0006CDr 2  48                   pha
0006CEr 2  EE 70 03             inc     BAS_POSX
0006D1r 2  68                   pla
0006D2r 2  4C rr rr             jmp     Chrout
0006D5r 2               @cr:
0006D5r 2  9C 70 03             stz     BAS_POSX
0006D8r 2  4C rr rr             jmp     Chrout
0006DBr 2               
0006DBr 2               ; ---------------------------------------------------------------------------
0006DBr 2               ; PrintNum -- emit FAC as ASCII via Fout, tracking column.
0006DBr 2               ; ---------------------------------------------------------------------------
0006DBr 2               PrintNum:
0006DBr 2  20 rr rr             jsr     Fout                    ; (Y,A) = NUL-terminated buffer
0006DEr 2  85 20                sta     INDEX
0006E0r 2  84 21                sty     INDEX+1
0006E2r 2  A0 00                ldy     #0
0006E4r 2               @loop:
0006E4r 2  B1 20                lda     (INDEX),y
0006E6r 2  F0 06                beq     @done
0006E8r 2  20 rr rr             jsr     PrintCh
0006EBr 2  C8                   iny
0006ECr 2  D0 F6                bne     @loop
0006EEr 2               @done:
0006EEr 2  60                   rts
0006EFr 2               
0006EFr 2               ; ---------------------------------------------------------------------------
0006EFr 2               ; PrintStrFAC -- emit string-descriptor at FAC..FAC+2.
0006EFr 2               ; ---------------------------------------------------------------------------
0006EFr 2               PrintStrFAC:
0006EFr 2  A5 0F                lda     FAC+1
0006F1r 2  85 20                sta     INDEX
0006F3r 2  A5 10                lda     FAC+2
0006F5r 2  85 21                sta     INDEX+1
0006F7r 2  A0 00                ldy     #0
0006F9r 2               @loop:
0006F9r 2  C4 0E                cpy     FAC
0006FBr 2  F0 08                beq     @done
0006FDr 2  B1 20                lda     (INDEX),y
0006FFr 2  20 rr rr             jsr     PrintCh
000702r 2  C8                   iny
000703r 2  80 F4                bra     @loop
000705r 2               @done:
000705r 2  60                   rts
000706r 2               
000706r 2               ; ---------------------------------------------------------------------------
000706r 2               ; PrintHex16 -- emit FAC+3,FAC+4 (lo,hi) as "$XXXX".
000706r 2               ; ---------------------------------------------------------------------------
000706r 2               PrintHex16:
000706r 2  A9 24                lda     #'$'
000708r 2  20 rr rr             jsr     PrintCh
00070Br 2  A5 11                lda     FAC+3
00070Dr 2  20 rr rr             jsr     PrintHexByte
000710r 2  A5 12                lda     FAC+4
000712r 2                       ; fall through
000712r 2               PrintHexByte:
000712r 2  48                   pha
000713r 2  4A                   lsr     a
000714r 2  4A                   lsr     a
000715r 2  4A                   lsr     a
000716r 2  4A                   lsr     a
000717r 2  20 rr rr             jsr     @nib
00071Ar 2  68                   pla
00071Br 2  29 0F                and     #$0F
00071Dr 2               @nib:
00071Dr 2  C9 0A                cmp     #10
00071Fr 2  90 02                bcc     @dig
000721r 2  69 06                adc     #'A'-'9'-2              ; +'A'-10-1 (carry already set)
000723r 2               @dig:
000723r 2  69 30                adc     #'0'
000725r 2  4C rr rr             jmp     PrintCh
000728r 2               
000728r 2               ; =============================================================================
000728r 2               ;   B a s P r i n t K e y w o r d
000728r 2               ; =============================================================================
000728r 2               ; Print the keyword whose token byte is in A (bit 7 set).
000728r 2               ; Walks the keyword table to find entry (A - TOK_BASE) and prints its chars.
000728r 2               ; =============================================================================
000728r 2               BasPrintKeyword:
000728r 2  38                   sec
000729r 2  E9 80                sbc     #TOK_BASE               ; A = index
00072Br 2  AA                   tax
00072Cr 2                       ; Walk via 16-bit BAS_KWPTR since the table is > 256 bytes.
00072Cr 2  A9 rr                lda     #<KeywordTbl
00072Er 2  85 61                sta     BAS_KWPTR
000730r 2  A9 rr                lda     #>KeywordTbl
000732r 2  85 62                sta     BAS_KWPTR+1
000734r 2  A0 00                ldy     #0
000736r 2               @FindLoop:
000736r 2  E0 00                cpx     #0
000738r 2  F0 0F                beq     @PrintIt
00073Ar 2                       ; Skip current keyword: walk byte-by-byte until we consume a byte
00073Ar 2                       ; whose bit 7 is set (last char of the keyword).
00073Ar 2               @Skip:
00073Ar 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
00073Cr 2  E6 61                inc     BAS_KWPTR
00073Er 2  D0 02                bne     @SkipNoCarry
000740r 2  E6 62                inc     BAS_KWPTR+1
000742r 2               @SkipNoCarry:
000742r 2  C9 80                cmp     #$80                    ; C set iff loaded byte >= $80
000744r 2  90 F4                bcc     @Skip
000746r 2               @SkipEnd:
000746r 2  CA                   dex
000747r 2  80 ED                bra     @FindLoop
000749r 2               @PrintIt:
000749r 2               @PrintLoop:
000749r 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
00074Br 2  E6 61                inc     BAS_KWPTR
00074Dr 2  D0 02                bne     @PrintNoCarry
00074Fr 2  E6 62                inc     BAS_KWPTR+1
000751r 2               @PrintNoCarry:
000751r 2  48                   pha
000752r 2  29 7F                and     #$7F
000754r 2  20 rr rr             jsr     Chrout
000757r 2  68                   pla
000758r 2  10 EF                bpl     @PrintLoop
00075Ar 2  60                   rts
00075Br 2               
00075Br 2               ; =============================================================================
00075Br 2               ;   E R R O R   H A N D L I N G
00075Br 2               ; =============================================================================
00075Br 2               
00075Br 2               BasErrSyntax:
00075Br 2  A9 00                lda     #ERR_SYNTAX
00075Dr 2                       ; fall through
00075Dr 2               
00075Dr 2               ; BasError - print "?<msg> ERROR[ IN nnnn]" and return to the REPL.
00075Dr 2               ;   Input: A = error code (index into ErrorMessages).
00075Dr 2               ;   Resets the stack, prints, and jumps to BasReadyLoop.
00075Dr 2               BasError:
00075Dr 2  85 3E                sta     BAS_TMP3                ; stash code (stack reset wipes A on stack)
00075Fr 2  A2 FF                ldx     #$FF
000761r 2  9A                   txs
000762r 2  20 rr rr             jsr     BasPrintCRLF
000765r 2  A9 3F                lda     #'?'
000767r 2  20 rr rr             jsr     Chrout
00076Ar 2  A5 3E                lda     BAS_TMP3
00076Cr 2                       ; A = error code; print the matching message.
00076Cr 2  20 rr rr             jsr     BasPrintErrorMsg
00076Fr 2                       ; Append " ERROR" and (if not direct mode) line number.
00076Fr 2  A9 rr                lda     #<MsgErrorWord
000771r 2  A0 rr                ldy     #>MsgErrorWord
000773r 2  20 rr rr             jsr     BasPrintStr
000776r 2  AD 6A 03             lda     BAS_CURLIN+1
000779r 2  C9 FF                cmp     #$FF
00077Br 2  F0 14                beq     @NoLine
00077Dr 2  A9 rr                lda     #<MsgInWord
00077Fr 2  A0 rr                ldy     #>MsgInWord
000781r 2  20 rr rr             jsr     BasPrintStr
000784r 2  AD 69 03             lda     BAS_CURLIN
000787r 2  85 08                sta     BAS_LINNUM
000789r 2  AD 6A 03             lda     BAS_CURLIN+1
00078Cr 2  85 09                sta     BAS_LINNUM+1
00078Er 2  20 rr rr             jsr     BasPrintLineNum
000791r 2               @NoLine:
000791r 2                       ; Mark direct mode and bounce back to REPL.
000791r 2  A9 FF                lda     #$FF
000793r 2  8D 69 03             sta     BAS_CURLIN
000796r 2  8D 6A 03             sta     BAS_CURLIN+1
000799r 2  4C rr rr             jmp     BasReadyLoop
00079Cr 2               
00079Cr 2               ; BasPrintErrorMsg - print message #A from the error-message table.
00079Cr 2               ;   Each message is NUL-terminated; the table is a sequence of those.
00079Cr 2               BasPrintErrorMsg:
00079Cr 2  AA                   tax
00079Dr 2  A9 rr                lda     #<ErrorMessages
00079Fr 2  85 3A                sta     BAS_TMP1
0007A1r 2  A9 rr                lda     #>ErrorMessages
0007A3r 2  85 3B                sta     BAS_TMP1+1
0007A5r 2               @Skip:
0007A5r 2  E0 00                cpx     #0
0007A7r 2  F0 17                beq     @Print
0007A9r 2                       ; Walk past one message (advance until NUL, then one more).
0007A9r 2               @SkipLoop:
0007A9r 2  A0 00                ldy     #0
0007ABr 2  B1 3A                lda     (BAS_TMP1),y
0007ADr 2  F0 08                beq     @SkipDone
0007AFr 2  E6 3A                inc     BAS_TMP1
0007B1r 2  D0 F6                bne     @SkipLoop
0007B3r 2  E6 3B                inc     BAS_TMP1+1
0007B5r 2  80 F2                bra     @SkipLoop
0007B7r 2               @SkipDone:
0007B7r 2  E6 3A                inc     BAS_TMP1
0007B9r 2  D0 02                bne     @SkippedHi
0007BBr 2  E6 3B                inc     BAS_TMP1+1
0007BDr 2               @SkippedHi:
0007BDr 2  CA                   dex
0007BEr 2  80 E5                bra     @Skip
0007C0r 2               @Print:
0007C0r 2  A5 3A                lda     BAS_TMP1
0007C2r 2  A4 3B                ldy     BAS_TMP1+1
0007C4r 2  4C rr rr             jmp     BasPrintStr
0007C7r 2               
0007C7r 2               
0007C7r 2               ; =============================================================================
0007C7r 2               ;   F L O A T I N G - P O I N T   R U N T I M E
0007C7r 2               ;
0007C7r 2               ;   Externals required by the inlined MSBASIC FP code:
0007C7r 2               ;     ChrGet   - advance TXTPTR and load next non-space tokenized char
0007C7r 2               ;                (used by Fin; never exercised by the FP tests).
0007C7r 2               ;     BasErrorVec    - error vector; X = error code
0007C7r 2               ;     IqErr    - "?ILLEGAL QUANTITY" entry
0007C7r 2               ;     STROUT   - print NUL-terminated string at (A=lo, Y=hi)
0007C7r 2               ;     QtIn    - the literal " IN " string (used only by InPrt)
0007C7r 2               ; =============================================================================
0007C7r 2               
0007C7r 2               ; --- ChrGet / ChrGot --------------------------------------------------------
0007C7r 2               ; Real implementation (ROM, not ZP self-modifying).  Increments TXTPTR and
0007C7r 2               ; returns the next non-space byte at (TXTPTR) in A, with carry CLEAR if the
0007C7r 2               ; byte is a digit '0'-'9'.  ChrGot re-reads the current byte without
0007C7r 2               ; advancing first.  Both clobber only A and flags.
0007C7r 2               ;
0007C7r 2               ; Side effects on flags after the routine returns:
0007C7r 2               ;   Z=1  if A == $00 or A is a tokenized/keyword byte that wraps to zero
0007C7r 2               ;        (used by callers checking end-of-statement).
0007C7r 2               ;   C=0  if A is a digit ('0'-'9'); else C=1.
0007C7r 2               ;
0007C7r 2               ; Implementation matches msbasic-master/chrget.s.
0007C7r 2               ChrGet:
0007C7r 2  E6 04                inc     TXTPTR
0007C9r 2  D0 02                bne     ChrGot
0007CBr 2  E6 05                inc     TXTPTR+1
0007CDr 2               ChrGot:
0007CDr 2  B2 04                lda     (TXTPTR)
0007CFr 2  C9 3A                cmp     #':'
0007D1r 2  B0 0A                bcs     @out
0007D3r 2  C9 20                cmp     #' '
0007D5r 2  F0 F0                beq     ChrGet
0007D7r 2  38                   sec
0007D8r 2  E9 30                sbc     #'0'
0007DAr 2  38                   sec
0007DBr 2  E9 D0                sbc     #$D0                    ; restore A; sets C=0 iff digit
0007DDr 2               @out:
0007DDr 2  60                   rts
0007DEr 2               
0007DEr 2               ; --- Error trampolines ------------------------------------------------------
0007DEr 2               ; The MSBASIC convention is "ldx #code / jmp ERROR".  Our BasError takes
0007DEr 2               ; the code in A, so translate.
0007DEr 2               BasErrorVec:
0007DEr 2  8A                   txa
0007DFr 2  4C rr rr             jmp     BasError
0007E2r 2               
0007E2r 2               IqErr:
0007E2r 2  A2 0B                ldx     #ERR_ILLQUAN
0007E4r 2  4C rr rr             jmp     BasErrorVec
0007E7r 2               
0007E7r 2               ; --- String output ----------------------------------------------------------
0007E7r 2               ; FP code calls STROUT with (A=lo, Y=hi).  BasPrintStr matches that ABI.
0007E7r 2               STROUT          := BasPrintStr
0007E7r 2               
0007E7r 2               ; --- "IN " literal (referenced by InPrt) ----------------------------------
0007E7r 2               QtIn:
0007E7r 2  20 49 4E 20          .byte   " IN ",0
0007EBr 2  00           
0007ECr 2               
0007ECr 2               ; --- Shared RTS targets used by branches in the FP code --------------------
0007ECr 2               ; The original MSBASIC defines Rts3 in poke.s (which we don't include).
0007ECr 2               ; Provide a single shared RTS landing pad here.
0007ECr 2               Rts3:
0007ECr 2  60                   rts
