000B13r 2               @NotRem:
000B13r 2  C9 8D          cmp #TOK_END
000B15r 2  D0 03          bne @NotEnd
000B17r 2  4C rr rr       jmp @JmpEnd
000B1Ar 2               @NotEnd:
000B1Ar 2  C9 8E          cmp #TOK_LIST
000B1Cr 2  D0 03          bne @NotList
