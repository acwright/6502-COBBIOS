0017C2r 2               VT_SetTxt:
0017C2r 2                       ; Set TXTPTR = VT_TXTPTR_TMP - 1 then ChrGet to load first char.
0017C2r 2                       ; Actually simpler: caller passes (Y,A) = pointer; we set TXTPTR =
0017C2r 2                       ; (Y,A) - 1 and call ChrGet to land on (Y,A).
0017C2r 2                       sta     TXTPTR
0017C2r 2                       sty     TXTPTR+1
0017C2r 2                       lda     TXTPTR
0017C2r 2                       bne     @nb
0017C2r 2                       dec     TXTPTR+1
0017C2r 2               @nb:
0017C2r 2                       dec     TXTPTR
0017C2r 2                       jmp     ChrGet
