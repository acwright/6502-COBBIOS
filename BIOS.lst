000000r 1               
000000r 1               .segment "KERNAL"
000000r 1               .include "Kernal.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   KERNAL    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; === Kernal Jump Table ($A000-$A0FF) ===
000000r 2               ; 85 slots of 3-byte JMP instructions plus 1 padding byte
000000r 2               ; Provides stable entry points for external code and cartridges
000000r 2               
000000r 2  4C rr rr     Chrout:         jmp ChroutDispatch      ; $A000 - Output char (dispatched by IO_MODE)
000003r 2  4C rr rr     Chrin:          jmp ChrinImpl           ; $A003 - Input char from buffer
000006r 2  4C rr rr     WriteBuffer:    jmp WriteBufferImpl     ; $A006 - Write byte to input buffer
000009r 2  4C rr rr     ReadBuffer:     jmp ReadBufferImpl      ; $A009 - Read byte from input buffer
00000Cr 2  4C rr rr     BufferSize:     jmp BufferSizeImpl      ; $A00C - Get buffer count
00000Fr 2  4C rr rr     InitVideo:      jmp InitVideoImpl       ; $A00F - Initialize TMS9918
000012r 2  4C rr rr     InitKB:         jmp InitKBImpl          ; $A012 - Initialize GPIO/VIA keyboard
000015r 2  4C rr rr     InitSC:         jmp InitSCImpl          ; $A015 - Initialize serial 6551
000018r 2  4C rr rr     InitSID:        jmp InitSIDImpl         ; $A018 - Initialize SID
00001Br 2  4C rr rr     Beep:           jmp BeepImpl            ; $A01B - Play beep tone
00001Er 2  4C rr rr     VideoClear:     jmp VideoClearImpl      ; $A01E - Clear video screen
000021r 2  4C rr rr     VideoPutChar:   jmp VideoPutCharImpl    ; $A021 - Write char at cursor
000024r 2  4C rr rr     VideoSetCursor: jmp VideoSetCursorImpl  ; $A024 - Set cursor (X=col, Y=row)
000027r 2  4C rr rr     VideoGetCursor: jmp VideoGetCursorImpl  ; $A027 - Get cursor position
00002Ar 2  4C rr rr     VideoScroll:    jmp VideoScrollImpl     ; $A02A - Scroll screen up one line
00002Dr 2  4C rr rr     SerialChrout:   jmp SerialChroutImpl    ; $A02D - Direct serial output (bypass IO_MODE)
000030r 2  4C rr rr     ReadJoystick1:  jmp ReadJoystick1Impl   ; $A030 - Read joystick 1
000033r 2  4C rr rr     ReadJoystick2:  jmp ReadJoystick2Impl   ; $A033 - Read joystick 2
000036r 2  4C rr rr     RtcReadTime:    jmp RtcReadTimeImpl     ; $A036 - Read RTC time
000039r 2  4C rr rr     RtcReadDate:    jmp RtcReadDateImpl     ; $A039 - Read RTC date
00003Cr 2  4C rr rr     RtcWriteTime:   jmp RtcWriteTimeImpl    ; $A03C - Set RTC time
00003Fr 2  4C rr rr     RtcWriteDate:   jmp RtcWriteDateImpl    ; $A03F - Set RTC date
000042r 2  4C rr rr     RtcReadNVRAM:   jmp RtcReadNVRAMImpl    ; $A042 - Read NVRAM byte
000045r 2  4C rr rr     RtcWriteNVRAM:  jmp RtcWriteNVRAMImpl   ; $A045 - Write NVRAM byte
000048r 2  4C rr rr     StReadSector:   jmp StReadSectorImpl    ; $A048 - Read CF sector
00004Br 2  4C rr rr     StWriteSector:  jmp StWriteSectorImpl   ; $A04B - Write CF sector
00004Er 2  4C rr rr     StWaitReady:    jmp StWaitReadyImpl     ; $A04E - Wait CF ready
000051r 2  4C rr rr     SetIOMode:      jmp SetIOModeImpl       ; $A051 - Set IO_MODE
000054r 2  4C rr rr     GetIOMode:      jmp GetIOModeImpl       ; $A054 - Get IO_MODE
000057r 2  4C rr rr     AsciiLoad:      jmp AsciiLoadImpl       ; $A057 - Load raw binary via serial
00005Ar 2  4C rr rr     AsciiSave:      jmp AsciiSaveImpl       ; $A05A - Save raw binary via serial
00005Dr 2  4C rr rr     SidPlayNote:    jmp SidPlayNoteImpl     ; $A05D - Play note (A=voice, X=freqLo, Y=freqHi)
000060r 2  4C rr rr     SidSilence:     jmp SidSilenceImpl      ; $A060 - Silence all voices
000063r 2  4C rr rr     FsDeleteFile:   jmp FsDeleteFileImpl    ; $A063 - Delete file from CF
000066r 2               
000066r 2  4C rr rr     SysDelay:       jmp SysDelayImpl        ; $A066 - Delay A=cnt_lo, X=cnt_hi centiseconds
000069r 2  4C rr rr     SidSetVolume:   jmp SidSetVolumeImpl    ; $A069 - Set SID master volume (A=0-15)
00006Cr 2  4C rr rr     VideoSetColor:  jmp VideoSetColorImpl   ; $A06C - Set TMS9918 text color (A=reg7 byte: hi=fg, lo=bg)
00006Fr 2               
00006Fr 2               ; Reserved entries ($A06F-$A0FE)
00006Fr 2  4C rr rr 4C  .repeat 48
000073r 2  rr rr 4C rr  
000077r 2  rr 4C rr rr  
0000FFr 2                               jmp UnimplementedStub
0000FFr 2               .endrepeat
0000FFr 2  00           .byte $00                             ; Pad to 256 bytes ($A0FF)
000100r 2               
000100r 2               ; === Kernal Implementation ===
000100r 2               
000100r 2               ; Stub for unimplemented jump table entries
000100r 2               UnimplementedStub:
000100r 2  60             rts
000101r 2               
000101r 2               ; Chrout dispatcher — routes output based on IO_MODE
000101r 2               ; Input: A = character to output
000101r 2               ; Modifies: Flags
000101r 2               ChroutDispatch:
000101r 2  48             pha
000102r 2  AD 06 03       lda IO_MODE
000105r 2  29 01          and #$01                      ; Bit 0: 0=video, 1=serial
000107r 2  D0 04          bne @Serial
000109r 2  68             pla
00010Ar 2  4C rr rr       jmp VideoChroutImpl
00010Dr 2               @Serial:
00010Dr 2  68             pla
00010Er 2  4C rr rr       jmp SerialChroutImpl
000111r 2               
000111r 2               ; Set IO_MODE
000111r 2               ; Input: A = mode (bit 0: 0=video, 1=serial)
000111r 2               SetIOModeImpl:
000111r 2  8D 06 03       sta IO_MODE
000114r 2  60             rts
000115r 2               
000115r 2               ; Get IO_MODE
000115r 2               ; Output: A = current IO_MODE
000115r 2               GetIOModeImpl:
000115r 2  AD 06 03       lda IO_MODE
000118r 2  60             rts
000119r 2               
000119r 2               ; === TMS9918 Video Driver ===
000119r 2               
000119r 2               ; VideoClear — Fill name table (960 bytes at VRAM $0000) with spaces, reset cursor to (0,0)
000119r 2               ; Modifies: Flags, A, X, Y
000119r 2               VideoClearImpl:
000119r 2                 ; Set VRAM write address to $0000 (name table base)
000119r 2  A9 00          lda #$00
00011Br 2  8D 01 9C       sta VC_REG
00011Er 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
000120r 2  8D 01 9C       sta VC_REG
000123r 2                 ; Fill 960 bytes with space ($20) — 3 full pages + 192 bytes
000123r 2  A9 20          lda #$20
000125r 2  A0 00          ldy #$00
000127r 2  A2 03          ldx #$03                      ; 3 full pages (768 bytes)
000129r 2               @VideoClearPage:
000129r 2  8D 00 9C       sta VC_DATA
00012Cr 2  C8             iny
00012Dr 2  D0 FA          bne @VideoClearPage
00012Fr 2  CA             dex
000130r 2  D0 F7          bne @VideoClearPage
000132r 2                 ; Remaining 192 bytes (960 - 768)
000132r 2  A0 C0          ldy #192
000134r 2               @VideoClearRem:
000134r 2  8D 00 9C       sta VC_DATA
000137r 2  88             dey
000138r 2  D0 FA          bne @VideoClearRem
00013Ar 2                 ; Reset cursor to (0,0)
00013Ar 2  9C 07 03       stz VID_CURSOR_X
00013Dr 2  9C 08 03       stz VID_CURSOR_Y
000140r 2  9C 09 03       stz VID_CURSOR_ADDR
000143r 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
000146r 2  60             rts
000147r 2               
000147r 2               ; VideoSetCursor — Set cursor position
000147r 2               ; Input: X = column (0-39), Y = row (0-23)
000147r 2               ; Calculates VRAM address = Y * 40 + X and stores in VID_CURSOR_ADDR
000147r 2               ; Modifies: Flags, A
000147r 2               VideoSetCursorImpl:
000147r 2  8E 07 03       stx VID_CURSOR_X
00014Ar 2  8C 08 03       sty VID_CURSOR_Y
00014Dr 2                 ; Calculate VRAM address = Y * 40 + X
00014Dr 2                 ; Y * 40 = Y * 32 + Y * 8
00014Dr 2  A9 00          lda #$00
00014Fr 2  8D 0A 03       sta VID_CURSOR_ADDR + 1       ; Clear high byte
000152r 2  98             tya                           ; A = row
000153r 2                 ; Multiply by 8: shift left 3
000153r 2  0A             asl a
000154r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000157r 2  0A             asl a
000158r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Br 2  0A             asl a
00015Cr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Fr 2  8D 09 03       sta VID_CURSOR_ADDR           ; Store Y*8 low byte
000162r 2                 ; Save Y*8 for later addition
000162r 2  48             pha
000163r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
000166r 2  48             pha
000167r 2                 ; Multiply original row by 32: shift left 5 total (Y*8 << 2)
000167r 2  AD 09 03       lda VID_CURSOR_ADDR
00016Ar 2  0A             asl a
00016Br 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00016Er 2  0A             asl a
00016Fr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000172r 2  8D 09 03       sta VID_CURSOR_ADDR           ; Now holds Y*32 low byte
000175r 2                 ; Add Y*8 + Y*32
000175r 2  68             pla                           ; Restore Y*8 high byte
000176r 2  6D 0A 03       adc VID_CURSOR_ADDR + 1       ; Carry still valid from last rol
000179r 2  8D 0A 03       sta VID_CURSOR_ADDR + 1
00017Cr 2  68             pla                           ; Restore Y*8 low byte
00017Dr 2  18             clc
00017Er 2  6D 09 03       adc VID_CURSOR_ADDR
000181r 2  8D 09 03       sta VID_CURSOR_ADDR
000184r 2  90 03          bcc @NoCarry
000186r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000189r 2               @NoCarry:
000189r 2                 ; Add X (column)
000189r 2  8A             txa
00018Ar 2  18             clc
00018Br 2  6D 09 03       adc VID_CURSOR_ADDR
00018Er 2  8D 09 03       sta VID_CURSOR_ADDR
000191r 2  90 03          bcc @SetCursorDone
000193r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000196r 2               @SetCursorDone:
000196r 2  60             rts
000197r 2               
000197r 2               ; VideoGetCursor — Get cursor position
000197r 2               ; Output: X = column (0-39), Y = row (0-23)
000197r 2               ; Modifies: Flags
000197r 2               VideoGetCursorImpl:
000197r 2  AE 07 03       ldx VID_CURSOR_X
00019Ar 2  AC 08 03       ldy VID_CURSOR_Y
00019Dr 2  60             rts
00019Er 2               
00019Er 2               ; VideoPutChar — Write a single character to VRAM at VID_CURSOR_ADDR
00019Er 2               ; Input: A = character to write
00019Er 2               ; Modifies: Flags
00019Er 2               VideoPutCharImpl:
00019Er 2  48             pha
00019Fr 2                 ; Set VRAM write address from VID_CURSOR_ADDR
00019Fr 2  AD 09 03       lda VID_CURSOR_ADDR
0001A2r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
0001A5r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
0001A8r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001AAr 2  8D 01 9C       sta VC_REG                    ; High byte with write flag
0001ADr 2  68             pla
0001AEr 2  8D 00 9C       sta VC_DATA                   ; Write character to VRAM
0001B1r 2  60             rts
0001B2r 2               
0001B2r 2               ; VideoScroll — Scroll screen up one line
0001B2r 2               ; Copies VRAM rows 1-23 to rows 0-22 (920 bytes), clears row 23 with spaces
0001B2r 2               ; Uses SCROLL_BUF ($0320, 40 bytes) as temporary storage
0001B2r 2               ; Modifies: Flags, A, X, Y
0001B2r 2               VideoScrollImpl:
0001B2r 2                 ; Save STR_PTR (may be in use by caller, e.g. VideoPrintStr)
0001B2r 2  A5 02          lda STR_PTR
0001B4r 2  48             pha
0001B5r 2  A5 03          lda STR_PTR + 1
0001B7r 2  48             pha
0001B8r 2                 ; Source starts at row 1 (VRAM offset 40=$28), dest at row 0 (offset 0)
0001B8r 2                 ; We process 23 rows, copying each row up by one
0001B8r 2  A9 28          lda #<40                      ; Source address low = 40 (row 1)
0001BAr 2  85 02          sta STR_PTR
0001BCr 2  A9 00          lda #>40
0001BEr 2  85 03          sta STR_PTR + 1
0001C0r 2               
0001C0r 2  A2 17          ldx #23                       ; 23 rows to copy
0001C2r 2               @ScrollRowLoop:
0001C2r 2  DA             phx                           ; Save row counter
0001C3r 2               
0001C3r 2                 ; Set VRAM read address (source row)
0001C3r 2  A5 02          lda STR_PTR
0001C5r 2  8D 01 9C       sta VC_REG
0001C8r 2  A5 03          lda STR_PTR + 1
0001CAr 2  8D 01 9C       sta VC_REG                    ; Bit 6 clear = read mode
0001CDr 2                 ; Read 40 bytes into SCROLL_BUF
0001CDr 2  A0 00          ldy #$00
0001CFr 2               @ScrollRead:
0001CFr 2  AD 00 9C       lda VC_DATA
0001D2r 2  99 20 03       sta SCROLL_BUF,y
0001D5r 2  C8             iny
0001D6r 2  C0 28          cpy #40
0001D8r 2  D0 F5          bne @ScrollRead
0001DAr 2               
0001DAr 2                 ; Set VRAM write address (dest = source - 40)
0001DAr 2  A5 02          lda STR_PTR
0001DCr 2  38             sec
0001DDr 2  E9 28          sbc #40
0001DFr 2  8D 01 9C       sta VC_REG                    ; Dest address low
0001E2r 2  A5 03          lda STR_PTR + 1
0001E4r 2  E9 00          sbc #$00
0001E6r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001E8r 2  8D 01 9C       sta VC_REG                    ; Dest address high
0001EBr 2               
0001EBr 2                 ; Write 40 bytes from SCROLL_BUF
0001EBr 2  A0 00          ldy #$00
0001EDr 2               @ScrollWrite:
0001EDr 2  B9 20 03       lda SCROLL_BUF,y
0001F0r 2  8D 00 9C       sta VC_DATA
0001F3r 2  C8             iny
0001F4r 2  C0 28          cpy #40
0001F6r 2  D0 F5          bne @ScrollWrite
0001F8r 2               
0001F8r 2                 ; Advance source pointer by 40 for next row
0001F8r 2  A5 02          lda STR_PTR
0001FAr 2  18             clc
0001FBr 2  69 28          adc #40
0001FDr 2  85 02          sta STR_PTR
0001FFr 2  90 02          bcc @ScrollNoCarry
000201r 2  E6 03          inc STR_PTR + 1
000203r 2               @ScrollNoCarry:
000203r 2  FA             plx                           ; Restore row counter
000204r 2  CA             dex
000205r 2  D0 BB          bne @ScrollRowLoop
000207r 2               
000207r 2                 ; Clear bottom row (row 23) with spaces
000207r 2                 ; Row 23 address = 23 * 40 = 920 = $0398
000207r 2  A9 98          lda #$98                      ; Low byte of $0398
000209r 2  8D 01 9C       sta VC_REG
00020Cr 2  A9 03          lda #$03
00020Er 2  09 40          ora #$40                      ; Write mode
000210r 2  8D 01 9C       sta VC_REG
000213r 2  A9 20          lda #$20                      ; Space character
000215r 2  A0 28          ldy #40
000217r 2               @ScrollClearBottom:
000217r 2  8D 00 9C       sta VC_DATA
00021Ar 2  88             dey
00021Br 2  D0 FA          bne @ScrollClearBottom
00021Dr 2                 ; Restore STR_PTR
00021Dr 2  68             pla
00021Er 2  85 03          sta STR_PTR + 1
000220r 2  68             pla
000221r 2  85 02          sta STR_PTR
000223r 2  60             rts
000224r 2               
000224r 2               ; VideoChrout — Output character to video display
000224r 2               ; Handles control characters: CR ($0D), LF ($0A), BS ($08), BEL ($07)
000224r 2               ; Auto-wraps at column 40, auto-scrolls at row 24
000224r 2               ; Input: A = character to output
000224r 2               ; Preserves: A, X, Y (callers like ChrinImpl, BasPrintStr and Wozmon depend on this)
000224r 2               ; Modifies: Flags
000224r 2               VideoChroutImpl:
000224r 2  48             pha
000225r 2  DA             phx
000226r 2  5A             phy
000227r 2  C9 0D          cmp #$0D                      ; Carriage Return?
000229r 2  F0 43          beq @VideoCR
00022Br 2  C9 0A          cmp #$0A                      ; Line Feed?
00022Dr 2  F0 4C          beq @VideoLF
00022Fr 2  C9 08          cmp #$08                      ; Backspace?
000231r 2  F0 65          beq @VideoBS
000233r 2  C9 07          cmp #$07                      ; Bell?
000235r 2  F0 79          beq @VideoBEL
000237r 2                 ; Regular printable character — write at cursor and advance
000237r 2  20 rr rr       jsr VideoPutChar              ; Write char to VRAM at cursor
00023Ar 2                 ; Advance cursor
00023Ar 2  EE 07 03       inc VID_CURSOR_X
00023Dr 2                 ; Increment VRAM address
00023Dr 2  EE 09 03       inc VID_CURSOR_ADDR
000240r 2  D0 03          bne @CheckWrap
000242r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000245r 2               @CheckWrap:
000245r 2  AD 07 03       lda VID_CURSOR_X
000248r 2  C9 28          cmp #40                       ; Past last column?
00024Ar 2  90 1E          bcc @VideoChroutDone          ; No, done
00024Cr 2                 ; Auto-wrap: CR + LF
00024Cr 2  9C 07 03       stz VID_CURSOR_X
00024Fr 2  EE 08 03       inc VID_CURSOR_Y
000252r 2  AD 08 03       lda VID_CURSOR_Y
000255r 2  C9 18          cmp #24                       ; Past last row?
000257r 2  90 08          bcc @WrapRecalc
000259r 2                 ; Need to scroll
000259r 2  20 rr rr       jsr VideoScroll
00025Cr 2  A9 17          lda #23
00025Er 2  8D 08 03       sta VID_CURSOR_Y
000261r 2               @WrapRecalc:
000261r 2  AE 07 03       ldx VID_CURSOR_X
000264r 2  AC 08 03       ldy VID_CURSOR_Y
000267r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
00026Ar 2               @VideoChroutDone:
00026Ar 2  7A             ply
00026Br 2  FA             plx
00026Cr 2  68             pla
00026Dr 2  60             rts
00026Er 2               
00026Er 2               @VideoCR:
00026Er 2  9C 07 03       stz VID_CURSOR_X              ; Column = 0
000271r 2  A2 00          ldx #$00
000273r 2  AC 08 03       ldy VID_CURSOR_Y
000276r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
000279r 2  80 EF          bra @VideoChroutDone
00027Br 2               
00027Br 2               @VideoLF:
00027Br 2  EE 08 03       inc VID_CURSOR_Y
00027Er 2  AD 08 03       lda VID_CURSOR_Y
000281r 2  C9 18          cmp #24                       ; Past last row?
000283r 2  90 08          bcc @LFRecalc
000285r 2  20 rr rr       jsr VideoScroll
000288r 2  A9 17          lda #23
00028Ar 2  8D 08 03       sta VID_CURSOR_Y
00028Dr 2               @LFRecalc:
00028Dr 2  AE 07 03       ldx VID_CURSOR_X
000290r 2  AC 08 03       ldy VID_CURSOR_Y
000293r 2  20 rr rr       jsr VideoSetCursor
000296r 2  80 D2          bra @VideoChroutDone
000298r 2               
000298r 2               @VideoBS:
000298r 2  AD 07 03       lda VID_CURSOR_X
00029Br 2  F0 CD          beq @VideoChroutDone          ; Already at column 0, ignore
00029Dr 2  CE 07 03       dec VID_CURSOR_X
0002A0r 2  AE 07 03       ldx VID_CURSOR_X
0002A3r 2  AC 08 03       ldy VID_CURSOR_Y
0002A6r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
0002A9r 2  A9 20          lda #$20                      ; Write space to erase character
0002ABr 2  20 rr rr       jsr VideoPutChar
0002AEr 2  80 BA          bra @VideoChroutDone
0002B0r 2               
0002B0r 2               @VideoBEL:
0002B0r 2  20 rr rr       jsr Beep
0002B3r 2  80 B5          bra @VideoChroutDone
0002B5r 2               
0002B5r 2               ; VideoPrintStr — Print null-terminated string to video
0002B5r 2               ; Input: STR_PTR ($02-$03) points to string
0002B5r 2               ; Modifies: Flags, A, X, Y
0002B5r 2               VideoPrintStrImpl:
0002B5r 2  A0 00          ldy #$00
0002B7r 2               @VideoPrintStrLoop:
0002B7r 2  B1 02          lda (STR_PTR),y
0002B9r 2  F0 08          beq @VideoPrintStrDone        ; Exit on null terminator
0002BBr 2  5A             phy
0002BCr 2  20 rr rr       jsr VideoChroutImpl           ; Output character via video
0002BFr 2  7A             ply
0002C0r 2  C8             iny
0002C1r 2  D0 F4          bne @VideoPrintStrLoop        ; Max 256 chars per string
0002C3r 2               @VideoPrintStrDone:
0002C3r 2  60             rts
0002C4r 2               
0002C4r 2               ; Main entry point
0002C4r 2               Reset:
0002C4r 2  D8             cld                           ; Clear decimal mode
0002C5r 2  78             sei                           ; Disable interrupts
0002C6r 2               
0002C6r 2  A2 FF          ldx #$ff
0002C8r 2  9A             txs                           ; Reset the stack pointer
0002C9r 2               
0002C9r 2  A9 rr          lda #<Irq                     ; Initialize the IRQ pointer
0002CBr 2  8D 00 03       sta IRQ_PTR
0002CEr 2  A9 rr          lda #>Irq
0002D0r 2  8D 01 03       sta IRQ_PTR + 1
0002D3r 2               
0002D3r 2  A9 rr          lda #<Break                   ; Initialize the BRK pointer
0002D5r 2  8D 02 03       sta BRK_PTR
0002D8r 2  A9 rr          lda #>Break
0002DAr 2  8D 03 03       sta BRK_PTR + 1
0002DDr 2               
0002DDr 2  A9 rr          lda #<Nmi                     ; Initialize the NMI pointer
0002DFr 2  8D 04 03       sta NMI_PTR
0002E2r 2  A9 rr          lda #>Nmi
0002E4r 2  8D 05 03       sta NMI_PTR + 1
0002E7r 2               
0002E7r 2  20 rr rr       jsr InitBuffer                ; Initialize the input buffer
0002EAr 2  20 rr rr       jsr InitSC                    ; Initialize the Serial Card (6551)
0002EDr 2  20 rr rr       jsr InitSID                   ; Initialize the Sound Card (6581)
0002F0r 2  20 rr rr       jsr InitVideo                 ; Initialize the Video Card (TMS9918)
0002F3r 2  20 rr rr       jsr InitCharacters            ; Initialize the character set
0002F6r 2  20 rr rr       jsr InitKB                    ; Initialize the keyboard (VIA)
0002F9r 2  20 rr rr       jsr StInit                    ; Initialize CompactFlash (8-bit mode)
0002FCr 2               
0002FCr 2  A9 00          lda #$00                      ; Default to video output mode
0002FEr 2  8D 06 03       sta IO_MODE
000301r 2  9C 07 03       stz VID_CURSOR_X              ; Initialize video cursor state
000304r 2  9C 08 03       stz VID_CURSOR_Y
000307r 2  9C 09 03       stz VID_CURSOR_ADDR
00030Ar 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
00030Dr 2               
00030Dr 2  20 rr rr       jsr Beep                      ; Play the startup beep
000310r 2  20 rr rr       jsr Splash                    ; Draw the splash screen
000313r 2               
000313r 2  58             cli                           ; Enable interrupts
000314r 2               
000314r 2                 ; Boot menu — wait for keypress
000314r 2               @BootWait:
000314r 2  20 rr rr       jsr BufferSize
000317r 2  F0 FB          beq @BootWait                 ; Loop until a key is pressed
000319r 2  20 rr rr       jsr ReadBuffer                ; Read the keypress
00031Cr 2  C9 0D          cmp #$0D                      ; ENTER?
00031Er 2  F0 06          beq @BootBASIC
000320r 2  C9 1B          cmp #$1B                      ; ESC?
000322r 2  F0 08          beq @BootMonitor
000324r 2  80 EE          bra @BootWait                 ; Ignore other keys
000326r 2               @BootBASIC:
000326r 2  20 rr rr       jsr VideoClear                ; Clear screen before entering BASIC
000329r 2  4C rr rr       jmp BasEntry
00032Cr 2               @BootMonitor:
00032Cr 2  20 rr rr       jsr VideoClear                ; Clear screen before entering Monitor
00032Fr 2  4C rr rr       jmp MonitorEntry
000332r 2               
000332r 2               ; Initialize the Keyboard via VIA (IO 6)
000332r 2               ; Configures Port B (matrix) and Port A (PS/2) as inputs
000332r 2               ; CB2 low (enable matrix encoder), CA2 low (enable PS/2 encoder)
000332r 2               ; CB1 and CA1 falling-edge IRQs enabled
000332r 2               ; Modifies: Flags, A
000332r 2               InitKBImpl:
000332r 2  A9 00          lda #$00                      ; Port B all inputs (matrix keyboard data bus)
000334r 2  8D 02 94       sta GPIO_DDRB
000337r 2  A9 00          lda #$00                      ; Port A all inputs (PS/2 keyboard data bus)
000339r 2  8D 03 94       sta GPIO_DDRA
00033Cr 2                 ; PCR: CB2 low + CB1 neg + CA2 low + CA1 neg
00033Cr 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
00033Er 2  8D 0C 94       sta GPIO_PCR
000341r 2                 ; Enable both CB1 and CA1 interrupts
000341r 2  A9 92          lda #(GPIO_IER_SET | GPIO_INT_CB1 | GPIO_INT_CA1)
000343r 2  8D 0E 94       sta GPIO_IER
000346r 2  60             rts
000347r 2               
000347r 2               ; Initialize the Serial Card (6551)
000347r 2               ; Modifies: Flags, A
000347r 2               InitSCImpl:
000347r 2  A9 1F          lda     #$1F                  ; 8-N-1, 19200 baud
000349r 2  8D 03 90       sta     SC_CTRL
00034Cr 2  A9 09          lda     #$09                  ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
00034Er 2  8D 02 90       sta     SC_CMD
000351r 2  60             rts
000352r 2               
000352r 2               ; Initialze the Sound Card (6581)
000352r 2               ; Modifies: Flags, A, X
000352r 2               InitSIDImpl:
000352r 2  A9 00          lda #$00
000354r 2  A2 1D          ldx #$1D                      ; Clear all 29 SID registers
000356r 2               @InitSIDLoop:
000356r 2  9D 00 98       sta SID_V1_FREQ_LO,x          ; Clear register
000359r 2  CA             dex
00035Ar 2  10 FA          bpl @InitSIDLoop              ; Loop until all registers cleared
00035Cr 2  A9 0F          lda #$0F                      ; Set volume to maximum
00035Er 2  8D 18 98       sta SID_MODE_VOL
000361r 2  60             rts
000362r 2               
000362r 2               ; Initialize the Video Card (TMS9918)
000362r 2               ; Modifies: Flags, A, X
000362r 2               InitVideoImpl:
000362r 2  A2 00          ldx #$00                      ; Start with register 0
000364r 2               @InitVideoLoop:
000364r 2  BD rr rr       lda @InitVideoRegData,x       ; Load register value
000367r 2  8D 01 9C       sta VC_REG                    ; Write data byte
00036Ar 2  8A             txa
00036Br 2  09 80          ora #$80                      ; Set bit 7 to indicate register write
00036Dr 2  8D 01 9C       sta VC_REG                    ; Write register number
000370r 2  E8             inx
000371r 2  E0 08          cpx #$08                      ; Check if all 8 registers written
000373r 2  D0 EF          bne @InitVideoLoop            ; Continue until done
000375r 2  60             rts
000376r 2               @InitVideoRegData:
000376r 2  00             .byte $00                     ; R0: Mode control (no external video)
000377r 2  D0             .byte $D0                     ; R1: 16K, display on, interrupt off, text mode M1
000378r 2  00             .byte $00                     ; R2: Name table at $0000 (0x00 * 0x400)
000379r 2  00             .byte $00                     ; R3: Color table (not used in text mode)
00037Ar 2  01             .byte $01                     ; R4: Pattern table at $0800 (0x01 * 0x800)
00037Br 2  00             .byte $00                     ; R5: Sprite attribute table (not used in text mode)
00037Cr 2  00             .byte $00                     ; R6: Sprite pattern table (not used in text mode)
00037Dr 2  F0             .byte $F0                     ; R7: White text on black background
00037Er 2               
00037Er 2               ; Initialize the character set
00037Er 2               ; Modifies: Flags, A, X, Y
00037Er 2               InitCharacters:
00037Er 2                 ; Set VRAM write address to $0800 (pattern table base)
00037Er 2  A9 00          lda #$00                      ; Low byte of address
000380r 2  8D 01 9C       sta VC_REG
000383r 2  A9 48          lda #$48                      ; High byte ($08) OR $40 for write mode
000385r 2  8D 01 9C       sta VC_REG
000388r 2                 ; Set up source pointer
000388r 2  A9 rr          lda #<CharacterSet
00038Ar 2  85 02          sta STR_PTR                   ; Use STR_PTR ($02-$03) for character set pointer
00038Cr 2  A9 rr          lda #>CharacterSet
00038Er 2  85 03          sta STR_PTR + 1
000390r 2                 ; Copy 2048 bytes (8 pages of 256 bytes each)
000390r 2  A2 08          ldx #$08                      ; 8 pages to copy
000392r 2  A0 00          ldy #$00                      ; Byte counter within page
000394r 2               @InitCharPageLoop:
000394r 2  B1 02          lda (STR_PTR),y               ; Load from character set
000396r 2  8D 00 9C       sta VC_DATA                   ; Write to VRAM
000399r 2  C8             iny
00039Ar 2  D0 F8          bne @InitCharPageLoop         ; Loop until page complete (256 bytes)
00039Cr 2  E6 03          inc STR_PTR + 1               ; Move to next page
00039Er 2  CA             dex
00039Fr 2  D0 F3          bne @InitCharPageLoop         ; Loop for all 8 pages
0003A1r 2  60             rts
0003A2r 2               
0003A2r 2               ; Initialize the INPUT_BUFFER
0003A2r 2               ; Modifies: Flags, A
0003A2r 2               InitBuffer:
0003A2r 2  A9 00          lda #$00
0003A4r 2  85 00          sta READ_PTR                  ; Init read and write pointers
0003A6r 2  85 01          sta WRITE_PTR
0003A8r 2  60             rts
0003A9r 2               
0003A9r 2               ; Write a character from the A register to the INPUT_BUFFER
0003A9r 2               ; Modifies: Flags, X
0003A9r 2               WriteBufferImpl:
0003A9r 2  A6 01          ldx WRITE_PTR
0003ABr 2  9D 00 02       sta INPUT_BUFFER,x
0003AEr 2  E6 01          inc WRITE_PTR
0003B0r 2  60             rts
0003B1r 2               
0003B1r 2               ; Read a character from the INPUT_BUFFER and store it in A register
0003B1r 2               ; Modifies: Flags, X, A
0003B1r 2               ReadBufferImpl:
0003B1r 2  A6 00          ldx READ_PTR
0003B3r 2  BD 00 02       lda INPUT_BUFFER,x
0003B6r 2  E6 00          inc READ_PTR
0003B8r 2  60             rts
0003B9r 2               
0003B9r 2               ; Return in A register the number of unread bytes in the INPUT_BUFFER
0003B9r 2               ; Modifies: Flags, A
0003B9r 2               BufferSizeImpl:
0003B9r 2  A5 01          lda WRITE_PTR
0003BBr 2  38             sec
0003BCr 2  E5 00          sbc READ_PTR
0003BEr 2  60             rts
0003BFr 2               
0003BFr 2               ; Get a character from the INPUT_BUFFER if available
0003BFr 2               ; On return, carry flag indicates whether a character was available
0003BFr 2               ; If character available the character will be in the A register
0003BFr 2               ; Modifies: Flags, A
0003BFr 2               ChrinImpl:
0003BFr 2  DA             phx
0003C0r 2  20 rr rr       jsr BufferSize                ; Check for character available
0003C3r 2  F0 1E          beq @ChrinNoChar              ; Branch if no character available
0003C5r 2  20 rr rr       jsr ReadBuffer                ; Read the character from the buffer
0003C8r 2  20 rr rr       jsr Chrout                    ; Echo
0003CBr 2  48             pha
0003CCr 2  20 rr rr       jsr BufferSize
0003CFr 2  C9 B0          cmp #$B0                      ; Check if buffer is mostly full
0003D1r 2  90 07          bcc @ChrinNotFull             ; Branch if buffer size < $B0
0003D3r 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
0003D5r 2  8D 02 90       sta SC_CMD
0003D8r 2  80 05          bra @ChrinExit
0003DAr 2               @ChrinNotFull:
0003DAr 2  A9 09          lda #$09                      ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
0003DCr 2  8D 02 90       sta SC_CMD
0003DFr 2               @ChrinExit:
0003DFr 2  68             pla
0003E0r 2  FA             plx
0003E1r 2  38             sec
0003E2r 2  60             rts
0003E3r 2               @ChrinNoChar:
0003E3r 2  FA             plx
0003E4r 2  18             clc
0003E5r 2  60             rts
0003E6r 2               
0003E6r 2               ; Output a character from the A register to the Serial Card
0003E6r 2               ; Modifies: Flags
0003E6r 2               SerialChroutImpl:
0003E6r 2  8D 00 90       sta SC_DATA
0003E9r 2  48             pha
0003EAr 2               @ChroutWait:
0003EAr 2  AD 01 90       lda SC_STATUS
0003EDr 2  29 10          and #SC_STATUS_TDRE           ; Check if TX buffer not empty
0003EFr 2  F0 F9          beq @ChroutWait               ; Loop if TX buffer not empty
0003F1r 2  68             pla
0003F2r 2  60             rts
0003F3r 2               
0003F3r 2               ; SidPlayNote — Play a note on a SID voice
0003F3r 2               ; Input: A = voice (0-2), X = frequency low byte, Y = frequency high byte
0003F3r 2               ; Uses triangle waveform with standard ADSR (Attack=0, Decay=9, Sustain=A, Release=2)
0003F3r 2               ; Modifies: Flags, A
0003F3r 2               SidPlayNoteImpl:
0003F3r 2  C9 01          cmp #$01
0003F5r 2  F0 1A          beq @Voice2
0003F7r 2  C9 02          cmp #$02
0003F9r 2  F0 2C          beq @Voice3
0003FBr 2                 ; Voice 0
0003FBr 2  8E 00 98       stx SID_V1_FREQ_LO
0003FEr 2  8C 01 98       sty SID_V1_FREQ_HI
000401r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
000403r 2  8D 05 98       sta SID_V1_AD
000406r 2  A9 A2          lda #$A2                      ; Sustain = A, Release = 2
000408r 2  8D 06 98       sta SID_V1_SR
00040Br 2  A9 11          lda #$11                      ; Triangle wave + Gate on
00040Dr 2  8D 04 98       sta SID_V1_CTRL
000410r 2  60             rts
000411r 2               @Voice2:
000411r 2  8E 07 98       stx SID_V2_FREQ_LO
000414r 2  8C 08 98       sty SID_V2_FREQ_HI
000417r 2  A9 09          lda #$09
000419r 2  8D 0C 98       sta SID_V2_AD
00041Cr 2  A9 A2          lda #$A2
00041Er 2  8D 0D 98       sta SID_V2_SR
000421r 2  A9 11          lda #$11
000423r 2  8D 0B 98       sta SID_V2_CTRL
000426r 2  60             rts
000427r 2               @Voice3:
000427r 2  8E 0E 98       stx SID_V3_FREQ_LO
00042Ar 2  8C 0F 98       sty SID_V3_FREQ_HI
00042Dr 2  A9 09          lda #$09
00042Fr 2  8D 13 98       sta SID_V3_AD
000432r 2  A9 A2          lda #$A2
000434r 2  8D 14 98       sta SID_V3_SR
000437r 2  A9 11          lda #$11
000439r 2  8D 12 98       sta SID_V3_CTRL
00043Cr 2  60             rts
00043Dr 2               
00043Dr 2               ; SidSilence — Silence all 3 SID voices
00043Dr 2               ; Gates off all voices and zeros their frequencies
00043Dr 2               ; Modifies: Flags, A
00043Dr 2               SidSilenceImpl:
00043Dr 2  A9 10          lda #$10                      ; Triangle wave, Gate off
00043Fr 2  8D 04 98       sta SID_V1_CTRL
000442r 2  8D 0B 98       sta SID_V2_CTRL
000445r 2  8D 12 98       sta SID_V3_CTRL
000448r 2  A9 00          lda #$00
00044Ar 2  8D 00 98       sta SID_V1_FREQ_LO
00044Dr 2  8D 01 98       sta SID_V1_FREQ_HI
000450r 2  8D 07 98       sta SID_V2_FREQ_LO
000453r 2  8D 08 98       sta SID_V2_FREQ_HI
000456r 2  8D 0E 98       sta SID_V3_FREQ_LO
000459r 2  8D 0F 98       sta SID_V3_FREQ_HI
00045Cr 2  60             rts
00045Dr 2               
00045Dr 2               ; Play a short beep sound
00045Dr 2               ; Uses SidPlayNote on voice 0 with ~1000 Hz tone, then silences
00045Dr 2               ; Modifies: Flags, A, X, Y
00045Dr 2               BeepImpl:
00045Dr 2  A9 00          lda #$00                      ; Voice 0
00045Fr 2  A2 20          ldx #$20                      ; Frequency low byte (~1000 Hz)
000461r 2  A0 1F          ldy #$1F                      ; Frequency high byte
000463r 2  20 rr rr       jsr SidPlayNote
000466r 2                 ; Override ADSR for beep: fast decay, no sustain
000466r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
000468r 2  8D 05 98       sta SID_V1_AD
00046Br 2  A9 00          lda #$00                      ; Sustain = 0, Release = 0
00046Dr 2  8D 06 98       sta SID_V1_SR
000470r 2                 ; Delay for beep duration
000470r 2  A2 F0          ldx #$F0                      ; Outer loop counter
000472r 2               @BeepDelay1:
000472r 2  A0 FF          ldy #$FF                      ; Inner loop counter
000474r 2               @BeepDelay2:
000474r 2  88             dey
000475r 2  D0 FD          bne @BeepDelay2
000477r 2  CA             dex
000478r 2  D0 F8          bne @BeepDelay1
00047Ar 2  20 rr rr       jsr SidSilence                ; Gate off all voices
00047Dr 2  60             rts
00047Er 2               
00047Er 2               ; SysDelay — Delay for a specified number of centiseconds
00047Er 2               ; Input: A = count low byte, X = count high byte
00047Er 2               ; Uses VIA T1 in one-shot mode. 9999 cycles @ 1MHz = ~10ms per tick.
00047Er 2               ; Modifies: Flags, A
00047Er 2               SysDelayImpl:
00047Er 2  85 2C          sta DELAY_CNT
000480r 2  86 2D          stx DELAY_CNT + 1
000482r 2                 ; Return immediately if count is zero
000482r 2  05 2D          ora DELAY_CNT + 1
000484r 2  F0 2F          beq @DelayDone
000486r 2                 ; Configure T1 one-shot mode: clear ACR bit 6
000486r 2  AD 0B 94       lda GPIO_ACR
000489r 2  29 BF          and #%10111111
00048Br 2  8D 0B 94       sta GPIO_ACR
00048Er 2               @DelayLoop:
00048Er 2                 ; Load T1 latch: 9999 = $270F
00048Er 2  A9 0F          lda #$0F
000490r 2  8D 06 94       sta GPIO_T1LL
000493r 2  A9 27          lda #$27
000495r 2  8D 07 94       sta GPIO_T1LH
000498r 2                 ; Write T1CH to start countdown (also clears IFR T1 flag)
000498r 2  A9 27          lda #$27
00049Ar 2  8D 05 94       sta GPIO_T1CH
00049Dr 2               @DelayPoll:
00049Dr 2  AD 0D 94       lda GPIO_IFR
0004A0r 2  29 40          and #%01000000                ; T1 timeout flag
0004A2r 2  F0 F9          beq @DelayPoll
0004A4r 2                 ; Clear flag by reading T1CL
0004A4r 2  AD 04 94       lda GPIO_T1CL
0004A7r 2                 ; 16-bit decrement
0004A7r 2  A5 2C          lda DELAY_CNT
0004A9r 2  D0 02          bne @DelayDecLo
0004ABr 2  C6 2D          dec DELAY_CNT + 1
0004ADr 2               @DelayDecLo:
0004ADr 2  C6 2C          dec DELAY_CNT
0004AFr 2                 ; Loop until both bytes zero
0004AFr 2  A5 2C          lda DELAY_CNT
0004B1r 2  05 2D          ora DELAY_CNT + 1
0004B3r 2  D0 D9          bne @DelayLoop
0004B5r 2               @DelayDone:
0004B5r 2  60             rts
0004B6r 2               
0004B6r 2               ; SidSetVolume — Set SID master volume
0004B6r 2               ; Input: A = volume (0-15); upper nibble of SID_MODE_VOL is cleared (no filter)
0004B6r 2               ; Modifies: Flags, A
0004B6r 2               SidSetVolumeImpl:
0004B6r 2  29 0F          and #$0F
0004B8r 2  8D 18 98       sta SID_MODE_VOL
0004BBr 2  60             rts
0004BCr 2               
0004BCr 2               ; VideoSetColor — Set TMS9918 text color register
0004BCr 2               ; Input: A = color byte (high nibble = fg color, low nibble = bg color)
0004BCr 2               ; Modifies: Flags, A
0004BCr 2               VideoSetColorImpl:
0004BCr 2  8D 01 9C       sta VC_REG                    ; Data byte
0004BFr 2  A9 87          lda #$87                      ; Register 7 | $80 (write mode flag)
0004C1r 2  8D 01 9C       sta VC_REG
0004C4r 2  60             rts
0004C5r 2               
0004C5r 2               ; KBDisable — Disable both keyboard encoders for raw port access
0004C5r 2               ; Sets CB2 high (disable matrix encoder) and CA2 high (disable PS/2 encoder)
0004C5r 2               ; Modifies: Flags, A
0004C5r 2               KBDisable:
0004C5r 2  A9 EE          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0004C7r 2  8D 0C 94       sta GPIO_PCR
0004CAr 2  60             rts
0004CBr 2               
0004CBr 2               ; KBEnable — Re-enable both keyboard encoders
0004CBr 2               ; Sets CB2 low (enable matrix encoder) and CA2 low (enable PS/2 encoder)
0004CBr 2               ; Modifies: Flags, A
0004CBr 2               KBEnable:
0004CBr 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0004CDr 2  8D 0C 94       sta GPIO_PCR
0004D0r 2  60             rts
0004D1r 2               
0004D1r 2               ; ReadJoystick1 — Read joystick 1 on Port B
0004D1r 2               ; Temporarily disables matrix keyboard encoder (CB2 high) to read raw port data
0004D1r 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
0004D1r 2               ; Modifies: Flags, A
0004D1r 2               ReadJoystick1Impl:
0004D1r 2  78             sei                           ; Disable interrupts during raw port read
0004D2r 2  AD 0C 94       lda GPIO_PCR
0004D5r 2  48             pha                           ; Save current PCR state
0004D6r 2                 ; Set CB2 high to disable matrix encoder, preserve CA2 state
0004D6r 2  A9 EC          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0004D8r 2  8D 0C 94       sta GPIO_PCR
0004DBr 2  AD 00 94       lda GPIO_PORTB                ; Read raw joystick data from Port B
0004DEr 2  AA             tax                           ; Save result in X
0004DFr 2  68             pla                           ; Restore original PCR state
0004E0r 2  8D 0C 94       sta GPIO_PCR
0004E3r 2  8A             txa                           ; Return result in A
0004E4r 2  58             cli                           ; Re-enable interrupts
0004E5r 2  60             rts
0004E6r 2               
0004E6r 2               ; ReadJoystick2 — Read joystick 2 on Port A
0004E6r 2               ; Temporarily disables PS/2 keyboard encoder (CA2 high) to read raw port data
0004E6r 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
0004E6r 2               ; Modifies: Flags, A
0004E6r 2               ReadJoystick2Impl:
0004E6r 2  78             sei                           ; Disable interrupts during raw port read
0004E7r 2  AD 0C 94       lda GPIO_PCR
0004EAr 2  48             pha                           ; Save current PCR state
0004EBr 2                 ; Set CA2 high to disable PS/2 encoder, preserve CB2 state
0004EBr 2  A9 CE          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0004EDr 2  8D 0C 94       sta GPIO_PCR
0004F0r 2  AD 01 94       lda GPIO_PORTA                ; Read raw joystick data from Port A
0004F3r 2  AA             tax                           ; Save result in X
0004F4r 2  68             pla                           ; Restore original PCR state
0004F5r 2  8D 0C 94       sta GPIO_PCR
0004F8r 2  8A             txa                           ; Return result in A
0004F9r 2  58             cli                           ; Re-enable interrupts
0004FAr 2  60             rts
0004FBr 2               
0004FBr 2               ; === BCD Conversion Helpers ===
0004FBr 2               
0004FBr 2               ; BcdToBin — Convert BCD byte to binary
0004FBr 2               ; Input: A = BCD value (e.g. $35 represents 35)
0004FBr 2               ; Output: A = binary value (e.g. 35 = $23)
0004FBr 2               ; Modifies: Flags
0004FBr 2               BcdToBin:
0004FBr 2  48             pha
0004FCr 2  4A             lsr a                         ; Shift tens digit to low nibble
0004FDr 2  4A             lsr a
0004FEr 2  4A             lsr a
0004FFr 2  4A             lsr a                         ; A = tens digit (0-9)
000500r 2  0A             asl a                         ; A = tens * 2
000501r 2  8D 0C 03       sta RTC_TMP
000504r 2  0A             asl a                         ; A = tens * 4
000505r 2  0A             asl a                         ; A = tens * 8
000506r 2  18             clc
000507r 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 (8 + 2)
00050Ar 2  8D 0C 03       sta RTC_TMP
00050Dr 2  68             pla
00050Er 2  29 0F          and #$0F                      ; A = ones digit
000510r 2  18             clc
000511r 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 + ones = binary
000514r 2  60             rts
000515r 2               
000515r 2               ; BinToBcd — Convert binary byte to BCD
000515r 2               ; Input: A = binary value (0-99)
000515r 2               ; Output: A = BCD value
000515r 2               ; Modifies: Flags, X
000515r 2               BinToBcd:
000515r 2  A2 FF          ldx #$FF                      ; Tens counter (starts at -1)
000517r 2               @BinToBcdLoop:
000517r 2  E8             inx
000518r 2  38             sec
000519r 2  E9 0A          sbc #10
00051Br 2  B0 FA          bcs @BinToBcdLoop             ; Count tens
00051Dr 2  69 0A          adc #10                       ; Restore ones (carry clear, so adds 10 + 0)
00051Fr 2  8D 0C 03       sta RTC_TMP                   ; Save ones digit
000522r 2  8A             txa                           ; A = tens digit
000523r 2  0A             asl a
000524r 2  0A             asl a
000525r 2  0A             asl a
000526r 2  0A             asl a                         ; Shift tens to high nibble
000527r 2  0D 0C 03       ora RTC_TMP                   ; Combine with ones
00052Ar 2  60             rts
00052Br 2               
00052Br 2               ; === DS1511Y RTC Routines ===
00052Br 2               
00052Br 2               ; RtcReadTime — Read current time from DS1511Y
00052Br 2               ; Output: A = hours (binary), X = minutes (binary), Y = seconds (binary)
00052Br 2               ; Modifies: Flags
00052Br 2               RtcReadTimeImpl:
00052Br 2  AD 02 88       lda RTC_HR
00052Er 2  20 rr rr       jsr BcdToBin
000531r 2  48             pha                           ; Save hours
000532r 2  AD 01 88       lda RTC_MIN
000535r 2  20 rr rr       jsr BcdToBin
000538r 2  AA             tax                           ; X = minutes
000539r 2  AD 00 88       lda RTC_SEC
00053Cr 2  20 rr rr       jsr BcdToBin
00053Fr 2  A8             tay                           ; Y = seconds
000540r 2  68             pla                           ; A = hours
000541r 2  60             rts
000542r 2               
000542r 2               ; RtcReadDate — Read current date from DS1511Y
000542r 2               ; Output: A = day of month (binary), X = month (binary), Y = year (binary)
000542r 2               ;         RTC_BUF_CENT = century (binary)
000542r 2               ; Modifies: Flags
000542r 2               RtcReadDateImpl:
000542r 2  AD 07 88       lda RTC_CENT
000545r 2  20 rr rr       jsr BcdToBin
000548r 2  8D 0B 03       sta RTC_BUF_CENT              ; Store century in buffer
00054Br 2  AD 05 88       lda RTC_MON
00054Er 2  20 rr rr       jsr BcdToBin
000551r 2  AA             tax                           ; X = month
000552r 2  AD 06 88       lda RTC_YR
000555r 2  20 rr rr       jsr BcdToBin
000558r 2  A8             tay                           ; Y = year
000559r 2  AD 04 88       lda RTC_DATE
00055Cr 2  20 rr rr       jsr BcdToBin                  ; A = day of month
00055Fr 2  60             rts
000560r 2               
000560r 2               ; RtcWriteTime — Set DS1511Y time
000560r 2               ; Input: A = hours (binary), X = minutes (binary), Y = seconds (binary)
000560r 2               ; Modifies: Flags, A, X
000560r 2               RtcWriteTimeImpl:
000560r 2  48             pha                           ; Save hours
000561r 2  DA             phx                           ; Save minutes
000562r 2  5A             phy                           ; Save seconds
000563r 2                 ; Set TE bit to inhibit update transfers
000563r 2  AD 0F 88       lda RTC_CTRL_B
000566r 2  09 80          ora #RTC_CTRL_B_TE
000568r 2  8D 0F 88       sta RTC_CTRL_B
00056Br 2                 ; Write seconds
00056Br 2  68             pla                           ; A = seconds
00056Cr 2  20 rr rr       jsr BinToBcd
00056Fr 2  8D 00 88       sta RTC_SEC
000572r 2                 ; Write minutes
000572r 2  68             pla                           ; A = minutes
000573r 2  20 rr rr       jsr BinToBcd
000576r 2  8D 01 88       sta RTC_MIN
000579r 2                 ; Write hours
000579r 2  68             pla                           ; A = hours
00057Ar 2  20 rr rr       jsr BinToBcd
00057Dr 2  8D 02 88       sta RTC_HR
000580r 2                 ; Clear TE bit to resume updates
000580r 2  AD 0F 88       lda RTC_CTRL_B
000583r 2  29 7F          and #<~RTC_CTRL_B_TE
000585r 2  8D 0F 88       sta RTC_CTRL_B
000588r 2  60             rts
000589r 2               
000589r 2               ; RtcWriteDate — Set DS1511Y date
000589r 2               ; Input: A = day of month (binary), X = month (binary), Y = year (binary)
000589r 2               ;        RTC_BUF_CENT = century (binary)
000589r 2               ; Modifies: Flags, A, X
000589r 2               RtcWriteDateImpl:
000589r 2  48             pha                           ; Save day
00058Ar 2  DA             phx                           ; Save month
00058Br 2  5A             phy                           ; Save year
00058Cr 2                 ; Set TE bit to inhibit update transfers
00058Cr 2  AD 0F 88       lda RTC_CTRL_B
00058Fr 2  09 80          ora #RTC_CTRL_B_TE
000591r 2  8D 0F 88       sta RTC_CTRL_B
000594r 2                 ; Write century
000594r 2  AD 0B 03       lda RTC_BUF_CENT
000597r 2  20 rr rr       jsr BinToBcd
00059Ar 2  8D 07 88       sta RTC_CENT
00059Dr 2                 ; Write year
00059Dr 2  68             pla                           ; A = year
00059Er 2  20 rr rr       jsr BinToBcd
0005A1r 2  8D 06 88       sta RTC_YR
0005A4r 2                 ; Write month
0005A4r 2  68             pla                           ; A = month
0005A5r 2  20 rr rr       jsr BinToBcd
0005A8r 2  8D 05 88       sta RTC_MON
0005ABr 2                 ; Write day
0005ABr 2  68             pla                           ; A = day
0005ACr 2  20 rr rr       jsr BinToBcd
0005AFr 2  8D 04 88       sta RTC_DATE
0005B2r 2                 ; Clear TE bit to resume updates
0005B2r 2  AD 0F 88       lda RTC_CTRL_B
0005B5r 2  29 7F          and #<~RTC_CTRL_B_TE
0005B7r 2  8D 0F 88       sta RTC_CTRL_B
0005BAr 2  60             rts
0005BBr 2               
0005BBr 2               ; RtcReadNVRAM — Read a byte from DS1511Y NVRAM
0005BBr 2               ; Input: X = NVRAM address ($00-$FF)
0005BBr 2               ; Output: A = data byte
0005BBr 2               ; Modifies: Flags
0005BBr 2               RtcReadNVRAMImpl:
0005BBr 2  8E 10 88       stx RTC_RAM_ADDR
0005BEr 2  AD 13 88       lda RTC_RAM_DATA
0005C1r 2  60             rts
0005C2r 2               
0005C2r 2               ; RtcWriteNVRAM — Write a byte to DS1511Y NVRAM
0005C2r 2               ; Input: X = NVRAM address ($00-$FF), A = data byte
0005C2r 2               ; Modifies: Flags
0005C2r 2               RtcWriteNVRAMImpl:
0005C2r 2  8E 10 88       stx RTC_RAM_ADDR
0005C5r 2  8D 13 88       sta RTC_RAM_DATA
0005C8r 2  60             rts
0005C9r 2               
0005C9r 2               ; === CompactFlash Storage Driver (True 8-bit IDE Mode) ===
0005C9r 2               
0005C9r 2               ; StWaitReady — Wait for CompactFlash to become ready
0005C9r 2               ; Polls ST_STATUS until BSY=0 and RDY=1
0005C9r 2               ; Output: Carry clear = ready, Carry set = error (ERR bit set)
0005C9r 2               ; Modifies: Flags, A
0005C9r 2               StWaitReadyImpl:
0005C9r 2               @StWaitBsy:
0005C9r 2  AD 07 8C       lda ST_STATUS
0005CCr 2  29 80          and #ST_STATUS_BSY            ; Check BSY bit
0005CEr 2  D0 F9          bne @StWaitBsy                ; Loop while busy
0005D0r 2  AD 07 8C       lda ST_STATUS
0005D3r 2  29 40          and #ST_STATUS_RDY            ; Check RDY bit
0005D5r 2  F0 F2          beq @StWaitBsy                ; Loop until ready
0005D7r 2  AD 07 8C       lda ST_STATUS
0005DAr 2  29 01          and #ST_STATUS_ERR            ; Check ERR bit
0005DCr 2  D0 02          bne @StWaitErr
0005DEr 2  18             clc                           ; Ready, no error
0005DFr 2  60             rts
0005E0r 2               @StWaitErr:
0005E0r 2  38             sec                           ; Error condition
0005E1r 2  60             rts
0005E2r 2               
0005E2r 2               ; StWaitDrq — Wait for CompactFlash data request
0005E2r 2               ; Polls ST_STATUS until BSY=0 and DRQ=1
0005E2r 2               ; Output: Carry clear = DRQ active, Carry set = error
0005E2r 2               ; Modifies: Flags, A
0005E2r 2               StWaitDrq:
0005E2r 2               @StDrqBsy:
0005E2r 2  AD 07 8C       lda ST_STATUS
0005E5r 2  29 80          and #ST_STATUS_BSY
0005E7r 2  D0 F9          bne @StDrqBsy
0005E9r 2  AD 07 8C       lda ST_STATUS
0005ECr 2  29 01          and #ST_STATUS_ERR
0005EEr 2  D0 09          bne @StDrqErr
0005F0r 2  AD 07 8C       lda ST_STATUS
0005F3r 2  29 08          and #ST_STATUS_DRQ
0005F5r 2  F0 EB          beq @StDrqBsy
0005F7r 2  18             clc
0005F8r 2  60             rts
0005F9r 2               @StDrqErr:
0005F9r 2  38             sec
0005FAr 2  60             rts
0005FBr 2               
0005FBr 2               ; StInit — Initialize CompactFlash for 8-bit data transfers
0005FBr 2               ; Issues Set Features command with subcommand $01 (enable 8-bit I/O)
0005FBr 2               ; Output: Carry clear = success, Carry set = error
0005FBr 2               ; Modifies: Flags, A
0005FBr 2               StInit:
0005FBr 2  20 rr rr       jsr StWaitReady
0005FEr 2  B0 0D          bcs @StInitDone
000600r 2  A9 01          lda #ST_FEAT_8BIT             ; Feature: enable 8-bit data I/O
000602r 2  8D 01 8C       sta ST_FEATURE
000605r 2  A9 EF          lda #ST_CMD_SET_FEAT          ; Set Features command
000607r 2  8D 07 8C       sta ST_CMD
00060Ar 2  20 rr rr       jsr StWaitReady               ; Wait for command completion
00060Dr 2               @StInitDone:
00060Dr 2  60             rts
00060Er 2               
00060Er 2               ; StSetupLba — Set up LBA registers from CF_LBA zero page variables
00060Er 2               ; Also sets sector count to 1 and selects master drive in LBA mode
00060Er 2               ; Modifies: Flags, A
00060Er 2               StSetupLba:
00060Er 2  A9 01          lda #$01
000610r 2  8D 02 8C       sta ST_SECT_CNT               ; Always 1 sector
000613r 2  A5 26          lda CF_LBA
000615r 2  8D 03 8C       sta ST_LBA_0                  ; LBA bits 0-7
000618r 2  A5 27          lda CF_LBA + 1
00061Ar 2  8D 04 8C       sta ST_LBA_1                  ; LBA bits 8-15
00061Dr 2  A5 28          lda CF_LBA + 2
00061Fr 2  8D 05 8C       sta ST_LBA_2                  ; LBA bits 16-23
000622r 2  A5 29          lda CF_LBA + 3
000624r 2  29 0F          and #$0F                      ; Mask to 4 bits (LBA 24-27)
000626r 2  09 E0          ora #ST_LBA3_MASTER           ; LBA mode, master drive
000628r 2  8D 06 8C       sta ST_LBA_3
00062Br 2  60             rts
00062Cr 2               
00062Cr 2               ; StReadSector — Read one 512-byte sector from CompactFlash
00062Cr 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = destination pointer
00062Cr 2               ; Output: Carry clear = success, Carry set = error
00062Cr 2               ;         CF_BUF_PTR advanced by 512 bytes on success
00062Cr 2               ; Modifies: Flags, A, X, Y
00062Cr 2               StReadSectorImpl:
00062Cr 2  20 rr rr       jsr StWaitReady
00062Fr 2  B0 1F          bcs @StReadDone
000631r 2  20 rr rr       jsr StSetupLba
000634r 2  A9 20          lda #ST_CMD_READ              ; Issue read command
000636r 2  8D 07 8C       sta ST_CMD
000639r 2  20 rr rr       jsr StWaitDrq                 ; Wait for data ready
00063Cr 2  B0 12          bcs @StReadDone
00063Er 2                 ; Read 512 bytes: 2 pages of 256 bytes
00063Er 2  A0 00          ldy #$00
000640r 2  A2 02          ldx #$02                      ; 2 pages
000642r 2               @StReadPage:
000642r 2  AD 00 8C       lda ST_DATA                   ; Read byte from CF
000645r 2  91 24          sta (CF_BUF_PTR),y            ; Store to destination
000647r 2  C8             iny
000648r 2  D0 F8          bne @StReadPage               ; Loop for 256 bytes
00064Ar 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
00064Cr 2  CA             dex
00064Dr 2  D0 F3          bne @StReadPage
00064Fr 2  18             clc                           ; Success
000650r 2               @StReadDone:
000650r 2  60             rts
000651r 2               
000651r 2               ; StWriteSector — Write one 512-byte sector to CompactFlash
000651r 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = source pointer
000651r 2               ; Output: Carry clear = success, Carry set = error
000651r 2               ;         CF_BUF_PTR advanced by 512 bytes on success
000651r 2               ; Modifies: Flags, A, X, Y
000651r 2               StWriteSectorImpl:
000651r 2  20 rr rr       jsr StWaitReady
000654r 2  B0 21          bcs @StWriteDone
000656r 2  20 rr rr       jsr StSetupLba
000659r 2  A9 30          lda #ST_CMD_WRITE             ; Issue write command
00065Br 2  8D 07 8C       sta ST_CMD
00065Er 2  20 rr rr       jsr StWaitDrq                 ; Wait for data request
000661r 2  B0 14          bcs @StWriteDone
000663r 2                 ; Write 512 bytes: 2 pages of 256 bytes
000663r 2  A0 00          ldy #$00
000665r 2  A2 02          ldx #$02                      ; 2 pages
000667r 2               @StWritePage:
000667r 2  B1 24          lda (CF_BUF_PTR),y            ; Load from source
000669r 2  8D 00 8C       sta ST_DATA                   ; Write byte to CF
00066Cr 2  C8             iny
00066Dr 2  D0 F8          bne @StWritePage              ; Loop for 256 bytes
00066Fr 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
000671r 2  CA             dex
000672r 2  D0 F3          bne @StWritePage
000674r 2  20 rr rr       jsr StWaitReady               ; Wait for write to complete
000677r 2               @StWriteDone:
000677r 2  60             rts
000678r 2               
000678r 2               ; === Simple Custom Filesystem ===
000678r 2               ; Directory at LBA 0: 16 entries x 32 bytes = 512 bytes
000678r 2               ; Entry format:
000678r 2               ;   $00-$07: 8-byte filename (space-padded)
000678r 2               ;   $08-$0A: 3-byte extension (space-padded)
000678r 2               ;   $0B:     flags (bit 0 = in use)
000678r 2               ;   $0C-$0D: start sector (little-endian)
000678r 2               ;   $0E-$0F: file size in bytes (little-endian)
000678r 2               ;   $10-$1F: reserved (16 bytes)
000678r 2               
000678r 2               ; FsParseName — Parse null-terminated filename at STR_PTR into FS_FNAME_BUF
000678r 2               ; Converts "NAME.EXT" into 8+3 space-padded format
000678r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000678r 2               ; Output: FS_FNAME_BUF filled with padded 8+3 name
000678r 2               ; Modifies: Flags, A, X, Y
000678r 2               FsParseName:
000678r 2                 ; Fill FS_FNAME_BUF with spaces
000678r 2  A9 20          lda #$20
00067Ar 2  A2 0A          ldx #10
00067Cr 2               @FsParseClr:
00067Cr 2  9D 50 03       sta FS_FNAME_BUF,x
00067Fr 2  CA             dex
000680r 2  10 FA          bpl @FsParseClr
000682r 2                 ; Copy name part (up to 8 chars, stop at '.' or null)
000682r 2  A0 00          ldy #$00                      ; Source index
000684r 2  A2 00          ldx #$00                      ; Dest index (name portion)
000686r 2               @FsParseName:
000686r 2  B1 02          lda (STR_PTR),y
000688r 2  F0 35          beq @FsParseDone              ; Null terminator — no extension
00068Ar 2  C9 2E          cmp #'.'
00068Cr 2  F0 15          beq @FsParseExt               ; Found dot — start extension
00068Er 2  E0 08          cpx #$08
000690r 2  B0 0E          bcs @FsParseSkipName          ; Already 8 chars, skip extras
000692r 2                 ; Convert lowercase to uppercase
000692r 2  C9 61          cmp #'a'
000694r 2  90 06          bcc @FsStoreNameChar
000696r 2  C9 7B          cmp #'z' + 1
000698r 2  B0 02          bcs @FsStoreNameChar
00069Ar 2  29 DF          and #$DF                      ; Clear bit 5 to uppercase
00069Cr 2               @FsStoreNameChar:
00069Cr 2  9D 50 03       sta FS_FNAME_BUF,x
00069Fr 2  E8             inx
0006A0r 2               @FsParseSkipName:
0006A0r 2  C8             iny
0006A1r 2  80 E3          bra @FsParseName
0006A3r 2               @FsParseExt:
0006A3r 2  C8             iny                           ; Skip the dot
0006A4r 2  A2 08          ldx #$08                      ; Extension starts at offset 8
0006A6r 2               @FsParseExtLoop:
0006A6r 2  B1 02          lda (STR_PTR),y
0006A8r 2  F0 15          beq @FsParseDone              ; Null terminator
0006AAr 2  E0 0B          cpx #$0B
0006ACr 2  B0 11          bcs @FsParseDone              ; Max 3 ext chars
0006AEr 2                 ; Convert lowercase to uppercase
0006AEr 2  C9 61          cmp #'a'
0006B0r 2  90 06          bcc @FsStoreExtChar
0006B2r 2  C9 7B          cmp #'z' + 1
0006B4r 2  B0 02          bcs @FsStoreExtChar
0006B6r 2  29 DF          and #$DF
0006B8r 2               @FsStoreExtChar:
0006B8r 2  9D 50 03       sta FS_FNAME_BUF,x
0006BBr 2  E8             inx
0006BCr 2  C8             iny
0006BDr 2  80 E7          bra @FsParseExtLoop
0006BFr 2               @FsParseDone:
0006BFr 2  60             rts
0006C0r 2               
0006C0r 2               ; FsReadDir — Read directory sector (LBA 0) into FS_SECTOR_BUF
0006C0r 2               ; Output: Carry clear = success, Carry set = error
0006C0r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
0006C0r 2               FsReadDir:
0006C0r 2  64 26          stz CF_LBA                    ; LBA = 0 (directory sector)
0006C2r 2  64 27          stz CF_LBA + 1
0006C4r 2  64 28          stz CF_LBA + 2
0006C6r 2  64 29          stz CF_LBA + 3
0006C8r 2  A9 00          lda #<FS_SECTOR_BUF
0006CAr 2  85 24          sta CF_BUF_PTR
0006CCr 2  A9 06          lda #>FS_SECTOR_BUF
0006CEr 2  85 25          sta CF_BUF_PTR + 1
0006D0r 2  4C rr rr       jmp StReadSector
0006D3r 2               
0006D3r 2               ; FsWriteDir — Write directory sector from FS_SECTOR_BUF to LBA 0
0006D3r 2               ; Output: Carry clear = success, Carry set = error
0006D3r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
0006D3r 2               FsWriteDir:
0006D3r 2  64 26          stz CF_LBA
0006D5r 2  64 27          stz CF_LBA + 1
0006D7r 2  64 28          stz CF_LBA + 2
0006D9r 2  64 29          stz CF_LBA + 3
0006DBr 2  A9 00          lda #<FS_SECTOR_BUF
0006DDr 2  85 24          sta CF_BUF_PTR
0006DFr 2  A9 06          lda #>FS_SECTOR_BUF
0006E1r 2  85 25          sta CF_BUF_PTR + 1
0006E3r 2  4C rr rr       jmp StWriteSector
0006E6r 2               
0006E6r 2               ; FsFindFile — Search directory for filename in FS_FNAME_BUF
0006E6r 2               ; Must call FsReadDir first to load directory into FS_SECTOR_BUF
0006E6r 2               ; Output: Carry clear = found, X = entry index (0-15), CF_BUF_PTR points to entry
0006E6r 2               ;         Carry set = not found
0006E6r 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
0006E6r 2               FsFindFile:
0006E6r 2  A9 00          lda #<FS_SECTOR_BUF
0006E8r 2  85 24          sta CF_BUF_PTR
0006EAr 2  A9 06          lda #>FS_SECTOR_BUF
0006ECr 2  85 25          sta CF_BUF_PTR + 1
0006EEr 2  A2 00          ldx #$00                      ; Entry index
0006F0r 2               @FsFindLoop:
0006F0r 2                 ; Check if entry is in use
0006F0r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0006F2r 2  B1 24          lda (CF_BUF_PTR),y
0006F4r 2  29 01          and #FS_FLAG_USED
0006F6r 2  F0 13          beq @FsFindNext               ; Skip unused entries
0006F8r 2                 ; Compare 11-byte filename
0006F8r 2  A0 00          ldy #$00
0006FAr 2               @FsFindCmp:
0006FAr 2  B1 24          lda (CF_BUF_PTR),y
0006FCr 2  D9 50 03       cmp FS_FNAME_BUF,y
0006FFr 2  D0 0A          bne @FsFindNext               ; Mismatch
000701r 2  C8             iny
000702r 2  C0 0B          cpy #11
000704r 2  D0 F4          bne @FsFindCmp
000706r 2                 ; Match found
000706r 2  8E 4D 03       stx FS_DIR_IDX
000709r 2  18             clc
00070Ar 2  60             rts
00070Br 2               @FsFindNext:
00070Br 2                 ; Advance CF_BUF_PTR by 32 (FS_ENTRY_SIZE)
00070Br 2  A5 24          lda CF_BUF_PTR
00070Dr 2  18             clc
00070Er 2  69 20          adc #FS_ENTRY_SIZE
000710r 2  85 24          sta CF_BUF_PTR
000712r 2  90 02          bcc @FsFindNoCarry
000714r 2  E6 25          inc CF_BUF_PTR + 1
000716r 2               @FsFindNoCarry:
000716r 2  E8             inx
000717r 2  E0 10          cpx #FS_MAX_FILES
000719r 2  D0 D5          bne @FsFindLoop
00071Br 2  38             sec                           ; Not found
00071Cr 2  60             rts
00071Dr 2               
00071Dr 2               ; FsFindFree — Find first free directory entry
00071Dr 2               ; Must call FsReadDir first
00071Dr 2               ; Output: Carry clear = found, X = entry index, CF_BUF_PTR points to entry
00071Dr 2               ;         Carry set = directory full
00071Dr 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
00071Dr 2               FsFindFree:
00071Dr 2  A9 00          lda #<FS_SECTOR_BUF
00071Fr 2  85 24          sta CF_BUF_PTR
000721r 2  A9 06          lda #>FS_SECTOR_BUF
000723r 2  85 25          sta CF_BUF_PTR + 1
000725r 2  A2 00          ldx #$00
000727r 2               @FsFreeLoop:
000727r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000729r 2  B1 24          lda (CF_BUF_PTR),y
00072Br 2  29 01          and #FS_FLAG_USED
00072Dr 2  F0 12          beq @FsFreeFound              ; Found unused entry
00072Fr 2                 ; Advance by 32
00072Fr 2  A5 24          lda CF_BUF_PTR
000731r 2  18             clc
000732r 2  69 20          adc #FS_ENTRY_SIZE
000734r 2  85 24          sta CF_BUF_PTR
000736r 2  90 02          bcc @FsFreeNoCarry
000738r 2  E6 25          inc CF_BUF_PTR + 1
00073Ar 2               @FsFreeNoCarry:
00073Ar 2  E8             inx
00073Br 2  E0 10          cpx #FS_MAX_FILES
00073Dr 2  D0 E8          bne @FsFreeLoop
00073Fr 2  38             sec                           ; Directory full
000740r 2  60             rts
000741r 2               @FsFreeFound:
000741r 2  8E 4D 03       stx FS_DIR_IDX
000744r 2  18             clc
000745r 2  60             rts
000746r 2               
000746r 2               ; FsCalcNextSec — Calculate next free sector by scanning all directory entries
000746r 2               ; Must call FsReadDir first
000746r 2               ; Output: FS_NEXT_SEC = first free sector after all used files
000746r 2               ; Modifies: Flags, A, X, Y
000746r 2               FsCalcNextSec:
000746r 2  A9 01          lda #<FS_DATA_START           ; Start with first data sector
000748r 2  8D 4E 03       sta FS_NEXT_SEC
00074Br 2  A9 00          lda #>FS_DATA_START
00074Dr 2  8D 4F 03       sta FS_NEXT_SEC + 1
000750r 2                 ; Scan all entries to find highest used sector + file sector count
000750r 2  A9 00          lda #<FS_SECTOR_BUF
000752r 2  85 24          sta CF_BUF_PTR
000754r 2  A9 06          lda #>FS_SECTOR_BUF
000756r 2  85 25          sta CF_BUF_PTR + 1
000758r 2  A2 00          ldx #$00
00075Ar 2               @FsCalcLoop:
00075Ar 2  A0 0B          ldy #FS_ENTRY_FLAGS
00075Cr 2  B1 24          lda (CF_BUF_PTR),y
00075Er 2  29 01          and #FS_FLAG_USED
000760r 2  F0 51          beq @FsCalcNext               ; Skip unused
000762r 2                 ; Get start sector + ceil(size/512)
000762r 2  A0 0C          ldy #FS_ENTRY_START
000764r 2  B1 24          lda (CF_BUF_PTR),y
000766r 2  8D 48 03       sta FS_START_SEC
000769r 2  C8             iny
00076Ar 2  B1 24          lda (CF_BUF_PTR),y
00076Cr 2  8D 49 03       sta FS_START_SEC + 1
00076Fr 2                 ; Get file size
00076Fr 2  A0 0E          ldy #FS_ENTRY_FSIZE
000771r 2  B1 24          lda (CF_BUF_PTR),y
000773r 2  8D 4A 03       sta FS_FILE_SIZE
000776r 2  C8             iny
000777r 2  B1 24          lda (CF_BUF_PTR),y
000779r 2  8D 4B 03       sta FS_FILE_SIZE + 1
00077Cr 2                 ; Calculate sectors used = (size + 511) / 512 = (size + 511) >> 9
00077Cr 2                 ; = (size_hi + 1) if size_lo > 0, else size_hi / 2... simplify:
00077Cr 2                 ; sectors = (size >> 9) rounded up = high_byte >> 1, plus 1 if any remainder
00077Cr 2  AD 4B 03       lda FS_FILE_SIZE + 1          ; High byte of size
00077Fr 2  4A             lsr a                         ; Divide by 2 (each sector = 512 = 2 pages)
000780r 2  8D 4C 03       sta FS_SEC_COUNT
000783r 2                 ; Check if there's a remainder (low byte != 0 or high byte bit 0 was set)
000783r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000786r 2  29 01          and #$01                      ; Was high byte odd?
000788r 2  D0 05          bne @FsCalcRound
00078Ar 2  AD 4A 03       lda FS_FILE_SIZE              ; Low byte non-zero?
00078Dr 2  F0 03          beq @FsCalcNoRound
00078Fr 2               @FsCalcRound:
00078Fr 2  EE 4C 03       inc FS_SEC_COUNT              ; Round up
000792r 2               @FsCalcNoRound:
000792r 2                 ; End sector = start + sector count
000792r 2  AD 48 03       lda FS_START_SEC
000795r 2  18             clc
000796r 2  6D 4C 03       adc FS_SEC_COUNT
000799r 2  48             pha
00079Ar 2  AD 49 03       lda FS_START_SEC + 1
00079Dr 2  69 00          adc #$00
00079Fr 2  AA             tax                           ; X = end sector high
0007A0r 2  68             pla                           ; A = end sector low
0007A1r 2                 ; Compare with FS_NEXT_SEC — keep the larger value
0007A1r 2  EC 4F 03       cpx FS_NEXT_SEC + 1
0007A4r 2  90 0D          bcc @FsCalcNext               ; End < FS_NEXT_SEC, skip
0007A6r 2  D0 05          bne @FsCalcUpdate             ; End high > FS_NEXT_SEC high, update
0007A8r 2  CD 4E 03       cmp FS_NEXT_SEC
0007ABr 2  90 06          bcc @FsCalcNext               ; End low < FS_NEXT_SEC low
0007ADr 2               @FsCalcUpdate:
0007ADr 2  8D 4E 03       sta FS_NEXT_SEC
0007B0r 2  8E 4F 03       stx FS_NEXT_SEC + 1
0007B3r 2               @FsCalcNext:
0007B3r 2                 ; Advance CF_BUF_PTR by 32
0007B3r 2  A5 24          lda CF_BUF_PTR
0007B5r 2  18             clc
0007B6r 2  69 20          adc #FS_ENTRY_SIZE
0007B8r 2  85 24          sta CF_BUF_PTR
0007BAr 2  90 02          bcc @FsCalcNoCarry
0007BCr 2  E6 25          inc CF_BUF_PTR + 1
0007BEr 2               @FsCalcNoCarry:
0007BEr 2  E8             inx
0007BFr 2  E0 10          cpx #FS_MAX_FILES
0007C1r 2  D0 97          bne @FsCalcLoop
0007C3r 2  60             rts
0007C4r 2               
0007C4r 2               ; FsDirectory — Print directory listing of all used entries
0007C4r 2               ; Output via Chrout (respects current IO_MODE)
0007C4r 2               ; Modifies: Flags, A, X, Y
0007C4r 2               FsDirectory:
0007C4r 2  20 rr rr       jsr FsReadDir                 ; Load directory sector
0007C7r 2  90 01          bcc @FsDirStart
0007C9r 2  60             rts                           ; Error reading directory
0007CAr 2               @FsDirStart:
0007CAr 2  A9 00          lda #<FS_SECTOR_BUF
0007CCr 2  85 24          sta CF_BUF_PTR
0007CEr 2  A9 06          lda #>FS_SECTOR_BUF
0007D0r 2  85 25          sta CF_BUF_PTR + 1
0007D2r 2  A2 00          ldx #$00                      ; Entry counter
0007D4r 2               @FsDirLoop:
0007D4r 2  DA             phx
0007D5r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0007D7r 2  B1 24          lda (CF_BUF_PTR),y
0007D9r 2  29 01          and #FS_FLAG_USED
0007DBr 2  F0 3A          beq @FsDirNext                ; Skip unused entries
0007DDr 2                 ; Print filename (8 chars)
0007DDr 2  A0 00          ldy #$00
0007DFr 2               @FsDirName:
0007DFr 2  B1 24          lda (CF_BUF_PTR),y
0007E1r 2  20 rr rr       jsr Chrout
0007E4r 2  C8             iny
0007E5r 2  C0 08          cpy #$08
0007E7r 2  D0 F6          bne @FsDirName
0007E9r 2                 ; Print dot separator
0007E9r 2  A9 2E          lda #'.'
0007EBr 2  20 rr rr       jsr Chrout
0007EEr 2                 ; Print extension (3 chars)
0007EEr 2               @FsDirExt:
0007EEr 2  B1 24          lda (CF_BUF_PTR),y
0007F0r 2  20 rr rr       jsr Chrout
0007F3r 2  C8             iny
0007F4r 2  C0 0B          cpy #$0B
0007F6r 2  D0 F6          bne @FsDirExt
0007F8r 2                 ; Print space
0007F8r 2  A9 20          lda #' '
0007FAr 2  20 rr rr       jsr Chrout
0007FDr 2                 ; Print file size in decimal
0007FDr 2  A0 0E          ldy #FS_ENTRY_FSIZE
0007FFr 2  B1 24          lda (CF_BUF_PTR),y
000801r 2  8D 4A 03       sta FS_FILE_SIZE
000804r 2  C8             iny
000805r 2  B1 24          lda (CF_BUF_PTR),y
000807r 2  8D 4B 03       sta FS_FILE_SIZE + 1
00080Ar 2  20 rr rr       jsr FsPrintSize
00080Dr 2                 ; Print newline
00080Dr 2  A9 0D          lda #$0D
00080Fr 2  20 rr rr       jsr Chrout
000812r 2  A9 0A          lda #$0A
000814r 2  20 rr rr       jsr Chrout
000817r 2               @FsDirNext:
000817r 2                 ; Advance CF_BUF_PTR by 32
000817r 2  A5 24          lda CF_BUF_PTR
000819r 2  18             clc
00081Ar 2  69 20          adc #FS_ENTRY_SIZE
00081Cr 2  85 24          sta CF_BUF_PTR
00081Er 2  90 02          bcc @FsDirNoCarry
000820r 2  E6 25          inc CF_BUF_PTR + 1
000822r 2               @FsDirNoCarry:
000822r 2  FA             plx
000823r 2  E8             inx
000824r 2  E0 10          cpx #FS_MAX_FILES
000826r 2  D0 AC          bne @FsDirLoop
000828r 2  60             rts
000829r 2               
000829r 2               ; FsPrintSize — Print 16-bit value in FS_FILE_SIZE as decimal
000829r 2               ; Modifies: Flags, A, X, Y
000829r 2               FsPrintSize:
000829r 2                 ; Convert 16-bit value to decimal digits (up to 5 digits for 0-65535)
000829r 2                 ; Use successive subtraction of powers of 10
000829r 2  A2 00          ldx #$00                      ; Digit index / leading zero suppression
00082Br 2  A0 00          ldy #$00                      ; Power-of-10 table index
00082Dr 2               @FsPrintSizeLoop:
00082Dr 2  A9 2F          lda #'0' - 1                  ; Start character below '0'
00082Fr 2  8D 4D 03       sta FS_DIR_IDX                ; Reuse as digit scratch
000832r 2               @FsPrintSub:
000832r 2  EE 4D 03       inc FS_DIR_IDX
000835r 2  AD 4A 03       lda FS_FILE_SIZE
000838r 2  38             sec
000839r 2  F9 rr rr       sbc @FsPow10Lo,y
00083Cr 2  48             pha
00083Dr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000840r 2  F9 rr rr       sbc @FsPow10Hi,y
000843r 2  90 09          bcc @FsPrintSizeDig           ; Underflow — done subtracting
000845r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000848r 2  68             pla
000849r 2  8D 4A 03       sta FS_FILE_SIZE
00084Cr 2  80 E4          bra @FsPrintSub
00084Er 2               @FsPrintSizeDig:
00084Er 2  68             pla                           ; Discard underflowed low byte
00084Fr 2  AD 4D 03       lda FS_DIR_IDX
000852r 2  C9 30          cmp #'0'
000854r 2  D0 04          bne @FsPrintSizeOut           ; Non-zero digit
000856r 2  E0 00          cpx #$00
000858r 2  F0 04          beq @FsPrintSizeSkip          ; Suppress leading zeros
00085Ar 2               @FsPrintSizeOut:
00085Ar 2  20 rr rr       jsr Chrout
00085Dr 2  E8             inx                           ; Mark that we've printed a digit
00085Er 2               @FsPrintSizeSkip:
00085Er 2  C8             iny
00085Fr 2  C0 04          cpy #$04                      ; 4 powers of 10 (10000, 1000, 100, 10)
000861r 2  D0 CA          bne @FsPrintSizeLoop
000863r 2                 ; Always print ones digit
000863r 2  AD 4A 03       lda FS_FILE_SIZE
000866r 2  09 30          ora #'0'                      ; Low byte is 0-9 at this point
000868r 2  20 rr rr       jsr Chrout
00086Br 2  60             rts
00086Cr 2  10 E8 64 0A  @FsPow10Lo: .byte <10000, <1000, <100, <10
000870r 2  27 03 00 00  @FsPow10Hi: .byte >10000, >1000, >100, >10
000874r 2               
000874r 2               ; FsLoadFile — Load file from CF into PROGRAM_START ($0800)
000874r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000874r 2               ; Output: Carry clear = success, FS_FILE_SIZE = bytes loaded
000874r 2               ;         Carry set = file not found or read error
000874r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000874r 2               FsLoadFile:
000874r 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000877r 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
00087Ar 2  B0 63          bcs @FsLoadErr
00087Cr 2  20 rr rr       jsr FsFindFile                ; Search for filename
00087Fr 2  B0 5E          bcs @FsLoadErr                ; Not found
000881r 2                 ; Read file metadata from entry
000881r 2  A0 0C          ldy #FS_ENTRY_START
000883r 2  B1 24          lda (CF_BUF_PTR),y
000885r 2  8D 48 03       sta FS_START_SEC
000888r 2  C8             iny
000889r 2  B1 24          lda (CF_BUF_PTR),y
00088Br 2  8D 49 03       sta FS_START_SEC + 1
00088Er 2  A0 0E          ldy #FS_ENTRY_FSIZE
000890r 2  B1 24          lda (CF_BUF_PTR),y
000892r 2  8D 4A 03       sta FS_FILE_SIZE
000895r 2  C8             iny
000896r 2  B1 24          lda (CF_BUF_PTR),y
000898r 2  8D 4B 03       sta FS_FILE_SIZE + 1
00089Br 2                 ; Calculate number of sectors to read
00089Br 2  AD 4B 03       lda FS_FILE_SIZE + 1
00089Er 2  4A             lsr a
00089Fr 2  8D 4C 03       sta FS_SEC_COUNT
0008A2r 2  AD 4B 03       lda FS_FILE_SIZE + 1
0008A5r 2  29 01          and #$01
0008A7r 2  D0 05          bne @FsLoadRound
0008A9r 2  AD 4A 03       lda FS_FILE_SIZE
0008ACr 2  F0 03          beq @FsLoadNoRound
0008AEr 2               @FsLoadRound:
0008AEr 2  EE 4C 03       inc FS_SEC_COUNT
0008B1r 2               @FsLoadNoRound:
0008B1r 2                 ; Set up LBA starting at file's start sector
0008B1r 2  AD 48 03       lda FS_START_SEC
0008B4r 2  85 26          sta CF_LBA
0008B6r 2  AD 49 03       lda FS_START_SEC + 1
0008B9r 2  85 27          sta CF_LBA + 1
0008BBr 2  64 28          stz CF_LBA + 2
0008BDr 2  64 29          stz CF_LBA + 3
0008BFr 2                 ; Set destination pointer to PROGRAM_START
0008BFr 2  A9 00          lda #<PROGRAM_START
0008C1r 2  85 24          sta CF_BUF_PTR
0008C3r 2  A9 08          lda #>PROGRAM_START
0008C5r 2  85 25          sta CF_BUF_PTR + 1
0008C7r 2                 ; Read sectors
0008C7r 2  AE 4C 03       ldx FS_SEC_COUNT
0008CAr 2  F0 10          beq @FsLoadOk                 ; Zero-size file
0008CCr 2               @FsLoadSec:
0008CCr 2  DA             phx
0008CDr 2  20 rr rr       jsr StReadSector              ; Read sector (advances CF_BUF_PTR by 512)
0008D0r 2  B0 0C          bcs @FsLoadSecErr
0008D2r 2                 ; Increment LBA
0008D2r 2  E6 26          inc CF_LBA
0008D4r 2  D0 02          bne @FsLoadSecNext
0008D6r 2  E6 27          inc CF_LBA + 1
0008D8r 2               @FsLoadSecNext:
0008D8r 2  FA             plx
0008D9r 2  CA             dex
0008DAr 2  D0 F0          bne @FsLoadSec
0008DCr 2               @FsLoadOk:
0008DCr 2  18             clc
0008DDr 2  60             rts
0008DEr 2               @FsLoadSecErr:
0008DEr 2  FA             plx                           ; Balance stack
0008DFr 2               @FsLoadErr:
0008DFr 2  38             sec
0008E0r 2  60             rts
0008E1r 2               
0008E1r 2               ; FsSaveFile — Save data from PROGRAM_START to CF
0008E1r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
0008E1r 2               ;        FS_FILE_SIZE ($034A-$034B) = number of bytes to save
0008E1r 2               ; Output: Carry clear = success, Carry set = error (directory full or write error)
0008E1r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
0008E1r 2               FsSaveFile:
0008E1r 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
0008E4r 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
0008E7r 2  90 03          bcc @FsSaveReadOk
0008E9r 2  4C rr rr       jmp @FsSaveErr
0008ECr 2               @FsSaveReadOk:
0008ECr 2                 ; Try to find existing file with same name
0008ECr 2  20 rr rr       jsr FsFindFile
0008EFr 2  90 08          bcc @FsSaveOverwrite
0008F1r 2                 ; Not found — find a free slot
0008F1r 2  20 rr rr       jsr FsFindFree
0008F4r 2  90 11          bcc @FsSaveAlloc
0008F6r 2  4C rr rr       jmp @FsSaveErr                ; Directory full
0008F9r 2               @FsSaveOverwrite:
0008F9r 2                 ; CF_BUF_PTR already points to the existing entry — clear old flags
0008F9r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0008FBr 2  A9 00          lda #$00
0008FDr 2  91 24          sta (CF_BUF_PTR),y            ; Mark old entry as free
0008FFr 2                 ; Find a free slot (could be the one we just freed or another)
0008FFr 2  20 rr rr       jsr FsFindFree
000902r 2  90 03          bcc @FsSaveAlloc
000904r 2  4C rr rr       jmp @FsSaveErr
000907r 2               @FsSaveAlloc:
000907r 2                 ; Save CF_BUF_PTR (points to free entry from FsFindFree)
000907r 2  A5 24          lda CF_BUF_PTR
000909r 2  48             pha
00090Ar 2  A5 25          lda CF_BUF_PTR + 1
00090Cr 2  48             pha
00090Dr 2                 ; Calculate next free sector (clobbers CF_BUF_PTR)
00090Dr 2  20 rr rr       jsr FsCalcNextSec
000910r 2                 ; Restore CF_BUF_PTR to the free directory entry
000910r 2  68             pla
000911r 2  85 25          sta CF_BUF_PTR + 1
000913r 2  68             pla
000914r 2  85 24          sta CF_BUF_PTR
000916r 2                 ; Calculate sectors needed
000916r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000919r 2  4A             lsr a
00091Ar 2  8D 4C 03       sta FS_SEC_COUNT
00091Dr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000920r 2  29 01          and #$01
000922r 2  D0 05          bne @FsSaveRound
000924r 2  AD 4A 03       lda FS_FILE_SIZE
000927r 2  F0 03          beq @FsSaveNoRound
000929r 2               @FsSaveRound:
000929r 2  EE 4C 03       inc FS_SEC_COUNT
00092Cr 2               @FsSaveNoRound:
00092Cr 2                 ; Fill in directory entry at CF_BUF_PTR
00092Cr 2                 ; Copy filename (11 bytes)
00092Cr 2  A0 00          ldy #$00
00092Er 2               @FsSaveCopyName:
00092Er 2  B9 50 03       lda FS_FNAME_BUF,y
000931r 2  91 24          sta (CF_BUF_PTR),y
000933r 2  C8             iny
000934r 2  C0 0B          cpy #11
000936r 2  D0 F6          bne @FsSaveCopyName
000938r 2                 ; Set flags = in use
000938r 2  A9 01          lda #FS_FLAG_USED
00093Ar 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
00093Cr 2                 ; Set start sector
00093Cr 2  A0 0C          ldy #FS_ENTRY_START
00093Er 2  AD 4E 03       lda FS_NEXT_SEC
000941r 2  91 24          sta (CF_BUF_PTR),y
000943r 2  8D 48 03       sta FS_START_SEC
000946r 2  C8             iny
000947r 2  AD 4F 03       lda FS_NEXT_SEC + 1
00094Ar 2  91 24          sta (CF_BUF_PTR),y
00094Cr 2  8D 49 03       sta FS_START_SEC + 1
00094Fr 2                 ; Set file size
00094Fr 2  A0 0E          ldy #FS_ENTRY_FSIZE
000951r 2  AD 4A 03       lda FS_FILE_SIZE
000954r 2  91 24          sta (CF_BUF_PTR),y
000956r 2  C8             iny
000957r 2  AD 4B 03       lda FS_FILE_SIZE + 1
00095Ar 2  91 24          sta (CF_BUF_PTR),y
00095Cr 2                 ; Clear reserved bytes
00095Cr 2  A0 10          ldy #$10
00095Er 2  A9 00          lda #$00
000960r 2               @FsSaveClearRsv:
000960r 2  91 24          sta (CF_BUF_PTR),y
000962r 2  C8             iny
000963r 2  C0 20          cpy #FS_ENTRY_SIZE
000965r 2  D0 F9          bne @FsSaveClearRsv
000967r 2                 ; Write updated directory back to CF
000967r 2  20 rr rr       jsr FsWriteDir
00096Ar 2  B0 2E          bcs @FsSaveErr
00096Cr 2                 ; Now write file data sectors
00096Cr 2  AD 48 03       lda FS_START_SEC
00096Fr 2  85 26          sta CF_LBA
000971r 2  AD 49 03       lda FS_START_SEC + 1
000974r 2  85 27          sta CF_LBA + 1
000976r 2  64 28          stz CF_LBA + 2
000978r 2  64 29          stz CF_LBA + 3
00097Ar 2                 ; Source = PROGRAM_START
00097Ar 2  A9 00          lda #<PROGRAM_START
00097Cr 2  85 24          sta CF_BUF_PTR
00097Er 2  A9 08          lda #>PROGRAM_START
000980r 2  85 25          sta CF_BUF_PTR + 1
000982r 2  AE 4C 03       ldx FS_SEC_COUNT
000985r 2  F0 10          beq @FsSaveOk                 ; Zero-size file
000987r 2               @FsSaveSec:
000987r 2  DA             phx
000988r 2  20 rr rr       jsr StWriteSector             ; Write sector (advances CF_BUF_PTR by 512)
00098Br 2  B0 0C          bcs @FsSaveSecErr
00098Dr 2                 ; Increment LBA
00098Dr 2  E6 26          inc CF_LBA
00098Fr 2  D0 02          bne @FsSaveSecNext
000991r 2  E6 27          inc CF_LBA + 1
000993r 2               @FsSaveSecNext:
000993r 2  FA             plx
000994r 2  CA             dex
000995r 2  D0 F0          bne @FsSaveSec
000997r 2               @FsSaveOk:
000997r 2  18             clc
000998r 2  60             rts
000999r 2               @FsSaveSecErr:
000999r 2  FA             plx                           ; Balance stack
00099Ar 2               @FsSaveErr:
00099Ar 2  38             sec
00099Br 2  60             rts
00099Cr 2               
00099Cr 2               ; FsDeleteFile — Delete a file from the CompactFlash filesystem
00099Cr 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
00099Cr 2               ; Output: Carry clear = success, Carry set = file not found or error
00099Cr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
00099Cr 2               FsDeleteFileImpl:
00099Cr 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
00099Fr 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
0009A2r 2  B0 0F          bcs @FsDelErr
0009A4r 2  20 rr rr       jsr FsFindFile                ; Search for filename
0009A7r 2  B0 0A          bcs @FsDelErr                 ; Not found
0009A9r 2                 ; Clear the flags byte to mark entry as unused
0009A9r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0009ABr 2  A9 00          lda #$00
0009ADr 2  91 24          sta (CF_BUF_PTR),y
0009AFr 2                 ; Write updated directory back to CF
0009AFr 2  20 rr rr       jsr FsWriteDir
0009B2r 2                 ; Carry already set/clear from FsWriteDir
0009B2r 2  60             rts
0009B3r 2               @FsDelErr:
0009B3r 2  38             sec
0009B4r 2  60             rts
0009B5r 2               
0009B5r 2               ; === Serial ASCII LOAD/SAVE ===
0009B5r 2               ; Plain binary transfer protocol over serial
0009B5r 2               ; Load: receives 2-byte size (lo/hi) then raw data bytes into PROGRAM_START
0009B5r 2               ; Save: sends 2-byte size (lo/hi) then raw data bytes from PROGRAM_START
0009B5r 2               
0009B5r 2               ; --- ASCII Load ---
0009B5r 2               
0009B5r 2               ; AsciiLoadImpl — Receive raw binary data via serial into program memory
0009B5r 2               ; Switches IO_MODE to serial, receives 2-byte size then raw data bytes
0009B5r 2               ; Data is written starting at PROGRAM_START ($0800)
0009B5r 2               ; Output: Carry clear = success, XFER_PTR points past last byte written
0009B5r 2               ; Modifies: Flags, A, X, Y
0009B5r 2               AsciiLoadImpl:
0009B5r 2                 ; Save and switch IO_MODE to serial
0009B5r 2  AD 06 03       lda IO_MODE
0009B8r 2  8D 19 03       sta XFER_IO_SAVE
0009BBr 2  A9 01          lda #$01                      ; Serial mode
0009BDr 2  8D 06 03       sta IO_MODE
0009C0r 2                 ; Print prompt
0009C0r 2  A9 0D          lda #$0D
0009C2r 2  20 rr rr       jsr SerialChrout
0009C5r 2  A9 0A          lda #$0A
0009C7r 2  20 rr rr       jsr SerialChrout
0009CAr 2  A9 rr          lda #<@AsciiLoadMsg
0009CCr 2  85 02          sta STR_PTR
0009CEr 2  A9 rr          lda #>@AsciiLoadMsg
0009D0r 2  85 03          sta STR_PTR + 1
0009D2r 2  20 rr rr       jsr @SerialPrintStr
0009D5r 2                 ; Read 2-byte size (low byte first)
0009D5r 2               @AsciiWaitSzLo:
0009D5r 2  20 rr rr       jsr BufferSize
0009D8r 2  F0 FB          beq @AsciiWaitSzLo
0009DAr 2  20 rr rr       jsr ReadBuffer
0009DDr 2  8D 17 03       sta XFER_REMAIN
0009E0r 2               @AsciiWaitSzHi:
0009E0r 2  20 rr rr       jsr BufferSize
0009E3r 2  F0 FB          beq @AsciiWaitSzHi
0009E5r 2  20 rr rr       jsr ReadBuffer
0009E8r 2  8D 18 03       sta XFER_REMAIN + 1
0009EBr 2                 ; Initialize write pointer to PROGRAM_START
0009EBr 2  A9 00          lda #<PROGRAM_START
0009EDr 2  85 2A          sta XFER_PTR
0009EFr 2  A9 08          lda #>PROGRAM_START
0009F1r 2  85 2B          sta XFER_PTR + 1
0009F3r 2                 ; Check for zero-length transfer
0009F3r 2  AD 17 03       lda XFER_REMAIN
0009F6r 2  0D 18 03       ora XFER_REMAIN + 1
0009F9r 2  F0 25          beq @AsciiLoadOk
0009FBr 2                 ; Receive data bytes (Y stays 0, pointer is advanced each byte)
0009FBr 2  A0 00          ldy #$00
0009FDr 2               @AsciiLoadByte:
0009FDr 2  20 rr rr       jsr BufferSize
000A00r 2  F0 FB          beq @AsciiLoadByte
000A02r 2  20 rr rr       jsr ReadBuffer
000A05r 2  91 2A          sta (XFER_PTR),y              ; Write byte to target address
000A07r 2                 ; Advance write pointer
000A07r 2  E6 2A          inc XFER_PTR
000A09r 2  D0 02          bne @AsciiLoadNoPage
000A0Br 2  E6 2B          inc XFER_PTR + 1
000A0Dr 2               @AsciiLoadNoPage:
000A0Dr 2                 ; Decrement remaining count
000A0Dr 2  AD 17 03       lda XFER_REMAIN
000A10r 2  D0 03          bne @AsciiLoadDecLo
000A12r 2  CE 18 03       dec XFER_REMAIN + 1
000A15r 2               @AsciiLoadDecLo:
000A15r 2  CE 17 03       dec XFER_REMAIN
000A18r 2                 ; Check if done
000A18r 2  AD 17 03       lda XFER_REMAIN
000A1Br 2  0D 18 03       ora XFER_REMAIN + 1
000A1Er 2  D0 DD          bne @AsciiLoadByte
000A20r 2               @AsciiLoadOk:
000A20r 2                 ; XFER_PTR now points past last byte written
000A20r 2                 ; Print success message
000A20r 2  A9 0D          lda #$0D
000A22r 2  20 rr rr       jsr SerialChrout
000A25r 2  A9 0A          lda #$0A
000A27r 2  20 rr rr       jsr SerialChrout
000A2Ar 2  A9 rr          lda #<@AsciiOkMsg
000A2Cr 2  85 02          sta STR_PTR
000A2Er 2  A9 rr          lda #>@AsciiOkMsg
000A30r 2  85 03          sta STR_PTR + 1
000A32r 2  20 rr rr       jsr @SerialPrintStr
000A35r 2                 ; Restore IO_MODE
000A35r 2  AD 19 03       lda XFER_IO_SAVE
000A38r 2  8D 06 03       sta IO_MODE
000A3Br 2  18             clc                           ; Success
000A3Cr 2  60             rts
000A3Dr 2               
000A3Dr 2               ; Internal: print null-terminated string via serial
000A3Dr 2               ; Input: STR_PTR points to string
000A3Dr 2               @SerialPrintStr:
000A3Dr 2  A0 00          ldy #$00
000A3Fr 2               @SerialPrintLoop:
000A3Fr 2  B1 02          lda (STR_PTR),y
000A41r 2  F0 06          beq @SerialPrintDone
000A43r 2  20 rr rr       jsr SerialChrout
000A46r 2  C8             iny
000A47r 2  D0 F6          bne @SerialPrintLoop
000A49r 2               @SerialPrintDone:
000A49r 2  60             rts
000A4Ar 2               
000A4Ar 2  52 45 41 44  @AsciiLoadMsg: .asciiz "READY TO RECEIVE"
000A4Er 2  59 20 54 4F  
000A52r 2  20 52 45 43  
000A5Br 2  4F 4B 00     @AsciiOkMsg:   .asciiz "OK"
000A5Er 2               
000A5Er 2               ; --- ASCII Save ---
000A5Er 2               
000A5Er 2               ; AsciiSaveImpl — Transmit program memory as raw binary via serial
000A5Er 2               ; Sends 2-byte size (lo/hi) then raw data bytes from PROGRAM_START to BAS_PRGEND
000A5Er 2               ; Output: Carry clear = success
000A5Er 2               ; Modifies: Flags, A, X, Y
000A5Er 2               AsciiSaveImpl:
000A5Er 2                 ; Save and switch IO_MODE to serial
000A5Er 2  AD 06 03       lda IO_MODE
000A61r 2  8D 19 03       sta XFER_IO_SAVE
000A64r 2  A9 01          lda #$01
000A66r 2  8D 06 03       sta IO_MODE
000A69r 2                 ; Initialize save pointer
000A69r 2  A9 00          lda #<PROGRAM_START
000A6Br 2  85 2A          sta XFER_PTR
000A6Dr 2  A9 08          lda #>PROGRAM_START
000A6Fr 2  85 2B          sta XFER_PTR + 1
000A71r 2                 ; Calculate remaining bytes = BAS_PRGEND - PROGRAM_START
000A71r 2  A5 12          lda z:BAS_PRGEND
000A73r 2  38             sec
000A74r 2  E9 00          sbc #<PROGRAM_START
000A76r 2  8D 17 03       sta XFER_REMAIN
000A79r 2  A5 13          lda z:BAS_PRGEND + 1
000A7Br 2  E9 08          sbc #>PROGRAM_START
000A7Dr 2  8D 18 03       sta XFER_REMAIN + 1
000A80r 2                 ; Send 2-byte size (low byte first)
000A80r 2  AD 17 03       lda XFER_REMAIN
000A83r 2  20 rr rr       jsr SerialChrout
000A86r 2  AD 18 03       lda XFER_REMAIN + 1
000A89r 2  20 rr rr       jsr SerialChrout
000A8Cr 2                 ; Check for zero-length program
000A8Cr 2  AD 17 03       lda XFER_REMAIN
000A8Fr 2  0D 18 03       ora XFER_REMAIN + 1
000A92r 2  F0 20          beq @AsciiSaveDone
000A94r 2                 ; Send data bytes (Y stays 0, pointer is advanced each byte)
000A94r 2  A0 00          ldy #$00
000A96r 2               @AsciiSaveByte:
000A96r 2  B1 2A          lda (XFER_PTR),y
000A98r 2  20 rr rr       jsr SerialChrout
000A9Br 2                 ; Advance read pointer
000A9Br 2  E6 2A          inc XFER_PTR
000A9Dr 2  D0 02          bne @AsciiSaveNoPage
000A9Fr 2  E6 2B          inc XFER_PTR + 1
000AA1r 2               @AsciiSaveNoPage:
000AA1r 2                 ; Decrement remaining count
000AA1r 2  AD 17 03       lda XFER_REMAIN
000AA4r 2  D0 03          bne @AsciiSaveDecLo
000AA6r 2  CE 18 03       dec XFER_REMAIN + 1
000AA9r 2               @AsciiSaveDecLo:
000AA9r 2  CE 17 03       dec XFER_REMAIN
000AACr 2                 ; Check if done
000AACr 2  AD 17 03       lda XFER_REMAIN
000AAFr 2  0D 18 03       ora XFER_REMAIN + 1
000AB2r 2  D0 E2          bne @AsciiSaveByte
000AB4r 2               @AsciiSaveDone:
000AB4r 2                 ; Restore IO_MODE
000AB4r 2  AD 19 03       lda XFER_IO_SAVE
000AB7r 2  8D 06 03       sta IO_MODE
000ABAr 2  18             clc                           ; Success
000ABBr 2  60             rts
000ABCr 2               
000ABCr 2               ; Draw the splash screen
000ABCr 2               ; Uses video output to display centered title and boot menu
000ABCr 2               ; Modifies: Flags, A, X, Y
000ABCr 2               Splash:
000ABCr 2  20 rr rr       jsr VideoClear                ; Clear the video screen
000ABFr 2                 ; Position cursor at row 10, col 10 for title
000ABFr 2  A2 0A          ldx #10
000AC1r 2  A0 0A          ldy #10
000AC3r 2  20 rr rr       jsr VideoSetCursor
000AC6r 2  A9 rr          lda #<@SplashTitle
000AC8r 2  85 02          sta STR_PTR
000ACAr 2  A9 rr          lda #>@SplashTitle
000ACCr 2  85 03          sta STR_PTR + 1
000ACEr 2  20 rr rr       jsr VideoPrintStrImpl
000AD1r 2                 ; Position cursor at row 12, col 8 for boot menu (centered: (40-24)/2 = 8)
000AD1r 2  A2 08          ldx #8
000AD3r 2  A0 0C          ldy #12
000AD5r 2  20 rr rr       jsr VideoSetCursor
000AD8r 2  A9 rr          lda #<@SplashMenu
000ADAr 2  85 02          sta STR_PTR
000ADCr 2  A9 rr          lda #>@SplashMenu
000ADEr 2  85 03          sta STR_PTR + 1
000AE0r 2  20 rr rr       jsr VideoPrintStrImpl
000AE3r 2  60             rts
000AE4r 2  2D 2D 20 54  @SplashTitle: .asciiz "-- The 'COB' v1.0 --"
000AE8r 2  68 65 20 27  
000AECr 2  43 4F 42 27  
000AF9r 2  45 4E 54 45  @SplashMenu:  .asciiz "ENTER=BASIC  ESC=MONITOR"
000AFDr 2  52 3D 42 41  
000B01r 2  53 49 43 20  
000B12r 2               
000B12r 2               ; NMI Handler
000B12r 2               Nmi:
000B12r 2  40             rti
000B13r 2               
000B13r 2               ; BRK Handler — default dispatches to WozMon
000B13r 2               ; On entry the stack holds the processor-pushed state from the BRK:
000B13r 2               ;   SP+1 = saved P, SP+2 = PCL (PC+2), SP+3 = PCH
000B13r 2               ; State is saved to BRK_P/BRK_PCL/BRK_PCH for inspection by a custom handler.
000B13r 2               Break:
000B13r 2  68             pla                           ; Pull saved P
000B14r 2  8D 10 03       sta BRK_P
000B17r 2  68             pla                           ; Pull saved PCL (PC+2)
000B18r 2  8D 11 03       sta BRK_PCL
000B1Br 2  68             pla                           ; Pull saved PCH
000B1Cr 2  8D 12 03       sta BRK_PCH
000B1Fr 2  4C rr rr       jmp MonitorEntry
000B22r 2               
000B22r 2               ; IRQ Handler
000B22r 2               Irq:
000B22r 2  48             pha
000B23r 2  5A             phy
000B24r 2  DA             phx
000B25r 2  BA             tsx                           ; Get stack pointer to check saved status register
000B26r 2  BD 04 01       lda $104,x                    ; Load saved P (SP+4: past X, Y, A we pushed)
000B29r 2  29 10          and #$10                      ; Test B flag — set by BRK, clear by hardware IRQ
000B2Br 2  D0 3B          bne @IrqBrk                   ; Branch if this was a BRK instruction
000B2Dr 2               @IrqSc:
000B2Dr 2  AD 01 90       lda SC_STATUS
000B30r 2  29 80          and #SC_STATUS_IRQ            ; Check if serial data caused the interrupt
000B32r 2  F0 14          beq @IrqCheckKB               ; If not, check keyboard
000B34r 2  AD 00 90       lda SC_DATA                   ; Read the data from serial register
000B37r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000B3Ar 2  20 rr rr       jsr BufferSize
000B3Dr 2  C9 F0          cmp #$F0                      ; Is the buffer almost full?
000B3Fr 2  90 23          bcc @IrqExit                  ; If not, exit
000B41r 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
000B43r 2  8D 02 90       sta SC_CMD                    ; Otherwise, signal not ready for receiving (RTSB high)
000B46r 2  80 1C          bra @IrqExit
000B48r 2               @IrqCheckKB:
000B48r 2  AD 0D 94       lda GPIO_IFR
000B4Br 2  29 10          and #GPIO_INT_CB1             ; Check if CB1 (matrix keyboard data ready) caused the interrupt
000B4Dr 2  F0 08          beq @IrqCheckPS2              ; If not, check PS/2 keyboard
000B4Fr 2  AD 00 94       lda GPIO_PORTB                ; Read ASCII byte from matrix keyboard (also clears CB1 IFR flag)
000B52r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000B55r 2  80 0D          bra @IrqExit
000B57r 2               @IrqCheckPS2:
000B57r 2  AD 0D 94       lda GPIO_IFR
000B5Ar 2  29 02          and #GPIO_INT_CA1             ; Check if CA1 (PS/2 keyboard data ready) caused the interrupt
000B5Cr 2  F0 06          beq @IrqExit                  ; If not, exit
000B5Er 2  AD 01 94       lda GPIO_PORTA                ; Read ASCII byte from PS/2 keyboard (also clears CA1 IFR flag)
000B61r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000B64r 2               @IrqExit:
000B64r 2  FA             plx
000B65r 2  7A             ply
000B66r 2  68             pla
000B67r 2  40             rti
000B68r 2               @IrqBrk:
000B68r 2  FA             plx                           ; Restore saved registers
000B69r 2  7A             ply
000B6Ar 2  68             pla
000B6Br 2  58             cli                           ; Re-enable interrupts — abandoning interrupt context
000B6Cr 2  6C 02 03       jmp (BRK_PTR)                 ; BRK — dispatch with P/PCL/PCH still on stack
000B6Fr 2               
000B6Fr 2               ; NMI Vector
000B6Fr 2               NmiVec:
000B6Fr 2  6C 04 03       jmp (NMI_PTR)                 ; Indirect jump through NMI pointer to the NMI handler
000B72r 2               
000B72r 2               ; Reset Vector
000B72r 2               ResetVec:
000B72r 2  4C rr rr       jmp Reset                     ; Initialize the system
000B75r 2               
000B75r 2               ; IRQ Vector
000B75r 2               IrqVec:
000B75r 2  6C 00 03       jmp (IRQ_PTR)                 ; Indirect jump through IRQ pointer to the IRQ handler
000B78r 2               
000B78r 1               .segment "CHARS"
000000r 1               .include "Chars.asm"
000000r 2               ; IBM Code Page 437 Character Set
000000r 2               ; 6x8 pixel font in 8x8 area, 8 bytes per character (256 characters total)
000000r 2               ; Each byte represents one horizontal row of pixels (6 pixels centered in 8-bit space)
000000r 2               
000000r 2               CharacterSet:
000000r 2                   ; Character $00 - NULL (blank)
000000r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $00, $00, $00
000004r 2  00 00 00 00  
000008r 2                   ; Character $01 - ☺ (white smiling face)
000008r 2  00 7C 82 AA      .byte $00, $7C, $82, $AA, $82, $BA, $44, $38
00000Cr 2  82 BA 44 38  
000010r 2                   ; Character $02 - ☻ (black smiling face)
000010r 2  00 7C FE D6      .byte $00, $7C, $FE, $D6, $FE, $C6, $7C, $38
000014r 2  FE C6 7C 38  
