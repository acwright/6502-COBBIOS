000000r 1               
000000r 1               .segment "KERNAL"
000000r 1               .include "Kernal.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   KERNAL    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; === Kernal Jump Table ($A000-$A0FF) ===
000000r 2               ; 85 slots of 3-byte JMP instructions plus 1 padding byte
000000r 2               ; Provides stable entry points for external code and cartridges
000000r 2               
000000r 2  4C rr rr     Chrout:         jmp ChroutDispatch      ; $A000 - Output char (dispatched by IO_MODE)
000003r 2  4C rr rr     Chrin:          jmp ChrinImpl           ; $A003 - Input char from buffer
000006r 2  4C rr rr     WriteBuffer:    jmp WriteBufferImpl     ; $A006 - Write byte to input buffer
000009r 2  4C rr rr     ReadBuffer:     jmp ReadBufferImpl      ; $A009 - Read byte from input buffer
00000Cr 2  4C rr rr     BufferSize:     jmp BufferSizeImpl      ; $A00C - Get buffer count
00000Fr 2  4C rr rr     InitVideo:      jmp InitVideoImpl       ; $A00F - Initialize TMS9918
000012r 2  4C rr rr     InitKB:         jmp InitKBImpl          ; $A012 - Initialize GPIO/VIA keyboard
000015r 2  4C rr rr     InitSC:         jmp InitSCImpl          ; $A015 - Initialize serial 6551
000018r 2  4C rr rr     InitSID:        jmp InitSIDImpl         ; $A018 - Initialize SID
00001Br 2  4C rr rr     Beep:           jmp BeepImpl            ; $A01B - Play beep tone
00001Er 2  4C rr rr     VideoClear:     jmp VideoClearImpl      ; $A01E - Clear video screen
000021r 2  4C rr rr     VideoPutChar:   jmp VideoPutCharImpl    ; $A021 - Write char at cursor
000024r 2  4C rr rr     VideoSetCursor: jmp VideoSetCursorImpl  ; $A024 - Set cursor (X=col, Y=row)
000027r 2  4C rr rr     VideoGetCursor: jmp VideoGetCursorImpl  ; $A027 - Get cursor position
00002Ar 2  4C rr rr     VideoScroll:    jmp VideoScrollImpl     ; $A02A - Scroll screen up one line
00002Dr 2  4C rr rr     SerialChrout:   jmp SerialChroutImpl    ; $A02D - Direct serial output (bypass IO_MODE)
000030r 2  4C rr rr     ReadJoystick1:  jmp ReadJoystick1Impl   ; $A030 - Read joystick 1
000033r 2  4C rr rr     ReadJoystick2:  jmp ReadJoystick2Impl   ; $A033 - Read joystick 2
000036r 2  4C rr rr     RtcReadTime:    jmp RtcReadTimeImpl     ; $A036 - Read RTC time
000039r 2  4C rr rr     RtcReadDate:    jmp RtcReadDateImpl     ; $A039 - Read RTC date
00003Cr 2  4C rr rr     RtcWriteTime:   jmp RtcWriteTimeImpl    ; $A03C - Set RTC time
00003Fr 2  4C rr rr     RtcWriteDate:   jmp RtcWriteDateImpl    ; $A03F - Set RTC date
000042r 2  4C rr rr     RtcReadNVRAM:   jmp RtcReadNVRAMImpl    ; $A042 - Read NVRAM byte
000045r 2  4C rr rr     RtcWriteNVRAM:  jmp RtcWriteNVRAMImpl   ; $A045 - Write NVRAM byte
000048r 2  4C rr rr     StReadSector:   jmp StReadSectorImpl    ; $A048 - Read CF sector
00004Br 2  4C rr rr     StWriteSector:  jmp StWriteSectorImpl   ; $A04B - Write CF sector
00004Er 2  4C rr rr     StWaitReady:    jmp StWaitReadyImpl     ; $A04E - Wait CF ready
000051r 2  4C rr rr     SetIOMode:      jmp SetIOModeImpl       ; $A051 - Set IO_MODE
000054r 2  4C rr rr     GetIOMode:      jmp GetIOModeImpl       ; $A054 - Get IO_MODE
000057r 2  4C rr rr     AsciiLoad:      jmp AsciiLoadImpl       ; $A057 - Load raw binary via serial
00005Ar 2  4C rr rr     AsciiSave:      jmp AsciiSaveImpl       ; $A05A - Save raw binary via serial
00005Dr 2  4C rr rr     SidPlayNote:    jmp SidPlayNoteImpl     ; $A05D - Play note (A=voice, X=freqLo, Y=freqHi)
000060r 2  4C rr rr     SidSilence:     jmp SidSilenceImpl      ; $A060 - Silence all voices
000063r 2               
000063r 2               ; Reserved entries ($A063-$A0FE)
000063r 2  4C rr rr 4C  .repeat 52
000067r 2  rr rr 4C rr  
00006Br 2  rr 4C rr rr  
0000FFr 2                               jmp UnimplementedStub
0000FFr 2               .endrepeat
0000FFr 2  00           .byte $00                             ; Pad to 256 bytes ($A0FF)
000100r 2               
000100r 2               ; === Kernal Implementation ===
000100r 2               
000100r 2               ; Stub for unimplemented jump table entries
000100r 2               UnimplementedStub:
000100r 2  60             rts
000101r 2               
000101r 2               ; Chrout dispatcher — routes output based on IO_MODE
000101r 2               ; Input: A = character to output
000101r 2               ; Modifies: Flags
000101r 2               ChroutDispatch:
000101r 2  48             pha
000102r 2  AD 06 03       lda IO_MODE
000105r 2  29 01          and #$01                      ; Bit 0: 0=video, 1=serial
000107r 2  D0 04          bne @Serial
000109r 2  68             pla
00010Ar 2  4C rr rr       jmp VideoChroutImpl
00010Dr 2               @Serial:
00010Dr 2  68             pla
00010Er 2  4C rr rr       jmp SerialChroutImpl
000111r 2               
000111r 2               ; Set IO_MODE
000111r 2               ; Input: A = mode (bit 0: 0=video, 1=serial)
000111r 2               SetIOModeImpl:
000111r 2  8D 06 03       sta IO_MODE
000114r 2  60             rts
000115r 2               
000115r 2               ; Get IO_MODE
000115r 2               ; Output: A = current IO_MODE
000115r 2               GetIOModeImpl:
000115r 2  AD 06 03       lda IO_MODE
000118r 2  60             rts
000119r 2               
000119r 2               ; === TMS9918 Video Driver ===
000119r 2               
000119r 2               ; VideoClear — Fill name table (960 bytes at VRAM $0000) with spaces, reset cursor to (0,0)
000119r 2               ; Modifies: Flags, A, X, Y
000119r 2               VideoClearImpl:
000119r 2                 ; Set VRAM write address to $0000 (name table base)
000119r 2  A9 00          lda #$00
00011Br 2  8D 01 9C       sta VC_REG
00011Er 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
000120r 2  8D 01 9C       sta VC_REG
000123r 2                 ; Fill 960 bytes with space ($20) — 3 full pages + 192 bytes
000123r 2  A9 20          lda #$20
000125r 2  A0 00          ldy #$00
000127r 2  A2 03          ldx #$03                      ; 3 full pages (768 bytes)
000129r 2               @VideoClearPage:
000129r 2  8D 00 9C       sta VC_DATA
00012Cr 2  C8             iny
00012Dr 2  D0 FA          bne @VideoClearPage
00012Fr 2  CA             dex
000130r 2  D0 F7          bne @VideoClearPage
000132r 2                 ; Remaining 192 bytes (960 - 768)
000132r 2  A0 C0          ldy #192
000134r 2               @VideoClearRem:
000134r 2  8D 00 9C       sta VC_DATA
000137r 2  88             dey
000138r 2  D0 FA          bne @VideoClearRem
00013Ar 2                 ; Reset cursor to (0,0)
00013Ar 2  9C 07 03       stz VID_CURSOR_X
00013Dr 2  9C 08 03       stz VID_CURSOR_Y
000140r 2  9C 09 03       stz VID_CURSOR_ADDR
000143r 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
000146r 2  60             rts
000147r 2               
000147r 2               ; VideoSetCursor — Set cursor position
000147r 2               ; Input: X = column (0-39), Y = row (0-23)
000147r 2               ; Calculates VRAM address = Y * 40 + X and stores in VID_CURSOR_ADDR
000147r 2               ; Modifies: Flags, A
000147r 2               VideoSetCursorImpl:
000147r 2  8E 07 03       stx VID_CURSOR_X
00014Ar 2  8C 08 03       sty VID_CURSOR_Y
00014Dr 2                 ; Calculate VRAM address = Y * 40 + X
00014Dr 2                 ; Y * 40 = Y * 32 + Y * 8
00014Dr 2  A9 00          lda #$00
00014Fr 2  8D 0A 03       sta VID_CURSOR_ADDR + 1       ; Clear high byte
000152r 2  98             tya                           ; A = row
000153r 2                 ; Multiply by 8: shift left 3
000153r 2  0A             asl a
000154r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000157r 2  0A             asl a
000158r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Br 2  0A             asl a
00015Cr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Fr 2  8D 09 03       sta VID_CURSOR_ADDR           ; Store Y*8 low byte
000162r 2                 ; Save Y*8 for later addition
000162r 2  48             pha
000163r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
000166r 2  48             pha
000167r 2                 ; Multiply original row by 32: shift left 5 total (Y*8 << 2)
000167r 2  AD 09 03       lda VID_CURSOR_ADDR
00016Ar 2  0A             asl a
00016Br 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00016Er 2  0A             asl a
00016Fr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000172r 2  8D 09 03       sta VID_CURSOR_ADDR           ; Now holds Y*32 low byte
000175r 2                 ; Add Y*8 + Y*32
000175r 2  68             pla                           ; Restore Y*8 high byte
000176r 2  6D 0A 03       adc VID_CURSOR_ADDR + 1       ; Carry still valid from last rol
000179r 2  8D 0A 03       sta VID_CURSOR_ADDR + 1
00017Cr 2  68             pla                           ; Restore Y*8 low byte
00017Dr 2  18             clc
00017Er 2  6D 09 03       adc VID_CURSOR_ADDR
000181r 2  8D 09 03       sta VID_CURSOR_ADDR
000184r 2  90 03          bcc @NoCarry
000186r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000189r 2               @NoCarry:
000189r 2                 ; Add X (column)
000189r 2  8A             txa
00018Ar 2  18             clc
00018Br 2  6D 09 03       adc VID_CURSOR_ADDR
00018Er 2  8D 09 03       sta VID_CURSOR_ADDR
000191r 2  90 03          bcc @SetCursorDone
000193r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000196r 2               @SetCursorDone:
000196r 2  60             rts
000197r 2               
000197r 2               ; VideoGetCursor — Get cursor position
000197r 2               ; Output: X = column (0-39), Y = row (0-23)
000197r 2               ; Modifies: Flags
000197r 2               VideoGetCursorImpl:
000197r 2  AE 07 03       ldx VID_CURSOR_X
00019Ar 2  AC 08 03       ldy VID_CURSOR_Y
00019Dr 2  60             rts
00019Er 2               
00019Er 2               ; VideoPutChar — Write a single character to VRAM at VID_CURSOR_ADDR
00019Er 2               ; Input: A = character to write
00019Er 2               ; Modifies: Flags
00019Er 2               VideoPutCharImpl:
00019Er 2  48             pha
00019Fr 2                 ; Set VRAM write address from VID_CURSOR_ADDR
00019Fr 2  AD 09 03       lda VID_CURSOR_ADDR
0001A2r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
0001A5r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
0001A8r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001AAr 2  8D 01 9C       sta VC_REG                    ; High byte with write flag
0001ADr 2  68             pla
0001AEr 2  8D 00 9C       sta VC_DATA                   ; Write character to VRAM
0001B1r 2  60             rts
0001B2r 2               
0001B2r 2               ; VideoScroll — Scroll screen up one line
0001B2r 2               ; Copies VRAM rows 1-23 to rows 0-22 (920 bytes), clears row 23 with spaces
0001B2r 2               ; Uses SCROLL_BUF ($0320, 40 bytes) as temporary storage
0001B2r 2               ; Modifies: Flags, A, X, Y
0001B2r 2               VideoScrollImpl:
0001B2r 2                 ; Save STR_PTR (may be in use by caller, e.g. VideoPrintStr)
0001B2r 2  A5 02          lda STR_PTR
0001B4r 2  48             pha
0001B5r 2  A5 03          lda STR_PTR + 1
0001B7r 2  48             pha
0001B8r 2                 ; Source starts at row 1 (VRAM offset 40=$28), dest at row 0 (offset 0)
0001B8r 2                 ; We process 23 rows, copying each row up by one
0001B8r 2  A9 28          lda #<40                      ; Source address low = 40 (row 1)
0001BAr 2  85 02          sta STR_PTR
0001BCr 2  A9 00          lda #>40
0001BEr 2  85 03          sta STR_PTR + 1
0001C0r 2               
0001C0r 2  A2 17          ldx #23                       ; 23 rows to copy
0001C2r 2               @ScrollRowLoop:
0001C2r 2  DA             phx                           ; Save row counter
0001C3r 2               
0001C3r 2                 ; Set VRAM read address (source row)
0001C3r 2  A5 02          lda STR_PTR
0001C5r 2  8D 01 9C       sta VC_REG
0001C8r 2  A5 03          lda STR_PTR + 1
0001CAr 2  8D 01 9C       sta VC_REG                    ; Bit 6 clear = read mode
0001CDr 2                 ; Read 40 bytes into SCROLL_BUF
0001CDr 2  A0 00          ldy #$00
0001CFr 2               @ScrollRead:
0001CFr 2  AD 00 9C       lda VC_DATA
0001D2r 2  99 20 03       sta SCROLL_BUF,y
0001D5r 2  C8             iny
0001D6r 2  C0 28          cpy #40
0001D8r 2  D0 F5          bne @ScrollRead
0001DAr 2               
0001DAr 2                 ; Set VRAM write address (dest = source - 40)
0001DAr 2  A5 02          lda STR_PTR
0001DCr 2  38             sec
0001DDr 2  E9 28          sbc #40
0001DFr 2  8D 01 9C       sta VC_REG                    ; Dest address low
0001E2r 2  A5 03          lda STR_PTR + 1
0001E4r 2  E9 00          sbc #$00
0001E6r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001E8r 2  8D 01 9C       sta VC_REG                    ; Dest address high
0001EBr 2               
0001EBr 2                 ; Write 40 bytes from SCROLL_BUF
0001EBr 2  A0 00          ldy #$00
0001EDr 2               @ScrollWrite:
0001EDr 2  B9 20 03       lda SCROLL_BUF,y
0001F0r 2  8D 00 9C       sta VC_DATA
0001F3r 2  C8             iny
0001F4r 2  C0 28          cpy #40
0001F6r 2  D0 F5          bne @ScrollWrite
0001F8r 2               
0001F8r 2                 ; Advance source pointer by 40 for next row
0001F8r 2  A5 02          lda STR_PTR
0001FAr 2  18             clc
0001FBr 2  69 28          adc #40
0001FDr 2  85 02          sta STR_PTR
0001FFr 2  90 02          bcc @ScrollNoCarry
000201r 2  E6 03          inc STR_PTR + 1
000203r 2               @ScrollNoCarry:
000203r 2  FA             plx                           ; Restore row counter
000204r 2  CA             dex
000205r 2  D0 BB          bne @ScrollRowLoop
000207r 2               
000207r 2                 ; Clear bottom row (row 23) with spaces
000207r 2                 ; Row 23 address = 23 * 40 = 920 = $0398
000207r 2  A9 98          lda #$98                      ; Low byte of $0398
000209r 2  8D 01 9C       sta VC_REG
00020Cr 2  A9 03          lda #$03
00020Er 2  09 40          ora #$40                      ; Write mode
000210r 2  8D 01 9C       sta VC_REG
000213r 2  A9 20          lda #$20                      ; Space character
000215r 2  A0 28          ldy #40
000217r 2               @ScrollClearBottom:
000217r 2  8D 00 9C       sta VC_DATA
00021Ar 2  88             dey
00021Br 2  D0 FA          bne @ScrollClearBottom
00021Dr 2                 ; Restore STR_PTR
00021Dr 2  68             pla
00021Er 2  85 03          sta STR_PTR + 1
000220r 2  68             pla
000221r 2  85 02          sta STR_PTR
000223r 2  60             rts
000224r 2               
000224r 2               ; VideoChrout — Output character to video display
000224r 2               ; Handles control characters: CR ($0D), LF ($0A), BS ($08), BEL ($07)
000224r 2               ; Auto-wraps at column 40, auto-scrolls at row 24
000224r 2               ; Input: A = character to output
000224r 2               ; Preserves: A, X, Y (callers like ChrinImpl, BasPrintStr and Wozmon depend on this)
000224r 2               ; Modifies: Flags
000224r 2               VideoChroutImpl:
000224r 2  48             pha
000225r 2  DA             phx
000226r 2  5A             phy
000227r 2  C9 0D          cmp #$0D                      ; Carriage Return?
000229r 2  F0 43          beq @VideoCR
00022Br 2  C9 0A          cmp #$0A                      ; Line Feed?
00022Dr 2  F0 4C          beq @VideoLF
00022Fr 2  C9 08          cmp #$08                      ; Backspace?
000231r 2  F0 65          beq @VideoBS
000233r 2  C9 07          cmp #$07                      ; Bell?
000235r 2  F0 79          beq @VideoBEL
000237r 2                 ; Regular printable character — write at cursor and advance
000237r 2  20 rr rr       jsr VideoPutChar              ; Write char to VRAM at cursor
00023Ar 2                 ; Advance cursor
00023Ar 2  EE 07 03       inc VID_CURSOR_X
00023Dr 2                 ; Increment VRAM address
00023Dr 2  EE 09 03       inc VID_CURSOR_ADDR
000240r 2  D0 03          bne @CheckWrap
000242r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000245r 2               @CheckWrap:
000245r 2  AD 07 03       lda VID_CURSOR_X
000248r 2  C9 28          cmp #40                       ; Past last column?
00024Ar 2  90 1E          bcc @VideoChroutDone          ; No, done
00024Cr 2                 ; Auto-wrap: CR + LF
00024Cr 2  9C 07 03       stz VID_CURSOR_X
00024Fr 2  EE 08 03       inc VID_CURSOR_Y
000252r 2  AD 08 03       lda VID_CURSOR_Y
000255r 2  C9 18          cmp #24                       ; Past last row?
000257r 2  90 08          bcc @WrapRecalc
000259r 2                 ; Need to scroll
000259r 2  20 rr rr       jsr VideoScroll
00025Cr 2  A9 17          lda #23
00025Er 2  8D 08 03       sta VID_CURSOR_Y
000261r 2               @WrapRecalc:
000261r 2  AE 07 03       ldx VID_CURSOR_X
000264r 2  AC 08 03       ldy VID_CURSOR_Y
000267r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
00026Ar 2               @VideoChroutDone:
00026Ar 2  7A             ply
00026Br 2  FA             plx
00026Cr 2  68             pla
00026Dr 2  60             rts
00026Er 2               
00026Er 2               @VideoCR:
00026Er 2  9C 07 03       stz VID_CURSOR_X              ; Column = 0
000271r 2  A2 00          ldx #$00
000273r 2  AC 08 03       ldy VID_CURSOR_Y
000276r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
000279r 2  80 EF          bra @VideoChroutDone
00027Br 2               
00027Br 2               @VideoLF:
00027Br 2  EE 08 03       inc VID_CURSOR_Y
00027Er 2  AD 08 03       lda VID_CURSOR_Y
000281r 2  C9 18          cmp #24                       ; Past last row?
000283r 2  90 08          bcc @LFRecalc
000285r 2  20 rr rr       jsr VideoScroll
000288r 2  A9 17          lda #23
00028Ar 2  8D 08 03       sta VID_CURSOR_Y
00028Dr 2               @LFRecalc:
00028Dr 2  AE 07 03       ldx VID_CURSOR_X
000290r 2  AC 08 03       ldy VID_CURSOR_Y
000293r 2  20 rr rr       jsr VideoSetCursor
000296r 2  80 D2          bra @VideoChroutDone
000298r 2               
000298r 2               @VideoBS:
000298r 2  AD 07 03       lda VID_CURSOR_X
00029Br 2  F0 CD          beq @VideoChroutDone          ; Already at column 0, ignore
00029Dr 2  CE 07 03       dec VID_CURSOR_X
0002A0r 2  AE 07 03       ldx VID_CURSOR_X
0002A3r 2  AC 08 03       ldy VID_CURSOR_Y
0002A6r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
0002A9r 2  A9 20          lda #$20                      ; Write space to erase character
0002ABr 2  20 rr rr       jsr VideoPutChar
0002AEr 2  80 BA          bra @VideoChroutDone
0002B0r 2               
0002B0r 2               @VideoBEL:
0002B0r 2  20 rr rr       jsr Beep
0002B3r 2  80 B5          bra @VideoChroutDone
0002B5r 2               
0002B5r 2               ; VideoPrintStr — Print null-terminated string to video
0002B5r 2               ; Input: STR_PTR ($02-$03) points to string
0002B5r 2               ; Modifies: Flags, A, X, Y
0002B5r 2               VideoPrintStrImpl:
0002B5r 2  A0 00          ldy #$00
0002B7r 2               @VideoPrintStrLoop:
0002B7r 2  B1 02          lda (STR_PTR),y
0002B9r 2  F0 08          beq @VideoPrintStrDone        ; Exit on null terminator
0002BBr 2  5A             phy
0002BCr 2  20 rr rr       jsr VideoChroutImpl           ; Output character via video
0002BFr 2  7A             ply
0002C0r 2  C8             iny
0002C1r 2  D0 F4          bne @VideoPrintStrLoop        ; Max 256 chars per string
0002C3r 2               @VideoPrintStrDone:
0002C3r 2  60             rts
0002C4r 2               
0002C4r 2               ; Main entry point
0002C4r 2               Reset:
0002C4r 2  D8             cld                           ; Clear decimal mode
0002C5r 2  78             sei                           ; Disable interrupts
0002C6r 2               
0002C6r 2  A2 FF          ldx #$ff
0002C8r 2  9A             txs                           ; Reset the stack pointer
0002C9r 2               
0002C9r 2  A9 rr          lda #<Irq                     ; Initialize the IRQ pointer
0002CBr 2  8D 00 03       sta IRQ_PTR
0002CEr 2  A9 rr          lda #>Irq
0002D0r 2  8D 01 03       sta IRQ_PTR + 1
0002D3r 2               
0002D3r 2  A9 rr          lda #<Break                   ; Initialize the BRK pointer
0002D5r 2  8D 02 03       sta BRK_PTR
0002D8r 2  A9 rr          lda #>Break
0002DAr 2  8D 03 03       sta BRK_PTR + 1
0002DDr 2               
0002DDr 2  A9 rr          lda #<Nmi                     ; Initialize the NMI pointer
0002DFr 2  8D 04 03       sta NMI_PTR
0002E2r 2  A9 rr          lda #>Nmi
0002E4r 2  8D 05 03       sta NMI_PTR + 1
0002E7r 2               
0002E7r 2  20 rr rr       jsr InitBuffer                ; Initialize the input buffer
0002EAr 2  20 rr rr       jsr InitSC                    ; Initialize the Serial Card (6551)
0002EDr 2  20 rr rr       jsr InitSID                   ; Initialize the Sound Card (6581)
0002F0r 2  20 rr rr       jsr InitVideo                 ; Initialize the Video Card (TMS9918)
0002F3r 2  20 rr rr       jsr InitCharacters            ; Initialize the character set
0002F6r 2  20 rr rr       jsr InitKB                    ; Initialize the keyboard (VIA)
0002F9r 2  20 rr rr       jsr StInit                    ; Initialize CompactFlash (8-bit mode)
0002FCr 2               
0002FCr 2  A9 00          lda #$00                      ; Default to video output mode
0002FEr 2  8D 06 03       sta IO_MODE
000301r 2  9C 07 03       stz VID_CURSOR_X              ; Initialize video cursor state
000304r 2  9C 08 03       stz VID_CURSOR_Y
000307r 2  9C 09 03       stz VID_CURSOR_ADDR
00030Ar 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
00030Dr 2               
00030Dr 2  20 rr rr       jsr Beep                      ; Play the startup beep
000310r 2  20 rr rr       jsr Splash                    ; Draw the splash screen
000313r 2               
000313r 2  58             cli                           ; Enable interrupts
000314r 2               
000314r 2                 ; Boot menu — wait for keypress
000314r 2               @BootWait:
000314r 2  20 rr rr       jsr BufferSize
000317r 2  F0 FB          beq @BootWait                 ; Loop until a key is pressed
000319r 2  20 rr rr       jsr ReadBuffer                ; Read the keypress
00031Cr 2  C9 0D          cmp #$0D                      ; ENTER?
00031Er 2  F0 06          beq @BootBASIC
000320r 2  C9 1B          cmp #$1B                      ; ESC?
000322r 2  F0 08          beq @BootMonitor
000324r 2  80 EE          bra @BootWait                 ; Ignore other keys
000326r 2               @BootBASIC:
000326r 2  20 rr rr       jsr VideoClear                ; Clear screen before entering BASIC
000329r 2  4C rr rr       jmp BasEntry
00032Cr 2               @BootMonitor:
00032Cr 2  20 rr rr       jsr VideoClear                ; Clear screen before entering Monitor
00032Fr 2  4C rr rr       jmp MonitorEntry
000332r 2               
000332r 2               ; Initialize the Keyboard via VIA (IO 6)
000332r 2               ; Configures Port B (matrix) and Port A (PS/2) as inputs
000332r 2               ; CB2 low (enable matrix encoder), CA2 low (enable PS/2 encoder)
000332r 2               ; CB1 and CA1 falling-edge IRQs enabled
000332r 2               ; Modifies: Flags, A
000332r 2               InitKBImpl:
000332r 2  A9 00          lda #$00                      ; Port B all inputs (matrix keyboard data bus)
000334r 2  8D 02 94       sta GPIO_DDRB
000337r 2  A9 00          lda #$00                      ; Port A all inputs (PS/2 keyboard data bus)
000339r 2  8D 03 94       sta GPIO_DDRA
00033Cr 2                 ; PCR: CB2 low + CB1 neg + CA2 low + CA1 neg
00033Cr 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
00033Er 2  8D 0C 94       sta GPIO_PCR
000341r 2                 ; Enable both CB1 and CA1 interrupts
000341r 2  A9 92          lda #(GPIO_IER_SET | GPIO_INT_CB1 | GPIO_INT_CA1)
000343r 2  8D 0E 94       sta GPIO_IER
000346r 2  60             rts
000347r 2               
000347r 2               ; Initialize the Serial Card (6551)
000347r 2               ; Modifies: Flags, A
000347r 2               InitSCImpl:
000347r 2  A9 1F          lda     #$1F                  ; 8-N-1, 19200 baud
000349r 2  8D 03 90       sta     SC_CTRL
00034Cr 2  A9 09          lda     #$09                  ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
00034Er 2  8D 02 90       sta     SC_CMD
000351r 2  60             rts
000352r 2               
000352r 2               ; Initialze the Sound Card (6581)
000352r 2               ; Modifies: Flags, A, X
000352r 2               InitSIDImpl:
000352r 2  A9 00          lda #$00
000354r 2  A2 1D          ldx #$1D                      ; Clear all 29 SID registers
000356r 2               @InitSIDLoop:
000356r 2  9D 00 98       sta SID_V1_FREQ_LO,x          ; Clear register
000359r 2  CA             dex
00035Ar 2  10 FA          bpl @InitSIDLoop              ; Loop until all registers cleared
00035Cr 2  A9 0F          lda #$0F                      ; Set volume to maximum
00035Er 2  8D 18 98       sta SID_MODE_VOL
000361r 2  60             rts
000362r 2               
000362r 2               ; Initialize the Video Card (TMS9918)
000362r 2               ; Modifies: Flags, A, X
000362r 2               InitVideoImpl:
000362r 2  A2 00          ldx #$00                      ; Start with register 0
000364r 2               @InitVideoLoop:
000364r 2  BD rr rr       lda @InitVideoRegData,x       ; Load register value
000367r 2  8D 01 9C       sta VC_REG                    ; Write data byte
00036Ar 2  8A             txa
00036Br 2  09 80          ora #$80                      ; Set bit 7 to indicate register write
00036Dr 2  8D 01 9C       sta VC_REG                    ; Write register number
000370r 2  E8             inx
000371r 2  E0 08          cpx #$08                      ; Check if all 8 registers written
000373r 2  D0 EF          bne @InitVideoLoop            ; Continue until done
000375r 2  60             rts
000376r 2               @InitVideoRegData:
000376r 2  00             .byte $00                     ; R0: Mode control (no external video)
000377r 2  D0             .byte $D0                     ; R1: 16K, display on, interrupt off, text mode M1
000378r 2  00             .byte $00                     ; R2: Name table at $0000 (0x00 * 0x400)
000379r 2  00             .byte $00                     ; R3: Color table (not used in text mode)
00037Ar 2  01             .byte $01                     ; R4: Pattern table at $0800 (0x01 * 0x800)
00037Br 2  00             .byte $00                     ; R5: Sprite attribute table (not used in text mode)
00037Cr 2  00             .byte $00                     ; R6: Sprite pattern table (not used in text mode)
00037Dr 2  F0             .byte $F0                     ; R7: White text on black background
00037Er 2               
00037Er 2               ; Initialize the character set
00037Er 2               ; Modifies: Flags, A, X, Y
00037Er 2               InitCharacters:
00037Er 2                 ; Set VRAM write address to $0800 (pattern table base)
00037Er 2  A9 00          lda #$00                      ; Low byte of address
000380r 2  8D 01 9C       sta VC_REG
000383r 2  A9 48          lda #$48                      ; High byte ($08) OR $40 for write mode
000385r 2  8D 01 9C       sta VC_REG
000388r 2                 ; Set up source pointer
000388r 2  A9 rr          lda #<CharacterSet
00038Ar 2  85 02          sta STR_PTR                   ; Use STR_PTR ($02-$03) for character set pointer
00038Cr 2  A9 rr          lda #>CharacterSet
00038Er 2  85 03          sta STR_PTR + 1
000390r 2                 ; Copy 2048 bytes (8 pages of 256 bytes each)
000390r 2  A2 08          ldx #$08                      ; 8 pages to copy
000392r 2  A0 00          ldy #$00                      ; Byte counter within page
000394r 2               @InitCharPageLoop:
000394r 2  B1 02          lda (STR_PTR),y               ; Load from character set
000396r 2  8D 00 9C       sta VC_DATA                   ; Write to VRAM
000399r 2  C8             iny
00039Ar 2  D0 F8          bne @InitCharPageLoop         ; Loop until page complete (256 bytes)
00039Cr 2  E6 03          inc STR_PTR + 1               ; Move to next page
00039Er 2  CA             dex
00039Fr 2  D0 F3          bne @InitCharPageLoop         ; Loop for all 8 pages
0003A1r 2  60             rts
0003A2r 2               
0003A2r 2               ; Initialize the INPUT_BUFFER
0003A2r 2               ; Modifies: Flags, A
0003A2r 2               InitBuffer:
0003A2r 2  A9 00          lda #$00
0003A4r 2  85 00          sta READ_PTR                  ; Init read and write pointers
0003A6r 2  85 01          sta WRITE_PTR
0003A8r 2  60             rts
0003A9r 2               
0003A9r 2               ; Write a character from the A register to the INPUT_BUFFER
0003A9r 2               ; Modifies: Flags, X
0003A9r 2               WriteBufferImpl:
0003A9r 2  A6 01          ldx WRITE_PTR
0003ABr 2  9D 00 02       sta INPUT_BUFFER,x
0003AEr 2  E6 01          inc WRITE_PTR
0003B0r 2  60             rts
0003B1r 2               
0003B1r 2               ; Read a character from the INPUT_BUFFER and store it in A register
0003B1r 2               ; Modifies: Flags, X, A
0003B1r 2               ReadBufferImpl:
0003B1r 2  A6 00          ldx READ_PTR
0003B3r 2  BD 00 02       lda INPUT_BUFFER,x
0003B6r 2  E6 00          inc READ_PTR
0003B8r 2  60             rts
0003B9r 2               
0003B9r 2               ; Return in A register the number of unread bytes in the INPUT_BUFFER
0003B9r 2               ; Modifies: Flags, A
0003B9r 2               BufferSizeImpl:
0003B9r 2  A5 01          lda WRITE_PTR
0003BBr 2  38             sec
0003BCr 2  E5 00          sbc READ_PTR
0003BEr 2  60             rts
0003BFr 2               
0003BFr 2               ; Get a character from the INPUT_BUFFER if available
0003BFr 2               ; On return, carry flag indicates whether a character was available
0003BFr 2               ; If character available the character will be in the A register
0003BFr 2               ; Modifies: Flags, A
0003BFr 2               ChrinImpl:
0003BFr 2  DA             phx
0003C0r 2  20 rr rr       jsr BufferSize                ; Check for character available
0003C3r 2  F0 1E          beq @ChrinNoChar              ; Branch if no character available
0003C5r 2  20 rr rr       jsr ReadBuffer                ; Read the character from the buffer
0003C8r 2  20 rr rr       jsr Chrout                    ; Echo
0003CBr 2  48             pha
0003CCr 2  20 rr rr       jsr BufferSize
0003CFr 2  C9 B0          cmp #$B0                      ; Check if buffer is mostly full
0003D1r 2  90 07          bcc @ChrinNotFull             ; Branch if buffer size < $B0
0003D3r 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
0003D5r 2  8D 02 90       sta SC_CMD
0003D8r 2  80 05          bra @ChrinExit
0003DAr 2               @ChrinNotFull:
0003DAr 2  A9 09          lda #$09                      ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
0003DCr 2  8D 02 90       sta SC_CMD
0003DFr 2               @ChrinExit:
0003DFr 2  68             pla
0003E0r 2  FA             plx
0003E1r 2  38             sec
0003E2r 2  60             rts
0003E3r 2               @ChrinNoChar:
0003E3r 2  FA             plx
0003E4r 2  18             clc
0003E5r 2  60             rts
0003E6r 2               
0003E6r 2               ; Output a character from the A register to the Serial Card
0003E6r 2               ; Modifies: Flags
0003E6r 2               SerialChroutImpl:
0003E6r 2  8D 00 90       sta SC_DATA
0003E9r 2  48             pha
0003EAr 2               @ChroutWait:
0003EAr 2  AD 01 90       lda SC_STATUS
0003EDr 2  29 10          and #SC_STATUS_TDRE           ; Check if TX buffer not empty
0003EFr 2  F0 F9          beq @ChroutWait               ; Loop if TX buffer not empty
0003F1r 2  68             pla
0003F2r 2  60             rts
0003F3r 2               
0003F3r 2               ; SidPlayNote — Play a note on a SID voice
0003F3r 2               ; Input: A = voice (0-2), X = frequency low byte, Y = frequency high byte
0003F3r 2               ; Uses triangle waveform with standard ADSR (Attack=0, Decay=9, Sustain=A, Release=2)
0003F3r 2               ; Modifies: Flags, A
0003F3r 2               SidPlayNoteImpl:
0003F3r 2  C9 01          cmp #$01
0003F5r 2  F0 1A          beq @Voice2
0003F7r 2  C9 02          cmp #$02
0003F9r 2  F0 2C          beq @Voice3
0003FBr 2                 ; Voice 0
0003FBr 2  8E 00 98       stx SID_V1_FREQ_LO
0003FEr 2  8C 01 98       sty SID_V1_FREQ_HI
000401r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
000403r 2  8D 05 98       sta SID_V1_AD
000406r 2  A9 A2          lda #$A2                      ; Sustain = A, Release = 2
000408r 2  8D 06 98       sta SID_V1_SR
00040Br 2  A9 11          lda #$11                      ; Triangle wave + Gate on
00040Dr 2  8D 04 98       sta SID_V1_CTRL
000410r 2  60             rts
000411r 2               @Voice2:
000411r 2  8E 07 98       stx SID_V2_FREQ_LO
000414r 2  8C 08 98       sty SID_V2_FREQ_HI
000417r 2  A9 09          lda #$09
000419r 2  8D 0C 98       sta SID_V2_AD
00041Cr 2  A9 A2          lda #$A2
00041Er 2  8D 0D 98       sta SID_V2_SR
000421r 2  A9 11          lda #$11
000423r 2  8D 0B 98       sta SID_V2_CTRL
000426r 2  60             rts
000427r 2               @Voice3:
000427r 2  8E 0E 98       stx SID_V3_FREQ_LO
00042Ar 2  8C 0F 98       sty SID_V3_FREQ_HI
00042Dr 2  A9 09          lda #$09
00042Fr 2  8D 13 98       sta SID_V3_AD
000432r 2  A9 A2          lda #$A2
000434r 2  8D 14 98       sta SID_V3_SR
000437r 2  A9 11          lda #$11
000439r 2  8D 12 98       sta SID_V3_CTRL
00043Cr 2  60             rts
00043Dr 2               
00043Dr 2               ; SidSilence — Silence all 3 SID voices
00043Dr 2               ; Gates off all voices and zeros their frequencies
00043Dr 2               ; Modifies: Flags, A
00043Dr 2               SidSilenceImpl:
00043Dr 2  A9 10          lda #$10                      ; Triangle wave, Gate off
00043Fr 2  8D 04 98       sta SID_V1_CTRL
000442r 2  8D 0B 98       sta SID_V2_CTRL
000445r 2  8D 12 98       sta SID_V3_CTRL
000448r 2  A9 00          lda #$00
00044Ar 2  8D 00 98       sta SID_V1_FREQ_LO
00044Dr 2  8D 01 98       sta SID_V1_FREQ_HI
000450r 2  8D 07 98       sta SID_V2_FREQ_LO
000453r 2  8D 08 98       sta SID_V2_FREQ_HI
000456r 2  8D 0E 98       sta SID_V3_FREQ_LO
000459r 2  8D 0F 98       sta SID_V3_FREQ_HI
00045Cr 2  60             rts
00045Dr 2               
00045Dr 2               ; Play a short beep sound
00045Dr 2               ; Uses SidPlayNote on voice 0 with ~1000 Hz tone, then silences
00045Dr 2               ; Modifies: Flags, A, X, Y
00045Dr 2               BeepImpl:
00045Dr 2  A9 00          lda #$00                      ; Voice 0
00045Fr 2  A2 20          ldx #$20                      ; Frequency low byte (~1000 Hz)
000461r 2  A0 1F          ldy #$1F                      ; Frequency high byte
000463r 2  20 rr rr       jsr SidPlayNote
000466r 2                 ; Override ADSR for beep: fast decay, no sustain
000466r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
000468r 2  8D 05 98       sta SID_V1_AD
00046Br 2  A9 00          lda #$00                      ; Sustain = 0, Release = 0
00046Dr 2  8D 06 98       sta SID_V1_SR
000470r 2                 ; Delay for beep duration
000470r 2  A2 F0          ldx #$F0                      ; Outer loop counter
000472r 2               @BeepDelay1:
000472r 2  A0 FF          ldy #$FF                      ; Inner loop counter
000474r 2               @BeepDelay2:
000474r 2  88             dey
000475r 2  D0 FD          bne @BeepDelay2
000477r 2  CA             dex
000478r 2  D0 F8          bne @BeepDelay1
00047Ar 2  20 rr rr       jsr SidSilence                ; Gate off all voices
00047Dr 2  60             rts
00047Er 2               
00047Er 2               ; KBDisable — Disable both keyboard encoders for raw port access
00047Er 2               ; Sets CB2 high (disable matrix encoder) and CA2 high (disable PS/2 encoder)
00047Er 2               ; Modifies: Flags, A
00047Er 2               KBDisable:
00047Er 2  A9 EE          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
000480r 2  8D 0C 94       sta GPIO_PCR
000483r 2  60             rts
000484r 2               
000484r 2               ; KBEnable — Re-enable both keyboard encoders
000484r 2               ; Sets CB2 low (enable matrix encoder) and CA2 low (enable PS/2 encoder)
000484r 2               ; Modifies: Flags, A
000484r 2               KBEnable:
000484r 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
000486r 2  8D 0C 94       sta GPIO_PCR
000489r 2  60             rts
00048Ar 2               
00048Ar 2               ; ReadJoystick1 — Read joystick 1 on Port B
00048Ar 2               ; Temporarily disables matrix keyboard encoder (CB2 high) to read raw port data
00048Ar 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
00048Ar 2               ; Modifies: Flags, A
00048Ar 2               ReadJoystick1Impl:
00048Ar 2  78             sei                           ; Disable interrupts during raw port read
00048Br 2  AD 0C 94       lda GPIO_PCR
00048Er 2  48             pha                           ; Save current PCR state
00048Fr 2                 ; Set CB2 high to disable matrix encoder, preserve CA2 state
00048Fr 2  A9 EC          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
000491r 2  8D 0C 94       sta GPIO_PCR
000494r 2  AD 00 94       lda GPIO_PORTB                ; Read raw joystick data from Port B
000497r 2  AA             tax                           ; Save result in X
000498r 2  68             pla                           ; Restore original PCR state
000499r 2  8D 0C 94       sta GPIO_PCR
00049Cr 2  8A             txa                           ; Return result in A
00049Dr 2  58             cli                           ; Re-enable interrupts
00049Er 2  60             rts
00049Fr 2               
00049Fr 2               ; ReadJoystick2 — Read joystick 2 on Port A
00049Fr 2               ; Temporarily disables PS/2 keyboard encoder (CA2 high) to read raw port data
00049Fr 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
00049Fr 2               ; Modifies: Flags, A
00049Fr 2               ReadJoystick2Impl:
00049Fr 2  78             sei                           ; Disable interrupts during raw port read
0004A0r 2  AD 0C 94       lda GPIO_PCR
0004A3r 2  48             pha                           ; Save current PCR state
0004A4r 2                 ; Set CA2 high to disable PS/2 encoder, preserve CB2 state
0004A4r 2  A9 CE          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0004A6r 2  8D 0C 94       sta GPIO_PCR
0004A9r 2  AD 01 94       lda GPIO_PORTA                ; Read raw joystick data from Port A
0004ACr 2  AA             tax                           ; Save result in X
0004ADr 2  68             pla                           ; Restore original PCR state
0004AEr 2  8D 0C 94       sta GPIO_PCR
0004B1r 2  8A             txa                           ; Return result in A
0004B2r 2  58             cli                           ; Re-enable interrupts
0004B3r 2  60             rts
0004B4r 2               
0004B4r 2               ; === BCD Conversion Helpers ===
0004B4r 2               
0004B4r 2               ; BcdToBin — Convert BCD byte to binary
0004B4r 2               ; Input: A = BCD value (e.g. $35 represents 35)
0004B4r 2               ; Output: A = binary value (e.g. 35 = $23)
0004B4r 2               ; Modifies: Flags
0004B4r 2               BcdToBin:
0004B4r 2  48             pha
0004B5r 2  4A             lsr a                         ; Shift tens digit to low nibble
0004B6r 2  4A             lsr a
0004B7r 2  4A             lsr a
0004B8r 2  4A             lsr a                         ; A = tens digit (0-9)
0004B9r 2  0A             asl a                         ; A = tens * 2
0004BAr 2  8D 0C 03       sta RTC_TMP
0004BDr 2  0A             asl a                         ; A = tens * 4
0004BEr 2  0A             asl a                         ; A = tens * 8
0004BFr 2  18             clc
0004C0r 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 (8 + 2)
0004C3r 2  8D 0C 03       sta RTC_TMP
0004C6r 2  68             pla
0004C7r 2  29 0F          and #$0F                      ; A = ones digit
0004C9r 2  18             clc
0004CAr 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 + ones = binary
0004CDr 2  60             rts
0004CEr 2               
0004CEr 2               ; BinToBcd — Convert binary byte to BCD
0004CEr 2               ; Input: A = binary value (0-99)
0004CEr 2               ; Output: A = BCD value
0004CEr 2               ; Modifies: Flags, X
0004CEr 2               BinToBcd:
0004CEr 2  A2 FF          ldx #$FF                      ; Tens counter (starts at -1)
0004D0r 2               @BinToBcdLoop:
0004D0r 2  E8             inx
0004D1r 2  38             sec
0004D2r 2  E9 0A          sbc #10
0004D4r 2  B0 FA          bcs @BinToBcdLoop             ; Count tens
0004D6r 2  69 0A          adc #10                       ; Restore ones (carry clear, so adds 10 + 0)
0004D8r 2  8D 0C 03       sta RTC_TMP                   ; Save ones digit
0004DBr 2  8A             txa                           ; A = tens digit
0004DCr 2  0A             asl a
0004DDr 2  0A             asl a
0004DEr 2  0A             asl a
0004DFr 2  0A             asl a                         ; Shift tens to high nibble
0004E0r 2  0D 0C 03       ora RTC_TMP                   ; Combine with ones
0004E3r 2  60             rts
0004E4r 2               
0004E4r 2               ; === DS1511Y RTC Routines ===
0004E4r 2               
0004E4r 2               ; RtcReadTime — Read current time from DS1511Y
0004E4r 2               ; Output: A = hours (binary), X = minutes (binary), Y = seconds (binary)
0004E4r 2               ; Modifies: Flags
0004E4r 2               RtcReadTimeImpl:
0004E4r 2  AD 02 88       lda RTC_HR
0004E7r 2  20 rr rr       jsr BcdToBin
0004EAr 2  48             pha                           ; Save hours
0004EBr 2  AD 01 88       lda RTC_MIN
0004EEr 2  20 rr rr       jsr BcdToBin
0004F1r 2  AA             tax                           ; X = minutes
0004F2r 2  AD 00 88       lda RTC_SEC
0004F5r 2  20 rr rr       jsr BcdToBin
0004F8r 2  A8             tay                           ; Y = seconds
0004F9r 2  68             pla                           ; A = hours
0004FAr 2  60             rts
0004FBr 2               
0004FBr 2               ; RtcReadDate — Read current date from DS1511Y
0004FBr 2               ; Output: A = day of month (binary), X = month (binary), Y = year (binary)
0004FBr 2               ;         RTC_BUF_CENT = century (binary)
0004FBr 2               ; Modifies: Flags
0004FBr 2               RtcReadDateImpl:
0004FBr 2  AD 07 88       lda RTC_CENT
0004FEr 2  20 rr rr       jsr BcdToBin
000501r 2  8D 0B 03       sta RTC_BUF_CENT              ; Store century in buffer
000504r 2  AD 05 88       lda RTC_MON
000507r 2  20 rr rr       jsr BcdToBin
00050Ar 2  AA             tax                           ; X = month
00050Br 2  AD 06 88       lda RTC_YR
00050Er 2  20 rr rr       jsr BcdToBin
000511r 2  A8             tay                           ; Y = year
000512r 2  AD 04 88       lda RTC_DATE
000515r 2  20 rr rr       jsr BcdToBin                  ; A = day of month
000518r 2  60             rts
000519r 2               
000519r 2               ; RtcWriteTime — Set DS1511Y time
000519r 2               ; Input: A = hours (binary), X = minutes (binary), Y = seconds (binary)
000519r 2               ; Modifies: Flags, A, X
000519r 2               RtcWriteTimeImpl:
000519r 2  48             pha                           ; Save hours
00051Ar 2  DA             phx                           ; Save minutes
00051Br 2  5A             phy                           ; Save seconds
00051Cr 2                 ; Set TE bit to inhibit update transfers
00051Cr 2  AD 0F 88       lda RTC_CTRL_B
00051Fr 2  09 80          ora #RTC_CTRL_B_TE
000521r 2  8D 0F 88       sta RTC_CTRL_B
000524r 2                 ; Write seconds
000524r 2  68             pla                           ; A = seconds
000525r 2  20 rr rr       jsr BinToBcd
000528r 2  8D 00 88       sta RTC_SEC
00052Br 2                 ; Write minutes
00052Br 2  68             pla                           ; A = minutes
00052Cr 2  20 rr rr       jsr BinToBcd
00052Fr 2  8D 01 88       sta RTC_MIN
000532r 2                 ; Write hours
000532r 2  68             pla                           ; A = hours
000533r 2  20 rr rr       jsr BinToBcd
000536r 2  8D 02 88       sta RTC_HR
000539r 2                 ; Clear TE bit to resume updates
000539r 2  AD 0F 88       lda RTC_CTRL_B
00053Cr 2  29 7F          and #<~RTC_CTRL_B_TE
00053Er 2  8D 0F 88       sta RTC_CTRL_B
000541r 2  60             rts
000542r 2               
000542r 2               ; RtcWriteDate — Set DS1511Y date
000542r 2               ; Input: A = day of month (binary), X = month (binary), Y = year (binary)
000542r 2               ;        RTC_BUF_CENT = century (binary)
000542r 2               ; Modifies: Flags, A, X
000542r 2               RtcWriteDateImpl:
000542r 2  48             pha                           ; Save day
000543r 2  DA             phx                           ; Save month
000544r 2  5A             phy                           ; Save year
000545r 2                 ; Set TE bit to inhibit update transfers
000545r 2  AD 0F 88       lda RTC_CTRL_B
000548r 2  09 80          ora #RTC_CTRL_B_TE
00054Ar 2  8D 0F 88       sta RTC_CTRL_B
00054Dr 2                 ; Write century
00054Dr 2  AD 0B 03       lda RTC_BUF_CENT
000550r 2  20 rr rr       jsr BinToBcd
000553r 2  8D 07 88       sta RTC_CENT
000556r 2                 ; Write year
000556r 2  68             pla                           ; A = year
000557r 2  20 rr rr       jsr BinToBcd
00055Ar 2  8D 06 88       sta RTC_YR
00055Dr 2                 ; Write month
00055Dr 2  68             pla                           ; A = month
00055Er 2  20 rr rr       jsr BinToBcd
000561r 2  8D 05 88       sta RTC_MON
000564r 2                 ; Write day
000564r 2  68             pla                           ; A = day
000565r 2  20 rr rr       jsr BinToBcd
000568r 2  8D 04 88       sta RTC_DATE
00056Br 2                 ; Clear TE bit to resume updates
00056Br 2  AD 0F 88       lda RTC_CTRL_B
00056Er 2  29 7F          and #<~RTC_CTRL_B_TE
000570r 2  8D 0F 88       sta RTC_CTRL_B
000573r 2  60             rts
000574r 2               
000574r 2               ; RtcReadNVRAM — Read a byte from DS1511Y NVRAM
000574r 2               ; Input: X = NVRAM address ($00-$FF)
000574r 2               ; Output: A = data byte
000574r 2               ; Modifies: Flags
000574r 2               RtcReadNVRAMImpl:
000574r 2  8E 10 88       stx RTC_RAM_ADDR
000577r 2  AD 13 88       lda RTC_RAM_DATA
00057Ar 2  60             rts
00057Br 2               
00057Br 2               ; RtcWriteNVRAM — Write a byte to DS1511Y NVRAM
00057Br 2               ; Input: X = NVRAM address ($00-$FF), A = data byte
00057Br 2               ; Modifies: Flags
00057Br 2               RtcWriteNVRAMImpl:
00057Br 2  8E 10 88       stx RTC_RAM_ADDR
00057Er 2  8D 13 88       sta RTC_RAM_DATA
000581r 2  60             rts
000582r 2               
000582r 2               ; === CompactFlash Storage Driver (True 8-bit IDE Mode) ===
000582r 2               
000582r 2               ; StWaitReady — Wait for CompactFlash to become ready
000582r 2               ; Polls ST_STATUS until BSY=0 and RDY=1
000582r 2               ; Output: Carry clear = ready, Carry set = error (ERR bit set)
000582r 2               ; Modifies: Flags, A
000582r 2               StWaitReadyImpl:
000582r 2               @StWaitBsy:
000582r 2  AD 07 8C       lda ST_STATUS
000585r 2  29 80          and #ST_STATUS_BSY            ; Check BSY bit
000587r 2  D0 F9          bne @StWaitBsy                ; Loop while busy
000589r 2  AD 07 8C       lda ST_STATUS
00058Cr 2  29 40          and #ST_STATUS_RDY            ; Check RDY bit
00058Er 2  F0 F2          beq @StWaitBsy                ; Loop until ready
000590r 2  AD 07 8C       lda ST_STATUS
000593r 2  29 01          and #ST_STATUS_ERR            ; Check ERR bit
000595r 2  D0 02          bne @StWaitErr
000597r 2  18             clc                           ; Ready, no error
000598r 2  60             rts
000599r 2               @StWaitErr:
000599r 2  38             sec                           ; Error condition
00059Ar 2  60             rts
00059Br 2               
00059Br 2               ; StWaitDrq — Wait for CompactFlash data request
00059Br 2               ; Polls ST_STATUS until BSY=0 and DRQ=1
00059Br 2               ; Output: Carry clear = DRQ active, Carry set = error
00059Br 2               ; Modifies: Flags, A
00059Br 2               StWaitDrq:
00059Br 2               @StDrqBsy:
00059Br 2  AD 07 8C       lda ST_STATUS
00059Er 2  29 80          and #ST_STATUS_BSY
0005A0r 2  D0 F9          bne @StDrqBsy
0005A2r 2  AD 07 8C       lda ST_STATUS
0005A5r 2  29 01          and #ST_STATUS_ERR
0005A7r 2  D0 09          bne @StDrqErr
0005A9r 2  AD 07 8C       lda ST_STATUS
0005ACr 2  29 08          and #ST_STATUS_DRQ
0005AEr 2  F0 EB          beq @StDrqBsy
0005B0r 2  18             clc
0005B1r 2  60             rts
0005B2r 2               @StDrqErr:
0005B2r 2  38             sec
0005B3r 2  60             rts
0005B4r 2               
0005B4r 2               ; StInit — Initialize CompactFlash for 8-bit data transfers
0005B4r 2               ; Issues Set Features command with subcommand $01 (enable 8-bit I/O)
0005B4r 2               ; Output: Carry clear = success, Carry set = error
0005B4r 2               ; Modifies: Flags, A
0005B4r 2               StInit:
0005B4r 2  20 rr rr       jsr StWaitReady
0005B7r 2  B0 0D          bcs @StInitDone
0005B9r 2  A9 01          lda #ST_FEAT_8BIT             ; Feature: enable 8-bit data I/O
0005BBr 2  8D 01 8C       sta ST_FEATURE
0005BEr 2  A9 EF          lda #ST_CMD_SET_FEAT          ; Set Features command
0005C0r 2  8D 07 8C       sta ST_CMD
0005C3r 2  20 rr rr       jsr StWaitReady               ; Wait for command completion
0005C6r 2               @StInitDone:
0005C6r 2  60             rts
0005C7r 2               
0005C7r 2               ; StSetupLba — Set up LBA registers from CF_LBA zero page variables
0005C7r 2               ; Also sets sector count to 1 and selects master drive in LBA mode
0005C7r 2               ; Modifies: Flags, A
0005C7r 2               StSetupLba:
0005C7r 2  A9 01          lda #$01
0005C9r 2  8D 02 8C       sta ST_SECT_CNT               ; Always 1 sector
0005CCr 2  A5 26          lda CF_LBA
0005CEr 2  8D 03 8C       sta ST_LBA_0                  ; LBA bits 0-7
0005D1r 2  A5 27          lda CF_LBA + 1
0005D3r 2  8D 04 8C       sta ST_LBA_1                  ; LBA bits 8-15
0005D6r 2  A5 28          lda CF_LBA + 2
0005D8r 2  8D 05 8C       sta ST_LBA_2                  ; LBA bits 16-23
0005DBr 2  A5 29          lda CF_LBA + 3
0005DDr 2  29 0F          and #$0F                      ; Mask to 4 bits (LBA 24-27)
0005DFr 2  09 E0          ora #ST_LBA3_MASTER           ; LBA mode, master drive
0005E1r 2  8D 06 8C       sta ST_LBA_3
0005E4r 2  60             rts
0005E5r 2               
0005E5r 2               ; StReadSector — Read one 512-byte sector from CompactFlash
0005E5r 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = destination pointer
0005E5r 2               ; Output: Carry clear = success, Carry set = error
0005E5r 2               ;         CF_BUF_PTR advanced by 512 bytes on success
0005E5r 2               ; Modifies: Flags, A, X, Y
0005E5r 2               StReadSectorImpl:
0005E5r 2  20 rr rr       jsr StWaitReady
0005E8r 2  B0 1F          bcs @StReadDone
0005EAr 2  20 rr rr       jsr StSetupLba
0005EDr 2  A9 20          lda #ST_CMD_READ              ; Issue read command
0005EFr 2  8D 07 8C       sta ST_CMD
0005F2r 2  20 rr rr       jsr StWaitDrq                 ; Wait for data ready
0005F5r 2  B0 12          bcs @StReadDone
0005F7r 2                 ; Read 512 bytes: 2 pages of 256 bytes
0005F7r 2  A0 00          ldy #$00
0005F9r 2  A2 02          ldx #$02                      ; 2 pages
0005FBr 2               @StReadPage:
0005FBr 2  AD 00 8C       lda ST_DATA                   ; Read byte from CF
0005FEr 2  91 24          sta (CF_BUF_PTR),y            ; Store to destination
000600r 2  C8             iny
000601r 2  D0 F8          bne @StReadPage               ; Loop for 256 bytes
000603r 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
000605r 2  CA             dex
000606r 2  D0 F3          bne @StReadPage
000608r 2  18             clc                           ; Success
000609r 2               @StReadDone:
000609r 2  60             rts
00060Ar 2               
00060Ar 2               ; StWriteSector — Write one 512-byte sector to CompactFlash
00060Ar 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = source pointer
00060Ar 2               ; Output: Carry clear = success, Carry set = error
00060Ar 2               ;         CF_BUF_PTR advanced by 512 bytes on success
00060Ar 2               ; Modifies: Flags, A, X, Y
00060Ar 2               StWriteSectorImpl:
00060Ar 2  20 rr rr       jsr StWaitReady
00060Dr 2  B0 21          bcs @StWriteDone
00060Fr 2  20 rr rr       jsr StSetupLba
000612r 2  A9 30          lda #ST_CMD_WRITE             ; Issue write command
000614r 2  8D 07 8C       sta ST_CMD
000617r 2  20 rr rr       jsr StWaitDrq                 ; Wait for data request
00061Ar 2  B0 14          bcs @StWriteDone
00061Cr 2                 ; Write 512 bytes: 2 pages of 256 bytes
00061Cr 2  A0 00          ldy #$00
00061Er 2  A2 02          ldx #$02                      ; 2 pages
000620r 2               @StWritePage:
000620r 2  B1 24          lda (CF_BUF_PTR),y            ; Load from source
000622r 2  8D 00 8C       sta ST_DATA                   ; Write byte to CF
000625r 2  C8             iny
000626r 2  D0 F8          bne @StWritePage              ; Loop for 256 bytes
000628r 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
00062Ar 2  CA             dex
00062Br 2  D0 F3          bne @StWritePage
00062Dr 2  20 rr rr       jsr StWaitReady               ; Wait for write to complete
000630r 2               @StWriteDone:
000630r 2  60             rts
000631r 2               
000631r 2               ; === Simple Custom Filesystem ===
000631r 2               ; Directory at LBA 0: 16 entries x 32 bytes = 512 bytes
000631r 2               ; Entry format:
000631r 2               ;   $00-$07: 8-byte filename (space-padded)
000631r 2               ;   $08-$0A: 3-byte extension (space-padded)
000631r 2               ;   $0B:     flags (bit 0 = in use)
000631r 2               ;   $0C-$0D: start sector (little-endian)
000631r 2               ;   $0E-$0F: file size in bytes (little-endian)
000631r 2               ;   $10-$1F: reserved (16 bytes)
000631r 2               
000631r 2               ; FsParseName — Parse null-terminated filename at STR_PTR into FS_FNAME_BUF
000631r 2               ; Converts "NAME.EXT" into 8+3 space-padded format
000631r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000631r 2               ; Output: FS_FNAME_BUF filled with padded 8+3 name
000631r 2               ; Modifies: Flags, A, X, Y
000631r 2               FsParseName:
000631r 2                 ; Fill FS_FNAME_BUF with spaces
000631r 2  A9 20          lda #$20
000633r 2  A2 0A          ldx #10
000635r 2               @FsParseClr:
000635r 2  9D 50 03       sta FS_FNAME_BUF,x
000638r 2  CA             dex
000639r 2  10 FA          bpl @FsParseClr
00063Br 2                 ; Copy name part (up to 8 chars, stop at '.' or null)
00063Br 2  A0 00          ldy #$00                      ; Source index
00063Dr 2  A2 00          ldx #$00                      ; Dest index (name portion)
00063Fr 2               @FsParseName:
00063Fr 2  B1 02          lda (STR_PTR),y
000641r 2  F0 35          beq @FsParseDone              ; Null terminator — no extension
000643r 2  C9 2E          cmp #'.'
000645r 2  F0 15          beq @FsParseExt               ; Found dot — start extension
000647r 2  E0 08          cpx #$08
000649r 2  B0 0E          bcs @FsParseSkipName          ; Already 8 chars, skip extras
00064Br 2                 ; Convert lowercase to uppercase
00064Br 2  C9 61          cmp #'a'
00064Dr 2  90 06          bcc @FsStoreNameChar
00064Fr 2  C9 7B          cmp #'z' + 1
000651r 2  B0 02          bcs @FsStoreNameChar
000653r 2  29 DF          and #$DF                      ; Clear bit 5 to uppercase
000655r 2               @FsStoreNameChar:
000655r 2  9D 50 03       sta FS_FNAME_BUF,x
000658r 2  E8             inx
000659r 2               @FsParseSkipName:
000659r 2  C8             iny
00065Ar 2  80 E3          bra @FsParseName
00065Cr 2               @FsParseExt:
00065Cr 2  C8             iny                           ; Skip the dot
00065Dr 2  A2 08          ldx #$08                      ; Extension starts at offset 8
00065Fr 2               @FsParseExtLoop:
00065Fr 2  B1 02          lda (STR_PTR),y
000661r 2  F0 15          beq @FsParseDone              ; Null terminator
000663r 2  E0 0B          cpx #$0B
000665r 2  B0 11          bcs @FsParseDone              ; Max 3 ext chars
000667r 2                 ; Convert lowercase to uppercase
000667r 2  C9 61          cmp #'a'
000669r 2  90 06          bcc @FsStoreExtChar
00066Br 2  C9 7B          cmp #'z' + 1
00066Dr 2  B0 02          bcs @FsStoreExtChar
00066Fr 2  29 DF          and #$DF
000671r 2               @FsStoreExtChar:
000671r 2  9D 50 03       sta FS_FNAME_BUF,x
000674r 2  E8             inx
000675r 2  C8             iny
000676r 2  80 E7          bra @FsParseExtLoop
000678r 2               @FsParseDone:
000678r 2  60             rts
000679r 2               
000679r 2               ; FsReadDir — Read directory sector (LBA 0) into FS_SECTOR_BUF
000679r 2               ; Output: Carry clear = success, Carry set = error
000679r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000679r 2               FsReadDir:
000679r 2  64 26          stz CF_LBA                    ; LBA = 0 (directory sector)
00067Br 2  64 27          stz CF_LBA + 1
00067Dr 2  64 28          stz CF_LBA + 2
00067Fr 2  64 29          stz CF_LBA + 3
000681r 2  A9 00          lda #<FS_SECTOR_BUF
000683r 2  85 24          sta CF_BUF_PTR
000685r 2  A9 06          lda #>FS_SECTOR_BUF
000687r 2  85 25          sta CF_BUF_PTR + 1
000689r 2  4C rr rr       jmp StReadSector
00068Cr 2               
00068Cr 2               ; FsWriteDir — Write directory sector from FS_SECTOR_BUF to LBA 0
00068Cr 2               ; Output: Carry clear = success, Carry set = error
00068Cr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
00068Cr 2               FsWriteDir:
00068Cr 2  64 26          stz CF_LBA
00068Er 2  64 27          stz CF_LBA + 1
000690r 2  64 28          stz CF_LBA + 2
000692r 2  64 29          stz CF_LBA + 3
000694r 2  A9 00          lda #<FS_SECTOR_BUF
000696r 2  85 24          sta CF_BUF_PTR
000698r 2  A9 06          lda #>FS_SECTOR_BUF
00069Ar 2  85 25          sta CF_BUF_PTR + 1
00069Cr 2  4C rr rr       jmp StWriteSector
00069Fr 2               
00069Fr 2               ; FsFindFile — Search directory for filename in FS_FNAME_BUF
00069Fr 2               ; Must call FsReadDir first to load directory into FS_SECTOR_BUF
00069Fr 2               ; Output: Carry clear = found, X = entry index (0-15), CF_BUF_PTR points to entry
00069Fr 2               ;         Carry set = not found
00069Fr 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
00069Fr 2               FsFindFile:
00069Fr 2  A9 00          lda #<FS_SECTOR_BUF
0006A1r 2  85 24          sta CF_BUF_PTR
0006A3r 2  A9 06          lda #>FS_SECTOR_BUF
0006A5r 2  85 25          sta CF_BUF_PTR + 1
0006A7r 2  A2 00          ldx #$00                      ; Entry index
0006A9r 2               @FsFindLoop:
0006A9r 2                 ; Check if entry is in use
0006A9r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0006ABr 2  B1 24          lda (CF_BUF_PTR),y
0006ADr 2  29 01          and #FS_FLAG_USED
0006AFr 2  F0 13          beq @FsFindNext               ; Skip unused entries
0006B1r 2                 ; Compare 11-byte filename
0006B1r 2  A0 00          ldy #$00
0006B3r 2               @FsFindCmp:
0006B3r 2  B1 24          lda (CF_BUF_PTR),y
0006B5r 2  D9 50 03       cmp FS_FNAME_BUF,y
0006B8r 2  D0 0A          bne @FsFindNext               ; Mismatch
0006BAr 2  C8             iny
0006BBr 2  C0 0B          cpy #11
0006BDr 2  D0 F4          bne @FsFindCmp
0006BFr 2                 ; Match found
0006BFr 2  8E 4D 03       stx FS_DIR_IDX
0006C2r 2  18             clc
0006C3r 2  60             rts
0006C4r 2               @FsFindNext:
0006C4r 2                 ; Advance CF_BUF_PTR by 32 (FS_ENTRY_SIZE)
0006C4r 2  A5 24          lda CF_BUF_PTR
0006C6r 2  18             clc
0006C7r 2  69 20          adc #FS_ENTRY_SIZE
0006C9r 2  85 24          sta CF_BUF_PTR
0006CBr 2  90 02          bcc @FsFindNoCarry
0006CDr 2  E6 25          inc CF_BUF_PTR + 1
0006CFr 2               @FsFindNoCarry:
0006CFr 2  E8             inx
0006D0r 2  E0 10          cpx #FS_MAX_FILES
0006D2r 2  D0 D5          bne @FsFindLoop
0006D4r 2  38             sec                           ; Not found
0006D5r 2  60             rts
0006D6r 2               
0006D6r 2               ; FsFindFree — Find first free directory entry
0006D6r 2               ; Must call FsReadDir first
0006D6r 2               ; Output: Carry clear = found, X = entry index, CF_BUF_PTR points to entry
0006D6r 2               ;         Carry set = directory full
0006D6r 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
0006D6r 2               FsFindFree:
0006D6r 2  A9 00          lda #<FS_SECTOR_BUF
0006D8r 2  85 24          sta CF_BUF_PTR
0006DAr 2  A9 06          lda #>FS_SECTOR_BUF
0006DCr 2  85 25          sta CF_BUF_PTR + 1
0006DEr 2  A2 00          ldx #$00
0006E0r 2               @FsFreeLoop:
0006E0r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0006E2r 2  B1 24          lda (CF_BUF_PTR),y
0006E4r 2  29 01          and #FS_FLAG_USED
0006E6r 2  F0 12          beq @FsFreeFound              ; Found unused entry
0006E8r 2                 ; Advance by 32
0006E8r 2  A5 24          lda CF_BUF_PTR
0006EAr 2  18             clc
0006EBr 2  69 20          adc #FS_ENTRY_SIZE
0006EDr 2  85 24          sta CF_BUF_PTR
0006EFr 2  90 02          bcc @FsFreeNoCarry
0006F1r 2  E6 25          inc CF_BUF_PTR + 1
0006F3r 2               @FsFreeNoCarry:
0006F3r 2  E8             inx
0006F4r 2  E0 10          cpx #FS_MAX_FILES
0006F6r 2  D0 E8          bne @FsFreeLoop
0006F8r 2  38             sec                           ; Directory full
0006F9r 2  60             rts
0006FAr 2               @FsFreeFound:
0006FAr 2  8E 4D 03       stx FS_DIR_IDX
0006FDr 2  18             clc
0006FEr 2  60             rts
0006FFr 2               
0006FFr 2               ; FsCalcNextSec — Calculate next free sector by scanning all directory entries
0006FFr 2               ; Must call FsReadDir first
0006FFr 2               ; Output: FS_NEXT_SEC = first free sector after all used files
0006FFr 2               ; Modifies: Flags, A, X, Y
0006FFr 2               FsCalcNextSec:
0006FFr 2  A9 01          lda #<FS_DATA_START           ; Start with first data sector
000701r 2  8D 4E 03       sta FS_NEXT_SEC
000704r 2  A9 00          lda #>FS_DATA_START
000706r 2  8D 4F 03       sta FS_NEXT_SEC + 1
000709r 2                 ; Scan all entries to find highest used sector + file sector count
000709r 2  A9 00          lda #<FS_SECTOR_BUF
00070Br 2  85 24          sta CF_BUF_PTR
00070Dr 2  A9 06          lda #>FS_SECTOR_BUF
00070Fr 2  85 25          sta CF_BUF_PTR + 1
000711r 2  A2 00          ldx #$00
000713r 2               @FsCalcLoop:
000713r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000715r 2  B1 24          lda (CF_BUF_PTR),y
000717r 2  29 01          and #FS_FLAG_USED
000719r 2  F0 51          beq @FsCalcNext               ; Skip unused
00071Br 2                 ; Get start sector + ceil(size/512)
00071Br 2  A0 0C          ldy #FS_ENTRY_START
00071Dr 2  B1 24          lda (CF_BUF_PTR),y
00071Fr 2  8D 48 03       sta FS_START_SEC
000722r 2  C8             iny
000723r 2  B1 24          lda (CF_BUF_PTR),y
000725r 2  8D 49 03       sta FS_START_SEC + 1
000728r 2                 ; Get file size
000728r 2  A0 0E          ldy #FS_ENTRY_FSIZE
00072Ar 2  B1 24          lda (CF_BUF_PTR),y
00072Cr 2  8D 4A 03       sta FS_FILE_SIZE
00072Fr 2  C8             iny
000730r 2  B1 24          lda (CF_BUF_PTR),y
000732r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000735r 2                 ; Calculate sectors used = (size + 511) / 512 = (size + 511) >> 9
000735r 2                 ; = (size_hi + 1) if size_lo > 0, else size_hi / 2... simplify:
000735r 2                 ; sectors = (size >> 9) rounded up = high_byte >> 1, plus 1 if any remainder
000735r 2  AD 4B 03       lda FS_FILE_SIZE + 1          ; High byte of size
000738r 2  4A             lsr a                         ; Divide by 2 (each sector = 512 = 2 pages)
000739r 2  8D 4C 03       sta FS_SEC_COUNT
00073Cr 2                 ; Check if there's a remainder (low byte != 0 or high byte bit 0 was set)
00073Cr 2  AD 4B 03       lda FS_FILE_SIZE + 1
00073Fr 2  29 01          and #$01                      ; Was high byte odd?
000741r 2  D0 05          bne @FsCalcRound
000743r 2  AD 4A 03       lda FS_FILE_SIZE              ; Low byte non-zero?
000746r 2  F0 03          beq @FsCalcNoRound
000748r 2               @FsCalcRound:
000748r 2  EE 4C 03       inc FS_SEC_COUNT              ; Round up
00074Br 2               @FsCalcNoRound:
00074Br 2                 ; End sector = start + sector count
00074Br 2  AD 48 03       lda FS_START_SEC
00074Er 2  18             clc
00074Fr 2  6D 4C 03       adc FS_SEC_COUNT
000752r 2  48             pha
000753r 2  AD 49 03       lda FS_START_SEC + 1
000756r 2  69 00          adc #$00
000758r 2  AA             tax                           ; X = end sector high
000759r 2  68             pla                           ; A = end sector low
00075Ar 2                 ; Compare with FS_NEXT_SEC — keep the larger value
00075Ar 2  EC 4F 03       cpx FS_NEXT_SEC + 1
00075Dr 2  90 0D          bcc @FsCalcNext               ; End < FS_NEXT_SEC, skip
00075Fr 2  D0 05          bne @FsCalcUpdate             ; End high > FS_NEXT_SEC high, update
000761r 2  CD 4E 03       cmp FS_NEXT_SEC
000764r 2  90 06          bcc @FsCalcNext               ; End low < FS_NEXT_SEC low
000766r 2               @FsCalcUpdate:
000766r 2  8D 4E 03       sta FS_NEXT_SEC
000769r 2  8E 4F 03       stx FS_NEXT_SEC + 1
00076Cr 2               @FsCalcNext:
00076Cr 2                 ; Advance CF_BUF_PTR by 32
00076Cr 2  A5 24          lda CF_BUF_PTR
00076Er 2  18             clc
00076Fr 2  69 20          adc #FS_ENTRY_SIZE
000771r 2  85 24          sta CF_BUF_PTR
000773r 2  90 02          bcc @FsCalcNoCarry
000775r 2  E6 25          inc CF_BUF_PTR + 1
000777r 2               @FsCalcNoCarry:
000777r 2  E8             inx
000778r 2  E0 10          cpx #FS_MAX_FILES
00077Ar 2  D0 97          bne @FsCalcLoop
00077Cr 2  60             rts
00077Dr 2               
00077Dr 2               ; FsDirectory — Print directory listing of all used entries
00077Dr 2               ; Output via Chrout (respects current IO_MODE)
00077Dr 2               ; Modifies: Flags, A, X, Y
00077Dr 2               FsDirectory:
00077Dr 2  20 rr rr       jsr FsReadDir                 ; Load directory sector
000780r 2  90 01          bcc @FsDirStart
000782r 2  60             rts                           ; Error reading directory
000783r 2               @FsDirStart:
000783r 2  A9 00          lda #<FS_SECTOR_BUF
000785r 2  85 24          sta CF_BUF_PTR
000787r 2  A9 06          lda #>FS_SECTOR_BUF
000789r 2  85 25          sta CF_BUF_PTR + 1
00078Br 2  A2 00          ldx #$00                      ; Entry counter
00078Dr 2               @FsDirLoop:
00078Dr 2  DA             phx
00078Er 2  A0 0B          ldy #FS_ENTRY_FLAGS
000790r 2  B1 24          lda (CF_BUF_PTR),y
000792r 2  29 01          and #FS_FLAG_USED
000794r 2  F0 3A          beq @FsDirNext                ; Skip unused entries
000796r 2                 ; Print filename (8 chars)
000796r 2  A0 00          ldy #$00
000798r 2               @FsDirName:
000798r 2  B1 24          lda (CF_BUF_PTR),y
00079Ar 2  20 rr rr       jsr Chrout
00079Dr 2  C8             iny
00079Er 2  C0 08          cpy #$08
0007A0r 2  D0 F6          bne @FsDirName
0007A2r 2                 ; Print dot separator
0007A2r 2  A9 2E          lda #'.'
0007A4r 2  20 rr rr       jsr Chrout
0007A7r 2                 ; Print extension (3 chars)
0007A7r 2               @FsDirExt:
0007A7r 2  B1 24          lda (CF_BUF_PTR),y
0007A9r 2  20 rr rr       jsr Chrout
0007ACr 2  C8             iny
0007ADr 2  C0 0B          cpy #$0B
0007AFr 2  D0 F6          bne @FsDirExt
0007B1r 2                 ; Print space
0007B1r 2  A9 20          lda #' '
0007B3r 2  20 rr rr       jsr Chrout
0007B6r 2                 ; Print file size in decimal
0007B6r 2  A0 0E          ldy #FS_ENTRY_FSIZE
0007B8r 2  B1 24          lda (CF_BUF_PTR),y
0007BAr 2  8D 4A 03       sta FS_FILE_SIZE
0007BDr 2  C8             iny
0007BEr 2  B1 24          lda (CF_BUF_PTR),y
0007C0r 2  8D 4B 03       sta FS_FILE_SIZE + 1
0007C3r 2  20 rr rr       jsr FsPrintSize
0007C6r 2                 ; Print newline
0007C6r 2  A9 0D          lda #$0D
0007C8r 2  20 rr rr       jsr Chrout
0007CBr 2  A9 0A          lda #$0A
0007CDr 2  20 rr rr       jsr Chrout
0007D0r 2               @FsDirNext:
0007D0r 2                 ; Advance CF_BUF_PTR by 32
0007D0r 2  A5 24          lda CF_BUF_PTR
0007D2r 2  18             clc
0007D3r 2  69 20          adc #FS_ENTRY_SIZE
0007D5r 2  85 24          sta CF_BUF_PTR
0007D7r 2  90 02          bcc @FsDirNoCarry
0007D9r 2  E6 25          inc CF_BUF_PTR + 1
0007DBr 2               @FsDirNoCarry:
0007DBr 2  FA             plx
0007DCr 2  E8             inx
0007DDr 2  E0 10          cpx #FS_MAX_FILES
0007DFr 2  D0 AC          bne @FsDirLoop
0007E1r 2  60             rts
0007E2r 2               
0007E2r 2               ; FsPrintSize — Print 16-bit value in FS_FILE_SIZE as decimal
0007E2r 2               ; Modifies: Flags, A, X, Y
0007E2r 2               FsPrintSize:
0007E2r 2                 ; Convert 16-bit value to decimal digits (up to 5 digits for 0-65535)
0007E2r 2                 ; Use successive subtraction of powers of 10
0007E2r 2  A2 00          ldx #$00                      ; Digit index / leading zero suppression
0007E4r 2  A0 00          ldy #$00                      ; Power-of-10 table index
0007E6r 2               @FsPrintSizeLoop:
0007E6r 2  A9 2F          lda #'0' - 1                  ; Start character below '0'
0007E8r 2  8D 4D 03       sta FS_DIR_IDX                ; Reuse as digit scratch
0007EBr 2               @FsPrintSub:
0007EBr 2  EE 4D 03       inc FS_DIR_IDX
0007EEr 2  AD 4A 03       lda FS_FILE_SIZE
0007F1r 2  38             sec
0007F2r 2  F9 rr rr       sbc @FsPow10Lo,y
0007F5r 2  48             pha
0007F6r 2  AD 4B 03       lda FS_FILE_SIZE + 1
0007F9r 2  F9 rr rr       sbc @FsPow10Hi,y
0007FCr 2  90 09          bcc @FsPrintSizeDig           ; Underflow — done subtracting
0007FEr 2  8D 4B 03       sta FS_FILE_SIZE + 1
000801r 2  68             pla
000802r 2  8D 4A 03       sta FS_FILE_SIZE
000805r 2  80 E4          bra @FsPrintSub
000807r 2               @FsPrintSizeDig:
000807r 2  68             pla                           ; Discard underflowed low byte
000808r 2  AD 4D 03       lda FS_DIR_IDX
00080Br 2  C9 30          cmp #'0'
00080Dr 2  D0 04          bne @FsPrintSizeOut           ; Non-zero digit
00080Fr 2  E0 00          cpx #$00
000811r 2  F0 04          beq @FsPrintSizeSkip          ; Suppress leading zeros
000813r 2               @FsPrintSizeOut:
000813r 2  20 rr rr       jsr Chrout
000816r 2  E8             inx                           ; Mark that we've printed a digit
000817r 2               @FsPrintSizeSkip:
000817r 2  C8             iny
000818r 2  C0 04          cpy #$04                      ; 4 powers of 10 (10000, 1000, 100, 10)
00081Ar 2  D0 CA          bne @FsPrintSizeLoop
00081Cr 2                 ; Always print ones digit
00081Cr 2  AD 4A 03       lda FS_FILE_SIZE
00081Fr 2  09 30          ora #'0'                      ; Low byte is 0-9 at this point
000821r 2  20 rr rr       jsr Chrout
000824r 2  60             rts
000825r 2  10 E8 64 0A  @FsPow10Lo: .byte <10000, <1000, <100, <10
000829r 2  27 03 00 00  @FsPow10Hi: .byte >10000, >1000, >100, >10
00082Dr 2               
00082Dr 2               ; FsLoadFile — Load file from CF into PROGRAM_START ($0800)
00082Dr 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
00082Dr 2               ; Output: Carry clear = success, FS_FILE_SIZE = bytes loaded
00082Dr 2               ;         Carry set = file not found or read error
00082Dr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
00082Dr 2               FsLoadFile:
00082Dr 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000830r 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000833r 2  B0 63          bcs @FsLoadErr
000835r 2  20 rr rr       jsr FsFindFile                ; Search for filename
000838r 2  B0 5E          bcs @FsLoadErr                ; Not found
00083Ar 2                 ; Read file metadata from entry
00083Ar 2  A0 0C          ldy #FS_ENTRY_START
00083Cr 2  B1 24          lda (CF_BUF_PTR),y
00083Er 2  8D 48 03       sta FS_START_SEC
000841r 2  C8             iny
000842r 2  B1 24          lda (CF_BUF_PTR),y
000844r 2  8D 49 03       sta FS_START_SEC + 1
000847r 2  A0 0E          ldy #FS_ENTRY_FSIZE
000849r 2  B1 24          lda (CF_BUF_PTR),y
00084Br 2  8D 4A 03       sta FS_FILE_SIZE
00084Er 2  C8             iny
00084Fr 2  B1 24          lda (CF_BUF_PTR),y
000851r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000854r 2                 ; Calculate number of sectors to read
000854r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000857r 2  4A             lsr a
000858r 2  8D 4C 03       sta FS_SEC_COUNT
00085Br 2  AD 4B 03       lda FS_FILE_SIZE + 1
00085Er 2  29 01          and #$01
000860r 2  D0 05          bne @FsLoadRound
000862r 2  AD 4A 03       lda FS_FILE_SIZE
000865r 2  F0 03          beq @FsLoadNoRound
000867r 2               @FsLoadRound:
000867r 2  EE 4C 03       inc FS_SEC_COUNT
00086Ar 2               @FsLoadNoRound:
00086Ar 2                 ; Set up LBA starting at file's start sector
00086Ar 2  AD 48 03       lda FS_START_SEC
00086Dr 2  85 26          sta CF_LBA
00086Fr 2  AD 49 03       lda FS_START_SEC + 1
000872r 2  85 27          sta CF_LBA + 1
000874r 2  64 28          stz CF_LBA + 2
000876r 2  64 29          stz CF_LBA + 3
000878r 2                 ; Set destination pointer to PROGRAM_START
000878r 2  A9 00          lda #<PROGRAM_START
00087Ar 2  85 24          sta CF_BUF_PTR
00087Cr 2  A9 08          lda #>PROGRAM_START
00087Er 2  85 25          sta CF_BUF_PTR + 1
000880r 2                 ; Read sectors
000880r 2  AE 4C 03       ldx FS_SEC_COUNT
000883r 2  F0 10          beq @FsLoadOk                 ; Zero-size file
000885r 2               @FsLoadSec:
000885r 2  DA             phx
000886r 2  20 rr rr       jsr StReadSector              ; Read sector (advances CF_BUF_PTR by 512)
000889r 2  B0 0C          bcs @FsLoadSecErr
00088Br 2                 ; Increment LBA
00088Br 2  E6 26          inc CF_LBA
00088Dr 2  D0 02          bne @FsLoadSecNext
00088Fr 2  E6 27          inc CF_LBA + 1
000891r 2               @FsLoadSecNext:
000891r 2  FA             plx
000892r 2  CA             dex
000893r 2  D0 F0          bne @FsLoadSec
000895r 2               @FsLoadOk:
000895r 2  18             clc
000896r 2  60             rts
000897r 2               @FsLoadSecErr:
000897r 2  FA             plx                           ; Balance stack
000898r 2               @FsLoadErr:
000898r 2  38             sec
000899r 2  60             rts
00089Ar 2               
00089Ar 2               ; FsSaveFile — Save data from PROGRAM_START to CF
00089Ar 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
00089Ar 2               ;        FS_FILE_SIZE ($034A-$034B) = number of bytes to save
00089Ar 2               ; Output: Carry clear = success, Carry set = error (directory full or write error)
00089Ar 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
00089Ar 2               FsSaveFile:
00089Ar 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
00089Dr 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
0008A0r 2  90 03          bcc @FsSaveReadOk
0008A2r 2  4C rr rr       jmp @FsSaveErr
0008A5r 2               @FsSaveReadOk:
0008A5r 2                 ; Try to find existing file with same name
0008A5r 2  20 rr rr       jsr FsFindFile
0008A8r 2  90 08          bcc @FsSaveOverwrite
0008AAr 2                 ; Not found — find a free slot
0008AAr 2  20 rr rr       jsr FsFindFree
0008ADr 2  90 11          bcc @FsSaveAlloc
0008AFr 2  4C rr rr       jmp @FsSaveErr                ; Directory full
0008B2r 2               @FsSaveOverwrite:
0008B2r 2                 ; CF_BUF_PTR already points to the existing entry — clear old flags
0008B2r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0008B4r 2  A9 00          lda #$00
0008B6r 2  91 24          sta (CF_BUF_PTR),y            ; Mark old entry as free
0008B8r 2                 ; Find a free slot (could be the one we just freed or another)
0008B8r 2  20 rr rr       jsr FsFindFree
0008BBr 2  90 03          bcc @FsSaveAlloc
0008BDr 2  4C rr rr       jmp @FsSaveErr
0008C0r 2               @FsSaveAlloc:
0008C0r 2                 ; Save CF_BUF_PTR (points to free entry from FsFindFree)
0008C0r 2  A5 24          lda CF_BUF_PTR
0008C2r 2  48             pha
0008C3r 2  A5 25          lda CF_BUF_PTR + 1
0008C5r 2  48             pha
0008C6r 2                 ; Calculate next free sector (clobbers CF_BUF_PTR)
0008C6r 2  20 rr rr       jsr FsCalcNextSec
0008C9r 2                 ; Restore CF_BUF_PTR to the free directory entry
0008C9r 2  68             pla
0008CAr 2  85 25          sta CF_BUF_PTR + 1
0008CCr 2  68             pla
0008CDr 2  85 24          sta CF_BUF_PTR
0008CFr 2                 ; Calculate sectors needed
0008CFr 2  AD 4B 03       lda FS_FILE_SIZE + 1
0008D2r 2  4A             lsr a
0008D3r 2  8D 4C 03       sta FS_SEC_COUNT
0008D6r 2  AD 4B 03       lda FS_FILE_SIZE + 1
0008D9r 2  29 01          and #$01
0008DBr 2  D0 05          bne @FsSaveRound
0008DDr 2  AD 4A 03       lda FS_FILE_SIZE
0008E0r 2  F0 03          beq @FsSaveNoRound
0008E2r 2               @FsSaveRound:
0008E2r 2  EE 4C 03       inc FS_SEC_COUNT
0008E5r 2               @FsSaveNoRound:
0008E5r 2                 ; Fill in directory entry at CF_BUF_PTR
0008E5r 2                 ; Copy filename (11 bytes)
0008E5r 2  A0 00          ldy #$00
0008E7r 2               @FsSaveCopyName:
0008E7r 2  B9 50 03       lda FS_FNAME_BUF,y
0008EAr 2  91 24          sta (CF_BUF_PTR),y
0008ECr 2  C8             iny
0008EDr 2  C0 0B          cpy #11
0008EFr 2  D0 F6          bne @FsSaveCopyName
0008F1r 2                 ; Set flags = in use
0008F1r 2  A9 01          lda #FS_FLAG_USED
0008F3r 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
0008F5r 2                 ; Set start sector
0008F5r 2  A0 0C          ldy #FS_ENTRY_START
0008F7r 2  AD 4E 03       lda FS_NEXT_SEC
0008FAr 2  91 24          sta (CF_BUF_PTR),y
0008FCr 2  8D 48 03       sta FS_START_SEC
0008FFr 2  C8             iny
000900r 2  AD 4F 03       lda FS_NEXT_SEC + 1
000903r 2  91 24          sta (CF_BUF_PTR),y
000905r 2  8D 49 03       sta FS_START_SEC + 1
000908r 2                 ; Set file size
000908r 2  A0 0E          ldy #FS_ENTRY_FSIZE
00090Ar 2  AD 4A 03       lda FS_FILE_SIZE
00090Dr 2  91 24          sta (CF_BUF_PTR),y
00090Fr 2  C8             iny
000910r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000913r 2  91 24          sta (CF_BUF_PTR),y
000915r 2                 ; Clear reserved bytes
000915r 2  A0 10          ldy #$10
000917r 2  A9 00          lda #$00
000919r 2               @FsSaveClearRsv:
000919r 2  91 24          sta (CF_BUF_PTR),y
00091Br 2  C8             iny
00091Cr 2  C0 20          cpy #FS_ENTRY_SIZE
00091Er 2  D0 F9          bne @FsSaveClearRsv
000920r 2                 ; Write updated directory back to CF
000920r 2  20 rr rr       jsr FsWriteDir
000923r 2  B0 2E          bcs @FsSaveErr
000925r 2                 ; Now write file data sectors
000925r 2  AD 48 03       lda FS_START_SEC
000928r 2  85 26          sta CF_LBA
00092Ar 2  AD 49 03       lda FS_START_SEC + 1
00092Dr 2  85 27          sta CF_LBA + 1
00092Fr 2  64 28          stz CF_LBA + 2
000931r 2  64 29          stz CF_LBA + 3
000933r 2                 ; Source = PROGRAM_START
000933r 2  A9 00          lda #<PROGRAM_START
000935r 2  85 24          sta CF_BUF_PTR
000937r 2  A9 08          lda #>PROGRAM_START
000939r 2  85 25          sta CF_BUF_PTR + 1
00093Br 2  AE 4C 03       ldx FS_SEC_COUNT
00093Er 2  F0 10          beq @FsSaveOk                 ; Zero-size file
000940r 2               @FsSaveSec:
000940r 2  DA             phx
000941r 2  20 rr rr       jsr StWriteSector             ; Write sector (advances CF_BUF_PTR by 512)
000944r 2  B0 0C          bcs @FsSaveSecErr
000946r 2                 ; Increment LBA
000946r 2  E6 26          inc CF_LBA
000948r 2  D0 02          bne @FsSaveSecNext
00094Ar 2  E6 27          inc CF_LBA + 1
00094Cr 2               @FsSaveSecNext:
00094Cr 2  FA             plx
00094Dr 2  CA             dex
00094Er 2  D0 F0          bne @FsSaveSec
000950r 2               @FsSaveOk:
000950r 2  18             clc
000951r 2  60             rts
000952r 2               @FsSaveSecErr:
000952r 2  FA             plx                           ; Balance stack
000953r 2               @FsSaveErr:
000953r 2  38             sec
000954r 2  60             rts
000955r 2               
000955r 2               ; === Serial ASCII LOAD/SAVE ===
000955r 2               ; Plain binary transfer protocol over serial
000955r 2               ; Load: receives 2-byte size (lo/hi) then raw data bytes into PROGRAM_START
000955r 2               ; Save: sends 2-byte size (lo/hi) then raw data bytes from PROGRAM_START
000955r 2               
000955r 2               ; --- ASCII Load ---
000955r 2               
000955r 2               ; AsciiLoadImpl — Receive raw binary data via serial into program memory
000955r 2               ; Switches IO_MODE to serial, receives 2-byte size then raw data bytes
000955r 2               ; Data is written starting at PROGRAM_START ($0800)
000955r 2               ; Output: Carry clear = success, XFER_PTR points past last byte written
000955r 2               ; Modifies: Flags, A, X, Y
000955r 2               AsciiLoadImpl:
000955r 2                 ; Save and switch IO_MODE to serial
000955r 2  AD 06 03       lda IO_MODE
000958r 2  8D 19 03       sta XFER_IO_SAVE
00095Br 2  A9 01          lda #$01                      ; Serial mode
00095Dr 2  8D 06 03       sta IO_MODE
000960r 2                 ; Print prompt
000960r 2  A9 0D          lda #$0D
000962r 2  20 rr rr       jsr SerialChrout
000965r 2  A9 0A          lda #$0A
000967r 2  20 rr rr       jsr SerialChrout
00096Ar 2  A9 rr          lda #<@AsciiLoadMsg
00096Cr 2  85 02          sta STR_PTR
00096Er 2  A9 rr          lda #>@AsciiLoadMsg
000970r 2  85 03          sta STR_PTR + 1
000972r 2  20 rr rr       jsr @SerialPrintStr
000975r 2                 ; Read 2-byte size (low byte first)
000975r 2               @AsciiWaitSzLo:
000975r 2  20 rr rr       jsr BufferSize
000978r 2  F0 FB          beq @AsciiWaitSzLo
00097Ar 2  20 rr rr       jsr ReadBuffer
00097Dr 2  8D 17 03       sta XFER_REMAIN
000980r 2               @AsciiWaitSzHi:
000980r 2  20 rr rr       jsr BufferSize
000983r 2  F0 FB          beq @AsciiWaitSzHi
000985r 2  20 rr rr       jsr ReadBuffer
000988r 2  8D 18 03       sta XFER_REMAIN + 1
00098Br 2                 ; Initialize write pointer to PROGRAM_START
00098Br 2  A9 00          lda #<PROGRAM_START
00098Dr 2  85 2A          sta XFER_PTR
00098Fr 2  A9 08          lda #>PROGRAM_START
000991r 2  85 2B          sta XFER_PTR + 1
000993r 2                 ; Check for zero-length transfer
000993r 2  AD 17 03       lda XFER_REMAIN
000996r 2  0D 18 03       ora XFER_REMAIN + 1
000999r 2  F0 25          beq @AsciiLoadOk
00099Br 2                 ; Receive data bytes (Y stays 0, pointer is advanced each byte)
00099Br 2  A0 00          ldy #$00
00099Dr 2               @AsciiLoadByte:
00099Dr 2  20 rr rr       jsr BufferSize
0009A0r 2  F0 FB          beq @AsciiLoadByte
0009A2r 2  20 rr rr       jsr ReadBuffer
0009A5r 2  91 2A          sta (XFER_PTR),y              ; Write byte to target address
0009A7r 2                 ; Advance write pointer
0009A7r 2  E6 2A          inc XFER_PTR
0009A9r 2  D0 02          bne @AsciiLoadNoPage
0009ABr 2  E6 2B          inc XFER_PTR + 1
0009ADr 2               @AsciiLoadNoPage:
0009ADr 2                 ; Decrement remaining count
0009ADr 2  AD 17 03       lda XFER_REMAIN
0009B0r 2  D0 03          bne @AsciiLoadDecLo
0009B2r 2  CE 18 03       dec XFER_REMAIN + 1
0009B5r 2               @AsciiLoadDecLo:
0009B5r 2  CE 17 03       dec XFER_REMAIN
0009B8r 2                 ; Check if done
0009B8r 2  AD 17 03       lda XFER_REMAIN
0009BBr 2  0D 18 03       ora XFER_REMAIN + 1
0009BEr 2  D0 DD          bne @AsciiLoadByte
0009C0r 2               @AsciiLoadOk:
0009C0r 2                 ; XFER_PTR now points past last byte written
0009C0r 2                 ; Print success message
0009C0r 2  A9 0D          lda #$0D
0009C2r 2  20 rr rr       jsr SerialChrout
0009C5r 2  A9 0A          lda #$0A
0009C7r 2  20 rr rr       jsr SerialChrout
0009CAr 2  A9 rr          lda #<@AsciiOkMsg
0009CCr 2  85 02          sta STR_PTR
0009CEr 2  A9 rr          lda #>@AsciiOkMsg
0009D0r 2  85 03          sta STR_PTR + 1
0009D2r 2  20 rr rr       jsr @SerialPrintStr
0009D5r 2                 ; Restore IO_MODE
0009D5r 2  AD 19 03       lda XFER_IO_SAVE
0009D8r 2  8D 06 03       sta IO_MODE
0009DBr 2  18             clc                           ; Success
0009DCr 2  60             rts
0009DDr 2               
0009DDr 2               ; Internal: print null-terminated string via serial
0009DDr 2               ; Input: STR_PTR points to string
0009DDr 2               @SerialPrintStr:
0009DDr 2  A0 00          ldy #$00
0009DFr 2               @SerialPrintLoop:
0009DFr 2  B1 02          lda (STR_PTR),y
0009E1r 2  F0 06          beq @SerialPrintDone
0009E3r 2  20 rr rr       jsr SerialChrout
0009E6r 2  C8             iny
0009E7r 2  D0 F6          bne @SerialPrintLoop
0009E9r 2               @SerialPrintDone:
0009E9r 2  60             rts
0009EAr 2               
0009EAr 2  52 45 41 44  @AsciiLoadMsg: .asciiz "READY TO RECEIVE"
0009EEr 2  59 20 54 4F  
0009F2r 2  20 52 45 43  
0009FBr 2  4F 4B 00     @AsciiOkMsg:   .asciiz "OK"
0009FEr 2               
0009FEr 2               ; --- ASCII Save ---
0009FEr 2               
0009FEr 2               ; AsciiSaveImpl — Transmit program memory as raw binary via serial
0009FEr 2               ; Sends 2-byte size (lo/hi) then raw data bytes from PROGRAM_START to BAS_PRGEND
0009FEr 2               ; Output: Carry clear = success
0009FEr 2               ; Modifies: Flags, A, X, Y
0009FEr 2               AsciiSaveImpl:
0009FEr 2                 ; Save and switch IO_MODE to serial
0009FEr 2  AD 06 03       lda IO_MODE
000A01r 2  8D 19 03       sta XFER_IO_SAVE
000A04r 2  A9 01          lda #$01
000A06r 2  8D 06 03       sta IO_MODE
000A09r 2                 ; Initialize save pointer
000A09r 2  A9 00          lda #<PROGRAM_START
000A0Br 2  85 2A          sta XFER_PTR
000A0Dr 2  A9 08          lda #>PROGRAM_START
000A0Fr 2  85 2B          sta XFER_PTR + 1
000A11r 2                 ; Calculate remaining bytes = BAS_PRGEND - PROGRAM_START
000A11r 2  A5 12          lda z:BAS_PRGEND
000A13r 2  38             sec
000A14r 2  E9 00          sbc #<PROGRAM_START
000A16r 2  8D 17 03       sta XFER_REMAIN
000A19r 2  A5 13          lda z:BAS_PRGEND + 1
000A1Br 2  E9 08          sbc #>PROGRAM_START
000A1Dr 2  8D 18 03       sta XFER_REMAIN + 1
000A20r 2                 ; Send 2-byte size (low byte first)
000A20r 2  AD 17 03       lda XFER_REMAIN
000A23r 2  20 rr rr       jsr SerialChrout
000A26r 2  AD 18 03       lda XFER_REMAIN + 1
000A29r 2  20 rr rr       jsr SerialChrout
000A2Cr 2                 ; Check for zero-length program
000A2Cr 2  AD 17 03       lda XFER_REMAIN
000A2Fr 2  0D 18 03       ora XFER_REMAIN + 1
000A32r 2  F0 20          beq @AsciiSaveDone
000A34r 2                 ; Send data bytes (Y stays 0, pointer is advanced each byte)
000A34r 2  A0 00          ldy #$00
000A36r 2               @AsciiSaveByte:
000A36r 2  B1 2A          lda (XFER_PTR),y
000A38r 2  20 rr rr       jsr SerialChrout
000A3Br 2                 ; Advance read pointer
000A3Br 2  E6 2A          inc XFER_PTR
000A3Dr 2  D0 02          bne @AsciiSaveNoPage
000A3Fr 2  E6 2B          inc XFER_PTR + 1
000A41r 2               @AsciiSaveNoPage:
000A41r 2                 ; Decrement remaining count
000A41r 2  AD 17 03       lda XFER_REMAIN
000A44r 2  D0 03          bne @AsciiSaveDecLo
000A46r 2  CE 18 03       dec XFER_REMAIN + 1
000A49r 2               @AsciiSaveDecLo:
000A49r 2  CE 17 03       dec XFER_REMAIN
000A4Cr 2                 ; Check if done
000A4Cr 2  AD 17 03       lda XFER_REMAIN
000A4Fr 2  0D 18 03       ora XFER_REMAIN + 1
000A52r 2  D0 E2          bne @AsciiSaveByte
000A54r 2               @AsciiSaveDone:
000A54r 2                 ; Restore IO_MODE
000A54r 2  AD 19 03       lda XFER_IO_SAVE
000A57r 2  8D 06 03       sta IO_MODE
000A5Ar 2  18             clc                           ; Success
000A5Br 2  60             rts
000A5Cr 2               
000A5Cr 2               ; Draw the splash screen
000A5Cr 2               ; Uses video output to display centered title and boot menu
000A5Cr 2               ; Modifies: Flags, A, X, Y
000A5Cr 2               Splash:
000A5Cr 2  20 rr rr       jsr VideoClear                ; Clear the video screen
000A5Fr 2                 ; Position cursor at row 10, col 10 for title
000A5Fr 2  A2 0A          ldx #10
000A61r 2  A0 0A          ldy #10
000A63r 2  20 rr rr       jsr VideoSetCursor
000A66r 2  A9 rr          lda #<@SplashTitle
000A68r 2  85 02          sta STR_PTR
000A6Ar 2  A9 rr          lda #>@SplashTitle
000A6Cr 2  85 03          sta STR_PTR + 1
000A6Er 2  20 rr rr       jsr VideoPrintStrImpl
000A71r 2                 ; Position cursor at row 12, col 8 for boot menu (centered: (40-24)/2 = 8)
000A71r 2  A2 08          ldx #8
000A73r 2  A0 0C          ldy #12
000A75r 2  20 rr rr       jsr VideoSetCursor
000A78r 2  A9 rr          lda #<@SplashMenu
000A7Ar 2  85 02          sta STR_PTR
000A7Cr 2  A9 rr          lda #>@SplashMenu
000A7Er 2  85 03          sta STR_PTR + 1
000A80r 2  20 rr rr       jsr VideoPrintStrImpl
000A83r 2  60             rts
000A84r 2  2D 2D 20 54  @SplashTitle: .asciiz "-- The 'COB' v1.0 --"
000A88r 2  68 65 20 27  
000A8Cr 2  43 4F 42 27  
000A99r 2  45 4E 54 45  @SplashMenu:  .asciiz "ENTER=BASIC  ESC=MONITOR"
000A9Dr 2  52 3D 42 41  
000AA1r 2  53 49 43 20  
000AB2r 2               
000AB2r 2               ; NMI Handler
000AB2r 2               Nmi:
000AB2r 2  40             rti
000AB3r 2               
000AB3r 2               ; BRK Handler — default dispatches to WozMon
000AB3r 2               ; On entry the stack holds the processor-pushed state from the BRK:
000AB3r 2               ;   SP+1 = saved P, SP+2 = PCL (PC+2), SP+3 = PCH
000AB3r 2               ; State is saved to BRK_P/BRK_PCL/BRK_PCH for inspection by a custom handler.
000AB3r 2               Break:
000AB3r 2  68             pla                           ; Pull saved P
000AB4r 2  8D 10 03       sta BRK_P
000AB7r 2  68             pla                           ; Pull saved PCL (PC+2)
000AB8r 2  8D 11 03       sta BRK_PCL
000ABBr 2  68             pla                           ; Pull saved PCH
000ABCr 2  8D 12 03       sta BRK_PCH
000ABFr 2  4C rr rr       jmp MonitorEntry
000AC2r 2               
000AC2r 2               ; IRQ Handler
000AC2r 2               Irq:
000AC2r 2  48             pha
000AC3r 2  5A             phy
000AC4r 2  DA             phx
000AC5r 2  BA             tsx                           ; Get stack pointer to check saved status register
000AC6r 2  BD 04 01       lda $104,x                    ; Load saved P (SP+4: past X, Y, A we pushed)
000AC9r 2  29 10          and #$10                      ; Test B flag — set by BRK, clear by hardware IRQ
000ACBr 2  D0 3B          bne @IrqBrk                   ; Branch if this was a BRK instruction
000ACDr 2               @IrqSc:
000ACDr 2  AD 01 90       lda SC_STATUS
000AD0r 2  29 80          and #SC_STATUS_IRQ            ; Check if serial data caused the interrupt
000AD2r 2  F0 14          beq @IrqCheckKB               ; If not, check keyboard
000AD4r 2  AD 00 90       lda SC_DATA                   ; Read the data from serial register
000AD7r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000ADAr 2  20 rr rr       jsr BufferSize
000ADDr 2  C9 F0          cmp #$F0                      ; Is the buffer almost full?
000ADFr 2  90 23          bcc @IrqExit                  ; If not, exit
000AE1r 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
000AE3r 2  8D 02 90       sta SC_CMD                    ; Otherwise, signal not ready for receiving (RTSB high)
000AE6r 2  80 1C          bra @IrqExit
000AE8r 2               @IrqCheckKB:
000AE8r 2  AD 0D 94       lda GPIO_IFR
000AEBr 2  29 10          and #GPIO_INT_CB1             ; Check if CB1 (matrix keyboard data ready) caused the interrupt
000AEDr 2  F0 08          beq @IrqCheckPS2              ; If not, check PS/2 keyboard
000AEFr 2  AD 00 94       lda GPIO_PORTB                ; Read ASCII byte from matrix keyboard (also clears CB1 IFR flag)
000AF2r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000AF5r 2  80 0D          bra @IrqExit
000AF7r 2               @IrqCheckPS2:
000AF7r 2  AD 0D 94       lda GPIO_IFR
000AFAr 2  29 02          and #GPIO_INT_CA1             ; Check if CA1 (PS/2 keyboard data ready) caused the interrupt
000AFCr 2  F0 06          beq @IrqExit                  ; If not, exit
000AFEr 2  AD 01 94       lda GPIO_PORTA                ; Read ASCII byte from PS/2 keyboard (also clears CA1 IFR flag)
000B01r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000B04r 2               @IrqExit:
000B04r 2  FA             plx
000B05r 2  7A             ply
000B06r 2  68             pla
000B07r 2  40             rti
000B08r 2               @IrqBrk:
000B08r 2  FA             plx                           ; Restore saved registers
000B09r 2  7A             ply
000B0Ar 2  68             pla
000B0Br 2  58             cli                           ; Re-enable interrupts — abandoning interrupt context
000B0Cr 2  6C 02 03       jmp (BRK_PTR)                 ; BRK — dispatch with P/PCL/PCH still on stack
000B0Fr 2               
000B0Fr 2               ; NMI Vector
000B0Fr 2               NmiVec:
000B0Fr 2  6C 04 03       jmp (NMI_PTR)                 ; Indirect jump through NMI pointer to the NMI handler
000B12r 2               
000B12r 2               ; Reset Vector
000B12r 2               ResetVec:
000B12r 2  4C rr rr       jmp Reset                     ; Initialize the system
000B15r 2               
000B15r 2               ; IRQ Vector
000B15r 2               IrqVec:
000B15r 2  6C 00 03       jmp (IRQ_PTR)                 ; Indirect jump through IRQ pointer to the IRQ handler
000B18r 2               
000B18r 1               .segment "CHARS"
000000r 1               .include "Chars.asm"
000000r 2               ; IBM Code Page 437 Character Set
000000r 2               ; 6x8 pixel font in 8x8 area, 8 bytes per character (256 characters total)
000000r 2               ; Each byte represents one horizontal row of pixels (6 pixels centered in 8-bit space)
000000r 2               
000000r 2               CharacterSet:
000000r 2                   ; Character $00 - NULL (blank)
000000r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $00, $00, $00
000004r 2  00 00 00 00  
000008r 2                   ; Character $01 - ☺ (white smiling face)
000008r 2  00 7C 82 AA      .byte $00, $7C, $82, $AA, $82, $BA, $44, $38
00000Cr 2  82 BA 44 38  
000010r 2                   ; Character $02 - ☻ (black smiling face)
000010r 2  00 7C FE D6      .byte $00, $7C, $FE, $D6, $FE, $C6, $7C, $38
000014r 2  FE C6 7C 38  
000018r 2                   ; Character $03 - ♥ (heart)
000018r 2  00 00 6C FE      .byte $00, $00, $6C, $FE, $FE, $7C, $38, $10
00001Cr 2  FE 7C 38 10  
000020r 2                   ; Character $04 - ♦ (diamond)
000020r 2  00 10 38 7C      .byte $00, $10, $38, $7C, $FE, $7C, $38, $10
000024r 2  FE 7C 38 10  
000028r 2                   ; Character $05 - ♣ (club)
000028r 2  00 38 7C 38      .byte $00, $38, $7C, $38, $FE, $D6, $10, $38
00002Cr 2  FE D6 10 38  
000030r 2                   ; Character $06 - ♠ (spade)
000030r 2  00 10 38 7C      .byte $00, $10, $38, $7C, $FE, $7C, $10, $38
000034r 2  FE 7C 10 38  
000038r 2                   ; Character $07 - • (bullet)
000038r 2  00 00 00 38      .byte $00, $00, $00, $38, $38, $00, $00, $00
00003Cr 2  38 00 00 00  
000040r 2                   ; Character $08 - ◘ (inverse bullet)
000040r 2  FE FE FE C6      .byte $FE, $FE, $FE, $C6, $C6, $FE, $FE, $FE
000044r 2  C6 FE FE FE  
000048r 2                   ; Character $09 - ○ (white circle)
000048r 2  00 00 38 44      .byte $00, $00, $38, $44, $44, $44, $38, $00
00004Cr 2  44 44 38 00  
000050r 2                   ; Character $0A - ◙ (inverse white circle)
000050r 2  FE FE C6 BA      .byte $FE, $FE, $C6, $BA, $BA, $BA, $C6, $FE
000054r 2  BA BA C6 FE  
000058r 2                   ; Character $0B - ♂ (male symbol)
000058r 2  00 78 30 68      .byte $00, $78, $30, $68, $5C, $CC, $CC, $78
00005Cr 2  5C CC CC 78  
000060r 2                   ; Character $0C - ♀ (female symbol)
000060r 2  00 78 CC CC      .byte $00, $78, $CC, $CC, $78, $30, $FC, $30
000064r 2  78 30 FC 30  
000068r 2                   ; Character $0D - ♪ (eighth note)
000068r 2  00 70 60 60      .byte $00, $70, $60, $60, $60, $E0, $E0, $C0
00006Cr 2  60 E0 E0 C0  
000070r 2                   ; Character $0E - ♫ (beamed eighth notes)
000070r 2  00 6C 6C 6C      .byte $00, $6C, $6C, $6C, $6C, $EC, $EC, $C0
000074r 2  6C EC EC C0  
000078r 2                   ; Character $0F - ☼ (sun)
000078r 2  00 92 54 38      .byte $00, $92, $54, $38, $EE, $38, $54, $92
00007Cr 2  EE 38 54 92  
000080r 2                   ; Character $10 - ► (right-pointing triangle)
000080r 2  00 00 40 60      .byte $00, $00, $40, $60, $78, $60, $40, $00
000084r 2  78 60 40 00  
000088r 2                   ; Character $11 - ◄ (left-pointing triangle)
000088r 2  00 00 08 18      .byte $00, $00, $08, $18, $78, $18, $08, $00
00008Cr 2  78 18 08 00  
000090r 2                   ; Character $12 - ↕ (up/down arrow)
000090r 2  00 10 38 54      .byte $00, $10, $38, $54, $10, $54, $38, $10
000094r 2  10 54 38 10  
000098r 2                   ; Character $13 - ‼ (double exclamation mark)
000098r 2  00 00 48 48      .byte $00, $00, $48, $48, $48, $00, $48, $00
00009Cr 2  48 00 48 00  
0000A0r 2                   ; Character $14 - ¶ (pilcrow)
0000A0r 2  00 7C D4 D4      .byte $00, $7C, $D4, $D4, $54, $54, $54, $00
0000A4r 2  54 54 54 00  
0000A8r 2                   ; Character $15 - § (section sign)
0000A8r 2  00 38 40 30      .byte $00, $38, $40, $30, $48, $30, $08, $70
0000ACr 2  48 30 08 70  
0000B0r 2                   ; Character $16 - ▬ (black rectangle)
0000B0r 2  00 00 00 00      .byte $00, $00, $00, $00, $FC, $FC, $00, $00
0000B4r 2  FC FC 00 00  
0000B8r 2                   ; Character $17 - ↨ (up/down arrow with base)
0000B8r 2  00 10 38 54      .byte $00, $10, $38, $54, $10, $54, $38, $10
0000BCr 2  10 54 38 10  
0000C0r 2                   ; Character $18 - ↑ (up arrow)
0000C0r 2  00 10 38 54      .byte $00, $10, $38, $54, $10, $10, $10, $00
0000C4r 2  10 10 10 00  
0000C8r 2                   ; Character $19 - ↓ (down arrow)
0000C8r 2  00 10 10 10      .byte $00, $10, $10, $10, $54, $38, $10, $00
0000CCr 2  54 38 10 00  
0000D0r 2                   ; Character $1A - → (right arrow)
0000D0r 2  00 00 10 08      .byte $00, $00, $10, $08, $FC, $08, $10, $00
0000D4r 2  FC 08 10 00  
0000D8r 2                   ; Character $1B - ← (left arrow)
0000D8r 2  00 00 10 20      .byte $00, $00, $10, $20, $FC, $20, $10, $00
