002B34r 2  rr rr                .word   SynErr-1                ; $A2 AND
002B36r 2  rr rr                .word   SynErr-1                ; $A3 OR
002B38r 2  rr rr                .word   BasCmdRem-1             ; $A4 ELSE (skip rest of line; THEN-branch ran)
002B3Ar 2  rr rr                .word   BasCmdSys-1             ; $A5 SYS
002B3Cr 2  rr rr                .word   BasCmdDir-1             ; $A6 DIR
002B3Er 2  rr rr                .word   BasCmdDel-1             ; $A7 DEL
