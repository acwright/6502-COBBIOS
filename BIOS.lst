0007B8r 2               @AndFalse:
0007B8r 2  64 0A          stz BAS_ACC
0007BAr 2  64 0B          stz BAS_ACC + 1
0007BCr 2  80 CA          bra @AndLoop
0007BEr 2               @AndDone:
0007BEr 2  60             rts
0007BFr 2               
0007BFr 2               ; BasExprNot — Handle NOT (unary prefix)
0007BFr 2               BasExprNot:
