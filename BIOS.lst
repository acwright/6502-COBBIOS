001900r 2               ; ============================================================================
001900r 2               ; DATA Scanning Helpers
001900r 2               ; ============================================================================
001900r 2               
001900r 2               ; BasDataFindFirst — Find first DATA line from program start
001900r 2               ; Sets BAS_DATAPTR to first value in the first DATA statement
001900r 2               ; Errors ERR_OUT_OF_DATA if no DATA found.
001900r 2               
001900r 2               BasDataFindFirst:
001900r 2  A9 00          lda #<BAS_PRG_START
001902r 2  85 0E          sta BAS_TMP1
001904r 2  A9 08          lda #>BAS_PRG_START
001906r 2  85 0F          sta BAS_TMP1 + 1
001908r 2  20 rr rr       jsr BasDataScan
00190Br 2  90 05          bcc @FindFirstOk
00190Dr 2  A9 0A          lda #ERR_OUT_OF_DATA
00190Fr 2  4C rr rr       jmp BasError
001912r 2               @FindFirstOk:
001912r 2  60             rts
001913r 2               
001913r 2               ; BasDataFindNext — Find next DATA line after current position
001913r 2               ; BAS_DATAPTR points into current DATA line; scans forward to null,
001913r 2               ; then searches subsequent lines for TOK_DATA.
001913r 2               ; Sets BAS_DATAPTR to first value in the next DATA statement.
001913r 2               ; Errors ERR_OUT_OF_DATA if no more DATA found.
001913r 2               
001913r 2               BasDataFindNext:
001913r 2  AD 1A 03       lda BAS_DATAPTR
001916r 2  85 0E          sta BAS_TMP1
001918r 2  AD 1B 03       lda BAS_DATAPTR + 1
00191Br 2  85 0F          sta BAS_TMP1 + 1
00191Dr 2                 ; Scan to end of current line (null terminator)
00191Dr 2  A0 00          ldy #$00
00191Fr 2               @ScanToNull:
00191Fr 2  B1 0E          lda (BAS_TMP1),y
001921r 2  F0 07          beq @GotNull
001923r 2  C8             iny
001924r 2  D0 F9          bne @ScanToNull
001926r 2  E6 0F          inc BAS_TMP1 + 1
001928r 2  80 F5          bra @ScanToNull
00192Ar 2               @GotNull:
00192Ar 2                 ; Advance past null to start of next line
00192Ar 2  C8             iny
00192Br 2  98             tya
00192Cr 2  18             clc
00192Dr 2  65 0E          adc BAS_TMP1
00192Fr 2  85 0E          sta BAS_TMP1
001931r 2  A9 00          lda #$00
001933r 2  65 0F          adc BAS_TMP1 + 1
001935r 2  85 0F          sta BAS_TMP1 + 1
001937r 2                 ; Fall through to scan
001937r 2               
001937r 2               ; BasDataScan — Scan program lines starting at BAS_TMP1 for TOK_DATA
001937r 2               ; Sets BAS_DATAPTR to point past the DATA token (first value byte)
001937r 2               ; Errors ERR_OUT_OF_DATA if no DATA found before end of program.
001937r 2               
001937r 2               BasDataScan:
001937r 2               @ScanLoop:
001937r 2                 ; At end of program?
001937r 2  A5 0E          lda BAS_TMP1
001939r 2  C5 12          cmp BAS_PRGEND
00193Br 2  D0 06          bne @ScanNotEnd
00193Dr 2  A5 0F          lda BAS_TMP1 + 1
00193Fr 2  C5 13          cmp BAS_PRGEND + 1
001941r 2  F0 2E          beq @ScanNotFound
001943r 2               @ScanNotEnd:
001943r 2                 ; Check first token of this line
001943r 2  A0 04          ldy #LINE_PAYLOAD
001945r 2  B1 0E          lda (BAS_TMP1),y
001947r 2  C9 B3          cmp #TOK_DATA
001949r 2  F0 16          beq @ScanFound
00194Br 2                 ; Skip to next line by scanning for null terminator
00194Br 2               @ScanSkipLine:
00194Br 2  B1 0E          lda (BAS_TMP1),y
00194Dr 2  F0 03          beq @ScanSkipDone
00194Fr 2  C8             iny
001950r 2  80 F9          bra @ScanSkipLine
001952r 2               @ScanSkipDone:
001952r 2  C8             iny                            ; Past null
001953r 2  98             tya
001954r 2  18             clc
001955r 2  65 0E          adc BAS_TMP1
001957r 2  85 0E          sta BAS_TMP1
001959r 2  A9 00          lda #$00
00195Br 2  65 0F          adc BAS_TMP1 + 1
00195Dr 2  85 0F          sta BAS_TMP1 + 1
00195Fr 2  80 D6          bra @ScanLoop
001961r 2               
001961r 2               @ScanFound:
001961r 2                 ; Point DATAPTR past the DATA token
001961r 2  18             clc
001962r 2  A5 0E          lda BAS_TMP1
001964r 2  69 05          adc #(LINE_PAYLOAD + 1)
001966r 2  8D 1A 03       sta BAS_DATAPTR
001969r 2  A5 0F          lda BAS_TMP1 + 1
00196Br 2  69 00          adc #$00
00196Dr 2  8D 1B 03       sta BAS_DATAPTR + 1
001970r 2  60             rts
001971r 2               
001971r 2               @ScanNotFound:
001971r 2  38             sec                            ; Carry set = not found
001972r 2  60             rts
001973r 2               
001973r 2               ; ============================================================================
001973r 2               ; SQR(n) — Integer square root (16-bit unsigned)
001973r 2               ; ============================================================================
001973r 2               ; Input: BAS_ACC = n (signed; negative → ILLEGAL QTY error)
001973r 2               ; Output: BAS_ACC = floor(sqrt(n))
001973r 2               ; Algorithm: Newton's method — guess = n/2, iterate guess = (guess + n/guess)/2
001973r 2               ; Uses BAS_AUX as "n" copy, BAS_NUMTMP to save current guess across division
001973r 2               
001973r 2               BasFuncSqr:
001973r 2                 ; Negative → error
001973r 2  A5 0B          lda BAS_ACC + 1
001975r 2  30 66          bmi @SqrErr
001977r 2                 ; n = 0 or 1 → result is n
001977r 2  A5 0B          lda BAS_ACC + 1
001979r 2  D0 06          bne @SqrBig
00197Br 2  A5 0A          lda BAS_ACC
00197Dr 2  C9 02          cmp #2
00197Fr 2  90 59          bcc @SqrDone                   ; 0 or 1 → return as-is
001981r 2               @SqrBig:
001981r 2                 ; Copy n to AUX
001981r 2  A5 0A          lda BAS_ACC
001983r 2  85 0C          sta BAS_AUX
001985r 2  A5 0B          lda BAS_ACC + 1
001987r 2  85 0D          sta BAS_AUX + 1
001989r 2                 ; Initial guess = n / 2 (unsigned shift right)
001989r 2  46 0B          lsr BAS_ACC + 1
00198Br 2  66 0A          ror BAS_ACC
00198Dr 2                 ; If guess becomes 0 (n was 1, already handled), set to 1
00198Dr 2  A5 0A          lda BAS_ACC
00198Fr 2  05 0B          ora BAS_ACC + 1
001991r 2  D0 04          bne @SqrLoop
001993r 2  A9 01          lda #$01
001995r 2  85 0A          sta BAS_ACC
001997r 2               @SqrLoop:
001997r 2                 ; Save current guess in NUMTMP (survives BasMathDiv)
001997r 2  A5 0A          lda BAS_ACC
001999r 2  85 22          sta BAS_NUMTMP
00199Br 2  A5 0B          lda BAS_ACC + 1
00199Dr 2  85 23          sta BAS_NUMTMP + 1
00199Fr 2                 ; Compute n / guess: AUX / ACC → ACC
00199Fr 2                 ; BasMathDiv clobbers AUX — save n on stack
00199Fr 2  A5 0C          lda BAS_AUX
0019A1r 2  48             pha
0019A2r 2  A5 0D          lda BAS_AUX + 1
0019A4r 2  48             pha
0019A5r 2  20 rr rr       jsr BasMathDiv                 ; ACC = AUX / ACC
0019A8r 2                 ; new_guess = (guess + n/guess) / 2
0019A8r 2  18             clc
0019A9r 2  A5 0A          lda BAS_ACC
0019ABr 2  65 22          adc BAS_NUMTMP
0019ADr 2  85 0A          sta BAS_ACC
0019AFr 2  A5 0B          lda BAS_ACC + 1
0019B1r 2  65 23          adc BAS_NUMTMP + 1
0019B3r 2  85 0B          sta BAS_ACC + 1
0019B5r 2                 ; Unsigned divide by 2
0019B5r 2  46 0B          lsr BAS_ACC + 1
0019B7r 2  66 0A          ror BAS_ACC
0019B9r 2                 ; Restore n to AUX
0019B9r 2  68             pla
0019BAr 2  85 0D          sta BAS_AUX + 1
0019BCr 2  68             pla
0019BDr 2  85 0C          sta BAS_AUX
0019BFr 2                 ; Converged? Compare new_guess with old guess (NUMTMP)
0019BFr 2  A5 0A          lda BAS_ACC
0019C1r 2  C5 22          cmp BAS_NUMTMP
0019C3r 2  D0 06          bne @SqrNotSame
0019C5r 2  A5 0B          lda BAS_ACC + 1
0019C7r 2  C5 23          cmp BAS_NUMTMP + 1
0019C9r 2  F0 0F          beq @SqrDone                   ; Converged
0019CBr 2               @SqrNotSame:
0019CBr 2                 ; Check if new_guess = old_guess - 1 (oscillation)
0019CBr 2  38             sec
0019CCr 2  A5 22          lda BAS_NUMTMP
0019CEr 2  E5 0A          sbc BAS_ACC
0019D0r 2  C9 01          cmp #$01
0019D2r 2  D0 C3          bne @SqrLoop
0019D4r 2  A5 23          lda BAS_NUMTMP + 1
0019D6r 2  E5 0B          sbc BAS_ACC + 1
0019D8r 2  D0 BD          bne @SqrLoop
0019DAr 2                 ; Oscillating between guess and guess-1; take the smaller (ACC)
0019DAr 2               @SqrDone:
0019DAr 2  64 0B          stz BAS_ACC + 1                ; Result fits in low byte for values ≤255
0019DCr 2  60             rts                            ; For larger roots, high byte already correct from loop
0019DDr 2               
0019DDr 2               @SqrErr:
0019DDr 2  A9 08          lda #ERR_ILLEGAL_QTY
0019DFr 2  4C rr rr       jmp BasError
0019E2r 2               
0019E2r 2               ; ============================================================================
0019E2r 2               ; POW(b,e) — Integer exponentiation
0019E2r 2               ; ============================================================================
0019E2r 2               ; Input: BAS_ACC = base, BAS_AUX = exponent
0019E2r 2               ; Output: BAS_ACC = base^exponent
0019E2r 2               ; Negative exponent → return 0 (integer truncation)
0019E2r 2               ; Uses BAS_SCRATCH2 for base (safe across BasMathMul),
0019E2r 2               ;      BAS_NUMTMP for exponent counter (safe across BasMathMul)
0019E2r 2               
0019E2r 2               BasFuncPow:
0019E2r 2                 ; If exponent is negative → result is 0
0019E2r 2  A5 0D          lda BAS_AUX + 1
0019E4r 2  30 41          bmi @PowZero
0019E6r 2                 ; If exponent = 0 → return 1
0019E6r 2  A5 0C          lda BAS_AUX
0019E8r 2  05 0D          ora BAS_AUX + 1
0019EAr 2  D0 07          bne @PowStart
0019ECr 2  A9 01          lda #$01
0019EEr 2  85 0A          sta BAS_ACC
0019F0r 2  64 0B          stz BAS_ACC + 1
0019F2r 2  60             rts
0019F3r 2               @PowStart:
0019F3r 2                 ; Save base in SCRATCH2 (survives BasMathMul which only uses SCRATCH)
0019F3r 2  A5 0A          lda BAS_ACC
0019F5r 2  85 1E          sta BAS_SCRATCH2
0019F7r 2  A5 0B          lda BAS_ACC + 1
0019F9r 2  85 1F          sta BAS_SCRATCH2 + 1
0019FBr 2                 ; Save exponent counter in NUMTMP (survives BasMathMul)
0019FBr 2  A5 0C          lda BAS_AUX
0019FDr 2  85 22          sta BAS_NUMTMP
0019FFr 2  A5 0D          lda BAS_AUX + 1
001A01r 2  85 23          sta BAS_NUMTMP + 1
001A03r 2                 ; Decrement counter: ACC already holds base^1
001A03r 2  A5 22          lda BAS_NUMTMP
001A05r 2  D0 02          bne :+
001A07r 2  C6 23          dec BAS_NUMTMP + 1
001A09r 2  C6 22        : dec BAS_NUMTMP
001A0Br 2               @PowMulLoop:
001A0Br 2                 ; Counter = 0? done
001A0Br 2  A5 22          lda BAS_NUMTMP
001A0Dr 2  05 23          ora BAS_NUMTMP + 1
001A0Fr 2  F0 15          beq @PowDone
001A11r 2                 ; Set AUX = base for multiplication
001A11r 2  A5 1E          lda BAS_SCRATCH2
001A13r 2  85 0C          sta BAS_AUX
001A15r 2  A5 1F          lda BAS_SCRATCH2 + 1
001A17r 2  85 0D          sta BAS_AUX + 1
001A19r 2  20 rr rr       jsr BasMathMul                 ; ACC = ACC * base
001A1Cr 2                 ; Decrement counter
001A1Cr 2  A5 22          lda BAS_NUMTMP
001A1Er 2  D0 02          bne :+
001A20r 2  C6 23          dec BAS_NUMTMP + 1
001A22r 2  C6 22        : dec BAS_NUMTMP
001A24r 2  80 E5          bra @PowMulLoop
001A26r 2               @PowDone:
001A26r 2  60             rts
001A27r 2               @PowZero:
001A27r 2  64 0A          stz BAS_ACC
001A29r 2  64 0B          stz BAS_ACC + 1
001A2Br 2  60             rts
001A2Cr 2               
001A2Cr 2               ; ============================================================================
001A2Cr 2               ; SETTIME hh, mm, ss — Set RTC time
001A2Cr 2               ; ============================================================================
001A2Cr 2               
001A2Cr 2               BasCmdSettime:
001A2Cr 2  AD 0D 03       lda HW_PRESENT
001A2Fr 2  29 04          and #HW_RTC
001A31r 2  D0 03          bne @SettimeStart
001A33r 2  4C rr rr       jmp BasPrintNoDevice
001A36r 2               @SettimeStart:
001A36r 2  20 rr rr       jsr BasExpr                    ; hh -> BAS_ACC
001A39r 2  A5 0A          lda BAS_ACC
001A3Br 2  48             pha                            ; save hours
001A3Cr 2  20 rr rr       jsr BasSkipSpaces
001A3Fr 2  A9 2C          lda #CH_COMMA
001A41r 2  20 rr rr       jsr BasExpectChar
001A44r 2  20 rr rr       jsr BasExpr                    ; mm -> BAS_ACC
001A47r 2  A5 0A          lda BAS_ACC
001A49r 2  48             pha                            ; save minutes
001A4Ar 2  20 rr rr       jsr BasSkipSpaces
001A4Dr 2  A9 2C          lda #CH_COMMA
001A4Fr 2  20 rr rr       jsr BasExpectChar
001A52r 2  20 rr rr       jsr BasExpr                    ; ss -> BAS_ACC
001A55r 2                 ; Stack: top=minutes, bottom=hours. BAS_ACC has seconds.
001A55r 2                 ; RtcWriteTime wants: A=hours, X=minutes, Y=seconds
001A55r 2  A4 0A          ldy BAS_ACC                   ; Y = seconds
001A57r 2  FA             plx                            ; X = minutes (was pushed last)
001A58r 2  68             pla                            ; A = hours (was pushed first)
001A59r 2  20 rr rr       jsr RtcWriteTime
001A5Cr 2  60             rts
001A5Dr 2               
001A5Dr 2               ; ============================================================================
001A5Dr 2               ; SETDATE cc, yy, mm, dd — Set RTC date
001A5Dr 2               ; ============================================================================
001A5Dr 2               
001A5Dr 2               BasCmdSetdate:
001A5Dr 2  AD 0D 03       lda HW_PRESENT
001A60r 2  29 04          and #HW_RTC
001A62r 2  D0 03          bne @SetdateStart
001A64r 2  4C rr rr       jmp BasPrintNoDevice
001A67r 2               @SetdateStart:
001A67r 2  20 rr rr       jsr BasExpr                    ; cc -> BAS_ACC
001A6Ar 2  A5 0A          lda BAS_ACC
001A6Cr 2  8D 0B 03       sta RTC_BUF_CENT               ; Store century for RtcWriteDate
001A6Fr 2  20 rr rr       jsr BasSkipSpaces
001A72r 2  A9 2C          lda #CH_COMMA
001A74r 2  20 rr rr       jsr BasExpectChar
001A77r 2  20 rr rr       jsr BasExpr                    ; yy -> BAS_ACC
001A7Ar 2  A5 0A          lda BAS_ACC
001A7Cr 2  48             pha                            ; push year (1st on stack)
001A7Dr 2  20 rr rr       jsr BasSkipSpaces
001A80r 2  A9 2C          lda #CH_COMMA
001A82r 2  20 rr rr       jsr BasExpectChar
001A85r 2  20 rr rr       jsr BasExpr                    ; mm -> BAS_ACC
001A88r 2  A5 0A          lda BAS_ACC
001A8Ar 2  48             pha                            ; push month (2nd on stack)
001A8Br 2  20 rr rr       jsr BasSkipSpaces
001A8Er 2  A9 2C          lda #CH_COMMA
001A90r 2  20 rr rr       jsr BasExpectChar
001A93r 2  20 rr rr       jsr BasExpr                    ; dd -> BAS_ACC
001A96r 2                 ; Stack: top=month, bottom=year. BAS_ACC has day.
001A96r 2                 ; RtcWriteDate wants: A=day, X=month, Y=year
001A96r 2  A5 0A          lda BAS_ACC                   ; A = day
001A98r 2  FA             plx                            ; X = month (was pushed last)
001A99r 2  7A             ply                            ; Y = year (was pushed first)
001A9Ar 2  20 rr rr       jsr RtcWriteDate
001A9Dr 2  60             rts
001A9Er 2               
001A9Er 2               ; ============================================================================
001A9Er 2               ; NVRAM addr, value — Write byte to RTC NVRAM
001A9Er 2               ; ============================================================================
001A9Er 2               
001A9Er 2               BasCmdNvramW:
001A9Er 2  AD 0D 03       lda HW_PRESENT
001AA1r 2  29 04          and #HW_RTC
001AA3r 2  D0 03          bne @NvramWStart
001AA5r 2  4C rr rr       jmp BasPrintNoDevice
001AA8r 2               @NvramWStart:
001AA8r 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
001AABr 2  A5 0A          lda BAS_ACC
001AADr 2  85 21          sta BAS_TEMP                   ; save address
001AAFr 2  20 rr rr       jsr BasSkipSpaces
001AB2r 2  A9 2C          lda #CH_COMMA
001AB4r 2  20 rr rr       jsr BasExpectChar
001AB7r 2  20 rr rr       jsr BasExpr                    ; value -> BAS_ACC
001ABAr 2  A6 21          ldx BAS_TEMP                   ; X = address
001ABCr 2  A5 0A          lda BAS_ACC                    ; A = value
001ABEr 2  20 rr rr       jsr RtcWriteNVRAM
001AC1r 2  60             rts
001AC2r 2               
001AC2r 2               ; ============================================================================
001AC2r 2               ; MEM — Print system info
001AC2r 2               ; ============================================================================
001AC2r 2               
001AC2r 2               BasCmdMem:
001AC2r 2                 ; Print free bytes
001AC2r 2  20 rr rr       jsr BasPrintFree
001AC5r 2                 ; Print HW: $xx
001AC5r 2  A9 rr          lda #<BasStrMemHW
001AC7r 2  85 0E          sta BAS_TMP1
001AC9r 2  A9 rr          lda #>BasStrMemHW
001ACBr 2  85 0F          sta BAS_TMP1 + 1
001ACDr 2  20 rr rr       jsr BasPrintStr                ; CR+LF+"HW: $"
001AD0r 2  AD 0D 03       lda HW_PRESENT
001AD3r 2  20 rr rr       jsr BasMemHexByte
001AD6r 2                 ; Print IO mode
001AD6r 2  A9 rr          lda #<BasStrMemIO
001AD8r 2  85 0E          sta BAS_TMP1
001ADAr 2  A9 rr          lda #>BasStrMemIO
001ADCr 2  85 0F          sta BAS_TMP1 + 1
001ADEr 2  20 rr rr       jsr BasPrintStr                ; CR+LF+"IO: "
001AE1r 2  AD 06 03       lda IO_MODE
001AE4r 2  29 01          and #$01
001AE6r 2  D0 11          bne @MemSerial
001AE8r 2  A9 56          lda #'V'
001AEAr 2  20 rr rr       jsr Chrout
001AEDr 2  A9 49          lda #'I'
001AEFr 2  20 rr rr       jsr Chrout
001AF2r 2  A9 44          lda #'D'
001AF4r 2  20 rr rr       jsr Chrout
001AF7r 2  80 0F          bra @MemIODone
001AF9r 2               @MemSerial:
001AF9r 2  A9 53          lda #'S'
001AFBr 2  20 rr rr       jsr Chrout
001AFEr 2  A9 45          lda #'E'
001B00r 2  20 rr rr       jsr Chrout
001B03r 2  A9 52          lda #'R'
001B05r 2  20 rr rr       jsr Chrout
001B08r 2               @MemIODone:
001B08r 2  20 rr rr       jsr BasPrintCRLF
001B0Br 2  60             rts
001B0Cr 2               
001B0Cr 2               ; BasMemHexByte — print A as 2 hex digits
001B0Cr 2               BasMemHexByte:
001B0Cr 2  48             pha
001B0Dr 2  4A             lsr
001B0Er 2  4A             lsr
001B0Fr 2  4A             lsr
001B10r 2  4A             lsr
001B11r 2  20 rr rr       jsr @MemNibble
001B14r 2  68             pla
001B15r 2  29 0F          and #$0F
001B17r 2               @MemNibble:
001B17r 2  C9 0A          cmp #$0A
001B19r 2  90 04          bcc @MemDigit
001B1Br 2  69 36          adc #('A' - $0A - 1)
001B1Dr 2  80 02          bra @MemPrint
001B1Fr 2               @MemDigit:
001B1Fr 2  09 30          ora #'0'
001B21r 2               @MemPrint:
001B21r 2  4C rr rr       jmp Chrout
001B24r 2               
001B24r 2               ; ============================================================================
001B24r 2               ; DIM var(size) [, var(size) ...] — Dimension arrays
001B24r 2               ; ============================================================================
001B24r 2               
001B24r 2               BasCmdDim:
001B24r 2               @DimNext:
001B24r 2  20 rr rr       jsr BasSkipSpaces
001B27r 2  20 rr rr       jsr BasGetTokChar
001B2Ar 2               
001B2Ar 2                 ; Must be a variable A-Z
001B2Ar 2  C9 41          cmp #'A'
001B2Cr 2  B0 03          bcs @DimNotLow
001B2Er 2  4C rr rr       jmp @DimErr
001B31r 2               @DimNotLow:
001B31r 2  C9 5B          cmp #'Z' + 1
001B33r 2  90 03          bcc @DimNotHigh
001B35r 2  4C rr rr       jmp @DimErr
001B38r 2               @DimNotHigh:
001B38r 2               
001B38r 2  38             sec
001B39r 2  E9 41          sbc #'A'
001B3Br 2  0A             asl                            ; ×2 for descriptor table index
001B3Cr 2  85 21          sta BAS_TEMP                   ; Save var offset
001B3Er 2               
001B3Er 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
001B41r 2               
001B41r 2                 ; Expect '('
001B41r 2  A9 28          lda #CH_LPAREN
001B43r 2  20 rr rr       jsr BasExpectChar
001B46r 2               
001B46r 2  20 rr rr       jsr BasExpr                    ; size -> BAS_ACC (max valid index)
001B49r 2               
001B49r 2                 ; Expect ')'
001B49r 2  A9 29          lda #CH_RPAREN
001B4Br 2  20 rr rr       jsr BasExpectChar
001B4Er 2               
001B4Er 2                 ; Check if already dimensioned
001B4Er 2  A6 21          ldx BAS_TEMP
001B50r 2  BD 5B 03       lda BAS_ARYDESC,x
001B53r 2  1D 5C 03       ora BAS_ARYDESC + 1,x
001B56r 2  F0 03          beq @DimNotRedim
001B58r 2  4C rr rr       jmp @DimRedim
001B5Br 2               @DimNotRedim:
001B5Br 2               
001B5Br 2                 ; BAS_ACC = max index (0-based), elements = ACC + 1
001B5Br 2                 ; Total bytes = 2 (dim size) + (ACC + 1) * 2
001B5Br 2                 ; Check non-negative
001B5Br 2  A5 0B          lda BAS_ACC + 1
001B5Dr 2  10 03          bpl @DimNotNeg
001B5Fr 2  4C rr rr       jmp @DimIllegal
001B62r 2               @DimNotNeg:
001B62r 2               
001B62r 2                 ; Compute total size: (ACC + 1) * 2 + 2
001B62r 2  18             clc
001B63r 2  A5 0A          lda BAS_ACC
001B65r 2  69 01          adc #$01
001B67r 2  85 0C          sta BAS_AUX
001B69r 2  A5 0B          lda BAS_ACC + 1
001B6Br 2  69 00          adc #$00
001B6Dr 2  85 0D          sta BAS_AUX + 1                ; AUX = element count
001B6Fr 2  06 0C          asl BAS_AUX
001B71r 2  26 0D          rol BAS_AUX + 1                ; AUX = element count * 2
001B73r 2  18             clc
001B74r 2  A5 0C          lda BAS_AUX
001B76r 2  69 02          adc #$02                       ; + 2 for dim size header
001B78r 2  85 0C          sta BAS_AUX
001B7Ar 2  A5 0D          lda BAS_AUX + 1
001B7Cr 2  69 00          adc #$00
001B7Er 2  85 0D          sta BAS_AUX + 1                ; AUX = total bytes needed
001B80r 2               
001B80r 2                 ; New array top = BAS_ARYTOP - total_bytes
001B80r 2  38             sec
001B81r 2  AD 8F 03       lda BAS_ARYTOP
001B84r 2  E5 0C          sbc BAS_AUX
001B86r 2  85 10          sta BAS_TMP2
001B88r 2  AD 90 03       lda BAS_ARYTOP + 1
001B8Br 2  E5 0D          sbc BAS_AUX + 1
001B8Dr 2  85 11          sta BAS_TMP2 + 1               ; TMP2 = proposed new ARYTOP
001B8Fr 2               
001B8Fr 2                 ; Check for collision with program: new top must be > PRGEND
001B8Fr 2  A5 11          lda BAS_TMP2 + 1
001B91r 2  C5 13          cmp BAS_PRGEND + 1
001B93r 2  90 78          bcc @DimOOM
001B95r 2  D0 08          bne @DimOK
001B97r 2  A5 10          lda BAS_TMP2
001B99r 2  C5 12          cmp BAS_PRGEND
001B9Br 2  90 70          bcc @DimOOM
001B9Dr 2  F0 6E          beq @DimOOM
001B9Fr 2               @DimOK:
001B9Fr 2                 ; Commit: update ARYTOP
001B9Fr 2  A5 10          lda BAS_TMP2
001BA1r 2  8D 8F 03       sta BAS_ARYTOP
001BA4r 2  A5 11          lda BAS_TMP2 + 1
001BA6r 2  8D 90 03       sta BAS_ARYTOP + 1
001BA9r 2               
001BA9r 2                 ; Store base pointer in descriptor table
001BA9r 2  A6 21          ldx BAS_TEMP
001BABr 2  A5 10          lda BAS_TMP2
001BADr 2  9D 5B 03       sta BAS_ARYDESC,x
001BB0r 2  A5 11          lda BAS_TMP2 + 1
001BB2r 2  9D 5C 03       sta BAS_ARYDESC + 1,x
001BB5r 2               
001BB5r 2                 ; Write max index at base pointer
001BB5r 2  A0 00          ldy #$00
001BB7r 2  A5 0A          lda BAS_ACC
001BB9r 2  91 10          sta (BAS_TMP2),y
001BBBr 2  C8             iny
001BBCr 2  A5 0B          lda BAS_ACC + 1
001BBEr 2  91 10          sta (BAS_TMP2),y
001BC0r 2               
001BC0r 2                 ; Zero-fill element data (starts at base + 2, length = element_count * 2)
001BC0r 2  18             clc
001BC1r 2  A5 10          lda BAS_TMP2
001BC3r 2  69 02          adc #$02
001BC5r 2  85 10          sta BAS_TMP2
001BC7r 2  A5 11          lda BAS_TMP2 + 1
001BC9r 2  69 00          adc #$00
001BCBr 2  85 11          sta BAS_TMP2 + 1
001BCDr 2               
001BCDr 2                 ; AUX still holds total_bytes; element data = AUX - 2
001BCDr 2  38             sec
001BCEr 2  A5 0C          lda BAS_AUX
001BD0r 2  E9 02          sbc #$02
001BD2r 2  85 0C          sta BAS_AUX
001BD4r 2  A5 0D          lda BAS_AUX + 1
001BD6r 2  E9 00          sbc #$00
001BD8r 2  85 0D          sta BAS_AUX + 1
001BDAr 2               
001BDAr 2  A9 00          lda #$00
001BDCr 2  A0 00          ldy #$00
001BDEr 2               @DimZeroLoop:
001BDEr 2  A5 0C          lda BAS_AUX
001BE0r 2  05 0D          ora BAS_AUX + 1
001BE2r 2  F0 13          beq @DimZeroDone
001BE4r 2  A9 00          lda #$00
001BE6r 2  91 10          sta (BAS_TMP2),y
001BE8r 2  C8             iny
001BE9r 2  D0 02          bne @DimNoPage
001BEBr 2  E6 11          inc BAS_TMP2 + 1
001BEDr 2               @DimNoPage:
001BEDr 2                 ; Decrement AUX
001BEDr 2  A5 0C          lda BAS_AUX
001BEFr 2  D0 02          bne :+
001BF1r 2  C6 0D          dec BAS_AUX + 1
001BF3r 2  C6 0C        : dec BAS_AUX
001BF5r 2  80 E7          bra @DimZeroLoop
001BF7r 2               @DimZeroDone:
001BF7r 2               
001BF7r 2                 ; Check for comma (multiple DIM declarations)
001BF7r 2  20 rr rr       jsr BasSkipSpaces
001BFAr 2  20 rr rr       jsr BasGetTokChar
001BFDr 2  C9 2C          cmp #CH_COMMA
001BFFr 2  D0 06          bne @DimDone
001C01r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
001C04r 2  4C rr rr       jmp @DimNext
001C07r 2               @DimDone:
001C07r 2  60             rts
001C08r 2               
001C08r 2               @DimRedim:
001C08r 2  A9 0C          lda #ERR_REDIM
001C0Ar 2  4C rr rr       jmp BasError
001C0Dr 2               @DimOOM:
001C0Dr 2  A9 03          lda #ERR_OUT_OF_MEM
001C0Fr 2  4C rr rr       jmp BasError
001C12r 2               @DimIllegal:
001C12r 2  A9 08          lda #ERR_ILLEGAL_QTY
001C14r 2  4C rr rr       jmp BasError
001C17r 2               @DimErr:
001C17r 2  A9 00          lda #ERR_SYNTAX
001C19r 2  4C rr rr       jmp BasError
001C1Cr 2               
001C1Cr 2               ; ============================================================================
001C1Cr 2               ; BasArrayRead — Read array element: X = var_offset (already ×2)
001C1Cr 2               ; ============================================================================
001C1Cr 2               ; Called from BasExprPrimary when A(expr) is found
001C1Cr 2               ; TXTPTR points at '('
001C1Cr 2               
001C1Cr 2               BasArrayRead:
001C1Cr 2  86 21          stx BAS_TEMP                   ; Save var offset
001C1Er 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
001C21r 2  20 rr rr       jsr BasExpr                    ; index -> BAS_ACC
001C24r 2  A9 29          lda #CH_RPAREN
001C26r 2  20 rr rr       jsr BasExpectChar              ; Expect ')'
001C29r 2               
001C29r 2                 ; Resolve element address into BAS_TMP2
001C29r 2  A5 0A          lda BAS_ACC
001C2Br 2  85 0C          sta BAS_AUX
001C2Dr 2  A5 0B          lda BAS_ACC + 1
001C2Fr 2  85 0D          sta BAS_AUX + 1                ; AUX = index
001C31r 2  20 rr rr       jsr BasArrayAddr               ; BAS_TMP2 = element address
001C34r 2               
001C34r 2                 ; Read element
001C34r 2  A0 00          ldy #$00
001C36r 2  B1 10          lda (BAS_TMP2),y
001C38r 2  85 0A          sta BAS_ACC
001C3Ar 2  C8             iny
001C3Br 2  B1 10          lda (BAS_TMP2),y
001C3Dr 2  85 0B          sta BAS_ACC + 1
001C3Fr 2  60             rts
001C40r 2               
001C40r 2               ; ============================================================================
001C40r 2               ; BasArrayWrite — Write array element: X = var_offset (already ×2)
001C40r 2               ; ============================================================================
001C40r 2               ; Called from BasCmdLet when A(expr) = expr is found
001C40r 2               ; TXTPTR points at '('
001C40r 2               
001C40r 2               BasArrayWrite:
001C40r 2  86 21          stx BAS_TEMP                   ; Save var offset
001C42r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
001C45r 2  20 rr rr       jsr BasExpr                    ; index -> BAS_ACC
001C48r 2  A9 29          lda #CH_RPAREN
001C4Ar 2  20 rr rr       jsr BasExpectChar              ; Expect ')'
001C4Dr 2               
001C4Dr 2                 ; Save index on stack
001C4Dr 2  A5 0A          lda BAS_ACC
001C4Fr 2  48             pha
001C50r 2  A5 0B          lda BAS_ACC + 1
001C52r 2  48             pha
001C53r 2               
001C53r 2  20 rr rr       jsr BasSkipSpaces
001C56r 2  A9 3D          lda #CH_EQUALS
001C58r 2  20 rr rr       jsr BasExpectChar              ; Expect '='
001C5Br 2               
001C5Br 2  20 rr rr       jsr BasExpr                    ; value -> BAS_ACC
001C5Er 2               
001C5Er 2                 ; Pop index into AUX
001C5Er 2  68             pla
001C5Fr 2  85 0D          sta BAS_AUX + 1
001C61r 2  68             pla
001C62r 2  85 0C          sta BAS_AUX                    ; AUX = index
001C64r 2               
001C64r 2                 ; Resolve element address into BAS_TMP2
001C64r 2  20 rr rr       jsr BasArrayAddr               ; BAS_TMP2 = element address
001C67r 2               
001C67r 2                 ; Write element
001C67r 2  A0 00          ldy #$00
001C69r 2  A5 0A          lda BAS_ACC
001C6Br 2  91 10          sta (BAS_TMP2),y
001C6Dr 2  C8             iny
001C6Er 2  A5 0B          lda BAS_ACC + 1
001C70r 2  91 10          sta (BAS_TMP2),y
001C72r 2  60             rts
001C73r 2               
001C73r 2               ; ============================================================================
001C73r 2               ; BasArrayAddr — Compute array element address
001C73r 2               ; ============================================================================
001C73r 2               ; Input: BAS_TEMP = var_offset (×2), BAS_AUX = index
001C73r 2               ; Output: BAS_TMP2 = element address
001C73r 2               ; Errors: ERR_SYNTAX if not dimensioned, ERR_BAD_SUBSCRIPT if out of range
001C73r 2               
001C73r 2               BasArrayAddr:
001C73r 2                 ; Look up array base pointer
001C73r 2  A6 21          ldx BAS_TEMP
001C75r 2  BD 5B 03       lda BAS_ARYDESC,x
001C78r 2  85 10          sta BAS_TMP2
001C7Ar 2  BD 5C 03       lda BAS_ARYDESC + 1,x
001C7Dr 2  85 11          sta BAS_TMP2 + 1
001C7Fr 2               
001C7Fr 2                 ; Check if dimensioned
001C7Fr 2  05 10          ora BAS_TMP2
001C81r 2  F0 38          beq @AANotDim
001C83r 2               
001C83r 2                 ; Bounds check: AUX must be 0..max_index
001C83r 2  A5 0D          lda BAS_AUX + 1
001C85r 2  30 39          bmi @AABadSub                 ; Negative index
001C87r 2  A0 00          ldy #$00
001C89r 2  B1 10          lda (BAS_TMP2),y               ; max_index lo
001C8Br 2  85 1C          sta BAS_SCRATCH
001C8Dr 2  C8             iny
001C8Er 2  B1 10          lda (BAS_TMP2),y               ; max_index hi
001C90r 2  C5 0D          cmp BAS_AUX + 1
001C92r 2  90 2C          bcc @AABadSub
001C94r 2  D0 06          bne @AAInBounds
001C96r 2  A5 1C          lda BAS_SCRATCH
001C98r 2  C5 0C          cmp BAS_AUX
001C9Ar 2  90 24          bcc @AABadSub
001C9Cr 2               @AAInBounds:
001C9Cr 2                 ; Address = base + 2 + AUX * 2
001C9Cr 2  06 0C          asl BAS_AUX
001C9Er 2  26 0D          rol BAS_AUX + 1               ; AUX = index * 2
001CA0r 2  18             clc
001CA1r 2  A5 10          lda BAS_TMP2
001CA3r 2  69 02          adc #$02
001CA5r 2  85 10          sta BAS_TMP2
001CA7r 2  A5 11          lda BAS_TMP2 + 1
001CA9r 2  69 00          adc #$00
001CABr 2  85 11          sta BAS_TMP2 + 1               ; base + 2
001CADr 2  18             clc
001CAEr 2  A5 10          lda BAS_TMP2
001CB0r 2  65 0C          adc BAS_AUX
001CB2r 2  85 10          sta BAS_TMP2
001CB4r 2  A5 11          lda BAS_TMP2 + 1
001CB6r 2  65 0D          adc BAS_AUX + 1
001CB8r 2  85 11          sta BAS_TMP2 + 1               ; final address
001CBAr 2  60             rts
001CBBr 2               
001CBBr 2               @AANotDim:
001CBBr 2  A9 00          lda #ERR_SYNTAX
001CBDr 2  4C rr rr       jmp BasError
001CC0r 2               @AABadSub:
001CC0r 2  A9 0D          lda #ERR_BAD_SUBSCRIPT
001CC2r 2  4C rr rr       jmp BasError
001CC5r 2               
001CC5r 2               ; ============================================================================
001CC5r 2               ; Keyword Table
001CC5r 2               ; ============================================================================
001CC5r 2               ; Format: null-terminated keyword string, then token byte.
001CC5r 2               ; Longer keywords first to prevent partial matches (e.g. GOSUB before GOTO).
001CC5r 2               ; Table terminated by a lone $00.
001CC5r 2               
001CC5r 2               BasKeywordTable:
001CC5r 2  53 45 54 54    .byte "SETTIME", $00, TOK_SETTIME
001CC9r 2  49 4D 45 00  
001CCDr 2  BF           
001CCEr 2  53 45 54 44    .byte "SETDATE", $00, TOK_SETDATE
001CD2r 2  41 54 45 00  
001CD6r 2  C0           
001CD7r 2  52 45 53 54    .byte "RESTORE", $00, TOK_RESTORE
001CDBr 2  4F 52 45 00  
001CDFr 2  B5           
001CE0r 2  52 45 54 55    .byte "RETURN", $00, TOK_RETURN
001CE4r 2  52 4E 00 85  
001CE8r 2  4C 4F 43 41    .byte "LOCATE", $00, TOK_LOCATE
001CECr 2  54 45 00 A4  
001CF0r 2  4E 56 52 41    .byte "NVRAM",  $00, TOK_NVRAM
001CF4r 2  4D 00 C1     
001CF7r 2  49 4E 4B 45    .byte "INKEY",  $00, TOK_INKEY
001CFBr 2  59 00 BA     
001CFEr 2  50 52 49 4E    .byte "PRINT",  $00, TOK_PRINT
001D02r 2  54 00 80     
001D05r 2  49 4E 50 55    .byte "INPUT",  $00, TOK_INPUT
001D09r 2  54 00 81     
001D0Cr 2  47 4F 53 55    .byte "GOSUB",  $00, TOK_GOSUB
001D10r 2  42 00 84     
001D13r 2  53 4F 55 4E    .byte "SOUND",  $00, TOK_SOUND
001D17r 2  44 00 A7     
001D1Ar 2  50 41 55 53    .byte "PAUSE",  $00, TOK_PAUSE
001D1Er 2  45 00 AC     
001D21r 2  43 4F 4C 4F    .byte "COLOR",  $00, TOK_COLOR
001D25r 2  52 00 A5     
001D28r 2  46 52 45 45    .byte "FREE",   $00, TOK_FREE
001D2Cr 2  00 BE        
001D2Er 2  53 54 4F 50    .byte "STOP",   $00, TOK_STOP
001D32r 2  00 B0        
001D34r 2  43 4F 4E 54    .byte "CONT",   $00, TOK_CONT
001D38r 2  00 B1        
001D3Ar 2  44 41 54 41    .byte "DATA",   $00, TOK_DATA
001D3Er 2  00 B3        
001D40r 2  52 45 41 44    .byte "READ",   $00, TOK_READ
001D44r 2  00 B4        
001D46r 2  47 4F 54 4F    .byte "GOTO",   $00, TOK_GOTO
001D4Ar 2  00 83        
001D4Cr 2  54 48 45 4E    .byte "THEN",   $00, TOK_THEN
001D50r 2  00 87        
001D52r 2  53 54 45 50    .byte "STEP",   $00, TOK_STEP
001D56r 2  00 8A        
001D58r 2  4E 45 58 54    .byte "NEXT",   $00, TOK_NEXT
001D5Cr 2  00 8B        
001D5Er 2  50 45 45 4B    .byte "PEEK",   $00, TOK_PEEK
001D62r 2  00 92        
001D64r 2  50 4F 4B 45    .byte "POKE",   $00, TOK_POKE
001D68r 2  00 93        
001D6Ar 2  53 41 56 45    .byte "SAVE",   $00, TOK_SAVE
001D6Er 2  00 A0        
001D70r 2  4C 4F 41 44    .byte "LOAD",   $00, TOK_LOAD
001D74r 2  00 9F        
001D76r 2  4C 49 53 54    .byte "LIST",   $00, TOK_LIST
001D7Ar 2  00 8E        
001D7Cr 2  42 41 4E 4B    .byte "BANK",   $00, TOK_BANK
001D80r 2  00 AD        
001D82r 2  57 41 49 54    .byte "WAIT",   $00, TOK_WAIT
001D86r 2  00 AB        
001D88r 2  54 49 4D 45    .byte "TIME",   $00, TOK_TIME
001D8Cr 2  00 A9        
001D8Er 2  44 41 54 45    .byte "DATE",   $00, TOK_DATE
001D92r 2  00 AA        
001D94r 2  4C 45 54 00    .byte "LET",    $00, TOK_LET
001D98r 2  82           
001D99r 2  46 4F 52 00    .byte "FOR",    $00, TOK_FOR
001D9Dr 2  88           
001D9Er 2  52 45 4D 00    .byte "REM",    $00, TOK_REM
001DA2r 2  8C           
001DA3r 2  45 4E 44 00    .byte "END",    $00, TOK_END
001DA7r 2  8D           
001DA8r 2  52 55 4E 00    .byte "RUN",    $00, TOK_RUN
001DACr 2  8F           
001DADr 2  4E 45 57 00    .byte "NEW",    $00, TOK_NEW
001DB1r 2  90           
001DB2r 2  43 4C 52 00    .byte "CLR",    $00, TOK_CLR
001DB6r 2  91           
001DB7r 2  41 42 53 00    .byte "ABS",    $00, TOK_ABS
001DBBr 2  94           
001DBCr 2  52 4E 44 00    .byte "RND",    $00, TOK_RND
001DC0r 2  95           
001DC1r 2  4E 4F 54 00    .byte "NOT",    $00, TOK_NOT
001DC5r 2  96           
001DC6r 2  41 4E 44 00    .byte "AND",    $00, TOK_AND
001DCAr 2  97           
001DCBr 2  4D 4F 44 00    .byte "MOD",    $00, TOK_MOD
001DCFr 2  99           
001DD0r 2  44 49 4D 00    .byte "DIM",    $00, TOK_DIM
001DD4r 2  C3           
001DD5r 2  4D 45 4D 00    .byte "MEM",    $00, TOK_MEM
001DD9r 2  C2           
001DDAr 2  53 59 53 00    .byte "SYS",    $00, TOK_SYS
001DDEr 2  9E           
001DDFr 2  44 49 52 00    .byte "DIR",    $00, TOK_DIR
001DE3r 2  A1           
001DE4r 2  44 45 4C 00    .byte "DEL",    $00, TOK_DEL
001DE8r 2  A2           
001DE9r 2  42 52 4B 00    .byte "BRK",    $00, TOK_BRK
001DEDr 2  9D           
001DEEr 2  43 4C 53 00    .byte "CLS",    $00, TOK_CLS
001DF2r 2  A3           
001DF3r 2  56 4F 4C 00    .byte "VOL",    $00, TOK_VOL
001DF7r 2  A8           
001DF8r 2  4A 4F 59 00    .byte "JOY",    $00, TOK_JOY
001DFCr 2  A6           
001DFDr 2  53 47 4E 00    .byte "SGN",    $00, TOK_SGN
001E01r 2  AE           
001E02r 2  43 48 52 00    .byte "CHR",    $00, TOK_CHR
001E06r 2  AF           
001E07r 2  53 51 52 00    .byte "SQR",    $00, TOK_SQR
001E0Br 2  B6           
001E0Cr 2  4D 49 4E 00    .byte "MIN",    $00, TOK_MIN
001E10r 2  B7           
001E11r 2  4D 41 58 00    .byte "MAX",    $00, TOK_MAX
001E15r 2  B8           
001E16r 2  50 4F 57 00    .byte "POW",    $00, TOK_POW
001E1Ar 2  B9           
001E1Br 2  54 41 42 00    .byte "TAB",    $00, TOK_TAB
001E1Fr 2  BB           
001E20r 2  48 45 58 00    .byte "HEX",    $00, TOK_HEX
001E24r 2  BC           
001E25r 2  41 53 43 00    .byte "ASC",    $00, TOK_ASC
001E29r 2  BD           
001E2Ar 2  4F 4E 00 B2    .byte "ON",     $00, TOK_ON
001E2Er 2  49 46 00 86    .byte "IF",     $00, TOK_IF
001E32r 2  54 4F 00 89    .byte "TO",     $00, TOK_TO
001E36r 2  4F 52 00 98    .byte "OR",     $00, TOK_OR
001E3Ar 2  00             .byte $00                       ; End of table sentinel
001E3Br 2               
001E3Br 2               ; ============================================================================
001E3Br 2               ; BasPrintNoDevice — Print "?NO DEVICE" and return
001E3Br 2               ; Used by hardware-guarded commands when device is absent
001E3Br 2               ; ============================================================================
001E3Br 2               BasPrintNoDevice:
001E3Br 2  A9 rr          lda #<BasStrNoDevice
001E3Dr 2  85 0E          sta BAS_TMP1
001E3Fr 2  A9 rr          lda #>BasStrNoDevice
001E41r 2  85 0F          sta BAS_TMP1 + 1
001E43r 2  20 rr rr       jsr BasPrintStr
001E46r 2  60             rts
001E47r 2               
001E47r 2               ; ============================================================================
001E47r 2               ; String Data
001E47r 2               ; ============================================================================
001E47r 2               
001E47r 2  0D 0A 36 35  BasStrWelcome:  .byte CH_CR, CH_LF, "6502 BASIC v1.0", CH_CR, CH_LF, $00
001E4Br 2  30 32 20 42  
001E4Fr 2  41 53 49 43  
001E5Br 2  0D 0A 4F 4B  BasStrOK:       .byte CH_CR, CH_LF, "OK", CH_CR, CH_LF, $00
001E5Fr 2  0D 0A 00     
001E62r 2  20 42 59 54  BasStrFree:     .byte " BYTES FREE", $00
001E66r 2  45 53 20 46  
001E6Ar 2  52 45 45 00  
001E6Er 2  20 45 52 52  BasStrError:    .byte " ERROR", $00
001E72r 2  4F 52 00     
001E75r 2  20 49 4E 20  BasStrIn:       .byte " IN ", $00
001E79r 2  00           
001E7Ar 2  3F 52 45 44  BasStrRedo:     .byte "?REDO", CH_CR, CH_LF, $00
001E7Er 2  4F 0D 0A 00  
001E82r 2  3F 20 00     BasStrPrompt:   .byte "? ", $00
001E85r 2  0D 0A 3F 4C  BasStrLoadErr:  .byte CH_CR, CH_LF, "?LOAD ERROR", CH_CR, CH_LF, $00
001E89r 2  4F 41 44 20  
001E8Dr 2  45 52 52 4F  
001E95r 2  0D 0A 3F 53  BasStrSaveErr:  .byte CH_CR, CH_LF, "?SAVE ERROR", CH_CR, CH_LF, $00
001E99r 2  41 56 45 20  
001E9Dr 2  45 52 52 4F  
001EA5r 2  0D 0A 3F 44  BasStrDelErr:   .byte CH_CR, CH_LF, "?DEL ERROR", CH_CR, CH_LF, $00
001EA9r 2  45 4C 20 45  
001EADr 2  52 52 4F 52  
001EB4r 2  0D 0A 3F 4E  BasStrNoDevice: .byte CH_CR, CH_LF, "?NO DEVICE", CH_CR, CH_LF, $00
001EB8r 2  4F 20 44 45  
001EBCr 2  56 49 43 45  
001EC3r 2               
001EC3r 2               ; MEM command strings
001EC3r 2  0D 0A 48 57  BasStrMemHW:    .byte CH_CR, CH_LF, "HW: $", $00
001EC7r 2  3A 20 24 00  
001ECBr 2  0D 0A 49 4F  BasStrMemIO:    .byte CH_CR, CH_LF, "IO: ", $00
001ECFr 2  3A 20 00     
001ED2r 2               
001ED2r 2               
001ED2r 1               .segment "WOZMON"
000000r 1               .include "Wozmon.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   WOZMON    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               WOZ_XAML  = $24               ; Last "opened" location Low
000000r 2               WOZ_XAMH  = $25               ; Last "opened" location High
000000r 2               WOZ_STL   = $26               ; Store address Low
000000r 2               WOZ_STH   = $27               ; Store address High
000000r 2               WOZ_L     = $28               ; Hex value parsing Low
000000r 2               WOZ_H     = $29               ; Hex value parsing High
000000r 2               WOZ_YSAV  = $2A               ; Used to see if hex value is given
000000r 2               WOZ_MODE  = $2B               ; $00=XAM, $7F=STOR, $AE=BLOCK XAM
000000r 2               WOZ_IN    = USER_VARS         ; Input buffer
000000r 2               
000000r 2               WozMon:
000000r 2  A9 1B          lda     #$1B                ; Begin with escape
000002r 2               
000002r 2               WozNotCr:
000002r 2  C9 08          cmp     #$08                ; Backspace key?
000004r 2  F0 18          beq     WozBackspace        ; Yes
000006r 2  C9 1B          cmp     #$1B                ; ESC?
000008r 2  F0 03          beq     WozEscape           ; Yes
00000Ar 2  C8             iny                         ; Advance text index
00000Br 2  10 14          bpl     WozNextchar         ; Auto ESC if line longer than 127
00000Dr 2               
00000Dr 2               WozEscape:
00000Dr 2  A9 5C          lda     #$5C                ; "\"
00000Fr 2  20 rr rr       jsr     WozEcho             ; Output it
000012r 2               
000012r 2               WozGetline:
000012r 2  A9 0D          lda     #$0D                ; Send CR
000014r 2  20 rr rr       jsr     WozEcho
000017r 2  A9 0A          lda     #$0A                ; Send LF
000019r 2  20 rr rr       jsr     WozEcho
00001Cr 2               
00001Cr 2  A0 01          ldy     #$01                ; Initialize text index
00001Er 2               WozBackspace:
00001Er 2  88             dey                         ; Back up text index
00001Fr 2  30 F1          bmi     WozGetline          ; Beyond start of line, reinitialize
000021r 2               
000021r 2               WozNextchar:
000021r 2  20 rr rr       jsr     Chrin               ; Get next character
000024r 2  90 FB          bcc     WozNextchar         ; No character found
000026r 2  99 00 04       sta     WOZ_IN,y            ; Add to text buffer
000029r 2  C9 0D          cmp     #$0D                ; CR?
00002Br 2  D0 D5          bne     WozNotCr            ; No
00002Dr 2               
00002Dr 2  A0 FF          ldy     #$FF                ; Reset text index
00002Fr 2  A9 00          lda     #$00                ; For XAM mode
000031r 2  AA             tax                         ; X=0
000032r 2               WozSetblock:
000032r 2  0A             asl
000033r 2               WozSetstor:
000033r 2  0A             asl                         ; Leaves $7B if setting STOR mode
000034r 2  85 2B          sta     WOZ_MODE            ; $00 = XAM, $74 = STOR, $B8 = BLOK XAM
000036r 2               WozBlskip:
000036r 2  C8             iny                         ; Advance text index
000037r 2               WozNextitem:
000037r 2  B9 00 04       lda     WOZ_IN,y            ; Get character
00003Ar 2  C9 0D          cmp     #$0D                ; CR?
00003Cr 2  F0 D4          beq     WozGetline          ; Yes, done this line
00003Er 2  C9 2E          cmp     #$2E                ; "."?
000040r 2  90 F4          bcc     WozBlskip           ; Skip delimiter
000042r 2  F0 EE          beq     WozSetblock         ; Set BLOCK XAM mode
000044r 2  C9 3A          cmp     #$3A                ; ":"?
000046r 2  F0 EB          beq     WozSetstor          ; Yes, set STOR mode
000048r 2  C9 52          cmp     #$52                ; "R"?
00004Ar 2  F0 3B          beq     WozRun              ; Yes, run user program
00004Cr 2  86 28          stx     WOZ_L               ; $00 -> L
00004Er 2  86 29          stx     WOZ_H               ;    and H
000050r 2  84 2A          sty     WOZ_YSAV            ; Save Y for comparison
000052r 2               
000052r 2               WozNexthex:
000052r 2  B9 00 04       lda     WOZ_IN,y            ; Get character for hex test
000055r 2  49 30          eor     #$30                ; Map digits to $0-9
000057r 2  C9 0A          cmp     #$0A                ; Digit?
000059r 2  90 06          bcc     WozDig              ; Yes
00005Br 2  69 88          adc     #$88                ; Map letter "A"-"F" to $FA-FF
00005Dr 2  C9 FA          cmp     #$FA                ; Hex letter?
00005Fr 2  90 11          bcc     WozNothex           ; No, character not hex
000061r 2               WozDig:
000061r 2  0A             asl
000062r 2  0A             asl                         ; Hex digit to MSD of A
000063r 2  0A             asl
000064r 2  0A             asl
000065r 2               
000065r 2  A2 04          ldx     #$04                ; Shift count
000067r 2               WozHexshift:
000067r 2  0A             asl                         ; Hex digit left, MSB to carry
000068r 2  26 28          rol     WOZ_L               ; Rotate into LSD
00006Ar 2  26 29          rol     WOZ_H               ; Rotate into MSD's
00006Cr 2  CA             dex                         ; Done 4 shifts?
00006Dr 2  D0 F8          bne     WozHexshift         ; No, loop
00006Fr 2  C8             iny                         ; Advance text index
000070r 2  D0 E0          bne     WozNexthex          ; Always taken. Check next character for hex
000072r 2               
000072r 2               WozNothex:
000072r 2  C4 2A          cpy     WOZ_YSAV            ; Check if L, H empty (no hex digits)
000074r 2  F0 97          beq     WozEscape           ; Yes, generate ESC sequence
000076r 2               
000076r 2  24 2B          bit     WOZ_MODE            ; Test MODE byte
000078r 2  50 16          bvc     WozNotstor          ; B6=0 is STOR, 1 is XAM and BLOCK XAM
00007Ar 2               
00007Ar 2  A5 28          lda     WOZ_L               ; LSD's of hex data
00007Cr 2  81 26          sta     (WOZ_STL,x)         ; Store current 'store index'
00007Er 2  E6 26          inc     WOZ_STL             ; Increment store index
000080r 2  D0 B5          bne     WozNextitem         ; Get next item (no carry)
000082r 2  E6 27          inc     WOZ_STH             ; Add carry to 'store index' high order
000084r 2               WozTonextitem:
000084r 2  4C rr rr       jmp     WozNextitem         ; Get next command item
000087r 2               
000087r 2               WozRun:
000087r 2  20 rr rr       jsr     WozJump             ; Begin executing at XAM index
00008Ar 2  4C rr rr       jmp     WozMon              ; After returning we reset
00008Dr 2               WozJump:
00008Dr 2  6C 24 00       jmp     (WOZ_XAML)          ; Run at current XAM index
000090r 2               
000090r 2               WozNotstor:
000090r 2  30 30          bmi     WozXamnext          ; B7 = 0 for XAM, 1 for BLOCK XAM
000092r 2               
000092r 2  A2 02          ldx     #$02                ; Byte count
000094r 2               WozSetadr:
000094r 2  B5 27          lda     WOZ_L-1,x           ; Copy hex data to
000096r 2  95 25          sta     WOZ_STL-1,x         ;  'store index'
000098r 2  95 23          sta     WOZ_XAML-1,x        ; And to 'XAM index'
00009Ar 2  CA             dex                         ; Next of 2 bytes
00009Br 2  D0 F7          bne     WozSetadr           ; Loop unless X = 0
00009Dr 2               
00009Dr 2               WozNxtprnt:
00009Dr 2  D0 19          bne     WozPrdata           ; NE means no address to print
00009Fr 2  A9 0D          lda     #$0D                ; CR
0000A1r 2  20 rr rr       jsr     WozEcho             ; Output it
0000A4r 2  A9 0A          lda     #$0A                ; LF
0000A6r 2  20 rr rr       jsr     WozEcho             ; Output it
0000A9r 2  A5 25          lda     WOZ_XAMH            ; 'Examine index' high-order byte
0000ABr 2  20 rr rr       jsr     WozPrbyte           ; Output it in hex format
0000AEr 2  A5 24          lda     WOZ_XAML            ; Low-order 'examine index' byte
0000B0r 2  20 rr rr       jsr     WozPrbyte           ; Output it in hex format
0000B3r 2  A9 3A          lda     #$3A                ; ":"
0000B5r 2  20 rr rr       jsr     WozEcho             ; Output it
0000B8r 2               
0000B8r 2               WozPrdata:
0000B8r 2  A9 20          lda     #$20                ; Blank
0000BAr 2  20 rr rr       jsr     WozEcho             ; Output it
0000BDr 2  A1 24          lda     (WOZ_XAML,x)        ; Get data byte at 'examine index'
0000BFr 2  20 rr rr       jsr     WozPrbyte           ; Output it in hex format
0000C2r 2               WozXamnext:
0000C2r 2  86 2B          stx     WOZ_MODE            ; 0 -> MODE (XAM mode)
0000C4r 2  A5 24          lda     WOZ_XAML
0000C6r 2  C5 28          cmp     WOZ_L               ; Compare 'examine index' to hex data
0000C8r 2  A5 25          lda     WOZ_XAMH
0000CAr 2  E5 29          sbc     WOZ_H
0000CCr 2  B0 B6          bcs     WozTonextitem       ; Not less, so no more data to output
0000CEr 2               
0000CEr 2  E6 24          inc     WOZ_XAML
0000D0r 2  D0 02          bne     WozMod8chk          ; Increment 'examine index'
0000D2r 2  E6 25          inc     WOZ_XAMH
0000D4r 2               
0000D4r 2               WozMod8chk:
0000D4r 2  A5 24          lda     WOZ_XAML            ; Check low-order 'examine index' byte
0000D6r 2  29 07          and     #$07                ; For MOD 8 = 0
0000D8r 2  10 C3          bpl     WozNxtprnt          ; Always taken
0000DAr 2               
0000DAr 2               WozPrbyte:
0000DAr 2  48             pha                         ; Save A for LSD
0000DBr 2  4A             lsr
0000DCr 2  4A             lsr
0000DDr 2  4A             lsr                         ; MSD to LSD position
0000DEr 2  4A             lsr
0000DFr 2  20 rr rr       jsr     WozPrhex            ; Output hex digit
0000E2r 2  68             pla                         ; Restore A
0000E3r 2               
0000E3r 2               WozPrhex:
0000E3r 2  29 0F          and     #$0F                ; Mask LSD for hex print
0000E5r 2  09 30          ora     #$30                ; Add "0"
0000E7r 2  C9 3A          cmp     #$3A                ; Digit?
0000E9r 2  90 02          bcc     WozEcho             ; Yes, output it
0000EBr 2  69 06          adc     #$06                ; Add offset for letter
0000EDr 2               
0000EDr 2               WozEcho:
0000EDr 2  20 rr rr       jsr Chrout                  ; Output the character
0000F0r 2  60             rts                         ; Return
0000F1r 2               
0000F1r 1               .segment "VECTORS"
000000r 1               .include "Vectors.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   VECTORS   ***
000000r 2               ; ***             ***
000000r 2               
000000r 2  rr rr        .word   NmiVec           ; NMI vector
000002r 2  rr rr        .word   ResetVec         ; RESET vector
000004r 2  rr rr        .word   IrqVec           ; IRQ vector
000006r 2               
000006r 1               
