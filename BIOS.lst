001904r 2               ; ============================================================================
001904r 2               ; DATA Scanning Helpers
001904r 2               ; ============================================================================
001904r 2               
001904r 2               ; BasDataFindFirst — Find first DATA line from program start
001904r 2               ; Sets BAS_DATAPTR to first value in the first DATA statement
001904r 2               ; Errors ERR_OUT_OF_DATA if no DATA found.
001904r 2               
001904r 2               BasDataFindFirst:
001904r 2  A9 00          lda #<BAS_PRG_START
001906r 2  85 0E          sta BAS_TMP1
001908r 2  A9 08          lda #>BAS_PRG_START
00190Ar 2  85 0F          sta BAS_TMP1 + 1
00190Cr 2  20 rr rr       jsr BasDataScan
00190Fr 2  90 05          bcc @FindFirstOk
001911r 2  A9 0A          lda #ERR_OUT_OF_DATA
001913r 2  4C rr rr       jmp BasError
001916r 2               @FindFirstOk:
001916r 2  60             rts
001917r 2               
001917r 2               ; BasDataFindNext — Find next DATA line after current position
001917r 2               ; BAS_DATAPTR points into current DATA line; scans forward to null,
001917r 2               ; then searches subsequent lines for TOK_DATA.
001917r 2               ; Sets BAS_DATAPTR to first value in the next DATA statement.
001917r 2               ; Errors ERR_OUT_OF_DATA if no more DATA found.
001917r 2               
001917r 2               BasDataFindNext:
001917r 2  AD 1A 03       lda BAS_DATAPTR
00191Ar 2  85 0E          sta BAS_TMP1
00191Cr 2  AD 1B 03       lda BAS_DATAPTR + 1
00191Fr 2  85 0F          sta BAS_TMP1 + 1
001921r 2                 ; Scan to end of current line (null terminator)
001921r 2  A0 00          ldy #$00
001923r 2               @ScanToNull:
001923r 2  B1 0E          lda (BAS_TMP1),y
001925r 2  F0 07          beq @GotNull
001927r 2  C8             iny
001928r 2  D0 F9          bne @ScanToNull
00192Ar 2  E6 0F          inc BAS_TMP1 + 1
00192Cr 2  80 F5          bra @ScanToNull
00192Er 2               @GotNull:
00192Er 2                 ; Advance past null to start of next line
00192Er 2  C8             iny
00192Fr 2  98             tya
001930r 2  18             clc
001931r 2  65 0E          adc BAS_TMP1
001933r 2  85 0E          sta BAS_TMP1
001935r 2  A9 00          lda #$00
001937r 2  65 0F          adc BAS_TMP1 + 1
001939r 2  85 0F          sta BAS_TMP1 + 1
00193Br 2                 ; Fall through to scan
00193Br 2               
00193Br 2               ; BasDataScan — Scan program lines starting at BAS_TMP1 for TOK_DATA
00193Br 2               ; Sets BAS_DATAPTR to point past the DATA token (first value byte)
00193Br 2               ; Errors ERR_OUT_OF_DATA if no DATA found before end of program.
00193Br 2               
00193Br 2               BasDataScan:
00193Br 2               @ScanLoop:
00193Br 2                 ; At end of program?
00193Br 2  A5 0E          lda BAS_TMP1
00193Dr 2  C5 12          cmp BAS_PRGEND
00193Fr 2  D0 06          bne @ScanNotEnd
001941r 2  A5 0F          lda BAS_TMP1 + 1
001943r 2  C5 13          cmp BAS_PRGEND + 1
001945r 2  F0 2E          beq @ScanNotFound
001947r 2               @ScanNotEnd:
001947r 2                 ; Check first token of this line
001947r 2  A0 04          ldy #LINE_PAYLOAD
001949r 2  B1 0E          lda (BAS_TMP1),y
00194Br 2  C9 B3          cmp #TOK_DATA
00194Dr 2  F0 16          beq @ScanFound
00194Fr 2                 ; Skip to next line by scanning for null terminator
00194Fr 2               @ScanSkipLine:
00194Fr 2  B1 0E          lda (BAS_TMP1),y
001951r 2  F0 03          beq @ScanSkipDone
001953r 2  C8             iny
001954r 2  80 F9          bra @ScanSkipLine
001956r 2               @ScanSkipDone:
001956r 2  C8             iny                            ; Past null
001957r 2  98             tya
001958r 2  18             clc
001959r 2  65 0E          adc BAS_TMP1
00195Br 2  85 0E          sta BAS_TMP1
00195Dr 2  A9 00          lda #$00
00195Fr 2  65 0F          adc BAS_TMP1 + 1
001961r 2  85 0F          sta BAS_TMP1 + 1
001963r 2  80 D6          bra @ScanLoop
001965r 2               
001965r 2               @ScanFound:
001965r 2                 ; Point DATAPTR past the DATA token
001965r 2  18             clc
001966r 2  A5 0E          lda BAS_TMP1
001968r 2  69 05          adc #(LINE_PAYLOAD + 1)
00196Ar 2  8D 1A 03       sta BAS_DATAPTR
00196Dr 2  A5 0F          lda BAS_TMP1 + 1
00196Fr 2  69 00          adc #$00
001971r 2  8D 1B 03       sta BAS_DATAPTR + 1
001974r 2  60             rts
001975r 2               
001975r 2               @ScanNotFound:
001975r 2  38             sec                            ; Carry set = not found
001976r 2  60             rts
001977r 2               
001977r 2               ; ============================================================================
001977r 2               ; SQR(n) — Integer square root (16-bit unsigned)
001977r 2               ; ============================================================================
001977r 2               ; Input: BAS_ACC = n (signed; negative → ILLEGAL QTY error)
001977r 2               ; Output: BAS_ACC = floor(sqrt(n))
001977r 2               ; Algorithm: Newton's method — guess = n/2, iterate guess = (guess + n/guess)/2
001977r 2               ; Uses BAS_AUX as "n" copy, BAS_NUMTMP to save current guess across division
001977r 2               
001977r 2               BasFuncSqr:
001977r 2                 ; Negative → error
001977r 2  A5 0B          lda BAS_ACC + 1
001979r 2  30 66          bmi @SqrErr
00197Br 2                 ; n = 0 or 1 → result is n
00197Br 2  A5 0B          lda BAS_ACC + 1
00197Dr 2  D0 06          bne @SqrBig
00197Fr 2  A5 0A          lda BAS_ACC
001981r 2  C9 02          cmp #2
001983r 2  90 59          bcc @SqrDone                   ; 0 or 1 → return as-is
001985r 2               @SqrBig:
001985r 2                 ; Copy n to AUX
001985r 2  A5 0A          lda BAS_ACC
001987r 2  85 0C          sta BAS_AUX
001989r 2  A5 0B          lda BAS_ACC + 1
00198Br 2  85 0D          sta BAS_AUX + 1
00198Dr 2                 ; Initial guess = n / 2 (unsigned shift right)
00198Dr 2  46 0B          lsr BAS_ACC + 1
00198Fr 2  66 0A          ror BAS_ACC
001991r 2                 ; If guess becomes 0 (n was 1, already handled), set to 1
001991r 2  A5 0A          lda BAS_ACC
001993r 2  05 0B          ora BAS_ACC + 1
001995r 2  D0 04          bne @SqrLoop
001997r 2  A9 01          lda #$01
001999r 2  85 0A          sta BAS_ACC
00199Br 2               @SqrLoop:
00199Br 2                 ; Save current guess in NUMTMP (survives BasMathDiv)
00199Br 2  A5 0A          lda BAS_ACC
00199Dr 2  85 22          sta BAS_NUMTMP
00199Fr 2  A5 0B          lda BAS_ACC + 1
0019A1r 2  85 23          sta BAS_NUMTMP + 1
0019A3r 2                 ; Compute n / guess: AUX / ACC → ACC
0019A3r 2                 ; BasMathDiv clobbers AUX — save n on stack
0019A3r 2  A5 0C          lda BAS_AUX
0019A5r 2  48             pha
0019A6r 2  A5 0D          lda BAS_AUX + 1
0019A8r 2  48             pha
0019A9r 2  20 rr rr       jsr BasMathDiv                 ; ACC = AUX / ACC
0019ACr 2                 ; new_guess = (guess + n/guess) / 2
0019ACr 2  18             clc
0019ADr 2  A5 0A          lda BAS_ACC
0019AFr 2  65 22          adc BAS_NUMTMP
0019B1r 2  85 0A          sta BAS_ACC
0019B3r 2  A5 0B          lda BAS_ACC + 1
0019B5r 2  65 23          adc BAS_NUMTMP + 1
0019B7r 2  85 0B          sta BAS_ACC + 1
0019B9r 2                 ; Unsigned divide by 2
0019B9r 2  46 0B          lsr BAS_ACC + 1
0019BBr 2  66 0A          ror BAS_ACC
0019BDr 2                 ; Restore n to AUX
0019BDr 2  68             pla
0019BEr 2  85 0D          sta BAS_AUX + 1
0019C0r 2  68             pla
0019C1r 2  85 0C          sta BAS_AUX
0019C3r 2                 ; Converged? Compare new_guess with old guess (NUMTMP)
0019C3r 2  A5 0A          lda BAS_ACC
0019C5r 2  C5 22          cmp BAS_NUMTMP
0019C7r 2  D0 06          bne @SqrNotSame
0019C9r 2  A5 0B          lda BAS_ACC + 1
0019CBr 2  C5 23          cmp BAS_NUMTMP + 1
0019CDr 2  F0 0F          beq @SqrDone                   ; Converged
0019CFr 2               @SqrNotSame:
0019CFr 2                 ; Check if new_guess = old_guess - 1 (oscillation)
0019CFr 2  38             sec
0019D0r 2  A5 22          lda BAS_NUMTMP
0019D2r 2  E5 0A          sbc BAS_ACC
0019D4r 2  C9 01          cmp #$01
0019D6r 2  D0 C3          bne @SqrLoop
0019D8r 2  A5 23          lda BAS_NUMTMP + 1
0019DAr 2  E5 0B          sbc BAS_ACC + 1
0019DCr 2  D0 BD          bne @SqrLoop
0019DEr 2                 ; Oscillating between guess and guess-1; take the smaller (ACC)
0019DEr 2               @SqrDone:
0019DEr 2  64 0B          stz BAS_ACC + 1                ; Result fits in low byte for values ≤255
0019E0r 2  60             rts                            ; For larger roots, high byte already correct from loop
0019E1r 2               
0019E1r 2               @SqrErr:
0019E1r 2  A9 08          lda #ERR_ILLEGAL_QTY
0019E3r 2  4C rr rr       jmp BasError
0019E6r 2               
0019E6r 2               ; ============================================================================
0019E6r 2               ; POW(b,e) — Integer exponentiation
0019E6r 2               ; ============================================================================
0019E6r 2               ; Input: BAS_ACC = base, BAS_AUX = exponent
0019E6r 2               ; Output: BAS_ACC = base^exponent
0019E6r 2               ; Negative exponent → return 0 (integer truncation)
0019E6r 2               ; Uses BAS_SCRATCH2 for base (safe across BasMathMul),
0019E6r 2               ;      BAS_NUMTMP for exponent counter (safe across BasMathMul)
0019E6r 2               
0019E6r 2               BasFuncPow:
0019E6r 2                 ; If exponent is negative → result is 0
0019E6r 2  A5 0D          lda BAS_AUX + 1
0019E8r 2  30 41          bmi @PowZero
0019EAr 2                 ; If exponent = 0 → return 1
0019EAr 2  A5 0C          lda BAS_AUX
0019ECr 2  05 0D          ora BAS_AUX + 1
0019EEr 2  D0 07          bne @PowStart
0019F0r 2  A9 01          lda #$01
0019F2r 2  85 0A          sta BAS_ACC
0019F4r 2  64 0B          stz BAS_ACC + 1
0019F6r 2  60             rts
0019F7r 2               @PowStart:
0019F7r 2                 ; Save base in SCRATCH2 (survives BasMathMul which only uses SCRATCH)
0019F7r 2  A5 0A          lda BAS_ACC
0019F9r 2  85 1E          sta BAS_SCRATCH2
0019FBr 2  A5 0B          lda BAS_ACC + 1
0019FDr 2  85 1F          sta BAS_SCRATCH2 + 1
0019FFr 2                 ; Save exponent counter in NUMTMP (survives BasMathMul)
0019FFr 2  A5 0C          lda BAS_AUX
001A01r 2  85 22          sta BAS_NUMTMP
001A03r 2  A5 0D          lda BAS_AUX + 1
001A05r 2  85 23          sta BAS_NUMTMP + 1
001A07r 2                 ; Decrement counter: ACC already holds base^1
001A07r 2  A5 22          lda BAS_NUMTMP
001A09r 2  D0 02          bne :+
001A0Br 2  C6 23          dec BAS_NUMTMP + 1
001A0Dr 2  C6 22        : dec BAS_NUMTMP
001A0Fr 2               @PowMulLoop:
001A0Fr 2                 ; Counter = 0? done
001A0Fr 2  A5 22          lda BAS_NUMTMP
001A11r 2  05 23          ora BAS_NUMTMP + 1
001A13r 2  F0 15          beq @PowDone
001A15r 2                 ; Set AUX = base for multiplication
001A15r 2  A5 1E          lda BAS_SCRATCH2
001A17r 2  85 0C          sta BAS_AUX
001A19r 2  A5 1F          lda BAS_SCRATCH2 + 1
001A1Br 2  85 0D          sta BAS_AUX + 1
001A1Dr 2  20 rr rr       jsr BasMathMul                 ; ACC = ACC * base
001A20r 2                 ; Decrement counter
001A20r 2  A5 22          lda BAS_NUMTMP
001A22r 2  D0 02          bne :+
001A24r 2  C6 23          dec BAS_NUMTMP + 1
001A26r 2  C6 22        : dec BAS_NUMTMP
001A28r 2  80 E5          bra @PowMulLoop
001A2Ar 2               @PowDone:
001A2Ar 2  60             rts
001A2Br 2               @PowZero:
001A2Br 2  64 0A          stz BAS_ACC
001A2Dr 2  64 0B          stz BAS_ACC + 1
001A2Fr 2  60             rts
001A30r 2               
001A30r 2               ; ============================================================================
001A30r 2               ; SETTIME hh, mm, ss — Set RTC time
001A30r 2               ; ============================================================================
001A30r 2               
001A30r 2               BasCmdSettime:
001A30r 2  AD 0D 03       lda HW_PRESENT
001A33r 2  29 04          and #HW_RTC
001A35r 2  D0 03          bne @SettimeStart
001A37r 2  4C rr rr       jmp BasPrintNoDevice
001A3Ar 2               @SettimeStart:
001A3Ar 2  20 rr rr       jsr BasExpr                    ; hh -> BAS_ACC
001A3Dr 2  A5 0A          lda BAS_ACC
001A3Fr 2  48             pha                            ; save hours
001A40r 2  20 rr rr       jsr BasSkipSpaces
001A43r 2  A9 2C          lda #CH_COMMA
001A45r 2  20 rr rr       jsr BasExpectChar
001A48r 2  20 rr rr       jsr BasExpr                    ; mm -> BAS_ACC
001A4Br 2  A5 0A          lda BAS_ACC
001A4Dr 2  48             pha                            ; save minutes
001A4Er 2  20 rr rr       jsr BasSkipSpaces
001A51r 2  A9 2C          lda #CH_COMMA
001A53r 2  20 rr rr       jsr BasExpectChar
001A56r 2  20 rr rr       jsr BasExpr                    ; ss -> BAS_ACC
001A59r 2                 ; Stack: top=minutes, bottom=hours. BAS_ACC has seconds.
001A59r 2                 ; RtcWriteTime wants: A=hours, X=minutes, Y=seconds
001A59r 2  A4 0A          ldy BAS_ACC                   ; Y = seconds
001A5Br 2  FA             plx                            ; X = minutes (was pushed last)
001A5Cr 2  68             pla                            ; A = hours (was pushed first)
001A5Dr 2  20 rr rr       jsr RtcWriteTime
001A60r 2  60             rts
001A61r 2               
001A61r 2               ; ============================================================================
001A61r 2               ; SETDATE cc, yy, mm, dd — Set RTC date
001A61r 2               ; ============================================================================
001A61r 2               
001A61r 2               BasCmdSetdate:
001A61r 2  AD 0D 03       lda HW_PRESENT
001A64r 2  29 04          and #HW_RTC
001A66r 2  D0 03          bne @SetdateStart
001A68r 2  4C rr rr       jmp BasPrintNoDevice
001A6Br 2               @SetdateStart:
001A6Br 2  20 rr rr       jsr BasExpr                    ; cc -> BAS_ACC
001A6Er 2  A5 0A          lda BAS_ACC
001A70r 2  8D 0B 03       sta RTC_BUF_CENT               ; Store century for RtcWriteDate
001A73r 2  20 rr rr       jsr BasSkipSpaces
001A76r 2  A9 2C          lda #CH_COMMA
001A78r 2  20 rr rr       jsr BasExpectChar
001A7Br 2  20 rr rr       jsr BasExpr                    ; yy -> BAS_ACC
001A7Er 2  A5 0A          lda BAS_ACC
001A80r 2  48             pha                            ; push year (1st on stack)
001A81r 2  20 rr rr       jsr BasSkipSpaces
001A84r 2  A9 2C          lda #CH_COMMA
001A86r 2  20 rr rr       jsr BasExpectChar
001A89r 2  20 rr rr       jsr BasExpr                    ; mm -> BAS_ACC
001A8Cr 2  A5 0A          lda BAS_ACC
001A8Er 2  48             pha                            ; push month (2nd on stack)
001A8Fr 2  20 rr rr       jsr BasSkipSpaces
001A92r 2  A9 2C          lda #CH_COMMA
001A94r 2  20 rr rr       jsr BasExpectChar
001A97r 2  20 rr rr       jsr BasExpr                    ; dd -> BAS_ACC
001A9Ar 2                 ; Stack: top=month, bottom=year. BAS_ACC has day.
001A9Ar 2                 ; RtcWriteDate wants: A=day, X=month, Y=year
001A9Ar 2  A5 0A          lda BAS_ACC                   ; A = day
001A9Cr 2  FA             plx                            ; X = month (was pushed last)
001A9Dr 2  7A             ply                            ; Y = year (was pushed first)
001A9Er 2  20 rr rr       jsr RtcWriteDate
001AA1r 2  60             rts
001AA2r 2               
001AA2r 2               ; ============================================================================
001AA2r 2               ; NVRAM addr, value — Write byte to RTC NVRAM
001AA2r 2               ; ============================================================================
001AA2r 2               
001AA2r 2               BasCmdNvramW:
001AA2r 2  AD 0D 03       lda HW_PRESENT
001AA5r 2  29 04          and #HW_RTC
001AA7r 2  D0 03          bne @NvramWStart
001AA9r 2  4C rr rr       jmp BasPrintNoDevice
001AACr 2               @NvramWStart:
001AACr 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
001AAFr 2  A5 0A          lda BAS_ACC
001AB1r 2  85 21          sta BAS_TEMP                   ; save address
001AB3r 2  20 rr rr       jsr BasSkipSpaces
001AB6r 2  A9 2C          lda #CH_COMMA
001AB8r 2  20 rr rr       jsr BasExpectChar
001ABBr 2  20 rr rr       jsr BasExpr                    ; value -> BAS_ACC
001ABEr 2  A6 21          ldx BAS_TEMP                   ; X = address
001AC0r 2  A5 0A          lda BAS_ACC                    ; A = value
001AC2r 2  20 rr rr       jsr RtcWriteNVRAM
001AC5r 2  60             rts
001AC6r 2               
001AC6r 2               ; ============================================================================
001AC6r 2               ; MEM — Print system info
001AC6r 2               ; ============================================================================
001AC6r 2               
001AC6r 2               BasCmdMem:
001AC6r 2                 ; Print free bytes
001AC6r 2  20 rr rr       jsr BasPrintFree
001AC9r 2                 ; Print HW: $xx
001AC9r 2  A9 rr          lda #<BasStrMemHW
001ACBr 2  85 0E          sta BAS_TMP1
001ACDr 2  A9 rr          lda #>BasStrMemHW
001ACFr 2  85 0F          sta BAS_TMP1 + 1
001AD1r 2  20 rr rr       jsr BasPrintStr                ; CR+LF+"HW: $"
001AD4r 2  AD 0D 03       lda HW_PRESENT
001AD7r 2  20 rr rr       jsr BasMemHexByte
001ADAr 2                 ; Print IO mode
001ADAr 2  A9 rr          lda #<BasStrMemIO
001ADCr 2  85 0E          sta BAS_TMP1
001ADEr 2  A9 rr          lda #>BasStrMemIO
001AE0r 2  85 0F          sta BAS_TMP1 + 1
001AE2r 2  20 rr rr       jsr BasPrintStr                ; CR+LF+"IO: "
001AE5r 2  AD 06 03       lda IO_MODE
001AE8r 2  29 01          and #$01
001AEAr 2  D0 11          bne @MemSerial
001AECr 2  A9 56          lda #'V'
001AEEr 2  20 rr rr       jsr Chrout
001AF1r 2  A9 49          lda #'I'
001AF3r 2  20 rr rr       jsr Chrout
001AF6r 2  A9 44          lda #'D'
001AF8r 2  20 rr rr       jsr Chrout
001AFBr 2  80 0F          bra @MemIODone
001AFDr 2               @MemSerial:
001AFDr 2  A9 53          lda #'S'
001AFFr 2  20 rr rr       jsr Chrout
001B02r 2  A9 45          lda #'E'
001B04r 2  20 rr rr       jsr Chrout
001B07r 2  A9 52          lda #'R'
001B09r 2  20 rr rr       jsr Chrout
001B0Cr 2               @MemIODone:
001B0Cr 2  20 rr rr       jsr BasPrintCRLF
001B0Fr 2  60             rts
001B10r 2               
001B10r 2               ; BasMemHexByte — print A as 2 hex digits
001B10r 2               BasMemHexByte:
001B10r 2  48             pha
001B11r 2  4A             lsr
001B12r 2  4A             lsr
001B13r 2  4A             lsr
001B14r 2  4A             lsr
001B15r 2  20 rr rr       jsr @MemNibble
001B18r 2  68             pla
001B19r 2  29 0F          and #$0F
001B1Br 2               @MemNibble:
001B1Br 2  C9 0A          cmp #$0A
001B1Dr 2  90 04          bcc @MemDigit
001B1Fr 2  69 36          adc #('A' - $0A - 1)
001B21r 2  80 02          bra @MemPrint
001B23r 2               @MemDigit:
001B23r 2  09 30          ora #'0'
001B25r 2               @MemPrint:
001B25r 2  4C rr rr       jmp Chrout
001B28r 2               
001B28r 2               ; ============================================================================
001B28r 2               ; DIM var(size) [, var(size) ...] — Dimension arrays
001B28r 2               ; ============================================================================
001B28r 2               
001B28r 2               BasCmdDim:
001B28r 2               @DimNext:
001B28r 2  20 rr rr       jsr BasSkipSpaces
001B2Br 2  20 rr rr       jsr BasGetTokChar
001B2Er 2               
001B2Er 2                 ; Must be a variable A-Z
001B2Er 2  C9 41          cmp #'A'
001B30r 2  B0 03          bcs @DimNotLow
001B32r 2  4C rr rr       jmp @DimErr
001B35r 2               @DimNotLow:
001B35r 2  C9 5B          cmp #'Z' + 1
001B37r 2  90 03          bcc @DimNotHigh
001B39r 2  4C rr rr       jmp @DimErr
001B3Cr 2               @DimNotHigh:
001B3Cr 2               
001B3Cr 2  38             sec
001B3Dr 2  E9 41          sbc #'A'
001B3Fr 2  0A             asl                            ; ×2 for descriptor table index
001B40r 2  85 21          sta BAS_TEMP                   ; Save var offset
001B42r 2               
001B42r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
001B45r 2               
001B45r 2                 ; Expect '('
001B45r 2  A9 28          lda #CH_LPAREN
001B47r 2  20 rr rr       jsr BasExpectChar
001B4Ar 2               
001B4Ar 2  20 rr rr       jsr BasExpr                    ; size -> BAS_ACC (max valid index)
001B4Dr 2               
001B4Dr 2                 ; Expect ')'
001B4Dr 2  A9 29          lda #CH_RPAREN
001B4Fr 2  20 rr rr       jsr BasExpectChar
001B52r 2               
001B52r 2                 ; Check if already dimensioned
001B52r 2  A6 21          ldx BAS_TEMP
001B54r 2  BD 5B 03       lda BAS_ARYDESC,x
001B57r 2  1D 5C 03       ora BAS_ARYDESC + 1,x
001B5Ar 2  F0 03          beq @DimNotRedim
001B5Cr 2  4C rr rr       jmp @DimRedim
001B5Fr 2               @DimNotRedim:
001B5Fr 2               
001B5Fr 2                 ; BAS_ACC = max index (0-based), elements = ACC + 1
001B5Fr 2                 ; Total bytes = 2 (dim size) + (ACC + 1) * 2
001B5Fr 2                 ; Check non-negative
001B5Fr 2  A5 0B          lda BAS_ACC + 1
001B61r 2  10 03          bpl @DimNotNeg
001B63r 2  4C rr rr       jmp @DimIllegal
001B66r 2               @DimNotNeg:
001B66r 2               
001B66r 2                 ; Compute total size: (ACC + 1) * 2 + 2
001B66r 2  18             clc
001B67r 2  A5 0A          lda BAS_ACC
001B69r 2  69 01          adc #$01
001B6Br 2  85 0C          sta BAS_AUX
001B6Dr 2  A5 0B          lda BAS_ACC + 1
001B6Fr 2  69 00          adc #$00
001B71r 2  85 0D          sta BAS_AUX + 1                ; AUX = element count
001B73r 2  06 0C          asl BAS_AUX
001B75r 2  26 0D          rol BAS_AUX + 1                ; AUX = element count * 2
001B77r 2  18             clc
001B78r 2  A5 0C          lda BAS_AUX
001B7Ar 2  69 02          adc #$02                       ; + 2 for dim size header
001B7Cr 2  85 0C          sta BAS_AUX
001B7Er 2  A5 0D          lda BAS_AUX + 1
001B80r 2  69 00          adc #$00
001B82r 2  85 0D          sta BAS_AUX + 1                ; AUX = total bytes needed
001B84r 2               
001B84r 2                 ; New array top = BAS_ARYTOP - total_bytes
001B84r 2  38             sec
001B85r 2  AD 8F 03       lda BAS_ARYTOP
001B88r 2  E5 0C          sbc BAS_AUX
001B8Ar 2  85 10          sta BAS_TMP2
001B8Cr 2  AD 90 03       lda BAS_ARYTOP + 1
001B8Fr 2  E5 0D          sbc BAS_AUX + 1
001B91r 2  85 11          sta BAS_TMP2 + 1               ; TMP2 = proposed new ARYTOP
001B93r 2               
001B93r 2                 ; Check for collision with program: new top must be > PRGEND
001B93r 2  A5 11          lda BAS_TMP2 + 1
001B95r 2  C5 13          cmp BAS_PRGEND + 1
001B97r 2  90 78          bcc @DimOOM
001B99r 2  D0 08          bne @DimOK
001B9Br 2  A5 10          lda BAS_TMP2
001B9Dr 2  C5 12          cmp BAS_PRGEND
001B9Fr 2  90 70          bcc @DimOOM
001BA1r 2  F0 6E          beq @DimOOM
001BA3r 2               @DimOK:
001BA3r 2                 ; Commit: update ARYTOP
001BA3r 2  A5 10          lda BAS_TMP2
001BA5r 2  8D 8F 03       sta BAS_ARYTOP
001BA8r 2  A5 11          lda BAS_TMP2 + 1
001BAAr 2  8D 90 03       sta BAS_ARYTOP + 1
001BADr 2               
001BADr 2                 ; Store base pointer in descriptor table
001BADr 2  A6 21          ldx BAS_TEMP
001BAFr 2  A5 10          lda BAS_TMP2
001BB1r 2  9D 5B 03       sta BAS_ARYDESC,x
001BB4r 2  A5 11          lda BAS_TMP2 + 1
001BB6r 2  9D 5C 03       sta BAS_ARYDESC + 1,x
001BB9r 2               
001BB9r 2                 ; Write max index at base pointer
001BB9r 2  A0 00          ldy #$00
001BBBr 2  A5 0A          lda BAS_ACC
001BBDr 2  91 10          sta (BAS_TMP2),y
001BBFr 2  C8             iny
001BC0r 2  A5 0B          lda BAS_ACC + 1
001BC2r 2  91 10          sta (BAS_TMP2),y
001BC4r 2               
001BC4r 2                 ; Zero-fill element data (starts at base + 2, length = element_count * 2)
001BC4r 2  18             clc
001BC5r 2  A5 10          lda BAS_TMP2
001BC7r 2  69 02          adc #$02
001BC9r 2  85 10          sta BAS_TMP2
001BCBr 2  A5 11          lda BAS_TMP2 + 1
001BCDr 2  69 00          adc #$00
001BCFr 2  85 11          sta BAS_TMP2 + 1
001BD1r 2               
001BD1r 2                 ; AUX still holds total_bytes; element data = AUX - 2
001BD1r 2  38             sec
001BD2r 2  A5 0C          lda BAS_AUX
001BD4r 2  E9 02          sbc #$02
001BD6r 2  85 0C          sta BAS_AUX
001BD8r 2  A5 0D          lda BAS_AUX + 1
001BDAr 2  E9 00          sbc #$00
001BDCr 2  85 0D          sta BAS_AUX + 1
001BDEr 2               
001BDEr 2  A9 00          lda #$00
001BE0r 2  A0 00          ldy #$00
001BE2r 2               @DimZeroLoop:
001BE2r 2  A5 0C          lda BAS_AUX
001BE4r 2  05 0D          ora BAS_AUX + 1
001BE6r 2  F0 13          beq @DimZeroDone
001BE8r 2  A9 00          lda #$00
001BEAr 2  91 10          sta (BAS_TMP2),y
001BECr 2  C8             iny
001BEDr 2  D0 02          bne @DimNoPage
001BEFr 2  E6 11          inc BAS_TMP2 + 1
001BF1r 2               @DimNoPage:
001BF1r 2                 ; Decrement AUX
001BF1r 2  A5 0C          lda BAS_AUX
001BF3r 2  D0 02          bne :+
001BF5r 2  C6 0D          dec BAS_AUX + 1
001BF7r 2  C6 0C        : dec BAS_AUX
001BF9r 2  80 E7          bra @DimZeroLoop
001BFBr 2               @DimZeroDone:
001BFBr 2               
001BFBr 2                 ; Check for comma (multiple DIM declarations)
001BFBr 2  20 rr rr       jsr BasSkipSpaces
001BFEr 2  20 rr rr       jsr BasGetTokChar
001C01r 2  C9 2C          cmp #CH_COMMA
001C03r 2  D0 06          bne @DimDone
001C05r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
001C08r 2  4C rr rr       jmp @DimNext
001C0Br 2               @DimDone:
001C0Br 2  60             rts
001C0Cr 2               
001C0Cr 2               @DimRedim:
001C0Cr 2  A9 0C          lda #ERR_REDIM
001C0Er 2  4C rr rr       jmp BasError
001C11r 2               @DimOOM:
001C11r 2  A9 03          lda #ERR_OUT_OF_MEM
001C13r 2  4C rr rr       jmp BasError
001C16r 2               @DimIllegal:
001C16r 2  A9 08          lda #ERR_ILLEGAL_QTY
001C18r 2  4C rr rr       jmp BasError
001C1Br 2               @DimErr:
001C1Br 2  A9 00          lda #ERR_SYNTAX
001C1Dr 2  4C rr rr       jmp BasError
001C20r 2               
001C20r 2               ; ============================================================================
001C20r 2               ; BasArrayRead — Read array element: X = var_offset (already ×2)
001C20r 2               ; ============================================================================
001C20r 2               ; Called from BasExprPrimary when A(expr) is found
001C20r 2               ; TXTPTR points at '('
001C20r 2               
001C20r 2               BasArrayRead:
001C20r 2  86 21          stx BAS_TEMP                   ; Save var offset
001C22r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
001C25r 2  20 rr rr       jsr BasExpr                    ; index -> BAS_ACC
001C28r 2  A9 29          lda #CH_RPAREN
001C2Ar 2  20 rr rr       jsr BasExpectChar              ; Expect ')'
001C2Dr 2               
001C2Dr 2                 ; Resolve element address into BAS_TMP2
001C2Dr 2  A5 0A          lda BAS_ACC
001C2Fr 2  85 0C          sta BAS_AUX
001C31r 2  A5 0B          lda BAS_ACC + 1
001C33r 2  85 0D          sta BAS_AUX + 1                ; AUX = index
001C35r 2  20 rr rr       jsr BasArrayAddr               ; BAS_TMP2 = element address
001C38r 2               
001C38r 2                 ; Read element
001C38r 2  A0 00          ldy #$00
001C3Ar 2  B1 10          lda (BAS_TMP2),y
001C3Cr 2  85 0A          sta BAS_ACC
001C3Er 2  C8             iny
001C3Fr 2  B1 10          lda (BAS_TMP2),y
001C41r 2  85 0B          sta BAS_ACC + 1
001C43r 2  60             rts
001C44r 2               
001C44r 2               ; ============================================================================
001C44r 2               ; BasArrayWrite — Write array element: X = var_offset (already ×2)
001C44r 2               ; ============================================================================
001C44r 2               ; Called from BasCmdLet when A(expr) = expr is found
001C44r 2               ; TXTPTR points at '('
001C44r 2               
001C44r 2               BasArrayWrite:
001C44r 2  86 21          stx BAS_TEMP                   ; Save var offset
001C46r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
001C49r 2  20 rr rr       jsr BasExpr                    ; index -> BAS_ACC
001C4Cr 2  A9 29          lda #CH_RPAREN
001C4Er 2  20 rr rr       jsr BasExpectChar              ; Expect ')'
001C51r 2               
001C51r 2                 ; Save index on stack
001C51r 2  A5 0A          lda BAS_ACC
001C53r 2  48             pha
001C54r 2  A5 0B          lda BAS_ACC + 1
001C56r 2  48             pha
001C57r 2               
001C57r 2  20 rr rr       jsr BasSkipSpaces
001C5Ar 2  A9 3D          lda #CH_EQUALS
001C5Cr 2  20 rr rr       jsr BasExpectChar              ; Expect '='
001C5Fr 2               
001C5Fr 2  20 rr rr       jsr BasExpr                    ; value -> BAS_ACC
001C62r 2               
001C62r 2                 ; Pop index into AUX
001C62r 2  68             pla
001C63r 2  85 0D          sta BAS_AUX + 1
001C65r 2  68             pla
001C66r 2  85 0C          sta BAS_AUX                    ; AUX = index
001C68r 2               
001C68r 2                 ; Resolve element address into BAS_TMP2
001C68r 2  20 rr rr       jsr BasArrayAddr               ; BAS_TMP2 = element address
001C6Br 2               
001C6Br 2                 ; Write element
001C6Br 2  A0 00          ldy #$00
001C6Dr 2  A5 0A          lda BAS_ACC
001C6Fr 2  91 10          sta (BAS_TMP2),y
001C71r 2  C8             iny
001C72r 2  A5 0B          lda BAS_ACC + 1
001C74r 2  91 10          sta (BAS_TMP2),y
001C76r 2  60             rts
001C77r 2               
001C77r 2               ; ============================================================================
001C77r 2               ; BasArrayAddr — Compute array element address
001C77r 2               ; ============================================================================
001C77r 2               ; Input: BAS_TEMP = var_offset (×2), BAS_AUX = index
001C77r 2               ; Output: BAS_TMP2 = element address
001C77r 2               ; Errors: ERR_SYNTAX if not dimensioned, ERR_BAD_SUBSCRIPT if out of range
001C77r 2               
001C77r 2               BasArrayAddr:
001C77r 2                 ; Look up array base pointer
001C77r 2  A6 21          ldx BAS_TEMP
001C79r 2  BD 5B 03       lda BAS_ARYDESC,x
001C7Cr 2  85 10          sta BAS_TMP2
001C7Er 2  BD 5C 03       lda BAS_ARYDESC + 1,x
001C81r 2  85 11          sta BAS_TMP2 + 1
001C83r 2               
001C83r 2                 ; Check if dimensioned
001C83r 2  05 10          ora BAS_TMP2
001C85r 2  F0 38          beq @AANotDim
001C87r 2               
001C87r 2                 ; Bounds check: AUX must be 0..max_index
001C87r 2  A5 0D          lda BAS_AUX + 1
001C89r 2  30 39          bmi @AABadSub                 ; Negative index
001C8Br 2  A0 00          ldy #$00
001C8Dr 2  B1 10          lda (BAS_TMP2),y               ; max_index lo
001C8Fr 2  85 1C          sta BAS_SCRATCH
001C91r 2  C8             iny
001C92r 2  B1 10          lda (BAS_TMP2),y               ; max_index hi
001C94r 2  C5 0D          cmp BAS_AUX + 1
001C96r 2  90 2C          bcc @AABadSub
001C98r 2  D0 06          bne @AAInBounds
001C9Ar 2  A5 1C          lda BAS_SCRATCH
001C9Cr 2  C5 0C          cmp BAS_AUX
001C9Er 2  90 24          bcc @AABadSub
001CA0r 2               @AAInBounds:
001CA0r 2                 ; Address = base + 2 + AUX * 2
001CA0r 2  06 0C          asl BAS_AUX
001CA2r 2  26 0D          rol BAS_AUX + 1               ; AUX = index * 2
001CA4r 2  18             clc
001CA5r 2  A5 10          lda BAS_TMP2
001CA7r 2  69 02          adc #$02
001CA9r 2  85 10          sta BAS_TMP2
001CABr 2  A5 11          lda BAS_TMP2 + 1
001CADr 2  69 00          adc #$00
001CAFr 2  85 11          sta BAS_TMP2 + 1               ; base + 2
001CB1r 2  18             clc
001CB2r 2  A5 10          lda BAS_TMP2
001CB4r 2  65 0C          adc BAS_AUX
001CB6r 2  85 10          sta BAS_TMP2
001CB8r 2  A5 11          lda BAS_TMP2 + 1
001CBAr 2  65 0D          adc BAS_AUX + 1
001CBCr 2  85 11          sta BAS_TMP2 + 1               ; final address
001CBEr 2  60             rts
001CBFr 2               
001CBFr 2               @AANotDim:
001CBFr 2  A9 00          lda #ERR_SYNTAX
001CC1r 2  4C rr rr       jmp BasError
001CC4r 2               @AABadSub:
001CC4r 2  A9 0D          lda #ERR_BAD_SUBSCRIPT
001CC6r 2  4C rr rr       jmp BasError
001CC9r 2               
001CC9r 2               ; ============================================================================
001CC9r 2               ; Keyword Table
001CC9r 2               ; ============================================================================
001CC9r 2               ; Format: null-terminated keyword string, then token byte.
001CC9r 2               ; Longer keywords first to prevent partial matches (e.g. GOSUB before GOTO).
001CC9r 2               ; Table terminated by a lone $00.
001CC9r 2               
001CC9r 2               BasKeywordTable:
001CC9r 2  53 45 54 54    .byte "SETTIME", $00, TOK_SETTIME
001CCDr 2  49 4D 45 00  
001CD1r 2  BF           
001CD2r 2  53 45 54 44    .byte "SETDATE", $00, TOK_SETDATE
001CD6r 2  41 54 45 00  
001CDAr 2  C0           
001CDBr 2  52 45 53 54    .byte "RESTORE", $00, TOK_RESTORE
001CDFr 2  4F 52 45 00  
001CE3r 2  B5           
001CE4r 2  52 45 54 55    .byte "RETURN", $00, TOK_RETURN
001CE8r 2  52 4E 00 85  
001CECr 2  4C 4F 43 41    .byte "LOCATE", $00, TOK_LOCATE
001CF0r 2  54 45 00 A4  
001CF4r 2  4E 56 52 41    .byte "NVRAM",  $00, TOK_NVRAM
001CF8r 2  4D 00 C1     
001CFBr 2  49 4E 4B 45    .byte "INKEY",  $00, TOK_INKEY
001CFFr 2  59 00 BA     
001D02r 2  50 52 49 4E    .byte "PRINT",  $00, TOK_PRINT
001D06r 2  54 00 80     
001D09r 2  49 4E 50 55    .byte "INPUT",  $00, TOK_INPUT
001D0Dr 2  54 00 81     
001D10r 2  47 4F 53 55    .byte "GOSUB",  $00, TOK_GOSUB
001D14r 2  42 00 84     
001D17r 2  53 4F 55 4E    .byte "SOUND",  $00, TOK_SOUND
001D1Br 2  44 00 A7     
001D1Er 2  50 41 55 53    .byte "PAUSE",  $00, TOK_PAUSE
001D22r 2  45 00 AC     
001D25r 2  43 4F 4C 4F    .byte "COLOR",  $00, TOK_COLOR
001D29r 2  52 00 A5     
001D2Cr 2  46 52 45 45    .byte "FREE",   $00, TOK_FREE
001D30r 2  00 BE        
001D32r 2  53 54 4F 50    .byte "STOP",   $00, TOK_STOP
001D36r 2  00 B0        
001D38r 2  43 4F 4E 54    .byte "CONT",   $00, TOK_CONT
001D3Cr 2  00 B1        
001D3Er 2  44 41 54 41    .byte "DATA",   $00, TOK_DATA
001D42r 2  00 B3        
001D44r 2  52 45 41 44    .byte "READ",   $00, TOK_READ
001D48r 2  00 B4        
