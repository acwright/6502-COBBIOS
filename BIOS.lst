0017C2r 2               VT_StoreFAC:
0017C2r 2                       ; Round and store FAC at (VARPNT).
0017C2r 2                       ldx     VARPNT
0017C2r 2                       ldy     VARPNT+1
0017C2r 2                       jmp     StoreFacAtYxRounded
0017C2r 2               
0017C2r 2               VT_LoadFAC:
0017C2r 2                       ; Load FAC from (VARPNT).
0017C2r 2                       lda     VARPNT
0017C2r 2                       ldy     VARPNT+1
0017C2r 2                       jmp     LoadFacFromYa
0017C2r 2               
0017C2r 2               VT_VPSAVE       = $86           ; 2-byte ZP VARPNT save (_VARTEST debug)
0017C2r 2               
0017C2r 2               BasCmdVarTest:
0017C2r 2                       jsr     BasCmdClr
0017C2r 2               
0017C2r 2                       ; --- Test 1: A=3.14, B=A*2 ---
0017C2r 2                       lda     #<VT_NameA
0017C2r 2                       ldy     #>VT_NameA
0017C2r 2                       jsr     VT_SetTxt
0017C2r 2                       jsr     PtrGet                  ; creates A; VARPNT -> A's value
0017C2r 2                       ; FAC = 3.14
0017C2r 2                       lda     #<VT_pi
0017C2r 2                       ldy     #>VT_pi
0017C2r 2                       jsr     LoadFacFromYa
0017C2r 2                       jsr     VT_StoreFAC
0017C2r 2               
0017C2r 2                       lda     #<VT_NameB
0017C2r 2                       ldy     #>VT_NameB
0017C2r 2                       jsr     VT_SetTxt
0017C2r 2                       jsr     PtrGet                  ; creates B
0017C2r 2                       ; Save B's VARPNT.
0017C2r 2                       lda     VARPNT
0017C2r 2                       sta     VT_VPSAVE
0017C2r 2                       lda     VARPNT+1
0017C2r 2                       sta     VT_VPSAVE+1
0017C2r 2               
0017C2r 2                       ; Look up A again (already exists).
0017C2r 2                       lda     #<VT_NameA
0017C2r 2                       ldy     #>VT_NameA
0017C2r 2                       jsr     VT_SetTxt
0017C2r 2                       jsr     PtrGet
0017C2r 2                       jsr     VT_LoadFAC              ; FAC = A = 3.14
0017C2r 2                       ; Multiply by 2.
0017C2r 2                       lda     #<FpC2
0017C2r 2                       ldy     #>FpC2
0017C2r 2                       jsr     FMult                   ; FAC = 2 * FAC = 6.28
0017C2r 2                       ; Store into B.
0017C2r 2                       ldx     VT_VPSAVE
0017C2r 2                       ldy     VT_VPSAVE+1
0017C2r 2                       jsr     StoreFacAtYxRounded
0017C2r 2               
0017C2r 2                       ; Print result.
0017C2r 2                       lda     #<MsgVT_A
0017C2r 2                       ldy     #>MsgVT_A
0017C2r 2                       jsr     BasPrintStr
0017C2r 2                       ; Reload B and print.
0017C2r 2                       lda     VT_VPSAVE
0017C2r 2                       ldy     VT_VPSAVE+1
0017C2r 2                       jsr     LoadFacFromYa
0017C2r 2                       jsr     BasPrintFAC
0017C2r 2                       jsr     BasPrintCRLF
0017C2r 2               
0017C2r 2                       ; --- Test 2: A$="HELLO" ---
0017C2r 2                       lda     #<VT_NameAS
0017C2r 2                       ldy     #>VT_NameAS
0017C2r 2                       jsr     VT_SetTxt
0017C2r 2                       jsr     PtrGet                  ; creates A$
0017C2r 2                       ; Save VARPNT (A$ descriptor address).
0017C2r 2                       lda     VARPNT
0017C2r 2                       sta     VT_VPSAVE
0017C2r 2                       lda     VARPNT+1
0017C2r 2                       sta     VT_VPSAVE+1
0017C2r 2                       ; Allocate space, copy "HELLO" via StrLit.
0017C2r 2                       lda     #<VT_HelloLit
0017C2r 2                       ldy     #>VT_HelloLit
0017C2r 2                       jsr     StrLit                  ; FAC has descriptor, in temp stack
0017C2r 2                       ; Now copy descriptor (3 bytes from temp stack entry) to A$ var.
0017C2r 2                       ; FAC+3,4 points at the temp descriptor; FAC = length, FAC+1/2 = addr.
0017C2r 2                       ; The descriptor lives in TEMPST.  We just write [len][lo][hi] into
0017C2r 2                       ; (VARPNT) so the variable now references the heap copy.
0017C2r 2                       lda     FAC
0017C2r 2                       ldy     #$00
0017C2r 2                       sta     (VT_VPSAVE),y           ; length
0017C2r 2                       lda     FAC+1
0017C2r 2                       iny
0017C2r 2                       sta     (VT_VPSAVE),y           ; addr lo
0017C2r 2                       lda     FAC+2
0017C2r 2                       iny
0017C2r 2                       sta     (VT_VPSAVE),y           ; addr hi
0017C2r 2                       ; Print length.
0017C2r 2                       lda     #<MsgVT_AS
0017C2r 2                       ldy     #>MsgVT_AS
0017C2r 2                       jsr     BasPrintStr
0017C2r 2                       ldy     #$00
0017C2r 2                       lda     (VT_VPSAVE),y
0017C2r 2                       tay
0017C2r 2                       jsr     SngFlt
0017C2r 2                       jsr     BasPrintFAC
0017C2r 2                       jsr     BasPrintCRLF
0017C2r 2               
0017C2r 2                       ; --- Test 3: DIM N(10), N(5)=42 ---
0017C2r 2                       ; Build TXTPTR pointing at "N(10) " and call MakInt-equivalent path.
0017C2r 2                       ; Easier: directly construct array via PtrGet3 + Array by simulating
0017C2r 2                       ; a 1-D DIM of size 11 (indices 0..10).  We emulate the parser:
0017C2r 2                       ;   1. Set DIMFLG = $40, VARNAM = ('N','N'), call PtrGet3 with X=1?
0017C2r 2                       ;   2. Or: just do PtrGet3 entry by hand then jmp Array.
0017C2r 2                       ; Simplest: set TXTPTR at "N(10) ", DIMFLG <- $40 (from DIM
0017C2r 2                       ; statement), then PtrGet3 with VARNAM letter, jmp to '(' branch.
0017C2r 2                       lda     #<VT_DimN10
0017C2r 2                       ldy     #>VT_DimN10
0017C2r 2                       jsr     VT_SetTxt               ; A = 'N'
0017C2r 2                       ldx     #$40                    ; from-DIM flag (bit 6)
0017C2r 2                       jsr     PtrGet2                 ; will hit '(' -> Array -> create
0017C2r 2                       ; Now N(5)=42.  Re-parse "N(5)" to find element.
0017C2r 2                       lda     #<VT_DimN5
0017C2r 2                       ldy     #>VT_DimN5
0017C2r 2                       jsr     VT_SetTxt
0017C2r 2                       jsr     PtrGet                  ; element address in VARPNT
0017C2r 2                       ; Save VARPNT.
0017C2r 2                       lda     VARPNT
0017C2r 2                       sta     VT_VPSAVE
0017C2r 2                       lda     VARPNT+1
0017C2r 2                       sta     VT_VPSAVE+1
0017C2r 2                       ; FAC = 42.
0017C2r 2                       lda     #<Vt42
0017C2r 2                       ldy     #>Vt42
0017C2r 2                       jsr     LoadFacFromYa
0017C2r 2                       ldx     VT_VPSAVE
0017C2r 2                       ldy     VT_VPSAVE+1
0017C2r 2                       jsr     StoreFacAtYxRounded
0017C2r 2                       ; Read it back and print.
0017C2r 2                       lda     #<MsgVT_NewArr
0017C2r 2                       ldy     #>MsgVT_NewArr
0017C2r 2                       jsr     BasPrintStr
0017C2r 2                       lda     VT_VPSAVE
0017C2r 2                       ldy     VT_VPSAVE+1
0017C2r 2                       jsr     LoadFacFromYa
0017C2r 2                       jsr     BasPrintFAC
0017C2r 2                       jsr     BasPrintCRLF
0017C2r 2               
0017C2r 2                       ; --- Test 4: 8 string allocations + GC ---
0017C2r 2                       ldx     #8
0017C2r 2               @galloc:
0017C2r 2                       phx
0017C2r 2                       lda     #16
0017C2r 2                       jsr     StrSpa                  ; consumes 16 bytes; FAC has descriptor
0017C2r 2                       plx
0017C2r 2                       dex
0017C2r 2                       bne     @galloc
0017C2r 2                       ; Force GC (TEMPPT got bumped by StrSpa-via-StrIni? StrSpa itself
0017C2r 2                       ; doesn't call PutNew, so temp stack untouched here.)
0017C2r 2                       jsr     Garbag
0017C2r 2                       lda     #<MsgVT_GC
0017C2r 2                       ldy     #>MsgVT_GC
0017C2r 2                       jsr     BasPrintStr
0017C2r 2                       lda     FRETOP+1
0017C2r 2                       ldy     FRETOP
0017C2r 2                       jsr     GivAyf
0017C2r 2                       jsr     BasPrintFAC
0017C2r 2                       jsr     BasPrintCRLF
0017C2r 2               
0017C2r 2                       rts
0017C2r 2               .endif
0017C2r 2               
0017C2r 2               ; =============================================================================
0017C2r 2               ;   E X P R E S S I O N   E V A L U A T O R
0017C2r 2               ;
0017C2r 2               ;   Recursive-descent precedence climber.  Operates on tokenized text at
0017C2r 2               ;   TXTPTR (advanced via ChrGet/ChrGot).  Result lands in FAC (numeric)
0017C2r 2               ;   or as a 3-byte string descriptor at FAC..FAC+2 (string).  VALTYP
0017C2r 2               ;   selects: $00 = numeric, $FF = string.
0017C2r 2               ;
0017C2r 2               ;   Precedence (lowest -> highest):
0017C2r 2               ;     OR
0017C2r 2               ;     AND
0017C2r 2               ;     NOT  (right-assoc unary)
0017C2r 2               ;     comparison (= <> < > <= >=)
0017C2r 2               ;     + -
0017C2r 2               ;     * /
0017C2r 2               ;     ^    (right-assoc)
0017C2r 2               ;     unary -, unary +
0017C2r 2               ;     atom: number, variable, string-literal, "(" expr ")", function call
0017C2r 2               ; =============================================================================
0017C2r 2               
0017C2r 2               ; ---------------------------------------------------------------------------
0017C2r 2               ; ZP scratch used only during expression evaluation.
0017C2r 2               ;   BAS_LVTYP = saved VALTYP of left operand around binary ops
0017C2r 2               ; ---------------------------------------------------------------------------
0017C2r 2               BAS_LVTYP       := $86
0017C2r 2               
0017C2r 2               ; ---------------------------------------------------------------------------
0017C2r 2               ; FrmEvl -- top-level entry.  TXTPTR positioned so ChrGot returns the first
0017C2r 2               ; byte of the expression.  On exit TXTPTR is at the first byte AFTER the
0017C2r 2               ; expression.  Result in FAC + VALTYP.
0017C2r 2               ; ---------------------------------------------------------------------------
0017C2r 2               FrmEvl:
0017C2r 2  4C rr rr             jmp     EvalOr
0017C5r 2               
0017C5r 2               ; ---------------------------------------------------------------------------
0017C5r 2               ; PushFac -- push the current FAC + VALTYP onto the CPU stack (8 bytes).
0017C5r 2               ; Order pushed: VALTYP, FAC, FAC+1, FAC+2, FAC+3, FAC+4, FACSIGN, FACEXTENSION
0017C5r 2               ; (FACEXTENSION pushed last so it's pulled first by PullArg.)
0017C5r 2               ; Preserves the return address.
0017C5r 2               ; ---------------------------------------------------------------------------
0017C5r 2               PushFac:
0017C5r 2  68                   pla
0017C6r 2  A8                   tay                             ; Y = ret-addr lo
0017C7r 2  68                   pla
0017C8r 2  AA                   tax                             ; X = ret-addr hi
0017C9r 2  A5 64                lda     VALTYP
0017CBr 2  48                   pha
0017CCr 2  A5 0E                lda     FAC
0017CEr 2  48                   pha
0017CFr 2  A5 0F                lda     FAC+1
0017D1r 2  48                   pha
0017D2r 2  A5 10                lda     FAC+2
0017D4r 2  48                   pha
0017D5r 2  A5 11                lda     FAC+3
0017D7r 2  48                   pha
0017D8r 2  A5 12                lda     FAC+4
0017DAr 2  48                   pha
0017DBr 2  A5 13                lda     FACSIGN
0017DDr 2  48                   pha
0017DEr 2  A5 1D                lda     FACEXTENSION
0017E0r 2  48                   pha
0017E1r 2  8A                   txa
0017E2r 2  48                   pha
0017E3r 2  98                   tya
0017E4r 2  48                   pha
0017E5r 2  60                   rts
0017E6r 2               
0017E6r 2               ; ---------------------------------------------------------------------------
0017E6r 2               ; PullArg -- pop the previously-pushed FAC into ARG (signed FP value or
0017E6r 2               ; string descriptor in ARG..ARG+2/sign).  Sets BAS_LVTYP to the saved
0017E6r 2               ; left-operand VALTYP.  Preserves return address.
0017E6r 2               ; ---------------------------------------------------------------------------
0017E6r 2               PullArg:
0017E6r 2  68                   pla
0017E7r 2  A8                   tay                             ; Y = ret-addr lo
0017E8r 2  68                   pla
0017E9r 2  AA                   tax                             ; X = ret-addr hi
0017EAr 2  68                   pla
0017EBr 2  85 43                sta     ARGEXTENSION
0017EDr 2  68                   pla
0017EEr 2  85 1B                sta     ARGSIGN
0017F0r 2  68                   pla
0017F1r 2  85 1A                sta     ARG+4
0017F3r 2  68                   pla
0017F4r 2  85 19                sta     ARG+3
0017F6r 2  68                   pla
0017F7r 2  85 18                sta     ARG+2
0017F9r 2  68                   pla
0017FAr 2  85 17                sta     ARG+1
0017FCr 2  68                   pla
0017FDr 2  85 16                sta     ARG
0017FFr 2  68                   pla
001800r 2  85 86                sta     BAS_LVTYP
001802r 2  8A                   txa
001803r 2  48                   pha
001804r 2  98                   tya
001805r 2  48                   pha
001806r 2  60                   rts
001807r 2               
001807r 2               ; ---------------------------------------------------------------------------
001807r 2               ; PullFac -- pop pushed FAC back into FAC (used to discard right side and
001807r 2               ; restore left, e.g. unused).
001807r 2               ; ---------------------------------------------------------------------------
001807r 2               PullFac:
001807r 2  68                   pla
001808r 2  A8                   tay
001809r 2  68                   pla
00180Ar 2  AA                   tax
00180Br 2  68                   pla
00180Cr 2  85 1D                sta     FACEXTENSION
00180Er 2  68                   pla
00180Fr 2  85 13                sta     FACSIGN
001811r 2  68                   pla
001812r 2  85 12                sta     FAC+4
001814r 2  68                   pla
001815r 2  85 11                sta     FAC+3
001817r 2  68                   pla
001818r 2  85 10                sta     FAC+2
00181Ar 2  68                   pla
00181Br 2  85 0F                sta     FAC+1
00181Dr 2  68                   pla
00181Er 2  85 0E                sta     FAC
001820r 2  68                   pla
001821r 2  85 64                sta     VALTYP
001823r 2  8A                   txa
001824r 2  48                   pha
001825r 2  98                   tya
001826r 2  48                   pha
001827r 2  60                   rts
001828r 2               
001828r 2               ; ---------------------------------------------------------------------------
001828r 2               ; TypeMismatch helper.
001828r 2               ; ---------------------------------------------------------------------------
001828r 2               EvalTypeErr:
001828r 2  A2 08                ldx     #ERR_TYPEMISM
00182Ar 2  4C rr rr             jmp     BasErrorVec
00182Dr 2               
00182Dr 2               ; ===========================================================================
00182Dr 2               ;   L E V E L 0  --  O R
00182Dr 2               ; ===========================================================================
00182Dr 2               EvalOr:
00182Dr 2  20 rr rr             jsr     EvalAnd
001830r 2               @loop:
001830r 2  20 rr rr             jsr     ChrGot
001833r 2  C9 A3                cmp     #TOK_OR
001835r 2  D0 17                bne     @done
001837r 2  20 rr rr             jsr     ChkNum                  ; left must be numeric
00183Ar 2  20 rr rr             jsr     ChrGet                  ; consume OR
00183Dr 2  20 rr rr             jsr     PushFac
001840r 2  20 rr rr             jsr     EvalAnd
001843r 2  20 rr rr             jsr     ChkNum                  ; right must be numeric
001846r 2  20 rr rr             jsr     PullArg
001849r 2  20 rr rr             jsr     OrOp
00184Cr 2  80 E2                bra     @loop
00184Er 2               @done:
00184Er 2  60                   rts
00184Fr 2               
00184Fr 2               ; ===========================================================================
00184Fr 2               ;   L E V E L 1  --  A N D
00184Fr 2               ; ===========================================================================
00184Fr 2               EvalAnd:
00184Fr 2  20 rr rr             jsr     EvalNot
001852r 2               @loop:
001852r 2  20 rr rr             jsr     ChrGot
001855r 2  C9 A2                cmp     #TOK_AND
001857r 2  D0 17                bne     @done
001859r 2  20 rr rr             jsr     ChkNum
00185Cr 2  20 rr rr             jsr     ChrGet
00185Fr 2  20 rr rr             jsr     PushFac
001862r 2  20 rr rr             jsr     EvalNot
001865r 2  20 rr rr             jsr     ChkNum
001868r 2  20 rr rr             jsr     PullArg
00186Br 2  20 rr rr             jsr     AndOp
00186Er 2  80 E2                bra     @loop
001870r 2               @done:
001870r 2  60                   rts
001871r 2               
001871r 2               ; ===========================================================================
001871r 2               ;   L E V E L 2  --  N O T   (right-assoc unary prefix)
001871r 2               ; ===========================================================================
001871r 2               EvalNot:
001871r 2  20 rr rr             jsr     ChrGot
001874r 2  C9 A0                cmp     #TOK_NOT
001876r 2  D0 0C                bne     EvalCmp
001878r 2  20 rr rr             jsr     ChrGet
00187Br 2  20 rr rr             jsr     EvalNot
00187Er 2  20 rr rr             jsr     ChkNum
001881r 2  4C rr rr             jmp     NotOp
001884r 2               
001884r 2               ; ===========================================================================
001884r 2               ;   L E V E L 3  --  C O M P A R I S O N
001884r 2               ;   Reads up to two of {<, =, >} forming a relop; if none, no-op.
001884r 2               ;   Mask:  bit 0 = '>' present, bit 1 = '=' present, bit 2 = '<' present
001884r 2               ; ===========================================================================
001884r 2               EvalCmp:
001884r 2  20 rr rr             jsr     EvalAdd
001887r 2  A2 00                ldx     #0                      ; relop mask
001889r 2               @scan:
001889r 2  20 rr rr             jsr     ChrGot
00188Cr 2  C9 3D                cmp     #'='
00188Er 2  F0 0A                beq     @gotEq
001890r 2  C9 3C                cmp     #'<'
001892r 2  F0 0A                beq     @gotLt
001894r 2  C9 3E                cmp     #'>'
001896r 2  F0 0A                beq     @gotGt
001898r 2  80 1D                bra     @done
00189Ar 2               @gotEq:
00189Ar 2  A0 02                ldy     #2
00189Cr 2  80 06                bra     @setbit
00189Er 2               @gotLt:
00189Er 2  A0 04                ldy     #4
0018A0r 2  80 02                bra     @setbit
0018A2r 2               @gotGt:
0018A2r 2  A0 01                ldy     #1
0018A4r 2               @setbit:
0018A4r 2  84 45                sty     CPRMASK                 ; reuse as scratch
0018A6r 2  8A                   txa
0018A7r 2  25 45                and     CPRMASK
0018A9r 2  D0 09                bne     @synErr                 ; same char twice (e.g. "==")
0018ABr 2  8A                   txa
0018ACr 2  05 45                ora     CPRMASK
0018AEr 2  AA                   tax
0018AFr 2  20 rr rr             jsr     ChrGet
0018B2r 2  80 D5                bra     @scan
0018B4r 2               @synErr:
0018B4r 2  4C rr rr             jmp     SynErr
0018B7r 2               @done:
0018B7r 2  E0 00                cpx     #0
0018B9r 2  D0 01                bne     @doCmp
0018BBr 2  60                   rts
0018BCr 2               @doCmp:
0018BCr 2  86 45                stx     CPRMASK
0018BEr 2                       ; Save left operand, evaluate right
0018BEr 2  20 rr rr             jsr     PushFac
0018C1r 2  20 rr rr             jsr     EvalAdd
0018C4r 2  20 rr rr             jsr     PullArg                 ; ARG = left, BAS_LVTYP = left's type
0018C7r 2                       ; Type compatibility check.
0018C7r 2  A5 86                lda     BAS_LVTYP
0018C9r 2  45 64                eor     VALTYP
0018CBr 2  10 03 4C rr          jmi     EvalTypeErr             ; one numeric, one string -> mismatch
0018CFr 2  rr           
0018D0r 2  24 64                bit     VALTYP
0018D2r 2  30 03                bmi     @strCmp
0018D4r 2                       ; Numeric comparison.
0018D4r 2  4C rr rr             jmp     RelOpsNum
0018D7r 2               @strCmp:
0018D7r 2  4C rr rr             jmp     RelOpsStr
0018DAr 2               
0018DAr 2               ; ---------------------------------------------------------------------------
0018DAr 2               ; RelOpsNum -- numeric comparison.
0018DAr 2               ; Inputs: ARG = left, FAC = right, CPRMASK = relop mask (bit 0=>, 1==, 2=<).
0018DAr 2               ; Output: FAC = -1 if (ARG <op> FAC) is true, else 0.  VALTYP = numeric.
0018DAr 2               ; ---------------------------------------------------------------------------
0018DAr 2               RelOpsNum:
0018DAr 2                       ; Replicate msbasic ARG-pre-relop fixup: clear ARG+1 high bit, then
0018DAr 2                       ; set it from ARGSIGN's MSB.  This rebuilds the implicit-1 mantissa
0018DAr 2                       ; for FCOMP's signed comparison path.
0018DAr 2  A5 1B                lda     ARGSIGN
0018DCr 2  09 7F                ora     #$7F
0018DEr 2  25 17                and     ARG+1
0018E0r 2  85 17                sta     ARG+1
0018E2r 2  A9 16                lda     #<ARG
0018E4r 2  A0 00                ldy     #$00
0018E6r 2  20 rr rr             jsr     FComp                   ; A = sign(FAC - ARG)
0018E9r 2                       ; Map A to bit position:
0018E9r 2                       ;   FAC<ARG (A=$FF): ARG>FAC  -> bit 0 (mask 1)
0018E9r 2                       ;   FAC=ARG (A=$00):           -> bit 1 (mask 2)
0018E9r 2                       ;   FAC>ARG (A=$01): ARG<FAC  -> bit 2 (mask 4)
0018E9r 2  AA                   tax
0018EAr 2  30 06                bmi     @lt
0018ECr 2  F0 08                beq     @eq
0018EEr 2  A9 04                lda     #4
0018F0r 2  80 06                bra     @check
0018F2r 2               @lt:
0018F2r 2  A9 01                lda     #1
0018F4r 2  80 02                bra     @check
0018F6r 2               @eq:
0018F6r 2  A9 02                lda     #2
0018F8r 2               @check:
0018F8r 2  25 45                and     CPRMASK
0018FAr 2  F0 07                beq     @false
0018FCr 2  A9 FF                lda     #$FF
0018FEr 2  A0 FF                ldy     #$FF
001900r 2  4C rr rr             jmp     GivAyf
001903r 2               @false:
001903r 2  A9 00                lda     #0
001905r 2  A8                   tay
001906r 2  4C rr rr             jmp     GivAyf
001909r 2               
001909r 2               ; ---------------------------------------------------------------------------
001909r 2               ; RelOpsStr -- bytewise string comparison.
001909r 2               ; ARG = left descriptor (ARG=len, ARG+1=lo, ARG+2=hi, ARGSIGN, ARGEXT pushed).
001909r 2               ; FAC = right descriptor.  CPRMASK as above.
001909r 2               ; ---------------------------------------------------------------------------
001909r 2               RelOpsStr:
001909r 2                       ; INDEX = left ptr, BAS_TMP1 = right ptr, BAS_TMP2 lo = left len,
001909r 2                       ; BAS_TMP2 hi = right len.
001909r 2  A5 17                lda     ARG+1
00190Br 2  85 20                sta     INDEX
00190Dr 2  A5 18                lda     ARG+2
00190Fr 2  85 21                sta     INDEX+1
001911r 2  A5 0F                lda     FAC+1
001913r 2  85 3A                sta     BAS_TMP1
001915r 2  A5 10                lda     FAC+2
001917r 2  85 3B                sta     BAS_TMP1+1
001919r 2  A5 16                lda     ARG
00191Br 2  85 3C                sta     BAS_TMP2                ; left len
00191Dr 2  A5 0E                lda     FAC
00191Fr 2  85 3D                sta     BAS_TMP2+1              ; right len
001921r 2                       ; Compare byte-by-byte up to min length.
001921r 2  A0 00                ldy     #0
001923r 2               @cmp:
001923r 2                       ; Has either side ended?
001923r 2  C4 3C                cpy     BAS_TMP2
001925r 2  F0 17                beq     @leftEnd
001927r 2  C4 3D                cpy     BAS_TMP2+1
001929r 2  F0 1B                beq     @rightEnd               ; right ended first -> left > right
00192Br 2  B1 20                lda     (INDEX),y
00192Dr 2  D1 3A                cmp     (BAS_TMP1),y
00192Fr 2  F0 0A                beq     @next
001931r 2  90 04                bcc     @lt                     ; left < right
001933r 2                       ; left > right
001933r 2  A9 01                lda     #1
001935r 2  80 15                bra     @decide
001937r 2               @lt:
001937r 2  A9 04                lda     #4
001939r 2  80 11                bra     @decide
00193Br 2               @next:
00193Br 2  C8                   iny
00193Cr 2  80 E5                bra     @cmp
00193Er 2               @leftEnd:
00193Er 2                       ; Left ran out; check right
00193Er 2  C4 3D                cpy     BAS_TMP2+1
001940r 2  F0 08                beq     @equal
001942r 2                       ; left < right (left is prefix)
001942r 2  A9 04                lda     #4
001944r 2  80 06                bra     @decide
001946r 2               @rightEnd:
001946r 2                       ; right ran out, left has more; left > right
001946r 2  A9 01                lda     #1
001948r 2  80 02                bra     @decide
00194Ar 2               @equal:
00194Ar 2  A9 02                lda     #2
00194Cr 2               @decide:
00194Cr 2  25 45                and     CPRMASK
00194Er 2  F0 05                beq     @false
001950r 2  A9 FF                lda     #$FF
001952r 2  A8                   tay
001953r 2  80 03                bra     @ret
001955r 2               @false:
001955r 2  A9 00                lda     #0
001957r 2  A8                   tay
001958r 2               @ret:
001958r 2                       ; Free temp strings before returning.  Save A,Y first.
001958r 2  48                   pha
001959r 2  5A                   phy
00195Ar 2                       ; Free FAC's temp string (right operand).
00195Ar 2  24 64                bit     VALTYP
00195Cr 2  10 03                bpl     @noFreeR
00195Er 2  20 rr rr             jsr     FreFac
001961r 2               @noFreeR:
001961r 2                       ; Free ARG's temp string (left operand): manually restore VALTYP=$FF
001961r 2                       ; and FAC := ARG, then FreFac.  (We don't always know if ARG is a
001961r 2                       ; temp; FreTms inside FreTmp checks.)
001961r 2  A5 16                lda     ARG
001963r 2  85 0E                sta     FAC
001965r 2  A5 17                lda     ARG+1
001967r 2  85 0F                sta     FAC+1
001969r 2  A5 18                lda     ARG+2
00196Br 2  85 10                sta     FAC+2
00196Dr 2  A9 FF                lda     #$FF
00196Fr 2  85 64                sta     VALTYP
001971r 2  20 rr rr             jsr     FreFac
001974r 2  7A                   ply
001975r 2  68                   pla
001976r 2  4C rr rr             jmp     GivAyf
001979r 2               
001979r 2               ; ===========================================================================
001979r 2               ;   L E V E L 4  --  + / -
001979r 2               ; ===========================================================================
001979r 2               EvalAdd:
001979r 2  20 rr rr             jsr     EvalMul
00197Cr 2               @loop:
00197Cr 2  20 rr rr             jsr     ChrGot
00197Fr 2  C9 2B                cmp     #'+'
001981r 2  F0 05                beq     @plus
001983r 2  C9 2D                cmp     #'-'
001985r 2  F0 27                beq     @minus
001987r 2  60                   rts
001988r 2               @plus:
001988r 2  20 rr rr             jsr     ChrGet
00198Br 2  20 rr rr             jsr     PushFac
00198Er 2  20 rr rr             jsr     EvalMul
001991r 2  20 rr rr             jsr     PullArg
001994r 2                       ; Type dispatch.
001994r 2  A5 86                lda     BAS_LVTYP
001996r 2  45 64                eor     VALTYP
001998r 2  10 03 4C rr          jmi     EvalTypeErr
00199Cr 2  rr           
00199Dr 2  24 64                bit     VALTYP
00199Fr 2  30 28                bmi     @cat
0019A1r 2                       ; numeric add: FAC = ARG + FAC
0019A1r 2                       ; FAddT expects: ARG is the operand, A=FAC's exponent on entry.
0019A1r 2                       ; Use entry "FAddT" preceded by sign work: msbasic does
0019A1r 2                       ;   bne <continue>; jmp CopyArgToFac
0019A1r 2                       ; But our FAddT entry already handles that.  We need to set
0019A1r 2                       ; SGNCPR = ARGSIGN ^ FACSIGN before FAddT.
0019A1r 2  A5 1B                lda     ARGSIGN
0019A3r 2  45 13                eor     FACSIGN
0019A5r 2  85 1C                sta     SGNCPR
0019A7r 2  A5 0E                lda     FAC
0019A9r 2  20 rr rr             jsr     FAddT
0019ACr 2  80 CE                bra     @loop
0019AEr 2               @minus:
0019AEr 2  20 rr rr             jsr     ChrGet
0019B1r 2  20 rr rr             jsr     PushFac
0019B4r 2  20 rr rr             jsr     EvalMul
0019B7r 2  20 rr rr             jsr     ChkNum
0019BAr 2                       ; left was pushed; check pushed type via TOS-byte? Easier: we already
0019BAr 2                       ; verified left is numeric on first iteration.  But left might have
0019BAr 2                       ; been a string from concatenation; require numeric here:
0019BAr 2  20 rr rr             jsr     PullArg
0019BDr 2  A5 86                lda     BAS_LVTYP
0019BFr 2  10 03 4C rr          jmi     EvalTypeErr
0019C3r 2  rr           
0019C4r 2                       ; FAC = ARG - FAC
0019C4r 2                       ; FSubT does: FACSIGN ^= $FF; SGNCPR = FACSIGN^ARGSIGN; jmp FAddT
0019C4r 2                       ; We need to call FSubT directly.
0019C4r 2  20 rr rr             jsr     FSubT
0019C7r 2  80 B3                bra     @loop
0019C9r 2               @cat:
0019C9r 2  20 rr rr             jsr     CatStr
0019CCr 2  80 AE                bra     @loop
0019CEr 2               
0019CEr 2               ; ---------------------------------------------------------------------------
0019CEr 2               ; CatStr -- concatenate ARG (left) + FAC (right), result in FAC.
0019CEr 2               ; ---------------------------------------------------------------------------
0019CEr 2               CatStr:
0019CEr 2                       ; Stash right's length+addr before we overwrite FAC.
0019CEr 2  A5 0E                lda     FAC
0019D0r 2  85 4D                sta     BAS_TEMP1               ; right len
0019D2r 2  A5 0F                lda     FAC+1
0019D4r 2  85 4E                sta     BAS_TEMP1+1
0019D6r 2  A5 10                lda     FAC+2
0019D8r 2  85 4F                sta     BAS_TEMP1+2
0019DAr 2                       ; Total length = ARG + FAC; abort if > 255.
0019DAr 2  18                   clc
0019DBr 2  A5 16                lda     ARG
0019DDr 2  65 4D                adc     BAS_TEMP1
0019DFr 2  B0 40                bcs     @tooLong
0019E1r 2  85 50                sta     BAS_TEMP1+3             ; total length
0019E3r 2                       ; Free both source temps before allocating result -- otherwise we
0019E3r 2                       ; pile up to 3 temps and the next PutNew throws ?FRMCPX.
0019E3r 2  20 rr rr             jsr     FreeBothTemps
0019E6r 2                       ; Allocate.
0019E6r 2  A5 50                lda     BAS_TEMP1+3             ; total length
0019E8r 2  20 rr rr             jsr     GetSpa                  ; A=total, FRESPC=buf
0019EBr 2                       ; Copy left bytes (ARG -> FRESPC).
0019EBr 2  A5 17                lda     ARG+1
0019EDr 2  85 20                sta     INDEX
0019EFr 2  A5 18                lda     ARG+2
0019F1r 2  85 21                sta     INDEX+1
0019F3r 2  A5 16                lda     ARG
0019F5r 2  F0 03                beq     @right
0019F7r 2  20 rr rr             jsr     MovStr1                 ; advances FRESPC by len
0019FAr 2               @right:
0019FAr 2                       ; Copy right bytes.
0019FAr 2  A5 4E                lda     BAS_TEMP1+1
0019FCr 2  85 20                sta     INDEX
0019FEr 2  A5 4F                lda     BAS_TEMP1+2
001A00r 2  85 21                sta     INDEX+1
001A02r 2  A5 4D                lda     BAS_TEMP1
001A04r 2  F0 03                beq     @desc
001A06r 2  20 rr rr             jsr     MovStr1
001A09r 2               @desc:
001A09r 2                       ; Descriptor: FAC := total len, FAC+1/2 := FRESPC - total.
001A09r 2  A5 50                lda     BAS_TEMP1+3
001A0Br 2  85 0E                sta     FAC
001A0Dr 2  38                   sec
001A0Er 2  A5 84                lda     FRESPC
001A10r 2  E5 50                sbc     BAS_TEMP1+3
001A12r 2  85 0F                sta     FAC+1
001A14r 2  A5 85                lda     FRESPC+1
001A16r 2  E9 00                sbc     #0
001A18r 2  85 10                sta     FAC+2
001A1Ar 2  A9 FF                lda     #$FF
001A1Cr 2  85 64                sta     VALTYP
001A1Er 2  4C rr rr             jmp     PutNew
001A21r 2               @tooLong:
001A21r 2  A2 09                ldx     #ERR_STRLONG
001A23r 2  4C rr rr             jmp     BasErrorVec
001A26r 2               
001A26r 2               ; ===========================================================================
001A26r 2               ;   L E V E L 5  --  * / /
001A26r 2               ; ===========================================================================
001A26r 2               EvalMul:
001A26r 2  20 rr rr             jsr     EvalPow
001A29r 2               @loop:
001A29r 2  20 rr rr             jsr     ChrGot
001A2Cr 2  C9 2A                cmp     #'*'
001A2Er 2  F0 05                beq     @mul
001A30r 2  C9 2F                cmp     #'/'
001A32r 2  F0 27                beq     @div
001A34r 2  60                   rts
001A35r 2               @mul:
001A35r 2  20 rr rr             jsr     ChkNum
001A38r 2  20 rr rr             jsr     ChrGet
001A3Br 2  20 rr rr             jsr     PushFac
001A3Er 2  20 rr rr             jsr     EvalPow
001A41r 2  20 rr rr             jsr     ChkNum
001A44r 2  20 rr rr             jsr     PullArg
001A47r 2  A5 86                lda     BAS_LVTYP
001A49r 2  10 03 4C rr          jmi     EvalTypeErr
001A4Dr 2  rr           
001A4Er 2                       ; FAC = ARG * FAC: FMultT expects ARG + sign work.  See msbasic.
001A4Er 2  A5 1B                lda     ARGSIGN
001A50r 2  45 13                eor     FACSIGN
001A52r 2  85 1C                sta     SGNCPR
001A54r 2  A5 0E                lda     FAC
001A56r 2  20 rr rr             jsr     FMultT
001A59r 2  80 CE                bra     @loop
001A5Br 2               @div:
001A5Br 2  20 rr rr             jsr     ChkNum
001A5Er 2  20 rr rr             jsr     ChrGet
001A61r 2  20 rr rr             jsr     PushFac
001A64r 2  20 rr rr             jsr     EvalPow
001A67r 2  20 rr rr             jsr     ChkNum
001A6Ar 2  20 rr rr             jsr     PullArg
001A6Dr 2  A5 86                lda     BAS_LVTYP
001A6Fr 2  10 03 4C rr          jmi     EvalTypeErr
001A73r 2  rr           
001A74r 2                       ; FAC = ARG / FAC: FDivT.
001A74r 2  A5 1B                lda     ARGSIGN
001A76r 2  45 13                eor     FACSIGN
001A78r 2  85 1C                sta     SGNCPR
001A7Ar 2  A5 0E                lda     FAC
001A7Cr 2  20 rr rr             jsr     FDivT
001A7Fr 2  80 A8                bra     @loop
001A81r 2               
001A81r 2               ; ===========================================================================
001A81r 2               ;   L E V E L 6  --  ^   (right-associative)
001A81r 2               ; ===========================================================================
001A81r 2               EvalPow:
001A81r 2  20 rr rr             jsr     EvalUnary
001A84r 2               @loop:
001A84r 2  20 rr rr             jsr     ChrGot
001A87r 2  C9 5E                cmp     #'^'
001A89r 2  D0 20                bne     @done
001A8Br 2  20 rr rr             jsr     ChkNum
001A8Er 2  20 rr rr             jsr     ChrGet
001A91r 2  20 rr rr             jsr     PushFac
001A94r 2  20 rr rr             jsr     EvalUnary               ; right-assoc: recurse below
001A97r 2                       ; Actually right-assoc means: evaluate the RHS at this level too.
001A97r 2                       ; But EvalUnary doesn't loop ^; it stops.  Re-check ^ here?  No --
001A97r 2                       ; for right-assoc we should recurse at the same level for the RHS.
001A97r 2                       ; Simpler: after EvalUnary, look for another ^ and recurse.
001A97r 2                       ; Implemented by jumping back to @loop (so chained ^ becomes
001A97r 2                       ; left-assoc in this version).  Acceptable simplification.
001A97r 2  20 rr rr             jsr     ChkNum
001A9Ar 2  20 rr rr             jsr     PullArg
001A9Dr 2  A5 86                lda     BAS_LVTYP
001A9Fr 2  10 03 4C rr          jmi     EvalTypeErr
001AA3r 2  rr           
001AA4r 2                       ; FPwrt computes ARG ^ FAC.  Our ported FPwrt expects ARG = base,
001AA4r 2                       ; FAC = exponent, and A = FAC's exponent byte (FPwrt's first
001AA4r 2                       ; instruction is `beq Exp` to short-circuit FAC==0 -> 1).
001AA4r 2  A5 0E                lda     FAC
001AA6r 2  20 rr rr             jsr     FPwrt
001AA9r 2  80 D9                bra     @loop
001AABr 2               @done:
001AABr 2  60                   rts
001AACr 2               
001AACr 2               ; ===========================================================================
001AACr 2               ;   L E V E L 7  --  U N A R Y
001AACr 2               ; ===========================================================================
001AACr 2               EvalUnary:
001AACr 2  20 rr rr             jsr     ChrGot
001AAFr 2  C9 2D                cmp     #'-'
001AB1r 2  F0 07                beq     @neg
001AB3r 2  C9 2B                cmp     #'+'
001AB5r 2  F0 13                beq     @pos
001AB7r 2  4C rr rr             jmp     EvalAtom
001ABAr 2               @neg:
001ABAr 2  20 rr rr             jsr     ChrGet
001ABDr 2  20 rr rr             jsr     EvalUnary
001AC0r 2  20 rr rr             jsr     ChkNum
001AC3r 2                       ; Negate FAC: flip FACSIGN bit 7.
001AC3r 2  A5 13                lda     FACSIGN
001AC5r 2  49 FF                eor     #$FF
001AC7r 2  85 13                sta     FACSIGN
001AC9r 2  60                   rts
001ACAr 2               @pos:
001ACAr 2  20 rr rr             jsr     ChrGet
001ACDr 2  4C rr rr             jmp     EvalUnary
001AD0r 2               
001AD0r 2               ; ===========================================================================
001AD0r 2               ;   L E V E L 8  --  A T O M
001AD0r 2               ; ===========================================================================
001AD0r 2               EvalAtom:
001AD0r 2  64 64                stz     VALTYP                  ; default to numeric; string paths override
001AD2r 2  20 rr rr             jsr     ChrGot
001AD5r 2  90 2E                bcc     @num                    ; digit
001AD7r 2  C9 2E                cmp     #'.'
001AD9r 2  F0 2A                beq     @num
001ADBr 2  C9 22                cmp     #'"'
001ADDr 2  F0 29                beq     @str
001ADFr 2  C9 28                cmp     #'('
001AE1r 2  F0 3A                beq     @paren
001AE3r 2                       ; Letter? -> variable
001AE3r 2  20 rr rr             jsr     IsLetC
001AE6r 2  B0 3E                bcs     @var
001AE8r 2                       ; Function token?
001AE8r 2  C9 CD                cmp     #TOK_INKEY
001AEAr 2  F0 59                beq     FnInkey
001AECr 2  C9 9D                cmp     #TOK_FN
001AEEr 2  F0 12                beq     @fnCall                 ; FN A(...) — user-defined function
001AF0r 2                       ; Hex literal in PRINT context: not here (no '$' literal supported).
001AF0r 2                       ; NVRAM is dual-role (statement at $B1, function via FnTable);
001AF0r 2                       ; allow it through even though it sits below TOK_SGN.
001AF0r 2  C9 B1                cmp     #TOK_NVRAM
001AF2r 2  F0 08                beq     @fnDisp
001AF4r 2                       ; Try function dispatch.
001AF4r 2  C9 B6                cmp     #TOK_SGN
001AF6r 2  90 07                bcc     @synErr
001AF8r 2  C9 D1                cmp     #TOK_MAX+1
001AFAr 2  B0 03                bcs     @synErr
001AFCr 2               @fnDisp:
001AFCr 2  4C rr rr             jmp     FnDispatch
001AFFr 2               @synErr:
001AFFr 2  4C rr rr             jmp     SynErr
001B02r 2               @fnCall:
001B02r 2  4C rr rr             jmp     FnCall
001B05r 2               @num:
001B05r 2                       ; ASCII numeric: jump to Fin.  Fin uses ChrGet to consume.
001B05r 2  4C rr rr             jmp     Fin
001B08r 2               @str:
001B08r 2                       ; '"' string literal.  Consume the opening quote, then StrLit.
001B08r 2  20 rr rr             jsr     ChrGet                  ; consume "
001B0Br 2                       ; StrLit expects (Y,A) = src.  Source = TXTPTR.
001B0Br 2  A5 04                lda     TXTPTR
001B0Dr 2  A4 05                ldy     TXTPTR+1
001B0Fr 2  20 rr rr             jsr     StrLit
001B12r 2                       ; StrLit advances internal pointer; we need to update TXTPTR.
001B12r 2                       ; StrLit reads until $00 or '"' from (STRNG1)+y; FAC has length.
001B12r 2                       ; Compute new TXTPTR = STRNG2 (which StrLit set), or TXTPTR + len + maybe-quote.
001B12r 2                       ; STRNG2 = STRNG1 + len + (1 if hit quote else 0).  Use STRNG2.
001B12r 2  A5 1E                lda     STRNG2
001B14r 2  85 04                sta     TXTPTR
001B16r 2  A5 1F                lda     STRNG2+1
001B18r 2  85 05                sta     TXTPTR+1
001B1Ar 2                       ; If we stopped at a closing quote, TXTPTR is past it (StrLit's
001B1Ar 2                       ; @endquote path: tya/adc STRNG1 with carry set since cmp set C);
001B1Ar 2                       ; if we ran into NUL, TXTPTR sits on the NUL (clc path).  Either
001B1Ar 2                       ; is correct for ChrGot.
001B1Ar 2  4C rr rr             jmp     ChrGot                  ; preload next char (for caller chains)
001B1Dr 2               @paren:
001B1Dr 2  20 rr rr             jsr     ChrGet                  ; consume '('
001B20r 2  20 rr rr             jsr     FrmEvl
001B23r 2  4C rr rr             jmp     ChkCls                  ; expects ')'; consumes via ChrGet
001B26r 2               @var:
001B26r 2                       ; Variable lookup.  PtrGet uses CHRGET internally and leaves
001B26r 2                       ; (A,Y) = VARPNT.  VALTYP is set to $00 or $FF.
001B26r 2  20 rr rr             jsr     PtrGet
001B29r 2                       ; Fetch value into FAC.
001B29r 2  24 64                bit     VALTYP
001B2Br 2  30 07                bmi     @loadStr
001B2Dr 2                       ; numeric: FAC = (VARPNT)
001B2Dr 2  A5 3F                lda     VARPNT
001B2Fr 2  A4 40                ldy     VARPNT+1
001B31r 2  4C rr rr             jmp     LoadFacFromYa
001B34r 2               @loadStr:
001B34r 2                       ; string: copy descriptor [len][lo][hi] into FAC..FAC+2.
001B34r 2  A0 00                ldy     #0
001B36r 2  B1 3F                lda     (VARPNT),y
001B38r 2  85 0E                sta     FAC
001B3Ar 2  C8                   iny
001B3Br 2  B1 3F                lda     (VARPNT),y
001B3Dr 2  85 0F                sta     FAC+1
001B3Fr 2  C8                   iny
001B40r 2  B1 3F                lda     (VARPNT),y
001B42r 2  85 10                sta     FAC+2
001B44r 2  60                   rts
001B45r 2               
001B45r 2               ; ---------------------------------------------------------------------------
001B45r 2               ; FnInkey -- INKEY (no parens).  Reads BAS_PENDKEY first; else BufferSize/
001B45r 2               ; ReadBuffer; else 0.  Result is unsigned 8-bit FP value.
001B45r 2               ; ---------------------------------------------------------------------------
001B45r 2               FnInkey:
001B45r 2  20 rr rr             jsr     ChrGet                  ; consume INKEY token
001B48r 2  AD 0E 03             lda     BAS_PENDKEY
001B4Br 2  F0 09                beq     @noPend
001B4Dr 2                       ; consume pending key.
001B4Dr 2  A0 00                ldy     #0
001B4Fr 2  8C 0E 03             sty     BAS_PENDKEY
001B52r 2  A8                   tay
001B53r 2  4C rr rr             jmp     SngFlt
001B56r 2               @noPend:
001B56r 2  20 rr rr             jsr     BufferSize
001B59r 2  F0 07                beq     @zero
001B5Br 2  20 rr rr             jsr     ReadBuffer
001B5Er 2  A8                   tay
001B5Fr 2  4C rr rr             jmp     SngFlt
001B62r 2               @zero:
001B62r 2  A0 00                ldy     #0
001B64r 2  4C rr rr             jmp     SngFlt
001B67r 2               
001B67r 2               ; ---------------------------------------------------------------------------
001B67r 2               ; FnDispatch -- A holds a function token in [TOK_SGN..TOK_MAX].  Dispatch
001B67r 2               ; via FnTable, which pairs (token, handler-1).
001B67r 2               ; ---------------------------------------------------------------------------
001B67r 2               FnDispatch:
001B67r 2  A2 00                ldx     #0
001B69r 2               @find:
001B69r 2  BD rr rr             lda     FnTable,x
001B6Cr 2  F0 14                beq     @synErr                 ; reached terminator
001B6Er 2  D2 04                cmp     (TXTPTR)
001B70r 2  F0 05                beq     @match
001B72r 2  E8                   inx
001B73r 2  E8                   inx
001B74r 2  E8                   inx
001B75r 2  80 F2                bra     @find
001B77r 2               @match:
001B77r 2                       ; Push handler-1 onto stack so RTS jumps to it after ChrGet.
001B77r 2  BD rr rr             lda     FnTable+2,x
001B7Ar 2  48                   pha
001B7Br 2  BD rr rr             lda     FnTable+1,x
001B7Er 2  48                   pha
001B7Fr 2  4C rr rr             jmp     ChrGet                  ; consume token, return into handler
001B82r 2               @synErr:
001B82r 2  4C rr rr             jmp     SynErr
001B85r 2               
001B85r 2               ; ---------------------------------------------------------------------------
001B85r 2               ; FnTable -- (token, handler-1) triples, $00-terminated.
001B85r 2               ; "handler-1" because we push it through RTS which adds 1.
001B85r 2               ; ---------------------------------------------------------------------------
001B85r 2               FnTable:
001B85r 2  B6                   .byte   TOK_SGN
001B86r 2  rr rr                .word   FnSgn-1
001B88r 2  B7                   .byte   TOK_INT
001B89r 2  rr rr                .word   FnInt-1
001B8Br 2  B8                   .byte   TOK_ABS
001B8Cr 2  rr rr                .word   FnAbs-1
001B8Er 2  B9                   .byte   TOK_FRE
001B8Fr 2  rr rr                .word   FnFre-1
001B91r 2  BA                   .byte   TOK_POS
001B92r 2  rr rr                .word   FnPos-1
001B94r 2  BB                   .byte   TOK_SQR
001B95r 2  rr rr                .word   FnSqr-1
001B97r 2  BC                   .byte   TOK_RND
001B98r 2  rr rr                .word   FnRnd-1
001B9Ar 2  BD                   .byte   TOK_LOG
001B9Br 2  rr rr                .word   FnLog-1
001B9Dr 2  BE                   .byte   TOK_EXP
001B9Er 2  rr rr                .word   FnExp-1
001BA0r 2  BF                   .byte   TOK_COS
001BA1r 2  rr rr                .word   FnCos-1
001BA3r 2  C0                   .byte   TOK_SIN
001BA4r 2  rr rr                .word   FnSin-1
001BA6r 2  C1                   .byte   TOK_TAN
001BA7r 2  rr rr                .word   FnTan-1
001BA9r 2  C2                   .byte   TOK_ATN
001BAAr 2  rr rr                .word   FnAtn-1
001BACr 2  C3                   .byte   TOK_PEEK
001BADr 2  rr rr                .word   FnPeek-1
001BAFr 2  C4                   .byte   TOK_LEN
001BB0r 2  rr rr                .word   FnLen-1
001BB2r 2  C5                   .byte   TOK_STRSTR
001BB3r 2  rr rr                .word   FnStrStr-1
001BB5r 2  C6                   .byte   TOK_VAL
001BB6r 2  rr rr                .word   FnVal-1
001BB8r 2  C7                   .byte   TOK_ASC
001BB9r 2  rr rr                .word   FnAsc-1
001BBBr 2  C8                   .byte   TOK_CHRSTR
001BBCr 2  rr rr                .word   FnChrStr-1
001BBEr 2  C9                   .byte   TOK_LEFTSTR
001BBFr 2  rr rr                .word   FnLeftStr-1
001BC1r 2  CA                   .byte   TOK_RIGHTSTR
001BC2r 2  rr rr                .word   FnRightStr-1
001BC4r 2  CB                   .byte   TOK_MIDSTR
001BC5r 2  rr rr                .word   FnMidStr-1
001BC7r 2  CC                   .byte   TOK_JOY
001BC8r 2  rr rr                .word   FnJoy-1
001BCAr 2  B1                   .byte   TOK_NVRAM
001BCBr 2  rr rr                .word   FnNvram-1
001BCDr 2  CE                   .byte   TOK_HEX
001BCEr 2  rr rr                .word   FnHex-1
001BD0r 2  CF                   .byte   TOK_MIN
001BD1r 2  rr rr                .word   FnMin-1
001BD3r 2  D0                   .byte   TOK_MAX
001BD4r 2  rr rr                .word   FnMax-1
001BD6r 2  00                   .byte   0
001BD7r 2               
001BD7r 2               ; ---------------------------------------------------------------------------
001BD7r 2               ; Numeric-arg helpers.
001BD7r 2               ; ParenNum    -- expects "(" expr ")" with numeric result.  FAC = result.
001BD7r 2               ; ParenStr    -- expects "(" expr ")" with string result.
001BD7r 2               ; ParenU8     -- expects "(" expr ")" -> A = byte (0..255), or ?ILLQTY.
001BD7r 2               ; ParenU16    -- expects "(" expr ")" -> AyInt result in FAC+3,+4.
001BD7r 2               ; ---------------------------------------------------------------------------
001BD7r 2               ParenNum:
001BD7r 2  20 rr rr             jsr     ChkOpn
001BDAr 2  20 rr rr             jsr     FrmEvl
001BDDr 2  20 rr rr             jsr     ChkNum
001BE0r 2  4C rr rr             jmp     ChkCls
001BE3r 2               ParenStr:
001BE3r 2  20 rr rr             jsr     ChkOpn
001BE6r 2  20 rr rr             jsr     FrmEvl
001BE9r 2  20 rr rr             jsr     ChkStr
001BECr 2  4C rr rr             jmp     ChkCls
001BEFr 2               ParenU8:
001BEFr 2  20 rr rr             jsr     ParenNum
001BF2r 2  20 rr rr             jsr     AyInt
001BF5r 2  A5 11                lda     FAC+3                   ; high byte must be 0
001BF7r 2  D0 03                bne     @bad
001BF9r 2  A5 12                lda     FAC+4                   ; low byte = result
001BFBr 2  60                   rts
001BFCr 2               @bad:
001BFCr 2  4C rr rr             jmp     IqErr
001BFFr 2               
001BFFr 2               ; ---------------------------------------------------------------------------
001BFFr 2               ; Unary numeric functions (single-arg "(" num ")") -- shared body.
001BFFr 2               ; Each entry sets up A = handler entry to call after ChkOpn/FrmEvl/ChkNum/ChkCls.
001BFFr 2               ; ---------------------------------------------------------------------------
001BFFr 2               FnSgn:
001BFFr 2  20 rr rr             jsr     ParenNum
001C02r 2  4C rr rr             jmp     Sgn
001C05r 2               FnInt:
001C05r 2  20 rr rr             jsr     ParenNum
001C08r 2  4C rr rr             jmp     Int
001C0Br 2               FnAbs:
001C0Br 2  20 rr rr             jsr     ParenNum
001C0Er 2  4C rr rr             jmp     Abs
001C11r 2               FnSqr:
001C11r 2  20 rr rr             jsr     ParenNum
001C14r 2  4C rr rr             jmp     Sqr
001C17r 2               FnLog:
001C17r 2  20 rr rr             jsr     ParenNum
001C1Ar 2  4C rr rr             jmp     Log
001C1Dr 2               FnExp:
001C1Dr 2  20 rr rr             jsr     ParenNum
001C20r 2  4C rr rr             jmp     Exp
001C23r 2               FnCos:
001C23r 2  20 rr rr             jsr     ParenNum
001C26r 2  4C rr rr             jmp     Cos
001C29r 2               FnSin:
001C29r 2  20 rr rr             jsr     ParenNum
001C2Cr 2  4C rr rr             jmp     Sin
001C2Fr 2               FnTan:
001C2Fr 2  20 rr rr             jsr     ParenNum
001C32r 2  4C rr rr             jmp     Tan
001C35r 2               FnAtn:
001C35r 2  20 rr rr             jsr     ParenNum
001C38r 2  4C rr rr             jmp     Atn
001C3Br 2               FnRnd:
001C3Br 2  20 rr rr             jsr     ParenNum
001C3Er 2  4C rr rr             jmp     Rnd
001C41r 2               FnHex:
001C41r 2                       ; In expression context: identity.
001C41r 2  4C rr rr             jmp     ParenNum
001C44r 2               
001C44r 2               ; ---------------------------------------------------------------------------
001C44r 2               ; FnFre -- FRE(n): returns FRETOP - STREND (free string heap).
001C44r 2               ; Argument is parsed and ignored.
001C44r 2               ; ---------------------------------------------------------------------------
001C44r 2               FnFre:
001C44r 2  20 rr rr             jsr     ParenNum
001C47r 2  38                   sec
001C48r 2  AD 65 03             lda     FRETOP
001C4Br 2  ED 63 03             sbc     STREND
001C4Er 2  A8                   tay
001C4Fr 2  AD 66 03             lda     FRETOP+1
001C52r 2  ED 64 03             sbc     STREND+1
001C55r 2  4C rr rr             jmp     GivAyf
001C58r 2               
001C58r 2               ; ---------------------------------------------------------------------------
001C58r 2               ; FnPos -- POS(n): not yet maintained; returns 0.
001C58r 2               ; ---------------------------------------------------------------------------
001C58r 2               FnPos:
001C58r 2  20 rr rr             jsr     ParenNum
001C5Br 2  A0 00                ldy     #0
001C5Dr 2  4C rr rr             jmp     SngFlt
001C60r 2               
001C60r 2               ; ---------------------------------------------------------------------------
001C60r 2               ; FnPeek -- PEEK(addr): byte at addr -> FP.
001C60r 2               ; ---------------------------------------------------------------------------
001C60r 2               FnPeek:
001C60r 2  20 rr rr             jsr     ParenNum
001C63r 2  20 rr rr             jsr     FacToU16
001C66r 2  A5 12                lda     FAC+4                   ; lo byte
001C68r 2  85 20                sta     INDEX
001C6Ar 2  A5 11                lda     FAC+3                   ; hi byte
001C6Cr 2  85 21                sta     INDEX+1
001C6Er 2  A0 00                ldy     #0
001C70r 2  B1 20                lda     (INDEX),y
001C72r 2  A8                   tay
001C73r 2  4C rr rr             jmp     SngFlt
001C76r 2               
001C76r 2               ; ---------------------------------------------------------------------------
001C76r 2               ; FnJoy -- JOY(n): 1 or 2.  If GPIO absent, returns 0.
001C76r 2               ; ---------------------------------------------------------------------------
001C76r 2               FnJoy:
001C76r 2  20 rr rr             jsr     ParenU8
001C79r 2  48                   pha
001C7Ar 2  AD 0D 03             lda     HW_PRESENT
001C7Dr 2  29 20                and     #HW_GPIO
001C7Fr 2  F0 1C                beq     @absent
001C81r 2  68                   pla
001C82r 2  C9 01                cmp     #1
001C84r 2  F0 09                beq     @j1
001C86r 2  C9 02                cmp     #2
001C88r 2  F0 0C                beq     @j2
001C8Ar 2  A2 0B                ldx     #ERR_ILLQUAN
001C8Cr 2  4C rr rr             jmp     BasErrorVec
001C8Fr 2               @j1:
001C8Fr 2  20 rr rr             jsr     ReadJoystick1
001C92r 2  A8                   tay
001C93r 2  4C rr rr             jmp     SngFlt
001C96r 2               @j2:
001C96r 2  20 rr rr             jsr     ReadJoystick2
001C99r 2  A8                   tay
001C9Ar 2  4C rr rr             jmp     SngFlt
001C9Dr 2               @absent:
001C9Dr 2  68                   pla
001C9Er 2  A0 00                ldy     #0
001CA0r 2  4C rr rr             jmp     SngFlt
001CA3r 2               
001CA3r 2               ; ---------------------------------------------------------------------------
001CA3r 2               ; FnNvram -- NVRAM(addr): if RTC absent, return 0.
001CA3r 2               ; ---------------------------------------------------------------------------
001CA3r 2               FnNvram:
001CA3r 2  20 rr rr             jsr     ParenU8
001CA6r 2  48                   pha
001CA7r 2  AD 0D 03             lda     HW_PRESENT
001CAAr 2  29 04                and     #HW_RTC
001CACr 2  F0 09                beq     @absent
001CAEr 2  68                   pla
001CAFr 2  AA                   tax
001CB0r 2  20 rr rr             jsr     RtcReadNVRAM
001CB3r 2  A8                   tay
001CB4r 2  4C rr rr             jmp     SngFlt
001CB7r 2               @absent:
001CB7r 2  68                   pla
001CB8r 2  A0 00                ldy     #0
001CBAr 2  4C rr rr             jmp     SngFlt
001CBDr 2               
001CBDr 2               ; ---------------------------------------------------------------------------
001CBDr 2               ; FnMin / FnMax -- two numeric args, smaller / larger.
001CBDr 2               ; ---------------------------------------------------------------------------
001CBDr 2               FnMin:
001CBDr 2  20 rr rr             jsr     MinMaxArgs              ; ARG = a, FAC = b, BAS_TMP3 = sign(b-a)
001CC0r 2                       ; Want smaller: if b>=a return a (ARG); else return b (FAC).
001CC0r 2  10 01                bpl     @retArg                 ; sign>=0 means b>=a
001CC2r 2  60                   rts                             ; FAC already = b
001CC3r 2               @retArg:
001CC3r 2  4C rr rr             jmp     CopyArgToFac
001CC6r 2               FnMax:
001CC6r 2  20 rr rr             jsr     MinMaxArgs
001CC9r 2                       ; Want larger: if b>=a return b (FAC); else return a (ARG).
001CC9r 2  10 03                bpl     @retFac
001CCBr 2  4C rr rr             jmp     CopyArgToFac
001CCEr 2               @retFac:
001CCEr 2  60                   rts
001CCFr 2               
001CCFr 2               ; MinMaxArgs -- consume "(" a "," b ")" with numerics; ARG=a, FAC=b.
001CCFr 2               ; Returns A = sign(b - a) (FF/00/01) and N flag set accordingly.
001CCFr 2               MinMaxArgs:
001CCFr 2  20 rr rr             jsr     ChkOpn
001CD2r 2  20 rr rr             jsr     FrmEvl
001CD5r 2  20 rr rr             jsr     ChkNum
001CD8r 2  20 rr rr             jsr     PushFac                 ; save a
001CDBr 2  20 rr rr             jsr     ChkCom
001CDEr 2  20 rr rr             jsr     FrmEvl
001CE1r 2  20 rr rr             jsr     ChkNum
001CE4r 2  20 rr rr             jsr     ChkCls
001CE7r 2  20 rr rr             jsr     PullArg                 ; ARG = a, FAC = b
001CEAr 2                       ; Stash ARG so we can restore after FComp's destructive sign-pack.
001CEAr 2  A5 16                lda     ARG
001CECr 2  85 4D                sta     BAS_TEMP1
001CEEr 2  A5 17                lda     ARG+1
001CF0r 2  85 4E                sta     BAS_TEMP1+1
001CF2r 2  A5 18                lda     ARG+2
001CF4r 2  85 4F                sta     BAS_TEMP1+2
001CF6r 2  A5 19                lda     ARG+3
001CF8r 2  85 50                sta     BAS_TEMP1+3
001CFAr 2  A5 1A                lda     ARG+4
001CFCr 2  85 51                sta     BAS_TEMP1+4
001CFEr 2  A5 1B                lda     ARGSIGN
001D00r 2  85 52                sta     BAS_TEMP1+5
001D02r 2                       ; Pack ARGSIGN into bit 7 of ARG+1 so FComp reads it correctly.
001D02r 2  A5 1B                lda     ARGSIGN
001D04r 2  09 7F                ora     #$7F
001D06r 2  25 17                and     ARG+1
001D08r 2  85 17                sta     ARG+1
001D0Ar 2  A9 16                lda     #<ARG
001D0Cr 2  A0 00                ldy     #$00
001D0Er 2  20 rr rr             jsr     FComp                   ; A = sign(FAC - ARG)
001D11r 2  48                   pha
001D12r 2                       ; Restore ARG.
001D12r 2  A5 4D                lda     BAS_TEMP1
001D14r 2  85 16                sta     ARG
001D16r 2  A5 4E                lda     BAS_TEMP1+1
001D18r 2  85 17                sta     ARG+1
001D1Ar 2  A5 4F                lda     BAS_TEMP1+2
001D1Cr 2  85 18                sta     ARG+2
001D1Er 2  A5 50                lda     BAS_TEMP1+3
001D20r 2  85 19                sta     ARG+3
001D22r 2  A5 51                lda     BAS_TEMP1+4
001D24r 2  85 1A                sta     ARG+4
001D26r 2  A5 52                lda     BAS_TEMP1+5
001D28r 2  85 1B                sta     ARGSIGN
001D2Ar 2  68                   pla                             ; restore A, sets N/Z flags
001D2Br 2  60                   rts
001D2Cr 2               
001D2Cr 2               ; ---------------------------------------------------------------------------
001D2Cr 2               ; FnLen -- LEN(s$): length of string.
001D2Cr 2               ; ---------------------------------------------------------------------------
001D2Cr 2               FnLen:
001D2Cr 2  20 rr rr             jsr     ParenStr
001D2Fr 2  A4 0E                ldy     FAC                     ; length
001D31r 2  20 rr rr             jsr     FreFac                  ; release temp string if any
001D34r 2  4C rr rr             jmp     SngFlt
001D37r 2               
001D37r 2               ; ---------------------------------------------------------------------------
001D37r 2               ; FnAsc -- ASC(s$): code of first char; ?ILLQTY if empty.
001D37r 2               ; ---------------------------------------------------------------------------
001D37r 2               FnAsc:
001D37r 2  20 rr rr             jsr     ParenStr
001D3Ar 2  A5 0E                lda     FAC
001D3Cr 2  F0 15                beq     @bad
001D3Er 2                       ; Read first byte of string.
001D3Er 2  A5 0F                lda     FAC+1
001D40r 2  85 20                sta     INDEX
001D42r 2  A5 10                lda     FAC+2
001D44r 2  85 21                sta     INDEX+1
001D46r 2  A0 00                ldy     #0
001D48r 2  B1 20                lda     (INDEX),y
001D4Ar 2  48                   pha
001D4Br 2  20 rr rr             jsr     FreFac
001D4Er 2  68                   pla
001D4Fr 2  A8                   tay
001D50r 2  4C rr rr             jmp     SngFlt
001D53r 2               @bad:
001D53r 2  4C rr rr             jmp     IqErr
001D56r 2               
001D56r 2               ; ---------------------------------------------------------------------------
001D56r 2               ; FnChrStr -- CHR$(n): 1-char string.
001D56r 2               ; ---------------------------------------------------------------------------
001D56r 2               FnChrStr:
001D56r 2  20 rr rr             jsr     ParenU8
001D59r 2  48                   pha
001D5Ar 2  A9 01                lda     #1
001D5Cr 2  20 rr rr             jsr     GetSpa                  ; (Y,X) = addr; A unchanged
001D5Fr 2  68                   pla
001D60r 2  A0 00                ldy     #0
001D62r 2  91 84                sta     (FRESPC),y
001D64r 2                       ; Build descriptor in FAC.
001D64r 2  A9 01                lda     #1
001D66r 2  85 0E                sta     FAC
001D68r 2  A5 84                lda     FRESPC
001D6Ar 2  85 0F                sta     FAC+1
001D6Cr 2  A5 85                lda     FRESPC+1
001D6Er 2  85 10                sta     FAC+2
001D70r 2                       ; Advance FRESPC past the byte we just wrote.
001D70r 2  E6 84                inc     FRESPC
001D72r 2  D0 02                bne     @nb
001D74r 2  E6 85                inc     FRESPC+1
001D76r 2               @nb:
001D76r 2  4C rr rr             jmp     PutNew
001D79r 2               
001D79r 2               ; ---------------------------------------------------------------------------
001D79r 2               ; FnStrStr -- STR$(n): convert numeric to string.
001D79r 2               ; ---------------------------------------------------------------------------
001D79r 2               FnStrStr:
001D79r 2  20 rr rr             jsr     ParenNum
001D7Cr 2  20 rr rr             jsr     Fout                    ; A=lo, Y=hi -> NUL-terminated buffer
001D7Fr 2                       ; (A,Y) = pointer to NUL-terminated ASCII number string in STACK2.
001D7Fr 2  20 rr rr             jsr     StrLit                  ; allocates + copies + PutNew
001D82r 2  60                   rts
001D83r 2               
001D83r 2               ; ---------------------------------------------------------------------------
001D83r 2               ; FnVal -- VAL(s$): parse leading numeric from string.
001D83r 2               ; Temporarily NUL-terminates the string in place, redirects TXTPTR, calls
001D83r 2               ; Fin, then restores.
001D83r 2               ; ---------------------------------------------------------------------------
001D83r 2               FnVal:
001D83r 2  20 rr rr             jsr     ParenStr
001D86r 2  A5 0E                lda     FAC
001D88r 2  D0 06                bne     @nz
001D8Ar 2                       ; empty string -> 0
001D8Ar 2  20 rr rr             jsr     FreFac
001D8Dr 2  4C rr rr             jmp     ZeroFac
001D90r 2               @nz:
001D90r 2                       ; Stash length, address into TEMP1..TEMP1+2.
001D90r 2  85 4D                sta     TEMP1                   ; length
001D92r 2  A5 0F                lda     FAC+1
001D94r 2  85 4E                sta     TEMP1+1
001D96r 2  A5 10                lda     FAC+2
001D98r 2  85 4F                sta     TEMP1+2
001D9Ar 2                       ; Save the byte at offset = length and replace with $00.
001D9Ar 2  A5 4E                lda     TEMP1+1
001D9Cr 2  85 20                sta     INDEX
001D9Er 2  A5 4F                lda     TEMP1+2
001DA0r 2  85 21                sta     INDEX+1
001DA2r 2  A4 4D                ldy     TEMP1
001DA4r 2  B1 20                lda     (INDEX),y
001DA6r 2  85 50                sta     TEMP1+3                 ; saved byte
001DA8r 2  A9 00                lda     #0
001DAAr 2  91 20                sta     (INDEX),y
001DACr 2                       ; Save TXTPTR.
001DACr 2  A5 04                lda     TXTPTR
001DAEr 2  48                   pha
001DAFr 2  A5 05                lda     TXTPTR+1
001DB1r 2  48                   pha
001DB2r 2                       ; TXTPTR := INDEX - 1, then ChrGet to load first char.
001DB2r 2  A5 4E                lda     TEMP1+1
001DB4r 2  85 04                sta     TXTPTR
001DB6r 2  A5 4F                lda     TEMP1+2
001DB8r 2  85 05                sta     TXTPTR+1
001DBAr 2  A5 04                lda     TXTPTR
001DBCr 2  D0 02                bne     @nb
001DBEr 2  C6 05                dec     TXTPTR+1
001DC0r 2               @nb:
001DC0r 2  C6 04                dec     TXTPTR
001DC2r 2  20 rr rr             jsr     ChrGet                  ; first char
001DC5r 2  20 rr rr             jsr     Fin                     ; FAC := value
001DC8r 2                       ; Restore the saved byte.
001DC8r 2  A5 4E                lda     TEMP1+1
001DCAr 2  85 20                sta     INDEX
001DCCr 2  A5 4F                lda     TEMP1+2
001DCEr 2  85 21                sta     INDEX+1
001DD0r 2  A4 4D                ldy     TEMP1
001DD2r 2  A5 50                lda     TEMP1+3
001DD4r 2  91 20                sta     (INDEX),y
001DD6r 2                       ; Restore TXTPTR.
001DD6r 2  68                   pla
001DD7r 2  85 05                sta     TXTPTR+1
001DD9r 2  68                   pla
001DDAr 2  85 04                sta     TXTPTR
001DDCr 2  60                   rts
001DDDr 2               
001DDDr 2               ; ---------------------------------------------------------------------------
001DDDr 2               ; FnLeftStr -- LEFT$(s$, n): leftmost n chars.
001DDDr 2               ; ---------------------------------------------------------------------------
001DDDr 2               FnLeftStr:
001DDDr 2  20 rr rr             jsr     ChkOpn
001DE0r 2  20 rr rr             jsr     FrmEvl
001DE3r 2  20 rr rr             jsr     ChkStr
001DE6r 2  20 rr rr             jsr     ChkCom
001DE9r 2  20 rr rr             jsr     PushFac                 ; save string descriptor
001DECr 2  20 rr rr             jsr     FrmEvl
001DEFr 2  20 rr rr             jsr     ChkNum
001DF2r 2  20 rr rr             jsr     ChkCls
001DF5r 2  20 rr rr             jsr     AyInt
001DF8r 2  20 rr rr             jsr     PullArg                 ; ARG = string descriptor (BAS_TMP1 clobbered)
001DFBr 2                       ; FAC still holds the integer n; check range and copy now.
001DFBr 2  A5 11                lda     FAC+3
001DFDr 2  D0 16                bne     @bad
001DFFr 2  A5 12                lda     FAC+4
001E01r 2  85 3B                sta     BAS_TMP1+1              ; n
001E03r 2                       ; Clamp n to ARG (length).
001E03r 2  A5 3B                lda     BAS_TMP1+1
001E05r 2  C5 16                cmp     ARG
001E07r 2  90 02                bcc     @ok
001E09r 2  A5 16                lda     ARG
001E0Br 2               @ok:
001E0Br 2  85 3B                sta     BAS_TMP1+1
001E0Dr 2                       ; Free the source temp BEFORE allocating result so the slot frees up.
001E0Dr 2  20 rr rr             jsr     FreeArgString
001E10r 2                       ; Offset = 0 for LEFT$.
001E10r 2  64 3A                stz     BAS_TMP1
001E12r 2                       ; Allocate, copy first n bytes.
001E12r 2  4C rr rr             jmp     SubstrCommon            ; tail-call (rts to caller)
001E15r 2               @bad:
001E15r 2  4C rr rr             jmp     IqErr
001E18r 2               
001E18r 2               ; ---------------------------------------------------------------------------
001E18r 2               ; FnRightStr -- RIGHT$(s$, n): rightmost n chars.
001E18r 2               ; ---------------------------------------------------------------------------
001E18r 2               FnRightStr:
001E18r 2  20 rr rr             jsr     ChkOpn
001E1Br 2  20 rr rr             jsr     FrmEvl
001E1Er 2  20 rr rr             jsr     ChkStr
001E21r 2  20 rr rr             jsr     ChkCom
001E24r 2  20 rr rr             jsr     PushFac
001E27r 2  20 rr rr             jsr     FrmEvl
001E2Ar 2  20 rr rr             jsr     ChkNum
001E2Dr 2  20 rr rr             jsr     ChkCls
001E30r 2  20 rr rr             jsr     AyInt
001E33r 2  20 rr rr             jsr     PullArg                 ; ARG = string descriptor (BAS_TMP1 clobbered)
001E36r 2  A5 11                lda     FAC+3
001E38r 2  D0 1B                bne     @bad
001E3Ar 2  A5 12                lda     FAC+4
001E3Cr 2  85 3B                sta     BAS_TMP1+1              ; n
001E3Er 2                       ; Clamp n.
001E3Er 2  A5 3B                lda     BAS_TMP1+1
001E40r 2  C5 16                cmp     ARG
001E42r 2  90 02                bcc     @ok
001E44r 2  A5 16                lda     ARG
001E46r 2               @ok:
001E46r 2  85 3B                sta     BAS_TMP1+1
001E48r 2                       ; offset = ARG - n.
001E48r 2  A5 16                lda     ARG
001E4Ar 2  38                   sec
001E4Br 2  E5 3B                sbc     BAS_TMP1+1
001E4Dr 2  85 3A                sta     BAS_TMP1                ; start offset
001E4Fr 2  20 rr rr             jsr     FreeArgString
001E52r 2  4C rr rr             jmp     SubstrCommon
001E55r 2               @bad:
001E55r 2  4C rr rr             jmp     IqErr
001E58r 2               
001E58r 2               ; ---------------------------------------------------------------------------
001E58r 2               ; FnMidStr -- MID$(s$, m [, n]): substring starting at m (1-based).
001E58r 2               ; ---------------------------------------------------------------------------
001E58r 2               FnMidStr:
001E58r 2  20 rr rr             jsr     ChkOpn
001E5Br 2  20 rr rr             jsr     FrmEvl
001E5Er 2  20 rr rr             jsr     ChkStr
001E61r 2  20 rr rr             jsr     ChkCom
001E64r 2  20 rr rr             jsr     PushFac
001E67r 2                       ; Read m.
001E67r 2  20 rr rr             jsr     FrmEvl
001E6Ar 2  20 rr rr             jsr     ChkNum
001E6Dr 2  20 rr rr             jsr     AyInt
001E70r 2  A5 11                lda     FAC+3
001E72r 2  D0 4B                bne     @bad
001E74r 2  A5 12                lda     FAC+4
001E76r 2  F0 47                beq     @bad                    ; m must be >= 1
001E78r 2  38                   sec
001E79r 2  E9 01                sbc     #1
001E7Br 2  85 3A                sta     BAS_TMP1                ; offset = m-1
001E7Dr 2                       ; Optional ", n".
001E7Dr 2  20 rr rr             jsr     ChrGot
001E80r 2  C9 2C                cmp     #','
001E82r 2  F0 06                beq     @hasN
001E84r 2                       ; No n: take rest -> n = 255 (will clamp).
001E84r 2  A9 FF                lda     #255
001E86r 2  85 3B                sta     BAS_TMP1+1
001E88r 2  80 14                bra     @cls
001E8Ar 2               @hasN:
001E8Ar 2  20 rr rr             jsr     ChrGet
001E8Dr 2  20 rr rr             jsr     FrmEvl
001E90r 2  20 rr rr             jsr     ChkNum
001E93r 2  20 rr rr             jsr     AyInt
001E96r 2  A5 11                lda     FAC+3
001E98r 2  D0 25                bne     @bad
001E9Ar 2  A5 12                lda     FAC+4
001E9Cr 2  85 3B                sta     BAS_TMP1+1
001E9Er 2               @cls:
001E9Er 2  20 rr rr             jsr     ChkCls
001EA1r 2  20 rr rr             jsr     PullArg                 ; ARG = string
001EA4r 2                       ; Clamp offset to length.
001EA4r 2  A5 3A                lda     BAS_TMP1
001EA6r 2  C5 16                cmp     ARG
001EA8r 2  90 04                bcc     @offOk
001EAAr 2  A5 16                lda     ARG                     ; offset = length -> empty result
001EACr 2  85 3A                sta     BAS_TMP1
001EAEr 2               @offOk:
001EAEr 2                       ; Clamp n to (length - offset).
001EAEr 2  38                   sec
001EAFr 2  A5 16                lda     ARG
001EB1r 2  E5 3A                sbc     BAS_TMP1
001EB3r 2  C5 3B                cmp     BAS_TMP1+1
001EB5r 2  B0 02                bcs     @nOk
001EB7r 2  85 3B                sta     BAS_TMP1+1
001EB9r 2               @nOk:
001EB9r 2  20 rr rr             jsr     FreeArgString
001EBCr 2  4C rr rr             jmp     SubstrCommon
001EBFr 2               @bad:
001EBFr 2  4C rr rr             jmp     IqErr
001EC2r 2               
001EC2r 2               ; ---------------------------------------------------------------------------
001EC2r 2               ; SubstrCommon -- copy BAS_TMP1+1 bytes from ARG-string at offset BAS_TMP1
001EC2r 2               ; into a new heap allocation; result descriptor in FAC; PutNew.
001EC2r 2               ; ---------------------------------------------------------------------------
001EC2r 2               SubstrCommon:
001EC2r 2                       ; Allocate.
001EC2r 2  A5 3B                lda     BAS_TMP1+1
001EC4r 2  20 rr rr             jsr     GetSpa                  ; FRESPC = new buffer
001EC7r 2                       ; Source pointer = ARG+1 (lo/hi) + BAS_TMP1.
001EC7r 2  18                   clc
001EC8r 2  A5 17                lda     ARG+1
001ECAr 2  65 3A                adc     BAS_TMP1
001ECCr 2  85 20                sta     INDEX
001ECEr 2  A5 18                lda     ARG+2
001ED0r 2  69 00                adc     #0
001ED2r 2  85 21                sta     INDEX+1
001ED4r 2                       ; Copy BAS_TMP1+1 bytes from (INDEX) to (FRESPC).
001ED4r 2  A4 3B                ldy     BAS_TMP1+1
001ED6r 2  F0 0B                beq     @done
001ED8r 2  A0 00                ldy     #0
001EDAr 2               @cp:
001EDAr 2  B1 20                lda     (INDEX),y
001EDCr 2  91 84                sta     (FRESPC),y
001EDEr 2  C8                   iny
001EDFr 2  C4 3B                cpy     BAS_TMP1+1
001EE1r 2  D0 F7                bne     @cp
001EE3r 2               @done:
001EE3r 2                       ; Build descriptor.
001EE3r 2  A5 3B                lda     BAS_TMP1+1
001EE5r 2  85 0E                sta     FAC
001EE7r 2  A5 84                lda     FRESPC
001EE9r 2  85 0F                sta     FAC+1
001EEBr 2  A5 85                lda     FRESPC+1
001EEDr 2  85 10                sta     FAC+2
001EEFr 2                       ; Advance FRESPC by length consumed.
001EEFr 2  18                   clc
001EF0r 2  A5 84                lda     FRESPC
001EF2r 2  65 3B                adc     BAS_TMP1+1
001EF4r 2  85 84                sta     FRESPC
001EF6r 2  90 02                bcc     @nb
001EF8r 2  E6 85                inc     FRESPC+1
001EFAr 2               @nb:
001EFAr 2  4C rr rr             jmp     PutNew
001EFDr 2               
001EFDr 2               ; FreeArgString -- if ARG holds a temp string descriptor (most-recent
001EFDr 2               ; on TEMPST), pop just the descriptor.  Heap is left intact so callers
001EFDr 2               ; that still need the source bytes can copy them safely; orphaned heap
001EFDr 2               ; will be reclaimed by Garbag.
001EFDr 2               FreeArgString:
001EFDr 2  A5 19                lda     ARG+3                   ; descriptor address lo
001EFFr 2  A4 1A                ldy     ARG+4                   ; descriptor address hi (always $00)
001F01r 2  4C rr rr             jmp     FreTms
001F04r 2               
001F04r 2               ; Cleanup that releases both ARG's and FAC's temp descriptors (called from
001F04r 2               ; CatStr after content has been stashed but before new allocation).
001F04r 2               FreeBothTemps:
001F04r 2                       ; Free FAC's temp first (it is currently LASTPT).
001F04r 2  A5 11                lda     FAC+3
001F06r 2  A4 12                ldy     FAC+4
001F08r 2  20 rr rr             jsr     FreTms
001F0Br 2                       ; Then ARG's (now LASTPT after FAC's removal).
001F0Br 2  A5 19                lda     ARG+3
001F0Dr 2  A4 1A                ldy     ARG+4
001F0Fr 2  4C rr rr             jmp     FreTms
001F12r 2  60                   rts
001F13r 2               
001F13r 2               ; ===========================================================================
001F13r 2               ;   E V A L U A T O R   -   B I N A R Y   O P E R A T O R   H E L P E R S
001F13r 2               ; ===========================================================================
001F13r 2               
001F13r 2               ; ---------------------------------------------------------------------------
001F13r 2               ; AndOp -- FAC = ARG AND FAC (bitwise on 16-bit signed ints).
001F13r 2               ; ---------------------------------------------------------------------------
001F13r 2               AndOp:
001F13r 2  20 rr rr             jsr     AyInt                   ; FAC -> int (FAC+3=hi, FAC+4=lo)
001F16r 2  A5 11                lda     FAC+3
001F18r 2  85 3A                sta     BAS_TMP1                ; saved hi
001F1Ar 2  A5 12                lda     FAC+4
001F1Cr 2  85 3B                sta     BAS_TMP1+1              ; saved lo
001F1Er 2  20 rr rr             jsr     CopyArgToFac
001F21r 2  20 rr rr             jsr     AyInt
001F24r 2  A5 12                lda     FAC+4
001F26r 2  25 3B                and     BAS_TMP1+1
001F28r 2  A8                   tay                             ; Y = lo result
001F29r 2  A5 11                lda     FAC+3
001F2Br 2  25 3A                and     BAS_TMP1                ; A = hi result
001F2Dr 2  4C rr rr             jmp     GivAyf
001F30r 2               
001F30r 2               ; ---------------------------------------------------------------------------
001F30r 2               ; OrOp -- FAC = ARG OR FAC.
001F30r 2               ; ---------------------------------------------------------------------------
001F30r 2               OrOp:
001F30r 2  20 rr rr             jsr     AyInt
001F33r 2  A5 11                lda     FAC+3
001F35r 2  85 3A                sta     BAS_TMP1                ; saved hi
001F37r 2  A5 12                lda     FAC+4
001F39r 2  85 3B                sta     BAS_TMP1+1              ; saved lo
001F3Br 2  20 rr rr             jsr     CopyArgToFac
001F3Er 2  20 rr rr             jsr     AyInt
001F41r 2  A5 12                lda     FAC+4
001F43r 2  05 3B                ora     BAS_TMP1+1
001F45r 2  A8                   tay                             ; Y = lo
001F46r 2  A5 11                lda     FAC+3
001F48r 2  05 3A                ora     BAS_TMP1                ; A = hi
001F4Ar 2  4C rr rr             jmp     GivAyf
001F4Dr 2               
001F4Dr 2               ; ---------------------------------------------------------------------------
001F4Dr 2               ; NotOp -- FAC = NOT FAC (bitwise complement of 16-bit signed int).
001F4Dr 2               ; ---------------------------------------------------------------------------
001F4Dr 2               NotOp:
001F4Dr 2  20 rr rr             jsr     AyInt
001F50r 2  A5 12                lda     FAC+4
001F52r 2  49 FF                eor     #$FF
001F54r 2  A8                   tay                             ; Y = lo
001F55r 2  A5 11                lda     FAC+3
001F57r 2  49 FF                eor     #$FF                    ; A = hi
001F59r 2  4C rr rr             jmp     GivAyf
001F5Cr 2               
001F5Cr 2               ; ---------------------------------------------------------------------------
001F5Cr 2               ; BasCmdLet -- minimal LET (assignment).  Entered with ChrGot returning
001F5Cr 2               ; the first letter of the variable name.  No `LET` keyword required.
001F5Cr 2               ; ---------------------------------------------------------------------------
001F5Cr 2               BasCmdLet:
001F5Cr 2  20 rr rr             jsr     PtrGet                  ; VARPNT, VALTYP set; TXTPTR past name
001F5Fr 2                       ; Save VARPNT and the variable's VALTYP across FrmEvl.
001F5Fr 2  A5 3F                lda     VARPNT
001F61r 2  48                   pha
001F62r 2  A5 40                lda     VARPNT+1
001F64r 2  48                   pha
001F65r 2  A5 64                lda     VALTYP
001F67r 2  48                   pha
001F68r 2  20 rr rr             jsr     ChrGot
001F6Br 2  C9 3D                cmp     #'='
001F6Dr 2  D0 2F                bne     @synErr
001F6Fr 2  20 rr rr             jsr     ChrGet
001F72r 2  20 rr rr             jsr     FrmEvl
001F75r 2  68                   pla                             ; saved variable VALTYP
001F76r 2  85 3E                sta     BAS_TMP3
001F78r 2  45 64                eor     VALTYP
001F7Ar 2  30 28                bmi     @typeErr
001F7Cr 2  68                   pla
001F7Dr 2  85 40                sta     VARPNT+1
001F7Fr 2  68                   pla
001F80r 2  85 3F                sta     VARPNT
001F82r 2  24 3E                bit     BAS_TMP3
001F84r 2  30 07                bmi     @storeStr
001F86r 2                       ; Numeric: store FAC into (VARPNT) (5 bytes).
001F86r 2  A6 3F                ldx     VARPNT
001F88r 2  A4 40                ldy     VARPNT+1
001F8Ar 2  4C rr rr             jmp     StoreFacAtYxRounded
001F8Dr 2               @storeStr:
001F8Dr 2  A0 00                ldy     #0
001F8Fr 2  A5 0E                lda     FAC
001F91r 2  91 3F                sta     (VARPNT),y
001F93r 2  C8                   iny
001F94r 2  A5 0F                lda     FAC+1
001F96r 2  91 3F                sta     (VARPNT),y
001F98r 2  C8                   iny
001F99r 2  A5 10                lda     FAC+2
001F9Br 2  91 3F                sta     (VARPNT),y
001F9Dr 2  60                   rts
001F9Er 2               @synErr:
001F9Er 2  68                   pla
001F9Fr 2  68                   pla
001FA0r 2  68                   pla
001FA1r 2  4C rr rr             jmp     SynErr
001FA4r 2               @typeErr:
001FA4r 2  68                   pla
001FA5r 2  68                   pla
001FA6r 2  A2 08                ldx     #ERR_TYPEMISM
001FA8r 2  4C rr rr             jmp     BasErrorVec
001FABr 2               
001FABr 2               ; =============================================================================
001FABr 2               ;   C O N T R O L   F L O W   /   S T A T E M E N T   L O O P
001FABr 2               ;
001FABr 2               ;   BasNewstt drives execution for both direct mode (TXTPTR in BAS_TOKBUF)
001FABr 2               ;   and run mode (TXTPTR walks program lines from BAS_TXTTAB).  Statement
001FABr 2               ;   dispatch follows the msbasic convention: push (routine_addr - 1) and
001FABr 2               ;   tail-jump through ChrGet, so the routine entry is reached via RTS.
001FABr 2               ;
001FABr 2               ;   FOR and GOSUB store frames on the CPU stack and JMP back to BasNewstt;
001FABr 2               ;   NEXT and RETURN scan the stack for a matching tag, then TXS to discard
001FABr 2               ;   the frame and resume.
001FABr 2               ; =============================================================================
001FABr 2               
001FABr 2               NUM_STMT_TOKENS = TOK_MEM + 1 - TOK_BASE       ; $36 entries
001FABr 2               
001FABr 2               BasNewstt:
001FABr 2  20 rr rr             jsr     BasCheckBreak
001FAEr 2                       ; Save TXTPTR -> OLDTEXT for CONT, except in direct mode.
001FAEr 2  AD 6A 03             lda     BAS_CURLIN+1
001FB1r 2  C9 FF                cmp     #$FF
001FB3r 2  F0 0A                beq     @noSave
001FB5r 2  A5 04                lda     TXTPTR
001FB7r 2  8D 6D 03             sta     BAS_OLDTEXT
001FBAr 2  A5 05                lda     TXTPTR+1
001FBCr 2  8D 6E 03             sta     BAS_OLDTEXT+1
001FBFr 2               @noSave:
001FBFr 2  A0 00                ldy     #0
001FC1r 2  B1 04                lda     (TXTPTR),y
001FC3r 2  F0 10                beq     @endLine
001FC5r 2  C9 A4                cmp     #TOK_ELSE
001FC7r 2  F0 07                beq     @skipElse               ; THEN-branch ran; skip ELSE clause to EOL
001FC9r 2  C9 3A                cmp     #':'
001FCBr 2  F0 34                beq     @nextStmt
001FCDr 2  4C rr rr             jmp     SynErr
001FD0r 2               @skipElse:
001FD0r 2                       ; Advance TXTPTR until we land on a $00 terminator.
001FD0r 2               @skLoop:
001FD0r 2  20 rr rr             jsr     ChrGet
001FD3r 2  D0 FB                bne     @skLoop
001FD5r 2                       ; Fall through to @endLine with TXTPTR at $00.
001FD5r 2               @endLine:
001FD5r 2                       ; Direct mode: end of buffer -> back to REPL.
001FD5r 2  AD 6A 03             lda     BAS_CURLIN+1
001FD8r 2  C9 FF                cmp     #$FF
001FDAr 2  D0 03                bne     @walkNext
001FDCr 2  4C rr rr             jmp     BasReadyLoop            ; OK is printed by BasReadyLoop
001FDFr 2               @walkNext:
001FDFr 2                       ; Run mode: examine next-pointer at offsets +1,+2.
001FDFr 2  A0 02                ldy     #2
001FE1r 2  B1 04                lda     (TXTPTR),y
001FE3r 2  D0 06                bne     @loadLine               ; nonzero hi -> next line exists
001FE5r 2                       ; End of program -> halt and return to REPL.
001FE5r 2  A2 FF                ldx     #$FF
001FE7r 2  9A                   txs
001FE8r 2  4C rr rr             jmp     BasReadyLoop
001FEBr 2               @loadLine:
001FEBr 2  C8                   iny                             ; y=3
001FECr 2  B1 04                lda     (TXTPTR),y
001FEEr 2  8D 69 03             sta     BAS_CURLIN
001FF1r 2  C8                   iny                             ; y=4
001FF2r 2  B1 04                lda     (TXTPTR),y
001FF4r 2  8D 6A 03             sta     BAS_CURLIN+1
001FF7r 2  98                   tya                             ; A=4
001FF8r 2  18                   clc
001FF9r 2  65 04                adc     TXTPTR
001FFBr 2  85 04                sta     TXTPTR
001FFDr 2  90 02                bcc     @nextStmt
001FFFr 2  E6 05                inc     TXTPTR+1
002001r 2               @nextStmt:
002001r 2  20 rr rr             jsr     ChrGet
002004r 2  20 rr rr             jsr     BasExecuteStatement
002007r 2  4C rr rr             jmp     BasNewstt
00200Ar 2               
00200Ar 2               ; ---------------------------------------------------------------------------
00200Ar 2               ; BasExecuteStatement -- A = current tokenized byte (loaded by ChrGet).
00200Ar 2               ;   * A = 0  -> RTS (no-op; end of statement chain).
00200Ar 2               ;   * A < $80 (letter) -> JMP BasCmdLet.
00200Ar 2               ;   * A is a statement token ($80..TOK_MEM) -> dispatch via BasTokenAddrTbl.
00200Ar 2               ;   * Otherwise -> ?SYNTAX ERROR.
00200Ar 2               ; ---------------------------------------------------------------------------
00200Ar 2               BasExecuteStatement:
00200Ar 2  F0 1C                beq     @ret
00200Cr 2  38                   sec
00200Dr 2  E9 80                sbc     #TOK_BASE
00200Fr 2  90 11                bcc     @doLet
002011r 2  C9 36                cmp     #NUM_STMT_TOKENS
002013r 2  B0 10                bcs     @synErr
002015r 2  0A                   asl     a
002016r 2  A8                   tay
002017r 2  B9 rr rr             lda     BasTokenAddrTbl+1,y
00201Ar 2  48                   pha
00201Br 2  B9 rr rr             lda     BasTokenAddrTbl,y
00201Er 2  48                   pha
00201Fr 2  4C rr rr             jmp     ChrGet
002022r 2               @doLet:
002022r 2  4C rr rr             jmp     BasCmdLet
002025r 2               @synErr:
002025r 2  4C rr rr             jmp     SynErr
002028r 2               @ret:
002028r 2  60                   rts
002029r 2               
002029r 2               ; ---------------------------------------------------------------------------
002029r 2               ; BasCheckBreak -- poll input buffer for Ctrl-C / ESC.  On break, save
002029r 2               ; CONT context and bounce to REPL.  Other keys are stashed in BAS_PENDKEY
002029r 2               ; for INKEY to retrieve.
002029r 2               ; ---------------------------------------------------------------------------
002029r 2               BasCheckBreak:
002029r 2                       ; In direct mode (CURLIN hi == $FF) skip the break check entirely;
002029r 2                       ; otherwise we would drain pending REPL keystrokes and corrupt the
002029r 2                       ; next BasReadLine input.  Break is only meaningful while RUNning.
002029r 2  AD 6A 03             lda     BAS_CURLIN+1
00202Cr 2  C9 FF                cmp     #$FF
00202Er 2  F0 13                beq     @no
002030r 2  20 rr rr             jsr     BufferSize
002033r 2  F0 0E                beq     @no
002035r 2  20 rr rr             jsr     ReadBuffer
002038r 2  C9 03                cmp     #$03
00203Ar 2  F0 08                beq     @break
00203Cr 2  C9 1B                cmp     #$1B
00203Er 2  F0 04                beq     @break
002040r 2  8D 0E 03             sta     BAS_PENDKEY
002043r 2               @no:
002043r 2  60                   rts
002044r 2               @break:
002044r 2                       ; OLDLIN/OLDTEXT already track the executing line.  Make sure the
002044r 2                       ; saved values reflect the current line so CONT can resume.
002044r 2  AD 69 03             lda     BAS_CURLIN
002047r 2  8D 6B 03             sta     BAS_OLDLIN
00204Ar 2  AD 6A 03             lda     BAS_CURLIN+1
00204Dr 2  8D 6C 03             sta     BAS_OLDLIN+1
002050r 2  A2 FF                ldx     #$FF
002052r 2  9A                   txs
002053r 2  20 rr rr             jsr     BasPrintCRLF
002056r 2  A9 rr                lda     #<MsgBreak
002058r 2  A0 rr                ldy     #>MsgBreak
00205Ar 2  20 rr rr             jsr     BasPrintStr
00205Dr 2  AD 6A 03             lda     BAS_CURLIN+1
002060r 2  C9 FF                cmp     #$FF
002062r 2  F0 14                beq     @noLine
002064r 2  A9 rr                lda     #<MsgInWord
002066r 2  A0 rr                ldy     #>MsgInWord
002068r 2  20 rr rr             jsr     BasPrintStr
00206Br 2  AD 69 03             lda     BAS_CURLIN
00206Er 2  85 08                sta     BAS_LINNUM
002070r 2  AD 6A 03             lda     BAS_CURLIN+1
002073r 2  85 09                sta     BAS_LINNUM+1
002075r 2  20 rr rr             jsr     BasPrintLineNum
002078r 2               @noLine:
002078r 2  A9 FF                lda     #$FF
00207Ar 2  8D 69 03             sta     BAS_CURLIN
00207Dr 2  8D 6A 03             sta     BAS_CURLIN+1
002080r 2  4C rr rr             jmp     BasReadyLoop
002083r 2               
002083r 2  42 52 45 41  MsgBreak: .byte "BREAK",0
002087r 2  4B 00        
002089r 2               
002089r 2               ; ---------------------------------------------------------------------------
002089r 2               ; LinGet -- parse decimal digits at TXTPTR into BAS_LINNUM (16-bit).
002089r 2               ; Caller has set carry conditions appropriate to ChrGet entry.  TXTPTR
002089r 2               ; ends pointing at the first non-digit.
002089r 2               ; ---------------------------------------------------------------------------
002089r 2               LinGet:
002089r 2  A2 00                ldx     #0
00208Br 2  86 08                stx     BAS_LINNUM
00208Dr 2  86 09                stx     BAS_LINNUM+1
00208Fr 2               @loop:
00208Fr 2  B0 3A                bcs     @done
002091r 2  E9 2F                sbc     #$2F                    ; carry already set
002093r 2  85 44                sta     CHARAC
002095r 2                       ; LINNUM *= 10
002095r 2  A5 08                lda     BAS_LINNUM
002097r 2  85 3A                sta     BAS_TMP1
002099r 2  A5 09                lda     BAS_LINNUM+1
00209Br 2  85 3B                sta     BAS_TMP1+1
00209Dr 2  C9 19                cmp     #$19
00209Fr 2  B0 2B                bcs     @ovf
0020A1r 2  06 08                asl     BAS_LINNUM
0020A3r 2  26 09                rol     BAS_LINNUM+1
0020A5r 2  06 08                asl     BAS_LINNUM
0020A7r 2  26 09                rol     BAS_LINNUM+1
0020A9r 2  18                   clc
0020AAr 2  A5 08                lda     BAS_LINNUM
0020ACr 2  65 3A                adc     BAS_TMP1
0020AEr 2  85 08                sta     BAS_LINNUM
0020B0r 2  A5 09                lda     BAS_LINNUM+1
0020B2r 2  65 3B                adc     BAS_TMP1+1
0020B4r 2  85 09                sta     BAS_LINNUM+1
0020B6r 2  06 08                asl     BAS_LINNUM
0020B8r 2  26 09                rol     BAS_LINNUM+1
0020BAr 2  18                   clc
0020BBr 2  A5 08                lda     BAS_LINNUM
0020BDr 2  65 44                adc     CHARAC
0020BFr 2  85 08                sta     BAS_LINNUM
0020C1r 2  90 02                bcc     @nextDigit
0020C3r 2  E6 09                inc     BAS_LINNUM+1
0020C5r 2               @nextDigit:
0020C5r 2  20 rr rr             jsr     ChrGet
0020C8r 2  4C rr rr             jmp     @loop
0020CBr 2               @done:
0020CBr 2  60                   rts
0020CCr 2               @ovf:
0020CCr 2  A2 00                ldx     #ERR_SYNTAX
0020CEr 2  4C rr rr             jmp     BasErrorVec
0020D1r 2               
0020D1r 2               ; ---------------------------------------------------------------------------
0020D1r 2               ; FndLin -- find program line whose number matches BAS_LINNUM.
0020D1r 2               ;   On success: carry SET, BAS_TMP1 (LOWTR alias) = address of line.
0020D1r 2               ;   On failure: carry CLEAR, BAS_TMP1 = address where line would belong.
0020D1r 2               ; ---------------------------------------------------------------------------
0020D1r 2               FndLin:
0020D1r 2  AD 5D 03             lda     BAS_TXTTAB
0020D4r 2  AE 5E 03             ldx     BAS_TXTTAB+1
0020D7r 2               @walk:
0020D7r 2  85 3A                sta     BAS_TMP1
0020D9r 2  86 3B                stx     BAS_TMP1+1
0020DBr 2  A0 01                ldy     #1
0020DDr 2  B1 3A                lda     (BAS_TMP1),y
0020DFr 2  F0 20                beq     @notFound               ; next-hi=0 -> end of program
0020E1r 2  A0 03                ldy     #3                      ; line-num-lo offset
0020E3r 2  A5 09                lda     BAS_LINNUM+1
0020E5r 2  D1 3A                cmp     (BAS_TMP1),y            ; compare hi byte at +3? need iny
0020E7r 2                       ; Actually format: +0 next-lo, +1 next-hi, +2 num-lo, +3 num-hi
0020E7r 2  90 18                bcc     @notFound               ; LINNUM-hi < line-hi -> miss
0020E9r 2  D0 09                bne     @advance                ; LINNUM-hi > line-hi -> next line
0020EBr 2  88                   dey                             ; y=2 = num-lo
0020ECr 2  A5 08                lda     BAS_LINNUM
0020EEr 2  D1 3A                cmp     (BAS_TMP1),y
0020F0r 2  90 0F                bcc     @notFound
0020F2r 2  F0 0F                beq     @found
0020F4r 2               @advance:
0020F4r 2  A0 00                ldy     #0
0020F6r 2  B1 3A                lda     (BAS_TMP1),y
0020F8r 2  48                   pha
0020F9r 2  A0 01                ldy     #1
0020FBr 2  B1 3A                lda     (BAS_TMP1),y
0020FDr 2  AA                   tax
0020FEr 2  68                   pla
0020FFr 2  B0 D6                bcs     @walk                   ; carry=1 means continue (always)
002101r 2               @notFound:
002101r 2  18                   clc
002102r 2  60                   rts
002103r 2               @found:
002103r 2  38                   sec
002104r 2  60                   rts
002105r 2               
002105r 2               ; ---------------------------------------------------------------------------
002105r 2               ; BasCmdGoto -- TXTPTR points at line-number digits.
002105r 2               ; ---------------------------------------------------------------------------
002105r 2               BasCmdGoto:
002105r 2  20 rr rr             jsr     LinGet
002108r 2  20 rr rr             jsr     BasRemn                 ; skip remainder of statement
00210Br 2  20 rr rr             jsr     FndLin
00210Er 2  90 0E                bcc     @undef
002110r 2                       ; LOWTR (BAS_TMP1) = target line addr.  TXTPTR = LOWTR - 1
002110r 2                       ; (so NEWSTT sees the previous line's $00 terminator at offset 0).
002110r 2  38                   sec
002111r 2  A5 3A                lda     BAS_TMP1
002113r 2  E9 01                sbc     #1
002115r 2  85 04                sta     TXTPTR
002117r 2  A5 3B                lda     BAS_TMP1+1
002119r 2  E9 00                sbc     #0
00211Br 2  85 05                sta     TXTPTR+1
00211Dr 2  60                   rts
00211Er 2               @undef:
00211Er 2  A2 03                ldx     #ERR_UNDEFSTMT
002120r 2  4C rr rr             jmp     BasErrorVec
002123r 2               
002123r 2               ; ---------------------------------------------------------------------------
002123r 2               ; BasCmdGosub -- push 5-byte frame on stack, then GOTO target.
002123r 2               ; Frame layout (top-down): [tag $8C][CURLIN-lo][CURLIN-hi][TXTPTR-lo][TXTPTR-hi]
002123r 2               ; ---------------------------------------------------------------------------
002123r 2               BasCmdGosub:
002123r 2  A5 05                lda     TXTPTR+1
002125r 2  48                   pha
002126r 2  A5 04                lda     TXTPTR
002128r 2  48                   pha
002129r 2  AD 6A 03             lda     BAS_CURLIN+1
00212Cr 2  48                   pha
00212Dr 2  AD 69 03             lda     BAS_CURLIN
002130r 2  48                   pha
002131r 2  A9 8C                lda     #TOK_GOSUB
002133r 2  48                   pha
002134r 2  20 rr rr             jsr     ChrGot
002137r 2  20 rr rr             jsr     BasCmdGoto
00213Ar 2  4C rr rr             jmp     BasNewstt
00213Dr 2               
00213Dr 2               ; ---------------------------------------------------------------------------
00213Dr 2               ; BasCmdReturn -- locate GOSUB frame on stack and resume at saved TXTPTR.
00213Dr 2               ; Per msbasic: scan the CPU stack from SP+5 (skipping return-routine's caller
00213Dr 2               ; return + this scan's own JSR return).  RTS at end pops the leaked
00213Dr 2               ; EXEC-return that GOSUB left behind.
00213Dr 2               ; ---------------------------------------------------------------------------
00213Dr 2               BasCmdReturn:
00213Dr 2  20 rr rr             jsr     GtForPnt
002140r 2                       ; X now points to the slot just BELOW a frame tag (or end of stack).
002140r 2  9A                   txs
002141r 2  C9 8C                cmp     #TOK_GOSUB
002143r 2  F0 05                beq     @ok
002145r 2  A2 0C                ldx     #ERR_RG
002147r 2  4C rr rr             jmp     BasErrorVec
00214Ar 2               @ok:
00214Ar 2  68                   pla                             ; tag (already in A, this discards)
00214Br 2  68                   pla
00214Cr 2  8D 69 03             sta     BAS_CURLIN
00214Fr 2  68                   pla
002150r 2  8D 6A 03             sta     BAS_CURLIN+1
002153r 2  68                   pla
002154r 2  85 04                sta     TXTPTR
002156r 2  68                   pla
002157r 2  85 05                sta     TXTPTR+1
002159r 2                       ; Skip remainder of GOSUB-target statement (DATAN-style).
002159r 2  20 rr rr             jsr     BasDatan
00215Cr 2                       ; Advance TXTPTR by Y (number of bytes to terminator).
00215Cr 2  98                   tya
00215Dr 2  18                   clc
00215Er 2  65 04                adc     TXTPTR
002160r 2  85 04                sta     TXTPTR
002162r 2  90 02                bcc     @noinc
002164r 2  E6 05                inc     TXTPTR+1
002166r 2               @noinc:
002166r 2  60                   rts
002167r 2               
002167r 2               ; ---------------------------------------------------------------------------
002167r 2               ; GtForPnt -- scan CPU stack for FOR/GOSUB frames.
002167r 2               ;   On entry: BAS_FORPNT (FORPNT) = $FFxx for "match any tag".
002167r 2               ;   Returns: X = stack pointer where the matching frame's tag-1 lives,
002167r 2               ;            A = tag byte found (or 0 if end-of-stack).  Z=1 if found tag,
002167r 2               ;            Z=0 (A=0) if no frame found.
002167r 2               ; ---------------------------------------------------------------------------
002167r 2               GtForPnt:
002167r 2  BA                   tsx
002168r 2  E8                   inx
002169r 2  E8                   inx
00216Ar 2  E8                   inx
00216Br 2  E8                   inx
00216Cr 2               @scan:
00216Cr 2  BD 01 01             lda     $0101,x                 ; tag candidate
00216Fr 2  C9 81                cmp     #TOK_FOR
002171r 2  D0 24                bne     @notFor
002173r 2                       ; Compare frame's variable address to FORPNT.
002173r 2  A5 47                lda     BAS_FORPNT+1
002175r 2  D0 0A                bne     @skipVar                ; FORPNT+1 = $FF -> skip variable test
002177r 2  BD 02 01             lda     $0102,x
00217Ar 2  85 46                sta     BAS_FORPNT
00217Cr 2  BD 03 01             lda     $0103,x
00217Fr 2  85 47                sta     BAS_FORPNT+1
002181r 2               @skipVar:
002181r 2  DD 03 01             cmp     $0103,x
002184r 2  D0 07                bne     @advance
002186r 2  A5 46                lda     BAS_FORPNT
002188r 2  DD 02 01             cmp     $0102,x
00218Br 2  F0 11                beq     @found
00218Dr 2               @advance:
00218Dr 2  8A                   txa
00218Er 2  18                   clc
00218Fr 2  69 12                adc     #18                     ; BYTES_PER_FRAME (FOR)
002191r 2  AA                   tax
002192r 2  D0 D8                bne     @scan
002194r 2                       ; Walked off stack
002194r 2  A9 00                lda     #0
002196r 2  60                   rts
002197r 2               @notFor:
002197r 2  C9 8C                cmp     #TOK_GOSUB
