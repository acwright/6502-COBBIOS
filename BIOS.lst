000B67r 2  20 rr rr       jsr BasAdvTxtPtr               ; skip TOK_SGN
000B6Ar 2  A9 28          lda #CH_LPAREN
000B6Cr 2  20 rr rr       jsr BasExpectChar
000B6Fr 2  20 rr rr       jsr BasExpr                    ; x -> BAS_ACC
000B72r 2  A9 29          lda #CH_RPAREN
000B74r 2  20 rr rr       jsr BasExpectChar
000B77r 2  A5 0A          lda BAS_ACC
000B79r 2  05 0B          ora BAS_ACC + 1
000B7Br 2  F0 12          beq @SgnZero
