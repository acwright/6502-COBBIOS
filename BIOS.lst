000CC2r 2               
000CC2r 2                 ; NVRAM(addr) — read byte from RTC NVRAM
000CC2r 2  C9 C1          cmp #TOK_NVRAM
000CC4r 2  D0 26          bne @NotNvramFunc
000CC6r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_NVRAM
000CC9r 2  A9 28          lda #CH_LPAREN
000CCBr 2  20 rr rr       jsr BasExpectChar
000CCEr 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
000CD1r 2  A9 29          lda #CH_RPAREN
000CD3r 2  20 rr rr       jsr BasExpectChar
000CD6r 2  AD 0D 03       lda HW_PRESENT
000CD9r 2  29 04          and #HW_RTC
000CDBr 2  F0 0A          beq @NvramFuncNoDev
000CDDr 2  A6 0A          ldx BAS_ACC                   ; X = NVRAM address
000CDFr 2  20 rr rr       jsr RtcReadNVRAM              ; A = data byte
