0021F8r 2  4C rr rr             jmp     BasAddon
0021FBr 2               @gotElse:
0021FBr 2                       ; Advance TXTPTR past ELSE token; continue execution.
0021FBr 2  C8                   iny
0021FCr 2  98                   tya
0021FDr 2  18                   clc
0021FEr 2  65 04                adc     TXTPTR
002200r 2  85 04                sta     TXTPTR
