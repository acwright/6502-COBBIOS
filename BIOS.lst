0013AFr 2  0A             asl
0013B0r 2  85 21          sta BAS_TEMP                   ; Variable offset
0013B2r 2  20 rr rr       jsr BasAdvTxtPtr
0013B5r 2               
0013B5r 2                 ; Search FOR stack from top for matching variable
0013B5r 2  A6 1B          ldx BAS_FORSP
