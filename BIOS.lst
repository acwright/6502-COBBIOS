000FB8r 2               
000FB8r 2               BasCmdRun:
000FB8r 2  20 rr rr       jsr BasCmdClr
000FBBr 2  A9 01          lda #BAS_FLAG_RUN
000FBDr 2  85 17          sta BAS_FLAGS
000FBFr 2               
000FBFr 2                 ; Start at first program line
000FBFr 2  A9 00          lda #<BAS_PRG_START
000FC1r 2  85 06          sta BAS_CURLINE
000FC3r 2  A9 08          lda #>BAS_PRG_START
000FC5r 2  85 07          sta BAS_CURLINE + 1
000FC7r 2               
000FC7r 2               BasRunLoop:
000FC7r 2                 ; Check if at end of program (CURLINE == PRGEND)
000FC7r 2  A5 06          lda BAS_CURLINE
000FC9r 2  C5 12          cmp BAS_PRGEND
000FCBr 2  D0 06          bne @RunNotEnd
000FCDr 2  A5 07          lda BAS_CURLINE + 1
000FCFr 2  C5 13          cmp BAS_PRGEND + 1
000FD1r 2  F0 6C          beq BasRunDone
000FD3r 2               @RunNotEnd:
000FD3r 2               
000FD3r 2                 ; Check for Ctrl+C break
000FD3r 2  20 rr rr       jsr BasCheckBreak
000FD6r 2               
000FD6r 2                 ; Get line number
000FD6r 2  A0 02          ldy #LINE_NUM
000FD8r 2  B1 06          lda (BAS_CURLINE),y
000FDAr 2  85 08          sta BAS_LINENUM
000FDCr 2  C8             iny
000FDDr 2  B1 06          lda (BAS_CURLINE),y
000FDFr 2  85 09          sta BAS_LINENUM + 1
000FE1r 2               
000FE1r 2                 ; Save CURLINE before execution for GOTO/GOSUB detection
000FE1r 2  A5 06          lda BAS_CURLINE
000FE3r 2  85 14          sta BAS_VARPTR
000FE5r 2  A5 07          lda BAS_CURLINE + 1
000FE7r 2  85 15          sta BAS_VARPTR + 1
000FE9r 2               
000FE9r 2                 ; Set TXTPTR to payload (unless NEXT already set it)
000FE9r 2  A5 17          lda BAS_FLAGS
000FEBr 2  29 04          and #BAS_FLAG_TXTSET
000FEDr 2  D0 0D          bne @SkipTxtSet
000FEFr 2  18             clc
000FF0r 2  A5 06          lda BAS_CURLINE
000FF2r 2  69 04          adc #LINE_PAYLOAD
000FF4r 2  85 04          sta BAS_TXTPTR
000FF6r 2  A5 07          lda BAS_CURLINE + 1
000FF8r 2  69 00          adc #$00
000FFAr 2  85 05          sta BAS_TXTPTR + 1
000FFCr 2               @SkipTxtSet:
000FFCr 2  A5 17          lda BAS_FLAGS
000FFEr 2  29 FB          and #<~BAS_FLAG_TXTSET          ; Clear the flag
001000r 2  85 17          sta BAS_FLAGS
001002r 2               
001002r 2               BasRunExec:
001002r 2                 ; Execute the line (CONT re-enters here with TXTPTR already set)
001002r 2  20 rr rr       jsr BasExecLine
001005r 2               
001005r 2                 ; Check if END was executed (flags cleared)
001005r 2  A5 17          lda BAS_FLAGS
001007r 2  29 01          and #BAS_FLAG_RUN
001009r 2  F0 34          beq BasRunDone
00100Br 2               
00100Br 2                 ; Check if GOTO/GOSUB changed CURLINE (or GOTO flag set for same-line GOTO)
00100Br 2  A5 17          lda BAS_FLAGS
00100Dr 2  29 08          and #BAS_FLAG_GOTO
00100Fr 2  D0 25          bne @GotoDone
001011r 2  A5 06          lda BAS_CURLINE
001013r 2  C5 14          cmp BAS_VARPTR
001015r 2  D0 B0          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
001017r 2  A5 07          lda BAS_CURLINE + 1
001019r 2  C5 15          cmp BAS_VARPTR + 1
00101Br 2  D0 AA          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
00101Dr 2               
00101Dr 2                 ; Advance to next line by scanning for end of current line
00101Dr 2  A0 04          ldy #LINE_PAYLOAD
00101Fr 2               @RunScanNull:
00101Fr 2  B1 06          lda (BAS_CURLINE),y
001021r 2  F0 03          beq @RunFoundNull
001023r 2  C8             iny
001024r 2  80 F9          bra @RunScanNull
001026r 2               @RunFoundNull:
001026r 2  C8             iny                            ; Past null terminator
001027r 2  98             tya
001028r 2  18             clc
001029r 2  65 06          adc BAS_CURLINE
00102Br 2  85 06          sta BAS_CURLINE
00102Dr 2  A9 00          lda #$00
00102Fr 2  65 07          adc BAS_CURLINE + 1
001031r 2  85 07          sta BAS_CURLINE + 1
001033r 2  4C rr rr       jmp BasRunLoop
001036r 2               
001036r 2               @GotoDone:
001036r 2  A5 17          lda BAS_FLAGS
