000BC0r 2               
000BC0r 2                 ; MIN(a,b) — Return smaller of two values
000BC0r 2  C9 B7          cmp #TOK_MIN
000BC2r 2  D0 33          bne @NotMin
000BC4r 2  20 rr rr       jsr BasAdvTxtPtr
000BC7r 2  A9 28          lda #CH_LPAREN
000BC9r 2  20 rr rr       jsr BasExpectChar
000BCCr 2  20 rr rr       jsr BasExpr                    ; a -> BAS_ACC
000BCFr 2  A5 0A          lda BAS_ACC
000BD1r 2  48             pha
000BD2r 2  A5 0B          lda BAS_ACC + 1
000BD4r 2  48             pha
000BD5r 2  A9 2C          lda #CH_COMMA
000BD7r 2  20 rr rr       jsr BasExpectChar
