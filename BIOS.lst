000000r 2               MN_SEI = 54
000000r 2               MN_SMB = 55
000000r 2               MN_STA = 56
000000r 2               MN_STP = 57
000000r 2               MN_STX = 58
000000r 2               MN_STY = 59
000000r 2               MN_STZ = 60
000000r 2               MN_TAX = 61
000000r 2               MN_TAY = 62
000000r 2               MN_TRB = 63
000000r 2               MN_TSB = 64
000000r 2               MN_TSX = 65
000000r 2               MN_TXA = 66
000000r 2               MN_TXS = 67
000000r 2               MN_TYA = 68
000000r 2               MN_WAI = 69
000000r 2               MN_UND = 70
000000r 2               
000000r 2               ; Addressing Mode Indices
000000r 2               AM_IMP = 0
000000r 2               AM_ACC = 1
000000r 2               AM_IMM = 2
000000r 2               AM_ZP  = 3
000000r 2               AM_ZPX = 4
000000r 2               AM_ZPY = 5
000000r 2               AM_ABS = 6
000000r 2               AM_ABX = 7
000000r 2               AM_ABY = 8
000000r 2               AM_IND = 9
000000r 2               AM_IZX = 10
000000r 2               AM_IZY = 11
000000r 2               AM_ZPI = 12
000000r 2               AM_REL = 13
000000r 2               AM_ZPR = 14
000000r 2               AM_AIX = 15
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Entry Points
000000r 2               ; ============================================================================
000000r 2               
000000r 2               MonitorEntry:
000000r 2  4C rr rr       jmp MonColdEntry              ; $C000 - Cold entry (boot menu / return)
000003r 2               
000003r 2               MonitorBrkEntry:
000003r 2  4C rr rr       jmp MonBrkEntry               ; $C003 - BRK entry (register display)
000006r 2               
000006r 2               ; ============================================================================
000006r 2               ; Cold Entry — print banner and enter command loop
000006r 2               ; ============================================================================
000006r 2               
000006r 2               MonColdEntry:
000006r 2  A2 FF          ldx #$FF
000008r 2  9A             txs                           ; Reset stack pointer
000009r 2  D8             cld                           ; Ensure binary mode
00000Ar 2  20 rr rr       jsr VideoClear                ; Clear screen
00000Dr 2  20 rr rr       jsr MonPrintBanner            ; Print "MONITOR" banner
000010r 2  4C rr rr       jmp MonCmdLoop
000013r 2               
000013r 2               ; ============================================================================
000013r 2               ; BRK Entry — print BRK address, display registers, enter command loop
000013r 2               ; ============================================================================
000013r 2               
000013r 2               MonBrkEntry:
000013r 2  A2 FF          ldx #$FF
000015r 2  9A             txs                           ; Reset stack pointer
000016r 2  D8             cld
000017r 2  20 rr rr       jsr VideoClear                ; Clear screen
00001Ar 2  20 rr rr       jsr MonPrintBanner            ; Print "MONITOR" banner
00001Dr 2                 ; Print "BRK AT $"
00001Dr 2  A2 00          ldx #0
00001Fr 2               @BrkMsgLoop:
00001Fr 2  BD rr rr       lda MonStrBrk,x
000022r 2  F0 06          beq @BrkMsgDone
000024r 2  20 rr rr       jsr Chrout
000027r 2  E8             inx
000028r 2  80 F5          bra @BrkMsgLoop
00002Ar 2               @BrkMsgDone:
00002Ar 2                 ; Print PC address (adjusted: BRK_PC points to BRK+2, subtract 2 for actual BRK location)
00002Ar 2  38             sec
00002Br 2  AD 11 03       lda BRK_PCL
00002Er 2  E9 02          sbc #2
000030r 2  85 2E          sta MON_ADDR
000032r 2  AD 12 03       lda BRK_PCH
000035r 2  E9 00          sbc #0
000037r 2  85 2F          sta MON_ADDR + 1
000039r 2  20 rr rr       jsr MonPrintHex4
00003Cr 2  20 rr rr       jsr MonPrintCRLF
00003Fr 2                 ; Display registers
00003Fr 2  20 rr rr       jsr MonShowRegs
000042r 2  4C rr rr       jmp MonCmdLoop
000045r 2               
000045r 2               ; ============================================================================
000045r 2               ; Command Loop — prompt, read, parse, dispatch
000045r 2               ; ============================================================================
000045r 2               
000045r 2               MonCmdLoop:
000045r 2                 ; Print prompt
000045r 2  A9 2E          lda #MON_PROMPT
000047r 2  20 rr rr       jsr Chrout
00004Ar 2  A9 20          lda #' '
00004Cr 2  20 rr rr       jsr Chrout
00004Fr 2               
00004Fr 2                 ; Read input line
00004Fr 2  20 rr rr       jsr MonReadLine
000052r 2               
000052r 2                 ; Parse and dispatch
000052r 2  20 rr rr       jsr MonParseLine
000055r 2               
000055r 2                 ; Loop back for next command
000055r 2  4C rr rr       jmp MonCmdLoop
000058r 2               
000058r 2               ; ============================================================================
000058r 2               ; MonReadLine — Read a line of input into MON_LINBUF
000058r 2               ; Returns: MON_LINBUF contains null-terminated input, Y = length
000058r 2               ; ============================================================================
000058r 2               
000058r 2               MonReadLine:
000058r 2  A0 00          ldy #0                        ; Index into line buffer
00005Ar 2               @ReadWait:
00005Ar 2  20 rr rr       jsr Chrin                     ; Try to read a character (carry set = got one)
00005Dr 2  90 FB          bcc @ReadWait                 ; No char available, keep waiting
00005Fr 2                 ; Got a character in A
00005Fr 2  C9 0D          cmp #$0D                      ; Carriage return?
000061r 2  F0 1D          beq @ReadDone
000063r 2  C9 0A          cmp #$0A                      ; Line feed? (treat same as CR)
000065r 2  F0 19          beq @ReadDone
000067r 2  C9 08          cmp #$08                      ; Backspace?
000069r 2  F0 0E          beq @ReadBS
00006Br 2  C9 7F          cmp #$7F                      ; Delete? (treat as backspace)
00006Dr 2  F0 0A          beq @ReadBS
00006Fr 2                 ; Printable character — store if room
00006Fr 2  C0 C8          cpy #MON_LINBUF_SIZE
000071r 2  B0 E7          bcs @ReadWait                 ; Buffer full, ignore
000073r 2  99 34 04       sta MON_LINBUF,y
000076r 2  C8             iny
000077r 2  80 E1          bra @ReadWait
000079r 2               @ReadBS:
000079r 2  C0 00          cpy #0                        ; Anything to delete?
00007Br 2  F0 DD          beq @ReadWait                 ; No, ignore
00007Dr 2  88             dey                           ; Back up one position
00007Er 2  80 DA          bra @ReadWait
000080r 2               @ReadDone:
000080r 2  A9 0D          lda #$0D                      ; Echo CR
000082r 2  20 rr rr       jsr Chrout
000085r 2  A9 0A          lda #$0A                      ; Echo LF
000087r 2  20 rr rr       jsr Chrout
00008Ar 2  A9 00          lda #0
00008Cr 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate
00008Fr 2  60             rts
000090r 2               
000090r 2               ; ============================================================================
000090r 2               ; MonParseLine — Parse first char and dispatch to command handler
000090r 2               ; ============================================================================
000090r 2               
000090r 2               MonParseLine:
000090r 2  64 35          stz MON_IDX                   ; Reset parse index
000092r 2  20 rr rr       jsr MonSkipSpaces             ; Skip leading whitespace
000095r 2  A4 35          ldy MON_IDX
000097r 2  B9 34 04       lda MON_LINBUF,y              ; Get command character
00009Ar 2  F0 2A          beq @ParseDone                ; Empty line — just return
00009Cr 2                 ; Convert to uppercase
00009Cr 2  C9 61          cmp #'a'
00009Er 2  90 06          bcc @ParseNoConv
0000A0r 2  C9 7B          cmp #'z'+1
0000A2r 2  B0 02          bcs @ParseNoConv
0000A4r 2  29 DF          and #$DF                      ; Convert lowercase to uppercase
0000A6r 2               @ParseNoConv:
0000A6r 2  E6 35          inc MON_IDX                   ; Advance past command char
0000A8r 2                 ; Search dispatch table
0000A8r 2  A2 00          ldx #0
0000AAr 2               @DispatchLoop:
0000AAr 2  BC rr rr       ldy MonCmdTable,x             ; Load command character from table
0000ADr 2  F0 14          beq @ParseError               ; End of table (null terminator) — unknown command
0000AFr 2  DD rr rr       cmp MonCmdTable,x             ; Compare with input character
0000B2r 2  F0 05          beq @DispatchFound
0000B4r 2  E8             inx                           ; Skip char
0000B5r 2  E8             inx                           ; Skip address low
0000B6r 2  E8             inx                           ; Skip address high
0000B7r 2  80 F1          bra @DispatchLoop
0000B9r 2               @DispatchFound:
0000B9r 2  E8             inx                           ; Point to address low byte
0000BAr 2  BD rr rr       lda MonCmdTable+1,x           ; Handler address high byte — push first (big-endian on stack)
0000BDr 2  48             pha
0000BEr 2  BD rr rr       lda MonCmdTable,x             ; Handler address low byte
0000C1r 2  48             pha
0000C2r 2  60             rts                           ; "Return" to handler address (RTS adds 1 to address)
0000C3r 2               @ParseError:
0000C3r 2  20 rr rr       jsr MonPrintError
0000C6r 2               @ParseDone:
0000C6r 2  60             rts
0000C7r 2               
0000C7r 2               ; ============================================================================
0000C7r 2               ; Command Dispatch Table
0000C7r 2               ; Format: command char (1 byte), handler address - 1 (2 bytes, low/high for RTS trick)
0000C7r 2               ; ============================================================================
0000C7r 2               
0000C7r 2               MonCmdTable:
0000C7r 2  58             .byte 'X'
0000C8r 2  rr rr          .word MonCmdX - 1
0000CAr 2  52             .byte 'R'
0000CBr 2  rr rr          .word MonCmdR - 1
0000CDr 2  4D             .byte 'M'
0000CEr 2  rr rr          .word MonCmdM - 1
0000D0r 2  44             .byte 'D'
0000D1r 2  rr rr          .word MonCmdD - 1
0000D3r 2  3E             .byte '>'
0000D4r 2  rr rr          .word MonCmdDeposit - 1
0000D6r 2  46             .byte 'F'
0000D7r 2  rr rr          .word MonCmdFill - 1
0000D9r 2  54             .byte 'T'
0000DAr 2  rr rr          .word MonCmdTransfer - 1
0000DCr 2  48             .byte 'H'
0000DDr 2  rr rr          .word MonCmdHunt - 1
0000DFr 2  43             .byte 'C'
0000E0r 2  rr rr          .word MonCmdCompare - 1
0000E2r 2  47             .byte 'G'
0000E3r 2  rr rr          .word MonCmdGo - 1
0000E5r 2  4A             .byte 'J'
0000E6r 2  rr rr          .word MonCmdJsr - 1
0000E8r 2  3B             .byte ';'
0000E9r 2  rr rr          .word MonCmdModRegs - 1
0000EBr 2  4C             .byte 'L'
0000ECr 2  rr rr          .word MonCmdLoad - 1
0000EEr 2  53             .byte 'S'
0000EFr 2  rr rr          .word MonCmdSave - 1
0000F1r 2  40             .byte '@'
0000F2r 2  rr rr          .word MonCmdDir - 1
0000F4r 2  4E             .byte 'N'
0000F5r 2  rr rr          .word MonCmdNum - 1
0000F7r 2  00             .byte 0                       ; End of table sentinel
0000F8r 2               
0000F8r 2               ; ============================================================================
0000F8r 2               ; MonCmdX — Exit to BASIC
0000F8r 2               ; ============================================================================
0000F8r 2               
0000F8r 2               MonCmdX:
0000F8r 2  20 rr rr       jsr VideoClear                ; Clear screen before entering BASIC
0000FBr 2  4C rr rr       jmp BasColdStart
0000FEr 2               
0000FEr 2               ; ============================================================================
0000FEr 2               ; MonCmdR — Display CPU registers
0000FEr 2               ; ============================================================================
0000FEr 2               
0000FEr 2               MonCmdR:
0000FEr 2  20 rr rr       jsr MonShowRegs
000101r 2  60             rts
000102r 2               
000102r 2               ; ============================================================================
000102r 2               ; MonCmdDeposit — Deposit (write) bytes to memory
000102r 2               ; Syntax: > ADDR XX [XX XX ...]
000102r 2               ; ============================================================================
000102r 2               
000102r 2               MonCmdDeposit:
000102r 2  20 rr rr       jsr MonSkipSpaces
000105r 2  20 rr rr       jsr MonParseHex4              ; Parse target address into MON_ADDR
000108r 2  90 16          bcc @DepError                 ; No address → error
00010Ar 2  A0 00          ldy #0                        ; Byte offset from MON_ADDR
00010Cr 2               @DepLoop:
00010Cr 2  5A             phy                           ; Save byte offset (Y clobbered by parse routines)
00010Dr 2  20 rr rr       jsr MonSkipSpaces
000110r 2  20 rr rr       jsr MonParseHex2              ; Parse next byte into A
000113r 2  7A             ply                           ; Restore byte offset (PLY doesn't affect carry)
000114r 2  90 05          bcc @DepDone                  ; No more bytes → done
000116r 2  91 2E          sta (MON_ADDR),y
000118r 2  C8             iny
000119r 2  D0 F1          bne @DepLoop                  ; Up to 256 bytes (Y wraps)
00011Br 2               @DepDone:
00011Br 2  C0 00          cpy #0                        ; Did we deposit at least one byte?
00011Dr 2  F0 01          beq @DepError                 ; No bytes given → error
00011Fr 2  60             rts
000120r 2               @DepError:
000120r 2  4C rr rr       jmp MonPrintError
000123r 2               
000123r 2               ; ============================================================================
000123r 2               ; MonCmdFill — Fill memory range with a byte value
000123r 2               ; Syntax: F ADDR1 ADDR2 XX
000123r 2               ; ============================================================================
000123r 2               
000123r 2               MonCmdFill:
000123r 2  20 rr rr       jsr MonSkipSpaces
000126r 2  20 rr rr       jsr MonParseHex4              ; Parse start address → MON_ADDR
000129r 2  90 43          bcc @FillError
00012Br 2  A5 2E          lda MON_ADDR
00012Dr 2  85 32          sta MON_TMP
00012Fr 2  A5 2F          lda MON_ADDR+1
000131r 2  85 33          sta MON_TMP+1                 ; Save start in MON_TMP
000133r 2  20 rr rr       jsr MonSkipSpaces
000136r 2  20 rr rr       jsr MonParseHex4              ; Parse end address → MON_ADDR
000139r 2  90 33          bcc @FillError
00013Br 2  A5 2E          lda MON_ADDR
00013Dr 2  85 30          sta MON_END
00013Fr 2  A5 2F          lda MON_ADDR+1
000141r 2  85 31          sta MON_END+1                 ; Save end in MON_END
000143r 2                 ; Restore start into MON_ADDR
000143r 2  A5 32          lda MON_TMP
000145r 2  85 2E          sta MON_ADDR
000147r 2  A5 33          lda MON_TMP+1
000149r 2  85 2F          sta MON_ADDR+1
00014Br 2  20 rr rr       jsr MonSkipSpaces
00014Er 2  20 rr rr       jsr MonParseHex2              ; Parse fill byte → A
000151r 2  90 1B          bcc @FillError
000153r 2                 ; A = fill byte, MON_ADDR = start, MON_END = end (inclusive)
000153r 2  A0 00          ldy #0
000155r 2               @FillLoop:
000155r 2  91 2E          sta (MON_ADDR),y
000157r 2                 ; Check if MON_ADDR == MON_END
000157r 2  A6 2F          ldx MON_ADDR+1
000159r 2  E4 31          cpx MON_END+1
00015Br 2  D0 06          bne @FillNext
00015Dr 2  A6 2E          ldx MON_ADDR
00015Fr 2  E4 30          cpx MON_END
000161r 2  F0 0A          beq @FillDone
000163r 2               @FillNext:
000163r 2                 ; Advance MON_ADDR
000163r 2  48             pha                           ; Save fill byte
000164r 2  E6 2E          inc MON_ADDR
000166r 2  D0 02          bne @FillNoHi
000168r 2  E6 2F          inc MON_ADDR+1
00016Ar 2               @FillNoHi:
00016Ar 2  68             pla                           ; Restore fill byte
00016Br 2  80 E8          bra @FillLoop
00016Dr 2               @FillDone:
00016Dr 2  60             rts
00016Er 2               @FillError:
00016Er 2  4C rr rr       jmp MonPrintError
000171r 2               
000171r 2               ; ============================================================================
000171r 2               ; MonCmdTransfer — Copy memory block (handles overlapping regions)
000171r 2               ; Syntax: T SRC_START SRC_END DEST
000171r 2               ; ============================================================================
000171r 2               
000171r 2               MonCmdTransfer:
000171r 2  20 rr rr       jsr MonSkipSpaces
000174r 2  20 rr rr       jsr MonParseHex4              ; Parse source start → MON_ADDR
000177r 2  B0 03          bcs @XferGotStart
000179r 2  4C rr rr       jmp @XferError                ; No address → error
00017Cr 2               @XferGotStart:
00017Cr 2  A5 2E          lda MON_ADDR
00017Er 2  85 32          sta MON_TMP
000180r 2  A5 2F          lda MON_ADDR+1
000182r 2  85 33          sta MON_TMP+1                 ; MON_TMP = source start
000184r 2  20 rr rr       jsr MonSkipSpaces
000187r 2  20 rr rr       jsr MonParseHex4              ; Parse source end → MON_ADDR
00018Ar 2  B0 03          bcs @XferGotEnd
00018Cr 2  4C rr rr       jmp @XferError
00018Fr 2               @XferGotEnd:
00018Fr 2  A5 2E          lda MON_ADDR
000191r 2  85 30          sta MON_END
000193r 2  A5 2F          lda MON_ADDR+1
000195r 2  85 31          sta MON_END+1                 ; MON_END = source end (inclusive)
000197r 2  20 rr rr       jsr MonSkipSpaces
00019Ar 2  20 rr rr       jsr MonParseHex4              ; Parse dest → MON_ADDR
00019Dr 2  B0 03          bcs @XferGotDest
00019Fr 2  4C rr rr       jmp @XferError
0001A2r 2               @XferGotDest:
0001A2r 2                 ; MON_ADDR = dest, MON_TMP = src start, MON_END = src end
0001A2r 2                 ; Determine copy direction: if dest > src_start, copy backward to handle overlap
0001A2r 2  A5 2F          lda MON_ADDR+1
0001A4r 2  C5 33          cmp MON_TMP+1
0001A6r 2  90 5C          bcc @CopyForward              ; dest < src → forward is safe
0001A8r 2  D0 08          bne @CopyBackward             ; dest > src → need backward
0001AAr 2  A5 2E          lda MON_ADDR
0001ACr 2  C5 32          cmp MON_TMP
0001AEr 2  90 54          bcc @CopyForward
0001B0r 2  F0 72          beq @XferDone                 ; dest == src → nothing to do
0001B2r 2               @CopyBackward:
0001B2r 2                 ; Compute offset = src_end - src_start
0001B2r 2  38             sec
0001B3r 2  A5 30          lda MON_END
0001B5r 2  E5 32          sbc MON_TMP
0001B7r 2  85 34          sta MON_BYTE                  ; low byte of offset
0001B9r 2  A5 31          lda MON_END+1
0001BBr 2  E5 33          sbc MON_TMP+1
0001BDr 2  85 35          sta MON_IDX                   ; high byte of offset (reuse MON_IDX as scratch)
0001BFr 2                 ; Point MON_TMP to src_end, MON_ADDR to dest + offset
0001BFr 2                 ; MON_TMP already needs to be src_end (currently src_start)
0001BFr 2                 ; Swap: MON_TMP = MON_END (src_end)
0001BFr 2  A5 30          lda MON_END
0001C1r 2  48             pha
0001C2r 2  A5 31          lda MON_END+1
0001C4r 2  48             pha
0001C5r 2                 ; MON_END = src_start (save for later comparison)
0001C5r 2  A5 32          lda MON_TMP
0001C7r 2  85 30          sta MON_END
0001C9r 2  A5 33          lda MON_TMP+1
0001CBr 2  85 31          sta MON_END+1
0001CDr 2                 ; MON_TMP = src_end
0001CDr 2  68             pla
0001CEr 2  85 33          sta MON_TMP+1
0001D0r 2  68             pla
0001D1r 2  85 32          sta MON_TMP
0001D3r 2                 ; dest_end = MON_ADDR + offset
0001D3r 2  18             clc
0001D4r 2  A5 2E          lda MON_ADDR
0001D6r 2  65 34          adc MON_BYTE
0001D8r 2  85 2E          sta MON_ADDR
0001DAr 2  A5 2F          lda MON_ADDR+1
0001DCr 2  65 35          adc MON_IDX
0001DEr 2  85 2F          sta MON_ADDR+1
0001E0r 2               @BackLoop:
0001E0r 2  A0 00          ldy #0
0001E2r 2  B1 32          lda (MON_TMP),y
0001E4r 2  91 2E          sta (MON_ADDR),y
0001E6r 2                 ; Check if MON_TMP == MON_END (src start, our stop address)
0001E6r 2  A5 33          lda MON_TMP+1
0001E8r 2  C5 31          cmp MON_END+1
0001EAr 2  D0 06          bne @BackDec
0001ECr 2  A5 32          lda MON_TMP
0001EEr 2  C5 30          cmp MON_END
0001F0r 2  F0 32          beq @XferDone
0001F2r 2               @BackDec:
0001F2r 2                 ; Decrement both pointers
0001F2r 2  A5 32          lda MON_TMP
0001F4r 2  D0 02          bne @BackDecTmpLo
0001F6r 2  C6 33          dec MON_TMP+1
0001F8r 2               @BackDecTmpLo:
0001F8r 2  C6 32          dec MON_TMP
0001FAr 2  A5 2E          lda MON_ADDR
0001FCr 2  D0 02          bne @BackDecDstLo
0001FEr 2  C6 2F          dec MON_ADDR+1
000200r 2               @BackDecDstLo:
000200r 2  C6 2E          dec MON_ADDR
000202r 2  80 DC          bra @BackLoop
000204r 2               
000204r 2               @CopyForward:
000204r 2                 ; Copy from MON_TMP (src) to MON_ADDR (dest), up to MON_END (src end)
000204r 2  A0 00          ldy #0
000206r 2               @FwdLoop:
000206r 2  B1 32          lda (MON_TMP),y
000208r 2  91 2E          sta (MON_ADDR),y
00020Ar 2                 ; Check if MON_TMP == MON_END
00020Ar 2  A5 33          lda MON_TMP+1
00020Cr 2  C5 31          cmp MON_END+1
00020Er 2  D0 06          bne @FwdNext
000210r 2  A5 32          lda MON_TMP
000212r 2  C5 30          cmp MON_END
000214r 2  F0 0E          beq @XferDone
000216r 2               @FwdNext:
000216r 2                 ; Advance both pointers
000216r 2  E6 32          inc MON_TMP
000218r 2  D0 02          bne @FwdNoDstCarry
00021Ar 2  E6 33          inc MON_TMP+1
00021Cr 2               @FwdNoDstCarry:
00021Cr 2  E6 2E          inc MON_ADDR
00021Er 2  D0 E6          bne @FwdLoop
000220r 2  E6 2F          inc MON_ADDR+1
000222r 2  80 E2          bra @FwdLoop
000224r 2               
000224r 2               @XferDone:
000224r 2  60             rts
000225r 2               @XferError:
000225r 2  4C rr rr       jmp MonPrintError
000228r 2               
000228r 2               ; ============================================================================
000228r 2               ; MonCmdHunt — Search for byte pattern in memory range
000228r 2               ; Syntax: H ADDR1 ADDR2 XX [XX XX ...]
000228r 2               ; Prints address of each match on its own line.
000228r 2               ; ============================================================================
000228r 2               
000228r 2               ; Hunt uses a temp buffer at end of MON_LINBUF area for the pattern.
000228r 2               ; Pattern bytes stored at MON_LINBUF+128, max 64 pattern bytes.
000228r 2               MON_HUNT_PAT        = MON_LINBUF + 128
000228r 2               MON_HUNT_PAT_MAX    = 64
000228r 2               
000228r 2               MonCmdHunt:
000228r 2  20 rr rr       jsr MonSkipSpaces
00022Br 2  20 rr rr       jsr MonParseHex4              ; Parse start address → MON_ADDR
00022Er 2  90 65          bcc @HuntError
000230r 2  A5 2E          lda MON_ADDR
000232r 2  85 32          sta MON_TMP
000234r 2  A5 2F          lda MON_ADDR+1
000236r 2  85 33          sta MON_TMP+1                 ; MON_TMP = search start
000238r 2  20 rr rr       jsr MonSkipSpaces
00023Br 2  20 rr rr       jsr MonParseHex4              ; Parse end address → MON_ADDR
00023Er 2  90 55          bcc @HuntError
000240r 2  A5 2E          lda MON_ADDR
000242r 2  85 30          sta MON_END
000244r 2  A5 2F          lda MON_ADDR+1
000246r 2  85 31          sta MON_END+1                 ; MON_END = search end
000248r 2                 ; Restore start
000248r 2  A5 32          lda MON_TMP
00024Ar 2  85 2E          sta MON_ADDR
00024Cr 2  A5 33          lda MON_TMP+1
00024Er 2  85 2F          sta MON_ADDR+1
000250r 2                 ; Parse pattern bytes into MON_HUNT_PAT
000250r 2  A2 00          ldx #0                        ; Pattern length counter
000252r 2               @HuntParseByte:
000252r 2  DA             phx                           ; Save pattern counter (X clobbered by MonParseHex2)
000253r 2  20 rr rr       jsr MonSkipSpaces
000256r 2  20 rr rr       jsr MonParseHex2              ; Next byte → A
000259r 2  FA             plx                           ; Restore pattern counter (PLX doesn't affect carry)
00025Ar 2  90 0A          bcc @HuntParseEnd
00025Cr 2  E0 40          cpx #MON_HUNT_PAT_MAX
00025Er 2  B0 06          bcs @HuntParseEnd             ; Pattern buffer full
000260r 2  9D B4 04       sta MON_HUNT_PAT,x
000263r 2  E8             inx
000264r 2  80 EC          bra @HuntParseByte
000266r 2               @HuntParseEnd:
000266r 2  E0 00          cpx #0
000268r 2  F0 2B          beq @HuntError                ; No pattern bytes → error
00026Ar 2  86 34          stx MON_BYTE                  ; MON_BYTE = pattern length
00026Cr 2                 ; Search: scan MON_ADDR to MON_END for pattern match
00026Cr 2               @HuntScanLoop:
00026Cr 2  A0 00          ldy #0                        ; Pattern match index
00026Er 2               @HuntMatchLoop:
00026Er 2  B1 2E          lda (MON_ADDR),y
000270r 2  D9 B4 04       cmp MON_HUNT_PAT,y
000273r 2  D0 0B          bne @HuntNoMatch
000275r 2  C8             iny
000276r 2  C4 34          cpy MON_BYTE                  ; Matched all pattern bytes?
000278r 2  90 F4          bcc @HuntMatchLoop
00027Ar 2                 ; Full match — print address
00027Ar 2  20 rr rr       jsr MonPrintHex4
00027Dr 2  20 rr rr       jsr MonPrintCRLF
000280r 2               @HuntNoMatch:
000280r 2                 ; Check if MON_ADDR == MON_END
000280r 2  A5 2F          lda MON_ADDR+1
000282r 2  C5 31          cmp MON_END+1
000284r 2  D0 06          bne @HuntAdvance
000286r 2  A5 2E          lda MON_ADDR
000288r 2  C5 30          cmp MON_END
00028Ar 2  F0 08          beq @HuntDone
00028Cr 2               @HuntAdvance:
00028Cr 2  E6 2E          inc MON_ADDR
00028Er 2  D0 DC          bne @HuntScanLoop
000290r 2  E6 2F          inc MON_ADDR+1
000292r 2  80 D8          bra @HuntScanLoop
000294r 2               @HuntDone:
000294r 2  60             rts
000295r 2               @HuntError:
000295r 2  4C rr rr       jmp MonPrintError
000298r 2               
000298r 2               ; ============================================================================
000298r 2               ; MonCmdCompare — Compare two memory regions
000298r 2               ; Syntax: C ADDR1 ADDR2 ADDR3
000298r 2               ; Compares [addr1,addr2] with block at addr3, prints differing addresses.
000298r 2               ; ============================================================================
000298r 2               
000298r 2               MonCmdCompare:
000298r 2  20 rr rr       jsr MonSkipSpaces
00029Br 2  20 rr rr       jsr MonParseHex4              ; Parse addr1 (region1 start) → MON_ADDR
00029Er 2  90 57          bcc @CmpError
0002A0r 2                 ; Save addr1 on stack
0002A0r 2  A5 2F          lda MON_ADDR+1
0002A2r 2  48             pha
0002A3r 2  A5 2E          lda MON_ADDR
0002A5r 2  48             pha
0002A6r 2  20 rr rr       jsr MonSkipSpaces
0002A9r 2  20 rr rr       jsr MonParseHex4              ; Parse addr2 (region1 end) → MON_ADDR
0002ACr 2  90 47          bcc @CmpErrorPop
0002AEr 2  A5 2E          lda MON_ADDR
0002B0r 2  85 30          sta MON_END
0002B2r 2  A5 2F          lda MON_ADDR+1
0002B4r 2  85 31          sta MON_END+1                 ; MON_END = region1 end (inclusive)
0002B6r 2  20 rr rr       jsr MonSkipSpaces
0002B9r 2  20 rr rr       jsr MonParseHex4              ; Parse addr3 (region2 base) → MON_ADDR
0002BCr 2  90 37          bcc @CmpErrorPop
0002BEr 2  A5 2E          lda MON_ADDR
0002C0r 2  85 32          sta MON_TMP
0002C2r 2  A5 2F          lda MON_ADDR+1
0002C4r 2  85 33          sta MON_TMP+1                 ; MON_TMP = region2 pointer
0002C6r 2                 ; Restore addr1 → MON_ADDR
0002C6r 2  68             pla
0002C7r 2  85 2E          sta MON_ADDR
0002C9r 2  68             pla
0002CAr 2  85 2F          sta MON_ADDR+1
0002CCr 2                 ; Compare loop: [MON_ADDR..MON_END] vs [MON_TMP..]
0002CCr 2  A0 00          ldy #0
0002CEr 2               @CmpLoop:
0002CEr 2  B1 2E          lda (MON_ADDR),y
0002D0r 2  D1 32          cmp (MON_TMP),y
0002D2r 2  F0 06          beq @CmpMatch
0002D4r 2                 ; Mismatch — print addr1 address
0002D4r 2  20 rr rr       jsr MonPrintHex4
0002D7r 2  20 rr rr       jsr MonPrintCRLF
0002DAr 2               @CmpMatch:
0002DAr 2                 ; Check if MON_ADDR == MON_END
0002DAr 2  A5 2F          lda MON_ADDR+1
0002DCr 2  C5 31          cmp MON_END+1
0002DEr 2  D0 06          bne @CmpNext
0002E0r 2  A5 2E          lda MON_ADDR
0002E2r 2  C5 30          cmp MON_END
0002E4r 2  F0 0E          beq @CmpDone
0002E6r 2               @CmpNext:
0002E6r 2                 ; Advance both pointers
0002E6r 2  E6 2E          inc MON_ADDR
0002E8r 2  D0 02          bne @CmpNoHi1
0002EAr 2  E6 2F          inc MON_ADDR+1
0002ECr 2               @CmpNoHi1:
0002ECr 2  E6 32          inc MON_TMP
0002EEr 2  D0 DE          bne @CmpLoop
0002F0r 2  E6 33          inc MON_TMP+1
0002F2r 2  80 DA          bra @CmpLoop
0002F4r 2               @CmpDone:
0002F4r 2  60             rts
0002F5r 2               @CmpErrorPop:
0002F5r 2  68             pla                           ; Clean up stack
0002F6r 2  68             pla
0002F7r 2               @CmpError:
0002F7r 2  4C rr rr       jmp MonPrintError
0002FAr 2               
0002FAr 2               ; ============================================================================
0002FAr 2               ; MonCmdGo — Go (JMP to address with full register restore via RTI)
0002FAr 2               ; Syntax: G [addr]
0002FAr 2               ; If addr given, sets BRK_PCL/PCH. Restores A, X, Y, P, SP via RTI.
0002FAr 2               ; Program runs until BRK returns to monitor or forever.
0002FAr 2               ; ============================================================================
0002FAr 2               
0002FAr 2               MonCmdGo:
0002FAr 2  20 rr rr       jsr MonSkipSpaces
0002FDr 2  20 rr rr       jsr MonParseHex4
000300r 2  90 0A          bcc @GoNoAddr
000302r 2                 ; Address given — store to BRK_PCL/PCH
000302r 2  A5 2E          lda MON_ADDR
000304r 2  8D 11 03       sta BRK_PCL
000307r 2  A5 2F          lda MON_ADDR+1
000309r 2  8D 12 03       sta BRK_PCH
00030Cr 2               @GoNoAddr:
00030Cr 2  78             sei                           ; Disable interrupts during stack manipulation
00030Dr 2                 ; Restore user's stack pointer
00030Dr 2                 ; BRK_SP = SP at Break entry (user's original SP - 3 from BRK hardware push)
00030Dr 2                 ; We need SP = BRK_SP + 3 before our pushes, so RTI leaves SP at original
00030Dr 2  AE 16 03       ldx BRK_SP
000310r 2  E8             inx
000311r 2  E8             inx
000312r 2  E8             inx
000313r 2  9A             txs                           ; SP = user's original SP
000314r 2                 ; Push PCH, PCL, P for RTI (RTI pops P first, then PCL, PCH)
000314r 2  AD 12 03       lda BRK_PCH
000317r 2  48             pha
000318r 2  AD 11 03       lda BRK_PCL
00031Br 2  48             pha
00031Cr 2  AD 10 03       lda BRK_P
00031Fr 2  48             pha
000320r 2                 ; Restore registers
000320r 2  AC 15 03       ldy BRK_Y
000323r 2  AE 14 03       ldx BRK_X
000326r 2  AD 13 03       lda BRK_A
000329r 2  40             rti                           ; Pop P, PC → jump to target with full register state
00032Ar 2               
00032Ar 2               ; ============================================================================
00032Ar 2               ; MonCmdJsr — Call subroutine and return to monitor on RTS
00032Ar 2               ; Syntax: J [addr]
00032Ar 2               ; Pushes monitor return address, restores A/X/Y, JMPs to target.
00032Ar 2               ; When target does RTS, saves registers and re-enters monitor.
00032Ar 2               ; ============================================================================
00032Ar 2               
00032Ar 2               MonCmdJsr:
00032Ar 2  20 rr rr       jsr MonSkipSpaces
00032Dr 2  20 rr rr       jsr MonParseHex4
000330r 2  90 0A          bcc @JsrNoAddr
000332r 2                 ; Address given — store to BRK_PCL/PCH
000332r 2  A5 2E          lda MON_ADDR
000334r 2  8D 11 03       sta BRK_PCL
000337r 2  A5 2F          lda MON_ADDR+1
000339r 2  8D 12 03       sta BRK_PCH
00033Cr 2               @JsrNoAddr:
00033Cr 2                 ; Push return address (MonJsrReturn - 1) for RTS trick
00033Cr 2  A9 rr          lda #>(MonJsrReturn - 1)
00033Er 2  48             pha
00033Fr 2  A9 rr          lda #<(MonJsrReturn - 1)
000341r 2  48             pha
000342r 2                 ; Restore registers as inputs to subroutine
000342r 2  AC 15 03       ldy BRK_Y
000345r 2  AE 14 03       ldx BRK_X
000348r 2  AD 13 03       lda BRK_A
00034Br 2  6C 11 03       jmp (BRK_PCL)                 ; Jump to target — its RTS returns to MonJsrReturn
00034Er 2               
00034Er 2               ; MonJsrReturn — Landing point when user's subroutine does RTS
00034Er 2               MonJsrReturn:
00034Er 2  8D 13 03       sta BRK_A                     ; Save returned A
000351r 2  8E 14 03       stx BRK_X                    ; Save returned X
000354r 2  8C 15 03       sty BRK_Y                    ; Save returned Y
000357r 2  08             php                           ; Push current P
000358r 2  68             pla
000359r 2  8D 10 03       sta BRK_P                    ; Save processor status
00035Cr 2  BA             tsx
00035Dr 2  8E 16 03       stx BRK_SP                   ; Save current stack pointer
000360r 2                 ; Show registers and re-enter command loop
000360r 2  20 rr rr       jsr MonShowRegs
000363r 2  4C rr rr       jmp MonCmdLoop
000366r 2               
000366r 2               ; ============================================================================
000366r 2               ; MonCmdModRegs — Modify saved CPU registers
000366r 2               ; Syntax: ; PC xxxx A xx X xx Y xx SP xx P xx
000366r 2               ; Any subset, any order. Labels: PC, A, X, Y, SP, P
000366r 2               ; ============================================================================
000366r 2               
000366r 2               MonCmdModRegs:
000366r 2               @ModLoop:
000366r 2  20 rr rr       jsr MonSkipSpaces
000369r 2  A4 35          ldy MON_IDX
00036Br 2  B9 34 04       lda MON_LINBUF,y
00036Er 2  D0 03          bne @ModNotEnd
000370r 2  4C rr rr       jmp @ModDone                  ; End of line — trampoline (too far for beq)
000373r 2               @ModNotEnd:
000373r 2                 ; Convert to uppercase
000373r 2  C9 61          cmp #'a'
000375r 2  90 06          bcc @ModNoConv
000377r 2  C9 7B          cmp #'z'+1
000379r 2  B0 02          bcs @ModNoConv
00037Br 2  29 DF          and #$DF
00037Dr 2               @ModNoConv:
00037Dr 2  C9 50          cmp #'P'
00037Fr 2  F0 13          beq @ModCheckPCorP
000381r 2  C9 41          cmp #'A'
000383r 2  F0 4F          beq @ModA
000385r 2  C9 58          cmp #'X'
000387r 2  F0 5E          beq @ModX
000389r 2  C9 59          cmp #'Y'
00038Br 2  F0 6D          beq @ModY
00038Dr 2  C9 53          cmp #'S'
00038Fr 2  F0 7C          beq @ModCheckSP
000391r 2  4C rr rr       jmp @ModError                 ; Unknown label — trampoline (too far for bra)
000394r 2               
000394r 2               @ModCheckPCorP:
000394r 2                 ; Could be "PC" (program counter) or "P" (processor status)
000394r 2  E6 35          inc MON_IDX
000396r 2  A4 35          ldy MON_IDX
000398r 2  B9 34 04       lda MON_LINBUF,y
00039Br 2                 ; Convert to uppercase
00039Br 2  C9 61          cmp #'a'
00039Dr 2  90 06          bcc @ModPCNoConv
00039Fr 2  C9 7B          cmp #'z'+1
0003A1r 2  B0 02          bcs @ModPCNoConv
0003A3r 2  29 DF          and #$DF
0003A5r 2               @ModPCNoConv:
0003A5r 2  C9 43          cmp #'C'
0003A7r 2  F0 11          beq @ModPC
0003A9r 2                 ; It's just 'P' (processor status) — don't advance past the non-'C' char
0003A9r 2  20 rr rr       jsr MonSkipSpaces
0003ACr 2  20 rr rr       jsr MonParseHex2
0003AFr 2  B0 03          bcs @ModPOk
0003B1r 2  4C rr rr       jmp @ModError
0003B4r 2               @ModPOk:
0003B4r 2  8D 10 03       sta BRK_P
0003B7r 2  4C rr rr       jmp @ModLoop
0003BAr 2               
0003BAr 2               @ModPC:
0003BAr 2  E6 35          inc MON_IDX                   ; Advance past 'C'
0003BCr 2  20 rr rr       jsr MonSkipSpaces
0003BFr 2  20 rr rr       jsr MonParseHex4
0003C2r 2  B0 03          bcs @ModPCOk
0003C4r 2  4C rr rr       jmp @ModError
0003C7r 2               @ModPCOk:
0003C7r 2  A5 2E          lda MON_ADDR
0003C9r 2  8D 11 03       sta BRK_PCL
0003CCr 2  A5 2F          lda MON_ADDR+1
0003CEr 2  8D 12 03       sta BRK_PCH
0003D1r 2  4C rr rr       jmp @ModLoop
0003D4r 2               
0003D4r 2               @ModA:
0003D4r 2  E6 35          inc MON_IDX                   ; Advance past 'A'
0003D6r 2  20 rr rr       jsr MonSkipSpaces
0003D9r 2  20 rr rr       jsr MonParseHex2
0003DCr 2  B0 03          bcs @ModAOk
0003DEr 2  4C rr rr       jmp @ModError
0003E1r 2               @ModAOk:
0003E1r 2  8D 13 03       sta BRK_A
0003E4r 2  4C rr rr       jmp @ModLoop
0003E7r 2               
0003E7r 2               @ModX:
0003E7r 2  E6 35          inc MON_IDX                   ; Advance past 'X'
0003E9r 2  20 rr rr       jsr MonSkipSpaces
0003ECr 2  20 rr rr       jsr MonParseHex2
0003EFr 2  B0 03          bcs @ModXOk
0003F1r 2  4C rr rr       jmp @ModError
0003F4r 2               @ModXOk:
0003F4r 2  8D 14 03       sta BRK_X
0003F7r 2  4C rr rr       jmp @ModLoop
0003FAr 2               
0003FAr 2               @ModY:
0003FAr 2  E6 35          inc MON_IDX                   ; Advance past 'Y'
0003FCr 2  20 rr rr       jsr MonSkipSpaces
0003FFr 2  20 rr rr       jsr MonParseHex2
000402r 2  B0 03          bcs @ModYOk
000404r 2  4C rr rr       jmp @ModError
000407r 2               @ModYOk:
000407r 2  8D 15 03       sta BRK_Y
00040Ar 2  4C rr rr       jmp @ModLoop
00040Dr 2               
00040Dr 2               @ModCheckSP:
00040Dr 2                 ; Expect "SP" — must see 'P' next
00040Dr 2  E6 35          inc MON_IDX
00040Fr 2  A4 35          ldy MON_IDX
000411r 2  B9 34 04       lda MON_LINBUF,y
000414r 2  C9 50          cmp #'P'
000416r 2  F0 07          beq @ModSPGotP
000418r 2  C9 70          cmp #'p'
00041Ar 2  F0 03          beq @ModSPGotP
00041Cr 2  4C rr rr       jmp @ModError                 ; Just 'S' alone is invalid
00041Fr 2               @ModSPGotP:
00041Fr 2  E6 35          inc MON_IDX                   ; Advance past 'P'
000421r 2  20 rr rr       jsr MonSkipSpaces
000424r 2  20 rr rr       jsr MonParseHex2
000427r 2  B0 03          bcs @ModSPOk
000429r 2  4C rr rr       jmp @ModError
00042Cr 2               @ModSPOk:
00042Cr 2  8D 16 03       sta BRK_SP
00042Fr 2  4C rr rr       jmp @ModLoop
000432r 2               
000432r 2               @ModError:
000432r 2  4C rr rr       jmp MonPrintError
000435r 2               @ModDone:
000435r 2                 ; Display updated registers
000435r 2  20 rr rr       jsr MonShowRegs
000438r 2  60             rts
000439r 2               
000439r 2               ; ============================================================================
000439r 2               ; MonCmdDir — Display CF directory listing
000439r 2               ; Syntax: @
000439r 2               ; ============================================================================
000439r 2               
000439r 2               MonCmdDir:
000439r 2  20 rr rr       jsr FsDirectory
00043Cr 2  60             rts
00043Dr 2               
00043Dr 2               ; ============================================================================
00043Dr 2               ; MonCmdNum — Number base conversion
00043Dr 2               ; Syntax: N $XXXX  or  N +DDDDD  or  N %BBBBBBBBBBBBBBBB
00043Dr 2               ; Output: $XXXX  +DDDDD  %BBBBBBBBBBBBBBBB
00043Dr 2               ; ============================================================================
00043Dr 2               
00043Dr 2               MonCmdNum:
00043Dr 2  20 rr rr       jsr MonSkipSpaces
000440r 2  A4 35          ldy MON_IDX
000442r 2  B9 34 04       lda MON_LINBUF,y
000445r 2  C9 24          cmp #'$'
000447r 2  F0 0A          beq @NumHex
000449r 2  C9 2B          cmp #'+'
00044Br 2  F0 10          beq @NumDec
00044Dr 2  C9 25          cmp #'%'
00044Fr 2  F0 16          beq @NumBin
000451r 2                 ; Default: try hex (no prefix)
000451r 2  80 02          bra @NumHexDirect
000453r 2               @NumHex:
000453r 2  E6 35          inc MON_IDX                   ; Skip '$'
000455r 2               @NumHexDirect:
000455r 2  20 rr rr       jsr MonParseHex4
000458r 2  B0 17          bcs @NumPrint
00045Ar 2  4C rr rr       jmp MonPrintError
00045Dr 2               @NumDec:
00045Dr 2  E6 35          inc MON_IDX                   ; Skip '+'
00045Fr 2  20 rr rr       jsr MonParseDec16
000462r 2  B0 0D          bcs @NumPrint
000464r 2  4C rr rr       jmp MonPrintError
000467r 2               @NumBin:
000467r 2  E6 35          inc MON_IDX                   ; Skip '%'
000469r 2  20 rr rr       jsr MonParseBin16
00046Cr 2  B0 03          bcs @NumPrint
00046Er 2  4C rr rr       jmp MonPrintError
000471r 2               @NumPrint:
000471r 2                 ; Value is in MON_ADDR
000471r 2  A9 24          lda #'$'
000473r 2  20 rr rr       jsr Chrout
000476r 2  20 rr rr       jsr MonPrintHex4
000479r 2  20 rr rr       jsr MonPrintSpace
00047Cr 2  20 rr rr       jsr MonPrintSpace
00047Fr 2  A9 2B          lda #'+'
000481r 2  20 rr rr       jsr Chrout
000484r 2  20 rr rr       jsr MonPrintDec16
000487r 2  20 rr rr       jsr MonPrintSpace
00048Ar 2  20 rr rr       jsr MonPrintSpace
00048Dr 2  A9 25          lda #'%'
00048Fr 2  20 rr rr       jsr Chrout
000492r 2  20 rr rr       jsr MonPrintBin16
000495r 2  20 rr rr       jsr MonPrintCRLF
000498r 2  60             rts
000499r 2               
000499r 2               ; ============================================================================
000499r 2               ; MonCmdLoad — Load from CF (with quoted filename) or serial (without)
000499r 2               ; Syntax: L ["FILE"] [ADDR]
000499r 2               ; CF path:     L "FILENAME" [ADDR] — load file to addr (default $0800)
000499r 2               ; Serial path: L [ADDR]            — receive binary to addr (default $0800)
000499r 2               ; ============================================================================
000499r 2               
000499r 2               MonCmdLoad:
000499r 2  20 rr rr       jsr MonSkipSpaces
00049Cr 2  A4 35          ldy MON_IDX
00049Er 2  B9 34 04       lda MON_LINBUF,y
0004A1r 2  C9 22          cmp #'"'
0004A3r 2  D0 03          bne @LoadSerial
0004A5r 2  4C rr rr       jmp @LoadCF
0004A8r 2               
0004A8r 2                 ; --- Serial path ---
0004A8r 2               @LoadSerial:
0004A8r 2  20 rr rr       jsr MonParseHex4              ; Optional address
0004ABr 2  90 0A          bcc @LoadSerDefault
0004ADr 2                 ; Got address
0004ADr 2  A5 2E          lda MON_ADDR
0004AFr 2  85 2A          sta XFER_PTR
0004B1r 2  A5 2F          lda MON_ADDR+1
0004B3r 2  85 2B          sta XFER_PTR+1
0004B5r 2  80 08          bra @LoadSerStart
0004B7r 2               @LoadSerDefault:
0004B7r 2  A9 00          lda #<PROGRAM_START
0004B9r 2  85 2A          sta XFER_PTR
0004BBr 2  A9 08          lda #>PROGRAM_START
0004BDr 2  85 2B          sta XFER_PTR+1
0004BFr 2               @LoadSerStart:
0004BFr 2                 ; Save load address for success message
0004BFr 2  A5 2A          lda XFER_PTR
0004C1r 2  85 30          sta MON_END
0004C3r 2  A5 2B          lda XFER_PTR+1
0004C5r 2  85 31          sta MON_END+1
0004C7r 2                 ; Switch to serial I/O
0004C7r 2  AD 06 03       lda IO_MODE
0004CAr 2  8D 19 03       sta XFER_IO_SAVE
0004CDr 2  A9 01          lda #$01
0004CFr 2  8D 06 03       sta IO_MODE
0004D2r 2                 ; Print "READY TO RECEIVE" via serial
0004D2r 2  A9 rr          lda #<MonStrReady
0004D4r 2  85 02          sta STR_PTR
0004D6r 2  A9 rr          lda #>MonStrReady
0004D8r 2  85 03          sta STR_PTR+1
0004DAr 2  20 rr rr       jsr MonSerialPrintStr
0004DDr 2                 ; Read 2-byte size (lo/hi)
0004DDr 2               @SerWaitSzLo:
0004DDr 2  20 rr rr       jsr BufferSize
0004E0r 2  F0 FB          beq @SerWaitSzLo
0004E2r 2  20 rr rr       jsr ReadBuffer
0004E5r 2  8D 17 03       sta XFER_REMAIN
0004E8r 2               @SerWaitSzHi:
0004E8r 2  20 rr rr       jsr BufferSize
0004EBr 2  F0 FB          beq @SerWaitSzHi
0004EDr 2  20 rr rr       jsr ReadBuffer
0004F0r 2  8D 18 03       sta XFER_REMAIN+1
0004F3r 2                 ; Check for zero-length
0004F3r 2  AD 17 03       lda XFER_REMAIN
0004F6r 2  0D 18 03       ora XFER_REMAIN+1
0004F9r 2  F0 25          beq @LoadSerOk
0004FBr 2                 ; Receive data bytes
0004FBr 2  A0 00          ldy #0
0004FDr 2               @LoadSerByte:
0004FDr 2  20 rr rr       jsr BufferSize
000500r 2  F0 FB          beq @LoadSerByte
000502r 2  20 rr rr       jsr ReadBuffer
000505r 2  91 2A          sta (XFER_PTR),y
000507r 2  E6 2A          inc XFER_PTR
000509r 2  D0 02          bne @LoadSerNoPage
00050Br 2  E6 2B          inc XFER_PTR+1
00050Dr 2               @LoadSerNoPage:
00050Dr 2  AD 17 03       lda XFER_REMAIN
000510r 2  D0 03          bne @LoadSerDecLo
000512r 2  CE 18 03       dec XFER_REMAIN+1
000515r 2               @LoadSerDecLo:
000515r 2  CE 17 03       dec XFER_REMAIN
000518r 2  AD 17 03       lda XFER_REMAIN
00051Br 2  0D 18 03       ora XFER_REMAIN+1
00051Er 2  D0 DD          bne @LoadSerByte
000520r 2               @LoadSerOk:
000520r 2                 ; Restore IO_MODE
000520r 2  AD 19 03       lda XFER_IO_SAVE
000523r 2  8D 06 03       sta IO_MODE
000526r 2                 ; Calculate bytes loaded = XFER_PTR - MON_END
000526r 2  38             sec
000527r 2  A5 2A          lda XFER_PTR
000529r 2  E5 30          sbc MON_END
00052Br 2  85 2E          sta MON_ADDR
00052Dr 2  A5 2B          lda XFER_PTR+1
00052Fr 2  E5 31          sbc MON_END+1
000531r 2  85 2F          sta MON_ADDR+1
000533r 2  20 rr rr       jsr MonPrintLoaded            ; Print "LOADED nnnn BYTES AT $xxxx"
000536r 2  60             rts
000537r 2               
000537r 2                 ; --- CF path ---
000537r 2               @LoadCF:
000537r 2  E6 35          inc MON_IDX                   ; Skip opening quote
000539r 2                 ; Point STR_PTR into line buffer at the filename
000539r 2  A4 35          ldy MON_IDX
00053Br 2  98             tya
00053Cr 2  18             clc
00053Dr 2  69 34          adc #<MON_LINBUF
00053Fr 2  85 02          sta STR_PTR
000541r 2  A9 04          lda #>MON_LINBUF
000543r 2  69 00          adc #0
000545r 2  85 03          sta STR_PTR+1
000547r 2                 ; Find closing quote and null-terminate
000547r 2               @LoadCFFindQ:
000547r 2  B9 34 04       lda MON_LINBUF,y
00054Ar 2  F0 0D          beq @LoadCFQDone              ; End of line — use as-is
00054Cr 2  C9 22          cmp #'"'
00054Er 2  F0 03          beq @LoadCFGotQ
000550r 2  C8             iny
000551r 2  80 F4          bra @LoadCFFindQ
000553r 2               @LoadCFGotQ:
000553r 2  A9 00          lda #0
000555r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate at closing quote
000558r 2  C8             iny                           ; Advance past closing quote
000559r 2               @LoadCFQDone:
000559r 2  84 35          sty MON_IDX
00055Br 2                 ; Parse filename into FS_FNAME_BUF
00055Br 2  20 rr rr       jsr FsParseName
00055Er 2                 ; Read directory
00055Er 2  20 rr rr       jsr FsReadDir
000561r 2  90 03          bcc @LoadCFReadOk
000563r 2  4C rr rr       jmp @LoadCFErr
000566r 2               @LoadCFReadOk:
000566r 2                 ; Find file
000566r 2  20 rr rr       jsr FsFindFile
000569r 2  90 03          bcc @LoadCFFound
00056Br 2  4C rr rr       jmp @LoadCFNotFound
00056Er 2               @LoadCFFound:
00056Er 2                 ; Read file metadata
00056Er 2  A0 0C          ldy #FS_ENTRY_START
000570r 2  B1 24          lda (CF_BUF_PTR),y
000572r 2  8D 48 03       sta FS_START_SEC
000575r 2  C8             iny
000576r 2  B1 24          lda (CF_BUF_PTR),y
000578r 2  8D 49 03       sta FS_START_SEC+1
00057Br 2  A0 0E          ldy #FS_ENTRY_FSIZE
00057Dr 2  B1 24          lda (CF_BUF_PTR),y
00057Fr 2  8D 4A 03       sta FS_FILE_SIZE
000582r 2  C8             iny
000583r 2  B1 24          lda (CF_BUF_PTR),y
000585r 2  8D 4B 03       sta FS_FILE_SIZE+1
000588r 2                 ; Calculate sector count = ceil(size / 512)
000588r 2  AD 4B 03       lda FS_FILE_SIZE+1
00058Br 2  4A             lsr a
00058Cr 2  8D 4C 03       sta FS_SEC_COUNT
00058Fr 2  AD 4B 03       lda FS_FILE_SIZE+1
000592r 2  29 01          and #$01
000594r 2  D0 05          bne @LoadCFRound
000596r 2  AD 4A 03       lda FS_FILE_SIZE
000599r 2  F0 03          beq @LoadCFNoRound
00059Br 2               @LoadCFRound:
00059Br 2  EE 4C 03       inc FS_SEC_COUNT
00059Er 2               @LoadCFNoRound:
00059Er 2                 ; Parse optional load address
00059Er 2  20 rr rr       jsr MonSkipSpaces
0005A1r 2  20 rr rr       jsr MonParseHex4
0005A4r 2  90 0A          bcc @LoadCFDefAddr
0005A6r 2                 ; Got address — use it
0005A6r 2  A5 2E          lda MON_ADDR
0005A8r 2  85 24          sta CF_BUF_PTR
0005AAr 2  A5 2F          lda MON_ADDR+1
0005ACr 2  85 25          sta CF_BUF_PTR+1
0005AEr 2  80 08          bra @LoadCFSetLBA
0005B0r 2               @LoadCFDefAddr:
0005B0r 2  A9 00          lda #<PROGRAM_START
0005B2r 2  85 24          sta CF_BUF_PTR
0005B4r 2  A9 08          lda #>PROGRAM_START
0005B6r 2  85 25          sta CF_BUF_PTR+1
0005B8r 2               @LoadCFSetLBA:
0005B8r 2                 ; Save load base address for message
0005B8r 2  A5 24          lda CF_BUF_PTR
0005BAr 2  85 30          sta MON_END
0005BCr 2  A5 25          lda CF_BUF_PTR+1
0005BEr 2  85 31          sta MON_END+1
0005C0r 2                 ; Set up LBA
0005C0r 2  AD 48 03       lda FS_START_SEC
0005C3r 2  85 26          sta CF_LBA
0005C5r 2  AD 49 03       lda FS_START_SEC+1
0005C8r 2  85 27          sta CF_LBA+1
0005CAr 2  64 28          stz CF_LBA+2
0005CCr 2  64 29          stz CF_LBA+3
0005CEr 2                 ; Read sectors
0005CEr 2  AE 4C 03       ldx FS_SEC_COUNT
0005D1r 2  F0 10          beq @LoadCFOk
0005D3r 2               @LoadCFSec:
0005D3r 2  DA             phx
0005D4r 2  20 rr rr       jsr StReadSector              ; Reads 512 bytes, advances CF_BUF_PTR
0005D7r 2  B0 18          bcs @LoadCFSecErr
0005D9r 2  E6 26          inc CF_LBA
0005DBr 2  D0 02          bne @LoadCFSecNext
0005DDr 2  E6 27          inc CF_LBA+1
0005DFr 2               @LoadCFSecNext:
0005DFr 2  FA             plx
0005E0r 2  CA             dex
0005E1r 2  D0 F0          bne @LoadCFSec
0005E3r 2               @LoadCFOk:
0005E3r 2                 ; Print success
0005E3r 2  AD 4A 03       lda FS_FILE_SIZE
0005E6r 2  85 2E          sta MON_ADDR
0005E8r 2  AD 4B 03       lda FS_FILE_SIZE+1
0005EBr 2  85 2F          sta MON_ADDR+1
0005EDr 2  20 rr rr       jsr MonPrintLoaded            ; Print "LOADED nnnn BYTES AT $xxxx"
0005F0r 2  60             rts
0005F1r 2               @LoadCFSecErr:
0005F1r 2  FA             plx                           ; Balance stack
0005F2r 2               @LoadCFErr:
0005F2r 2  20 rr rr       jsr MonPrintIOErr
0005F5r 2  60             rts
0005F6r 2               @LoadCFNotFound:
0005F6r 2  A2 00          ldx #0
0005F8r 2               @LoadCFNFLoop:
0005F8r 2  BD rr rr       lda MonStrNotFound,x
0005FBr 2  F0 06          beq @LoadCFNFDone
0005FDr 2  20 rr rr       jsr Chrout
000600r 2  E8             inx
000601r 2  80 F5          bra @LoadCFNFLoop
000603r 2               @LoadCFNFDone:
000603r 2  20 rr rr       jsr MonPrintCRLF
000606r 2  60             rts
000607r 2               
000607r 2               ; ============================================================================
000607r 2               ; MonCmdSave — Save to CF (with quoted filename) or serial (without)
000607r 2               ; Syntax: S ["FILE"] ADDR1 ADDR2
000607r 2               ; CF path:     S "FILENAME" ADDR1 ADDR2 — save [addr1,addr2) to file
000607r 2               ; Serial path: S ADDR1 ADDR2            — send [addr1,addr2) via serial
000607r 2               ; ============================================================================
000607r 2               
000607r 2               MonCmdSave:
000607r 2  20 rr rr       jsr MonSkipSpaces
00060Ar 2  A4 35          ldy MON_IDX
00060Cr 2  B9 34 04       lda MON_LINBUF,y
00060Fr 2  C9 22          cmp #'"'
000611r 2  D0 03          bne @SaveSerial
000613r 2  4C rr rr       jmp @SaveCF
000616r 2               
000616r 2                 ; --- Serial path ---
000616r 2               @SaveSerial:
000616r 2  20 rr rr       jsr MonParseHex4              ; Parse start address
000619r 2  B0 03          bcs @SaveSerGotStart
00061Br 2  4C rr rr       jmp @SaveError
00061Er 2               @SaveSerGotStart:
00061Er 2  A5 2E          lda MON_ADDR
000620r 2  85 2A          sta XFER_PTR
000622r 2  A5 2F          lda MON_ADDR+1
000624r 2  85 2B          sta XFER_PTR+1
000626r 2  20 rr rr       jsr MonSkipSpaces
000629r 2  20 rr rr       jsr MonParseHex4              ; Parse end address
00062Cr 2  B0 03          bcs @SaveSerGotEnd
00062Er 2  4C rr rr       jmp @SaveError
000631r 2               @SaveSerGotEnd:
000631r 2                 ; Calculate size = end - start
000631r 2  38             sec
000632r 2  A5 2E          lda MON_ADDR
000634r 2  E5 2A          sbc XFER_PTR
000636r 2  8D 17 03       sta XFER_REMAIN
000639r 2  A5 2F          lda MON_ADDR+1
00063Br 2  E5 2B          sbc XFER_PTR+1
00063Dr 2  8D 18 03       sta XFER_REMAIN+1
000640r 2                 ; Save size for message
000640r 2  AD 17 03       lda XFER_REMAIN
000643r 2  85 30          sta MON_END
000645r 2  AD 18 03       lda XFER_REMAIN+1
000648r 2  85 31          sta MON_END+1
00064Ar 2                 ; Switch to serial I/O
00064Ar 2  AD 06 03       lda IO_MODE
00064Dr 2  8D 19 03       sta XFER_IO_SAVE
000650r 2  A9 01          lda #$01
000652r 2  8D 06 03       sta IO_MODE
000655r 2                 ; Send 2-byte size (lo/hi)
000655r 2  AD 17 03       lda XFER_REMAIN
000658r 2  20 rr rr       jsr SerialChrout
00065Br 2  AD 18 03       lda XFER_REMAIN+1
00065Er 2  20 rr rr       jsr SerialChrout
000661r 2                 ; Check for zero-length
000661r 2  AD 17 03       lda XFER_REMAIN
000664r 2  0D 18 03       ora XFER_REMAIN+1
000667r 2  F0 20          beq @SaveSerDone
000669r 2                 ; Send data bytes
000669r 2  A0 00          ldy #0
00066Br 2               @SaveSerByte:
00066Br 2  B1 2A          lda (XFER_PTR),y
00066Dr 2  20 rr rr       jsr SerialChrout
000670r 2  E6 2A          inc XFER_PTR
000672r 2  D0 02          bne @SaveSerNoPage
000674r 2  E6 2B          inc XFER_PTR+1
000676r 2               @SaveSerNoPage:
000676r 2  AD 17 03       lda XFER_REMAIN
000679r 2  D0 03          bne @SaveSerDecLo
00067Br 2  CE 18 03       dec XFER_REMAIN+1
00067Er 2               @SaveSerDecLo:
00067Er 2  CE 17 03       dec XFER_REMAIN
000681r 2  AD 17 03       lda XFER_REMAIN
000684r 2  0D 18 03       ora XFER_REMAIN+1
000687r 2  D0 E2          bne @SaveSerByte
000689r 2               @SaveSerDone:
000689r 2                 ; Restore IO_MODE
000689r 2  AD 19 03       lda XFER_IO_SAVE
00068Cr 2  8D 06 03       sta IO_MODE
00068Fr 2                 ; Print "SAVED nnnn BYTES"
00068Fr 2  A5 30          lda MON_END
000691r 2  85 2E          sta MON_ADDR
000693r 2  A5 31          lda MON_END+1
000695r 2  85 2F          sta MON_ADDR+1
000697r 2  20 rr rr       jsr MonPrintSaved
00069Ar 2  60             rts
00069Br 2               
00069Br 2                 ; --- CF path ---
00069Br 2               @SaveCF:
00069Br 2  E6 35          inc MON_IDX                   ; Skip opening quote
00069Dr 2                 ; Point STR_PTR into line buffer at the filename
00069Dr 2  A4 35          ldy MON_IDX
00069Fr 2  98             tya
0006A0r 2  18             clc
0006A1r 2  69 34          adc #<MON_LINBUF
0006A3r 2  85 02          sta STR_PTR
0006A5r 2  A9 04          lda #>MON_LINBUF
0006A7r 2  69 00          adc #0
0006A9r 2  85 03          sta STR_PTR+1
0006ABr 2                 ; Find closing quote and null-terminate
0006ABr 2               @SaveCFFindQ:
0006ABr 2  B9 34 04       lda MON_LINBUF,y
0006AEr 2  F0 0D          beq @SaveCFQDone
0006B0r 2  C9 22          cmp #'"'
0006B2r 2  F0 03          beq @SaveCFGotQ
0006B4r 2  C8             iny
0006B5r 2  80 F4          bra @SaveCFFindQ
0006B7r 2               @SaveCFGotQ:
0006B7r 2  A9 00          lda #0
0006B9r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate at closing quote
0006BCr 2  C8             iny
0006BDr 2               @SaveCFQDone:
0006BDr 2  84 35          sty MON_IDX
0006BFr 2                 ; Parse filename
0006BFr 2  20 rr rr       jsr FsParseName
0006C2r 2                 ; Parse start address
0006C2r 2  20 rr rr       jsr MonSkipSpaces
0006C5r 2  20 rr rr       jsr MonParseHex4
0006C8r 2  B0 03          bcs @SaveCFGotStart
0006CAr 2  4C rr rr       jmp @SaveError
0006CDr 2               @SaveCFGotStart:
0006CDr 2  A5 2E          lda MON_ADDR
0006CFr 2  85 32          sta MON_TMP                   ; MON_TMP = start address
0006D1r 2  A5 2F          lda MON_ADDR+1
0006D3r 2  85 33          sta MON_TMP+1
0006D5r 2                 ; Parse end address
0006D5r 2  20 rr rr       jsr MonSkipSpaces
0006D8r 2  20 rr rr       jsr MonParseHex4
0006DBr 2  B0 03          bcs @SaveCFGotEnd
0006DDr 2  4C rr rr       jmp @SaveError
0006E0r 2               @SaveCFGotEnd:
0006E0r 2                 ; Calculate size = end - start
0006E0r 2  38             sec
0006E1r 2  A5 2E          lda MON_ADDR
0006E3r 2  E5 32          sbc MON_TMP
0006E5r 2  8D 4A 03       sta FS_FILE_SIZE
0006E8r 2  A5 2F          lda MON_ADDR+1
0006EAr 2  E5 33          sbc MON_TMP+1
0006ECr 2  8D 4B 03       sta FS_FILE_SIZE+1
0006EFr 2                 ; Read directory
0006EFr 2  20 rr rr       jsr FsReadDir
0006F2r 2  90 03          bcc @SaveCFReadOk
0006F4r 2  4C rr rr       jmp @SaveCFIOErr
0006F7r 2               @SaveCFReadOk:
0006F7r 2                 ; Try to find existing file with same name
0006F7r 2  20 rr rr       jsr FsFindFile
0006FAr 2  90 08          bcc @SaveCFOverwrite
0006FCr 2                 ; Not found — find a free slot
0006FCr 2  20 rr rr       jsr FsFindFree
0006FFr 2  90 11          bcc @SaveCFAlloc
000701r 2  4C rr rr       jmp @SaveCFDirFull
000704r 2               @SaveCFOverwrite:
000704r 2                 ; Clear old entry's flags
000704r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000706r 2  A9 00          lda #$00
000708r 2  91 24          sta (CF_BUF_PTR),y
00070Ar 2                 ; Find a free slot (could be the one we just freed)
00070Ar 2  20 rr rr       jsr FsFindFree
00070Dr 2  90 03          bcc @SaveCFAllocOk
00070Fr 2  4C rr rr       jmp @SaveCFDirFull
000712r 2               @SaveCFAllocOk:
000712r 2               @SaveCFAlloc:
000712r 2                 ; Save CF_BUF_PTR (points to free entry)
000712r 2  A5 24          lda CF_BUF_PTR
000714r 2  48             pha
000715r 2  A5 25          lda CF_BUF_PTR+1
000717r 2  48             pha
000718r 2                 ; Calculate next free sector
000718r 2  20 rr rr       jsr FsCalcNextSec
00071Br 2                 ; Restore CF_BUF_PTR
00071Br 2  68             pla
00071Cr 2  85 25          sta CF_BUF_PTR+1
00071Er 2  68             pla
00071Fr 2  85 24          sta CF_BUF_PTR
000721r 2                 ; Calculate sectors needed
000721r 2  AD 4B 03       lda FS_FILE_SIZE+1
000724r 2  4A             lsr a
000725r 2  8D 4C 03       sta FS_SEC_COUNT
000728r 2  AD 4B 03       lda FS_FILE_SIZE+1
00072Br 2  29 01          and #$01
00072Dr 2  D0 05          bne @SaveCFRound
00072Fr 2  AD 4A 03       lda FS_FILE_SIZE
000732r 2  F0 03          beq @SaveCFNoRound
000734r 2               @SaveCFRound:
000734r 2  EE 4C 03       inc FS_SEC_COUNT
000737r 2               @SaveCFNoRound:
000737r 2                 ; Fill in directory entry
000737r 2                 ; Copy filename (11 bytes)
000737r 2  A0 00          ldy #0
000739r 2               @SaveCFCopyName:
000739r 2  B9 50 03       lda FS_FNAME_BUF,y
00073Cr 2  91 24          sta (CF_BUF_PTR),y
00073Er 2  C8             iny
00073Fr 2  C0 0B          cpy #11
000741r 2  D0 F6          bne @SaveCFCopyName
000743r 2                 ; Set flags = in use
000743r 2  A9 01          lda #FS_FLAG_USED
000745r 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
000747r 2                 ; Set start sector
000747r 2  A0 0C          ldy #FS_ENTRY_START
000749r 2  AD 4E 03       lda FS_NEXT_SEC
00074Cr 2  91 24          sta (CF_BUF_PTR),y
00074Er 2  8D 48 03       sta FS_START_SEC
000751r 2  C8             iny
000752r 2  AD 4F 03       lda FS_NEXT_SEC+1
000755r 2  91 24          sta (CF_BUF_PTR),y
000757r 2  8D 49 03       sta FS_START_SEC+1
00075Ar 2                 ; Set file size
00075Ar 2  A0 0E          ldy #FS_ENTRY_FSIZE
00075Cr 2  AD 4A 03       lda FS_FILE_SIZE
00075Fr 2  91 24          sta (CF_BUF_PTR),y
000761r 2  C8             iny
000762r 2  AD 4B 03       lda FS_FILE_SIZE+1
000765r 2  91 24          sta (CF_BUF_PTR),y
000767r 2                 ; Clear reserved bytes
000767r 2  A0 10          ldy #$10
000769r 2  A9 00          lda #$00
00076Br 2               @SaveCFClrRsv:
00076Br 2  91 24          sta (CF_BUF_PTR),y
00076Dr 2  C8             iny
00076Er 2  C0 20          cpy #FS_ENTRY_SIZE
000770r 2  D0 F9          bne @SaveCFClrRsv
000772r 2                 ; Write updated directory
000772r 2  20 rr rr       jsr FsWriteDir
000775r 2  B0 3A          bcs @SaveCFIOErr
000777r 2                 ; Write data sectors from user-specified start address (MON_TMP)
000777r 2  AD 48 03       lda FS_START_SEC
00077Ar 2  85 26          sta CF_LBA
00077Cr 2  AD 49 03       lda FS_START_SEC+1
00077Fr 2  85 27          sta CF_LBA+1
000781r 2  64 28          stz CF_LBA+2
000783r 2  64 29          stz CF_LBA+3
000785r 2                 ; Source = MON_TMP (start address)
000785r 2  A5 32          lda MON_TMP
000787r 2  85 24          sta CF_BUF_PTR
000789r 2  A5 33          lda MON_TMP+1
00078Br 2  85 25          sta CF_BUF_PTR+1
00078Dr 2  AE 4C 03       ldx FS_SEC_COUNT
000790r 2  F0 10          beq @SaveCFOk
000792r 2               @SaveCFSec:
000792r 2  DA             phx
000793r 2  20 rr rr       jsr StWriteSector             ; Writes 512 bytes, advances CF_BUF_PTR
000796r 2  B0 18          bcs @SaveCFSecErr
000798r 2  E6 26          inc CF_LBA
00079Ar 2  D0 02          bne @SaveCFSecNext
00079Cr 2  E6 27          inc CF_LBA+1
00079Er 2               @SaveCFSecNext:
00079Er 2  FA             plx
00079Fr 2  CA             dex
0007A0r 2  D0 F0          bne @SaveCFSec
0007A2r 2               @SaveCFOk:
0007A2r 2  AD 4A 03       lda FS_FILE_SIZE
0007A5r 2  85 2E          sta MON_ADDR
0007A7r 2  AD 4B 03       lda FS_FILE_SIZE+1
0007AAr 2  85 2F          sta MON_ADDR+1
0007ACr 2  20 rr rr       jsr MonPrintSaved             ; Print "SAVED nnnn BYTES"
0007AFr 2  60             rts
0007B0r 2               @SaveCFSecErr:
0007B0r 2  FA             plx                           ; Balance stack
0007B1r 2               @SaveCFIOErr:
0007B1r 2  20 rr rr       jsr MonPrintIOErr
0007B4r 2  60             rts
0007B5r 2               @SaveCFDirFull:
0007B5r 2  A2 00          ldx #0
0007B7r 2               @SaveCFDFLoop:
0007B7r 2  BD rr rr       lda MonStrDirFull,x
0007BAr 2  F0 06          beq @SaveCFDFDone
0007BCr 2  20 rr rr       jsr Chrout
0007BFr 2  E8             inx
0007C0r 2  80 F5          bra @SaveCFDFLoop
0007C2r 2               @SaveCFDFDone:
0007C2r 2  20 rr rr       jsr MonPrintCRLF
0007C5r 2  60             rts
0007C6r 2               @SaveError:
0007C6r 2  4C rr rr       jmp MonPrintError
0007C9r 2               
0007C9r 2               ; ============================================================================
0007C9r 2               ; MonCmdM — Memory dump (hex + ASCII, 8 bytes/row)
0007C9r 2               ; Syntax: M [addr] [addr]
0007C9r 2               ; Default: 8 lines (64 bytes). Remembers position for continuation.
0007C9r 2               ; ============================================================================
0007C9r 2               
0007C9r 2               MonCmdM:
0007C9r 2  20 rr rr       jsr MonSkipSpaces
0007CCr 2  20 rr rr       jsr MonParseHex4
0007CFr 2  90 2A          bcc @UseDefault               ; No address given — use current MON_ADDR
0007D1r 2                 ; Got first address in MON_ADDR — save it
0007D1r 2  A5 2E          lda MON_ADDR
0007D3r 2  85 32          sta MON_TMP
0007D5r 2  A5 2F          lda MON_ADDR+1
0007D7r 2  85 33          sta MON_TMP+1
0007D9r 2  20 rr rr       jsr MonSkipSpaces
0007DCr 2  20 rr rr       jsr MonParseHex4
0007DFr 2  90 12          bcc @StartOnly
0007E1r 2                 ; Got second address (end) in MON_ADDR
0007E1r 2  A5 2E          lda MON_ADDR
0007E3r 2  85 30          sta MON_END
0007E5r 2  A5 2F          lda MON_ADDR+1
0007E7r 2  85 31          sta MON_END+1
0007E9r 2                 ; Restore start address
0007E9r 2  A5 32          lda MON_TMP
0007EBr 2  85 2E          sta MON_ADDR
0007EDr 2  A5 33          lda MON_TMP+1
0007EFr 2  85 2F          sta MON_ADDR+1
0007F1r 2  80 15          bra @DumpRange
0007F3r 2               @StartOnly:
0007F3r 2                 ; Only start address — restore from MON_TMP
0007F3r 2  A5 32          lda MON_TMP
0007F5r 2  85 2E          sta MON_ADDR
0007F7r 2  A5 33          lda MON_TMP+1
0007F9r 2  85 2F          sta MON_ADDR+1
0007FBr 2               @UseDefault:
0007FBr 2                 ; Set end = start + 63 (8 lines x 8 bytes)
0007FBr 2  18             clc
0007FCr 2  A5 2E          lda MON_ADDR
0007FEr 2  69 3F          adc #63
000800r 2  85 30          sta MON_END
000802r 2  A5 2F          lda MON_ADDR+1
000804r 2  69 00          adc #0
000806r 2  85 31          sta MON_END+1
000808r 2               @DumpRange:
000808r 2  20 rr rr       jsr MonDumpLine
00080Br 2  B0 0E          bcs @DumpDone                 ; Carry set = address wrapped past $FFFF
00080Dr 2                 ; Check if MON_ADDR > MON_END
00080Dr 2  A5 31          lda MON_END+1
00080Fr 2  C5 2F          cmp MON_ADDR+1
000811r 2  90 08          bcc @DumpDone
000813r 2  D0 F3          bne @DumpRange
000815r 2  A5 30          lda MON_END
000817r 2  C5 2E          cmp MON_ADDR
000819r 2  B0 ED          bcs @DumpRange
00081Br 2               @DumpDone:
00081Br 2  60             rts
00081Cr 2               
00081Cr 2               ; MonDumpLine — Dump 8 bytes at MON_ADDR as hex + ASCII, advance by 8
00081Cr 2               
00081Cr 2               MonDumpLine:
00081Cr 2                 ; Print ".:ADDR " (39 chars/line avoids 40-col auto-wrap + CRLF double-newline)
00081Cr 2  A9 2E          lda #'.'
00081Er 2  20 rr rr       jsr Chrout
000821r 2  A9 3A          lda #':'
000823r 2  20 rr rr       jsr Chrout
000826r 2  20 rr rr       jsr MonPrintHex4
000829r 2  20 rr rr       jsr MonPrintSpace
00082Cr 2                 ; Print 8 hex bytes
00082Cr 2  A0 00          ldy #0
00082Er 2               @HexLoop:
00082Er 2  B1 2E          lda (MON_ADDR),y
000830r 2  5A             phy
000831r 2  20 rr rr       jsr MonPrintHex2
000834r 2  20 rr rr       jsr MonPrintSpace
000837r 2  7A             ply
000838r 2  C8             iny
000839r 2  C0 08          cpy #8
00083Br 2  90 F1          bcc @HexLoop
00083Dr 2                 ; Print 8 ASCII characters (no extra space — fits 40 cols)
00083Dr 2  A0 00          ldy #0
00083Fr 2               @AsciiLoop:
00083Fr 2  B1 2E          lda (MON_ADDR),y
000841r 2  C9 20          cmp #$20
000843r 2  90 04          bcc @NotPrint
000845r 2  C9 7F          cmp #$7F
000847r 2  90 02          bcc @DoPrint
000849r 2               @NotPrint:
000849r 2  A9 2E          lda #'.'
00084Br 2               @DoPrint:
00084Br 2  5A             phy
00084Cr 2  20 rr rr       jsr Chrout
00084Fr 2  7A             ply
000850r 2  C8             iny
000851r 2  C0 08          cpy #8
000853r 2  90 EA          bcc @AsciiLoop
000855r 2                 ; Advance MON_ADDR by 8
000855r 2  18             clc
000856r 2  A5 2E          lda MON_ADDR
000858r 2  69 08          adc #8
