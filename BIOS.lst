001161r 2  20 rr rr       jsr Chrout
001164r 2  20 rr rr       jsr BasAdvTxtPtr
001167r 2  80 EF          bra @InputPromptCh
001169r 2               @InputPromptEnd:
001169r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
00116Cr 2               @InputPromptDone:
00116Cr 2                 ; Expect semicolon or comma after prompt
00116Cr 2  20 rr rr       jsr BasSkipSpaces
