001140r 1               .segment "BASIC"
000000r 1               .include "BASIC.asm"
000000r 2               ; ***                         ***
000000r 2               ; ***   Integer BASIC v1.0    ***
000000r 2               ; ***   for 6502-COBBIOS      ***
000000r 2               ; ***   $E000-$FEFF (7936B)   ***
000000r 2               ; ***                         ***
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Zero Page — BASIC Interpreter Workspace ($04-$23)
000000r 2               ; ============================================================================
000000r 2               ; $00-$03 reserved by Kernal (READ_PTR, WRITE_PTR, STR_PTR)
000000r 2               
000000r 2               BAS_TXTPTR          := $04               ; $04-$05 - Current parse/exec pointer
000000r 2               BAS_CURLINE         := $06               ; $06-$07 - Pointer to current line start
000000r 2               BAS_LINENUM         := $08               ; $08-$09 - Current line number (16-bit)
000000r 2               BAS_ACC             := $0A               ; $0A-$0B - Expression accumulator (16-bit)
000000r 2               BAS_AUX             := $0C               ; $0C-$0D - Auxiliary register (right operand)
000000r 2               BAS_TMP1            := $0E               ; $0E-$0F - General-purpose temp / pointer
000000r 2               BAS_TMP2            := $10               ; $10-$11 - General-purpose temp / pointer
000000r 2               BAS_PRGEND          := $12               ; $12-$13 - First byte past end of program
000000r 2               BAS_VARPTR          := $14               ; $14-$15 - Variable address pointer
000000r 2               BAS_TOKIDX          := $16               ; $16     - Tokenizer index / scratch
000000r 2               BAS_FLAGS           := $17               ; $17     - Runtime flags
000000r 2               BAS_RNDSEED         := $18               ; $18-$19 - PRNG state (16-bit)
000000r 2               BAS_GOSUBSP         := $1A               ; $1A     - GOSUB stack pointer (byte index)
000000r 2               BAS_FORSP           := $1B               ; $1B     - FOR stack pointer (byte index)
000000r 2               BAS_SCRATCH         := $1C               ; $1C-$1D - Scratch / division workspace
000000r 2               BAS_SCRATCH2        := $1E               ; $1E-$1F - Scratch / division workspace
000000r 2               BAS_SIGN            := $20               ; $20     - Sign tracking for mul/div
000000r 2               BAS_TEMP            := $21               ; $21     - General temp byte
000000r 2               BAS_NUMTMP          := $22               ; $22-$23 - Number parsing accumulator
000000r 2               
000000r 2               ; BAS_FLAGS bit definitions
000000r 2               BAS_FLAG_RUN        = %00000001          ; Bit 0: program is running
000000r 2               BAS_FLAG_NOSEP      = %00000010          ; Bit 1: suppress CRLF after PRINT
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; RAM Layout — USER_VARS ($0400-$07FF)
000000r 2               ; ============================================================================
000000r 2               
000000r 2               BAS_VARS            := $0400             ; $0400-$0433 - 26 vars A-Z (2 bytes each)
000000r 2               BAS_LINBUF          := $0434             ; $0434-$04FF - Input line buffer (204 bytes)
000000r 2               BAS_GOSUBSTK        := $0500             ; $0500-$057F - GOSUB stack (128 bytes, 32 levels)
000000r 2               BAS_FORSTK          := $0580             ; $0580-$05FF - FOR/NEXT stack (128 bytes, 8 levels)
000000r 2               BAS_TOKBUF          := $0600             ; $0600-$06FF - Tokenized line buffer (256 bytes)
000000r 2               BAS_STRBUF          := $0700             ; $0700-$07FF - Scratch / number-to-string (256 bytes)
000000r 2               
000000r 2               ; Derived constants
000000r 2               BAS_LINBUF_SIZE     = 200                ; Max input line length
000000r 2               BAS_GOSUBSTK_SIZE   = 128               ; GOSUB stack capacity
000000r 2               BAS_FORSTK_SIZE     = 128               ; FOR stack capacity
000000r 2               BAS_GOSUB_ENTRY     = 2                  ; Bytes per GOSUB entry (CURLINE)
000000r 2               BAS_FOR_ENTRY       = 16                 ; Bytes per FOR entry
000000r 2               BAS_GOSUB_MAX       = BAS_GOSUBSTK_SIZE / BAS_GOSUB_ENTRY  ; 64 levels
000000r 2               BAS_FOR_MAX         = BAS_FORSTK_SIZE / BAS_FOR_ENTRY       ; 8 levels
000000r 2               
000000r 2               ; Program space
000000r 2               BAS_PRG_START       = PROGRAM_START      ; $0800 - Start of BASIC program storage
000000r 2               BAS_PRG_END         = $7FFF              ; Last usable byte for programs
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Program Line Format (in memory at $0800-$7FFF)
000000r 2               ; ============================================================================
000000r 2               ; Each stored line:
000000r 2               ;   [2 bytes] Next-line pointer (little-endian; $0000 = end of program)
000000r 2               ;   [2 bytes] Line number (little-endian; 0-65535)
000000r 2               ;   [N bytes] Tokenized payload
000000r 2               ;   [1 byte]  $00 terminator
000000r 2               ;
000000r 2               ; Offsets within a line:
000000r 2               LINE_NEXT           = 0                  ; Offset to next-line pointer
000000r 2               LINE_NUM            = 2                  ; Offset to line number
000000r 2               LINE_PAYLOAD        = 4                  ; Offset to tokenized data
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Token Definitions ($80+)
000000r 2               ; ============================================================================
000000r 2               ; Tokens >= $80 represent keywords; raw ASCII is stored as-is.
000000r 2               
000000r 2               ; Statement tokens
000000r 2               TOK_PRINT           = $80
000000r 2               TOK_INPUT           = $81
000000r 2               TOK_LET             = $82
000000r 2               TOK_GOTO            = $83
000000r 2               TOK_GOSUB           = $84
000000r 2               TOK_RETURN          = $85
000000r 2               TOK_IF              = $86
000000r 2               TOK_THEN            = $87
000000r 2               TOK_FOR             = $88
000000r 2               TOK_TO              = $89
000000r 2               TOK_STEP            = $8A
000000r 2               TOK_NEXT            = $8B
000000r 2               TOK_REM             = $8C
000000r 2               TOK_END             = $8D
000000r 2               TOK_LIST            = $8E
000000r 2               TOK_RUN             = $8F
000000r 2               TOK_NEW             = $90
000000r 2               TOK_CLR             = $91
000000r 2               TOK_PEEK            = $92
000000r 2               TOK_POKE            = $93
000000r 2               TOK_ABS             = $94
000000r 2               TOK_RND             = $95
000000r 2               TOK_NOT             = $96
000000r 2               TOK_AND             = $97
000000r 2               TOK_OR              = $98
000000r 2               TOK_MOD             = $99
000000r 2               
000000r 2               TOK_BRK             = $9D
000000r 2               TOK_SYS             = $9E
000000r 2               TOK_LOAD            = $9F
000000r 2               TOK_SAVE            = $A0
000000r 2               TOK_DIR             = $A1
000000r 2               TOK_DEL             = $A2
000000r 2               TOK_CLS             = $A3
000000r 2               TOK_LOCATE          = $A4
000000r 2               TOK_COLOR           = $A5
000000r 2               TOK_JOY             = $A6
000000r 2               TOK_SOUND           = $A7
000000r 2               TOK_VOL             = $A8
000000r 2               TOK_TIME            = $A9
000000r 2               TOK_DATE            = $AA
000000r 2               TOK_WAIT            = $AB
000000r 2               TOK_PAUSE           = $AC
000000r 2               TOK_BANK            = $AD
000000r 2               TOK_SGN             = $AE
000000r 2               
000000r 2               ; Multi-char operator tokens
000000r 2               TOK_GE              = $9A               ; >=
000000r 2               TOK_LE              = $9B               ; <=
000000r 2               TOK_NE              = $9C               ; <>
000000r 2               
000000r 2               ; ASCII characters used in parsing (for readability)
000000r 2               CH_CR               = $0D               ; Carriage return
000000r 2               CH_LF               = $0A               ; Line feed
000000r 2               CH_SPACE            = $20               ; Space
000000r 2               CH_QUOTE            = $22               ; Double-quote
000000r 2               CH_COMMA            = $2C               ; Comma
000000r 2               CH_MINUS            = $2D               ; Minus / dash
000000r 2               CH_COLON            = $3A               ; Colon (statement separator)
000000r 2               CH_SEMICOL          = $3B               ; Semicolon
000000r 2               CH_EQUALS           = $3D               ; Equals sign
000000r 2               CH_LPAREN           = $28               ; (
000000r 2               CH_RPAREN           = $29               ; )
000000r 2               CH_LESS             = $3C               ; <
000000r 2               CH_GREATER          = $3E               ; >
000000r 2               CH_PLUS             = $2B               ; +
000000r 2               CH_STAR             = $2A               ; *
000000r 2               CH_SLASH            = $2F               ; /
000000r 2               CH_BKSP             = $08               ; Backspace
000000r 2               CH_ESC              = $1B               ; Escape
000000r 2               CH_CTRLC            = $03               ; Ctrl+C (break)
000000r 2               
000000r 2               ; Error codes
000000r 2               ERR_SYNTAX          = 0
000000r 2               ERR_UNDEF_LINE      = 1
000000r 2               ERR_TYPE_MISMATCH   = 2
000000r 2               ERR_OUT_OF_MEM      = 3
000000r 2               ERR_RET_NO_GOSUB    = 4
000000r 2               ERR_NEXT_NO_FOR     = 5
000000r 2               ERR_DIV_ZERO        = 6
000000r 2               ERR_OVERFLOW        = 7
000000r 2               ERR_ILLEGAL_QTY     = 8
000000r 2               ERR_BREAK           = 9
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Entry Point
000000r 2               ; ============================================================================
000000r 2               
000000r 2               BasEntry:
000000r 2  4C rr rr       jmp BasColdStart               ; Jump to cold start initialization
000003r 2               
000003r 2               ; ============================================================================
000003r 2               ; Cold Start — Initialize interpreter and enter REPL
000003r 2               ; ============================================================================
000003r 2               
000003r 2               BasColdStart:
000003r 2                 ; Initialize program end pointer to start (empty program)
000003r 2  A9 00          lda #<BAS_PRG_START
000005r 2  85 12          sta BAS_PRGEND
000007r 2  A9 08          lda #>BAS_PRG_START
000009r 2  85 13          sta BAS_PRGEND + 1
00000Br 2               
00000Br 2                 ; Write end-of-program sentinel ($0000 next-line pointer)
00000Br 2  A9 00          lda #$00
00000Dr 2  8D 00 08       sta BAS_PRG_START
000010r 2  8D 01 08       sta BAS_PRG_START + 1
000013r 2               
000013r 2                 ; Clear variables and stacks
000013r 2  20 rr rr       jsr BasCmdClr
000016r 2               
000016r 2                 ; Seed PRNG with a nonzero value
000016r 2  A9 A5          lda #$A5
000018r 2  85 18          sta BAS_RNDSEED
00001Ar 2  A9 37          lda #$37
00001Cr 2  85 19          sta BAS_RNDSEED + 1
00001Er 2               
00001Er 2                 ; Print welcome banner
00001Er 2  A9 rr          lda #<BasStrWelcome
000020r 2  85 0E          sta BAS_TMP1
000022r 2  A9 rr          lda #>BasStrWelcome
000024r 2  85 0F          sta BAS_TMP1 + 1
000026r 2  20 rr rr       jsr BasPrintStr
000029r 2               
000029r 2                 ; Print free memory
000029r 2  20 rr rr       jsr BasPrintFree
00002Cr 2               
00002Cr 2                 ; Fall through to main REPL loop
00002Cr 2               
00002Cr 2               ; ============================================================================
00002Cr 2               ; Main REPL Loop
00002Cr 2               ; ============================================================================
00002Cr 2               
00002Cr 2               BasMainLoop:
00002Cr 2                 ; Reset flags for immediate mode
00002Cr 2  64 17          stz BAS_FLAGS
00002Er 2               
00002Er 2                 ; Print OK prompt
00002Er 2  A9 rr          lda #<BasStrOK
000030r 2  85 0E          sta BAS_TMP1
000032r 2  A9 rr          lda #>BasStrOK
000034r 2  85 0F          sta BAS_TMP1 + 1
000036r 2  20 rr rr       jsr BasPrintStr
000039r 2               
000039r 2                 ; Read a line of input
000039r 2  20 rr rr       jsr BasReadLine
00003Cr 2               
00003Cr 2                 ; Tokenize the input line
00003Cr 2  20 rr rr       jsr BasTokenize
00003Fr 2               
00003Fr 2                 ; Check if line has a line number (first 2 bytes of TOKBUF)
00003Fr 2  AD 00 06       lda BAS_TOKBUF
000042r 2  0D 01 06       ora BAS_TOKBUF + 1
000045r 2  F0 06          beq @Immediate                 ; No line number — execute immediately
000047r 2               
000047r 2                 ; Has line number — insert/replace in program
000047r 2  20 rr rr       jsr BasInsertLine
00004Ar 2  4C rr rr       jmp BasMainLoop
00004Dr 2               
00004Dr 2               @Immediate:
00004Dr 2                 ; Set TXTPTR to the tokenized payload (skip 2-byte line number slot)
00004Dr 2  A9 02          lda #<(BAS_TOKBUF + 2)
00004Fr 2  85 04          sta BAS_TXTPTR
000051r 2  A9 06          lda #>(BAS_TOKBUF + 2)
000053r 2  85 05          sta BAS_TXTPTR + 1
000055r 2               
000055r 2                 ; Execute the immediate line
000055r 2  20 rr rr       jsr BasExecLine
000058r 2  4C rr rr       jmp BasMainLoop
00005Br 2               
00005Br 2               ; ============================================================================
00005Br 2               ; CLR — Clear all variables and reset stacks
00005Br 2               ; ============================================================================
00005Br 2               
00005Br 2               BasCmdClr:
00005Br 2                 ; Zero 26 variables (52 bytes at BAS_VARS)
00005Br 2  A2 33          ldx #51
00005Dr 2  A9 00          lda #$00
00005Fr 2               @ClrLoop:
00005Fr 2  9D 00 04       sta BAS_VARS,x
000062r 2  CA             dex
000063r 2  10 FA          bpl @ClrLoop
000065r 2               
000065r 2                 ; Reset GOSUB and FOR stack pointers
000065r 2  64 1A          stz BAS_GOSUBSP
000067r 2  64 1B          stz BAS_FORSP
000069r 2  60             rts
00006Ar 2               
00006Ar 2               ; ============================================================================
00006Ar 2               ; Print Helpers
00006Ar 2               ; ============================================================================
00006Ar 2               
00006Ar 2               ; Print null-terminated string at (BAS_TMP1)
00006Ar 2               ; Modifies: A, Y, Flags
00006Ar 2               BasPrintStr:
00006Ar 2  A0 00          ldy #$00
00006Cr 2               @Loop:
00006Cr 2  B1 0E          lda (BAS_TMP1),y
00006Er 2  F0 06          beq @Done
000070r 2  20 rr rr       jsr Chrout
000073r 2  C8             iny
000074r 2  D0 F6          bne @Loop
000076r 2               @Done:
000076r 2  60             rts
000077r 2               
000077r 2               ; Print CR + LF
000077r 2               ; Modifies: A, Flags
000077r 2               BasPrintCRLF:
000077r 2  A9 0D          lda #CH_CR
000079r 2  20 rr rr       jsr Chrout
00007Cr 2  A9 0A          lda #CH_LF
00007Er 2  20 rr rr       jsr Chrout
000081r 2  60             rts
000082r 2               
000082r 2               ; Print free bytes message: "XXXXX BYTES FREE" + CRLF
000082r 2               ; Modifies: A, X, Y, Flags
000082r 2               BasPrintFree:
000082r 2                 ; Calculate free = BAS_PRG_END - BAS_PRGEND
000082r 2  38             sec
000083r 2  A9 FF          lda #<BAS_PRG_END
000085r 2  E5 12          sbc BAS_PRGEND
000087r 2  85 0A          sta BAS_ACC
000089r 2  A9 7F          lda #>BAS_PRG_END
00008Br 2  E5 13          sbc BAS_PRGEND + 1
00008Dr 2  85 0B          sta BAS_ACC + 1
00008Fr 2               
00008Fr 2  20 rr rr       jsr BasPrintInt
000092r 2               
000092r 2  A9 rr          lda #<BasStrFree
000094r 2  85 0E          sta BAS_TMP1
000096r 2  A9 rr          lda #>BasStrFree
000098r 2  85 0F          sta BAS_TMP1 + 1
00009Ar 2  20 rr rr       jsr BasPrintStr
00009Dr 2  4C rr rr       jmp BasPrintCRLF
0000A0r 2               
0000A0r 2               ; ============================================================================
0000A0r 2               ; Print signed 16-bit integer in BAS_ACC
0000A0r 2               ; Modifies: A, X, Y, Flags
0000A0r 2               ; ============================================================================
0000A0r 2               
0000A0r 2               BasPrintInt:
0000A0r 2                 ; Check if negative (bit 15 set)
0000A0r 2  A5 0B          lda BAS_ACC + 1
0000A2r 2  10 12          bpl @Positive
0000A4r 2               
0000A4r 2                 ; Print minus sign
0000A4r 2  A9 2D          lda #CH_MINUS
0000A6r 2  20 rr rr       jsr Chrout
0000A9r 2               
0000A9r 2                 ; Negate: ACC = 0 - ACC
0000A9r 2  38             sec
0000AAr 2  A9 00          lda #$00
0000ACr 2  E5 0A          sbc BAS_ACC
0000AEr 2  85 0A          sta BAS_ACC
0000B0r 2  A9 00          lda #$00
0000B2r 2  E5 0B          sbc BAS_ACC + 1
0000B4r 2  85 0B          sta BAS_ACC + 1
0000B6r 2               
0000B6r 2               @Positive:
0000B6r 2                 ; Push digits onto CPU stack (divide by 10 repeatedly)
0000B6r 2  A2 00          ldx #$00                       ; Digit counter on stack
0000B8r 2               
0000B8r 2               @DivLoop:
0000B8r 2                 ; Divide BAS_ACC by 10, remainder is next digit (least significant first)
0000B8r 2  A9 00          lda #$00
0000BAr 2  85 1C          sta BAS_SCRATCH               ; Remainder
0000BCr 2  A0 10          ldy #16                        ; 16-bit division
0000BEr 2               
0000BEr 2               @DivBit:
0000BEr 2  06 0A          asl BAS_ACC
0000C0r 2  26 0B          rol BAS_ACC + 1
0000C2r 2  26 1C          rol BAS_SCRATCH
0000C4r 2  38             sec
0000C5r 2  A5 1C          lda BAS_SCRATCH
0000C7r 2  E9 0A          sbc #10
0000C9r 2  90 04          bcc @DivNoSub
0000CBr 2  85 1C          sta BAS_SCRATCH
0000CDr 2  E6 0A          inc BAS_ACC                    ; Set quotient bit
0000CFr 2               
0000CFr 2               @DivNoSub:
0000CFr 2  88             dey
0000D0r 2  D0 EC          bne @DivBit
0000D2r 2               
0000D2r 2                 ; Push remainder digit (ASCII)
0000D2r 2  A5 1C          lda BAS_SCRATCH
0000D4r 2  09 30          ora #$30                       ; Convert to ASCII '0'-'9'
0000D6r 2  48             pha
0000D7r 2  E8             inx                            ; Count digits
0000D8r 2               
0000D8r 2                 ; Check if quotient is zero
0000D8r 2  A5 0A          lda BAS_ACC
0000DAr 2  05 0B          ora BAS_ACC + 1
0000DCr 2  D0 DA          bne @DivLoop
0000DEr 2               
0000DEr 2                 ; Pop and print digits (most significant first)
0000DEr 2               @PrintDigits:
0000DEr 2  68             pla
0000DFr 2  20 rr rr       jsr Chrout
0000E2r 2  CA             dex
0000E3r 2  D0 F9          bne @PrintDigits
0000E5r 2  60             rts
0000E6r 2               
0000E6r 2               ; ============================================================================
0000E6r 2               ; Read a line of input into BAS_LINBUF
0000E6r 2               ; Blocks until CR received. Handles backspace.
0000E6r 2               ; Modifies: A, X, Y, Flags
0000E6r 2               ; ============================================================================
0000E6r 2               
0000E6r 2               BasReadLine:
0000E6r 2  A0 00          ldy #$00                       ; Index into BAS_LINBUF
0000E8r 2               
0000E8r 2               @WaitChar:
0000E8r 2  20 rr rr       jsr Chrin                      ; Non-blocking read (carry=1 if char available)
0000EBr 2  90 FB          bcc @WaitChar                  ; Loop until character available
0000EDr 2               
0000EDr 2                 ; Check for backspace
0000EDr 2  C9 08          cmp #CH_BKSP
0000EFr 2  F0 20          beq @Backspace
0000F1r 2               
0000F1r 2                 ; Check for CR (end of line)
0000F1r 2  C9 0D          cmp #CH_CR
0000F3r 2  F0 2A          beq @Done
0000F5r 2               
0000F5r 2                 ; Check for Ctrl+C (cancel line)
0000F5r 2  C9 03          cmp #CH_CTRLC
0000F7r 2  F0 1F          beq @Cancel
0000F9r 2               
0000F9r 2                 ; Skip non-printable control characters (LF, NUL, ESC, etc.)
0000F9r 2  C9 20          cmp #CH_SPACE
0000FBr 2  90 EB          bcc @WaitChar
0000FDr 2               
0000FDr 2                 ; Ignore if buffer full
0000FDr 2  C0 C8          cpy #BAS_LINBUF_SIZE
0000FFr 2  B0 E7          bcs @WaitChar
000101r 2               
000101r 2                 ; Convert lowercase to uppercase
000101r 2  C9 61          cmp #'a'
000103r 2  90 06          bcc @Store
000105r 2  C9 7B          cmp #'z' + 1
000107r 2  B0 02          bcs @Store
000109r 2  29 DF          and #$DF                       ; Clear bit 5 → uppercase
00010Br 2               @Store:
00010Br 2                 ; Store character and advance
00010Br 2  99 34 04       sta BAS_LINBUF,y
00010Er 2  C8             iny
00010Fr 2  80 D7          bra @WaitChar
000111r 2               
000111r 2               @Backspace:
000111r 2  C0 00          cpy #$00
000113r 2  F0 D3          beq @WaitChar                  ; Nothing to delete
000115r 2  88             dey
000116r 2  80 D0          bra @WaitChar
000118r 2               
000118r 2               @Cancel:
000118r 2  A0 00          ldy #$00                       ; Reset buffer
00011Ar 2  20 rr rr       jsr BasPrintCRLF
00011Dr 2  80 C9          bra @WaitChar
00011Fr 2               
00011Fr 2               @Done:
00011Fr 2  A9 00          lda #$00
000121r 2  99 34 04       sta BAS_LINBUF,y               ; Null-terminate
000124r 2  20 rr rr       jsr BasPrintCRLF               ; Echo newline (Chrin echoed the CR)
000127r 2  60             rts
000128r 2               
000128r 2               ; ============================================================================
000128r 2               ; Tokenizer — Convert BAS_LINBUF ASCII text into BAS_TOKBUF tokenized form
000128r 2               ; ============================================================================
000128r 2               ; Input:  BAS_LINBUF contains null-terminated ASCII line
000128r 2               ; Output: BAS_TOKBUF contains:
000128r 2               ;           [2 bytes] line number (0 if no line number)
000128r 2               ;           [N bytes] tokenized payload
000128r 2               ;           [$00]     terminator
000128r 2               ; Modifies: A, X, Y, Flags, BAS_TMP1, BAS_TMP2, BAS_TOKIDX, BAS_NUMTMP
000128r 2               
000128r 2               BasTokenize:
000128r 2  A2 00          ldx #$00                       ; X = source index into BAS_LINBUF
00012Ar 2  64 16          stz BAS_TOKIDX                 ; Output index into BAS_TOKBUF
00012Cr 2               
00012Cr 2                 ; --- Parse optional line number ---
00012Cr 2  64 22          stz BAS_NUMTMP                 ; Clear 16-bit accumulator
00012Er 2  64 23          stz BAS_NUMTMP + 1
000130r 2  A0 00          ldy #$00                       ; Flag: any digit found?
000132r 2               
000132r 2               @TokNumLoop:
000132r 2  BD 34 04       lda BAS_LINBUF,x
000135r 2  38             sec
000136r 2  E9 30          sbc #'0'
000138r 2  90 3E          bcc @TokNumDone                ; < '0'
00013Ar 2  C9 0A          cmp #10
00013Cr 2  B0 3A          bcs @TokNumDone                ; > '9'
00013Er 2               
00013Er 2                 ; Accumulate: NUMTMP = NUMTMP * 10 + digit
00013Er 2  48             pha                            ; Save digit
00013Fr 2                 ; Multiply NUMTMP by 10: (val<<3) + (val<<1)
00013Fr 2  A5 22          lda BAS_NUMTMP
000141r 2  85 1C          sta BAS_SCRATCH
000143r 2  A5 23          lda BAS_NUMTMP + 1
000145r 2  85 1D          sta BAS_SCRATCH + 1
000147r 2                 ; Shift left 1 (×2)
000147r 2  06 22          asl BAS_NUMTMP
000149r 2  26 23          rol BAS_NUMTMP + 1
00014Br 2                 ; Shift left 3 more (×8 total from original)
00014Br 2  A5 1C          lda BAS_SCRATCH
00014Dr 2  0A             asl
00014Er 2  85 1C          sta BAS_SCRATCH
000150r 2  A5 1D          lda BAS_SCRATCH + 1
000152r 2  2A             rol
000153r 2  85 1D          sta BAS_SCRATCH + 1
000155r 2  06 1C          asl BAS_SCRATCH
000157r 2  26 1D          rol BAS_SCRATCH + 1
000159r 2  06 1C          asl BAS_SCRATCH
00015Br 2  26 1D          rol BAS_SCRATCH + 1
00015Dr 2                 ; Add ×2 + ×8 = ×10
00015Dr 2  18             clc
00015Er 2  A5 22          lda BAS_NUMTMP
000160r 2  65 1C          adc BAS_SCRATCH
000162r 2  85 22          sta BAS_NUMTMP
000164r 2  A5 23          lda BAS_NUMTMP + 1
000166r 2  65 1D          adc BAS_SCRATCH + 1
000168r 2  85 23          sta BAS_NUMTMP + 1
00016Ar 2                 ; Add the digit
00016Ar 2  68             pla
00016Br 2  18             clc
00016Cr 2  65 22          adc BAS_NUMTMP
00016Er 2  85 22          sta BAS_NUMTMP
000170r 2  90 02          bcc @TokNumNoCarry
000172r 2  E6 23          inc BAS_NUMTMP + 1
000174r 2               @TokNumNoCarry:
000174r 2  C8             iny                            ; Mark digit found
000175r 2  E8             inx                            ; Advance source
000176r 2  80 BA          bra @TokNumLoop
000178r 2               
000178r 2               @TokNumDone:
000178r 2                 ; Store line number (0 if none found)
000178r 2  A5 22          lda BAS_NUMTMP
00017Ar 2  8D 00 06       sta BAS_TOKBUF
00017Dr 2  A5 23          lda BAS_NUMTMP + 1
00017Fr 2  8D 01 06       sta BAS_TOKBUF + 1
000182r 2  A9 02          lda #2
000184r 2  85 16          sta BAS_TOKIDX                 ; Output starts after 2-byte line number
000186r 2               
000186r 2                 ; Skip spaces after line number
000186r 2  20 rr rr       jsr @TokSkipSpaces
000189r 2               
000189r 2                 ; --- Main tokenize loop ---
000189r 2               @TokLoop:
000189r 2  BD 34 04       lda BAS_LINBUF,x
00018Cr 2  F0 25          beq @TokEnd                   ; Null terminator — done
00018Er 2               
00018Er 2                 ; Check for string literal (copy verbatim including quotes)
00018Er 2  C9 22          cmp #CH_QUOTE
000190r 2  F0 79          beq @TokString
000192r 2               
000192r 2                 ; Check for multi-char operators: >=, <=, <>
000192r 2  C9 3E          cmp #CH_GREATER
000194r 2  F0 25          beq @TokCheckGE
000196r 2  C9 3C          cmp #CH_LESS
000198r 2  F0 39          beq @TokCheckLE
00019Ar 2               
00019Ar 2                 ; Check if uppercase letter — possible keyword
00019Ar 2  C9 41          cmp #'A'
00019Cr 2  90 0B          bcc @TokCopyChar               ; Below 'A' — just copy
00019Er 2  C9 5B          cmp #'Z' + 1
0001A0r 2  B0 07          bcs @TokCopyChar               ; Above 'Z' — just copy
0001A2r 2               
0001A2r 2                 ; Try to match a keyword
0001A2r 2  48             pha                            ; Save char in case match fails
0001A3r 2  20 rr rr       jsr BasMatchKeyword
0001A6r 2  B0 54          bcs @TokGotKeywordPop         ; Carry set = matched
0001A8r 2  68             pla                            ; Restore original character
0001A9r 2               
0001A9r 2                 ; Not a keyword — copy single character as-is
0001A9r 2               @TokCopyChar:
0001A9r 2  A4 16          ldy BAS_TOKIDX
0001ABr 2  99 00 06       sta BAS_TOKBUF,y
0001AEr 2  E6 16          inc BAS_TOKIDX
0001B0r 2  E8             inx                            ; Advance source
0001B1r 2  80 D6          bra @TokLoop
0001B3r 2               
0001B3r 2               @TokEnd:
0001B3r 2                 ; Null-terminate tokenized output
0001B3r 2  A4 16          ldy BAS_TOKIDX
0001B5r 2  A9 00          lda #$00
0001B7r 2  99 00 06       sta BAS_TOKBUF,y
0001BAr 2  60             rts
0001BBr 2               
0001BBr 2               @TokCheckGE:
0001BBr 2                 ; Current char is '>', check next for '='
0001BBr 2  BD 35 04       lda BAS_LINBUF+1,x
0001BEr 2  C9 3D          cmp #CH_EQUALS
0001C0r 2  D0 0D          bne @TokCopyGT
0001C2r 2  A9 9A          lda #TOK_GE
0001C4r 2  A4 16          ldy BAS_TOKIDX
0001C6r 2  99 00 06       sta BAS_TOKBUF,y
0001C9r 2  E6 16          inc BAS_TOKIDX
0001CBr 2  E8             inx                            ; Skip '>'
0001CCr 2  E8             inx                            ; Skip '='
0001CDr 2  80 BA          bra @TokLoop
0001CFr 2               @TokCopyGT:
0001CFr 2  A9 3E          lda #CH_GREATER
0001D1r 2  80 D6          bra @TokCopyChar
0001D3r 2               
0001D3r 2               @TokCheckLE:
0001D3r 2                 ; Current char is '<', check next
0001D3r 2  BD 35 04       lda BAS_LINBUF+1,x
0001D6r 2  C9 3D          cmp #CH_EQUALS
0001D8r 2  F0 08          beq @TokEmitLE
0001DAr 2  C9 3E          cmp #CH_GREATER
0001DCr 2  F0 11          beq @TokEmitNE
0001DEr 2  A9 3C          lda #CH_LESS
0001E0r 2  80 C7          bra @TokCopyChar
0001E2r 2               @TokEmitLE:
0001E2r 2  A9 9B          lda #TOK_LE
0001E4r 2  A4 16          ldy BAS_TOKIDX
0001E6r 2  99 00 06       sta BAS_TOKBUF,y
0001E9r 2  E6 16          inc BAS_TOKIDX
0001EBr 2  E8             inx
0001ECr 2  E8             inx
0001EDr 2  80 9A          bra @TokLoop
0001EFr 2               @TokEmitNE:
0001EFr 2  A9 9C          lda #TOK_NE
0001F1r 2  A4 16          ldy BAS_TOKIDX
0001F3r 2  99 00 06       sta BAS_TOKBUF,y
0001F6r 2  E6 16          inc BAS_TOKIDX
0001F8r 2  E8             inx
0001F9r 2  E8             inx
0001FAr 2  80 8D          bra @TokLoop
0001FCr 2               
0001FCr 2               @TokGotKeywordPop:
0001FCr 2  7A             ply                            ; Discard saved char (preserves A = token)
0001FDr 2               @TokGotKeyword:
0001FDr 2                 ; A = token byte, X already advanced past keyword
0001FDr 2  A4 16          ldy BAS_TOKIDX
0001FFr 2  99 00 06       sta BAS_TOKBUF,y
000202r 2  E6 16          inc BAS_TOKIDX
000204r 2               
000204r 2                 ; If REM token, copy rest of line verbatim
000204r 2  C9 8C          cmp #TOK_REM
000206r 2  F0 22          beq @TokRem
000208r 2  4C rr rr       jmp @TokLoop
00020Br 2               
00020Br 2               @TokString:
00020Br 2                 ; Copy opening quote
00020Br 2  A4 16          ldy BAS_TOKIDX
00020Dr 2  99 00 06       sta BAS_TOKBUF,y
000210r 2  E6 16          inc BAS_TOKIDX
000212r 2  E8             inx
000213r 2               @TokStrLoop:
000213r 2  BD 34 04       lda BAS_LINBUF,x
000216r 2  F0 0F          beq @TokEndJ                   ; Unterminated string — end of line
000218r 2  A4 16          ldy BAS_TOKIDX
00021Ar 2  99 00 06       sta BAS_TOKBUF,y
00021Dr 2  E6 16          inc BAS_TOKIDX
00021Fr 2  E8             inx
000220r 2  C9 22          cmp #CH_QUOTE                  ; Closing quote?
000222r 2  D0 EF          bne @TokStrLoop
000224r 2  4C rr rr       jmp @TokLoop                   ; Continue after closing quote
000227r 2               @TokEndJ:
000227r 2  4C rr rr       jmp @TokEnd
00022Ar 2               
00022Ar 2               @TokRem:
00022Ar 2                 ; Copy everything remaining verbatim
00022Ar 2               @TokRemLoop:
00022Ar 2  BD 34 04       lda BAS_LINBUF,x
00022Dr 2  F0 0A          beq @TokEndJ2
00022Fr 2  A4 16          ldy BAS_TOKIDX
000231r 2  99 00 06       sta BAS_TOKBUF,y
000234r 2  E6 16          inc BAS_TOKIDX
000236r 2  E8             inx
000237r 2  80 F1          bra @TokRemLoop
000239r 2               @TokEndJ2:
000239r 2  4C rr rr       jmp @TokEnd
00023Cr 2               
00023Cr 2               ; Skip spaces in BAS_LINBUF at position X
00023Cr 2               @TokSkipSpaces:
00023Cr 2  BD 34 04       lda BAS_LINBUF,x
00023Fr 2  C9 20          cmp #CH_SPACE
000241r 2  D0 03          bne @TokSkipDone
000243r 2  E8             inx
000244r 2  80 F6          bra @TokSkipSpaces
000246r 2               @TokSkipDone:
000246r 2  60             rts
000247r 2               
000247r 2               ; ============================================================================
000247r 2               ; Keyword Matching — Try to match a keyword at BAS_LINBUF+X
000247r 2               ; ============================================================================
000247r 2               ; Input:  X = current source index in BAS_LINBUF
000247r 2               ; Output: Carry set if matched, A = token, X advanced past keyword
000247r 2               ;         Carry clear if no match, X unchanged
000247r 2               ; Modifies: A, Y, BAS_TMP1, BAS_TMP2
000247r 2               
000247r 2               BasMatchKeyword:
000247r 2  DA             phx                            ; Save source position for rollback
000248r 2               
000248r 2                 ; Set BAS_TMP1 to start of keyword table
000248r 2  A9 rr          lda #<BasKeywordTable
00024Ar 2  85 0E          sta BAS_TMP1
00024Cr 2  A9 rr          lda #>BasKeywordTable
00024Er 2  85 0F          sta BAS_TMP1 + 1
000250r 2               
000250r 2  A0 00          ldy #$00                       ; Index into keyword table
000252r 2               
000252r 2               @KwOuter:
000252r 2                 ; Load first byte of keyword entry — $00 = end of table
000252r 2  B1 0E          lda (BAS_TMP1),y
000254r 2  F0 35          beq @KwNoMatch                 ; End of table — no match
000256r 2               
000256r 2                 ; Save Y (table position) and try matching chars
000256r 2  FA             plx                            ; Restore original X (source position)
000257r 2  DA             phx                            ; Re-save it for next attempt
000258r 2  84 10          sty BAS_TMP2                   ; Save table offset
00025Ar 2               
00025Ar 2               @KwCompare:
00025Ar 2  B1 0E          lda (BAS_TMP1),y
00025Cr 2  F0 09          beq @KwMatched                 ; Null terminator in keyword = full match
00025Er 2  DD 34 04       cmp BAS_LINBUF,x
000261r 2  D0 1C          bne @KwSkip                   ; Mismatch — skip to next keyword
000263r 2  C8             iny
000264r 2  E8             inx
000265r 2  80 F3          bra @KwCompare
000267r 2               
000267r 2               @KwMatched:
000267r 2                 ; Keyword matched. The token byte follows the null terminator.
000267r 2  C8             iny                            ; Advance past the null
000268r 2  B1 0E          lda (BAS_TMP1),y               ; Read token byte
00026Ar 2               
00026Ar 2                 ; Check that the next source char is not a letter (prevent partial match)
00026Ar 2                 ; e.g. "TORE" should not match "TO"
00026Ar 2  48             pha                            ; Save token
00026Br 2  BD 34 04       lda BAS_LINBUF,x
00026Er 2  C9 41          cmp #'A'
000270r 2  90 09          bcc @KwConfirmed               ; Not a letter — confirmed
000272r 2  C9 5B          cmp #'Z' + 1
000274r 2  B0 05          bcs @KwConfirmed               ; Not a letter — confirmed
000276r 2                 ; Next char is a letter — this is a partial match, skip it
000276r 2  68             pla
000277r 2  A4 10          ldy BAS_TMP2
000279r 2  80 04          bra @KwSkip
00027Br 2               
00027Br 2               @KwConfirmed:
00027Br 2  68             pla                            ; Recover token
00027Cr 2  7A             ply                            ; Discard saved source position (PLY not PLX — X holds the advanced position)
00027Dr 2                 ; X is already advanced past the keyword
00027Dr 2  38             sec
00027Er 2  60             rts
00027Fr 2               
00027Fr 2               @KwSkip:
00027Fr 2                 ; Advance Y past current keyword string + null + token byte
00027Fr 2  A4 10          ldy BAS_TMP2                   ; Back to start of this keyword
000281r 2               @KwSkipStr:
000281r 2  B1 0E          lda (BAS_TMP1),y
000283r 2  C8             iny
000284r 2  C9 00          cmp #$00                       ; Found null terminator?
000286r 2  D0 F9          bne @KwSkipStr
000288r 2  C8             iny                            ; Skip token byte too
000289r 2  80 C7          bra @KwOuter                   ; Try next keyword
00028Br 2               
00028Br 2               @KwNoMatch:
00028Br 2  FA             plx                            ; Restore original source position
00028Cr 2  18             clc
00028Dr 2  60             rts
00028Er 2               
00028Er 2               ; ============================================================================
00028Er 2               ; Detokenizer — Convert tokenized line to printable ASCII
00028Er 2               ; ============================================================================
00028Er 2               ; Input:  BAS_TMP1 points to tokenized payload (past line number)
00028Er 2               ; Output: Characters sent to Chrout
00028Er 2               ; Input:  BAS_TXTPTR points to tokenized payload
00028Er 2               ; Output: Characters sent to Chrout
00028Er 2               ; Modifies: A, X, Y, Flags, BAS_TMP2
00028Er 2               
00028Er 2               BasDetokenize:
00028Er 2  A0 00          ldy #$00
000290r 2               
000290r 2               @DetokLoop:
000290r 2  B1 04          lda (BAS_TXTPTR),y
000292r 2  F0 44          beq @DetokDone                 ; Null terminator — done
000294r 2               
000294r 2                 ; Check if token (>= $80)
000294r 2  30 06          bmi @DetokKeyword
000296r 2               
000296r 2                 ; Regular ASCII character — output it
000296r 2  20 rr rr       jsr Chrout
000299r 2  C8             iny
00029Ar 2  80 F4          bra @DetokLoop
00029Cr 2               
00029Cr 2               @DetokKeyword:
00029Cr 2                 ; Look up keyword string for this token
00029Cr 2  5A             phy                            ; Save source index
00029Dr 2  85 21          sta BAS_TEMP                   ; Save target token
00029Fr 2               
00029Fr 2                 ; Walk the keyword table looking for matching token
00029Fr 2  A9 rr          lda #<BasKeywordTable
0002A1r 2  85 10          sta BAS_TMP2
0002A3r 2  A9 rr          lda #>BasKeywordTable
0002A5r 2  85 11          sta BAS_TMP2 + 1
0002A7r 2               
0002A7r 2  A0 00          ldy #$00                       ; Table index
0002A9r 2               
0002A9r 2               @DetokSearch:
0002A9r 2  B1 10          lda (BAS_TMP2),y
0002ABr 2  F0 22          beq @DetokNotFound             ; End of table — token not found
0002ADr 2                 ; Save start of this keyword string
0002ADr 2  84 16          sty BAS_TOKIDX                 ; Remember keyword start
0002AFr 2               @DetokScanStr:
0002AFr 2  B1 10          lda (BAS_TMP2),y
0002B1r 2  C8             iny
0002B2r 2  C9 00          cmp #$00                       ; End of keyword string?
0002B4r 2  D0 F9          bne @DetokScanStr
0002B6r 2                 ; Y now points to the token byte
0002B6r 2  B1 10          lda (BAS_TMP2),y
0002B8r 2  C8             iny                            ; Advance past token byte
0002B9r 2               
0002B9r 2                 ; Compare to our target token
0002B9r 2  C5 21          cmp BAS_TEMP
0002BBr 2  F0 02          beq @DetokFound
0002BDr 2                 ; Not this one — continue searching
0002BDr 2  80 EA          bra @DetokSearch
0002BFr 2               
0002BFr 2               @DetokFound:
0002BFr 2                 ; Print the keyword string starting at BAS_TOKIDX
0002BFr 2  A4 16          ldy BAS_TOKIDX
0002C1r 2               @DetokPrintKw:
0002C1r 2  B1 10          lda (BAS_TMP2),y
0002C3r 2  F0 06          beq @DetokKwDone               ; Null = end of keyword string
0002C5r 2  20 rr rr       jsr Chrout
0002C8r 2  C8             iny
0002C9r 2  80 F6          bra @DetokPrintKw
0002CBr 2               
0002CBr 2               @DetokKwDone:
0002CBr 2  7A             ply                            ; Restore source index
0002CCr 2  C8             iny                            ; Advance past the token byte in source
0002CDr 2  80 C1          bra @DetokLoop
0002CFr 2               
0002CFr 2               @DetokNotFound:
0002CFr 2                 ; Token not in table (shouldn't happen) — print '?' and continue
0002CFr 2  A9 3F          lda #'?'
0002D1r 2  20 rr rr       jsr Chrout
0002D4r 2  7A             ply
0002D5r 2  C8             iny
0002D6r 2  80 B8          bra @DetokLoop
0002D8r 2               
0002D8r 2               @DetokDone:
0002D8r 2  60             rts
0002D9r 2               
0002D9r 2               ; ============================================================================
0002D9r 2               ; Line Editor — Program Storage Management
0002D9r 2               ; ============================================================================
0002D9r 2               
0002D9r 2               ; ----------------------------------------------------------------------------
0002D9r 2               ; BasInsertLine — Insert or replace a program line
0002D9r 2               ; ----------------------------------------------------------------------------
0002D9r 2               ; Input:  BAS_TOKBUF contains tokenized line:
0002D9r 2               ;           [2 bytes] line number
0002D9r 2               ;           [N bytes] tokenized payload
0002D9r 2               ;           [$00]     terminator
0002D9r 2               ; If payload is empty (just null after line number), deletes existing line.
0002D9r 2               ; Modifies: A, X, Y, Flags, BAS_TMP1, BAS_TMP2, BAS_SCRATCH, BAS_SCRATCH2
0002D9r 2               
0002D9r 2               BasInsertLine:
0002D9r 2                 ; Load line number from TOKBUF
0002D9r 2  AD 00 06       lda BAS_TOKBUF
0002DCr 2  85 08          sta BAS_LINENUM
0002DEr 2  AD 01 06       lda BAS_TOKBUF + 1
0002E1r 2  85 09          sta BAS_LINENUM + 1
0002E3r 2               
0002E3r 2                 ; Calculate new line size: scan TOKBUF payload for null terminator
0002E3r 2  A2 02          ldx #2                         ; Start past line number in TOKBUF
0002E5r 2               @SizeLoop:
0002E5r 2  BD 00 06       lda BAS_TOKBUF,x
0002E8r 2  F0 03          beq @SizeDone
0002EAr 2  E8             inx
0002EBr 2  80 F8          bra @SizeLoop
0002EDr 2               @SizeDone:
0002EDr 2                 ; X = offset of null terminator (payload length = X - 2)
0002EDr 2                 ; Total line in memory: 2 (next ptr) + 2 (line num) + (X-2) payload + 1 (null) = X + 3
0002EDr 2  E8             inx                            ; Include the null terminator
0002EEr 2  E8             inx                            ; +2 for next-line pointer
0002EFr 2  E8             inx                            ; +2 for line number (but X already includes 2 from tokbuf offset)
0002F0r 2                 ; X now = new line byte count including header
0002F0r 2                 ; Actually: payload starts at TOKBUF+2, null at TOKBUF+X (original)
0002F0r 2                 ; Memory line = 4 header + (origX - 2) payload + 1 null = origX + 3
0002F0r 2                 ; But we already incremented X by 3, so X = origX + 3. Correct.
0002F0r 2  86 1E          stx BAS_SCRATCH2               ; Save new line size
0002F2r 2               
0002F2r 2                 ; Check if payload is empty (just the null after line number = delete only)
0002F2r 2  AD 02 06       lda BAS_TOKBUF + 2
0002F5r 2  85 21          sta BAS_TEMP                   ; $00 if empty, nonzero if has content
0002F7r 2               
0002F7r 2                 ; --- Try to find existing line with this number ---
0002F7r 2  20 rr rr       jsr BasFindLine                ; Sets BAS_TMP1 if found, carry set/clear
0002FAr 2               
0002FAr 2  90 45          bcc @NoExisting
0002FCr 2               
0002FCr 2                 ; --- Delete existing line ---
0002FCr 2                 ; BAS_TMP1 = address of existing line
0002FCr 2                 ; Calculate old line's size by scanning for null terminator
0002FCr 2  A0 04          ldy #LINE_PAYLOAD
0002FEr 2               @DelSizeLoop:
0002FEr 2  B1 0E          lda (BAS_TMP1),y
000300r 2  F0 03          beq @DelSizeDone
000302r 2  C8             iny
000303r 2  80 F9          bra @DelSizeLoop
000305r 2               @DelSizeDone:
000305r 2  C8             iny                            ; Include null byte; Y = total line size
000306r 2  84 0C          sty BAS_AUX                   ; Old line size low
000308r 2  64 0D          stz BAS_AUX + 1               ; High byte = 0 (lines < 256 bytes)
00030Ar 2               
00030Ar 2                 ; Compute source (next line address) = BAS_TMP1 + Y
00030Ar 2  98             tya
00030Br 2  18             clc
00030Cr 2  65 0E          adc BAS_TMP1
00030Er 2  85 1C          sta BAS_SCRATCH                ; Next-line address low
000310r 2  A9 00          lda #$00
000312r 2  65 0F          adc BAS_TMP1 + 1
000314r 2  85 1D          sta BAS_SCRATCH + 1            ; Next-line address high
000316r 2               
000316r 2                 ; Shift bytes down: copy from BAS_SCRATCH to BAS_TMP1, up to BAS_PRGEND
000316r 2                 ; Source = BAS_SCRATCH (next line), Dest = BAS_TMP1 (current line)
000316r 2                 ; Count = BAS_PRGEND - BAS_SCRATCH
000316r 2  A0 00          ldy #$00
000318r 2               @DeleteLoop:
000318r 2  A5 1C          lda BAS_SCRATCH
00031Ar 2  C5 12          cmp BAS_PRGEND
00031Cr 2  A5 1D          lda BAS_SCRATCH + 1
00031Er 2  E5 13          sbc BAS_PRGEND + 1
000320r 2  B0 12          bcs @DeleteDone                ; Source >= PRGEND, done copying
000322r 2               
000322r 2  B1 1C          lda (BAS_SCRATCH),y
000324r 2  91 0E          sta (BAS_TMP1),y
000326r 2               
000326r 2                 ; Increment source pointer
000326r 2  E6 1C          inc BAS_SCRATCH
000328r 2  D0 02          bne @DelSrcOk
00032Ar 2  E6 1D          inc BAS_SCRATCH + 1
00032Cr 2               @DelSrcOk:
00032Cr 2                 ; Increment dest pointer
00032Cr 2  E6 0E          inc BAS_TMP1
00032Er 2  D0 02          bne @DelDstOk
000330r 2  E6 0F          inc BAS_TMP1 + 1
000332r 2               @DelDstOk:
000332r 2  80 E4          bra @DeleteLoop
000334r 2               
000334r 2               @DeleteDone:
000334r 2                 ; Update PRGEND: subtract old line size
000334r 2  38             sec
000335r 2  A5 12          lda BAS_PRGEND
000337r 2  E5 0C          sbc BAS_AUX
000339r 2  85 12          sta BAS_PRGEND
00033Br 2  A5 13          lda BAS_PRGEND + 1
00033Dr 2  E5 0D          sbc BAS_AUX + 1
00033Fr 2  85 13          sta BAS_PRGEND + 1
000341r 2               
000341r 2               @NoExisting:
000341r 2                 ; If payload was empty, we're done (delete only)
000341r 2  A5 21          lda BAS_TEMP
000343r 2  D0 01          bne @DoInsert
000345r 2  60             rts                            ; Empty payload — delete only, done
000346r 2               
000346r 2               @DoInsert:
000346r 2               
000346r 2                 ; --- Find insertion point (keep lines sorted by number) ---
000346r 2  A9 00          lda #<BAS_PRG_START
000348r 2  85 0E          sta BAS_TMP1
00034Ar 2  A9 08          lda #>BAS_PRG_START
00034Cr 2  85 0F          sta BAS_TMP1 + 1
00034Er 2               
00034Er 2               @FindInsPos:
00034Er 2                 ; Check if we've reached end of program (TMP1 == PRGEND)
00034Er 2  A5 0E          lda BAS_TMP1
000350r 2  C5 12          cmp BAS_PRGEND
000352r 2  D0 06          bne @FindNotEnd
000354r 2  A5 0F          lda BAS_TMP1 + 1
000356r 2  C5 13          cmp BAS_PRGEND + 1
000358r 2  F0 2F          beq @InsertHere                ; At PRGEND — insert here
00035Ar 2               @FindNotEnd:
00035Ar 2               
00035Ar 2                 ; Compare this line's number with target
00035Ar 2  A0 02          ldy #LINE_NUM
00035Cr 2  B1 0E          lda (BAS_TMP1),y
00035Er 2  85 0C          sta BAS_AUX
000360r 2  C8             iny
000361r 2  B1 0E          lda (BAS_TMP1),y
000363r 2  85 0D          sta BAS_AUX + 1
000365r 2               
000365r 2                 ; If this line number >= target, insert before it
000365r 2  A5 08          lda BAS_LINENUM
000367r 2  C5 0C          cmp BAS_AUX
000369r 2  A5 09          lda BAS_LINENUM + 1
00036Br 2  E5 0D          sbc BAS_AUX + 1
00036Dr 2  90 1A          bcc @InsertHere                ; Target < this line — insert here
00036Fr 2               
00036Fr 2                 ; Advance to next line via next-ptr; if $0000, advance to PRGEND
00036Fr 2  A0 00          ldy #LINE_NEXT
000371r 2  B1 0E          lda (BAS_TMP1),y
000373r 2  AA             tax
000374r 2  C8             iny
000375r 2  B1 0E          lda (BAS_TMP1),y
000377r 2  85 0F          sta BAS_TMP1 + 1
000379r 2  86 0E          stx BAS_TMP1
00037Br 2                 ; If next-ptr was $0000, use PRGEND instead
00037Br 2  05 0E          ora BAS_TMP1
00037Dr 2  D0 CF          bne @FindInsPos
00037Fr 2  A5 12          lda BAS_PRGEND
000381r 2  85 0E          sta BAS_TMP1
000383r 2  A5 13          lda BAS_PRGEND + 1
000385r 2  85 0F          sta BAS_TMP1 + 1
000387r 2  80 C5          bra @FindInsPos
000389r 2               
000389r 2               @InsertHere:
000389r 2                 ; BAS_TMP1 = insertion point
000389r 2                 ; BAS_SCRATCH2 = new line size
000389r 2                 ; Check if there's room
000389r 2  18             clc
00038Ar 2  A5 12          lda BAS_PRGEND
00038Cr 2  65 1E          adc BAS_SCRATCH2
00038Er 2  85 1C          sta BAS_SCRATCH                ; Tentative new PRGEND low
000390r 2  A5 13          lda BAS_PRGEND + 1
000392r 2  69 00          adc #$00
000394r 2  85 1D          sta BAS_SCRATCH + 1            ; Tentative new PRGEND high
000396r 2               
000396r 2                 ; Check if new PRGEND > BAS_PRG_END ($7FFF)
000396r 2  A5 1D          lda BAS_SCRATCH + 1
000398r 2  C9 7F          cmp #>BAS_PRG_END
00039Ar 2  90 0F          bcc @HasRoom
00039Cr 2  D0 08          bne @OutOfMem
00039Er 2  A5 1C          lda BAS_SCRATCH
0003A0r 2  C9 FF          cmp #<BAS_PRG_END
0003A2r 2  90 07          bcc @HasRoom
0003A4r 2  F0 05          beq @HasRoom
0003A6r 2               @OutOfMem:
0003A6r 2  A9 03          lda #ERR_OUT_OF_MEM
0003A8r 2  4C rr rr       jmp BasError
0003ABr 2               
0003ABr 2               @HasRoom:
0003ABr 2                 ; Shift bytes up: move from PRGEND-1 down to TMP1, shifting by SCRATCH2 bytes
0003ABr 2                 ; Work backwards from PRGEND to TMP1
0003ABr 2               
0003ABr 2                 ; Source end = PRGEND - 1
0003ABr 2  38             sec
0003ACr 2  A5 12          lda BAS_PRGEND
0003AEr 2  E9 01          sbc #$01
0003B0r 2  85 1C          sta BAS_SCRATCH
0003B2r 2  A5 13          lda BAS_PRGEND + 1
0003B4r 2  E9 00          sbc #$00
0003B6r 2  85 1D          sta BAS_SCRATCH + 1
0003B8r 2               
0003B8r 2                 ; Dest end = source end + new line size
0003B8r 2  18             clc
0003B9r 2  A5 1C          lda BAS_SCRATCH
0003BBr 2  65 1E          adc BAS_SCRATCH2
0003BDr 2  85 0C          sta BAS_AUX
0003BFr 2  A5 1D          lda BAS_SCRATCH + 1
0003C1r 2  69 00          adc #$00
0003C3r 2  85 0D          sta BAS_AUX + 1
0003C5r 2               
0003C5r 2               @ShiftUpLoop:
0003C5r 2                 ; Check if source < insertion point (done)
0003C5r 2  A5 1C          lda BAS_SCRATCH
0003C7r 2  C5 0E          cmp BAS_TMP1
0003C9r 2  A5 1D          lda BAS_SCRATCH + 1
0003CBr 2  E5 0F          sbc BAS_TMP1 + 1
0003CDr 2  90 18          bcc @ShiftUpDone
0003CFr 2               
0003CFr 2                 ; Copy byte from source to dest
0003CFr 2  A0 00          ldy #$00
0003D1r 2  B1 1C          lda (BAS_SCRATCH),y
0003D3r 2  91 0C          sta (BAS_AUX),y
0003D5r 2               
0003D5r 2                 ; Decrement source
0003D5r 2  A5 1C          lda BAS_SCRATCH
0003D7r 2  D0 02          bne @ShiftSrcOk
0003D9r 2  C6 1D          dec BAS_SCRATCH + 1
0003DBr 2               @ShiftSrcOk:
0003DBr 2  C6 1C          dec BAS_SCRATCH
0003DDr 2               
0003DDr 2                 ; Decrement dest
0003DDr 2  A5 0C          lda BAS_AUX
0003DFr 2  D0 02          bne @ShiftDstOk
0003E1r 2  C6 0D          dec BAS_AUX + 1
0003E3r 2               @ShiftDstOk:
0003E3r 2  C6 0C          dec BAS_AUX
0003E5r 2  80 DE          bra @ShiftUpLoop
0003E7r 2               
0003E7r 2               @ShiftUpDone:
0003E7r 2                 ; Update PRGEND
0003E7r 2  18             clc
0003E8r 2  A5 12          lda BAS_PRGEND
0003EAr 2  65 1E          adc BAS_SCRATCH2
0003ECr 2  85 12          sta BAS_PRGEND
0003EEr 2  A5 13          lda BAS_PRGEND + 1
0003F0r 2  69 00          adc #$00
0003F2r 2  85 13          sta BAS_PRGEND + 1
0003F4r 2               
0003F4r 2                 ; Write the new line at BAS_TMP1
0003F4r 2                 ; Bytes 0-1: next-line pointer (filled by relink)
0003F4r 2                 ; Bytes 2-3: line number
0003F4r 2  A0 02          ldy #LINE_NUM
0003F6r 2  A5 08          lda BAS_LINENUM
0003F8r 2  91 0E          sta (BAS_TMP1),y
0003FAr 2  C8             iny
0003FBr 2  A5 09          lda BAS_LINENUM + 1
0003FDr 2  91 0E          sta (BAS_TMP1),y
0003FFr 2               
0003FFr 2                 ; Copy tokenized payload from BAS_TOKBUF+2 to line+4
0003FFr 2  A2 00          ldx #$00                       ; Source index into TOKBUF+2
000401r 2  A0 04          ldy #LINE_PAYLOAD              ; Dest offset in line
000403r 2               @CopyPayload:
000403r 2  BD 02 06       lda BAS_TOKBUF + 2,x
000406r 2  91 0E          sta (BAS_TMP1),y
000408r 2  F0 04          beq @CopyDone                  ; Copied the null terminator — done
00040Ar 2  E8             inx
00040Br 2  C8             iny
00040Cr 2  80 F5          bra @CopyPayload
00040Er 2               
00040Er 2               @CopyDone:
00040Er 2                 ; Relink all lines
00040Er 2  20 rr rr       jsr BasRelink
000411r 2               
000411r 2               @InsertDone:
000411r 2  60             rts
000412r 2               
000412r 2               ; ----------------------------------------------------------------------------
000412r 2               ; BasFindLine — Find a program line by line number
000412r 2               ; ----------------------------------------------------------------------------
000412r 2               ; Input:  BAS_LINENUM = target line number (16-bit)
000412r 2               ; Output: Carry set if found, clear if not found
000412r 2               ;         BAS_TMP1 = pointer to line (if found) or insertion point (if not)
000412r 2               ; Modifies: A, Y, Flags, BAS_TMP1
000412r 2               
000412r 2               BasFindLine:
000412r 2  A9 00          lda #<BAS_PRG_START
000414r 2  85 0E          sta BAS_TMP1
000416r 2  A9 08          lda #>BAS_PRG_START
000418r 2  85 0F          sta BAS_TMP1 + 1
00041Ar 2               
00041Ar 2               @FindLoop:
00041Ar 2                 ; Check if at end of program (TMP1 == PRGEND)
00041Ar 2  A5 0E          lda BAS_TMP1
00041Cr 2  C5 12          cmp BAS_PRGEND
00041Er 2  D0 06          bne @FindNotEnd
000420r 2  A5 0F          lda BAS_TMP1 + 1
000422r 2  C5 13          cmp BAS_PRGEND + 1
000424r 2  F0 3A          beq @FindNotFound              ; End of program
000426r 2               @FindNotEnd:
000426r 2               
000426r 2                 ; Compare this line's number with target
000426r 2  A0 02          ldy #LINE_NUM
000428r 2  B1 0E          lda (BAS_TMP1),y
00042Ar 2  C5 08          cmp BAS_LINENUM
00042Cr 2  D0 07          bne @FindNotEqual
00042Er 2  C8             iny
00042Fr 2  B1 0E          lda (BAS_TMP1),y
000431r 2  C5 09          cmp BAS_LINENUM + 1
000433r 2  F0 29          beq @FindFound                 ; Exact match
000435r 2               
000435r 2               @FindNotEqual:
000435r 2                 ; Check if this line number > target (past where it would be)
000435r 2  A0 03          ldy #LINE_NUM + 1
000437r 2  A5 09          lda BAS_LINENUM + 1
000439r 2  D1 0E          cmp (BAS_TMP1),y
00043Br 2  90 23          bcc @FindNotFound              ; Target high < line high — not found
00043Dr 2  D0 07          bne @FindAdvance               ; Target high > line high — keep looking
00043Fr 2  88             dey
000440r 2  A5 08          lda BAS_LINENUM
000442r 2  D1 0E          cmp (BAS_TMP1),y
000444r 2  90 1A          bcc @FindNotFound              ; Target < line — not found
000446r 2               
000446r 2               @FindAdvance:
000446r 2                 ; Move to next line by scanning for null terminator
000446r 2  A0 04          ldy #LINE_PAYLOAD
000448r 2               @FindScan:
000448r 2  B1 0E          lda (BAS_TMP1),y
00044Ar 2  F0 03          beq @FindScanDone
00044Cr 2  C8             iny
00044Dr 2  80 F9          bra @FindScan
00044Fr 2               @FindScanDone:
00044Fr 2  C8             iny                            ; Past null
000450r 2  98             tya
000451r 2  18             clc
000452r 2  65 0E          adc BAS_TMP1
000454r 2  85 0E          sta BAS_TMP1
000456r 2  A9 00          lda #$00
000458r 2  65 0F          adc BAS_TMP1 + 1
00045Ar 2  85 0F          sta BAS_TMP1 + 1
00045Cr 2  80 BC          bra @FindLoop
00045Er 2               
00045Er 2               @FindFound:
00045Er 2  38             sec
00045Fr 2  60             rts
000460r 2               
000460r 2               @FindNotFound:
000460r 2  18             clc
000461r 2  60             rts
000462r 2               
000462r 2               ; ----------------------------------------------------------------------------
000462r 2               ; BasRelink — Rebuild all next-line pointers from PROGRAM_START
000462r 2               ; ----------------------------------------------------------------------------
000462r 2               ; Walks program lines, computes each line's length, sets next-pointer.
000462r 2               ; Modifies: A, X, Y, Flags, BAS_TMP2
000462r 2               
000462r 2               BasRelink:
000462r 2  A9 00          lda #<BAS_PRG_START
000464r 2  85 10          sta BAS_TMP2
000466r 2  A9 08          lda #>BAS_PRG_START
000468r 2  85 11          sta BAS_TMP2 + 1
00046Ar 2               
00046Ar 2               @RelinkLoop:
00046Ar 2                 ; Check if at PRGEND
00046Ar 2  A5 10          lda BAS_TMP2
00046Cr 2  C5 12          cmp BAS_PRGEND
00046Er 2  D0 06          bne @RelinkNotEnd
000470r 2  A5 11          lda BAS_TMP2 + 1
000472r 2  C5 13          cmp BAS_PRGEND + 1
000474r 2  F0 42          beq @RelinkDone
000476r 2               
000476r 2               @RelinkNotEnd:
000476r 2                 ; Find length of this line by scanning for null terminator in payload
000476r 2  A0 04          ldy #LINE_PAYLOAD
000478r 2               @RelinkScan:
000478r 2  B1 10          lda (BAS_TMP2),y
00047Ar 2  F0 03          beq @RelinkFoundNull
00047Cr 2  C8             iny
00047Dr 2  80 F9          bra @RelinkScan
00047Fr 2               
00047Fr 2               @RelinkFoundNull:
00047Fr 2                 ; Y = offset of null terminator. Line length = Y + 1.
00047Fr 2  C8             iny                            ; Include the null byte
000480r 2                 ; Next line address = BAS_TMP2 + Y
000480r 2  98             tya
000481r 2  18             clc
000482r 2  65 10          adc BAS_TMP2
000484r 2  85 1C          sta BAS_SCRATCH
000486r 2  A9 00          lda #$00
000488r 2  65 11          adc BAS_TMP2 + 1
00048Ar 2  85 1D          sta BAS_SCRATCH + 1
00048Cr 2               
00048Cr 2                 ; Check if next line is at or past PRGEND — if so, write $0000
00048Cr 2  A5 1C          lda BAS_SCRATCH
00048Er 2  C5 12          cmp BAS_PRGEND
000490r 2  D0 11          bne @RelinkWrite
000492r 2  A5 1D          lda BAS_SCRATCH + 1
000494r 2  C5 13          cmp BAS_PRGEND + 1
000496r 2  D0 0B          bne @RelinkWrite
000498r 2                 ; At PRGEND — write end-of-program sentinel
000498r 2  A0 00          ldy #LINE_NEXT
00049Ar 2  A9 00          lda #$00
00049Cr 2  91 10          sta (BAS_TMP2),y
00049Er 2  C8             iny
00049Fr 2  91 10          sta (BAS_TMP2),y
0004A1r 2  80 15          bra @RelinkDone
0004A3r 2               
0004A3r 2               @RelinkWrite:
0004A3r 2                 ; Write next-line pointer
0004A3r 2  A0 00          ldy #LINE_NEXT
0004A5r 2  A5 1C          lda BAS_SCRATCH
0004A7r 2  91 10          sta (BAS_TMP2),y
0004A9r 2  C8             iny
0004AAr 2  A5 1D          lda BAS_SCRATCH + 1
0004ACr 2  91 10          sta (BAS_TMP2),y
0004AEr 2               
0004AEr 2                 ; Advance to next line
0004AEr 2  A5 1C          lda BAS_SCRATCH
0004B0r 2  85 10          sta BAS_TMP2
0004B2r 2  A5 1D          lda BAS_SCRATCH + 1
0004B4r 2  85 11          sta BAS_TMP2 + 1
0004B6r 2  80 B2          bra @RelinkLoop
0004B8r 2               
0004B8r 2               @RelinkDone:
0004B8r 2                 ; Write end sentinel at PRGEND
0004B8r 2  A0 00          ldy #$00
0004BAr 2  A9 00          lda #$00
0004BCr 2  91 12          sta (BAS_PRGEND),y
0004BEr 2  C8             iny
0004BFr 2  91 12          sta (BAS_PRGEND),y
0004C1r 2  60             rts
0004C2r 2               
0004C2r 2               ; ============================================================================
0004C2r 2               ; BasParseInt — Parse decimal integer from tokenized text at TXTPTR
0004C2r 2               ; ============================================================================
0004C2r 2               ; Input:  BAS_TXTPTR points at text
0004C2r 2               ; Output: BAS_ACC = parsed 16-bit value, BAS_TXTPTR advanced
0004C2r 2               ;         Carry set on error (no digits found)
0004C2r 2               ; Modifies: A, X, Y, Flags, BAS_NUMTMP, BAS_SCRATCH
0004C2r 2               
0004C2r 2               BasParseInt:
0004C2r 2  64 22          stz BAS_NUMTMP
0004C4r 2  64 23          stz BAS_NUMTMP + 1
0004C6r 2  A2 00          ldx #$00                       ; Digit count
0004C8r 2               
0004C8r 2  A0 00          ldy #$00
0004CAr 2               
0004CAr 2               @ParseLoop:
0004CAr 2  B1 04          lda (BAS_TXTPTR),y
0004CCr 2  38             sec
0004CDr 2  E9 30          sbc #'0'
0004CFr 2  90 38          bcc @ParseDone                 ; Not a digit
0004D1r 2  C9 0A          cmp #10
0004D3r 2  B0 34          bcs @ParseDone                 ; Not a digit
0004D5r 2               
0004D5r 2                 ; Have a digit — multiply accumulator by 10 and add
0004D5r 2  48             pha                            ; Save digit
0004D6r 2               
0004D6r 2                 ; NUMTMP × 10 = (NUMTMP × 8) + (NUMTMP × 2)
0004D6r 2  A5 22          lda BAS_NUMTMP
0004D8r 2  85 1C          sta BAS_SCRATCH
0004DAr 2  A5 23          lda BAS_NUMTMP + 1
0004DCr 2  85 1D          sta BAS_SCRATCH + 1
0004DEr 2               
0004DEr 2                 ; ×2
0004DEr 2  06 22          asl BAS_NUMTMP
0004E0r 2  26 23          rol BAS_NUMTMP + 1
0004E2r 2                 ; ×8 from original (3 shifts)
0004E2r 2  06 1C          asl BAS_SCRATCH
0004E4r 2  26 1D          rol BAS_SCRATCH + 1
0004E6r 2  06 1C          asl BAS_SCRATCH
0004E8r 2  26 1D          rol BAS_SCRATCH + 1
0004EAr 2  06 1C          asl BAS_SCRATCH
0004ECr 2  26 1D          rol BAS_SCRATCH + 1
0004EEr 2               
0004EEr 2                 ; ×2 + ×8 = ×10
0004EEr 2  18             clc
0004EFr 2  A5 22          lda BAS_NUMTMP
0004F1r 2  65 1C          adc BAS_SCRATCH
0004F3r 2  85 22          sta BAS_NUMTMP
0004F5r 2  A5 23          lda BAS_NUMTMP + 1
0004F7r 2  65 1D          adc BAS_SCRATCH + 1
0004F9r 2  85 23          sta BAS_NUMTMP + 1
0004FBr 2               
0004FBr 2                 ; Add digit
0004FBr 2  68             pla
0004FCr 2  18             clc
0004FDr 2  65 22          adc BAS_NUMTMP
0004FFr 2  85 22          sta BAS_NUMTMP
000501r 2  90 02          bcc @ParseNoCarry
000503r 2  E6 23          inc BAS_NUMTMP + 1
000505r 2               @ParseNoCarry:
000505r 2  E8             inx                            ; Count digit
000506r 2  C8             iny                            ; Advance past digit
000507r 2  80 C1          bra @ParseLoop
000509r 2               
000509r 2               @ParseDone:
000509r 2                 ; Advance TXTPTR by Y
000509r 2  98             tya
00050Ar 2  18             clc
00050Br 2  65 04          adc BAS_TXTPTR
00050Dr 2  85 04          sta BAS_TXTPTR
00050Fr 2  A9 00          lda #$00
000511r 2  65 05          adc BAS_TXTPTR + 1
000513r 2  85 05          sta BAS_TXTPTR + 1
000515r 2               
000515r 2                 ; Copy result to ACC
000515r 2  A5 22          lda BAS_NUMTMP
000517r 2  85 0A          sta BAS_ACC
000519r 2  A5 23          lda BAS_NUMTMP + 1
00051Br 2  85 0B          sta BAS_ACC + 1
00051Dr 2               
00051Dr 2                 ; Set carry if no digits found
00051Dr 2  E0 00          cpx #$00
00051Fr 2  F0 02          beq @ParseError
000521r 2  18             clc
000522r 2  60             rts
000523r 2               
000523r 2               @ParseError:
000523r 2  38             sec
000524r 2  60             rts
000525r 2               
000525r 2               ; BasNibble — Convert ASCII hex character in A to nibble value (0-15)
000525r 2               ; Input:  A = ASCII character ('0'-'9', 'A'-'F')
000525r 2               ; Output: A = nibble value 0-15, carry clear on success
000525r 2               ;         Carry set if character is not a valid hex digit
000525r 2               ; Modifies: Flags, A
000525r 2               BasNibble:
000525r 2  C9 30          cmp #'0'
000527r 2  90 16          bcc @NibbleInvalid
000529r 2  C9 3A          cmp #'9' + 1
00052Br 2  B0 05          bcs @NibbleTryAlpha
00052Dr 2  38             sec
00052Er 2  E9 30          sbc #'0'
000530r 2  18             clc
000531r 2  60             rts
000532r 2               @NibbleTryAlpha:
000532r 2  C9 41          cmp #'A'
000534r 2  90 09          bcc @NibbleInvalid
000536r 2  C9 47          cmp #'F' + 1
000538r 2  B0 05          bcs @NibbleInvalid
00053Ar 2  38             sec
00053Br 2  E9 37          sbc #'A' - 10
00053Dr 2  18             clc
00053Er 2  60             rts
00053Fr 2               @NibbleInvalid:
00053Fr 2  38             sec
000540r 2  60             rts
000541r 2               
000541r 2               ; ============================================================================
000541r 2               ; BasSkipSpaces — Advance TXTPTR past spaces
000541r 2               ; ============================================================================
000541r 2               ; Modifies: A, Y, Flags
000541r 2               
000541r 2               BasSkipSpaces:
000541r 2  A0 00          ldy #$00
000543r 2               @SkipLoop:
000543r 2  B1 04          lda (BAS_TXTPTR),y
000545r 2  C9 20          cmp #CH_SPACE
000547r 2  D0 03          bne @SkipDone
000549r 2  C8             iny
00054Ar 2  80 F7          bra @SkipLoop
00054Cr 2               @SkipDone:
00054Cr 2                 ; Advance TXTPTR by Y
00054Cr 2  98             tya
00054Dr 2  18             clc
00054Er 2  65 04          adc BAS_TXTPTR
000550r 2  85 04          sta BAS_TXTPTR
000552r 2  A9 00          lda #$00
000554r 2  65 05          adc BAS_TXTPTR + 1
000556r 2  85 05          sta BAS_TXTPTR + 1
000558r 2  60             rts
000559r 2               
000559r 2               ; ============================================================================
000559r 2               ; BasGetTokChar — Get current token byte at TXTPTR without advancing
000559r 2               ; ============================================================================
000559r 2               ; Output: A = byte at TXTPTR, Z flag set if null
000559r 2               ; Modifies: A, Y, Flags
000559r 2               
000559r 2               BasGetTokChar:
000559r 2  A0 00          ldy #$00
00055Br 2  B1 04          lda (BAS_TXTPTR),y
00055Dr 2  60             rts
00055Er 2               
00055Er 2               ; ============================================================================
00055Er 2               ; BasAdvTxtPtr — Advance TXTPTR by 1
00055Er 2               ; ============================================================================
00055Er 2               ; Modifies: Flags
00055Er 2               
00055Er 2               BasAdvTxtPtr:
00055Er 2  E6 04          inc BAS_TXTPTR
000560r 2  D0 02          bne @Done
000562r 2  E6 05          inc BAS_TXTPTR + 1
000564r 2               @Done:
000564r 2  60             rts
000565r 2               
000565r 2               ; ============================================================================
000565r 2               ; BasExpectChar — Expect a specific character at TXTPTR, error if not found
000565r 2               ; ============================================================================
000565r 2               ; Input: A = expected character
000565r 2               ; Modifies: A, Y, Flags
000565r 2               
000565r 2               BasExpectChar:
000565r 2  A0 00          ldy #$00
000567r 2  D1 04          cmp (BAS_TXTPTR),y             ; Compare expected (A) with actual
000569r 2  D0 04          bne @SyntaxErr
00056Br 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip the character
00056Er 2  60             rts
00056Fr 2               @SyntaxErr:
00056Fr 2  A9 00          lda #ERR_SYNTAX
000571r 2  4C rr rr       jmp BasError
000574r 2               
000574r 2               ; ============================================================================
000574r 2               ; BasCheckBreak — Check for Ctrl+C during program execution
000574r 2               ; ============================================================================
000574r 2               ; Call at the top of each line in RUN mode.
000574r 2               ; Modifies: A, Flags
000574r 2               
000574r 2               BasCheckBreak:
000574r 2  A5 17          lda BAS_FLAGS
000576r 2  29 01          and #BAS_FLAG_RUN
000578r 2  F0 0D          beq @NoBrk                    ; Not running — skip check
00057Ar 2  20 rr rr       jsr Chrin                      ; Non-blocking read
00057Dr 2  90 08          bcc @NoBrk                    ; No character available
00057Fr 2  C9 03          cmp #CH_CTRLC
000581r 2  F0 05          beq @Break
000583r 2  C9 1B          cmp #CH_ESC
000585r 2  F0 01          beq @Break
000587r 2               @NoBrk:
000587r 2  60             rts
000588r 2               @Break:
000588r 2  A9 09          lda #ERR_BREAK
00058Ar 2  4C rr rr       jmp BasError
00058Dr 2               
00058Dr 2               ; ============================================================================
00058Dr 2               ; Error Handling
00058Dr 2               ; ============================================================================
00058Dr 2               
00058Dr 2               ; BasError — Print error message and return to REPL
00058Dr 2               ; Input: A = error code (ERR_* constant)
00058Dr 2               ; Never returns — jumps to BasMainLoop
00058Dr 2               
00058Dr 2               BasError:
00058Dr 2  48             pha                            ; Save error code
00058Er 2               
00058Er 2  20 rr rr       jsr BasPrintCRLF
000591r 2               
000591r 2  A9 3F          lda #'?'
000593r 2  20 rr rr       jsr Chrout
000596r 2               
000596r 2                 ; Look up error message pointer
000596r 2  68             pla
000597r 2  0A             asl                            ; ×2 for word-sized table index
000598r 2  AA             tax
000599r 2  BD rr rr       lda BasErrTable,x
00059Cr 2  85 0E          sta BAS_TMP1
00059Er 2  BD rr rr       lda BasErrTable+1,x
0005A1r 2  85 0F          sta BAS_TMP1 + 1
0005A3r 2               
0005A3r 2                 ; Print error message
0005A3r 2  20 rr rr       jsr BasPrintStr
0005A6r 2               
0005A6r 2                 ; Print " ERROR" (skip for BREAK)
0005A6r 2  E0 12          cpx #(ERR_BREAK * 2)
0005A8r 2  F0 0B          beq @SkipErrorWord
0005AAr 2  A9 rr          lda #<BasStrError
0005ACr 2  85 0E          sta BAS_TMP1
0005AEr 2  A9 rr          lda #>BasStrError
0005B0r 2  85 0F          sta BAS_TMP1 + 1
0005B2r 2  20 rr rr       jsr BasPrintStr
0005B5r 2               @SkipErrorWord:
0005B5r 2               
0005B5r 2                 ; If running, print " IN " + line number
0005B5r 2  A5 17          lda BAS_FLAGS
0005B7r 2  29 01          and #BAS_FLAG_RUN
0005B9r 2  F0 16          beq @ErrDone
0005BBr 2               
0005BBr 2  A9 rr          lda #<BasStrIn
0005BDr 2  85 0E          sta BAS_TMP1
0005BFr 2  A9 rr          lda #>BasStrIn
0005C1r 2  85 0F          sta BAS_TMP1 + 1
0005C3r 2  20 rr rr       jsr BasPrintStr
0005C6r 2               
0005C6r 2                 ; Print current line number
0005C6r 2  A5 08          lda BAS_LINENUM
0005C8r 2  85 0A          sta BAS_ACC
0005CAr 2  A5 09          lda BAS_LINENUM + 1
0005CCr 2  85 0B          sta BAS_ACC + 1
0005CEr 2  20 rr rr       jsr BasPrintInt
0005D1r 2               
0005D1r 2               @ErrDone:
0005D1r 2  20 rr rr       jsr BasPrintCRLF
0005D4r 2               
0005D4r 2                 ; Reset state and return to REPL
0005D4r 2  64 17          stz BAS_FLAGS
0005D6r 2  64 1A          stz BAS_GOSUBSP
0005D8r 2  64 1B          stz BAS_FORSP
0005DAr 2               
0005DAr 2                 ; Reset stack pointer to avoid stack corruption from nested calls
0005DAr 2  A2 FF          ldx #$FF
0005DCr 2  9A             txs
0005DDr 2               
0005DDr 2  4C rr rr       jmp BasMainLoop
0005E0r 2               
0005E0r 2               ; Error message pointer table
0005E0r 2               BasErrTable:
0005E0r 2  rr rr          .word BasErrSyntax             ; 0 - SYNTAX
0005E2r 2  rr rr          .word BasErrUndef              ; 1 - UNDEF'D LINE
0005E4r 2  rr rr          .word BasErrType               ; 2 - TYPE MISMATCH
0005E6r 2  rr rr          .word BasErrMem                ; 3 - OUT OF MEMORY
0005E8r 2  rr rr          .word BasErrRetGosub           ; 4 - RETURN W/O GOSUB
0005EAr 2  rr rr          .word BasErrNextFor            ; 5 - NEXT W/O FOR
0005ECr 2  rr rr          .word BasErrDivZero            ; 6 - DIVISION BY ZERO
0005EEr 2  rr rr          .word BasErrOverflow           ; 7 - OVERFLOW
0005F0r 2  rr rr          .word BasErrIllegal            ; 8 - ILLEGAL QUANTITY
0005F2r 2  rr rr          .word BasErrBreak              ; 9 - BREAK
0005F4r 2               
0005F4r 2               ; Error message strings
0005F4r 2  53 59 4E 54  BasErrSyntax:    .byte "SYNTAX", $00
0005F8r 2  41 58 00     
0005FBr 2  55 4E 44 45  BasErrUndef:     .byte "UNDEF'D LINE", $00
0005FFr 2  46 27 44 20  
000603r 2  4C 49 4E 45  
000608r 2  54 59 50 45  BasErrType:      .byte "TYPE MISMATCH", $00
00060Cr 2  20 4D 49 53  
000610r 2  4D 41 54 43  
000616r 2  4F 55 54 20  BasErrMem:       .byte "OUT OF MEMORY", $00
00061Ar 2  4F 46 20 4D  
00061Er 2  45 4D 4F 52  
000624r 2  52 45 54 55  BasErrRetGosub:  .byte "RETURN W/O GOSUB", $00
000628r 2  52 4E 20 57  
00062Cr 2  2F 4F 20 47  
000635r 2  4E 45 58 54  BasErrNextFor:   .byte "NEXT W/O FOR", $00
000639r 2  20 57 2F 4F  
00063Dr 2  20 46 4F 52  
000642r 2  44 49 56 49  BasErrDivZero:   .byte "DIVISION BY ZERO", $00
000646r 2  53 49 4F 4E  
00064Ar 2  20 42 59 20  
000653r 2  4F 56 45 52  BasErrOverflow:  .byte "OVERFLOW", $00
000657r 2  46 4C 4F 57  
00065Br 2  00           
00065Cr 2  49 4C 4C 45  BasErrIllegal:   .byte "ILLEGAL QUANTITY", $00
000660r 2  47 41 4C 20  
000664r 2  51 55 41 4E  
00066Dr 2  42 52 45 41  BasErrBreak:     .byte "BREAK", $00
000671r 2  4B 00        
000673r 2               
000673r 2               ; ============================================================================
000673r 2               ; 16-Bit Math Routines
000673r 2               ; ============================================================================
000673r 2               
000673r 2               ; BasMathAdd — ACC = AUX + ACC
000673r 2               BasMathAdd:
000673r 2  18             clc
000674r 2  A5 0C          lda BAS_AUX
000676r 2  65 0A          adc BAS_ACC
000678r 2  85 0A          sta BAS_ACC
00067Ar 2  A5 0D          lda BAS_AUX + 1
00067Cr 2  65 0B          adc BAS_ACC + 1
00067Er 2  85 0B          sta BAS_ACC + 1
000680r 2  60             rts
000681r 2               
000681r 2               ; BasMathSub — ACC = AUX - ACC
000681r 2               BasMathSub:
000681r 2  38             sec
000682r 2  A5 0C          lda BAS_AUX
000684r 2  E5 0A          sbc BAS_ACC
000686r 2  85 0A          sta BAS_ACC
000688r 2  A5 0D          lda BAS_AUX + 1
00068Ar 2  E5 0B          sbc BAS_ACC + 1
00068Cr 2  85 0B          sta BAS_ACC + 1
00068Er 2  60             rts
00068Fr 2               
00068Fr 2               ; BasMathNeg — ACC = -ACC (two's complement)
00068Fr 2               BasMathNeg:
00068Fr 2  38             sec
000690r 2  A9 00          lda #$00
000692r 2  E5 0A          sbc BAS_ACC
000694r 2  85 0A          sta BAS_ACC
000696r 2  A9 00          lda #$00
000698r 2  E5 0B          sbc BAS_ACC + 1
00069Ar 2  85 0B          sta BAS_ACC + 1
00069Cr 2  60             rts
00069Dr 2               
00069Dr 2               ; BasMathAbs — ACC = |ACC|
00069Dr 2               BasMathAbs:
00069Dr 2  A5 0B          lda BAS_ACC + 1
00069Fr 2  10 03          bpl @Done
0006A1r 2  4C rr rr       jmp BasMathNeg
0006A4r 2               @Done:
0006A4r 2  60             rts
0006A5r 2               
0006A5r 2               ; BasMathMul — ACC = AUX * ACC (16-bit signed)
0006A5r 2               ; Uses shift-and-add on magnitudes, applies sign separately
0006A5r 2               BasMathMul:
0006A5r 2                 ; Determine result sign
0006A5r 2  A5 0D          lda BAS_AUX + 1
0006A7r 2  45 0B          eor BAS_ACC + 1
0006A9r 2  85 20          sta BAS_SIGN                   ; Bit 7 = result sign
0006ABr 2               
0006ABr 2                 ; Make both operands positive
0006ABr 2  A5 0D          lda BAS_AUX + 1
0006ADr 2  10 0D          bpl @AuxPos
0006AFr 2  38             sec
0006B0r 2  A9 00          lda #$00
0006B2r 2  E5 0C          sbc BAS_AUX
0006B4r 2  85 0C          sta BAS_AUX
0006B6r 2  A9 00          lda #$00
0006B8r 2  E5 0D          sbc BAS_AUX + 1
0006BAr 2  85 0D          sta BAS_AUX + 1
0006BCr 2               @AuxPos:
0006BCr 2  A5 0B          lda BAS_ACC + 1
0006BEr 2  10 03          bpl @AccPos
0006C0r 2  20 rr rr       jsr BasMathNeg
0006C3r 2               @AccPos:
0006C3r 2                 ; ACC = multiplier, AUX = multiplicand
0006C3r 2                 ; Result accumulates in SCRATCH:SCRATCH+1
0006C3r 2  64 1C          stz BAS_SCRATCH
0006C5r 2  64 1D          stz BAS_SCRATCH + 1
0006C7r 2  A2 10          ldx #16                        ; 16 bits
0006C9r 2               
0006C9r 2               @MulLoop:
0006C9r 2                 ; Shift multiplier (ACC) right
0006C9r 2  46 0B          lsr BAS_ACC + 1
0006CBr 2  66 0A          ror BAS_ACC
0006CDr 2  90 0D          bcc @MulNoAdd
0006CFr 2               
0006CFr 2                 ; Add multiplicand to result
0006CFr 2  18             clc
0006D0r 2  A5 1C          lda BAS_SCRATCH
0006D2r 2  65 0C          adc BAS_AUX
0006D4r 2  85 1C          sta BAS_SCRATCH
0006D6r 2  A5 1D          lda BAS_SCRATCH + 1
0006D8r 2  65 0D          adc BAS_AUX + 1
0006DAr 2  85 1D          sta BAS_SCRATCH + 1
0006DCr 2               
0006DCr 2               @MulNoAdd:
0006DCr 2                 ; Shift multiplicand left
0006DCr 2  06 0C          asl BAS_AUX
0006DEr 2  26 0D          rol BAS_AUX + 1
0006E0r 2  CA             dex
0006E1r 2  D0 E6          bne @MulLoop
0006E3r 2               
0006E3r 2                 ; Copy result
0006E3r 2  A5 1C          lda BAS_SCRATCH
0006E5r 2  85 0A          sta BAS_ACC
0006E7r 2  A5 1D          lda BAS_SCRATCH + 1
0006E9r 2  85 0B          sta BAS_ACC + 1
0006EBr 2               
0006EBr 2                 ; Apply sign
0006EBr 2  A5 20          lda BAS_SIGN
0006EDr 2  10 03          bpl @MulDone
0006EFr 2  4C rr rr       jmp BasMathNeg
0006F2r 2               @MulDone:
0006F2r 2  60             rts
0006F3r 2               
0006F3r 2               ; BasMathDiv — ACC = AUX / ACC, remainder in BAS_SCRATCH2
0006F3r 2               ; 16-bit signed division
0006F3r 2               BasMathDiv:
0006F3r 2                 ; Check for division by zero
0006F3r 2  A5 0A          lda BAS_ACC
0006F5r 2  05 0B          ora BAS_ACC + 1
0006F7r 2  D0 05          bne @DivNotZero
0006F9r 2  A9 06          lda #ERR_DIV_ZERO
0006FBr 2  4C rr rr       jmp BasError
0006FEr 2               
0006FEr 2               @DivNotZero:
0006FEr 2                 ; Determine result sign
0006FEr 2  A5 0D          lda BAS_AUX + 1
000700r 2  45 0B          eor BAS_ACC + 1
000702r 2  85 20          sta BAS_SIGN
000704r 2               
000704r 2                 ; Save remainder sign (same as dividend) on CPU stack
000704r 2  A5 0D          lda BAS_AUX + 1
000706r 2  48             pha
000707r 2               
000707r 2                 ; Make both positive
000707r 2  A5 0D          lda BAS_AUX + 1
000709r 2  10 0D          bpl @DivAuxPos
00070Br 2  38             sec
00070Cr 2  A9 00          lda #$00
00070Er 2  E5 0C          sbc BAS_AUX
000710r 2  85 0C          sta BAS_AUX
000712r 2  A9 00          lda #$00
000714r 2  E5 0D          sbc BAS_AUX + 1
000716r 2  85 0D          sta BAS_AUX + 1
000718r 2               @DivAuxPos:
000718r 2  A5 0B          lda BAS_ACC + 1
00071Ar 2  10 03          bpl @DivAccPos
00071Cr 2  20 rr rr       jsr BasMathNeg
00071Fr 2               @DivAccPos:
00071Fr 2                 ; AUX = dividend, ACC = divisor
00071Fr 2                 ; Remainder in SCRATCH2
00071Fr 2  64 1E          stz BAS_SCRATCH2
000721r 2  64 1F          stz BAS_SCRATCH2 + 1
000723r 2               
000723r 2  A2 10          ldx #16
000725r 2               
000725r 2               @DivLoop:
000725r 2                 ; Shift dividend left into remainder
000725r 2  06 0C          asl BAS_AUX
000727r 2  26 0D          rol BAS_AUX + 1
000729r 2  26 1E          rol BAS_SCRATCH2
00072Br 2  26 1F          rol BAS_SCRATCH2 + 1
00072Dr 2               
00072Dr 2                 ; Try subtract divisor from remainder
00072Dr 2  38             sec
00072Er 2  A5 1E          lda BAS_SCRATCH2
000730r 2  E5 0A          sbc BAS_ACC
000732r 2  85 1C          sta BAS_SCRATCH
000734r 2  A5 1F          lda BAS_SCRATCH2 + 1
000736r 2  E5 0B          sbc BAS_ACC + 1
000738r 2               
000738r 2  90 08          bcc @DivNoSub
00073Ar 2               
00073Ar 2                 ; Subtraction succeeded — set quotient bit
00073Ar 2  85 1F          sta BAS_SCRATCH2 + 1
00073Cr 2  A5 1C          lda BAS_SCRATCH
00073Er 2  85 1E          sta BAS_SCRATCH2
000740r 2  E6 0C          inc BAS_AUX                    ; Set low bit of quotient
000742r 2               
000742r 2               @DivNoSub:
000742r 2  CA             dex
000743r 2  D0 E0          bne @DivLoop
000745r 2               
000745r 2                 ; Quotient is in AUX, remainder in SCRATCH2
000745r 2  A5 0C          lda BAS_AUX
000747r 2  85 0A          sta BAS_ACC
000749r 2  A5 0D          lda BAS_AUX + 1
00074Br 2  85 0B          sta BAS_ACC + 1
00074Dr 2               
00074Dr 2                 ; Apply sign to quotient
00074Dr 2  A5 20          lda BAS_SIGN
00074Fr 2  10 03          bpl @DivQuotPos
000751r 2  20 rr rr       jsr BasMathNeg
000754r 2               @DivQuotPos:
000754r 2                 ; Apply sign to remainder (same sign as dividend)
000754r 2  68             pla                            ; Remainder sign (was dividend's high byte)
000755r 2  10 0D          bpl @DivDone
000757r 2                 ; Negate remainder
000757r 2  38             sec
000758r 2  A9 00          lda #$00
00075Ar 2  E5 1E          sbc BAS_SCRATCH2
00075Cr 2  85 1E          sta BAS_SCRATCH2
00075Er 2  A9 00          lda #$00
000760r 2  E5 1F          sbc BAS_SCRATCH2 + 1
000762r 2  85 1F          sta BAS_SCRATCH2 + 1
000764r 2               @DivDone:
000764r 2  60             rts
000765r 2               
000765r 2               ; ============================================================================
000765r 2               ; Expression Evaluator — Recursive Descent
000765r 2               ; ============================================================================
000765r 2               ; Result always in BAS_ACC (16-bit signed).
000765r 2               ; TXTPTR is advanced past consumed tokens.
000765r 2               
000765r 2               ; BasExpr — Top level: handle OR
000765r 2               BasExpr:
000765r 2  20 rr rr       jsr BasExprAnd
000768r 2               @OrLoop:
000768r 2  20 rr rr       jsr BasSkipSpaces
00076Br 2  20 rr rr       jsr BasGetTokChar
00076Er 2  C9 98          cmp #TOK_OR
000770r 2  D0 2E          bne @OrDone
000772r 2  20 rr rr       jsr BasAdvTxtPtr
000775r 2  A5 0A          lda BAS_ACC
000777r 2  48             pha
000778r 2  A5 0B          lda BAS_ACC + 1
00077Ar 2  48             pha
00077Br 2  20 rr rr       jsr BasExprAnd
00077Er 2                 ; Pop left operand into AUX
00077Er 2  68             pla
00077Fr 2  85 0D          sta BAS_AUX + 1
000781r 2  68             pla
000782r 2  85 0C          sta BAS_AUX
000784r 2                 ; OR: result = (AUX != 0) || (ACC != 0) ? 1 : 0
000784r 2  A5 0C          lda BAS_AUX
000786r 2  05 0D          ora BAS_AUX + 1
000788r 2  F0 04          beq @OrRight
00078Ar 2  A9 01          lda #$01
00078Cr 2  80 0C          bra @OrStore
00078Er 2               @OrRight:
00078Er 2  A5 0A          lda BAS_ACC
000790r 2  05 0B          ora BAS_ACC + 1
000792r 2  F0 04          beq @OrFalse
000794r 2  A9 01          lda #$01
000796r 2  80 02          bra @OrStore
000798r 2               @OrFalse:
000798r 2  A9 00          lda #$00
00079Ar 2               @OrStore:
00079Ar 2  85 0A          sta BAS_ACC
00079Cr 2  64 0B          stz BAS_ACC + 1
00079Er 2  80 C8          bra @OrLoop
0007A0r 2               @OrDone:
0007A0r 2  60             rts
0007A1r 2               
0007A1r 2               ; BasExprAnd — Handle AND
0007A1r 2               BasExprAnd:
0007A1r 2  20 rr rr       jsr BasExprNot
0007A4r 2               @AndLoop:
0007A4r 2  20 rr rr       jsr BasSkipSpaces
0007A7r 2  20 rr rr       jsr BasGetTokChar
0007AAr 2  C9 97          cmp #TOK_AND
0007ACr 2  D0 2C          bne @AndDone
0007AEr 2  20 rr rr       jsr BasAdvTxtPtr
0007B1r 2  A5 0A          lda BAS_ACC
0007B3r 2  48             pha
0007B4r 2  A5 0B          lda BAS_ACC + 1
0007B6r 2  48             pha
0007B7r 2  20 rr rr       jsr BasExprNot
0007BAr 2  68             pla
0007BBr 2  85 0D          sta BAS_AUX + 1
0007BDr 2  68             pla
0007BEr 2  85 0C          sta BAS_AUX
0007C0r 2                 ; AND: both nonzero = 1, else 0
0007C0r 2  A5 0C          lda BAS_AUX
0007C2r 2  05 0D          ora BAS_AUX + 1
0007C4r 2  F0 0E          beq @AndFalse
0007C6r 2  A5 0A          lda BAS_ACC
0007C8r 2  05 0B          ora BAS_ACC + 1
0007CAr 2  F0 08          beq @AndFalse
0007CCr 2  A9 01          lda #$01
0007CEr 2  64 0B          stz BAS_ACC + 1
0007D0r 2  85 0A          sta BAS_ACC
0007D2r 2  80 D0          bra @AndLoop
0007D4r 2               @AndFalse:
0007D4r 2  64 0A          stz BAS_ACC
0007D6r 2  64 0B          stz BAS_ACC + 1
0007D8r 2  80 CA          bra @AndLoop
0007DAr 2               @AndDone:
0007DAr 2  60             rts
0007DBr 2               
0007DBr 2               ; BasExprNot — Handle NOT (unary prefix)
0007DBr 2               BasExprNot:
0007DBr 2  20 rr rr       jsr BasSkipSpaces
0007DEr 2  20 rr rr       jsr BasGetTokChar
0007E1r 2  C9 96          cmp #TOK_NOT
0007E3r 2  D0 18          bne @NotSkip
0007E5r 2  20 rr rr       jsr BasAdvTxtPtr
0007E8r 2  20 rr rr       jsr BasExprCmp
0007EBr 2                 ; NOT: 0 -> 1, nonzero -> 0
0007EBr 2  A5 0A          lda BAS_ACC
0007EDr 2  05 0B          ora BAS_ACC + 1
0007EFr 2  F0 05          beq @NotTrue
0007F1r 2  64 0A          stz BAS_ACC
0007F3r 2  64 0B          stz BAS_ACC + 1
0007F5r 2  60             rts
0007F6r 2               @NotTrue:
0007F6r 2  A9 01          lda #$01
0007F8r 2  85 0A          sta BAS_ACC
0007FAr 2  64 0B          stz BAS_ACC + 1
0007FCr 2  60             rts
0007FDr 2               @NotSkip:
0007FDr 2  4C rr rr       jmp BasExprCmp
000800r 2               
000800r 2               ; BasExprCmp — Handle comparison: =, <>, <, >, <=, >=
000800r 2               BasExprCmp:
000800r 2  20 rr rr       jsr BasExprAdd
000803r 2  20 rr rr       jsr BasSkipSpaces
000806r 2  20 rr rr       jsr BasGetTokChar
000809r 2               
000809r 2                 ; Check each comparison operator
000809r 2  C9 3D          cmp #CH_EQUALS
00080Br 2  F0 15          beq @CmpEQ
00080Dr 2  C9 3C          cmp #CH_LESS
00080Fr 2  F0 39          beq @CmpLT
000811r 2  C9 3E          cmp #CH_GREATER
000813r 2  F0 42          beq @CmpGT
000815r 2  C9 9C          cmp #TOK_NE
000817r 2  F0 1D          beq @CmpNE
000819r 2  C9 9B          cmp #TOK_LE
00081Br 2  F0 49          beq @CmpLE
00081Dr 2  C9 9A          cmp #TOK_GE
00081Fr 2  F0 54          beq @CmpGE
000821r 2  60             rts                            ; No comparison operator
000822r 2               
000822r 2               @CmpEQ:
000822r 2  20 rr rr       jsr BasAdvTxtPtr
000825r 2  20 rr rr       jsr @CmpPushEvalRight
000828r 2                 ; Equal: ACC == AUX
000828r 2  A5 0A          lda BAS_ACC
00082Ar 2  C5 0C          cmp BAS_AUX
00082Cr 2  D0 5B          bne @CmpSetFalse
00082Er 2  A5 0B          lda BAS_ACC + 1
000830r 2  C5 0D          cmp BAS_AUX + 1
000832r 2  D0 55          bne @CmpSetFalse
000834r 2  80 4C          bra @CmpSetTrue
000836r 2               
000836r 2               @CmpNE:
000836r 2  20 rr rr       jsr BasAdvTxtPtr
000839r 2  20 rr rr       jsr @CmpPushEvalRight
00083Cr 2  A5 0A          lda BAS_ACC
00083Er 2  C5 0C          cmp BAS_AUX
000840r 2  D0 40          bne @CmpSetTrue
000842r 2  A5 0B          lda BAS_ACC + 1
000844r 2  C5 0D          cmp BAS_AUX + 1
000846r 2  D0 3A          bne @CmpSetTrue
000848r 2  80 3F          bra @CmpSetFalse
00084Ar 2               
00084Ar 2               @CmpLT:
00084Ar 2  20 rr rr       jsr BasAdvTxtPtr
00084Dr 2  20 rr rr       jsr @CmpPushEvalRight
000850r 2  20 rr rr       jsr BasCmpAuxAcc
000853r 2  30 2D          bmi @CmpSetTrue
000855r 2  80 32          bra @CmpSetFalse
000857r 2               
000857r 2               @CmpGT:
000857r 2  20 rr rr       jsr BasAdvTxtPtr
00085Ar 2  20 rr rr       jsr @CmpPushEvalRight
00085Dr 2  20 rr rr       jsr BasCmpAuxAcc
000860r 2  F0 27          beq @CmpSetFalse
000862r 2  10 1E          bpl @CmpSetTrue
000864r 2  80 23          bra @CmpSetFalse
000866r 2               
000866r 2               @CmpLE:
000866r 2  20 rr rr       jsr BasAdvTxtPtr
000869r 2  20 rr rr       jsr @CmpPushEvalRight
00086Cr 2  20 rr rr       jsr BasCmpAuxAcc
00086Fr 2  30 11          bmi @CmpSetTrue
000871r 2  F0 0F          beq @CmpSetTrue
000873r 2  80 14          bra @CmpSetFalse
000875r 2               
000875r 2               @CmpGE:
000875r 2  20 rr rr       jsr BasAdvTxtPtr
000878r 2  20 rr rr       jsr @CmpPushEvalRight
00087Br 2  20 rr rr       jsr BasCmpAuxAcc
00087Er 2  10 02          bpl @CmpSetTrue
000880r 2  80 07          bra @CmpSetFalse
000882r 2               
000882r 2               @CmpSetTrue:
000882r 2  A9 01          lda #$01
000884r 2  85 0A          sta BAS_ACC
000886r 2  64 0B          stz BAS_ACC + 1
000888r 2  60             rts
000889r 2               @CmpSetFalse:
000889r 2  64 0A          stz BAS_ACC
00088Br 2  64 0B          stz BAS_ACC + 1
00088Dr 2  60             rts
00088Er 2               
00088Er 2               ; Helper: push left, evaluate right into ACC, pop left into AUX
00088Er 2               @CmpPushEvalRight:
00088Er 2  A5 0A          lda BAS_ACC
000890r 2  48             pha
000891r 2  A5 0B          lda BAS_ACC + 1
000893r 2  48             pha
000894r 2  20 rr rr       jsr BasExprAdd
000897r 2  68             pla
000898r 2  85 0D          sta BAS_AUX + 1
00089Ar 2  68             pla
00089Br 2  85 0C          sta BAS_AUX
00089Dr 2  60             rts
00089Er 2               
00089Er 2               ; BasCmpAuxAcc — Signed compare AUX vs ACC
00089Er 2               ; Returns: N flag set if AUX < ACC, Z if equal, N clear & Z clear if AUX > ACC
00089Er 2               BasCmpAuxAcc:
00089Er 2                 ; Compare high bytes first (signed)
00089Er 2  A5 0D          lda BAS_AUX + 1
0008A0r 2  38             sec
0008A1r 2  E5 0B          sbc BAS_ACC + 1
0008A3r 2  50 02          bvc @CmpNoOvf
0008A5r 2  49 80          eor #$80                       ; Fix sign on overflow
0008A7r 2               @CmpNoOvf:
0008A7r 2  30 0D          bmi @CmpLess
0008A9r 2  D0 08          bne @CmpGreater
0008ABr 2                 ; High bytes equal — compare low bytes (unsigned)
0008ABr 2  A5 0C          lda BAS_AUX
0008ADr 2  C5 0A          cmp BAS_ACC
0008AFr 2  F0 08          beq @CmpEqual
0008B1r 2  90 03          bcc @CmpLess
0008B3r 2               @CmpGreater:
0008B3r 2  A9 01          lda #$01                       ; Positive, non-zero
0008B5r 2  60             rts
0008B6r 2               @CmpLess:
0008B6r 2  A9 FF          lda #$FF                       ; Negative
0008B8r 2  60             rts
0008B9r 2               @CmpEqual:
0008B9r 2  A9 00          lda #$00                       ; Zero
0008BBr 2  60             rts
0008BCr 2               
0008BCr 2               ; BasExprAdd — Handle + and -
0008BCr 2               BasExprAdd:
0008BCr 2  20 rr rr       jsr BasExprMul
0008BFr 2               @AddLoop:
0008BFr 2  20 rr rr       jsr BasSkipSpaces
0008C2r 2  20 rr rr       jsr BasGetTokChar
