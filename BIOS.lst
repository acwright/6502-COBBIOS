000C0Br 2  48             pha
000C0Cr 2  A9 2C          lda #CH_COMMA
000C0Er 2  20 rr rr       jsr BasExpectChar
000C11r 2  20 rr rr       jsr BasExpr                    ; b -> BAS_ACC
000C14r 2  A9 29          lda #CH_RPAREN
000C16r 2  20 rr rr       jsr BasExpectChar
000C19r 2                 ; Pop a into AUX
000C19r 2  68             pla
000C1Ar 2  85 0D          sta BAS_AUX + 1
000C1Cr 2  68             pla
000C1Dr 2  85 0C          sta BAS_AUX
000C1Fr 2  20 rr rr       jsr BasCmpAuxAcc               ; compare AUX(a) vs ACC(b)
000C22r 2  F0 02          beq @MaxKeepAcc                ; equal, either is fine
000C24r 2  10 01          bpl @MaxUseAux                 ; AUX > ACC, use AUX
000C26r 2               @MaxKeepAcc:
000C26r 2  60             rts                            ; ACC is larger or equal
000C27r 2               @MaxUseAux:
000C27r 2  A5 0C          lda BAS_AUX
000C29r 2  85 0A          sta BAS_ACC
000C2Br 2  A5 0D          lda BAS_AUX + 1
000C2Dr 2  85 0B          sta BAS_ACC + 1
000C2Fr 2  60             rts
