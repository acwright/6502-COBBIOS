000A51r 2               
000A51r 2               DisOpRel:
000A51r 2                 ; Target = current_addr + 2 + signed_offset
000A51r 2  A0 01          ldy #1
000A53r 2  B1 2E          lda (MON_ADDR),y              ; offset byte
000A55r 2  30 0D          bmi @Neg
000A57r 2                 ; Positive offset
000A57r 2  18             clc
000A58r 2  65 2E          adc MON_ADDR
000A5Ar 2  85 32          sta MON_TMP
000A5Cr 2  A5 2F          lda MON_ADDR+1
000A5Er 2  69 00          adc #0
000A60r 2  85 33          sta MON_TMP+1
000A62r 2  80 0B          bra @Add2
000A64r 2               @Neg:
000A64r 2  18             clc
000A65r 2  65 2E          adc MON_ADDR
000A67r 2  85 32          sta MON_TMP
000A69r 2  A5 2F          lda MON_ADDR+1
000A6Br 2  69 FF          adc #$FF                      ; sign extension
000A6Dr 2  85 33          sta MON_TMP+1
000A6Fr 2               @Add2:
000A6Fr 2  18             clc
000A70r 2  A5 32          lda MON_TMP
000A72r 2  69 02          adc #2
000A74r 2  85 32          sta MON_TMP
000A76r 2  A5 33          lda MON_TMP+1
000A78r 2  69 00          adc #0
000A7Ar 2  85 33          sta MON_TMP+1
000A7Cr 2                 ; Print "$XXXX"
000A7Cr 2  A9 24          lda #'$'
000A7Er 2  20 rr rr       jsr Chrout
000A81r 2  A5 33          lda MON_TMP+1
000A83r 2  20 rr rr       jsr MonPrintHex2
