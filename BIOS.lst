000BE2r 2                 ; Pop a into AUX
000BE2r 2  68             pla
000BE3r 2  85 0D          sta BAS_AUX + 1
000BE5r 2  68             pla
000BE6r 2  85 0C          sta BAS_AUX
000BE8r 2  20 rr rr       jsr BasCmpAuxAcc               ; compare AUX(a) vs ACC(b)
000BEBr 2  30 01          bmi @MinDone                   ; AUX < ACC, use AUX
000BEDr 2  60             rts                            ; ACC is smaller or equal
000BEEr 2               @MinDone:
000BEEr 2  A5 0C          lda BAS_AUX
000BF0r 2  85 0A          sta BAS_ACC
000BF2r 2  A5 0D          lda BAS_AUX + 1
000BF4r 2  85 0B          sta BAS_ACC + 1
000BF6r 2  60             rts
000BF7r 2               @NotMin:
000BF7r 2               
000BF7r 2                 ; MAX(a,b) — Return larger of two values
000BF7r 2  C9 B8          cmp #TOK_MAX
000BF9r 2  D0 35          bne @NotMax
