000726r 2               
000726r 2               @DivNoSub:
000726r 2  CA             dex
000727r 2  D0 E0          bne @DivLoop
000729r 2               
000729r 2                 ; Quotient is in AUX, remainder in SCRATCH2
000729r 2  A5 0C          lda BAS_AUX
00072Br 2  85 0A          sta BAS_ACC
00072Dr 2  A5 0D          lda BAS_AUX + 1
00072Fr 2  85 0B          sta BAS_ACC + 1
000731r 2               
000731r 2                 ; Apply sign to quotient
000731r 2  A5 20          lda BAS_SIGN
000733r 2  10 03          bpl @DivQuotPos
000735r 2  20 rr rr       jsr BasMathNeg
000738r 2               @DivQuotPos:
000738r 2                 ; Apply sign to remainder (same sign as dividend)
000738r 2  68             pla                            ; Remainder sign (was dividend's high byte)
000739r 2  10 0D          bpl @DivDone
00073Br 2                 ; Negate remainder
00073Br 2  38             sec
00073Cr 2  A9 00          lda #$00
00073Er 2  E5 1E          sbc BAS_SCRATCH2
000740r 2  85 1E          sta BAS_SCRATCH2
000742r 2  A9 00          lda #$00
000744r 2  E5 1F          sbc BAS_SCRATCH2 + 1
000746r 2  85 1F          sta BAS_SCRATCH2 + 1
000748r 2               @DivDone:
000748r 2  60             rts
000749r 2               
000749r 2               ; ============================================================================
000749r 2               ; Expression Evaluator — Recursive Descent
000749r 2               ; ============================================================================
000749r 2               ; Result always in BAS_ACC (16-bit signed).
000749r 2               ; TXTPTR is advanced past consumed tokens.
000749r 2               
000749r 2               ; BasExpr — Top level: handle OR
000749r 2               BasExpr:
000749r 2  20 rr rr       jsr BasExprAnd
00074Cr 2               @OrLoop:
00074Cr 2  20 rr rr       jsr BasSkipSpaces
