000000r 2               RTC_SEC             := $8800
000000r 2               RTC_MIN             := $8801
000000r 2               RTC_HR              := $8802
000000r 2               RTC_DAY             := $8803
000000r 2               RTC_DATE            := $8804
000000r 2               RTC_MON             := $8805
000000r 2               RTC_YR              := $8806
000000r 2               RTC_CENT            := $8807
