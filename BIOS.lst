000FB4r 2               ; ============================================================================
000FB4r 2               ; RUN — Execute program from first line
000FB4r 2               ; ============================================================================
000FB4r 2               
000FB4r 2               BasCmdRun:
000FB4r 2  20 rr rr       jsr BasCmdClr
000FB7r 2  A9 01          lda #BAS_FLAG_RUN
000FB9r 2  85 17          sta BAS_FLAGS
000FBBr 2               
000FBBr 2                 ; Start at first program line
000FBBr 2  A9 00          lda #<BAS_PRG_START
000FBDr 2  85 06          sta BAS_CURLINE
000FBFr 2  A9 08          lda #>BAS_PRG_START
000FC1r 2  85 07          sta BAS_CURLINE + 1
000FC3r 2               
000FC3r 2               BasRunLoop:
000FC3r 2                 ; Check if at end of program (CURLINE == PRGEND)
000FC3r 2  A5 06          lda BAS_CURLINE
000FC5r 2  C5 12          cmp BAS_PRGEND
000FC7r 2  D0 06          bne @RunNotEnd
000FC9r 2  A5 07          lda BAS_CURLINE + 1
000FCBr 2  C5 13          cmp BAS_PRGEND + 1
000FCDr 2  F0 6C          beq BasRunDone
000FCFr 2               @RunNotEnd:
000FCFr 2               
000FCFr 2                 ; Check for Ctrl+C break
000FCFr 2  20 rr rr       jsr BasCheckBreak
000FD2r 2               
000FD2r 2                 ; Get line number
000FD2r 2  A0 02          ldy #LINE_NUM
000FD4r 2  B1 06          lda (BAS_CURLINE),y
000FD6r 2  85 08          sta BAS_LINENUM
000FD8r 2  C8             iny
000FD9r 2  B1 06          lda (BAS_CURLINE),y
000FDBr 2  85 09          sta BAS_LINENUM + 1
000FDDr 2               
000FDDr 2                 ; Save CURLINE before execution for GOTO/GOSUB detection
000FDDr 2  A5 06          lda BAS_CURLINE
000FDFr 2  85 14          sta BAS_VARPTR
000FE1r 2  A5 07          lda BAS_CURLINE + 1
000FE3r 2  85 15          sta BAS_VARPTR + 1
000FE5r 2               
000FE5r 2                 ; Set TXTPTR to payload (unless NEXT already set it)
000FE5r 2  A5 17          lda BAS_FLAGS
000FE7r 2  29 04          and #BAS_FLAG_TXTSET
000FE9r 2  D0 0D          bne @SkipTxtSet
000FEBr 2  18             clc
000FECr 2  A5 06          lda BAS_CURLINE
000FEEr 2  69 04          adc #LINE_PAYLOAD
000FF0r 2  85 04          sta BAS_TXTPTR
000FF2r 2  A5 07          lda BAS_CURLINE + 1
000FF4r 2  69 00          adc #$00
000FF6r 2  85 05          sta BAS_TXTPTR + 1
000FF8r 2               @SkipTxtSet:
000FF8r 2  A5 17          lda BAS_FLAGS
000FFAr 2  29 FB          and #<~BAS_FLAG_TXTSET          ; Clear the flag
000FFCr 2  85 17          sta BAS_FLAGS
000FFEr 2               
000FFEr 2               BasRunExec:
000FFEr 2                 ; Execute the line (CONT re-enters here with TXTPTR already set)
000FFEr 2  20 rr rr       jsr BasExecLine
001001r 2               
001001r 2                 ; Check if END was executed (flags cleared)
001001r 2  A5 17          lda BAS_FLAGS
001003r 2  29 01          and #BAS_FLAG_RUN
001005r 2  F0 34          beq BasRunDone
001007r 2               
001007r 2                 ; Check if GOTO/GOSUB changed CURLINE (or GOTO flag set for same-line GOTO)
001007r 2  A5 17          lda BAS_FLAGS
001009r 2  29 08          and #BAS_FLAG_GOTO
00100Br 2  D0 25          bne @GotoDone
00100Dr 2  A5 06          lda BAS_CURLINE
00100Fr 2  C5 14          cmp BAS_VARPTR
001011r 2  D0 B0          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
001013r 2  A5 07          lda BAS_CURLINE + 1
001015r 2  C5 15          cmp BAS_VARPTR + 1
001017r 2  D0 AA          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
001019r 2               
001019r 2                 ; Advance to next line by scanning for end of current line
001019r 2  A0 04          ldy #LINE_PAYLOAD
00101Br 2               @RunScanNull:
00101Br 2  B1 06          lda (BAS_CURLINE),y
00101Dr 2  F0 03          beq @RunFoundNull
00101Fr 2  C8             iny
001020r 2  80 F9          bra @RunScanNull
001022r 2               @RunFoundNull:
001022r 2  C8             iny                            ; Past null terminator
001023r 2  98             tya
001024r 2  18             clc
001025r 2  65 06          adc BAS_CURLINE
001027r 2  85 06          sta BAS_CURLINE
001029r 2  A9 00          lda #$00
00102Br 2  65 07          adc BAS_CURLINE + 1
00102Dr 2  85 07          sta BAS_CURLINE + 1
00102Fr 2  4C rr rr       jmp BasRunLoop
001032r 2               
001032r 2               @GotoDone:
001032r 2  A5 17          lda BAS_FLAGS
001034r 2  29 F7          and #<~BAS_FLAG_GOTO
001036r 2  85 17          sta BAS_FLAGS
001038r 2  4C rr rr       jmp BasRunLoop
00103Br 2               
00103Br 2               BasRunDone:
00103Br 2  64 17          stz BAS_FLAGS
00103Dr 2  60             rts
00103Er 2               
00103Er 2               ; ============================================================================
00103Er 2               ; Statement Handlers
00103Er 2               ; ============================================================================
00103Er 2               
00103Er 2               ; --- PRINT ---
00103Er 2               BasCmdPrint:
00103Er 2  20 rr rr       jsr BasSkipSpaces
001041r 2  20 rr rr       jsr BasGetTokChar
001044r 2  D0 03          bne :+
001046r 2  4C rr rr       jmp @PrintNewline              ; Empty PRINT — just newline
001049r 2  C9 3A        : cmp #CH_COLON
00104Br 2  D0 03          bne :+
00104Dr 2  4C rr rr       jmp @PrintNewline              ; PRINT: — newline then next statement
001050r 2               :
001050r 2               
001050r 2               @PrintLoop:
001050r 2  20 rr rr       jsr BasSkipSpaces
001053r 2  20 rr rr       jsr BasGetTokChar
001056r 2  D0 03          bne :+
001058r 2  4C rr rr       jmp @PrintEnd                  ; End of line
00105Br 2  C9 3A        : cmp #CH_COLON
00105Dr 2  D0 03          bne :+
00105Fr 2  4C rr rr       jmp @PrintEnd
001062r 2               :
001062r 2               
001062r 2                 ; String literal?
001062r 2  C9 22          cmp #CH_QUOTE
001064r 2  D0 03          bne :+
001066r 2  4C rr rr       jmp @PrintString
001069r 2               :
001069r 2               
001069r 2                 ; CHR(n) — output character directly
001069r 2  C9 AF          cmp #TOK_CHR
00106Br 2  D0 03          bne :+
00106Dr 2  4C rr rr       jmp @PrintChr
001070r 2               :
001070r 2               
001070r 2                 ; TAB(n) — tab to column n
001070r 2  C9 BB          cmp #TOK_TAB
001072r 2  D0 03          bne :+
001074r 2  4C rr rr       jmp @PrintTab
001077r 2               :
001077r 2               
001077r 2                 ; HEX(n) — print value as $xxxx hex
001077r 2  C9 BC          cmp #TOK_HEX
001079r 2  D0 03          bne :+
00107Br 2  4C rr rr       jmp @PrintHex
00107Er 2               :
00107Er 2               
00107Er 2                 ; Otherwise evaluate expression and print number
00107Er 2  20 rr rr       jsr BasExpr
001081r 2  20 rr rr       jsr BasPrintInt
001084r 2  4C rr rr       jmp @PrintSep
001087r 2               
001087r 2               @PrintString:
001087r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00108Ar 2               @PrintStrCh:
00108Ar 2  20 rr rr       jsr BasGetTokChar
00108Dr 2  D0 03          bne :+
00108Fr 2  4C rr rr       jmp @PrintEnd                  ; Unterminated string
001092r 2  C9 22        : cmp #CH_QUOTE
001094r 2  F0 08          beq @PrintStrEnd
001096r 2  20 rr rr       jsr Chrout
001099r 2  20 rr rr       jsr BasAdvTxtPtr
00109Cr 2  80 EC          bra @PrintStrCh
00109Er 2               @PrintStrEnd:
00109Er 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
0010A1r 2  4C rr rr       jmp @PrintSep
0010A4r 2               
0010A4r 2               @PrintChr:
0010A4r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_CHR
0010A7r 2  A9 28          lda #CH_LPAREN
0010A9r 2  20 rr rr       jsr BasExpectChar
0010ACr 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
0010AFr 2  A9 29          lda #CH_RPAREN
0010B1r 2  20 rr rr       jsr BasExpectChar
0010B4r 2  A5 0A          lda BAS_ACC                    ; Output low byte as character
0010B6r 2  20 rr rr       jsr VideoChroutRaw             ; Raw output — no control-code interception
0010B9r 2  4C rr rr       jmp @PrintSep
0010BCr 2               
0010BCr 2               @PrintTab:
0010BCr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_TAB
0010BFr 2  A9 28          lda #CH_LPAREN
0010C1r 2  20 rr rr       jsr BasExpectChar
0010C4r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
0010C7r 2  A9 29          lda #CH_RPAREN
0010C9r 2  20 rr rr       jsr BasExpectChar
0010CCr 2               @TabLoop:
0010CCr 2  AD 07 03       lda VID_CURSOR_X               ; Current column
0010CFr 2  C5 0A          cmp BAS_ACC                    ; Already at or past target?
0010D1r 2  B0 40          bcs @PrintSep                  ; Yes — done
0010D3r 2  A9 20          lda #CH_SPACE
0010D5r 2  20 rr rr       jsr Chrout
0010D8r 2  80 F2          bra @TabLoop
0010DAr 2               
0010DAr 2               @PrintHex:
0010DAr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_HEX
0010DDr 2  A9 28          lda #CH_LPAREN
0010DFr 2  20 rr rr       jsr BasExpectChar
0010E2r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
0010E5r 2  A9 29          lda #CH_RPAREN
0010E7r 2  20 rr rr       jsr BasExpectChar
0010EAr 2  A9 24          lda #'$'
0010ECr 2  20 rr rr       jsr Chrout                     ; Output '$' prefix
0010EFr 2  A5 0B          lda BAS_ACC + 1                ; High byte first
0010F1r 2  20 rr rr       jsr @HexOutByte
0010F4r 2  A5 0A          lda BAS_ACC                    ; Low byte
0010F6r 2  20 rr rr       jsr @HexOutByte
0010F9r 2  80 18          bra @PrintSep
0010FBr 2               
0010FBr 2               @HexOutByte:
0010FBr 2                 ; Output byte in A as two hex digits
0010FBr 2  48             pha
0010FCr 2  4A             lsr
0010FDr 2  4A             lsr
0010FEr 2  4A             lsr
0010FFr 2  4A             lsr                            ; High nibble
001100r 2  20 rr rr       jsr @HexOutNibble
001103r 2  68             pla
001104r 2  29 0F          and #$0F                       ; Low nibble
001106r 2               @HexOutNibble:
001106r 2  C9 0A          cmp #$0A
001108r 2  90 04          bcc @HexDigit
00110Ar 2  69 36          adc #('A' - $0A - 1)          ; Carry is set from cmp
00110Cr 2  80 02          bra @HexPrint
00110Er 2               @HexDigit:
00110Er 2  09 30          ora #'0'
001110r 2               @HexPrint:
001110r 2  4C rr rr       jmp Chrout                     ; Output and return
001113r 2               
001113r 2               @PrintSep:
001113r 2  20 rr rr       jsr BasSkipSpaces
001116r 2  20 rr rr       jsr BasGetTokChar
001119r 2  C9 3B          cmp #CH_SEMICOL
00111Br 2  F0 06          beq @PrintSemicolon
00111Dr 2  C9 2C          cmp #CH_COMMA
00111Fr 2  F0 14          beq @PrintComma
001121r 2                 ; No separator — done, print newline
001121r 2  80 20          bra @PrintNewline
001123r 2               
001123r 2               @PrintSemicolon:
001123r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ';'
001126r 2                 ; Check if end of statement (suppress newline)
001126r 2  20 rr rr       jsr BasSkipSpaces
001129r 2  20 rr rr       jsr BasGetTokChar
00112Cr 2  F0 18          beq @PrintDone                 ; End of line — suppress newline
00112Er 2  C9 3A          cmp #CH_COLON
001130r 2  F0 14          beq @PrintDone                 ; Colon — suppress newline
001132r 2  4C rr rr       jmp @PrintLoop
001135r 2               
001135r 2               @PrintComma:
001135r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
001138r 2                 ; Print separator spaces
001138r 2  A9 20          lda #CH_SPACE
00113Ar 2  20 rr rr       jsr Chrout
00113Dr 2  20 rr rr       jsr Chrout
001140r 2  4C rr rr       jmp @PrintLoop
001143r 2               
001143r 2               @PrintNewline:
001143r 2  20 rr rr       jsr BasPrintCRLF
001146r 2               @PrintDone:
001146r 2               @PrintEnd:
001146r 2  60             rts
001147r 2               
001147r 2               ; --- INPUT ---
001147r 2               BasCmdInput:
001147r 2  20 rr rr       jsr BasSkipSpaces
00114Ar 2  20 rr rr       jsr BasGetTokChar
00114Dr 2               
00114Dr 2                 ; Check for optional prompt string
00114Dr 2  C9 22          cmp #CH_QUOTE
00114Fr 2  D0 3B          bne @InputNoPrompt
001151r 2               
001151r 2                 ; Print prompt string
001151r 2  20 rr rr       jsr BasAdvTxtPtr
001154r 2               @InputPromptCh:
001154r 2  20 rr rr       jsr BasGetTokChar
001157r 2  F0 0F          beq @InputPromptDone
001159r 2  C9 22          cmp #CH_QUOTE
00115Br 2  F0 08          beq @InputPromptEnd
00115Dr 2  20 rr rr       jsr Chrout
001160r 2  20 rr rr       jsr BasAdvTxtPtr
001163r 2  80 EF          bra @InputPromptCh
001165r 2               @InputPromptEnd:
001165r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
001168r 2               @InputPromptDone:
001168r 2                 ; Expect semicolon or comma after prompt
001168r 2  20 rr rr       jsr BasSkipSpaces
00116Br 2  20 rr rr       jsr BasGetTokChar
00116Er 2  C9 3B          cmp #CH_SEMICOL
001170r 2  F0 06          beq @InputSemiSep
001172r 2  C9 2C          cmp #CH_COMMA
001174r 2  F0 11          beq @InputCommaSep
001176r 2  80 1E          bra @InputGetVar
001178r 2               
001178r 2               @InputSemiSep:
001178r 2  20 rr rr       jsr BasAdvTxtPtr
00117Br 2                 ; Print "? " after semicolon-style prompt
00117Br 2  A9 3F          lda #'?'
00117Dr 2  20 rr rr       jsr Chrout
001180r 2  A9 20          lda #CH_SPACE
001182r 2  20 rr rr       jsr Chrout
001185r 2  80 0F          bra @InputGetVar
001187r 2               
001187r 2               @InputCommaSep:
001187r 2  20 rr rr       jsr BasAdvTxtPtr
00118Ar 2                 ; No "? " with comma separator
00118Ar 2  80 0A          bra @InputGetVar
00118Cr 2               
00118Cr 2               @InputNoPrompt:
00118Cr 2                 ; Print default "? " prompt
00118Cr 2  A9 3F          lda #'?'
00118Er 2  20 rr rr       jsr Chrout
001191r 2  A9 20          lda #CH_SPACE
001193r 2  20 rr rr       jsr Chrout
001196r 2               
001196r 2               @InputGetVar:
001196r 2  20 rr rr       jsr BasSkipSpaces
