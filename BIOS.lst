0008F3r 2  85 0D          sta BAS_AUX + 1
0008F5r 2  68             pla
0008F6r 2  85 0C          sta BAS_AUX
0008F8r 2  20 rr rr       jsr BasMathSub
0008FBr 2  4C rr rr       jmp @AddLoop
0008FEr 2               
0008FEr 2               ; BasExprMul — Handle *, /, MOD
0008FEr 2               BasExprMul:
0008FEr 2  20 rr rr       jsr BasExprUnary
000901r 2               @MulLoop:
000901r 2  20 rr rr       jsr BasSkipSpaces
000904r 2  20 rr rr       jsr BasGetTokChar
000907r 2  C9 2A          cmp #CH_STAR
