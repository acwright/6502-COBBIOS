001867r 2               ; ============================================================================
001867r 2               ; READ var[,var,...] — Read values from DATA statements
001867r 2               ; ============================================================================
001867r 2               
001867r 2               BasCmdRead:
001867r 2               @ReadLoop:
001867r 2                 ; Ensure DATA pointer is initialized
001867r 2  AD 1A 03       lda BAS_DATAPTR
00186Ar 2  0D 1B 03       ora BAS_DATAPTR + 1
00186Dr 2  D0 05          bne @ReadHaveData
