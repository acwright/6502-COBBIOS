000AE5r 2  F0 11          beq @FlagsDone
000AE7r 2  06 34          asl MON_BYTE                  ; Shift next flag bit into carry
000AE9r 2  B0 04          bcs @FlagSet
000AEBr 2  A9 2D          lda #'-'                      ; Flag clear — print dash
000AEDr 2  80 03          bra @FlagPrint
000AEFr 2               @FlagSet:
000AEFr 2                 ; A already has the flag character
000AEFr 2  BD rr rr       lda MonFlagChars,x
000AF2r 2               @FlagPrint:
000AF2r 2  20 rr rr       jsr Chrout
000AF5r 2  E8             inx
000AF6r 2  80 EA          bra @FlagLoop
000AF8r 2               @FlagsDone:
000AF8r 2  20 rr rr       jsr MonPrintCRLF
000AFBr 2  60             rts
000AFCr 2               
000AFCr 2               MonFlagChars:
000AFCr 2  4E 56 2D 42    .byte "NV-BDIZC", 0
000B00r 2  44 49 5A 43  
000B04r 2  00           
000B05r 2               
000B05r 2               ; ============================================================================
000B05r 2               ; Hex Parsing Utilities
000B05r 2               ; ============================================================================
000B05r 2               
000B05r 2               ; MonParseHex4 — Parse up to 4 hex digits from MON_LINBUF into MON_ADDR
000B05r 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B05r 2               ; Output: MON_ADDR/MON_ADDR+1 = parsed 16-bit value, carry set if valid
000B05r 2               ;         MON_IDX advanced past parsed digits
000B05r 2               
000B05r 2               MonParseHex4:
000B05r 2  64 2E          stz MON_ADDR
000B07r 2  64 2F          stz MON_ADDR + 1
000B09r 2  A2 00          ldx #0                        ; Digit count
000B0Br 2               @ParseLoop:
000B0Br 2  A4 35          ldy MON_IDX
000B0Dr 2  B9 00 04       lda MON_LINBUF,y
000B10r 2  20 rr rr       jsr MonCharToNibble           ; Convert ASCII to 0-15, carry clear if valid
000B13r 2  B0 1B          bcs @ParseDone                ; Not a hex digit — stop
000B15r 2                 ; Shift result left 4 bits and OR in new nibble
000B15r 2  06 2E          asl MON_ADDR
000B17r 2  26 2F          rol MON_ADDR + 1
000B19r 2  06 2E          asl MON_ADDR
000B1Br 2  26 2F          rol MON_ADDR + 1
000B1Dr 2  06 2E          asl MON_ADDR
000B1Fr 2  26 2F          rol MON_ADDR + 1
000B21r 2  06 2E          asl MON_ADDR
000B23r 2  26 2F          rol MON_ADDR + 1
000B25r 2  05 2E          ora MON_ADDR
000B27r 2  85 2E          sta MON_ADDR
000B29r 2  E6 35          inc MON_IDX
000B2Br 2  E8             inx
000B2Cr 2  E0 04          cpx #4                        ; Max 4 digits
000B2Er 2  90 DB          bcc @ParseLoop
000B30r 2               @ParseDone:
000B30r 2  E0 00          cpx #0                        ; Did we parse at least one digit?
000B32r 2  F0 02          beq @ParseFail
000B34r 2  38             sec                           ; Success
000B35r 2  60             rts
000B36r 2               @ParseFail:
000B36r 2  18             clc                           ; Failure — no digits parsed
000B37r 2  60             rts
000B38r 2               
000B38r 2               ; MonParseHex2 — Parse up to 2 hex digits from MON_LINBUF into A
000B38r 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B38r 2               ; Output: A = parsed 8-bit value, carry set if valid
000B38r 2               ;         MON_IDX advanced past parsed digits
000B38r 2               
000B38r 2               MonParseHex2:
000B38r 2  64 34          stz MON_BYTE
000B3Ar 2  A2 00          ldx #0                        ; Digit count
000B3Cr 2               @ParseLoop:
000B3Cr 2  A4 35          ldy MON_IDX
000B3Er 2  B9 00 04       lda MON_LINBUF,y
000B41r 2  20 rr rr       jsr MonCharToNibble
000B44r 2  B0 13          bcs @ParseDone
000B46r 2  06 34          asl MON_BYTE
000B48r 2  06 34          asl MON_BYTE
000B4Ar 2  06 34          asl MON_BYTE
000B4Cr 2  06 34          asl MON_BYTE
000B4Er 2  05 34          ora MON_BYTE
000B50r 2  85 34          sta MON_BYTE
000B52r 2  E6 35          inc MON_IDX
000B54r 2  E8             inx
000B55r 2  E0 02          cpx #2
000B57r 2  90 E3          bcc @ParseLoop
000B59r 2               @ParseDone:
000B59r 2  E0 00          cpx #0
000B5Br 2  F0 04          beq @ParseFail
000B5Dr 2  A5 34          lda MON_BYTE
000B5Fr 2  38             sec
000B60r 2  60             rts
000B61r 2               @ParseFail:
000B61r 2  18             clc
000B62r 2  60             rts
000B63r 2               
000B63r 2               ; MonCharToNibble — Convert ASCII hex char in A to nibble value 0-15
000B63r 2               ; Input:  A = ASCII character
000B63r 2               ; Output: A = 0-15 if valid hex digit, carry clear
000B63r 2               ;         carry set if not a valid hex digit (A preserved)
000B63r 2               
000B63r 2               MonCharToNibble:
000B63r 2  C9 30          cmp #'0'
000B65r 2  90 23          bcc @NotHex
000B67r 2  C9 3A          cmp #'9'+1
000B69r 2  90 15          bcc @IsDigit
000B6Br 2  C9 41          cmp #'A'
000B6Dr 2  90 04          bcc @CheckLower
000B6Fr 2  C9 47          cmp #'F'+1
000B71r 2  90 12          bcc @IsUpper
000B73r 2               @CheckLower:
000B73r 2  C9 61          cmp #'a'
000B75r 2  90 13          bcc @NotHex
000B77r 2  C9 67          cmp #'f'+1
000B79r 2  B0 0F          bcs @NotHex
000B7Br 2                 ; Lowercase a-f
000B7Br 2  38             sec
000B7Cr 2  E9 57          sbc #('a' - 10)
000B7Er 2  18             clc
000B7Fr 2  60             rts
000B80r 2               @IsDigit:
000B80r 2  38             sec
000B81r 2  E9 30          sbc #'0'
000B83r 2  18             clc
000B84r 2  60             rts
000B85r 2               @IsUpper:
000B85r 2  38             sec
000B86r 2  E9 37          sbc #('A' - 10)
000B88r 2  18             clc
000B89r 2  60             rts
000B8Ar 2               @NotHex:
000B8Ar 2  38             sec
000B8Br 2  60             rts
000B8Cr 2               
000B8Cr 2               ; MonSkipSpaces — Advance MON_IDX past whitespace in MON_LINBUF
000B8Cr 2               
000B8Cr 2               MonSkipSpaces:
000B8Cr 2  A4 35          ldy MON_IDX
000B8Er 2  B9 00 04       lda MON_LINBUF,y
000B91r 2  C9 20          cmp #' '
000B93r 2  D0 04          bne @Done
000B95r 2  E6 35          inc MON_IDX
000B97r 2  80 F3          bra MonSkipSpaces
000B99r 2               @Done:
000B99r 2  60             rts
000B9Ar 2               
000B9Ar 2               ; ============================================================================
000B9Ar 2               ; Decimal & Binary Parsing Utilities
000B9Ar 2               ; ============================================================================
000B9Ar 2               
000B9Ar 2               ; MonParseDec16 — Parse decimal digits from MON_LINBUF into MON_ADDR
000B9Ar 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B9Ar 2               ; Output: MON_ADDR = parsed 16-bit value, carry set if valid
000B9Ar 2               ;         MON_IDX advanced past parsed digits
000B9Ar 2               ; Modifies: A, X, Y, MON_ADDR, MON_TMP
000B9Ar 2               
000B9Ar 2               MonParseDec16:
000B9Ar 2  64 2E          stz MON_ADDR
000B9Cr 2  64 2F          stz MON_ADDR+1
000B9Er 2  A2 00          ldx #0                        ; Digit count
000BA0r 2               @DecLoop:
000BA0r 2  A4 35          ldy MON_IDX
000BA2r 2  B9 00 04       lda MON_LINBUF,y
000BA5r 2  C9 30          cmp #'0'
000BA7r 2  90 3A          bcc @DecDone
000BA9r 2  C9 3A          cmp #'9'+1
000BABr 2  B0 36          bcs @DecDone
000BADr 2  38             sec
000BAEr 2  E9 30          sbc #'0'                      ; A = digit 0-9
000BB0r 2  48             pha                           ; Save digit
000BB1r 2                 ; MON_ADDR = MON_ADDR * 10 + digit
000BB1r 2                 ; *10 = (*2 + *8): save *2, then *8, add
000BB1r 2  06 2E          asl MON_ADDR
000BB3r 2  26 2F          rol MON_ADDR+1
000BB5r 2  A5 2E          lda MON_ADDR
000BB7r 2  85 32          sta MON_TMP
000BB9r 2  A5 2F          lda MON_ADDR+1
000BBBr 2  85 33          sta MON_TMP+1                 ; MON_TMP = *2
000BBDr 2  06 2E          asl MON_ADDR
000BBFr 2  26 2F          rol MON_ADDR+1                ; *4
000BC1r 2  06 2E          asl MON_ADDR
000BC3r 2  26 2F          rol MON_ADDR+1                ; *8
000BC5r 2  18             clc
000BC6r 2  A5 2E          lda MON_ADDR
000BC8r 2  65 32          adc MON_TMP
000BCAr 2  85 2E          sta MON_ADDR
000BCCr 2  A5 2F          lda MON_ADDR+1
000BCEr 2  65 33          adc MON_TMP+1
000BD0r 2  85 2F          sta MON_ADDR+1                ; *10
000BD2r 2                 ; + digit
000BD2r 2  68             pla
000BD3r 2  18             clc
000BD4r 2  65 2E          adc MON_ADDR
000BD6r 2  85 2E          sta MON_ADDR
000BD8r 2  90 02          bcc @DecNoCarry
000BDAr 2  E6 2F          inc MON_ADDR+1
000BDCr 2               @DecNoCarry:
000BDCr 2  E6 35          inc MON_IDX
000BDEr 2  E8             inx
000BDFr 2  E0 05          cpx #5                        ; Max 5 digits (65535)
000BE1r 2  90 BD          bcc @DecLoop
000BE3r 2               @DecDone:
000BE3r 2  E0 00          cpx #0
000BE5r 2  F0 02          beq @DecFail
000BE7r 2  38             sec                           ; Success
000BE8r 2  60             rts
000BE9r 2               @DecFail:
000BE9r 2  18             clc                           ; Failure
000BEAr 2  60             rts
000BEBr 2               
000BEBr 2               ; MonParseBin16 — Parse binary digits from MON_LINBUF into MON_ADDR
000BEBr 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000BEBr 2               ; Output: MON_ADDR = parsed 16-bit value, carry set if valid
000BEBr 2               ;         MON_IDX advanced past parsed digits
000BEBr 2               ; Modifies: A, X, Y, MON_ADDR
000BEBr 2               
000BEBr 2               MonParseBin16:
000BEBr 2  64 2E          stz MON_ADDR
000BEDr 2  64 2F          stz MON_ADDR+1
000BEFr 2  A2 00          ldx #0                        ; Digit count
000BF1r 2               @BinLoop:
000BF1r 2  A4 35          ldy MON_IDX
000BF3r 2  B9 00 04       lda MON_LINBUF,y
000BF6r 2  C9 30          cmp #'0'
000BF8r 2  F0 06          beq @BinGot
000BFAr 2  C9 31          cmp #'1'
000BFCr 2  F0 02          beq @BinGot
000BFEr 2  80 0F          bra @BinDone
000C00r 2               @BinGot:
000C00r 2  38             sec
000C01r 2  E9 30          sbc #'0'                      ; A = 0 or 1
000C03r 2  4A             lsr a                         ; Bit into carry
000C04r 2  26 2E          rol MON_ADDR
000C06r 2  26 2F          rol MON_ADDR+1
000C08r 2  E6 35          inc MON_IDX
000C0Ar 2  E8             inx
000C0Br 2  E0 10          cpx #16                       ; Max 16 bits
000C0Dr 2  90 E2          bcc @BinLoop
000C0Fr 2               @BinDone:
000C0Fr 2  E0 00          cpx #0
000C11r 2  F0 02          beq @BinFail
000C13r 2  38             sec                           ; Success
000C14r 2  60             rts
000C15r 2               @BinFail:
000C15r 2  18             clc                           ; Failure
000C16r 2  60             rts
000C17r 2               
000C17r 2               ; ============================================================================
000C17r 2               ; Decimal & Binary Output Utilities
000C17r 2               ; ============================================================================
000C17r 2               
000C17r 2               ; MonPrintDec16 — Print MON_ADDR as up to 5 decimal digits
000C17r 2               ; Uses successive subtraction of powers of 10
000C17r 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000C17r 2               
000C17r 2               MonPrintDec16:
000C17r 2                 ; Copy value to MON_TMP so we don't destroy MON_ADDR
000C17r 2  A5 2E          lda MON_ADDR
000C19r 2  85 32          sta MON_TMP
000C1Br 2  A5 2F          lda MON_ADDR+1
000C1Dr 2  85 33          sta MON_TMP+1
000C1Fr 2  A2 00          ldx #0                        ; Leading zero suppression flag
000C21r 2  A0 00          ldy #0                        ; Power-of-10 index
000C23r 2               @Dec16Loop:
000C23r 2  A9 2F          lda #'0'-1
000C25r 2  85 34          sta MON_BYTE                  ; Digit scratch
000C27r 2               @Dec16Sub:
000C27r 2  E6 34          inc MON_BYTE
000C29r 2  A5 32          lda MON_TMP
000C2Br 2  38             sec
000C2Cr 2  F9 rr rr       sbc @Dec16Pow10Lo,y
000C2Fr 2  48             pha
000C30r 2  A5 33          lda MON_TMP+1
000C32r 2  F9 rr rr       sbc @Dec16Pow10Hi,y
000C35r 2  90 07          bcc @Dec16Digit               ; Underflow — digit done
000C37r 2  85 33          sta MON_TMP+1
000C39r 2  68             pla
000C3Ar 2  85 32          sta MON_TMP
000C3Cr 2  80 E9          bra @Dec16Sub
000C3Er 2               @Dec16Digit:
000C3Er 2  68             pla                           ; Discard underflowed low byte
000C3Fr 2  A5 34          lda MON_BYTE
000C41r 2  C9 30          cmp #'0'
000C43r 2  D0 04          bne @Dec16Print               ; Non-zero → print
000C45r 2  E0 00          cpx #0
000C47r 2  F0 08          beq @Dec16Skip                ; Leading zero → skip
000C49r 2               @Dec16Print:
000C49r 2  DA             phx
000C4Ar 2  5A             phy
000C4Br 2  20 rr rr       jsr Chrout
000C4Er 2  7A             ply
000C4Fr 2  FA             plx
000C50r 2  E8             inx                           ; Mark we've printed a digit
000C51r 2               @Dec16Skip:
000C51r 2  C8             iny
000C52r 2  C0 04          cpy #4                        ; 4 powers: 10000, 1000, 100, 10
000C54r 2  D0 CD          bne @Dec16Loop
000C56r 2                 ; Always print ones digit
000C56r 2  A5 32          lda MON_TMP
000C58r 2  09 30          ora #'0'
000C5Ar 2  20 rr rr       jsr Chrout
000C5Dr 2  60             rts
000C5Er 2  10 E8 64 0A  @Dec16Pow10Lo: .byte <10000, <1000, <100, <10
000C62r 2  27 03 00 00  @Dec16Pow10Hi: .byte >10000, >1000, >100, >10
000C66r 2               
000C66r 2               ; MonPrintBin16 — Print MON_ADDR as 16 binary digits (MSB first)
000C66r 2               ; Modifies: A, X
000C66r 2               
000C66r 2               MonPrintBin16:
000C66r 2  A5 2F          lda MON_ADDR+1                ; High byte first
000C68r 2  20 rr rr       jsr @PrintBin8
000C6Br 2  A5 2E          lda MON_ADDR                  ; Then low byte
000C6Dr 2               @PrintBin8:
000C6Dr 2  A2 08          ldx #8
000C6Fr 2               @BinBitLoop:
000C6Fr 2  0A             asl a                         ; Shift MSB into carry
000C70r 2  48             pha
000C71r 2  A9 30          lda #'0'
000C73r 2  69 00          adc #0                        ; +1 if carry → '1'
000C75r 2  20 rr rr       jsr Chrout
000C78r 2  68             pla
000C79r 2  CA             dex
000C7Ar 2  D0 F3          bne @BinBitLoop
000C7Cr 2  60             rts
000C7Dr 2               
000C7Dr 2               ; ============================================================================
000C7Dr 2               ; Message Print Helpers (Phase 5)
000C7Dr 2               ; ============================================================================
000C7Dr 2               
000C7Dr 2               ; MonPrintLoaded — Print "LOADED nnnn BYTES AT $xxxx"
000C7Dr 2               ; Input: MON_ADDR = byte count, MON_END = load address
000C7Dr 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000C7Dr 2               
000C7Dr 2               MonPrintLoaded:
000C7Dr 2  A2 00          ldx #0
000C7Fr 2               @PLoop1:
000C7Fr 2  BD rr rr       lda MonStrLoadPfx,x
000C82r 2  F0 06          beq @PDone1
000C84r 2  20 rr rr       jsr Chrout
000C87r 2  E8             inx
000C88r 2  80 F5          bra @PLoop1
000C8Ar 2               @PDone1:
000C8Ar 2  20 rr rr       jsr MonPrintDec16             ; Print byte count from MON_ADDR
000C8Dr 2  A2 00          ldx #0
000C8Fr 2               @PLoop2:
000C8Fr 2  BD rr rr       lda MonStrBytesAt,x
000C92r 2  F0 06          beq @PDone2
000C94r 2  20 rr rr       jsr Chrout
000C97r 2  E8             inx
000C98r 2  80 F5          bra @PLoop2
000C9Ar 2               @PDone2:
000C9Ar 2                 ; Print address from MON_END
000C9Ar 2  A5 30          lda MON_END
000C9Cr 2  85 2E          sta MON_ADDR
000C9Er 2  A5 31          lda MON_END+1
000CA0r 2  85 2F          sta MON_ADDR+1
000CA2r 2  20 rr rr       jsr MonPrintHex4
000CA5r 2  4C rr rr       jmp MonPrintCRLF
000CA8r 2               
000CA8r 2               ; MonPrintSaved — Print "SAVED nnnn BYTES"
000CA8r 2               ; Input: MON_ADDR = byte count
000CA8r 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000CA8r 2               
000CA8r 2               MonPrintSaved:
000CA8r 2  A2 00          ldx #0
000CAAr 2               @SLoop1:
000CAAr 2  BD rr rr       lda MonStrSavePfx,x
000CADr 2  F0 06          beq @SDone1
000CAFr 2  20 rr rr       jsr Chrout
000CB2r 2  E8             inx
000CB3r 2  80 F5          bra @SLoop1
000CB5r 2               @SDone1:
000CB5r 2  20 rr rr       jsr MonPrintDec16             ; Print byte count from MON_ADDR
000CB8r 2  A2 00          ldx #0
000CBAr 2               @SLoop2:
000CBAr 2  BD rr rr       lda MonStrBytes,x
000CBDr 2  F0 06          beq @SDone2
000CBFr 2  20 rr rr       jsr Chrout
000CC2r 2  E8             inx
000CC3r 2  80 F5          bra @SLoop2
000CC5r 2               @SDone2:
000CC5r 2  4C rr rr       jmp MonPrintCRLF
000CC8r 2               
000CC8r 2               ; MonPrintIOErr — Print "I/O ERROR"
000CC8r 2               ; Modifies: A, X
000CC8r 2               
000CC8r 2               MonPrintIOErr:
000CC8r 2  A2 00          ldx #0
000CCAr 2               @ELoop:
000CCAr 2  BD rr rr       lda MonStrIOErr,x
000CCDr 2  F0 06          beq @EDone
000CCFr 2  20 rr rr       jsr Chrout
000CD2r 2  E8             inx
000CD3r 2  80 F5          bra @ELoop
000CD5r 2               @EDone:
000CD5r 2  4C rr rr       jmp MonPrintCRLF
000CD8r 2               
000CD8r 2               ; ============================================================================
000CD8r 2               ; Hex Output Utilities
000CD8r 2               ; ============================================================================
000CD8r 2               
000CD8r 2               ; MonPrintHex2 — Print A as two hex digits
000CD8r 2               ; Input:  A = byte to print
000CD8r 2               ; Modifies: A, flags
000CD8r 2               
000CD8r 2               MonPrintHex2:
000CD8r 2  48             pha                           ; Save original byte
000CD9r 2  4A             lsr                           ; Shift high nibble down
000CDAr 2  4A             lsr
000CDBr 2  4A             lsr
000CDCr 2  4A             lsr
000CDDr 2  20 rr rr       jsr @PrintNibble              ; Print high nibble
000CE0r 2  68             pla                           ; Restore original byte
000CE1r 2  29 0F          and #$0F                      ; Isolate low nibble
000CE3r 2               @PrintNibble:
000CE3r 2  C9 0A          cmp #10
000CE5r 2  90 06          bcc @IsDigit
000CE7r 2  18             clc
000CE8r 2  69 37          adc #('A' - 10)
000CEAr 2  4C rr rr       jmp Chrout
000CEDr 2               @IsDigit:
000CEDr 2  18             clc
000CEEr 2  69 30          adc #'0'
000CF0r 2  4C rr rr       jmp Chrout
000CF3r 2               
000CF3r 2               ; MonPrintHex4 — Print MON_ADDR as four hex digits
000CF3r 2               ; Input:  MON_ADDR, MON_ADDR+1 = 16-bit value
000CF3r 2               ; Modifies: A, flags
000CF3r 2               
000CF3r 2               MonPrintHex4:
000CF3r 2  A5 2F          lda MON_ADDR + 1              ; High byte first
000CF5r 2  20 rr rr       jsr MonPrintHex2
000CF8r 2  A5 2E          lda MON_ADDR                  ; Then low byte
000CFAr 2  4C rr rr       jmp MonPrintHex2
000CFDr 2               
000CFDr 2               ; MonPrintSpace — Print a space character
000CFDr 2               
000CFDr 2               MonPrintSpace:
000CFDr 2  A9 20          lda #' '
000CFFr 2  4C rr rr       jmp Chrout
000D02r 2               
000D02r 2               ; MonPrintCRLF — Print carriage return + line feed
000D02r 2               
000D02r 2               MonPrintCRLF:
000D02r 2  A9 0D          lda #$0D
000D04r 2  20 rr rr       jsr Chrout
000D07r 2  A9 0A          lda #$0A
000D09r 2  4C rr rr       jmp Chrout
000D0Cr 2               
000D0Cr 2               ; MonPrintError — Print "?" for unrecognized command
000D0Cr 2               
000D0Cr 2               MonPrintError:
000D0Cr 2  A9 3F          lda #'?'
000D0Er 2  20 rr rr       jsr Chrout
000D11r 2  4C rr rr       jmp MonPrintCRLF
000D14r 2               
000D14r 2               ; MonPrintBanner — Print the monitor banner string
000D14r 2               
000D14r 2               MonPrintBanner:
000D14r 2  A2 00          ldx #0
000D16r 2               @Loop:
000D16r 2  BD rr rr       lda MonStrBanner,x
000D19r 2  F0 06          beq @Done
000D1Br 2  20 rr rr       jsr Chrout
000D1Er 2  E8             inx
000D1Fr 2  80 F5          bra @Loop
000D21r 2               @Done:
000D21r 2  60             rts
000D22r 2               
000D22r 2               ; ============================================================================
000D22r 2               ; String Data
000D22r 2               ; ============================================================================
000D22r 2               
000D22r 2               MonStrBanner:
000D22r 2  36 35 30 32    .byte "6502 MONITOR v1.0", $0D, $0A, 0
000D26r 2  20 4D 4F 4E  
000D2Ar 2  49 54 4F 52  
000D36r 2               MonStrBrk:
000D36r 2  42 52 4B 20    .byte "BRK AT $", 0
000D3Ar 2  41 54 20 24  
000D3Er 2  00           
000D3Fr 2               MonStrNotFound:
000D3Fr 2  46 49 4C 45    .byte "FILE NOT FOUND", 0
000D43r 2  20 4E 4F 54  
000D47r 2  20 46 4F 55  
000D4Er 2               MonStrDirFull:
000D4Er 2  44 49 52 45    .byte "DIRECTORY FULL", 0
000D52r 2  43 54 4F 52  
000D56r 2  59 20 46 55  
000D5Dr 2               MonStrLoadPfx:
000D5Dr 2  4C 4F 41 44    .byte "LOADED ", 0
000D61r 2  45 44 20 00  
000D65r 2               MonStrSavePfx:
000D65r 2  53 41 56 45    .byte "SAVED ", 0
000D69r 2  44 20 00     
000D6Cr 2               MonStrBytesAt:
000D6Cr 2  20 42 59 54    .byte " BYTES AT $", 0
000D70r 2  45 53 20 41  
000D74r 2  54 20 24 00  
000D78r 2               MonStrBytes:
000D78r 2  20 42 59 54    .byte " BYTES", 0
000D7Cr 2  45 53 00     
000D7Fr 2               MonStrIOErr:
000D7Fr 2  49 2F 4F 20    .byte "I/O ERROR", 0
000D83r 2  45 52 52 4F  
