000000r 2               RAM_DATA_H          := $8400             ; R/W ($8400-$87FE)
000000r 2               RAM_BANK_H          := $87FF             ; Write-only RAM bank latch, value ($00-$FF) sets which of 256 ~1K banks of RAM is selected
