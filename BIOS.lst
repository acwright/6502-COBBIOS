000911r 2  F0 31          beq @DoMod
000913r 2  60             rts
000914r 2               
000914r 2               @DoMul:
000914r 2  20 rr rr       jsr BasAdvTxtPtr
000917r 2  A5 0A          lda BAS_ACC
000919r 2  48             pha
00091Ar 2  A5 0B          lda BAS_ACC + 1
00091Cr 2  48             pha
00091Dr 2  20 rr rr       jsr BasExprUnary
