001871r 2  D0 05          bne @ReadHaveData
001873r 2  20 rr rr       jsr BasDataFindFirst           ; Find first DATA line (errors if none)
001876r 2  80 0C          bra @ReadDataOk
001878r 2               
001878r 2               @ReadHaveData:
001878r 2                 ; Check for exhausted DATA sentinel ($FFFF)
001878r 2  AD 1B 03       lda BAS_DATAPTR + 1
00187Br 2  C9 FF          cmp #$FF
00187Dr 2  D0 05          bne @ReadDataOk
00187Fr 2  A9 0A          lda #ERR_OUT_OF_DATA
001881r 2  4C rr rr       jmp BasError
001884r 2               
001884r 2               @ReadDataOk:
001884r 2                 ; Parse variable name (A-Z)
001884r 2  20 rr rr       jsr BasSkipSpaces
001887r 2  20 rr rr       jsr BasGetTokChar
00188Ar 2  C9 41          cmp #'A'
00188Cr 2  90 6A          bcc @ReadSyntax
00188Er 2  C9 5B          cmp #'Z' + 1
001890r 2  B0 66          bcs @ReadSyntax
001892r 2               
001892r 2                 ; Compute variable offset and advance past variable letter
001892r 2  38             sec
001893r 2  E9 41          sbc #'A'
001895r 2  0A             asl                            ; ×2 for 16-bit vars
001896r 2  48             pha                            ; Save var offset on stack
001897r 2  20 rr rr       jsr BasAdvTxtPtr
00189Ar 2               
00189Ar 2                 ; Save current TXTPTR on stack
00189Ar 2  A5 05          lda BAS_TXTPTR + 1
00189Cr 2  48             pha
00189Dr 2  A5 04          lda BAS_TXTPTR
00189Fr 2  48             pha
0018A0r 2               
0018A0r 2                 ; Switch TXTPTR to DATA read position
0018A0r 2  AD 1A 03       lda BAS_DATAPTR
0018A3r 2  85 04          sta BAS_TXTPTR
0018A5r 2  AD 1B 03       lda BAS_DATAPTR + 1
0018A8r 2  85 05          sta BAS_TXTPTR + 1
