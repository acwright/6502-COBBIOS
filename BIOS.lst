001E89r 2  0D 0A 3F 4C  BasStrLoadErr:  .byte CH_CR, CH_LF, "?LOAD ERROR", CH_CR, CH_LF, $00
001E8Dr 2  4F 41 44 20  
001E91r 2  45 52 52 4F  
