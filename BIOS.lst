000C7Dr 2  80 28          bra @ExecCheckMore
000C7Fr 2               @JmpTime:
000C7Fr 2  20 rr rr       jsr BasAdvTxtPtr
000C82r 2  20 rr rr       jsr BasCmdTime
000C85r 2  80 20          bra @ExecCheckMore
000C87r 2               @JmpDate:
000C87r 2  20 rr rr       jsr BasAdvTxtPtr
000C8Ar 2  20 rr rr       jsr BasCmdDate
000C8Dr 2  80 18          bra @ExecCheckMore
000C8Fr 2               @JmpWait:
000C8Fr 2  20 rr rr       jsr BasAdvTxtPtr
000C92r 2  20 rr rr       jsr BasCmdWait
000C95r 2  80 10          bra @ExecCheckMore
000C97r 2               @JmpPause:
000C97r 2  20 rr rr       jsr BasAdvTxtPtr
000C9Ar 2  20 rr rr       jsr BasCmdPause
000C9Dr 2  80 08          bra @ExecCheckMore
000C9Fr 2               @JmpBank:
000C9Fr 2  20 rr rr       jsr BasAdvTxtPtr
000CA2r 2  20 rr rr       jsr BasCmdBank
000CA5r 2  80 00          bra @ExecCheckMore
000CA7r 2               
000CA7r 2               @ExecCheckMore:
000CA7r 2                 ; Check for ':' statement separator
000CA7r 2  20 rr rr       jsr BasSkipSpaces
000CAAr 2  20 rr rr       jsr BasGetTokChar
000CADr 2  C9 3A          cmp #CH_COLON
000CAFr 2  D0 06          bne @ExecDone
000CB1r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ':'
000CB4r 2  4C rr rr       jmp BasExecLine                ; Execute next statement
000CB7r 2               @ExecDone:
000CB7r 2  60             rts
000CB8r 2               
000CB8r 2               ; ============================================================================
000CB8r 2               ; RUN — Execute program from first line
000CB8r 2               ; ============================================================================
000CB8r 2               
000CB8r 2               BasCmdRun:
000CB8r 2  20 rr rr       jsr BasCmdClr
000CBBr 2  A9 01          lda #BAS_FLAG_RUN
000CBDr 2  85 17          sta BAS_FLAGS
000CBFr 2               
000CBFr 2                 ; Start at first program line
000CBFr 2  A9 00          lda #<BAS_PRG_START
000CC1r 2  85 06          sta BAS_CURLINE
000CC3r 2  A9 08          lda #>BAS_PRG_START
000CC5r 2  85 07          sta BAS_CURLINE + 1
000CC7r 2               
000CC7r 2               BasRunLoop:
000CC7r 2                 ; Check if at end of program (CURLINE == PRGEND)
000CC7r 2  A5 06          lda BAS_CURLINE
000CC9r 2  C5 12          cmp BAS_PRGEND
000CCBr 2  D0 06          bne @RunNotEnd
000CCDr 2  A5 07          lda BAS_CURLINE + 1
000CCFr 2  C5 13          cmp BAS_PRGEND + 1
000CD1r 2  F0 51          beq BasRunDone
000CD3r 2               @RunNotEnd:
000CD3r 2               
000CD3r 2                 ; Check for Ctrl+C break
000CD3r 2  20 rr rr       jsr BasCheckBreak
000CD6r 2               
000CD6r 2                 ; Get line number
000CD6r 2  A0 02          ldy #LINE_NUM
000CD8r 2  B1 06          lda (BAS_CURLINE),y
000CDAr 2  85 08          sta BAS_LINENUM
000CDCr 2  C8             iny
000CDDr 2  B1 06          lda (BAS_CURLINE),y
000CDFr 2  85 09          sta BAS_LINENUM + 1
000CE1r 2               
000CE1r 2                 ; Save CURLINE before execution for GOTO/GOSUB detection
000CE1r 2  A5 06          lda BAS_CURLINE
000CE3r 2  85 14          sta BAS_VARPTR
000CE5r 2  A5 07          lda BAS_CURLINE + 1
000CE7r 2  85 15          sta BAS_VARPTR + 1
000CE9r 2               
000CE9r 2                 ; Set TXTPTR to payload
000CE9r 2  18             clc
000CEAr 2  A5 06          lda BAS_CURLINE
000CECr 2  69 04          adc #LINE_PAYLOAD
000CEEr 2  85 04          sta BAS_TXTPTR
000CF0r 2  A5 07          lda BAS_CURLINE + 1
000CF2r 2  69 00          adc #$00
000CF4r 2  85 05          sta BAS_TXTPTR + 1
000CF6r 2               
000CF6r 2                 ; Execute the line
000CF6r 2  20 rr rr       jsr BasExecLine
000CF9r 2               
000CF9r 2                 ; Check if END was executed (flags cleared)
000CF9r 2  A5 17          lda BAS_FLAGS
000CFBr 2  29 01          and #BAS_FLAG_RUN
000CFDr 2  F0 25          beq BasRunDone
000CFFr 2               
000CFFr 2                 ; Check if GOTO/GOSUB changed CURLINE
000CFFr 2  A5 06          lda BAS_CURLINE
000D01r 2  C5 14          cmp BAS_VARPTR
000D03r 2  D0 C2          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
000D05r 2  A5 07          lda BAS_CURLINE + 1
000D07r 2  C5 15          cmp BAS_VARPTR + 1
000D09r 2  D0 BC          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
000D0Br 2               
000D0Br 2                 ; Advance to next line by scanning for end of current line
000D0Br 2  A0 04          ldy #LINE_PAYLOAD
000D0Dr 2               @RunScanNull:
000D0Dr 2  B1 06          lda (BAS_CURLINE),y
000D0Fr 2  F0 03          beq @RunFoundNull
000D11r 2  C8             iny
000D12r 2  80 F9          bra @RunScanNull
000D14r 2               @RunFoundNull:
000D14r 2  C8             iny                            ; Past null terminator
000D15r 2  98             tya
000D16r 2  18             clc
000D17r 2  65 06          adc BAS_CURLINE
000D19r 2  85 06          sta BAS_CURLINE
000D1Br 2  A9 00          lda #$00
000D1Dr 2  65 07          adc BAS_CURLINE + 1
000D1Fr 2  85 07          sta BAS_CURLINE + 1
000D21r 2  4C rr rr       jmp BasRunLoop
000D24r 2               
000D24r 2               BasRunDone:
000D24r 2  64 17          stz BAS_FLAGS
000D26r 2  60             rts
000D27r 2               
000D27r 2               ; ============================================================================
000D27r 2               ; Statement Handlers
000D27r 2               ; ============================================================================
000D27r 2               
000D27r 2               ; --- PRINT ---
000D27r 2               BasCmdPrint:
000D27r 2  20 rr rr       jsr BasSkipSpaces
000D2Ar 2  20 rr rr       jsr BasGetTokChar
000D2Dr 2  F0 61          beq @PrintNewline              ; Empty PRINT — just newline
000D2Fr 2  C9 3A          cmp #CH_COLON
000D31r 2  F0 5D          beq @PrintNewline              ; PRINT: — newline then next statement
000D33r 2               
000D33r 2               @PrintLoop:
000D33r 2  20 rr rr       jsr BasSkipSpaces
000D36r 2  20 rr rr       jsr BasGetTokChar
000D39r 2  F0 58          beq @PrintEnd                  ; End of line
000D3Br 2  C9 3A          cmp #CH_COLON
000D3Dr 2  F0 54          beq @PrintEnd
000D3Fr 2               
000D3Fr 2                 ; String literal?
000D3Fr 2  C9 22          cmp #CH_QUOTE
000D41r 2  F0 08          beq @PrintString
000D43r 2               
000D43r 2                 ; Otherwise evaluate expression and print number
000D43r 2  20 rr rr       jsr BasExpr
000D46r 2  20 rr rr       jsr BasPrintInt
000D49r 2  80 17          bra @PrintSep
000D4Br 2               
000D4Br 2               @PrintString:
000D4Br 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
000D4Er 2               @PrintStrCh:
000D4Er 2  20 rr rr       jsr BasGetTokChar
000D51r 2  F0 40          beq @PrintEnd                  ; Unterminated string
000D53r 2  C9 22          cmp #CH_QUOTE
000D55r 2  F0 08          beq @PrintStrEnd
000D57r 2  20 rr rr       jsr Chrout
000D5Ar 2  20 rr rr       jsr BasAdvTxtPtr
000D5Dr 2  80 EF          bra @PrintStrCh
000D5Fr 2               @PrintStrEnd:
000D5Fr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
000D62r 2               
000D62r 2               @PrintSep:
000D62r 2  20 rr rr       jsr BasSkipSpaces
000D65r 2  20 rr rr       jsr BasGetTokChar
000D68r 2  C9 3B          cmp #CH_SEMICOL
000D6Ar 2  F0 06          beq @PrintSemicolon
000D6Cr 2  C9 2C          cmp #CH_COMMA
000D6Er 2  F0 13          beq @PrintComma
000D70r 2                 ; No separator — done, print newline
000D70r 2  80 1E          bra @PrintNewline
000D72r 2               
000D72r 2               @PrintSemicolon:
000D72r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ';'
000D75r 2                 ; Check if end of statement (suppress newline)
000D75r 2  20 rr rr       jsr BasSkipSpaces
000D78r 2  20 rr rr       jsr BasGetTokChar
000D7Br 2  F0 16          beq @PrintDone                 ; End of line — suppress newline
000D7Dr 2  C9 3A          cmp #CH_COLON
000D7Fr 2  F0 12          beq @PrintDone                 ; Colon — suppress newline
000D81r 2  80 B0          bra @PrintLoop
000D83r 2               
000D83r 2               @PrintComma:
000D83r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
000D86r 2                 ; Print separator spaces
000D86r 2  A9 20          lda #CH_SPACE
000D88r 2  20 rr rr       jsr Chrout
000D8Br 2  20 rr rr       jsr Chrout
000D8Er 2  80 A3          bra @PrintLoop
000D90r 2               
000D90r 2               @PrintNewline:
000D90r 2  20 rr rr       jsr BasPrintCRLF
000D93r 2               @PrintDone:
000D93r 2               @PrintEnd:
000D93r 2  60             rts
000D94r 2               
000D94r 2               ; --- INPUT ---
000D94r 2               BasCmdInput:
000D94r 2  20 rr rr       jsr BasSkipSpaces
000D97r 2  20 rr rr       jsr BasGetTokChar
000D9Ar 2               
000D9Ar 2                 ; Check for optional prompt string
000D9Ar 2  C9 22          cmp #CH_QUOTE
000D9Cr 2  D0 3B          bne @InputNoPrompt
000D9Er 2               
000D9Er 2                 ; Print prompt string
000D9Er 2  20 rr rr       jsr BasAdvTxtPtr
000DA1r 2               @InputPromptCh:
000DA1r 2  20 rr rr       jsr BasGetTokChar
000DA4r 2  F0 0F          beq @InputPromptDone
000DA6r 2  C9 22          cmp #CH_QUOTE
000DA8r 2  F0 08          beq @InputPromptEnd
000DAAr 2  20 rr rr       jsr Chrout
000DADr 2  20 rr rr       jsr BasAdvTxtPtr
000DB0r 2  80 EF          bra @InputPromptCh
000DB2r 2               @InputPromptEnd:
000DB2r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
000DB5r 2               @InputPromptDone:
000DB5r 2                 ; Expect semicolon or comma after prompt
000DB5r 2  20 rr rr       jsr BasSkipSpaces
000DB8r 2  20 rr rr       jsr BasGetTokChar
000DBBr 2  C9 3B          cmp #CH_SEMICOL
000DBDr 2  F0 06          beq @InputSemiSep
000DBFr 2  C9 2C          cmp #CH_COMMA
000DC1r 2  F0 11          beq @InputCommaSep
000DC3r 2  80 1E          bra @InputGetVar
000DC5r 2               
000DC5r 2               @InputSemiSep:
000DC5r 2  20 rr rr       jsr BasAdvTxtPtr
000DC8r 2                 ; Print "? " after semicolon-style prompt
000DC8r 2  A9 3F          lda #'?'
000DCAr 2  20 rr rr       jsr Chrout
000DCDr 2  A9 20          lda #CH_SPACE
000DCFr 2  20 rr rr       jsr Chrout
000DD2r 2  80 0F          bra @InputGetVar
000DD4r 2               
000DD4r 2               @InputCommaSep:
000DD4r 2  20 rr rr       jsr BasAdvTxtPtr
000DD7r 2                 ; No "? " with comma separator
000DD7r 2  80 0A          bra @InputGetVar
000DD9r 2               
000DD9r 2               @InputNoPrompt:
000DD9r 2                 ; Print default "? " prompt
000DD9r 2  A9 3F          lda #'?'
000DDBr 2  20 rr rr       jsr Chrout
000DDEr 2  A9 20          lda #CH_SPACE
000DE0r 2  20 rr rr       jsr Chrout
000DE3r 2               
000DE3r 2               @InputGetVar:
000DE3r 2  20 rr rr       jsr BasSkipSpaces
000DE6r 2  20 rr rr       jsr BasGetTokChar
000DE9r 2               
000DE9r 2                 ; Must be a variable A-Z
000DE9r 2  C9 41          cmp #'A'
000DEBr 2  90 5D          bcc @InputErr
000DEDr 2  C9 5B          cmp #'Z' + 1
000DEFr 2  B0 59          bcs @InputErr
000DF1r 2               
000DF1r 2                 ; Save variable index
000DF1r 2  38             sec
000DF2r 2  E9 41          sbc #'A'
000DF4r 2  0A             asl
000DF5r 2  85 21          sta BAS_TEMP                   ; Variable offset
000DF7r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000DFAr 2               
000DFAr 2                 ; Save TXTPTR (points into tokenized program line)
000DFAr 2  A5 04          lda BAS_TXTPTR
000DFCr 2  48             pha
000DFDr 2  A5 05          lda BAS_TXTPTR + 1
000DFFr 2  48             pha
000E00r 2               
000E00r 2               @InputRetry:
000E00r 2                 ; Read a line of input
000E00r 2  20 rr rr       jsr BasReadLine
000E03r 2               
000E03r 2                 ; Point TXTPTR at input buffer for parsing
000E03r 2  A9 34          lda #<BAS_LINBUF
000E05r 2  85 04          sta BAS_TXTPTR
000E07r 2  A9 04          lda #>BAS_LINBUF
000E09r 2  85 05          sta BAS_TXTPTR + 1
000E0Br 2               
000E0Br 2                 ; Handle optional negative sign
000E0Br 2  64 20          stz BAS_SIGN
000E0Dr 2  20 rr rr       jsr BasSkipSpaces
000E10r 2  20 rr rr       jsr BasGetTokChar
000E13r 2  C9 2D          cmp #CH_MINUS
000E15r 2  D0 07          bne @InputParse
000E17r 2  A9 FF          lda #$FF
000E19r 2  85 20          sta BAS_SIGN
000E1Br 2  20 rr rr       jsr BasAdvTxtPtr
000E1Er 2               
000E1Er 2               @InputParse:
000E1Er 2  20 rr rr       jsr BasParseInt
000E21r 2  B0 1A          bcs @InputBadNum               ; No digits found
000E23r 2               
000E23r 2                 ; Negate if minus was present
000E23r 2  A5 20          lda BAS_SIGN
000E25r 2  F0 03          beq @InputStore
000E27r 2  20 rr rr       jsr BasMathNeg
000E2Ar 2               
000E2Ar 2               @InputStore:
000E2Ar 2                 ; Store in variable
000E2Ar 2  A6 21          ldx BAS_TEMP
000E2Cr 2  A5 0A          lda BAS_ACC
000E2Er 2  9D 00 04       sta BAS_VARS,x
000E31r 2  A5 0B          lda BAS_ACC + 1
000E33r 2  9D 01 04       sta BAS_VARS + 1,x
000E36r 2               
000E36r 2                 ; Restore TXTPTR to tokenized program line
000E36r 2  68             pla
000E37r 2  85 05          sta BAS_TXTPTR + 1
000E39r 2  68             pla
000E3Ar 2  85 04          sta BAS_TXTPTR
000E3Cr 2  60             rts
000E3Dr 2               
000E3Dr 2               @InputBadNum:
000E3Dr 2  A9 rr          lda #<BasStrRedo
000E3Fr 2  85 0E          sta BAS_TMP1
000E41r 2  A9 rr          lda #>BasStrRedo
000E43r 2  85 0F          sta BAS_TMP1 + 1
000E45r 2  20 rr rr       jsr BasPrintStr
000E48r 2  80 B6          bra @InputRetry
000E4Ar 2               
000E4Ar 2               @InputErr:
000E4Ar 2  A9 00          lda #ERR_SYNTAX
000E4Cr 2  4C rr rr       jmp BasError
000E4Fr 2               
000E4Fr 2               ; --- LET (also implicit assignment) ---
000E4Fr 2               BasCmdLet:
000E4Fr 2  20 rr rr       jsr BasSkipSpaces
000E52r 2  20 rr rr       jsr BasGetTokChar
000E55r 2               
000E55r 2                 ; Must be a variable A-Z
000E55r 2  C9 41          cmp #'A'
000E57r 2  90 25          bcc @LetErr
000E59r 2  C9 5B          cmp #'Z' + 1
000E5Br 2  B0 21          bcs @LetErr
000E5Dr 2               
000E5Dr 2  38             sec
000E5Er 2  E9 41          sbc #'A'
000E60r 2  0A             asl
000E61r 2  85 21          sta BAS_TEMP                   ; Variable offset
000E63r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000E66r 2               
000E66r 2  20 rr rr       jsr BasSkipSpaces
000E69r 2  A9 3D          lda #CH_EQUALS
000E6Br 2  20 rr rr       jsr BasExpectChar              ; Expect '='
000E6Er 2               
000E6Er 2  20 rr rr       jsr BasExpr                    ; Evaluate RHS
000E71r 2               
000E71r 2                 ; Store result in variable
000E71r 2  A6 21          ldx BAS_TEMP
000E73r 2  A5 0A          lda BAS_ACC
000E75r 2  9D 00 04       sta BAS_VARS,x
000E78r 2  A5 0B          lda BAS_ACC + 1
000E7Ar 2  9D 01 04       sta BAS_VARS + 1,x
000E7Dr 2  60             rts
000E7Er 2               
000E7Er 2               @LetErr:
000E7Er 2  A9 00          lda #ERR_SYNTAX
000E80r 2  4C rr rr       jmp BasError
000E83r 2               
000E83r 2               ; --- GOTO ---
000E83r 2               BasCmdGoto:
000E83r 2  20 rr rr       jsr BasExpr                    ; Evaluate target line number
000E86r 2  A5 0A          lda BAS_ACC
000E88r 2  85 08          sta BAS_LINENUM
000E8Ar 2  A5 0B          lda BAS_ACC + 1
000E8Cr 2  85 09          sta BAS_LINENUM + 1
000E8Er 2  20 rr rr       jsr BasFindLine
000E91r 2  90 09          bcc @GotoErr
000E93r 2               
000E93r 2                 ; Set CURLINE to the found line — run loop will detect the change
000E93r 2  A5 0E          lda BAS_TMP1
000E95r 2  85 06          sta BAS_CURLINE
000E97r 2  A5 0F          lda BAS_TMP1 + 1
000E99r 2  85 07          sta BAS_CURLINE + 1
000E9Br 2  60             rts
000E9Cr 2               
000E9Cr 2               @GotoErr:
000E9Cr 2  A9 01          lda #ERR_UNDEF_LINE
000E9Er 2  4C rr rr       jmp BasError
000EA1r 2               
000EA1r 2               ; --- GOSUB ---
000EA1r 2               BasCmdGosub:
000EA1r 2                 ; Push current CURLINE onto GOSUB stack (2 bytes per entry)
000EA1r 2  A6 1A          ldx BAS_GOSUBSP
000EA3r 2  8A             txa
000EA4r 2  18             clc
000EA5r 2  69 02          adc #BAS_GOSUB_ENTRY
000EA7r 2  C9 81          cmp #BAS_GOSUBSTK_SIZE + 1
000EA9r 2  B0 13          bcs @GosubFull
000EABr 2               
000EABr 2  A5 06          lda BAS_CURLINE
000EADr 2  9D 00 05       sta BAS_GOSUBSTK,x
000EB0r 2  A5 07          lda BAS_CURLINE + 1
000EB2r 2  9D 01 05       sta BAS_GOSUBSTK + 1,x
000EB5r 2  8A             txa
000EB6r 2  18             clc
000EB7r 2  69 02          adc #BAS_GOSUB_ENTRY
000EB9r 2  85 1A          sta BAS_GOSUBSP
000EBBr 2               
000EBBr 2                 ; Now do GOTO (sets CURLINE to target)
000EBBr 2  4C rr rr       jmp BasCmdGoto
000EBEr 2               
000EBEr 2               @GosubFull:
000EBEr 2  A9 03          lda #ERR_OUT_OF_MEM
000EC0r 2  4C rr rr       jmp BasError
000EC3r 2               
000EC3r 2               ; --- RETURN ---
000EC3r 2               BasCmdReturn:
000EC3r 2  A6 1A          ldx BAS_GOSUBSP
000EC5r 2  F0 25          beq @RetErr
000EC7r 2               
000EC7r 2                 ; Pop CURLINE from GOSUB stack
000EC7r 2  CA             dex
000EC8r 2  CA             dex
000EC9r 2  BD 00 05       lda BAS_GOSUBSTK,x
000ECCr 2  85 06          sta BAS_CURLINE
000ECEr 2  BD 01 05       lda BAS_GOSUBSTK + 1,x
000ED1r 2  85 07          sta BAS_CURLINE + 1
000ED3r 2  86 1A          stx BAS_GOSUBSP
000ED5r 2               
000ED5r 2                 ; Advance CURLINE to the line AFTER the GOSUB line
000ED5r 2                 ; so the run loop continues from there
000ED5r 2  A0 04          ldy #LINE_PAYLOAD
000ED7r 2               @RetScan:
000ED7r 2  B1 06          lda (BAS_CURLINE),y
000ED9r 2  F0 03          beq @RetScanDone
000EDBr 2  C8             iny
000EDCr 2  80 F9          bra @RetScan
000EDEr 2               @RetScanDone:
000EDEr 2  C8             iny                            ; Past null
000EDFr 2  98             tya
000EE0r 2  18             clc
000EE1r 2  65 06          adc BAS_CURLINE
000EE3r 2  85 06          sta BAS_CURLINE
000EE5r 2  A9 00          lda #$00
000EE7r 2  65 07          adc BAS_CURLINE + 1
000EE9r 2  85 07          sta BAS_CURLINE + 1
000EEBr 2                 ; CURLINE now differs from saved VARPTR, so run loop re-executes
000EEBr 2  60             rts
000EECr 2               
000EECr 2               @RetErr:
000EECr 2  A9 04          lda #ERR_RET_NO_GOSUB
000EEEr 2  4C rr rr       jmp BasError
000EF1r 2               
000EF1r 2               ; --- IF...THEN ---
000EF1r 2               BasCmdIf:
000EF1r 2  20 rr rr       jsr BasExpr                    ; Evaluate condition
000EF4r 2  20 rr rr       jsr BasSkipSpaces
000EF7r 2               
000EF7r 2                 ; Expect THEN
000EF7r 2  20 rr rr       jsr BasGetTokChar
000EFAr 2  C9 87          cmp #TOK_THEN
000EFCr 2  D0 1E          bne @IfSyntax
000EFEr 2  20 rr rr       jsr BasAdvTxtPtr
000F01r 2               
000F01r 2                 ; Check condition: 0 = false, nonzero = true
000F01r 2  A5 0A          lda BAS_ACC
000F03r 2  05 0B          ora BAS_ACC + 1
000F05r 2  F0 14          beq @IfFalse
000F07r 2               
000F07r 2                 ; True — check if THEN is followed by a line number (implicit GOTO)
000F07r 2  20 rr rr       jsr BasSkipSpaces
000F0Ar 2  20 rr rr       jsr BasGetTokChar
000F0Dr 2  C9 30          cmp #'0'
000F0Fr 2  90 07          bcc @IfExecRest
000F11r 2  C9 3A          cmp #'9' + 1
000F13r 2  B0 03          bcs @IfExecRest
000F15r 2                 ; It's a digit — treat as GOTO line number
000F15r 2  4C rr rr       jmp BasCmdGoto
000F18r 2               
000F18r 2               @IfExecRest:
000F18r 2                 ; Execute rest of line as statement(s)
000F18r 2  4C rr rr       jmp BasExecLine
000F1Br 2               
000F1Br 2               @IfFalse:
000F1Br 2                 ; Skip rest of line (don't execute THEN clause)
000F1Br 2  60             rts
000F1Cr 2               
000F1Cr 2               @IfSyntax:
000F1Cr 2  A9 00          lda #ERR_SYNTAX
000F1Er 2  4C rr rr       jmp BasError
000F21r 2               
000F21r 2               ; --- FOR ---
000F21r 2               BasCmdFor:
000F21r 2  20 rr rr       jsr BasSkipSpaces
000F24r 2  20 rr rr       jsr BasGetTokChar
000F27r 2               
000F27r 2                 ; Must be a variable
000F27r 2  C9 41          cmp #'A'
000F29r 2  B0 03          bcs @ForVarOk1
000F2Br 2  4C rr rr       jmp @ForErr
000F2Er 2               @ForVarOk1:
000F2Er 2  C9 5B          cmp #'Z' + 1
000F30r 2  90 03          bcc @ForVarOk2
000F32r 2  4C rr rr       jmp @ForErr
000F35r 2               @ForVarOk2:
000F35r 2               
000F35r 2  38             sec
000F36r 2  E9 41          sbc #'A'
000F38r 2  0A             asl
000F39r 2  85 21          sta BAS_TEMP                   ; Variable offset
000F3Br 2  20 rr rr       jsr BasAdvTxtPtr
000F3Er 2               
000F3Er 2                 ; Expect '='
000F3Er 2  20 rr rr       jsr BasSkipSpaces
000F41r 2  A9 3D          lda #CH_EQUALS
000F43r 2  20 rr rr       jsr BasExpectChar
000F46r 2               
000F46r 2                 ; Evaluate initial value and store in variable
000F46r 2  20 rr rr       jsr BasExpr
000F49r 2  A6 21          ldx BAS_TEMP
000F4Br 2  A5 0A          lda BAS_ACC
000F4Dr 2  9D 00 04       sta BAS_VARS,x
000F50r 2  A5 0B          lda BAS_ACC + 1
000F52r 2  9D 01 04       sta BAS_VARS + 1,x
000F55r 2               
000F55r 2                 ; Expect TO
000F55r 2  20 rr rr       jsr BasSkipSpaces
000F58r 2  20 rr rr       jsr BasGetTokChar
000F5Br 2  C9 89          cmp #TOK_TO
000F5Dr 2  D0 75          bne @ForErr
000F5Fr 2  20 rr rr       jsr BasAdvTxtPtr
000F62r 2               
000F62r 2                 ; Evaluate limit — store temporarily in SCRATCH
000F62r 2  20 rr rr       jsr BasExpr
000F65r 2  A5 0A          lda BAS_ACC
000F67r 2  85 1C          sta BAS_SCRATCH
000F69r 2  A5 0B          lda BAS_ACC + 1
000F6Br 2  85 1D          sta BAS_SCRATCH + 1
000F6Dr 2               
000F6Dr 2                 ; Check for optional STEP — default is 1
000F6Dr 2  A9 01          lda #$01
000F6Fr 2  85 1E          sta BAS_SCRATCH2
000F71r 2  64 1F          stz BAS_SCRATCH2 + 1
000F73r 2               
000F73r 2  20 rr rr       jsr BasSkipSpaces
000F76r 2  20 rr rr       jsr BasGetTokChar
000F79r 2  C9 8A          cmp #TOK_STEP
000F7Br 2  D0 0E          bne @ForNoStep
000F7Dr 2  20 rr rr       jsr BasAdvTxtPtr
000F80r 2  20 rr rr       jsr BasExpr
000F83r 2  A5 0A          lda BAS_ACC
000F85r 2  85 1E          sta BAS_SCRATCH2
000F87r 2  A5 0B          lda BAS_ACC + 1
000F89r 2  85 1F          sta BAS_SCRATCH2 + 1
000F8Br 2               @ForNoStep:
000F8Br 2               
000F8Br 2                 ; Check room on FOR stack
000F8Br 2  A6 1B          ldx BAS_FORSP
000F8Dr 2  8A             txa
000F8Er 2  18             clc
000F8Fr 2  69 10          adc #BAS_FOR_ENTRY
000F91r 2  C9 81          cmp #BAS_FORSTK_SIZE + 1
000F93r 2  B0 3A          bcs @ForStackFull
000F95r 2               
000F95r 2                 ; Build FOR stack entry (16 bytes per entry):
000F95r 2                 ;  +0: var_offset (1)
000F95r 2                 ;  +1: limit_lo (1)
000F95r 2                 ;  +2: limit_hi (1)
000F95r 2                 ;  +3: step_lo (1)
000F95r 2                 ;  +4: step_hi (1)
000F95r 2                 ;  +5: body_start_lo (1) — first line of loop body (next line after FOR)
000F95r 2                 ;  +6: body_start_hi (1)
000F95r 2                 ; +7..+15: unused padding
000F95r 2               
000F95r 2  A5 21          lda BAS_TEMP
000F97r 2  9D 80 05       sta BAS_FORSTK,x               ; +0: var offset
000F9Ar 2  A5 1C          lda BAS_SCRATCH
000F9Cr 2  9D 81 05       sta BAS_FORSTK + 1,x           ; +1: limit lo
000F9Fr 2  A5 1D          lda BAS_SCRATCH + 1
000FA1r 2  9D 82 05       sta BAS_FORSTK + 2,x           ; +2: limit hi
000FA4r 2  A5 1E          lda BAS_SCRATCH2
000FA6r 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo
000FA9r 2  A5 1F          lda BAS_SCRATCH2 + 1
000FABr 2  9D 84 05       sta BAS_FORSTK + 4,x           ; +4: step hi
000FAEr 2                 ; body_start = next line after the FOR line (scan for null)
000FAEr 2  A0 04          ldy #LINE_PAYLOAD
000FB0r 2               @ForScanBody:
000FB0r 2  B1 06          lda (BAS_CURLINE),y
000FB2r 2  F0 03          beq @ForScanDone
000FB4r 2  C8             iny
000FB5r 2  80 F9          bra @ForScanBody
000FB7r 2               @ForScanDone:
000FB7r 2  C8             iny                            ; Past null terminator
000FB8r 2  98             tya
000FB9r 2  18             clc
000FBAr 2  65 06          adc BAS_CURLINE
000FBCr 2  48             pha
000FBDr 2  A9 00          lda #$00
000FBFr 2  65 07          adc BAS_CURLINE + 1
000FC1r 2  9D 86 05       sta BAS_FORSTK + 6,x           ; +6: body_start hi
000FC4r 2  68             pla
000FC5r 2  9D 85 05       sta BAS_FORSTK + 5,x           ; +5: body_start lo
000FC8r 2               
000FC8r 2  8A             txa
000FC9r 2  18             clc
000FCAr 2  69 10          adc #BAS_FOR_ENTRY
000FCCr 2  85 1B          sta BAS_FORSP
000FCEr 2  60             rts
000FCFr 2               
000FCFr 2               @ForStackFull:
000FCFr 2  A9 03          lda #ERR_OUT_OF_MEM
000FD1r 2  4C rr rr       jmp BasError
000FD4r 2               
000FD4r 2               @ForErr:
000FD4r 2  A9 00          lda #ERR_SYNTAX
000FD6r 2  4C rr rr       jmp BasError
000FD9r 2               
000FD9r 2               ; --- NEXT ---
000FD9r 2               BasCmdNext:
000FD9r 2  20 rr rr       jsr BasSkipSpaces
000FDCr 2  20 rr rr       jsr BasGetTokChar
000FDFr 2               
000FDFr 2                 ; Must be a variable
000FDFr 2  C9 41          cmp #'A'
000FE1r 2  B0 03          bcs @NextVarOk1
000FE3r 2  4C rr rr       jmp @NextErr
000FE6r 2               @NextVarOk1:
000FE6r 2  C9 5B          cmp #'Z' + 1
000FE8r 2  90 03          bcc @NextVarOk2
000FEAr 2  4C rr rr       jmp @NextErr
000FEDr 2               @NextVarOk2:
000FEDr 2               
000FEDr 2  38             sec
000FEEr 2  E9 41          sbc #'A'
000FF0r 2  0A             asl
000FF1r 2  85 21          sta BAS_TEMP                   ; Variable offset
000FF3r 2  20 rr rr       jsr BasAdvTxtPtr
000FF6r 2               
000FF6r 2                 ; Search FOR stack from top for matching variable
000FF6r 2  A6 1B          ldx BAS_FORSP
000FF8r 2  F0 63          beq @NextNoFor
000FFAr 2               
000FFAr 2               @NextSearch:
000FFAr 2  CA             dex                            ; Back up past padding and entries
000FFBr 2  8A             txa
000FFCr 2  38             sec
000FFDr 2  E9 0F          sbc #BAS_FOR_ENTRY - 1         ; Point to start of this entry
000FFFr 2  AA             tax
001000r 2  30 5B          bmi @NextNoFor
001002r 2  BD 80 05       lda BAS_FORSTK,x               ; var_offset
001005r 2  C5 21          cmp BAS_TEMP
001007r 2  F0 02          beq @NextFound
001009r 2                 ; Not this entry — keep searching
001009r 2  80 EF          bra @NextSearch
00100Br 2               
00100Br 2               @NextFound:
00100Br 2                 ; Add step to variable
00100Br 2  BD 83 05       lda BAS_FORSTK + 3,x           ; step lo
00100Er 2  85 0C          sta BAS_AUX
001010r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
001013r 2  85 0D          sta BAS_AUX + 1
001015r 2               
001015r 2  A4 21          ldy BAS_TEMP                   ; var offset
001017r 2  18             clc
001018r 2  B9 00 04       lda BAS_VARS,y
00101Br 2  65 0C          adc BAS_AUX
00101Dr 2  99 00 04       sta BAS_VARS,y
001020r 2  85 0A          sta BAS_ACC
001022r 2  B9 01 04       lda BAS_VARS + 1,y
001025r 2  65 0D          adc BAS_AUX + 1
001027r 2  99 01 04       sta BAS_VARS + 1,y
00102Ar 2  85 0B          sta BAS_ACC + 1
00102Cr 2               
00102Cr 2                 ; Load limit into AUX for comparison
00102Cr 2  BD 81 05       lda BAS_FORSTK + 1,x           ; limit lo
00102Fr 2  85 0C          sta BAS_AUX
001031r 2  BD 82 05       lda BAS_FORSTK + 2,x           ; limit hi
001034r 2  85 0D          sta BAS_AUX + 1
001036r 2               
001036r 2                 ; Check if loop is done:
001036r 2                 ; If step > 0: done when var > limit (AUX)
001036r 2                 ; If step < 0: done when var < limit (AUX)
001036r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
001039r 2  30 07          bmi @NextStepNeg
00103Br 2               
00103Br 2                 ; Step positive: compare var (ACC) vs limit (AUX)
00103Br 2                 ; Done if ACC > AUX (i.e., AUX < ACC)
00103Br 2  20 rr rr       jsr BasCmpAuxAcc
00103Er 2  30 1A          bmi @NextDone                  ; AUX < ACC means var > limit
001040r 2  80 07          bra @NextLoop                  ; Continue loop
001042r 2               
001042r 2               @NextStepNeg:
001042r 2                 ; Step negative: done if var < limit
001042r 2                 ; Done if ACC < AUX (i.e., AUX > ACC)
001042r 2  20 rr rr       jsr BasCmpAuxAcc
001045r 2  F0 02          beq @NextLoop
001047r 2  10 11          bpl @NextDone                  ; AUX > ACC means var < limit
001049r 2               
001049r 2               @NextLoop:
001049r 2                 ; Continue loop — set CURLINE to body start
001049r 2                 ; Keep the FOR entry on the stack (FORSP stays where it is)
001049r 2  BD 85 05       lda BAS_FORSTK + 5,x           ; body_start lo
00104Cr 2  85 06          sta BAS_CURLINE
00104Er 2  BD 86 05       lda BAS_FORSTK + 6,x           ; body_start hi
001051r 2  85 07          sta BAS_CURLINE + 1
001053r 2                 ; Invalidate saved CURLINE so run loop always detects the change,
001053r 2                 ; even when body_start == current line (empty loop body / NEXT on next line)
001053r 2  A9 FF          lda #$FF
001055r 2  85 14          sta BAS_VARPTR
001057r 2  85 15          sta BAS_VARPTR + 1
001059r 2  60             rts
00105Ar 2               
00105Ar 2               @NextDone:
00105Ar 2                 ; Loop complete — remove this FOR entry from stack
00105Ar 2  86 1B          stx BAS_FORSP                  ; Pop down to this entry (removes it)
00105Cr 2  60             rts
00105Dr 2               
00105Dr 2               @NextNoFor:
00105Dr 2               @NextErr:
00105Dr 2  A9 05          lda #ERR_NEXT_NO_FOR
00105Fr 2  4C rr rr       jmp BasError
001062r 2               
001062r 2               ; --- END ---
001062r 2               BasCmdEnd:
001062r 2  64 17          stz BAS_FLAGS                  ; Clear run flag
001064r 2  60             rts                            ; Returns to BasRunLoop which checks flags
001065r 2               
001065r 2               ; --- SYS ---
001065r 2               ; SYS <address> — Call machine code at 16-bit address, RTS returns to BASIC
001065r 2               BasCmdSys:
001065r 2  20 rr rr       jsr BasExpr                    ; Evaluate address expression → BAS_ACC
001068r 2                 ; Use BAS_TMP2 as the indirect jump target
001068r 2  A5 0A          lda BAS_ACC
00106Ar 2  85 10          sta BAS_TMP2
00106Cr 2  A5 0B          lda BAS_ACC + 1
00106Er 2  85 11          sta BAS_TMP2 + 1
001070r 2  6C 10 00       jmp (BAS_TMP2)                 ; JSR-like: callee RTSes back to caller
001073r 2               
001073r 2               ; --- LOAD ---
001073r 2               ; LOAD "filename" — Load from CF filesystem
001073r 2               ; LOAD (no arg)   — Load via serial ASCII transfer
001073r 2               BasCmdLoad:
001073r 2  20 rr rr       jsr BasSkipSpaces
001076r 2  20 rr rr       jsr BasGetTokChar
001079r 2  C9 22          cmp #CH_QUOTE
00107Br 2  F0 18          beq @LoadCF
00107Dr 2               
00107Dr 2                 ; No filename — serial ASCII load
00107Dr 2  AD 0D 03       lda HW_PRESENT
001080r 2  29 10          and #HW_SC
001082r 2  F0 0E          beq @LoadNoDev
001084r 2  20 rr rr       jsr AsciiLoad
001087r 2  B0 4A          bcs @LoadErr
001089r 2                 ; Update BAS_PRGEND from XFER_PTR (points past last byte written)
001089r 2  A5 2A          lda XFER_PTR
00108Br 2  85 12          sta BAS_PRGEND
00108Dr 2  A5 2B          lda XFER_PTR + 1
00108Fr 2  85 13          sta BAS_PRGEND + 1
001091r 2  60             rts
001092r 2               
001092r 2               @LoadNoDev:
001092r 2  4C rr rr       jmp BasPrintNoDevice
001095r 2               
001095r 2               @LoadCF:
001095r 2  AD 0D 03       lda HW_PRESENT
001098r 2  29 08          and #HW_CF
00109Ar 2  F0 F6          beq @LoadNoDev
00109Cr 2                 ; Parse quoted filename into STR_PTR for FsLoadFile
00109Cr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00109Fr 2                 ; Point STR_PTR at current position in tokenized text
00109Fr 2  A5 04          lda BAS_TXTPTR
0010A1r 2  85 02          sta STR_PTR
0010A3r 2  A5 05          lda BAS_TXTPTR + 1
0010A5r 2  85 03          sta STR_PTR + 1
0010A7r 2                 ; Advance TXTPTR past the filename to closing quote
0010A7r 2               @LoadScanName:
0010A7r 2  20 rr rr       jsr BasGetTokChar
0010AAr 2  F0 12          beq @LoadNameDone              ; End of line (unterminated — use what we have)
0010ACr 2  C9 22          cmp #CH_QUOTE
0010AEr 2  F0 05          beq @LoadNameEnd
0010B0r 2  20 rr rr       jsr BasAdvTxtPtr
0010B3r 2  80 F2          bra @LoadScanName
0010B5r 2               @LoadNameEnd:
0010B5r 2                 ; Null-terminate the filename in the token buffer (overwrite closing quote)
0010B5r 2  A0 00          ldy #$00
0010B7r 2  A9 00          lda #$00
0010B9r 2  91 04          sta (BAS_TXTPTR),y
0010BBr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
0010BEr 2               @LoadNameDone:
0010BEr 2                 ; Call filesystem load
0010BEr 2  20 rr rr       jsr FsLoadFile
0010C1r 2  B0 10          bcs @LoadErr
0010C3r 2                 ; Update BAS_PRGEND: PROGRAM_START + FS_FILE_SIZE
0010C3r 2  A9 00          lda #<PROGRAM_START
0010C5r 2  18             clc
0010C6r 2  6D 4A 03       adc FS_FILE_SIZE
0010C9r 2  85 12          sta BAS_PRGEND
0010CBr 2  A9 08          lda #>PROGRAM_START
0010CDr 2  6D 4B 03       adc FS_FILE_SIZE + 1
0010D0r 2  85 13          sta BAS_PRGEND + 1
0010D2r 2  60             rts
0010D3r 2               
0010D3r 2               @LoadErr:
0010D3r 2  A9 rr          lda #<BasStrLoadErr
0010D5r 2  85 0E          sta BAS_TMP1
0010D7r 2  A9 rr          lda #>BasStrLoadErr
0010D9r 2  85 0F          sta BAS_TMP1 + 1
0010DBr 2  20 rr rr       jsr BasPrintStr
0010DEr 2  60             rts
0010DFr 2               
0010DFr 2               ; --- SAVE ---
0010DFr 2               ; SAVE "filename" — Save to CF filesystem
0010DFr 2               ; SAVE (no arg)   — Save via serial ASCII transfer
0010DFr 2               BasCmdSave:
0010DFr 2  20 rr rr       jsr BasSkipSpaces
0010E2r 2  20 rr rr       jsr BasGetTokChar
0010E5r 2  C9 22          cmp #CH_QUOTE
0010E7r 2  F0 0E          beq @SaveCF
0010E9r 2               
0010E9r 2                 ; No filename — serial ASCII save
0010E9r 2  AD 0D 03       lda HW_PRESENT
0010ECr 2  29 10          and #HW_SC
0010EEr 2  F0 04          beq @SaveNoDev
0010F0r 2  20 rr rr       jsr AsciiSave
0010F3r 2  60             rts
0010F4r 2               
0010F4r 2               @SaveNoDev:
0010F4r 2  4C rr rr       jmp BasPrintNoDevice
0010F7r 2               
0010F7r 2               @SaveCF:
0010F7r 2  AD 0D 03       lda HW_PRESENT
0010FAr 2  29 08          and #HW_CF
0010FCr 2  F0 F6          beq @SaveNoDev
0010FEr 2                 ; Parse quoted filename into STR_PTR for FsSaveFile
0010FEr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
001101r 2  A5 04          lda BAS_TXTPTR
001103r 2  85 02          sta STR_PTR
001105r 2  A5 05          lda BAS_TXTPTR + 1
001107r 2  85 03          sta STR_PTR + 1
001109r 2                 ; Advance TXTPTR past the filename to closing quote
001109r 2               @SaveScanName:
001109r 2  20 rr rr       jsr BasGetTokChar
00110Cr 2  F0 12          beq @SaveNameDone
00110Er 2  C9 22          cmp #CH_QUOTE
001110r 2  F0 05          beq @SaveNameEnd
001112r 2  20 rr rr       jsr BasAdvTxtPtr
001115r 2  80 F2          bra @SaveScanName
001117r 2               @SaveNameEnd:
001117r 2  A0 00          ldy #$00
001119r 2  A9 00          lda #$00
00111Br 2  91 04          sta (BAS_TXTPTR),y
00111Dr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
001120r 2               @SaveNameDone:
001120r 2                 ; Calculate file size = BAS_PRGEND - PROGRAM_START
001120r 2  A5 12          lda BAS_PRGEND
001122r 2  38             sec
001123r 2  E9 00          sbc #<PROGRAM_START
001125r 2  8D 4A 03       sta FS_FILE_SIZE
001128r 2  A5 13          lda BAS_PRGEND + 1
00112Ar 2  E9 08          sbc #>PROGRAM_START
00112Cr 2  8D 4B 03       sta FS_FILE_SIZE + 1
00112Fr 2                 ; Call filesystem save
00112Fr 2  20 rr rr       jsr FsSaveFile
001132r 2  B0 01          bcs @SaveErr
001134r 2  60             rts
001135r 2               
001135r 2               @SaveErr:
001135r 2  A9 rr          lda #<BasStrSaveErr
001137r 2  85 0E          sta BAS_TMP1
001139r 2  A9 rr          lda #>BasStrSaveErr
00113Br 2  85 0F          sta BAS_TMP1 + 1
00113Dr 2  20 rr rr       jsr BasPrintStr
001140r 2  60             rts
001141r 2               
001141r 2               ; --- DIR ---
001141r 2               ; DIR — Print directory listing from CF
001141r 2               BasCmdDir:
001141r 2  AD 0D 03       lda HW_PRESENT
001144r 2  29 08          and #HW_CF
001146r 2  D0 03          bne @DirHasCF
001148r 2  4C rr rr       jmp BasPrintNoDevice
00114Br 2               @DirHasCF:
00114Br 2  20 rr rr       jsr FsDirectory
00114Er 2  60             rts
00114Fr 2               
00114Fr 2               ; --- DEL ---
00114Fr 2               ; DEL "filename" — Delete a file from CF
00114Fr 2               BasCmdDel:
00114Fr 2  AD 0D 03       lda HW_PRESENT
001152r 2  29 08          and #HW_CF
001154r 2  D0 03          bne @DelHasCF
001156r 2  4C rr rr       jmp BasPrintNoDevice
001159r 2               @DelHasCF:
001159r 2  20 rr rr       jsr BasSkipSpaces
00115Cr 2  20 rr rr       jsr BasGetTokChar
00115Fr 2  C9 22          cmp #CH_QUOTE
001161r 2  D0 28          bne @DelErr
001163r 2               
001163r 2                 ; Parse quoted filename into STR_PTR for FsDeleteFile
001163r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
001166r 2  A5 04          lda BAS_TXTPTR
001168r 2  85 02          sta STR_PTR
00116Ar 2  A5 05          lda BAS_TXTPTR + 1
00116Cr 2  85 03          sta STR_PTR + 1
00116Er 2                 ; Advance TXTPTR past the filename to closing quote
00116Er 2               @DelScanName:
00116Er 2  20 rr rr       jsr BasGetTokChar
001171r 2  F0 12          beq @DelNameDone
001173r 2  C9 22          cmp #CH_QUOTE
001175r 2  F0 05          beq @DelNameEnd
001177r 2  20 rr rr       jsr BasAdvTxtPtr
00117Ar 2  80 F2          bra @DelScanName
00117Cr 2               @DelNameEnd:
00117Cr 2  A0 00          ldy #$00
00117Er 2  A9 00          lda #$00
001180r 2  91 04          sta (BAS_TXTPTR),y
001182r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
001185r 2               @DelNameDone:
001185r 2                 ; Call filesystem delete
001185r 2  20 rr rr       jsr FsDeleteFile
001188r 2  B0 01          bcs @DelErr
00118Ar 2  60             rts
00118Br 2               
00118Br 2               @DelErr:
00118Br 2  A9 rr          lda #<BasStrDelErr
00118Dr 2  85 0E          sta BAS_TMP1
00118Fr 2  A9 rr          lda #>BasStrDelErr
001191r 2  85 0F          sta BAS_TMP1 + 1
001193r 2  20 rr rr       jsr BasPrintStr
001196r 2  60             rts
001197r 2               
001197r 2               ; --- CLS ---
001197r 2               BasCmdCls:
001197r 2  20 rr rr       jsr VideoClear
00119Ar 2  60             rts
00119Br 2               
00119Br 2               ; --- LOCATE row, col ---
00119Br 2               BasCmdLocate:
00119Br 2  20 rr rr       jsr BasExpr                    ; row -> BAS_ACC
00119Er 2  A5 0A          lda BAS_ACC
0011A0r 2  85 21          sta BAS_TEMP                   ; save row
0011A2r 2  20 rr rr       jsr BasSkipSpaces
0011A5r 2  A9 2C          lda #CH_COMMA
0011A7r 2  20 rr rr       jsr BasExpectChar
0011AAr 2  20 rr rr       jsr BasExpr                    ; col -> BAS_ACC
0011ADr 2  A5 0A          lda BAS_ACC
0011AFr 2  AA             tax                            ; X = col
0011B0r 2  A4 21          ldy BAS_TEMP                   ; Y = row
0011B2r 2  20 rr rr       jsr VideoSetCursor
0011B5r 2  60             rts
0011B6r 2               
0011B6r 2               ; --- COLOR fg, bg ---
0011B6r 2               BasCmdColor:
0011B6r 2  20 rr rr       jsr BasExpr                    ; fg -> BAS_ACC (0-15)
0011B9r 2  A5 0A          lda BAS_ACC
0011BBr 2  29 0F          and #$0F
0011BDr 2  0A             asl a
0011BEr 2  0A             asl a
0011BFr 2  0A             asl a
0011C0r 2  0A             asl a                          ; shift to high nibble
0011C1r 2  85 21          sta BAS_TEMP
0011C3r 2  20 rr rr       jsr BasSkipSpaces
0011C6r 2  A9 2C          lda #CH_COMMA
0011C8r 2  20 rr rr       jsr BasExpectChar
0011CBr 2  20 rr rr       jsr BasExpr                    ; bg -> BAS_ACC (0-15)
0011CEr 2  A5 0A          lda BAS_ACC
0011D0r 2  29 0F          and #$0F
0011D2r 2  05 21          ora BAS_TEMP                   ; combine fg|bg
0011D4r 2  20 rr rr       jsr VideoSetColor
0011D7r 2  60             rts
0011D8r 2               
0011D8r 2               ; --- SOUND voice, freq, dur ---
0011D8r 2               ; freq is in Hz; converted to SID register via: reg = Hz*16 + Hz - Hz/4
0011D8r 2               ; Approximation of Hz * 2^24 / 1000000 ≈ Hz * 16.75 (0.16% error)
0011D8r 2               BasCmdSound:
0011D8r 2  AD 0D 03       lda HW_PRESENT
0011DBr 2  29 40          and #HW_SID
0011DDr 2  D0 01          bne @SoundStart
0011DFr 2  60             rts
0011E0r 2               @SoundStart:
0011E0r 2  20 rr rr       jsr BasExpr                    ; voice (1-3) -> BAS_ACC
0011E3r 2  A5 0A          lda BAS_ACC
0011E5r 2  3A             dec a                          ; convert to 0-indexed
0011E6r 2  85 21          sta BAS_TEMP                   ; save voice
0011E8r 2  20 rr rr       jsr BasSkipSpaces
0011EBr 2  A9 2C          lda #CH_COMMA
0011EDr 2  20 rr rr       jsr BasExpectChar
0011F0r 2  20 rr rr       jsr BasExpr                    ; freq (Hz) -> BAS_ACC
0011F3r 2                 ; --- Convert Hz to SID register value ---
0011F3r 2  A5 0A          lda BAS_ACC                    ; save Hz in BAS_SCRATCH
0011F5r 2  85 1C          sta BAS_SCRATCH
0011F7r 2  A5 0B          lda BAS_ACC + 1
0011F9r 2  85 1D          sta BAS_SCRATCH + 1
0011FBr 2  06 0A          asl BAS_ACC                    ; BAS_ACC = Hz << 4 (multiply by 16)
0011FDr 2  26 0B          rol BAS_ACC + 1
0011FFr 2  06 0A          asl BAS_ACC
001201r 2  26 0B          rol BAS_ACC + 1
001203r 2  06 0A          asl BAS_ACC
001205r 2  26 0B          rol BAS_ACC + 1
001207r 2  06 0A          asl BAS_ACC
001209r 2  26 0B          rol BAS_ACC + 1
00120Br 2  18             clc                            ; BAS_ACC += Hz (now Hz * 17)
00120Cr 2  A5 0A          lda BAS_ACC
00120Er 2  65 1C          adc BAS_SCRATCH
001210r 2  85 0A          sta BAS_ACC
001212r 2  A5 0B          lda BAS_ACC + 1
001214r 2  65 1D          adc BAS_SCRATCH + 1
001216r 2  85 0B          sta BAS_ACC + 1
001218r 2  46 1D          lsr BAS_SCRATCH + 1            ; BAS_SCRATCH = Hz / 4
00121Ar 2  66 1C          ror BAS_SCRATCH
00121Cr 2  46 1D          lsr BAS_SCRATCH + 1
00121Er 2  66 1C          ror BAS_SCRATCH
001220r 2  38             sec                            ; BAS_ACC -= Hz/4 (now Hz * 16.75)
001221r 2  A5 0A          lda BAS_ACC
001223r 2  E5 1C          sbc BAS_SCRATCH
001225r 2  85 0A          sta BAS_ACC
001227r 2  A5 0B          lda BAS_ACC + 1
001229r 2  E5 1D          sbc BAS_SCRATCH + 1
00122Br 2  85 0B          sta BAS_ACC + 1
00122Dr 2                 ; --- SID register value now in BAS_ACC ---
00122Dr 2  A5 0B          lda BAS_ACC + 1
00122Fr 2  48             pha                            ; save regHi on stack
001230r 2  A5 0A          lda BAS_ACC
001232r 2  48             pha                            ; save regLo on stack
001233r 2  20 rr rr       jsr BasSkipSpaces
001236r 2  A9 2C          lda #CH_COMMA
001238r 2  20 rr rr       jsr BasExpectChar
00123Br 2  20 rr rr       jsr BasExpr                    ; dur (centiseconds) -> BAS_ACC
00123Er 2                 ; BAS_ACC holds dur; stack holds freq; BAS_TEMP holds voice
00123Er 2  68             pla                            ; freqLo
00123Fr 2  AA             tax                            ; X = freqLo
001240r 2  68             pla                            ; freqHi
001241r 2  A8             tay                            ; Y = freqHi
001242r 2  A5 21          lda BAS_TEMP                   ; A = voice (0-indexed)
001244r 2  20 rr rr       jsr SidPlayNote
001247r 2  A5 0A          lda BAS_ACC                    ; A = dur_lo (BAS_ACC not changed by SidPlayNote)
001249r 2  A6 0B          ldx BAS_ACC + 1                ; X = dur_hi
00124Br 2  20 rr rr       jsr SysDelay
00124Er 2  20 rr rr       jsr SidSilence
001251r 2  60             rts
001252r 2               
001252r 2               ; --- VOL n ---
001252r 2               BasCmdVol:
001252r 2  AD 0D 03       lda HW_PRESENT
001255r 2  29 40          and #HW_SID
001257r 2  D0 01          bne @VolStart
001259r 2  60             rts
00125Ar 2               @VolStart:
00125Ar 2  20 rr rr       jsr BasExpr
00125Dr 2  A5 0A          lda BAS_ACC
00125Fr 2  20 rr rr       jsr SidSetVolume
001262r 2  60             rts
001263r 2               
001263r 2               ; BasPrint2Digit — Print A as a 2-digit decimal with leading zero
001263r 2               ; Input: A = value 0-99
001263r 2               ; Modifies: A, X, Flags
001263r 2               BasPrint2Digit:
001263r 2  A2 00          ldx #0
001265r 2               @P2DLoop:
001265r 2  C9 0A          cmp #10
001267r 2  90 05          bcc @P2DDone
001269r 2  E9 0A          sbc #10                        ; carry already set from cmp
00126Br 2  E8             inx
00126Cr 2  80 F7          bra @P2DLoop
00126Er 2               @P2DDone:
00126Er 2  48             pha                            ; save units digit
00126Fr 2  8A             txa
001270r 2  09 30          ora #'0'                       ; tens digit as ASCII
001272r 2  20 rr rr       jsr Chrout
001275r 2  68             pla
001276r 2  09 30          ora #'0'                       ; units digit as ASCII
001278r 2  20 rr rr       jsr Chrout
00127Br 2  60             rts
00127Cr 2               
00127Cr 2               ; --- TIME ---
00127Cr 2               BasCmdTime:
00127Cr 2  AD 0D 03       lda HW_PRESENT
00127Fr 2  29 04          and #HW_RTC
001281r 2  D0 03          bne @TimeHasRTC
001283r 2  4C rr rr       jmp BasPrintNoDevice
001286r 2               @TimeHasRTC:
001286r 2  20 rr rr       jsr RtcReadTime                ; A=hours, X=minutes, Y=seconds
001289r 2  5A             phy                            ; save seconds
00128Ar 2  DA             phx                            ; save minutes
00128Br 2  20 rr rr       jsr BasPrint2Digit             ; print hours
00128Er 2  A9 3A          lda #':'
001290r 2  20 rr rr       jsr Chrout
001293r 2  68             pla                            ; restore minutes
001294r 2  20 rr rr       jsr BasPrint2Digit
001297r 2  A9 3A          lda #':'
001299r 2  20 rr rr       jsr Chrout
00129Cr 2  68             pla                            ; restore seconds
00129Dr 2  20 rr rr       jsr BasPrint2Digit
0012A0r 2  20 rr rr       jsr BasPrintCRLF
0012A3r 2  60             rts
0012A4r 2               
0012A4r 2               ; --- DATE ---
0012A4r 2               BasCmdDate:
0012A4r 2  AD 0D 03       lda HW_PRESENT
0012A7r 2  29 04          and #HW_RTC
0012A9r 2  D0 03          bne @DateHasRTC
0012ABr 2  4C rr rr       jmp BasPrintNoDevice
0012AEr 2               @DateHasRTC:
0012AEr 2  20 rr rr       jsr RtcReadDate                ; A=day, X=month, Y=year; RTC_BUF_CENT=century
0012B1r 2  48             pha                            ; save day
0012B2r 2  DA             phx                            ; save month
0012B3r 2  5A             phy                            ; save year (pushed last, popped first)
0012B4r 2  AD 0B 03       lda RTC_BUF_CENT
0012B7r 2  20 rr rr       jsr BasPrint2Digit             ; print century
0012BAr 2  68             pla                            ; restore year
0012BBr 2  20 rr rr       jsr BasPrint2Digit             ; print year (CCYY together)
0012BEr 2  A9 2D          lda #'-'
0012C0r 2  20 rr rr       jsr Chrout
0012C3r 2  68             pla                            ; restore month
0012C4r 2  20 rr rr       jsr BasPrint2Digit
0012C7r 2  A9 2D          lda #'-'
0012C9r 2  20 rr rr       jsr Chrout
0012CCr 2  68             pla                            ; restore day
0012CDr 2  20 rr rr       jsr BasPrint2Digit
0012D0r 2  20 rr rr       jsr BasPrintCRLF
0012D3r 2  60             rts
0012D4r 2               
0012D4r 2               ; --- WAIT addr, mask ---
0012D4r 2               BasCmdWait:
0012D4r 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
0012D7r 2  A5 0A          lda BAS_ACC
0012D9r 2  85 10          sta BAS_TMP2
0012DBr 2  A5 0B          lda BAS_ACC + 1
0012DDr 2  85 11          sta BAS_TMP2 + 1
0012DFr 2  20 rr rr       jsr BasSkipSpaces
0012E2r 2  A9 2C          lda #CH_COMMA
0012E4r 2  20 rr rr       jsr BasExpectChar
0012E7r 2  20 rr rr       jsr BasExpr                    ; mask -> BAS_ACC
0012EAr 2  A5 0A          lda BAS_ACC
0012ECr 2  85 21          sta BAS_TEMP
0012EEr 2               @WaitPoll:
0012EEr 2  20 rr rr       jsr BasCheckBreak              ; allow Ctrl+C to abort
0012F1r 2  A0 00          ldy #0
0012F3r 2  B1 10          lda (BAS_TMP2),y
0012F5r 2  25 21          and BAS_TEMP
0012F7r 2  F0 F5          beq @WaitPoll
0012F9r 2  60             rts
0012FAr 2               
0012FAr 2               ; --- PAUSE n ---
0012FAr 2               BasCmdPause:
0012FAr 2  20 rr rr       jsr BasExpr
0012FDr 2  A5 0A          lda BAS_ACC
0012FFr 2  A6 0B          ldx BAS_ACC + 1
001301r 2  20 rr rr       jsr SysDelay
001304r 2  60             rts
001305r 2               
001305r 2               ; --- BANK n ---
001305r 2               BasCmdBank:
001305r 2  AD 0D 03       lda HW_PRESENT
001308r 2  29 01          and #HW_RAM_L
00130Ar 2  D0 03          bne @BankHasRAM
00130Cr 2  4C rr rr       jmp BasPrintNoDevice
00130Fr 2               @BankHasRAM:
00130Fr 2  20 rr rr       jsr BasExpr
001312r 2  A5 0A          lda BAS_ACC
001314r 2  8D FF 83       sta RAM_BANK_L
001317r 2  60             rts
001318r 2               
001318r 2               ; --- BRK ---
001318r 2               BasCmdBrk:
001318r 2  64 17          stz BAS_FLAGS                  ; Clear run flag
00131Ar 2  00             brk                            ; Trigger BRK → IRQ vector → Wozmon
00131Br 2               
00131Br 2               ; --- NEW ---
00131Br 2               BasCmdNew:
00131Br 2                 ; Set program end to program start (empty program)
00131Br 2  A9 00          lda #<BAS_PRG_START
00131Dr 2  85 12          sta BAS_PRGEND
00131Fr 2  A9 08          lda #>BAS_PRG_START
001321r 2  85 13          sta BAS_PRGEND + 1
001323r 2                 ; Write end marker
001323r 2  A0 00          ldy #LINE_NEXT
001325r 2  A9 00          lda #$00
001327r 2  91 12          sta (BAS_PRGEND),y
001329r 2  C8             iny
00132Ar 2  91 12          sta (BAS_PRGEND),y
00132Cr 2                 ; Clear variables
00132Cr 2  20 rr rr       jsr BasCmdClr
00132Fr 2  64 17          stz BAS_FLAGS
001331r 2  4C rr rr       jmp BasMainLoop
001334r 2               
001334r 2               ; --- LIST ---
001334r 2               BasCmdList:
001334r 2                 ; Start at beginning of program
001334r 2  A9 00          lda #<BAS_PRG_START
001336r 2  85 0E          sta BAS_TMP1
001338r 2  A9 08          lda #>BAS_PRG_START
00133Ar 2  85 0F          sta BAS_TMP1 + 1
00133Cr 2               
00133Cr 2               @ListLoop:
00133Cr 2                 ; Check if at end of program (TMP1 == PRGEND)
00133Cr 2  A5 0E          lda BAS_TMP1
00133Er 2  C5 12          cmp BAS_PRGEND
001340r 2  D0 06          bne @ListNotEnd
001342r 2  A5 0F          lda BAS_TMP1 + 1
001344r 2  C5 13          cmp BAS_PRGEND + 1
001346r 2  F0 42          beq @ListDone
001348r 2               @ListNotEnd:
001348r 2               
001348r 2                 ; Check for Ctrl+C break
001348r 2  20 rr rr       jsr BasCheckBreak
00134Br 2               
00134Br 2                 ; Print line number
00134Br 2  A0 02          ldy #LINE_NUM
00134Dr 2  B1 0E          lda (BAS_TMP1),y
00134Fr 2  85 0A          sta BAS_ACC
001351r 2  C8             iny
001352r 2  B1 0E          lda (BAS_TMP1),y
001354r 2  85 0B          sta BAS_ACC + 1
001356r 2  20 rr rr       jsr BasPrintInt
001359r 2               
001359r 2                 ; Print space
001359r 2  A9 20          lda #CH_SPACE
00135Br 2  20 rr rr       jsr Chrout
00135Er 2               
00135Er 2                 ; Detokenize and print the payload
00135Er 2                 ; Set TXTPTR to payload
00135Er 2  18             clc
00135Fr 2  A5 0E          lda BAS_TMP1
001361r 2  69 04          adc #LINE_PAYLOAD
001363r 2  85 04          sta BAS_TXTPTR
001365r 2  A5 0F          lda BAS_TMP1 + 1
001367r 2  69 00          adc #$00
001369r 2  85 05          sta BAS_TXTPTR + 1
00136Br 2               
00136Br 2  20 rr rr       jsr BasDetokenize
00136Er 2               
00136Er 2                 ; Print CRLF
00136Er 2  20 rr rr       jsr BasPrintCRLF
001371r 2               
001371r 2                 ; Advance to next line by scanning for null terminator
001371r 2  A0 04          ldy #LINE_PAYLOAD
001373r 2               @ListScan:
001373r 2  B1 0E          lda (BAS_TMP1),y
001375r 2  F0 03          beq @ListScanDone
001377r 2  C8             iny
001378r 2  80 F9          bra @ListScan
00137Ar 2               @ListScanDone:
00137Ar 2  C8             iny                            ; Past null
00137Br 2  98             tya
00137Cr 2  18             clc
00137Dr 2  65 0E          adc BAS_TMP1
00137Fr 2  85 0E          sta BAS_TMP1
001381r 2  A9 00          lda #$00
001383r 2  65 0F          adc BAS_TMP1 + 1
001385r 2  85 0F          sta BAS_TMP1 + 1
001387r 2  4C rr rr       jmp @ListLoop
00138Ar 2               
00138Ar 2               @ListDone:
00138Ar 2  60             rts
00138Br 2               
00138Br 2               ; --- POKE addr, value ---
