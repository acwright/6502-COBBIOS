002AD7r 2               ; ---------------------------------------------------------------------------
002AD7r 2               ; Token-address dispatch table.  Indexed by (token - $80).  Each entry is
002AD7r 2               ; (routine_address - 1) since the dispatcher PHA-pushes it and uses the
002AD7r 2               ; "JMP ChrGet -> RTS" trick to enter.
002AD7r 2               ; ---------------------------------------------------------------------------
002AD7r 2               BasTokenAddrTbl:
002AD7r 2  rr rr                .word   BasCmdEnd-1             ; $80 END
