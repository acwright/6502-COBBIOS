000FD6r 2  A9 4D                lda     #TEMP1X
000FD8r 2  A0 00                ldy     #$00
000FDAr 2  4C rr rr             jmp     FMult
000FDDr 2               
000FDDr 2               ; ----------------------------------------------------------------------------
000FDDr 2               ; NORMAL Polynomial SUBROUTINE
000FDDr 2               ;
000FDDr 2               ; P(X) = C(0)*X^N + C(1)*X^(N-1) + ... + C(N)
000FDDr 2               ;
000FDDr 2               ; WHERE:  X IS VALUE IN FAC
000FDDr 2               ;	Y,A POINTS AT COEFFICIENT TABLE
000FDDr 2               ;	FIRST BYTE OF COEFF. TABLE IS N
000FDDr 2               ;	COEFFICIENTS FOLLOW, HIGHEST POWER FIRST
