000F15r 2               ; Addressing mode operand size table (bytes beyond opcode)
000F15r 2               DisModeSizes:
000F15r 2  00             .byte 0                  ; AM_IMP  = 0
000F16r 2  00             .byte 0                  ; AM_ACC  = 1
000F17r 2  01             .byte 1                  ; AM_IMM  = 2
000F18r 2  01             .byte 1                  ; AM_ZP   = 3
000F19r 2  01             .byte 1                  ; AM_ZPX  = 4
000F1Ar 2  01             .byte 1                  ; AM_ZPY  = 5
000F1Br 2  02             .byte 2                  ; AM_ABS  = 6
000F1Cr 2  02             .byte 2                  ; AM_ABX  = 7
000F1Dr 2  02             .byte 2                  ; AM_ABY  = 8
000F1Er 2  02             .byte 2                  ; AM_IND  = 9
000F1Fr 2  01             .byte 1                  ; AM_IZX  = 10
000F20r 2  01             .byte 1                  ; AM_IZY  = 11
000F21r 2  01             .byte 1                  ; AM_ZPI  = 12
000F22r 2  01             .byte 1                  ; AM_REL  = 13
000F23r 2  02             .byte 2                  ; AM_ZPR  = 14
000F24r 2  02             .byte 2                  ; AM_AIX  = 15
000F25r 2               
000F25r 2               ; Operand print dispatch table (16 addressing modes)
000F25r 2               DisOperandJmpTable:
000F25r 2  rr rr          .word DisOpImp             ; AM_IMP  = 0
000F27r 2  rr rr          .word DisOpAcc             ; AM_ACC  = 1
000F29r 2  rr rr          .word DisOpImm             ; AM_IMM  = 2
000F2Br 2  rr rr          .word DisOpZp              ; AM_ZP   = 3
000F2Dr 2  rr rr          .word DisOpZpx             ; AM_ZPX  = 4
000F2Fr 2  rr rr          .word DisOpZpy             ; AM_ZPY  = 5
000F31r 2  rr rr          .word DisOpAbs             ; AM_ABS  = 6
000F33r 2  rr rr          .word DisOpAbx             ; AM_ABX  = 7
000F35r 2  rr rr          .word DisOpAby             ; AM_ABY  = 8
000F37r 2  rr rr          .word DisOpInd             ; AM_IND  = 9
000F39r 2  rr rr          .word DisOpIzx             ; AM_IZX  = 10
000F3Br 2  rr rr          .word DisOpIzy             ; AM_IZY  = 11
000F3Dr 2  rr rr          .word DisOpZpi             ; AM_ZPI  = 12
000F3Fr 2  rr rr          .word DisOpRel             ; AM_REL  = 13
000F41r 2  rr rr          .word DisOpZpr             ; AM_ZPR  = 14
000F43r 2  rr rr          .word DisOpAix             ; AM_AIX  = 15
000F45r 2               
000F45r 2               ; 65C02 Opcode Table — 256 entries x 2 bytes (mnemonic index, addressing mode)
000F45r 2               DisOpcodeTable:
000F45r 2                 ; --- $0x ---
000F45r 2  0D 00 25 0A    .byte MN_BRK,AM_IMP, MN_ORA,AM_IZX, MN_UND,AM_IMP, MN_UND,AM_IMP  ; $00-$03
000F49r 2  46 00 46 00  
