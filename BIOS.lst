0021E1r 2  20 rr rr             jsr     SynChr
0021E4r 2               @testTrue:
0021E4r 2  A5 0E                lda     FAC
0021E6r 2  D0 1F                bne     @true
0021E8r 2                       ; FALSE: scan to end-of-line OR a TOK_ELSE; if ELSE found, advance
0021E8r 2                       ; TXTPTR past it and resume execution there.
0021E8r 2  A0 00                ldy     #0
0021EAr 2               @searchElse:
0021EAr 2  B1 04                lda     (TXTPTR),y
0021ECr 2  F0 07                beq     @noElse
