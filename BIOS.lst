000FA3r 2                 ; Check for ':' statement separator
000FA3r 2  20 rr rr       jsr BasSkipSpaces
000FA6r 2  20 rr rr       jsr BasGetTokChar
000FA9r 2  C9 3A          cmp #CH_COLON
000FABr 2  D0 06          bne @ExecDone
