000778r 2  A9 01          lda #$01
00077Ar 2  80 02          bra @OrStore
00077Cr 2               @OrFalse:
00077Cr 2  A9 00          lda #$00
00077Er 2               @OrStore:
00077Er 2  85 0A          sta BAS_ACC
000780r 2  64 0B          stz BAS_ACC + 1
000782r 2  80 C8          bra @OrLoop
000784r 2               @OrDone:
000784r 2  60             rts
000785r 2               
000785r 2               ; BasExprAnd — Handle AND
000785r 2               BasExprAnd:
