000000r 2               RTC_RAM_ADDR        := $8810
000000r 2               RTC_RAM_DATA        := $8813
000000r 2               ; DS1511Y Control Register B Bits
000000r 2               RTC_CTRL_B_TE       := %10000000         ; Transfer Enable — set to inhibit updates during write
000000r 2               
