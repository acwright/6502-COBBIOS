000000r 2               MN_PHP = 39
000000r 2               MN_PHX = 40
000000r 2               MN_PHY = 41
000000r 2               MN_PLA = 42
000000r 2               MN_PLP = 43
000000r 2               MN_PLX = 44
000000r 2               MN_PLY = 45
000000r 2               MN_RMB = 46
000000r 2               MN_ROL = 47
