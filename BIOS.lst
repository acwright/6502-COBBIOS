000685r 2  4C rr rr       jmp BasMathNeg
000688r 2               @Done:
000688r 2  60             rts
000689r 2               
000689r 2               ; BasMathMul — ACC = AUX * ACC (16-bit signed)
000689r 2               ; Uses shift-and-add on magnitudes, applies sign separately
000689r 2               BasMathMul:
000689r 2                 ; Determine result sign
000689r 2  A5 0D          lda BAS_AUX + 1
00068Br 2  45 0B          eor BAS_ACC + 1
00068Dr 2  85 20          sta BAS_SIGN                   ; Bit 7 = result sign
00068Fr 2               
00068Fr 2                 ; Make both operands positive
00068Fr 2  A5 0D          lda BAS_AUX + 1
000691r 2  10 0D          bpl @AuxPos
000693r 2  38             sec
000694r 2  A9 00          lda #$00
000696r 2  E5 0C          sbc BAS_AUX
000698r 2  85 0C          sta BAS_AUX
00069Ar 2  A9 00          lda #$00
00069Cr 2  E5 0D          sbc BAS_AUX + 1
00069Er 2  85 0D          sta BAS_AUX + 1
0006A0r 2               @AuxPos:
0006A0r 2  A5 0B          lda BAS_ACC + 1
0006A2r 2  10 03          bpl @AccPos
0006A4r 2  20 rr rr       jsr BasMathNeg
0006A7r 2               @AccPos:
0006A7r 2                 ; ACC = multiplier, AUX = multiplicand
0006A7r 2                 ; Result accumulates in SCRATCH:SCRATCH+1
0006A7r 2  64 1C          stz BAS_SCRATCH
0006A9r 2  64 1D          stz BAS_SCRATCH + 1
0006ABr 2  A2 10          ldx #16                        ; 16 bits
0006ADr 2               
0006ADr 2               @MulLoop:
0006ADr 2                 ; Shift multiplier (ACC) right
0006ADr 2  46 0B          lsr BAS_ACC + 1
0006AFr 2  66 0A          ror BAS_ACC
0006B1r 2  90 0D          bcc @MulNoAdd
0006B3r 2               
0006B3r 2                 ; Add multiplicand to result
0006B3r 2  18             clc
0006B4r 2  A5 1C          lda BAS_SCRATCH
0006B6r 2  65 0C          adc BAS_AUX
0006B8r 2  85 1C          sta BAS_SCRATCH
0006BAr 2  A5 1D          lda BAS_SCRATCH + 1
0006BCr 2  65 0D          adc BAS_AUX + 1
0006BEr 2  85 1D          sta BAS_SCRATCH + 1
0006C0r 2               
0006C0r 2               @MulNoAdd:
0006C0r 2                 ; Shift multiplicand left
0006C0r 2  06 0C          asl BAS_AUX
0006C2r 2  26 0D          rol BAS_AUX + 1
0006C4r 2  CA             dex
0006C5r 2  D0 E6          bne @MulLoop
0006C7r 2               
0006C7r 2                 ; Copy result
0006C7r 2  A5 1C          lda BAS_SCRATCH
0006C9r 2  85 0A          sta BAS_ACC
0006CBr 2  A5 1D          lda BAS_SCRATCH + 1
0006CDr 2  85 0B          sta BAS_ACC + 1
0006CFr 2               
0006CFr 2                 ; Apply sign
0006CFr 2  A5 20          lda BAS_SIGN
