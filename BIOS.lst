0021E7r 2  85 04                sta     TXTPTR
0021E9r 2  90 02                bcc     @done
0021EBr 2  E6 05                inc     TXTPTR+1
0021EDr 2               @done:
0021EDr 2  60                   rts
0021EEr 2               
0021EEr 2               ; ---------------------------------------------------------------------------
0021EEr 2               ; Statement: IF expr THEN (linenum | stmt) [ELSE stmt]
0021EEr 2               ;   IF expr GOTO linenum is also accepted.
0021EEr 2               ;   If expr is false, skip rest of line (REM-style).
0021EEr 2               ;   ELSE: scan ahead for TOK_ELSE on this line.
0021EEr 2               ; ---------------------------------------------------------------------------
0021EEr 2               BasCmdIf:
0021EEr 2  20 rr rr             jsr     FrmEvl
0021F1r 2  20 rr rr             jsr     ChrGot
