0007C6r 2               @SaveError:
0007C6r 2  4C rr rr       jmp MonPrintError
0007C9r 2               
0007C9r 2               ; ============================================================================
0007C9r 2               ; MonCmdM — Memory dump (hex + ASCII, 8 bytes/row)
0007C9r 2               ; Syntax: M [addr] [addr]
0007C9r 2               ; Default: 8 lines (64 bytes). Remembers position for continuation.
0007C9r 2               ; ============================================================================
0007C9r 2               
0007C9r 2               MonCmdM:
0007C9r 2  20 rr rr       jsr MonSkipSpaces
0007CCr 2  20 rr rr       jsr MonParseHex4
0007CFr 2  90 2A          bcc @UseDefault               ; No address given — use current MON_ADDR
0007D1r 2                 ; Got first address in MON_ADDR — save it
0007D1r 2  A5 2E          lda MON_ADDR
0007D3r 2  85 32          sta MON_TMP
0007D5r 2  A5 2F          lda MON_ADDR+1
0007D7r 2  85 33          sta MON_TMP+1
0007D9r 2  20 rr rr       jsr MonSkipSpaces
0007DCr 2  20 rr rr       jsr MonParseHex4
0007DFr 2  90 12          bcc @StartOnly
0007E1r 2                 ; Got second address (end) in MON_ADDR
0007E1r 2  A5 2E          lda MON_ADDR
0007E3r 2  85 30          sta MON_END
0007E5r 2  A5 2F          lda MON_ADDR+1
0007E7r 2  85 31          sta MON_END+1
0007E9r 2                 ; Restore start address
0007E9r 2  A5 32          lda MON_TMP
0007EBr 2  85 2E          sta MON_ADDR
0007EDr 2  A5 33          lda MON_TMP+1
0007EFr 2  85 2F          sta MON_ADDR+1
0007F1r 2  80 15          bra @DumpRange
0007F3r 2               @StartOnly:
0007F3r 2                 ; Only start address — restore from MON_TMP
0007F3r 2  A5 32          lda MON_TMP
0007F5r 2  85 2E          sta MON_ADDR
0007F7r 2  A5 33          lda MON_TMP+1
0007F9r 2  85 2F          sta MON_ADDR+1
0007FBr 2               @UseDefault:
0007FBr 2                 ; Set end = start + 63 (8 lines x 8 bytes)
0007FBr 2  18             clc
0007FCr 2  A5 2E          lda MON_ADDR
0007FEr 2  69 3F          adc #63
000800r 2  85 30          sta MON_END
000802r 2  A5 2F          lda MON_ADDR+1
000804r 2  69 00          adc #0
000806r 2  85 31          sta MON_END+1
000808r 2               @DumpRange:
000808r 2  20 rr rr       jsr MonDumpLine
00080Br 2  B0 0E          bcs @DumpDone                 ; Carry set = address wrapped past $FFFF
00080Dr 2                 ; Check if MON_ADDR > MON_END
00080Dr 2  A5 31          lda MON_END+1
00080Fr 2  C5 2F          cmp MON_ADDR+1
000811r 2  90 08          bcc @DumpDone
000813r 2  D0 F3          bne @DumpRange
000815r 2  A5 30          lda MON_END
000817r 2  C5 2E          cmp MON_ADDR
000819r 2  B0 ED          bcs @DumpRange
00081Br 2               @DumpDone:
00081Br 2  60             rts
00081Cr 2               
00081Cr 2               ; MonDumpLine — Dump 8 bytes at MON_ADDR as hex + ASCII, advance by 8
00081Cr 2               
00081Cr 2               MonDumpLine:
00081Cr 2                 ; Print ".:ADDR " (39 chars/line avoids 40-col auto-wrap + CRLF double-newline)
00081Cr 2  A9 2E          lda #'.'
00081Er 2  20 rr rr       jsr Chrout
000821r 2  A9 3A          lda #':'
000823r 2  20 rr rr       jsr Chrout
000826r 2  20 rr rr       jsr MonPrintHex4
000829r 2  20 rr rr       jsr MonPrintSpace
00082Cr 2                 ; Print 8 hex bytes
00082Cr 2  A0 00          ldy #0
00082Er 2               @HexLoop:
00082Er 2  B1 2E          lda (MON_ADDR),y
000830r 2  5A             phy
000831r 2  20 rr rr       jsr MonPrintHex2
000834r 2  20 rr rr       jsr MonPrintSpace
000837r 2  7A             ply
000838r 2  C8             iny
000839r 2  C0 08          cpy #8
00083Br 2  90 F1          bcc @HexLoop
00083Dr 2                 ; Print 8 ASCII characters (no extra space — fits 40 cols)
00083Dr 2  A0 00          ldy #0
00083Fr 2               @AsciiLoop:
00083Fr 2  B1 2E          lda (MON_ADDR),y
000841r 2  C9 20          cmp #$20
000843r 2  90 04          bcc @NotPrint
000845r 2  C9 7F          cmp #$7F
000847r 2  90 02          bcc @DoPrint
000849r 2               @NotPrint:
000849r 2  A9 2E          lda #'.'
00084Br 2               @DoPrint:
00084Br 2  5A             phy
00084Cr 2  20 rr rr       jsr Chrout
00084Fr 2  7A             ply
000850r 2  C8             iny
000851r 2  C0 08          cpy #8
000853r 2  90 EA          bcc @AsciiLoop
000855r 2                 ; Advance MON_ADDR by 8
000855r 2  18             clc
000856r 2  A5 2E          lda MON_ADDR
000858r 2  69 08          adc #8
00085Ar 2  85 2E          sta MON_ADDR
00085Cr 2  90 04          bcc @NoCarry
00085Er 2  E6 2F          inc MON_ADDR+1
000860r 2  F0 05          beq @Wrapped                  ; High byte became $00 = wrapped past $FFFF
000862r 2               @NoCarry:
000862r 2  20 rr rr       jsr MonPrintCRLF
000865r 2  18             clc                           ; Signal no overflow
000866r 2  60             rts
000867r 2               @Wrapped:
000867r 2  20 rr rr       jsr MonPrintCRLF
00086Ar 2  38             sec                           ; Signal overflow
00086Br 2  60             rts
00086Cr 2               
00086Cr 2               ; ============================================================================
00086Cr 2               ; MonCmdD — Disassemble 65C02 instructions
00086Cr 2               ; Syntax: D [addr] [addr]
00086Cr 2               ; Default: 20 lines. Remembers position for continuation.
00086Cr 2               ; ============================================================================
00086Cr 2               
00086Cr 2               MonCmdD:
00086Cr 2  20 rr rr       jsr MonSkipSpaces
00086Fr 2  20 rr rr       jsr MonParseHex4
000872r 2  90 2A          bcc @UseDefault
000874r 2                 ; Got first address
000874r 2  A5 2E          lda MON_ADDR
000876r 2  85 32          sta MON_TMP
000878r 2  A5 2F          lda MON_ADDR+1
00087Ar 2  85 33          sta MON_TMP+1
00087Cr 2  20 rr rr       jsr MonSkipSpaces
00087Fr 2  20 rr rr       jsr MonParseHex4
000882r 2  90 12          bcc @StartOnly
000884r 2                 ; Got end address
000884r 2  A5 2E          lda MON_ADDR
000886r 2  85 30          sta MON_END
000888r 2  A5 2F          lda MON_ADDR+1
00088Ar 2  85 31          sta MON_END+1
00088Cr 2  A5 32          lda MON_TMP
00088Er 2  85 2E          sta MON_ADDR
000890r 2  A5 33          lda MON_TMP+1
000892r 2  85 2F          sta MON_ADDR+1
000894r 2  80 15          bra @DisRange
000896r 2               @StartOnly:
000896r 2  A5 32          lda MON_TMP
000898r 2  85 2E          sta MON_ADDR
00089Ar 2  A5 33          lda MON_TMP+1
00089Cr 2  85 2F          sta MON_ADDR+1
00089Er 2               @UseDefault:
00089Er 2                 ; Disassemble 20 lines
00089Er 2  A2 14          ldx #20
0008A0r 2               @DisCountLoop:
0008A0r 2  DA             phx
0008A1r 2  20 rr rr       jsr DisOneLine
0008A4r 2  FA             plx
0008A5r 2  B0 17          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
0008A7r 2  CA             dex
0008A8r 2  D0 F6          bne @DisCountLoop
0008AAr 2  60             rts
0008ABr 2               @DisRange:
0008ABr 2  20 rr rr       jsr DisOneLine
0008AEr 2  B0 0E          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
0008B0r 2                 ; Check if MON_ADDR > MON_END
0008B0r 2  A5 31          lda MON_END+1
0008B2r 2  C5 2F          cmp MON_ADDR+1
0008B4r 2  90 08          bcc @DisDone
0008B6r 2  D0 F3          bne @DisRange
0008B8r 2  A5 30          lda MON_END
0008BAr 2  C5 2E          cmp MON_ADDR
0008BCr 2  B0 ED          bcs @DisRange
0008BEr 2               @DisDone:
0008BEr 2  60             rts
0008BFr 2               
0008BFr 2               ; ============================================================================
0008BFr 2               ; DisOneLine — Disassemble one instruction at MON_ADDR
0008BFr 2               ; Prints line, advances MON_ADDR by instruction length.
0008BFr 2               ; Uses: MON_BYTE=opcode, MON_TMP=mnemonic idx, MON_TMP+1=mode
0008BFr 2               ;       Stack holds instruction length throughout.
0008BFr 2               ; ============================================================================
0008BFr 2               
0008BFr 2               DisOneLine:
0008BFr 2                 ; Read opcode and look up table
0008BFr 2  A0 00          ldy #0
0008C1r 2  B1 2E          lda (MON_ADDR),y
0008C3r 2  85 34          sta MON_BYTE                  ; save opcode
0008C5r 2  0A             asl a                         ; opcode * 2 for table index
0008C6r 2  AA             tax
0008C7r 2  90 0C          bcc @LowHalf                  ; carry clear = opcodes $00-$7F
0008C9r 2  BD rr rr       lda DisOpcodeTable+256,x      ; opcodes $80-$FF: offset by 256
0008CCr 2  85 32          sta MON_TMP                   ; mnemonic index
0008CEr 2  BD rr rr       lda DisOpcodeTable+257,x
0008D1r 2  85 33          sta MON_TMP+1                 ; addressing mode
0008D3r 2  80 0A          bra @GotEntry
0008D5r 2               @LowHalf:
0008D5r 2  BD rr rr       lda DisOpcodeTable,x
0008D8r 2  85 32          sta MON_TMP                   ; mnemonic index
0008DAr 2  BD rr rr       lda DisOpcodeTable+1,x
0008DDr 2  85 33          sta MON_TMP+1                 ; addressing mode
0008DFr 2               @GotEntry:
0008DFr 2                 ; Get instruction length from mode
0008DFr 2  A6 33          ldx MON_TMP+1
0008E1r 2  BD rr rr       lda DisModeSizes,x
0008E4r 2  1A             inc a                         ; +1 for opcode = total length
0008E5r 2  48             pha                           ; save on stack (stays until end)
0008E6r 2                 ; Print prefix ".,ADDR" (no space — consistent with M command's .:ADDR)
0008E6r 2  A9 2E          lda #'.'
0008E8r 2  20 rr rr       jsr Chrout
0008EBr 2  A9 2C          lda #','
0008EDr 2  20 rr rr       jsr Chrout
0008F0r 2                 ; Print address
0008F0r 2  20 rr rr       jsr MonPrintHex4
0008F3r 2  20 rr rr       jsr MonPrintSpace
0008F6r 2  20 rr rr       jsr MonPrintSpace
0008F9r 2                 ; Print opcode byte
0008F9r 2  A5 34          lda MON_BYTE
0008FBr 2  20 rr rr       jsr MonPrintHex2
0008FEr 2                 ; Print 2nd byte or padding
0008FEr 2  68             pla
0008FFr 2  48             pha                           ; peek at length
000900r 2  C9 02          cmp #2
000902r 2  90 0C          bcc @Pad1
000904r 2  20 rr rr       jsr MonPrintSpace
000907r 2  A0 01          ldy #1
000909r 2  B1 2E          lda (MON_ADDR),y
00090Br 2  20 rr rr       jsr MonPrintHex2
00090Er 2  80 09          bra @Check3
000910r 2               @Pad1:
000910r 2  20 rr rr       jsr MonPrintSpace
000913r 2  20 rr rr       jsr MonPrintSpace
000916r 2  20 rr rr       jsr MonPrintSpace
000919r 2               @Check3:
000919r 2  68             pla
00091Ar 2  48             pha
00091Br 2  C9 03          cmp #3
00091Dr 2  90 0C          bcc @Pad2
00091Fr 2  20 rr rr       jsr MonPrintSpace
000922r 2  A0 02          ldy #2
000924r 2  B1 2E          lda (MON_ADDR),y
000926r 2  20 rr rr       jsr MonPrintHex2
000929r 2  80 09          bra @AfterBytes
00092Br 2               @Pad2:
00092Br 2  20 rr rr       jsr MonPrintSpace
00092Er 2  20 rr rr       jsr MonPrintSpace
000931r 2  20 rr rr       jsr MonPrintSpace
000934r 2               @AfterBytes:
000934r 2                 ; Separator before mnemonic
000934r 2  20 rr rr       jsr MonPrintSpace
000937r 2  20 rr rr       jsr MonPrintSpace
00093Ar 2                 ; Print mnemonic (3 chars)
00093Ar 2  20 rr rr       jsr DisPrintMnemonic
00093Dr 2                 ; For RMB/SMB/BBR/BBS, append bit number digit
00093Dr 2  A5 32          lda MON_TMP
00093Fr 2  C9 03          cmp #MN_BBR
000941r 2  F0 11          beq @BitNum
000943r 2  C9 04          cmp #MN_BBS
000945r 2  F0 0D          beq @BitNum
000947r 2  C9 2E          cmp #MN_RMB
000949r 2  F0 09          beq @BitNum
00094Br 2  C9 37          cmp #MN_SMB
00094Dr 2  F0 05          beq @BitNum
00094Fr 2  20 rr rr       jsr MonPrintSpace             ; normal mnemonic — space separator
000952r 2  80 11          bra @Operand
000954r 2               @BitNum:
000954r 2  A5 34          lda MON_BYTE                  ; opcode encodes bit in upper nibble
000956r 2  4A             lsr a
000957r 2  4A             lsr a
000958r 2  4A             lsr a
000959r 2  4A             lsr a
00095Ar 2  29 07          and #$07
00095Cr 2  18             clc
00095Dr 2  69 30          adc #'0'
