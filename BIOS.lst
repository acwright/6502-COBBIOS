000965r 2                 ; Print operand based on addressing mode
000965r 2  A5 33          lda MON_TMP+1
000967r 2  20 rr rr       jsr DisPrintOperand
00096Ar 2                 ; CRLF
00096Ar 2  20 rr rr       jsr MonPrintCRLF
00096Dr 2                 ; Advance MON_ADDR by instruction length
00096Dr 2  68             pla                           ; length from stack
00096Er 2  18             clc
00096Fr 2  65 2E          adc MON_ADDR
000971r 2  85 2E          sta MON_ADDR
000973r 2  90 04          bcc @NoWrap
000975r 2  E6 2F          inc MON_ADDR+1
000977r 2  F0 02          beq @DisWrapped               ; High byte became $00 = wrapped past $FFFF
000979r 2               @NoWrap:
000979r 2  18             clc                           ; Signal no overflow
00097Ar 2  60             rts
00097Br 2               @DisWrapped:
00097Br 2  38             sec                           ; Signal overflow
00097Cr 2  60             rts
00097Dr 2               
00097Dr 2               ; DisPrintMnemonic — Print 3-char mnemonic from MON_TMP index
00097Dr 2               
00097Dr 2               DisPrintMnemonic:
00097Dr 2  A5 32          lda MON_TMP                   ; mnemonic index
00097Fr 2  0A             asl a                         ; index * 2
000980r 2  18             clc
