001141r 2               
001141r 1               .segment "BASIC"
000000r 1               .include "BASIC.asm"
000000r 2               ; ***                         ***
000000r 2               ; ***   Integer BASIC v1.0    ***
000000r 2               ; ***     for 6502-BIOS       ***
000000r 2               ; ***   $E000-$FEFF (7936B)   ***
000000r 2               ; ***                         ***
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Zero Page — BASIC Interpreter Workspace ($04-$23)
000000r 2               ; ============================================================================
000000r 2               ; $00-$03 reserved by Kernal (READ_PTR, WRITE_PTR, STR_PTR)
000000r 2               
000000r 2               BAS_TXTPTR          := $04               ; $04-$05 - Current parse/exec pointer
000000r 2               BAS_CURLINE         := $06               ; $06-$07 - Pointer to current line start
000000r 2               BAS_LINENUM         := $08               ; $08-$09 - Current line number (16-bit)
000000r 2               BAS_ACC             := $0A               ; $0A-$0B - Expression accumulator (16-bit)
000000r 2               BAS_AUX             := $0C               ; $0C-$0D - Auxiliary register (right operand)
000000r 2               BAS_TMP1            := $0E               ; $0E-$0F - General-purpose temp / pointer
000000r 2               BAS_TMP2            := $10               ; $10-$11 - General-purpose temp / pointer
000000r 2               BAS_PRGEND          := $12               ; $12-$13 - First byte past end of program
000000r 2               BAS_VARPTR          := $14               ; $14-$15 - Variable address pointer
000000r 2               BAS_TOKIDX          := $16               ; $16     - Tokenizer index / scratch
000000r 2               BAS_FLAGS           := $17               ; $17     - Runtime flags
000000r 2               BAS_RNDSEED         := $18               ; $18-$19 - PRNG state (16-bit)
000000r 2               BAS_GOSUBSP         := $1A               ; $1A     - GOSUB stack pointer (byte index)
000000r 2               BAS_FORSP           := $1B               ; $1B     - FOR stack pointer (byte index)
000000r 2               BAS_SCRATCH         := $1C               ; $1C-$1D - Scratch / division workspace
000000r 2               BAS_SCRATCH2        := $1E               ; $1E-$1F - Scratch / division workspace
000000r 2               BAS_SIGN            := $20               ; $20     - Sign tracking for mul/div
000000r 2               BAS_TEMP            := $21               ; $21     - General temp byte
000000r 2               BAS_NUMTMP          := $22               ; $22-$23 - Number parsing accumulator
000000r 2               
000000r 2               ; BAS_FLAGS bit definitions
000000r 2               BAS_FLAG_RUN        = %00000001          ; Bit 0: program is running
000000r 2               BAS_FLAG_NOSEP      = %00000010          ; Bit 1: suppress CRLF after PRINT
000000r 2               BAS_FLAG_TXTSET     = %00000100          ; Bit 2: TXTPTR already set (NEXT loop-back)
000000r 2               BAS_FLAG_GOTO       = %00001000          ; Bit 3: GOTO/GOSUB executed (force re-enter run loop)
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; RAM Layout — USER_VARS ($0400-$07FF)
000000r 2               ; ============================================================================
000000r 2               
000000r 2               BAS_VARS            := $0400             ; $0400-$0433 - 26 vars A-Z (2 bytes each)
000000r 2               BAS_LINBUF          := $0434             ; $0434-$04FF - Input line buffer (204 bytes)
000000r 2               BAS_GOSUBSTK        := $0500             ; $0500-$057F - GOSUB stack (128 bytes, 32 levels)
000000r 2               BAS_FORSTK          := $0580             ; $0580-$05FF - FOR/NEXT stack (128 bytes, 8 levels)
000000r 2               BAS_TOKBUF          := $0600             ; $0600-$06FF - Tokenized line buffer (256 bytes)
000000r 2               BAS_STRBUF          := $0700             ; $0700-$07FF - Scratch / number-to-string (256 bytes)
000000r 2               
000000r 2               ; Derived constants
000000r 2               BAS_LINBUF_SIZE     = 200                ; Max input line length
000000r 2               BAS_GOSUBSTK_SIZE   = 128               ; GOSUB stack capacity
000000r 2               BAS_FORSTK_SIZE     = 128               ; FOR stack capacity
000000r 2               BAS_GOSUB_ENTRY     = 2                  ; Bytes per GOSUB entry (CURLINE)
000000r 2               BAS_FOR_ENTRY       = 16                 ; Bytes per FOR entry
000000r 2               BAS_GOSUB_MAX       = BAS_GOSUBSTK_SIZE / BAS_GOSUB_ENTRY  ; 64 levels
000000r 2               BAS_FOR_MAX         = BAS_FORSTK_SIZE / BAS_FOR_ENTRY       ; 8 levels
000000r 2               
000000r 2               ; Array support — stored in Kernal vars area ($035B+)
000000r 2               BAS_ARYDESC         := $035B             ; $035B-$038E - 26 × 2-byte array base pointers (0=not DIM'd)
000000r 2               BAS_ARYTOP          := $038F             ; $038F-$0390 - Bottom of array space (grows down from $8000)
000000r 2               
000000r 2               ; Program space
000000r 2               BAS_PRG_START       = PROGRAM_START      ; $0800 - Start of BASIC program storage
000000r 2               BAS_PRG_END         = $7FFF              ; Last usable byte for programs
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Program Line Format (in memory at $0800-$7FFF)
000000r 2               ; ============================================================================
000000r 2               ; Each stored line:
000000r 2               ;   [2 bytes] Next-line pointer (little-endian; $0000 = end of program)
000000r 2               ;   [2 bytes] Line number (little-endian; 0-65535)
000000r 2               ;   [N bytes] Tokenized payload
000000r 2               ;   [1 byte]  $00 terminator
000000r 2               ;
000000r 2               ; Offsets within a line:
000000r 2               LINE_NEXT           = 0                  ; Offset to next-line pointer
000000r 2               LINE_NUM            = 2                  ; Offset to line number
000000r 2               LINE_PAYLOAD        = 4                  ; Offset to tokenized data
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Token Definitions ($80+)
000000r 2               ; ============================================================================
000000r 2               ; Tokens >= $80 represent keywords; raw ASCII is stored as-is.
000000r 2               
000000r 2               ; Statement tokens
000000r 2               TOK_PRINT           = $80
000000r 2               TOK_INPUT           = $81
000000r 2               TOK_LET             = $82
000000r 2               TOK_GOTO            = $83
000000r 2               TOK_GOSUB           = $84
000000r 2               TOK_RETURN          = $85
000000r 2               TOK_IF              = $86
000000r 2               TOK_THEN            = $87
000000r 2               TOK_FOR             = $88
000000r 2               TOK_TO              = $89
000000r 2               TOK_STEP            = $8A
000000r 2               TOK_NEXT            = $8B
000000r 2               TOK_REM             = $8C
000000r 2               TOK_END             = $8D
000000r 2               TOK_LIST            = $8E
000000r 2               TOK_RUN             = $8F
000000r 2               TOK_NEW             = $90
000000r 2               TOK_CLR             = $91
000000r 2               TOK_PEEK            = $92
000000r 2               TOK_POKE            = $93
000000r 2               TOK_ABS             = $94
000000r 2               TOK_RND             = $95
000000r 2               TOK_NOT             = $96
000000r 2               TOK_AND             = $97
000000r 2               TOK_OR              = $98
000000r 2               TOK_MOD             = $99
000000r 2               
000000r 2               TOK_BRK             = $9D
000000r 2               TOK_SYS             = $9E
000000r 2               TOK_LOAD            = $9F
000000r 2               TOK_SAVE            = $A0
000000r 2               TOK_DIR             = $A1
000000r 2               TOK_DEL             = $A2
000000r 2               TOK_CLS             = $A3
000000r 2               TOK_LOCATE          = $A4
000000r 2               TOK_COLOR           = $A5
000000r 2               TOK_JOY             = $A6
000000r 2               TOK_SOUND           = $A7
000000r 2               TOK_VOL             = $A8
000000r 2               TOK_TIME            = $A9
000000r 2               TOK_DATE            = $AA
000000r 2               TOK_WAIT            = $AB
000000r 2               TOK_PAUSE           = $AC
000000r 2               TOK_BANK            = $AD
000000r 2               TOK_SGN             = $AE
000000r 2               TOK_CHR             = $AF
000000r 2               
000000r 2               ; New command/function tokens (Phase 1)
000000r 2               TOK_STOP            = $B0
000000r 2               TOK_CONT            = $B1
000000r 2               TOK_ON              = $B2
000000r 2               TOK_DATA            = $B3
000000r 2               TOK_READ            = $B4
000000r 2               TOK_RESTORE         = $B5
000000r 2               TOK_SQR             = $B6
000000r 2               TOK_MIN             = $B7
000000r 2               TOK_MAX             = $B8
000000r 2               TOK_POW             = $B9
000000r 2               TOK_INKEY           = $BA
000000r 2               TOK_TAB             = $BB
000000r 2               TOK_HEX             = $BC
000000r 2               TOK_ASC             = $BD
000000r 2               
000000r 2               ; Phase 2 tokens
000000r 2               TOK_FREE            = $BE
000000r 2               TOK_SETTIME         = $BF
000000r 2               TOK_SETDATE         = $C0
000000r 2               TOK_NVRAM           = $C1
000000r 2               TOK_MEM             = $C2
000000r 2               TOK_DIM             = $C3
000000r 2               
000000r 2               ; Multi-char operator tokens
000000r 2               TOK_GE              = $9A               ; >=
000000r 2               TOK_LE              = $9B               ; <=
000000r 2               TOK_NE              = $9C               ; <>
000000r 2               
000000r 2               ; ASCII characters used in parsing (for readability)
000000r 2               CH_CR               = $0D               ; Carriage return
000000r 2               CH_LF               = $0A               ; Line feed
000000r 2               CH_SPACE            = $20               ; Space
000000r 2               CH_QUOTE            = $22               ; Double-quote
000000r 2               CH_COMMA            = $2C               ; Comma
000000r 2               CH_MINUS            = $2D               ; Minus / dash
000000r 2               CH_COLON            = $3A               ; Colon (statement separator)
000000r 2               CH_SEMICOL          = $3B               ; Semicolon
000000r 2               CH_EQUALS           = $3D               ; Equals sign
000000r 2               CH_LPAREN           = $28               ; (
000000r 2               CH_RPAREN           = $29               ; )
000000r 2               CH_LESS             = $3C               ; <
000000r 2               CH_GREATER          = $3E               ; >
000000r 2               CH_PLUS             = $2B               ; +
000000r 2               CH_STAR             = $2A               ; *
000000r 2               CH_SLASH            = $2F               ; /
000000r 2               CH_BKSP             = $08               ; Backspace
000000r 2               CH_ESC              = $1B               ; Escape
000000r 2               CH_CTRLC            = $03               ; Ctrl+C (break)
000000r 2               
000000r 2               ; Error codes
000000r 2               ERR_SYNTAX          = 0
000000r 2               ERR_UNDEF_LINE      = 1
000000r 2               ERR_TYPE_MISMATCH   = 2
000000r 2               ERR_OUT_OF_MEM      = 3
000000r 2               ERR_RET_NO_GOSUB    = 4
000000r 2               ERR_NEXT_NO_FOR     = 5
000000r 2               ERR_DIV_ZERO        = 6
000000r 2               ERR_OVERFLOW        = 7
000000r 2               ERR_ILLEGAL_QTY     = 8
000000r 2               ERR_BREAK           = 9
000000r 2               ERR_OUT_OF_DATA     = 10
000000r 2               ERR_CANT_CONT       = 11
000000r 2               ERR_REDIM           = 12
000000r 2               ERR_BAD_SUBSCRIPT   = 13
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Entry Point
000000r 2               ; ============================================================================
000000r 2               
000000r 2               BasEntry:
000000r 2  4C rr rr       jmp BasColdStart               ; Jump to cold start initialization
000003r 2               
000003r 2               ; ============================================================================
000003r 2               ; Cold Start — Initialize interpreter and enter REPL
000003r 2               ; ============================================================================
000003r 2               
000003r 2               BasColdStart:
000003r 2                 ; --- Auto-detect a pre-loaded program at BAS_PRG_START ---
000003r 2                 ; A valid program has a next-line pointer whose high byte is in program
000003r 2                 ; space ($08-$7F).  If detected, walk the chain to find BAS_PRGEND and
000003r 2                 ; skip overwriting the sentinel.  Otherwise initialize fresh.
000003r 2  AD 01 08       lda BAS_PRG_START + 1          ; High byte of first next-line pointer
000006r 2  F0 4B          beq @NoPrg                     ; $00 → sentinel or below program space
000008r 2  C9 08          cmp #>BAS_PRG_START            ; Must be >= $08 (low bound of program space)
00000Ar 2  90 47          bcc @NoPrg
00000Cr 2  C9 80          cmp #$80                       ; Must be <  $80 (below I/O area)
00000Er 2  B0 43          bcs @NoPrg
000010r 2               
000010r 2                 ; Pointer looks valid — walk the chain to locate the end sentinel
000010r 2  A9 00          lda #<BAS_PRG_START
000012r 2  85 0E          sta BAS_TMP1
000014r 2  A9 08          lda #>BAS_PRG_START
000016r 2  85 0F          sta BAS_TMP1 + 1
000018r 2               
000018r 2               @WalkChain:
000018r 2  A0 00          ldy #LINE_NEXT
00001Ar 2  B1 0E          lda (BAS_TMP1),y               ; lo byte of next-line pointer
00001Cr 2  85 10          sta BAS_TMP2
00001Er 2  C8             iny
00001Fr 2  B1 0E          lda (BAS_TMP1),y               ; hi byte of next-line pointer
000021r 2  85 11          sta BAS_TMP2 + 1
000023r 2  05 10          ora BAS_TMP2                   ; lo | hi — zero means end sentinel
000025r 2  F0 22          beq @ChainEnd
000027r 2                 ; Validate: next ptr must be within program space
000027r 2  A5 11          lda BAS_TMP2 + 1
000029r 2  C9 08          cmp #>BAS_PRG_START
00002Br 2  90 26          bcc @NoPrg                     ; < $08 → corrupt
00002Dr 2  C9 80          cmp #$80
00002Fr 2  B0 22          bcs @NoPrg                     ; >= $80 → corrupt
000031r 2                 ; Validate: next ptr must be strictly greater than current (forward progress)
000031r 2  C5 0F          cmp BAS_TMP1 + 1
000033r 2  90 1E          bcc @NoPrg
000035r 2  D0 08          bne @DoAdvance
000037r 2  A5 10          lda BAS_TMP2
000039r 2  C5 0E          cmp BAS_TMP1
00003Br 2  90 16          bcc @NoPrg
00003Dr 2  F0 14          beq @NoPrg                     ; same address → zero-length loop → corrupt
00003Fr 2               @DoAdvance:
00003Fr 2  A5 10          lda BAS_TMP2
000041r 2  85 0E          sta BAS_TMP1
000043r 2  A5 11          lda BAS_TMP2 + 1
000045r 2  85 0F          sta BAS_TMP1 + 1
000047r 2  80 CF          bra @WalkChain
000049r 2               
000049r 2               @ChainEnd:
000049r 2                 ; BAS_TMP1 points to the end sentinel ($00 $00).
000049r 2                 ; PRGEND = sentinel address (matches @NoPrg convention).
000049r 2  A5 0E          lda BAS_TMP1
00004Br 2  85 12          sta BAS_PRGEND
00004Dr 2  A5 0F          lda BAS_TMP1 + 1
00004Fr 2  85 13          sta BAS_PRGEND + 1
000051r 2  80 10          bra @PrgDone
000053r 2               
000053r 2               @NoPrg:
000053r 2                 ; No valid program detected — initialize fresh
000053r 2  A9 00          lda #<BAS_PRG_START
000055r 2  85 12          sta BAS_PRGEND
000057r 2  A9 08          lda #>BAS_PRG_START
000059r 2  85 13          sta BAS_PRGEND + 1
00005Br 2  A9 00          lda #$00
00005Dr 2  8D 00 08       sta BAS_PRG_START
000060r 2  8D 01 08       sta BAS_PRG_START + 1
000063r 2               
000063r 2               @PrgDone:
000063r 2                 ; Clear variables and stacks
000063r 2  20 rr rr       jsr BasCmdClr
000066r 2               
000066r 2                 ; Seed PRNG with a nonzero value
000066r 2  A9 A5          lda #$A5
000068r 2  85 18          sta BAS_RNDSEED
00006Ar 2  A9 37          lda #$37
00006Cr 2  85 19          sta BAS_RNDSEED + 1
00006Er 2               
00006Er 2                 ; Print welcome banner
00006Er 2  A9 rr          lda #<BasStrWelcome
000070r 2  85 0E          sta BAS_TMP1
000072r 2  A9 rr          lda #>BasStrWelcome
000074r 2  85 0F          sta BAS_TMP1 + 1
000076r 2  20 rr rr       jsr BasPrintStr
000079r 2               
000079r 2                 ; Print free memory
000079r 2  20 rr rr       jsr BasPrintFree
00007Cr 2               
00007Cr 2                 ; Fall through to main REPL loop
00007Cr 2               
00007Cr 2               ; ============================================================================
00007Cr 2               ; Main REPL Loop
00007Cr 2               ; ============================================================================
00007Cr 2               
00007Cr 2               BasMainLoop:
00007Cr 2                 ; Reset flags for immediate mode
00007Cr 2  64 17          stz BAS_FLAGS
00007Er 2               
00007Er 2                 ; Print OK prompt
00007Er 2  A9 rr          lda #<BasStrOK
000080r 2  85 0E          sta BAS_TMP1
000082r 2  A9 rr          lda #>BasStrOK
000084r 2  85 0F          sta BAS_TMP1 + 1
000086r 2  20 rr rr       jsr BasPrintStr
000089r 2               
000089r 2                 ; Read a line of input
000089r 2  20 rr rr       jsr BasReadLine
00008Cr 2               
00008Cr 2                 ; Tokenize the input line
00008Cr 2  20 rr rr       jsr BasTokenize
00008Fr 2               
00008Fr 2                 ; Check if line has a line number (first 2 bytes of TOKBUF)
00008Fr 2  AD 00 06       lda BAS_TOKBUF
000092r 2  0D 01 06       ora BAS_TOKBUF + 1
000095r 2  F0 06          beq @Immediate                 ; No line number — execute immediately
000097r 2               
000097r 2                 ; Has line number — insert/replace in program
000097r 2  20 rr rr       jsr BasInsertLine
00009Ar 2  4C rr rr       jmp BasMainLoop
00009Dr 2               
00009Dr 2               @Immediate:
00009Dr 2                 ; Set TXTPTR to the tokenized payload (skip 2-byte line number slot)
00009Dr 2  A9 02          lda #<(BAS_TOKBUF + 2)
00009Fr 2  85 04          sta BAS_TXTPTR
0000A1r 2  A9 06          lda #>(BAS_TOKBUF + 2)
0000A3r 2  85 05          sta BAS_TXTPTR + 1
0000A5r 2               
0000A5r 2                 ; Execute the immediate line
0000A5r 2  20 rr rr       jsr BasExecLine
0000A8r 2  4C rr rr       jmp BasMainLoop
0000ABr 2               
0000ABr 2               ; ============================================================================
0000ABr 2               ; CLR — Clear all variables and reset stacks
0000ABr 2               ; ============================================================================
0000ABr 2               
0000ABr 2               BasCmdClr:
0000ABr 2                 ; Zero 26 variables (52 bytes at BAS_VARS)
0000ABr 2  A2 33          ldx #51
0000ADr 2  A9 00          lda #$00
0000AFr 2               @ClrLoop:
0000AFr 2  9D 00 04       sta BAS_VARS,x
0000B2r 2  CA             dex
0000B3r 2  10 FA          bpl @ClrLoop
0000B5r 2               
0000B5r 2                 ; Zero 26 array descriptors (52 bytes at BAS_ARYDESC)
0000B5r 2  A2 33          ldx #51
0000B7r 2               @ClrAryLoop:
0000B7r 2  9D 5B 03       sta BAS_ARYDESC,x
0000BAr 2  CA             dex
0000BBr 2  10 FA          bpl @ClrAryLoop
0000BDr 2               
0000BDr 2                 ; Reset array top to $8000 (no arrays allocated)
0000BDr 2  A9 00          lda #$00
0000BFr 2  8D 8F 03       sta BAS_ARYTOP
0000C2r 2  A9 80          lda #$80
0000C4r 2  8D 90 03       sta BAS_ARYTOP + 1
0000C7r 2               
0000C7r 2                 ; Reset GOSUB and FOR stack pointers
0000C7r 2  64 1A          stz BAS_GOSUBSP
0000C9r 2  64 1B          stz BAS_FORSP
0000CBr 2               
0000CBr 2                 ; Clear DATA/STOP/CONT state
0000CBr 2  9C 1A 03       stz BAS_DATAPTR
0000CEr 2  9C 1B 03       stz BAS_DATAPTR + 1
0000D1r 2  9C 1C 03       stz BAS_STOPLINE
0000D4r 2  9C 1D 03       stz BAS_STOPLINE + 1
0000D7r 2  9C 1E 03       stz BAS_STOPTXT
0000DAr 2  9C 1F 03       stz BAS_STOPTXT + 1
0000DDr 2  9C 0E 03       stz BAS_PENDKEY
0000E0r 2  60             rts
0000E1r 2               
0000E1r 2               ; ============================================================================
0000E1r 2               ; Print Helpers
0000E1r 2               ; ============================================================================
0000E1r 2               
0000E1r 2               ; Print null-terminated string at (BAS_TMP1)
0000E1r 2               ; Modifies: A, Y, Flags
0000E1r 2               BasPrintStr:
0000E1r 2  A0 00          ldy #$00
0000E3r 2               @Loop:
0000E3r 2  B1 0E          lda (BAS_TMP1),y
0000E5r 2  F0 06          beq @Done
0000E7r 2  20 rr rr       jsr Chrout
0000EAr 2  C8             iny
0000EBr 2  D0 F6          bne @Loop
0000EDr 2               @Done:
0000EDr 2  60             rts
0000EEr 2               
0000EEr 2               ; Print CR + LF
0000EEr 2               ; Modifies: A, Flags
0000EEr 2               BasPrintCRLF:
0000EEr 2  A9 0D          lda #CH_CR
0000F0r 2  20 rr rr       jsr Chrout
0000F3r 2  A9 0A          lda #CH_LF
0000F5r 2  20 rr rr       jsr Chrout
0000F8r 2  60             rts
0000F9r 2               
0000F9r 2               ; Print free bytes message: "XXXXX BYTES FREE" + CRLF
0000F9r 2               ; Modifies: A, X, Y, Flags
0000F9r 2               BasPrintFree:
0000F9r 2                 ; Calculate free = (BAS_ARYTOP - 1) - BAS_PRGEND
0000F9r 2  38             sec
0000FAr 2  AD 8F 03       lda BAS_ARYTOP
0000FDr 2  E9 01          sbc #$01
0000FFr 2  85 0A          sta BAS_ACC
000101r 2  AD 90 03       lda BAS_ARYTOP + 1
000104r 2  E9 00          sbc #$00
000106r 2  85 0B          sta BAS_ACC + 1
000108r 2  38             sec
000109r 2  A5 0A          lda BAS_ACC
00010Br 2  E5 12          sbc BAS_PRGEND
00010Dr 2  85 0A          sta BAS_ACC
00010Fr 2  A5 0B          lda BAS_ACC + 1
000111r 2  E5 13          sbc BAS_PRGEND + 1
000113r 2  85 0B          sta BAS_ACC + 1
000115r 2               
000115r 2  20 rr rr       jsr BasPrintInt
000118r 2               
000118r 2  A9 rr          lda #<BasStrFree
00011Ar 2  85 0E          sta BAS_TMP1
00011Cr 2  A9 rr          lda #>BasStrFree
00011Er 2  85 0F          sta BAS_TMP1 + 1
000120r 2  20 rr rr       jsr BasPrintStr
000123r 2  4C rr rr       jmp BasPrintCRLF
000126r 2               
000126r 2               ; ============================================================================
000126r 2               ; Print signed 16-bit integer in BAS_ACC
000126r 2               ; Modifies: A, X, Y, Flags
000126r 2               ; ============================================================================
000126r 2               
000126r 2               BasPrintInt:
000126r 2                 ; Check if negative (bit 15 set)
000126r 2  A5 0B          lda BAS_ACC + 1
000128r 2  10 12          bpl @Positive
00012Ar 2               
00012Ar 2                 ; Print minus sign
00012Ar 2  A9 2D          lda #CH_MINUS
00012Cr 2  20 rr rr       jsr Chrout
00012Fr 2               
00012Fr 2                 ; Negate: ACC = 0 - ACC
00012Fr 2  38             sec
000130r 2  A9 00          lda #$00
000132r 2  E5 0A          sbc BAS_ACC
000134r 2  85 0A          sta BAS_ACC
000136r 2  A9 00          lda #$00
000138r 2  E5 0B          sbc BAS_ACC + 1
00013Ar 2  85 0B          sta BAS_ACC + 1
00013Cr 2               
00013Cr 2               @Positive:
00013Cr 2                 ; Push digits onto CPU stack (divide by 10 repeatedly)
00013Cr 2  A2 00          ldx #$00                       ; Digit counter on stack
00013Er 2               
00013Er 2               @DivLoop:
00013Er 2                 ; Divide BAS_ACC by 10, remainder is next digit (least significant first)
00013Er 2  A9 00          lda #$00
000140r 2  85 1C          sta BAS_SCRATCH               ; Remainder
000142r 2  A0 10          ldy #16                        ; 16-bit division
000144r 2               
000144r 2               @DivBit:
000144r 2  06 0A          asl BAS_ACC
000146r 2  26 0B          rol BAS_ACC + 1
000148r 2  26 1C          rol BAS_SCRATCH
00014Ar 2  38             sec
00014Br 2  A5 1C          lda BAS_SCRATCH
00014Dr 2  E9 0A          sbc #10
00014Fr 2  90 04          bcc @DivNoSub
000151r 2  85 1C          sta BAS_SCRATCH
000153r 2  E6 0A          inc BAS_ACC                    ; Set quotient bit
000155r 2               
000155r 2               @DivNoSub:
000155r 2  88             dey
000156r 2  D0 EC          bne @DivBit
000158r 2               
000158r 2                 ; Push remainder digit (ASCII)
000158r 2  A5 1C          lda BAS_SCRATCH
00015Ar 2  09 30          ora #$30                       ; Convert to ASCII '0'-'9'
00015Cr 2  48             pha
00015Dr 2  E8             inx                            ; Count digits
00015Er 2               
00015Er 2                 ; Check if quotient is zero
00015Er 2  A5 0A          lda BAS_ACC
000160r 2  05 0B          ora BAS_ACC + 1
000162r 2  D0 DA          bne @DivLoop
000164r 2               
000164r 2                 ; Pop and print digits (most significant first)
000164r 2               @PrintDigits:
000164r 2  68             pla
000165r 2  20 rr rr       jsr Chrout
000168r 2  CA             dex
000169r 2  D0 F9          bne @PrintDigits
00016Br 2  60             rts
00016Cr 2               
00016Cr 2               ; ============================================================================
00016Cr 2               ; Read a line of input into BAS_LINBUF
00016Cr 2               ; Blocks until CR received. Handles backspace.
00016Cr 2               ; Modifies: A, X, Y, Flags
00016Cr 2               ; ============================================================================
00016Cr 2               
00016Cr 2               BasReadLine:
00016Cr 2  A0 00          ldy #$00                       ; Index into BAS_LINBUF
00016Er 2               
00016Er 2               @WaitChar:
00016Er 2  20 rr rr       jsr Chrin                      ; Non-blocking read (carry=1 if char available)
000171r 2  90 FB          bcc @WaitChar                  ; Loop until character available
000173r 2               
000173r 2                 ; Check for backspace
000173r 2  C9 08          cmp #CH_BKSP
000175r 2  F0 20          beq @Backspace
000177r 2               
000177r 2                 ; Check for CR (end of line)
000177r 2  C9 0D          cmp #CH_CR
000179r 2  F0 2A          beq @Done
00017Br 2               
00017Br 2                 ; Check for Ctrl+C (cancel line)
00017Br 2  C9 03          cmp #CH_CTRLC
00017Dr 2  F0 1F          beq @Cancel
00017Fr 2               
00017Fr 2                 ; Skip non-printable control characters (LF, NUL, ESC, etc.)
00017Fr 2  C9 20          cmp #CH_SPACE
000181r 2  90 EB          bcc @WaitChar
000183r 2               
000183r 2                 ; Ignore if buffer full
000183r 2  C0 C8          cpy #BAS_LINBUF_SIZE
000185r 2  B0 E7          bcs @WaitChar
000187r 2               
000187r 2                 ; Convert lowercase to uppercase
000187r 2  C9 61          cmp #'a'
000189r 2  90 06          bcc @Store
00018Br 2  C9 7B          cmp #'z' + 1
00018Dr 2  B0 02          bcs @Store
00018Fr 2  29 DF          and #$DF                       ; Clear bit 5 → uppercase
000191r 2               @Store:
000191r 2                 ; Store character and advance
000191r 2  99 34 04       sta BAS_LINBUF,y
000194r 2  C8             iny
000195r 2  80 D7          bra @WaitChar
000197r 2               
000197r 2               @Backspace:
000197r 2  C0 00          cpy #$00
000199r 2  F0 D3          beq @WaitChar                  ; Nothing to delete
00019Br 2  88             dey
00019Cr 2  80 D0          bra @WaitChar
00019Er 2               
00019Er 2               @Cancel:
00019Er 2  A0 00          ldy #$00                       ; Reset buffer
0001A0r 2  20 rr rr       jsr BasPrintCRLF
0001A3r 2  80 C9          bra @WaitChar
0001A5r 2               
0001A5r 2               @Done:
0001A5r 2  A9 00          lda #$00
0001A7r 2  99 34 04       sta BAS_LINBUF,y               ; Null-terminate
0001AAr 2  20 rr rr       jsr BasPrintCRLF               ; Echo newline (Chrin echoed the CR)
0001ADr 2  60             rts
0001AEr 2               
0001AEr 2               ; ============================================================================
0001AEr 2               ; Tokenizer — Convert BAS_LINBUF ASCII text into BAS_TOKBUF tokenized form
0001AEr 2               ; ============================================================================
0001AEr 2               ; Input:  BAS_LINBUF contains null-terminated ASCII line
0001AEr 2               ; Output: BAS_TOKBUF contains:
0001AEr 2               ;           [2 bytes] line number (0 if no line number)
0001AEr 2               ;           [N bytes] tokenized payload
0001AEr 2               ;           [$00]     terminator
0001AEr 2               ; Modifies: A, X, Y, Flags, BAS_TMP1, BAS_TMP2, BAS_TOKIDX, BAS_NUMTMP
0001AEr 2               
0001AEr 2               BasTokenize:
0001AEr 2  A2 00          ldx #$00                       ; X = source index into BAS_LINBUF
0001B0r 2  64 16          stz BAS_TOKIDX                 ; Output index into BAS_TOKBUF
0001B2r 2               
0001B2r 2                 ; --- Parse optional line number ---
0001B2r 2  64 22          stz BAS_NUMTMP                 ; Clear 16-bit accumulator
0001B4r 2  64 23          stz BAS_NUMTMP + 1
0001B6r 2  A0 00          ldy #$00                       ; Flag: any digit found?
0001B8r 2               
0001B8r 2               @TokNumLoop:
0001B8r 2  BD 34 04       lda BAS_LINBUF,x
0001BBr 2  38             sec
0001BCr 2  E9 30          sbc #'0'
0001BEr 2  90 3E          bcc @TokNumDone                ; < '0'
0001C0r 2  C9 0A          cmp #10
0001C2r 2  B0 3A          bcs @TokNumDone                ; > '9'
0001C4r 2               
0001C4r 2                 ; Accumulate: NUMTMP = NUMTMP * 10 + digit
0001C4r 2  48             pha                            ; Save digit
0001C5r 2                 ; Multiply NUMTMP by 10: (val<<3) + (val<<1)
0001C5r 2  A5 22          lda BAS_NUMTMP
0001C7r 2  85 1C          sta BAS_SCRATCH
0001C9r 2  A5 23          lda BAS_NUMTMP + 1
0001CBr 2  85 1D          sta BAS_SCRATCH + 1
0001CDr 2                 ; Shift left 1 (×2)
0001CDr 2  06 22          asl BAS_NUMTMP
0001CFr 2  26 23          rol BAS_NUMTMP + 1
0001D1r 2                 ; Shift left 3 more (×8 total from original)
0001D1r 2  A5 1C          lda BAS_SCRATCH
0001D3r 2  0A             asl
0001D4r 2  85 1C          sta BAS_SCRATCH
0001D6r 2  A5 1D          lda BAS_SCRATCH + 1
0001D8r 2  2A             rol
0001D9r 2  85 1D          sta BAS_SCRATCH + 1
0001DBr 2  06 1C          asl BAS_SCRATCH
0001DDr 2  26 1D          rol BAS_SCRATCH + 1
0001DFr 2  06 1C          asl BAS_SCRATCH
0001E1r 2  26 1D          rol BAS_SCRATCH + 1
0001E3r 2                 ; Add ×2 + ×8 = ×10
0001E3r 2  18             clc
0001E4r 2  A5 22          lda BAS_NUMTMP
0001E6r 2  65 1C          adc BAS_SCRATCH
0001E8r 2  85 22          sta BAS_NUMTMP
0001EAr 2  A5 23          lda BAS_NUMTMP + 1
0001ECr 2  65 1D          adc BAS_SCRATCH + 1
0001EEr 2  85 23          sta BAS_NUMTMP + 1
0001F0r 2                 ; Add the digit
0001F0r 2  68             pla
0001F1r 2  18             clc
0001F2r 2  65 22          adc BAS_NUMTMP
0001F4r 2  85 22          sta BAS_NUMTMP
0001F6r 2  90 02          bcc @TokNumNoCarry
0001F8r 2  E6 23          inc BAS_NUMTMP + 1
0001FAr 2               @TokNumNoCarry:
0001FAr 2  C8             iny                            ; Mark digit found
0001FBr 2  E8             inx                            ; Advance source
0001FCr 2  80 BA          bra @TokNumLoop
0001FEr 2               
0001FEr 2               @TokNumDone:
0001FEr 2                 ; Store line number (0 if none found)
0001FEr 2  A5 22          lda BAS_NUMTMP
000200r 2  8D 00 06       sta BAS_TOKBUF
000203r 2  A5 23          lda BAS_NUMTMP + 1
000205r 2  8D 01 06       sta BAS_TOKBUF + 1
000208r 2  A9 02          lda #2
00020Ar 2  85 16          sta BAS_TOKIDX                 ; Output starts after 2-byte line number
00020Cr 2               
00020Cr 2                 ; Skip spaces after line number
00020Cr 2  20 rr rr       jsr @TokSkipSpaces
00020Fr 2               
00020Fr 2                 ; --- Main tokenize loop ---
00020Fr 2               @TokLoop:
00020Fr 2  BD 34 04       lda BAS_LINBUF,x
000212r 2  F0 25          beq @TokEnd                   ; Null terminator — done
000214r 2               
000214r 2                 ; Check for string literal (copy verbatim including quotes)
000214r 2  C9 22          cmp #CH_QUOTE
000216r 2  F0 79          beq @TokString
000218r 2               
000218r 2                 ; Check for multi-char operators: >=, <=, <>
000218r 2  C9 3E          cmp #CH_GREATER
00021Ar 2  F0 25          beq @TokCheckGE
00021Cr 2  C9 3C          cmp #CH_LESS
00021Er 2  F0 39          beq @TokCheckLE
000220r 2               
000220r 2                 ; Check if uppercase letter — possible keyword
000220r 2  C9 41          cmp #'A'
000222r 2  90 0B          bcc @TokCopyChar               ; Below 'A' — just copy
000224r 2  C9 5B          cmp #'Z' + 1
000226r 2  B0 07          bcs @TokCopyChar               ; Above 'Z' — just copy
000228r 2               
000228r 2                 ; Try to match a keyword
000228r 2  48             pha                            ; Save char in case match fails
000229r 2  20 rr rr       jsr BasMatchKeyword
00022Cr 2  B0 54          bcs @TokGotKeywordPop         ; Carry set = matched
00022Er 2  68             pla                            ; Restore original character
00022Fr 2               
00022Fr 2                 ; Not a keyword — copy single character as-is
00022Fr 2               @TokCopyChar:
00022Fr 2  A4 16          ldy BAS_TOKIDX
000231r 2  99 00 06       sta BAS_TOKBUF,y
000234r 2  E6 16          inc BAS_TOKIDX
000236r 2  E8             inx                            ; Advance source
000237r 2  80 D6          bra @TokLoop
000239r 2               
000239r 2               @TokEnd:
000239r 2                 ; Null-terminate tokenized output
000239r 2  A4 16          ldy BAS_TOKIDX
00023Br 2  A9 00          lda #$00
00023Dr 2  99 00 06       sta BAS_TOKBUF,y
000240r 2  60             rts
000241r 2               
000241r 2               @TokCheckGE:
000241r 2                 ; Current char is '>', check next for '='
000241r 2  BD 35 04       lda BAS_LINBUF+1,x
000244r 2  C9 3D          cmp #CH_EQUALS
000246r 2  D0 0D          bne @TokCopyGT
000248r 2  A9 9A          lda #TOK_GE
00024Ar 2  A4 16          ldy BAS_TOKIDX
00024Cr 2  99 00 06       sta BAS_TOKBUF,y
00024Fr 2  E6 16          inc BAS_TOKIDX
000251r 2  E8             inx                            ; Skip '>'
000252r 2  E8             inx                            ; Skip '='
000253r 2  80 BA          bra @TokLoop
000255r 2               @TokCopyGT:
000255r 2  A9 3E          lda #CH_GREATER
000257r 2  80 D6          bra @TokCopyChar
000259r 2               
000259r 2               @TokCheckLE:
000259r 2                 ; Current char is '<', check next
000259r 2  BD 35 04       lda BAS_LINBUF+1,x
00025Cr 2  C9 3D          cmp #CH_EQUALS
00025Er 2  F0 08          beq @TokEmitLE
000260r 2  C9 3E          cmp #CH_GREATER
000262r 2  F0 11          beq @TokEmitNE
000264r 2  A9 3C          lda #CH_LESS
000266r 2  80 C7          bra @TokCopyChar
000268r 2               @TokEmitLE:
000268r 2  A9 9B          lda #TOK_LE
00026Ar 2  A4 16          ldy BAS_TOKIDX
00026Cr 2  99 00 06       sta BAS_TOKBUF,y
00026Fr 2  E6 16          inc BAS_TOKIDX
000271r 2  E8             inx
000272r 2  E8             inx
000273r 2  80 9A          bra @TokLoop
000275r 2               @TokEmitNE:
000275r 2  A9 9C          lda #TOK_NE
000277r 2  A4 16          ldy BAS_TOKIDX
000279r 2  99 00 06       sta BAS_TOKBUF,y
00027Cr 2  E6 16          inc BAS_TOKIDX
00027Er 2  E8             inx
00027Fr 2  E8             inx
000280r 2  80 8D          bra @TokLoop
000282r 2               
000282r 2               @TokGotKeywordPop:
000282r 2  7A             ply                            ; Discard saved char (preserves A = token)
000283r 2               @TokGotKeyword:
000283r 2                 ; A = token byte, X already advanced past keyword
000283r 2  A4 16          ldy BAS_TOKIDX
000285r 2  99 00 06       sta BAS_TOKBUF,y
000288r 2  E6 16          inc BAS_TOKIDX
00028Ar 2               
00028Ar 2                 ; If REM token, copy rest of line verbatim
00028Ar 2  C9 8C          cmp #TOK_REM
00028Cr 2  F0 22          beq @TokRem
00028Er 2  4C rr rr       jmp @TokLoop
000291r 2               
000291r 2               @TokString:
000291r 2                 ; Copy opening quote
000291r 2  A4 16          ldy BAS_TOKIDX
000293r 2  99 00 06       sta BAS_TOKBUF,y
000296r 2  E6 16          inc BAS_TOKIDX
000298r 2  E8             inx
000299r 2               @TokStrLoop:
000299r 2  BD 34 04       lda BAS_LINBUF,x
00029Cr 2  F0 0F          beq @TokEndJ                   ; Unterminated string — end of line
00029Er 2  A4 16          ldy BAS_TOKIDX
0002A0r 2  99 00 06       sta BAS_TOKBUF,y
0002A3r 2  E6 16          inc BAS_TOKIDX
0002A5r 2  E8             inx
0002A6r 2  C9 22          cmp #CH_QUOTE                  ; Closing quote?
0002A8r 2  D0 EF          bne @TokStrLoop
0002AAr 2  4C rr rr       jmp @TokLoop                   ; Continue after closing quote
0002ADr 2               @TokEndJ:
0002ADr 2  4C rr rr       jmp @TokEnd
0002B0r 2               
0002B0r 2               @TokRem:
0002B0r 2                 ; Copy everything remaining verbatim
0002B0r 2               @TokRemLoop:
0002B0r 2  BD 34 04       lda BAS_LINBUF,x
0002B3r 2  F0 0A          beq @TokEndJ2
0002B5r 2  A4 16          ldy BAS_TOKIDX
0002B7r 2  99 00 06       sta BAS_TOKBUF,y
0002BAr 2  E6 16          inc BAS_TOKIDX
0002BCr 2  E8             inx
0002BDr 2  80 F1          bra @TokRemLoop
0002BFr 2               @TokEndJ2:
0002BFr 2  4C rr rr       jmp @TokEnd
0002C2r 2               
0002C2r 2               ; Skip spaces in BAS_LINBUF at position X
0002C2r 2               @TokSkipSpaces:
0002C2r 2  BD 34 04       lda BAS_LINBUF,x
0002C5r 2  C9 20          cmp #CH_SPACE
0002C7r 2  D0 03          bne @TokSkipDone
0002C9r 2  E8             inx
0002CAr 2  80 F6          bra @TokSkipSpaces
0002CCr 2               @TokSkipDone:
0002CCr 2  60             rts
0002CDr 2               
0002CDr 2               ; ============================================================================
0002CDr 2               ; Keyword Matching — Try to match a keyword at BAS_LINBUF+X
0002CDr 2               ; ============================================================================
0002CDr 2               ; Input:  X = current source index in BAS_LINBUF
0002CDr 2               ; Output: Carry set if matched, A = token, X advanced past keyword
0002CDr 2               ;         Carry clear if no match, X unchanged
0002CDr 2               ; Modifies: A, Y, BAS_TMP1, BAS_TMP2
0002CDr 2               
0002CDr 2               BasMatchKeyword:
0002CDr 2  DA             phx                            ; Save source position for rollback
0002CEr 2               
0002CEr 2                 ; Set BAS_TMP1 to start of keyword table
0002CEr 2  A9 rr          lda #<BasKeywordTable
0002D0r 2  85 0E          sta BAS_TMP1
0002D2r 2  A9 rr          lda #>BasKeywordTable
0002D4r 2  85 0F          sta BAS_TMP1 + 1
0002D6r 2               
0002D6r 2               @KwOuter:
0002D6r 2                 ; Load first byte of keyword entry — $00 = end of table
0002D6r 2  A0 00          ldy #$00
0002D8r 2  B1 0E          lda (BAS_TMP1),y
0002DAr 2  F0 3B          beq @KwNoMatch                 ; End of table — no match
0002DCr 2               
0002DCr 2                 ; Restore original X (source position)
0002DCr 2  FA             plx
0002DDr 2  DA             phx                            ; Re-save it for next attempt
0002DEr 2               
0002DEr 2               @KwCompare:
0002DEr 2  B1 0E          lda (BAS_TMP1),y
0002E0r 2  F0 09          beq @KwMatched                 ; Null terminator in keyword = full match
0002E2r 2  DD 34 04       cmp BAS_LINBUF,x
0002E5r 2  D0 1A          bne @KwSkip                    ; Mismatch — skip to next keyword
0002E7r 2  C8             iny
0002E8r 2  E8             inx
0002E9r 2  80 F3          bra @KwCompare
0002EBr 2               
0002EBr 2               @KwMatched:
0002EBr 2                 ; Keyword matched. The token byte follows the null terminator.
0002EBr 2  C8             iny                            ; Advance past the null
0002ECr 2  B1 0E          lda (BAS_TMP1),y               ; Read token byte
0002EEr 2               
0002EEr 2                 ; Check that the next source char is not a letter (prevent partial match)
0002EEr 2                 ; e.g. "TORE" should not match "TO"
0002EEr 2  48             pha                            ; Save token
0002EFr 2  BD 34 04       lda BAS_LINBUF,x
0002F2r 2  C9 41          cmp #'A'
0002F4r 2  90 07          bcc @KwConfirmed               ; Not a letter — confirmed
0002F6r 2  C9 5B          cmp #'Z' + 1
0002F8r 2  B0 03          bcs @KwConfirmed               ; Not a letter — confirmed
0002FAr 2                 ; Next char is a letter — this is a partial match, skip it
0002FAr 2  68             pla
0002FBr 2  80 04          bra @KwSkip
0002FDr 2               
0002FDr 2               @KwConfirmed:
0002FDr 2  68             pla                            ; Recover token
0002FEr 2  7A             ply                            ; Discard saved source position (PLY not PLX — X holds the advanced position)
0002FFr 2                 ; X is already advanced past the keyword
0002FFr 2  38             sec
000300r 2  60             rts
000301r 2               
000301r 2               @KwSkip:
000301r 2                 ; Advance BAS_TMP1 past current keyword string + null + token byte
000301r 2  A0 00          ldy #$00
000303r 2               @KwSkipStr:
000303r 2  B1 0E          lda (BAS_TMP1),y
000305r 2  C8             iny
000306r 2  C9 00          cmp #$00                       ; Found null terminator?
000308r 2  D0 F9          bne @KwSkipStr
00030Ar 2  C8             iny                            ; Skip token byte too
00030Br 2                 ; Advance BAS_TMP1 by Y to point to next keyword entry
00030Br 2  98             tya
00030Cr 2  18             clc
00030Dr 2  65 0E          adc BAS_TMP1
00030Fr 2  85 0E          sta BAS_TMP1
000311r 2  90 C3          bcc @KwOuter
000313r 2  E6 0F          inc BAS_TMP1 + 1
000315r 2  80 BF          bra @KwOuter                   ; Try next keyword
000317r 2               
000317r 2               @KwNoMatch:
000317r 2  FA             plx                            ; Restore original source position
000318r 2  18             clc
000319r 2  60             rts
00031Ar 2               
00031Ar 2               ; ============================================================================
00031Ar 2               ; Detokenizer — Convert tokenized line to printable ASCII
00031Ar 2               ; ============================================================================
00031Ar 2               ; Input:  BAS_TMP1 points to tokenized payload (past line number)
00031Ar 2               ; Output: Characters sent to Chrout
00031Ar 2               ; Input:  BAS_TXTPTR points to tokenized payload
00031Ar 2               ; Output: Characters sent to Chrout
00031Ar 2               ; Modifies: A, X, Y, Flags, BAS_TMP2
00031Ar 2               
00031Ar 2               BasDetokenize:
00031Ar 2  A0 00          ldy #$00
00031Cr 2               
00031Cr 2               @DetokLoop:
00031Cr 2  B1 04          lda (BAS_TXTPTR),y
00031Er 2  F0 4C          beq @DetokDone                 ; Null terminator — done
000320r 2               
000320r 2                 ; Check if token (>= $80)
000320r 2  30 06          bmi @DetokKeyword
000322r 2               
000322r 2                 ; Regular ASCII character — output it
000322r 2  20 rr rr       jsr Chrout
000325r 2  C8             iny
000326r 2  80 F4          bra @DetokLoop
000328r 2               
000328r 2               @DetokKeyword:
000328r 2                 ; Look up keyword string for this token
000328r 2  5A             phy                            ; Save source index
000329r 2  85 21          sta BAS_TEMP                   ; Save target token
00032Br 2               
00032Br 2                 ; Walk the keyword table looking for matching token
00032Br 2  A9 rr          lda #<BasKeywordTable
00032Dr 2  85 10          sta BAS_TMP2
00032Fr 2  A9 rr          lda #>BasKeywordTable
000331r 2  85 11          sta BAS_TMP2 + 1
000333r 2               
000333r 2               @DetokSearch:
000333r 2  A0 00          ldy #$00
000335r 2  B1 10          lda (BAS_TMP2),y
000337r 2  F0 2A          beq @DetokNotFound             ; End of table — token not found
000339r 2               @DetokScanStr:
000339r 2  B1 10          lda (BAS_TMP2),y
00033Br 2  C8             iny
00033Cr 2  C9 00          cmp #$00                       ; End of keyword string?
00033Er 2  D0 F9          bne @DetokScanStr
000340r 2                 ; Y now points to the token byte
000340r 2  B1 10          lda (BAS_TMP2),y
000342r 2  C8             iny                            ; Advance past token byte
000343r 2               
000343r 2                 ; Compare to our target token
000343r 2  C5 21          cmp BAS_TEMP
000345r 2  F0 0C          beq @DetokFound
000347r 2                 ; Not this one — advance BAS_TMP2 to next entry
000347r 2  98             tya
000348r 2  18             clc
000349r 2  65 10          adc BAS_TMP2
00034Br 2  85 10          sta BAS_TMP2
00034Dr 2  90 E4          bcc @DetokSearch
00034Fr 2  E6 11          inc BAS_TMP2 + 1
000351r 2  80 E0          bra @DetokSearch
000353r 2               
000353r 2               @DetokFound:
000353r 2                 ; Print the keyword string from start of BAS_TMP2
000353r 2  A0 00          ldy #$00
000355r 2               @DetokPrintKw:
000355r 2  B1 10          lda (BAS_TMP2),y
000357r 2  F0 06          beq @DetokKwDone               ; Null = end of keyword string
000359r 2  20 rr rr       jsr Chrout
00035Cr 2  C8             iny
00035Dr 2  80 F6          bra @DetokPrintKw
00035Fr 2               
00035Fr 2               @DetokKwDone:
00035Fr 2  7A             ply                            ; Restore source index
000360r 2  C8             iny                            ; Advance past the token byte in source
000361r 2  80 B9          bra @DetokLoop
000363r 2               
000363r 2               @DetokNotFound:
000363r 2                 ; Token not in table (shouldn't happen) — print '?' and continue
000363r 2  A9 3F          lda #'?'
000365r 2  20 rr rr       jsr Chrout
000368r 2  7A             ply
000369r 2  C8             iny
00036Ar 2  80 B0          bra @DetokLoop
00036Cr 2               
00036Cr 2               @DetokDone:
00036Cr 2  60             rts
00036Dr 2               
00036Dr 2               ; ============================================================================
00036Dr 2               ; Line Editor — Program Storage Management
00036Dr 2               ; ============================================================================
00036Dr 2               
00036Dr 2               ; ----------------------------------------------------------------------------
00036Dr 2               ; BasInsertLine — Insert or replace a program line
00036Dr 2               ; ----------------------------------------------------------------------------
00036Dr 2               ; Input:  BAS_TOKBUF contains tokenized line:
00036Dr 2               ;           [2 bytes] line number
00036Dr 2               ;           [N bytes] tokenized payload
00036Dr 2               ;           [$00]     terminator
00036Dr 2               ; If payload is empty (just null after line number), deletes existing line.
00036Dr 2               ; Modifies: A, X, Y, Flags, BAS_TMP1, BAS_TMP2, BAS_SCRATCH, BAS_SCRATCH2
00036Dr 2               
00036Dr 2               BasInsertLine:
00036Dr 2                 ; Load line number from TOKBUF
00036Dr 2  AD 00 06       lda BAS_TOKBUF
000370r 2  85 08          sta BAS_LINENUM
000372r 2  AD 01 06       lda BAS_TOKBUF + 1
000375r 2  85 09          sta BAS_LINENUM + 1
000377r 2               
000377r 2                 ; Calculate new line size: scan TOKBUF payload for null terminator
000377r 2  A2 02          ldx #2                         ; Start past line number in TOKBUF
000379r 2               @SizeLoop:
000379r 2  BD 00 06       lda BAS_TOKBUF,x
00037Cr 2  F0 03          beq @SizeDone
00037Er 2  E8             inx
00037Fr 2  80 F8          bra @SizeLoop
000381r 2               @SizeDone:
000381r 2                 ; X = offset of null terminator (payload length = X - 2)
000381r 2                 ; Total line in memory: 2 (next ptr) + 2 (line num) + (X-2) payload + 1 (null) = X + 3
000381r 2  E8             inx                            ; Include the null terminator
000382r 2  E8             inx                            ; +2 for next-line pointer
000383r 2  E8             inx                            ; +2 for line number (but X already includes 2 from tokbuf offset)
000384r 2                 ; X now = new line byte count including header
000384r 2                 ; Actually: payload starts at TOKBUF+2, null at TOKBUF+X (original)
000384r 2                 ; Memory line = 4 header + (origX - 2) payload + 1 null = origX + 3
000384r 2                 ; But we already incremented X by 3, so X = origX + 3. Correct.
000384r 2  86 1E          stx BAS_SCRATCH2               ; Save new line size
000386r 2               
000386r 2                 ; Check if payload is empty (just the null after line number = delete only)
000386r 2  AD 02 06       lda BAS_TOKBUF + 2
000389r 2  85 21          sta BAS_TEMP                   ; $00 if empty, nonzero if has content
00038Br 2               
00038Br 2                 ; --- Try to find existing line with this number ---
00038Br 2  20 rr rr       jsr BasFindLine                ; Sets BAS_TMP1 if found, carry set/clear
00038Er 2               
00038Er 2  90 45          bcc @NoExisting
000390r 2               
000390r 2                 ; --- Delete existing line ---
000390r 2                 ; BAS_TMP1 = address of existing line
000390r 2                 ; Calculate old line's size by scanning for null terminator
000390r 2  A0 04          ldy #LINE_PAYLOAD
000392r 2               @DelSizeLoop:
000392r 2  B1 0E          lda (BAS_TMP1),y
000394r 2  F0 03          beq @DelSizeDone
000396r 2  C8             iny
000397r 2  80 F9          bra @DelSizeLoop
000399r 2               @DelSizeDone:
000399r 2  C8             iny                            ; Include null byte; Y = total line size
00039Ar 2  84 0C          sty BAS_AUX                   ; Old line size low
00039Cr 2  64 0D          stz BAS_AUX + 1               ; High byte = 0 (lines < 256 bytes)
00039Er 2               
00039Er 2                 ; Compute source (next line address) = BAS_TMP1 + Y
00039Er 2  98             tya
00039Fr 2  18             clc
0003A0r 2  65 0E          adc BAS_TMP1
0003A2r 2  85 1C          sta BAS_SCRATCH                ; Next-line address low
0003A4r 2  A9 00          lda #$00
0003A6r 2  65 0F          adc BAS_TMP1 + 1
0003A8r 2  85 1D          sta BAS_SCRATCH + 1            ; Next-line address high
0003AAr 2               
0003AAr 2                 ; Shift bytes down: copy from BAS_SCRATCH to BAS_TMP1, up to BAS_PRGEND
0003AAr 2                 ; Source = BAS_SCRATCH (next line), Dest = BAS_TMP1 (current line)
0003AAr 2                 ; Count = BAS_PRGEND - BAS_SCRATCH
0003AAr 2  A0 00          ldy #$00
0003ACr 2               @DeleteLoop:
0003ACr 2  A5 1C          lda BAS_SCRATCH
0003AEr 2  C5 12          cmp BAS_PRGEND
0003B0r 2  A5 1D          lda BAS_SCRATCH + 1
0003B2r 2  E5 13          sbc BAS_PRGEND + 1
0003B4r 2  B0 12          bcs @DeleteDone                ; Source >= PRGEND, done copying
0003B6r 2               
0003B6r 2  B1 1C          lda (BAS_SCRATCH),y
0003B8r 2  91 0E          sta (BAS_TMP1),y
0003BAr 2               
0003BAr 2                 ; Increment source pointer
0003BAr 2  E6 1C          inc BAS_SCRATCH
0003BCr 2  D0 02          bne @DelSrcOk
0003BEr 2  E6 1D          inc BAS_SCRATCH + 1
0003C0r 2               @DelSrcOk:
0003C0r 2                 ; Increment dest pointer
0003C0r 2  E6 0E          inc BAS_TMP1
0003C2r 2  D0 02          bne @DelDstOk
0003C4r 2  E6 0F          inc BAS_TMP1 + 1
0003C6r 2               @DelDstOk:
0003C6r 2  80 E4          bra @DeleteLoop
0003C8r 2               
0003C8r 2               @DeleteDone:
0003C8r 2                 ; Update PRGEND: subtract old line size
0003C8r 2  38             sec
0003C9r 2  A5 12          lda BAS_PRGEND
0003CBr 2  E5 0C          sbc BAS_AUX
0003CDr 2  85 12          sta BAS_PRGEND
0003CFr 2  A5 13          lda BAS_PRGEND + 1
0003D1r 2  E5 0D          sbc BAS_AUX + 1
0003D3r 2  85 13          sta BAS_PRGEND + 1
0003D5r 2               
0003D5r 2               @NoExisting:
0003D5r 2                 ; If payload was empty, we're done (delete only)
0003D5r 2  A5 21          lda BAS_TEMP
0003D7r 2  D0 01          bne @DoInsert
0003D9r 2  60             rts                            ; Empty payload — delete only, done
0003DAr 2               
0003DAr 2               @DoInsert:
0003DAr 2               
0003DAr 2                 ; --- Find insertion point (keep lines sorted by number) ---
0003DAr 2  A9 00          lda #<BAS_PRG_START
0003DCr 2  85 0E          sta BAS_TMP1
0003DEr 2  A9 08          lda #>BAS_PRG_START
0003E0r 2  85 0F          sta BAS_TMP1 + 1
0003E2r 2               
0003E2r 2               @FindInsPos:
0003E2r 2                 ; Check if we've reached end of program (TMP1 == PRGEND)
0003E2r 2  A5 0E          lda BAS_TMP1
0003E4r 2  C5 12          cmp BAS_PRGEND
0003E6r 2  D0 06          bne @FindNotEnd
0003E8r 2  A5 0F          lda BAS_TMP1 + 1
0003EAr 2  C5 13          cmp BAS_PRGEND + 1
0003ECr 2  F0 2F          beq @InsertHere                ; At PRGEND — insert here
0003EEr 2               @FindNotEnd:
0003EEr 2               
0003EEr 2                 ; Compare this line's number with target
0003EEr 2  A0 02          ldy #LINE_NUM
0003F0r 2  B1 0E          lda (BAS_TMP1),y
0003F2r 2  85 0C          sta BAS_AUX
0003F4r 2  C8             iny
0003F5r 2  B1 0E          lda (BAS_TMP1),y
0003F7r 2  85 0D          sta BAS_AUX + 1
0003F9r 2               
0003F9r 2                 ; If this line number >= target, insert before it
0003F9r 2  A5 08          lda BAS_LINENUM
0003FBr 2  C5 0C          cmp BAS_AUX
0003FDr 2  A5 09          lda BAS_LINENUM + 1
0003FFr 2  E5 0D          sbc BAS_AUX + 1
000401r 2  90 1A          bcc @InsertHere                ; Target < this line — insert here
000403r 2               
000403r 2                 ; Advance to next line via next-ptr; if $0000, advance to PRGEND
000403r 2  A0 00          ldy #LINE_NEXT
000405r 2  B1 0E          lda (BAS_TMP1),y
000407r 2  AA             tax
000408r 2  C8             iny
000409r 2  B1 0E          lda (BAS_TMP1),y
00040Br 2  85 0F          sta BAS_TMP1 + 1
00040Dr 2  86 0E          stx BAS_TMP1
00040Fr 2                 ; If next-ptr was $0000, use PRGEND instead
00040Fr 2  05 0E          ora BAS_TMP1
000411r 2  D0 CF          bne @FindInsPos
000413r 2  A5 12          lda BAS_PRGEND
000415r 2  85 0E          sta BAS_TMP1
000417r 2  A5 13          lda BAS_PRGEND + 1
000419r 2  85 0F          sta BAS_TMP1 + 1
00041Br 2  80 C5          bra @FindInsPos
00041Dr 2               
00041Dr 2               @InsertHere:
00041Dr 2                 ; BAS_TMP1 = insertion point
00041Dr 2                 ; BAS_SCRATCH2 = new line size
00041Dr 2                 ; Check if there's room
00041Dr 2  18             clc
00041Er 2  A5 12          lda BAS_PRGEND
000420r 2  65 1E          adc BAS_SCRATCH2
000422r 2  85 1C          sta BAS_SCRATCH                ; Tentative new PRGEND low
000424r 2  A5 13          lda BAS_PRGEND + 1
000426r 2  69 00          adc #$00
000428r 2  85 1D          sta BAS_SCRATCH + 1            ; Tentative new PRGEND high
00042Ar 2               
00042Ar 2                 ; Check if new PRGEND > BAS_PRG_END ($7FFF)
00042Ar 2  A5 1D          lda BAS_SCRATCH + 1
00042Cr 2  C9 7F          cmp #>BAS_PRG_END
00042Er 2  90 0F          bcc @HasRoom
000430r 2  D0 08          bne @OutOfMem
000432r 2  A5 1C          lda BAS_SCRATCH
000434r 2  C9 FF          cmp #<BAS_PRG_END
000436r 2  90 07          bcc @HasRoom
000438r 2  F0 05          beq @HasRoom
00043Ar 2               @OutOfMem:
00043Ar 2  A9 03          lda #ERR_OUT_OF_MEM
00043Cr 2  4C rr rr       jmp BasError
00043Fr 2               
00043Fr 2               @HasRoom:
00043Fr 2                 ; Shift bytes up: move from PRGEND-1 down to TMP1, shifting by SCRATCH2 bytes
00043Fr 2                 ; Work backwards from PRGEND to TMP1
00043Fr 2               
00043Fr 2                 ; Source end = PRGEND - 1
00043Fr 2  38             sec
000440r 2  A5 12          lda BAS_PRGEND
000442r 2  E9 01          sbc #$01
000444r 2  85 1C          sta BAS_SCRATCH
000446r 2  A5 13          lda BAS_PRGEND + 1
000448r 2  E9 00          sbc #$00
00044Ar 2  85 1D          sta BAS_SCRATCH + 1
00044Cr 2               
00044Cr 2                 ; Dest end = source end + new line size
00044Cr 2  18             clc
00044Dr 2  A5 1C          lda BAS_SCRATCH
00044Fr 2  65 1E          adc BAS_SCRATCH2
000451r 2  85 0C          sta BAS_AUX
000453r 2  A5 1D          lda BAS_SCRATCH + 1
000455r 2  69 00          adc #$00
000457r 2  85 0D          sta BAS_AUX + 1
000459r 2               
000459r 2               @ShiftUpLoop:
000459r 2                 ; Check if source < insertion point (done)
000459r 2  A5 1C          lda BAS_SCRATCH
00045Br 2  C5 0E          cmp BAS_TMP1
00045Dr 2  A5 1D          lda BAS_SCRATCH + 1
00045Fr 2  E5 0F          sbc BAS_TMP1 + 1
000461r 2  90 18          bcc @ShiftUpDone
000463r 2               
000463r 2                 ; Copy byte from source to dest
000463r 2  A0 00          ldy #$00
000465r 2  B1 1C          lda (BAS_SCRATCH),y
000467r 2  91 0C          sta (BAS_AUX),y
000469r 2               
000469r 2                 ; Decrement source
000469r 2  A5 1C          lda BAS_SCRATCH
00046Br 2  D0 02          bne @ShiftSrcOk
00046Dr 2  C6 1D          dec BAS_SCRATCH + 1
00046Fr 2               @ShiftSrcOk:
00046Fr 2  C6 1C          dec BAS_SCRATCH
000471r 2               
000471r 2                 ; Decrement dest
000471r 2  A5 0C          lda BAS_AUX
000473r 2  D0 02          bne @ShiftDstOk
000475r 2  C6 0D          dec BAS_AUX + 1
000477r 2               @ShiftDstOk:
000477r 2  C6 0C          dec BAS_AUX
000479r 2  80 DE          bra @ShiftUpLoop
00047Br 2               
00047Br 2               @ShiftUpDone:
00047Br 2                 ; Update PRGEND
00047Br 2  18             clc
00047Cr 2  A5 12          lda BAS_PRGEND
00047Er 2  65 1E          adc BAS_SCRATCH2
000480r 2  85 12          sta BAS_PRGEND
000482r 2  A5 13          lda BAS_PRGEND + 1
000484r 2  69 00          adc #$00
000486r 2  85 13          sta BAS_PRGEND + 1
000488r 2               
000488r 2                 ; Write the new line at BAS_TMP1
000488r 2                 ; Bytes 0-1: next-line pointer (filled by relink)
000488r 2                 ; Bytes 2-3: line number
000488r 2  A0 02          ldy #LINE_NUM
00048Ar 2  A5 08          lda BAS_LINENUM
00048Cr 2  91 0E          sta (BAS_TMP1),y
00048Er 2  C8             iny
00048Fr 2  A5 09          lda BAS_LINENUM + 1
000491r 2  91 0E          sta (BAS_TMP1),y
000493r 2               
000493r 2                 ; Copy tokenized payload from BAS_TOKBUF+2 to line+4
000493r 2  A2 00          ldx #$00                       ; Source index into TOKBUF+2
000495r 2  A0 04          ldy #LINE_PAYLOAD              ; Dest offset in line
000497r 2               @CopyPayload:
000497r 2  BD 02 06       lda BAS_TOKBUF + 2,x
00049Ar 2  91 0E          sta (BAS_TMP1),y
00049Cr 2  F0 04          beq @CopyDone                  ; Copied the null terminator — done
00049Er 2  E8             inx
00049Fr 2  C8             iny
0004A0r 2  80 F5          bra @CopyPayload
0004A2r 2               
0004A2r 2               @CopyDone:
0004A2r 2                 ; Relink all lines
0004A2r 2  20 rr rr       jsr BasRelink
0004A5r 2               
0004A5r 2               @InsertDone:
0004A5r 2  60             rts
0004A6r 2               
0004A6r 2               ; ----------------------------------------------------------------------------
0004A6r 2               ; BasFindLine — Find a program line by line number
0004A6r 2               ; ----------------------------------------------------------------------------
0004A6r 2               ; Input:  BAS_LINENUM = target line number (16-bit)
0004A6r 2               ; Output: Carry set if found, clear if not found
0004A6r 2               ;         BAS_TMP1 = pointer to line (if found) or insertion point (if not)
0004A6r 2               ; Modifies: A, Y, Flags, BAS_TMP1
0004A6r 2               
0004A6r 2               BasFindLine:
0004A6r 2  A9 00          lda #<BAS_PRG_START
0004A8r 2  85 0E          sta BAS_TMP1
0004AAr 2  A9 08          lda #>BAS_PRG_START
0004ACr 2  85 0F          sta BAS_TMP1 + 1
0004AEr 2               
0004AEr 2               @FindLoop:
0004AEr 2                 ; Check if at end of program (TMP1 == PRGEND)
0004AEr 2  A5 0E          lda BAS_TMP1
0004B0r 2  C5 12          cmp BAS_PRGEND
0004B2r 2  D0 06          bne @FindNotEnd
0004B4r 2  A5 0F          lda BAS_TMP1 + 1
0004B6r 2  C5 13          cmp BAS_PRGEND + 1
0004B8r 2  F0 3A          beq @FindNotFound              ; End of program
0004BAr 2               @FindNotEnd:
0004BAr 2               
0004BAr 2                 ; Compare this line's number with target
0004BAr 2  A0 02          ldy #LINE_NUM
0004BCr 2  B1 0E          lda (BAS_TMP1),y
0004BEr 2  C5 08          cmp BAS_LINENUM
0004C0r 2  D0 07          bne @FindNotEqual
0004C2r 2  C8             iny
0004C3r 2  B1 0E          lda (BAS_TMP1),y
0004C5r 2  C5 09          cmp BAS_LINENUM + 1
0004C7r 2  F0 29          beq @FindFound                 ; Exact match
0004C9r 2               
0004C9r 2               @FindNotEqual:
0004C9r 2                 ; Check if this line number > target (past where it would be)
0004C9r 2  A0 03          ldy #LINE_NUM + 1
0004CBr 2  A5 09          lda BAS_LINENUM + 1
0004CDr 2  D1 0E          cmp (BAS_TMP1),y
0004CFr 2  90 23          bcc @FindNotFound              ; Target high < line high — not found
0004D1r 2  D0 07          bne @FindAdvance               ; Target high > line high — keep looking
0004D3r 2  88             dey
0004D4r 2  A5 08          lda BAS_LINENUM
0004D6r 2  D1 0E          cmp (BAS_TMP1),y
0004D8r 2  90 1A          bcc @FindNotFound              ; Target < line — not found
0004DAr 2               
0004DAr 2               @FindAdvance:
0004DAr 2                 ; Move to next line by scanning for null terminator
0004DAr 2  A0 04          ldy #LINE_PAYLOAD
0004DCr 2               @FindScan:
0004DCr 2  B1 0E          lda (BAS_TMP1),y
0004DEr 2  F0 03          beq @FindScanDone
0004E0r 2  C8             iny
0004E1r 2  80 F9          bra @FindScan
0004E3r 2               @FindScanDone:
0004E3r 2  C8             iny                            ; Past null
0004E4r 2  98             tya
0004E5r 2  18             clc
0004E6r 2  65 0E          adc BAS_TMP1
0004E8r 2  85 0E          sta BAS_TMP1
0004EAr 2  A9 00          lda #$00
0004ECr 2  65 0F          adc BAS_TMP1 + 1
0004EEr 2  85 0F          sta BAS_TMP1 + 1
0004F0r 2  80 BC          bra @FindLoop
0004F2r 2               
0004F2r 2               @FindFound:
0004F2r 2  38             sec
0004F3r 2  60             rts
0004F4r 2               
0004F4r 2               @FindNotFound:
0004F4r 2  18             clc
0004F5r 2  60             rts
0004F6r 2               
0004F6r 2               ; ----------------------------------------------------------------------------
0004F6r 2               ; BasRelink — Rebuild all next-line pointers from PROGRAM_START
0004F6r 2               ; ----------------------------------------------------------------------------
0004F6r 2               ; Walks program lines, computes each line's length, sets next-pointer.
0004F6r 2               ; Modifies: A, X, Y, Flags, BAS_TMP2
0004F6r 2               
0004F6r 2               BasRelink:
0004F6r 2  A9 00          lda #<BAS_PRG_START
0004F8r 2  85 10          sta BAS_TMP2
0004FAr 2  A9 08          lda #>BAS_PRG_START
0004FCr 2  85 11          sta BAS_TMP2 + 1
0004FEr 2               
0004FEr 2               @RelinkLoop:
0004FEr 2                 ; Check if at PRGEND
0004FEr 2  A5 10          lda BAS_TMP2
000500r 2  C5 12          cmp BAS_PRGEND
000502r 2  D0 06          bne @RelinkNotEnd
000504r 2  A5 11          lda BAS_TMP2 + 1
000506r 2  C5 13          cmp BAS_PRGEND + 1
000508r 2  F0 42          beq @RelinkDone
00050Ar 2               
00050Ar 2               @RelinkNotEnd:
00050Ar 2                 ; Find length of this line by scanning for null terminator in payload
00050Ar 2  A0 04          ldy #LINE_PAYLOAD
00050Cr 2               @RelinkScan:
00050Cr 2  B1 10          lda (BAS_TMP2),y
00050Er 2  F0 03          beq @RelinkFoundNull
000510r 2  C8             iny
000511r 2  80 F9          bra @RelinkScan
000513r 2               
000513r 2               @RelinkFoundNull:
000513r 2                 ; Y = offset of null terminator. Line length = Y + 1.
000513r 2  C8             iny                            ; Include the null byte
000514r 2                 ; Next line address = BAS_TMP2 + Y
000514r 2  98             tya
000515r 2  18             clc
000516r 2  65 10          adc BAS_TMP2
000518r 2  85 1C          sta BAS_SCRATCH
00051Ar 2  A9 00          lda #$00
00051Cr 2  65 11          adc BAS_TMP2 + 1
00051Er 2  85 1D          sta BAS_SCRATCH + 1
000520r 2               
000520r 2                 ; Check if next line is at or past PRGEND — if so, write $0000
000520r 2  A5 1C          lda BAS_SCRATCH
000522r 2  C5 12          cmp BAS_PRGEND
000524r 2  D0 11          bne @RelinkWrite
000526r 2  A5 1D          lda BAS_SCRATCH + 1
000528r 2  C5 13          cmp BAS_PRGEND + 1
00052Ar 2  D0 0B          bne @RelinkWrite
00052Cr 2                 ; At PRGEND — write end-of-program sentinel
00052Cr 2  A0 00          ldy #LINE_NEXT
00052Er 2  A9 00          lda #$00
000530r 2  91 10          sta (BAS_TMP2),y
000532r 2  C8             iny
000533r 2  91 10          sta (BAS_TMP2),y
000535r 2  80 15          bra @RelinkDone
000537r 2               
000537r 2               @RelinkWrite:
000537r 2                 ; Write next-line pointer
000537r 2  A0 00          ldy #LINE_NEXT
000539r 2  A5 1C          lda BAS_SCRATCH
00053Br 2  91 10          sta (BAS_TMP2),y
00053Dr 2  C8             iny
00053Er 2  A5 1D          lda BAS_SCRATCH + 1
000540r 2  91 10          sta (BAS_TMP2),y
000542r 2               
000542r 2                 ; Advance to next line
000542r 2  A5 1C          lda BAS_SCRATCH
000544r 2  85 10          sta BAS_TMP2
000546r 2  A5 1D          lda BAS_SCRATCH + 1
000548r 2  85 11          sta BAS_TMP2 + 1
00054Ar 2  80 B2          bra @RelinkLoop
00054Cr 2               
00054Cr 2               @RelinkDone:
00054Cr 2                 ; Write end sentinel at PRGEND
00054Cr 2  A0 00          ldy #$00
00054Er 2  A9 00          lda #$00
000550r 2  91 12          sta (BAS_PRGEND),y
000552r 2  C8             iny
000553r 2  91 12          sta (BAS_PRGEND),y
000555r 2  60             rts
000556r 2               
000556r 2               ; ============================================================================
000556r 2               ; BasParseInt — Parse decimal integer from tokenized text at TXTPTR
000556r 2               ; ============================================================================
000556r 2               ; Input:  BAS_TXTPTR points at text
000556r 2               ; Output: BAS_ACC = parsed 16-bit value, BAS_TXTPTR advanced
000556r 2               ;         Carry set on error (no digits found)
000556r 2               ; Modifies: A, X, Y, Flags, BAS_NUMTMP, BAS_SCRATCH
000556r 2               
000556r 2               BasParseInt:
000556r 2  64 22          stz BAS_NUMTMP
000558r 2  64 23          stz BAS_NUMTMP + 1
00055Ar 2  A2 00          ldx #$00                       ; Digit count
00055Cr 2               
00055Cr 2  A0 00          ldy #$00
00055Er 2               
00055Er 2               @ParseLoop:
00055Er 2  B1 04          lda (BAS_TXTPTR),y
000560r 2  38             sec
000561r 2  E9 30          sbc #'0'
000563r 2  90 38          bcc @ParseDone                 ; Not a digit
000565r 2  C9 0A          cmp #10
000567r 2  B0 34          bcs @ParseDone                 ; Not a digit
000569r 2               
000569r 2                 ; Have a digit — multiply accumulator by 10 and add
000569r 2  48             pha                            ; Save digit
00056Ar 2               
00056Ar 2                 ; NUMTMP × 10 = (NUMTMP × 8) + (NUMTMP × 2)
00056Ar 2  A5 22          lda BAS_NUMTMP
00056Cr 2  85 1C          sta BAS_SCRATCH
00056Er 2  A5 23          lda BAS_NUMTMP + 1
000570r 2  85 1D          sta BAS_SCRATCH + 1
000572r 2               
000572r 2                 ; ×2
000572r 2  06 22          asl BAS_NUMTMP
000574r 2  26 23          rol BAS_NUMTMP + 1
000576r 2                 ; ×8 from original (3 shifts)
000576r 2  06 1C          asl BAS_SCRATCH
000578r 2  26 1D          rol BAS_SCRATCH + 1
00057Ar 2  06 1C          asl BAS_SCRATCH
00057Cr 2  26 1D          rol BAS_SCRATCH + 1
00057Er 2  06 1C          asl BAS_SCRATCH
000580r 2  26 1D          rol BAS_SCRATCH + 1
000582r 2               
000582r 2                 ; ×2 + ×8 = ×10
000582r 2  18             clc
000583r 2  A5 22          lda BAS_NUMTMP
000585r 2  65 1C          adc BAS_SCRATCH
000587r 2  85 22          sta BAS_NUMTMP
000589r 2  A5 23          lda BAS_NUMTMP + 1
00058Br 2  65 1D          adc BAS_SCRATCH + 1
00058Dr 2  85 23          sta BAS_NUMTMP + 1
00058Fr 2               
00058Fr 2                 ; Add digit
00058Fr 2  68             pla
000590r 2  18             clc
000591r 2  65 22          adc BAS_NUMTMP
000593r 2  85 22          sta BAS_NUMTMP
000595r 2  90 02          bcc @ParseNoCarry
000597r 2  E6 23          inc BAS_NUMTMP + 1
000599r 2               @ParseNoCarry:
000599r 2  E8             inx                            ; Count digit
00059Ar 2  C8             iny                            ; Advance past digit
00059Br 2  80 C1          bra @ParseLoop
00059Dr 2               
00059Dr 2               @ParseDone:
00059Dr 2                 ; Advance TXTPTR by Y
00059Dr 2  98             tya
00059Er 2  18             clc
00059Fr 2  65 04          adc BAS_TXTPTR
0005A1r 2  85 04          sta BAS_TXTPTR
0005A3r 2  A9 00          lda #$00
0005A5r 2  65 05          adc BAS_TXTPTR + 1
0005A7r 2  85 05          sta BAS_TXTPTR + 1
0005A9r 2               
0005A9r 2                 ; Copy result to ACC
0005A9r 2  A5 22          lda BAS_NUMTMP
0005ABr 2  85 0A          sta BAS_ACC
0005ADr 2  A5 23          lda BAS_NUMTMP + 1
0005AFr 2  85 0B          sta BAS_ACC + 1
0005B1r 2               
0005B1r 2                 ; Set carry if no digits found
0005B1r 2  E0 00          cpx #$00
0005B3r 2  F0 02          beq @ParseError
0005B5r 2  18             clc
0005B6r 2  60             rts
0005B7r 2               
0005B7r 2               @ParseError:
0005B7r 2  38             sec
0005B8r 2  60             rts
0005B9r 2               
0005B9r 2               ; BasNibble — Convert ASCII hex character in A to nibble value (0-15)
0005B9r 2               ; Input:  A = ASCII character ('0'-'9', 'A'-'F')
0005B9r 2               ; Output: A = nibble value 0-15, carry clear on success
0005B9r 2               ;         Carry set if character is not a valid hex digit
0005B9r 2               ; Modifies: Flags, A
0005B9r 2               BasNibble:
0005B9r 2  C9 30          cmp #'0'
0005BBr 2  90 16          bcc @NibbleInvalid
0005BDr 2  C9 3A          cmp #'9' + 1
0005BFr 2  B0 05          bcs @NibbleTryAlpha
0005C1r 2  38             sec
0005C2r 2  E9 30          sbc #'0'
0005C4r 2  18             clc
0005C5r 2  60             rts
0005C6r 2               @NibbleTryAlpha:
0005C6r 2  C9 41          cmp #'A'
0005C8r 2  90 09          bcc @NibbleInvalid
0005CAr 2  C9 47          cmp #'F' + 1
0005CCr 2  B0 05          bcs @NibbleInvalid
0005CEr 2  38             sec
0005CFr 2  E9 37          sbc #'A' - 10
0005D1r 2  18             clc
0005D2r 2  60             rts
0005D3r 2               @NibbleInvalid:
0005D3r 2  38             sec
0005D4r 2  60             rts
0005D5r 2               
0005D5r 2               ; ============================================================================
0005D5r 2               ; BasSkipSpaces — Advance TXTPTR past spaces
0005D5r 2               ; ============================================================================
0005D5r 2               ; Modifies: A, Y, Flags
0005D5r 2               
0005D5r 2               BasSkipSpaces:
0005D5r 2  A0 00          ldy #$00
0005D7r 2               @SkipLoop:
0005D7r 2  B1 04          lda (BAS_TXTPTR),y
0005D9r 2  C9 20          cmp #CH_SPACE
0005DBr 2  D0 03          bne @SkipDone
0005DDr 2  C8             iny
0005DEr 2  80 F7          bra @SkipLoop
0005E0r 2               @SkipDone:
0005E0r 2                 ; Advance TXTPTR by Y
0005E0r 2  98             tya
0005E1r 2  18             clc
0005E2r 2  65 04          adc BAS_TXTPTR
0005E4r 2  85 04          sta BAS_TXTPTR
0005E6r 2  A9 00          lda #$00
0005E8r 2  65 05          adc BAS_TXTPTR + 1
0005EAr 2  85 05          sta BAS_TXTPTR + 1
0005ECr 2  60             rts
0005EDr 2               
0005EDr 2               ; ============================================================================
0005EDr 2               ; BasGetTokChar — Get current token byte at TXTPTR without advancing
0005EDr 2               ; ============================================================================
0005EDr 2               ; Output: A = byte at TXTPTR, Z flag set if null
0005EDr 2               ; Modifies: A, Y, Flags
0005EDr 2               
0005EDr 2               BasGetTokChar:
0005EDr 2  A0 00          ldy #$00
0005EFr 2  B1 04          lda (BAS_TXTPTR),y
0005F1r 2  60             rts
0005F2r 2               
0005F2r 2               ; ============================================================================
0005F2r 2               ; BasAdvTxtPtr — Advance TXTPTR by 1
0005F2r 2               ; ============================================================================
0005F2r 2               ; Modifies: Flags
0005F2r 2               
0005F2r 2               BasAdvTxtPtr:
0005F2r 2  E6 04          inc BAS_TXTPTR
0005F4r 2  D0 02          bne @Done
0005F6r 2  E6 05          inc BAS_TXTPTR + 1
0005F8r 2               @Done:
0005F8r 2  60             rts
0005F9r 2               
0005F9r 2               ; ============================================================================
0005F9r 2               ; BasExpectChar — Expect a specific character at TXTPTR, error if not found
0005F9r 2               ; ============================================================================
0005F9r 2               ; Input: A = expected character
0005F9r 2               ; Modifies: A, Y, Flags
0005F9r 2               
0005F9r 2               BasExpectChar:
0005F9r 2  A0 00          ldy #$00
0005FBr 2  D1 04          cmp (BAS_TXTPTR),y             ; Compare expected (A) with actual
0005FDr 2  D0 04          bne @SyntaxErr
0005FFr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip the character
000602r 2  60             rts
000603r 2               @SyntaxErr:
000603r 2  A9 00          lda #ERR_SYNTAX
000605r 2  4C rr rr       jmp BasError
000608r 2               
000608r 2               ; ============================================================================
000608r 2               ; BasCheckBreak — Check for Ctrl+C during program execution
000608r 2               ; ============================================================================
000608r 2               ; Call at the top of each line in RUN mode.
000608r 2               ; Modifies: A, Flags
000608r 2               
000608r 2               BasCheckBreak:
000608r 2  A5 17          lda BAS_FLAGS
00060Ar 2  29 01          and #BAS_FLAG_RUN
00060Cr 2  F0 13          beq @NoBrk                    ; Not running — skip check
00060Er 2  20 rr rr       jsr BufferSize                 ; Non-echoing buffer check
000611r 2  F0 0E          beq @NoBrk                    ; No character available
000613r 2  20 rr rr       jsr ReadBuffer                 ; Read without echo
000616r 2  C9 03          cmp #CH_CTRLC
000618r 2  F0 08          beq @Break
00061Ar 2  C9 1B          cmp #CH_ESC
00061Cr 2  F0 04          beq @Break
00061Er 2  8D 0E 03       sta BAS_PENDKEY               ; Save non-break char for INKEY
000621r 2               @NoBrk:
000621r 2  60             rts
000622r 2               @Break:
000622r 2                 ; Save continuation state so CONT works after Ctrl+C
000622r 2  A5 06          lda BAS_CURLINE
000624r 2  8D 1C 03       sta BAS_STOPLINE
000627r 2  A5 07          lda BAS_CURLINE + 1
000629r 2  8D 1D 03       sta BAS_STOPLINE + 1
00062Cr 2  A5 04          lda BAS_TXTPTR
00062Er 2  8D 1E 03       sta BAS_STOPTXT
000631r 2  A5 05          lda BAS_TXTPTR + 1
000633r 2  8D 1F 03       sta BAS_STOPTXT + 1
000636r 2  A9 09          lda #ERR_BREAK
000638r 2  4C rr rr       jmp BasError
00063Br 2               
00063Br 2               ; ============================================================================
00063Br 2               ; Error Handling
00063Br 2               ; ============================================================================
00063Br 2               
00063Br 2               ; BasError — Print error message and return to REPL
00063Br 2               ; Input: A = error code (ERR_* constant)
00063Br 2               ; Never returns — jumps to BasMainLoop
00063Br 2               
00063Br 2               BasError:
00063Br 2  48             pha                            ; Save error code
00063Cr 2               
00063Cr 2  20 rr rr       jsr BasPrintCRLF
00063Fr 2               
00063Fr 2  A9 3F          lda #'?'
000641r 2  20 rr rr       jsr Chrout
000644r 2               
000644r 2                 ; Look up error message pointer
000644r 2  68             pla
000645r 2  0A             asl                            ; ×2 for word-sized table index
000646r 2  AA             tax
000647r 2  BD rr rr       lda BasErrTable,x
00064Ar 2  85 0E          sta BAS_TMP1
00064Cr 2  BD rr rr       lda BasErrTable+1,x
00064Fr 2  85 0F          sta BAS_TMP1 + 1
000651r 2               
000651r 2                 ; Print error message
000651r 2  20 rr rr       jsr BasPrintStr
000654r 2               
000654r 2                 ; Print " ERROR" (skip for BREAK)
000654r 2  E0 12          cpx #(ERR_BREAK * 2)
000656r 2  F0 0B          beq @SkipErrorWord
000658r 2  A9 rr          lda #<BasStrError
00065Ar 2  85 0E          sta BAS_TMP1
00065Cr 2  A9 rr          lda #>BasStrError
00065Er 2  85 0F          sta BAS_TMP1 + 1
000660r 2  20 rr rr       jsr BasPrintStr
000663r 2               @SkipErrorWord:
000663r 2               
000663r 2                 ; If running, print " IN " + line number
000663r 2  A5 17          lda BAS_FLAGS
000665r 2  29 01          and #BAS_FLAG_RUN
000667r 2  F0 16          beq @ErrDone
000669r 2               
000669r 2  A9 rr          lda #<BasStrIn
00066Br 2  85 0E          sta BAS_TMP1
00066Dr 2  A9 rr          lda #>BasStrIn
00066Fr 2  85 0F          sta BAS_TMP1 + 1
000671r 2  20 rr rr       jsr BasPrintStr
000674r 2               
000674r 2                 ; Print current line number
000674r 2  A5 08          lda BAS_LINENUM
000676r 2  85 0A          sta BAS_ACC
000678r 2  A5 09          lda BAS_LINENUM + 1
00067Ar 2  85 0B          sta BAS_ACC + 1
00067Cr 2  20 rr rr       jsr BasPrintInt
00067Fr 2               
00067Fr 2               @ErrDone:
00067Fr 2  20 rr rr       jsr BasPrintCRLF
000682r 2               
000682r 2                 ; Reset state and return to REPL
000682r 2  64 17          stz BAS_FLAGS
000684r 2  64 1A          stz BAS_GOSUBSP
000686r 2  64 1B          stz BAS_FORSP
000688r 2               
000688r 2                 ; Reset stack pointer to avoid stack corruption from nested calls
000688r 2  A2 FF          ldx #$FF
00068Ar 2  9A             txs
00068Br 2               
00068Br 2  4C rr rr       jmp BasMainLoop
00068Er 2               
00068Er 2               ; Error message pointer table
00068Er 2               BasErrTable:
00068Er 2  rr rr          .word BasErrSyntax             ; 0 - SYNTAX
000690r 2  rr rr          .word BasErrUndef              ; 1 - UNDEF'D LINE
000692r 2  rr rr          .word BasErrType               ; 2 - TYPE MISMATCH
000694r 2  rr rr          .word BasErrMem                ; 3 - OUT OF MEMORY
000696r 2  rr rr          .word BasErrRetGosub           ; 4 - RETURN W/O GOSUB
000698r 2  rr rr          .word BasErrNextFor            ; 5 - NEXT W/O FOR
00069Ar 2  rr rr          .word BasErrDivZero            ; 6 - DIVISION BY ZERO
00069Cr 2  rr rr          .word BasErrOverflow           ; 7 - OVERFLOW
00069Er 2  rr rr          .word BasErrIllegal            ; 8 - ILLEGAL QUANTITY
0006A0r 2  rr rr          .word BasErrBreak              ; 9 - BREAK
0006A2r 2  rr rr          .word BasErrOutOfData           ; 10 - OUT OF DATA
0006A4r 2  rr rr          .word BasErrCantCont            ; 11 - CAN'T CONTINUE
0006A6r 2  rr rr          .word BasErrRedim               ; 12 - REDIM'D ARRAY
0006A8r 2  rr rr          .word BasErrBadSub              ; 13 - BAD SUBSCRIPT
0006AAr 2               
0006AAr 2               ; Error message strings
0006AAr 2  53 59 4E 54  BasErrSyntax:    .byte "SYNTAX", $00
0006AEr 2  41 58 00     
0006B1r 2  55 4E 44 45  BasErrUndef:     .byte "UNDEF'D LINE", $00
0006B5r 2  46 27 44 20  
0006B9r 2  4C 49 4E 45  
0006BEr 2  54 59 50 45  BasErrType:      .byte "TYPE MISMATCH", $00
0006C2r 2  20 4D 49 53  
0006C6r 2  4D 41 54 43  
0006CCr 2  4F 55 54 20  BasErrMem:       .byte "OUT OF MEMORY", $00
0006D0r 2  4F 46 20 4D  
0006D4r 2  45 4D 4F 52  
0006DAr 2  52 45 54 55  BasErrRetGosub:  .byte "RETURN W/O GOSUB", $00
0006DEr 2  52 4E 20 57  
0006E2r 2  2F 4F 20 47  
0006EBr 2  4E 45 58 54  BasErrNextFor:   .byte "NEXT W/O FOR", $00
0006EFr 2  20 57 2F 4F  
0006F3r 2  20 46 4F 52  
0006F8r 2  44 49 56 49  BasErrDivZero:   .byte "DIVISION BY ZERO", $00
0006FCr 2  53 49 4F 4E  
000700r 2  20 42 59 20  
000709r 2  4F 56 45 52  BasErrOverflow:  .byte "OVERFLOW", $00
00070Dr 2  46 4C 4F 57  
000711r 2  00           
000712r 2  49 4C 4C 45  BasErrIllegal:   .byte "ILLEGAL QUANTITY", $00
000716r 2  47 41 4C 20  
00071Ar 2  51 55 41 4E  
000723r 2  42 52 45 41  BasErrBreak:     .byte "BREAK", $00
000727r 2  4B 00        
000729r 2  4F 55 54 20  BasErrOutOfData: .byte "OUT OF DATA", $00
00072Dr 2  4F 46 20 44  
000731r 2  41 54 41 00  
000735r 2  43 41 4E 27  BasErrCantCont:  .byte "CAN'T CONTINUE", $00
000739r 2  54 20 43 4F  
00073Dr 2  4E 54 49 4E  
000744r 2  52 45 44 49  BasErrRedim:     .byte "REDIM'D ARRAY", $00
000748r 2  4D 27 44 20  
00074Cr 2  41 52 52 41  
000752r 2  42 41 44 20  BasErrBadSub:    .byte "BAD SUBSCRIPT", $00
000756r 2  53 55 42 53  
00075Ar 2  43 52 49 50  
000760r 2               
000760r 2               ; ============================================================================
000760r 2               ; 16-Bit Math Routines
000760r 2               ; ============================================================================
000760r 2               
000760r 2               ; BasMathAdd — ACC = AUX + ACC
000760r 2               BasMathAdd:
000760r 2  18             clc
000761r 2  A5 0C          lda BAS_AUX
000763r 2  65 0A          adc BAS_ACC
000765r 2  85 0A          sta BAS_ACC
000767r 2  A5 0D          lda BAS_AUX + 1
000769r 2  65 0B          adc BAS_ACC + 1
00076Br 2  85 0B          sta BAS_ACC + 1
00076Dr 2  60             rts
00076Er 2               
00076Er 2               ; BasMathSub — ACC = AUX - ACC
00076Er 2               BasMathSub:
00076Er 2  38             sec
00076Fr 2  A5 0C          lda BAS_AUX
000771r 2  E5 0A          sbc BAS_ACC
000773r 2  85 0A          sta BAS_ACC
000775r 2  A5 0D          lda BAS_AUX + 1
000777r 2  E5 0B          sbc BAS_ACC + 1
000779r 2  85 0B          sta BAS_ACC + 1
00077Br 2  60             rts
00077Cr 2               
00077Cr 2               ; BasMathNeg — ACC = -ACC (two's complement)
00077Cr 2               BasMathNeg:
00077Cr 2  38             sec
00077Dr 2  A9 00          lda #$00
00077Fr 2  E5 0A          sbc BAS_ACC
000781r 2  85 0A          sta BAS_ACC
000783r 2  A9 00          lda #$00
000785r 2  E5 0B          sbc BAS_ACC + 1
000787r 2  85 0B          sta BAS_ACC + 1
000789r 2  60             rts
00078Ar 2               
00078Ar 2               ; BasMathAbs — ACC = |ACC|
00078Ar 2               BasMathAbs:
00078Ar 2  A5 0B          lda BAS_ACC + 1
00078Cr 2  10 03          bpl @Done
00078Er 2  4C rr rr       jmp BasMathNeg
000791r 2               @Done:
000791r 2  60             rts
000792r 2               
000792r 2               ; BasMathMul — ACC = AUX * ACC (16-bit signed)
000792r 2               ; Uses shift-and-add on magnitudes, applies sign separately
000792r 2               BasMathMul:
000792r 2                 ; Determine result sign
000792r 2  A5 0D          lda BAS_AUX + 1
000794r 2  45 0B          eor BAS_ACC + 1
000796r 2  85 20          sta BAS_SIGN                   ; Bit 7 = result sign
000798r 2               
000798r 2                 ; Make both operands positive
000798r 2  A5 0D          lda BAS_AUX + 1
00079Ar 2  10 0D          bpl @AuxPos
00079Cr 2  38             sec
00079Dr 2  A9 00          lda #$00
00079Fr 2  E5 0C          sbc BAS_AUX
0007A1r 2  85 0C          sta BAS_AUX
0007A3r 2  A9 00          lda #$00
0007A5r 2  E5 0D          sbc BAS_AUX + 1
0007A7r 2  85 0D          sta BAS_AUX + 1
0007A9r 2               @AuxPos:
0007A9r 2  A5 0B          lda BAS_ACC + 1
0007ABr 2  10 03          bpl @AccPos
0007ADr 2  20 rr rr       jsr BasMathNeg
0007B0r 2               @AccPos:
0007B0r 2                 ; ACC = multiplier, AUX = multiplicand
0007B0r 2                 ; Result accumulates in SCRATCH:SCRATCH+1
0007B0r 2  64 1C          stz BAS_SCRATCH
0007B2r 2  64 1D          stz BAS_SCRATCH + 1
0007B4r 2  A2 10          ldx #16                        ; 16 bits
0007B6r 2               
0007B6r 2               @MulLoop:
0007B6r 2                 ; Shift multiplier (ACC) right
0007B6r 2  46 0B          lsr BAS_ACC + 1
0007B8r 2  66 0A          ror BAS_ACC
0007BAr 2  90 0D          bcc @MulNoAdd
0007BCr 2               
0007BCr 2                 ; Add multiplicand to result
0007BCr 2  18             clc
0007BDr 2  A5 1C          lda BAS_SCRATCH
0007BFr 2  65 0C          adc BAS_AUX
0007C1r 2  85 1C          sta BAS_SCRATCH
0007C3r 2  A5 1D          lda BAS_SCRATCH + 1
0007C5r 2  65 0D          adc BAS_AUX + 1
0007C7r 2  85 1D          sta BAS_SCRATCH + 1
0007C9r 2               
0007C9r 2               @MulNoAdd:
0007C9r 2                 ; Shift multiplicand left
0007C9r 2  06 0C          asl BAS_AUX
0007CBr 2  26 0D          rol BAS_AUX + 1
0007CDr 2  CA             dex
0007CEr 2  D0 E6          bne @MulLoop
0007D0r 2               
0007D0r 2                 ; Copy result
0007D0r 2  A5 1C          lda BAS_SCRATCH
0007D2r 2  85 0A          sta BAS_ACC
0007D4r 2  A5 1D          lda BAS_SCRATCH + 1
0007D6r 2  85 0B          sta BAS_ACC + 1
0007D8r 2               
0007D8r 2                 ; Apply sign
0007D8r 2  A5 20          lda BAS_SIGN
0007DAr 2  10 03          bpl @MulDone
0007DCr 2  4C rr rr       jmp BasMathNeg
0007DFr 2               @MulDone:
0007DFr 2  60             rts
0007E0r 2               
0007E0r 2               ; BasMathDiv — ACC = AUX / ACC, remainder in BAS_SCRATCH2
0007E0r 2               ; 16-bit signed division
0007E0r 2               BasMathDiv:
0007E0r 2                 ; Check for division by zero
0007E0r 2  A5 0A          lda BAS_ACC
0007E2r 2  05 0B          ora BAS_ACC + 1
0007E4r 2  D0 05          bne @DivNotZero
0007E6r 2  A9 06          lda #ERR_DIV_ZERO
0007E8r 2  4C rr rr       jmp BasError
0007EBr 2               
0007EBr 2               @DivNotZero:
0007EBr 2                 ; Determine result sign
0007EBr 2  A5 0D          lda BAS_AUX + 1
0007EDr 2  45 0B          eor BAS_ACC + 1
0007EFr 2  85 20          sta BAS_SIGN
0007F1r 2               
0007F1r 2                 ; Save remainder sign (same as dividend) on CPU stack
0007F1r 2  A5 0D          lda BAS_AUX + 1
0007F3r 2  48             pha
0007F4r 2               
0007F4r 2                 ; Make both positive
0007F4r 2  A5 0D          lda BAS_AUX + 1
0007F6r 2  10 0D          bpl @DivAuxPos
0007F8r 2  38             sec
0007F9r 2  A9 00          lda #$00
0007FBr 2  E5 0C          sbc BAS_AUX
0007FDr 2  85 0C          sta BAS_AUX
0007FFr 2  A9 00          lda #$00
000801r 2  E5 0D          sbc BAS_AUX + 1
000803r 2  85 0D          sta BAS_AUX + 1
000805r 2               @DivAuxPos:
000805r 2  A5 0B          lda BAS_ACC + 1
000807r 2  10 03          bpl @DivAccPos
000809r 2  20 rr rr       jsr BasMathNeg
00080Cr 2               @DivAccPos:
00080Cr 2                 ; AUX = dividend, ACC = divisor
00080Cr 2                 ; Remainder in SCRATCH2
00080Cr 2  64 1E          stz BAS_SCRATCH2
00080Er 2  64 1F          stz BAS_SCRATCH2 + 1
000810r 2               
000810r 2  A2 10          ldx #16
000812r 2               
000812r 2               @DivLoop:
000812r 2                 ; Shift dividend left into remainder
000812r 2  06 0C          asl BAS_AUX
000814r 2  26 0D          rol BAS_AUX + 1
000816r 2  26 1E          rol BAS_SCRATCH2
000818r 2  26 1F          rol BAS_SCRATCH2 + 1
00081Ar 2               
00081Ar 2                 ; Try subtract divisor from remainder
00081Ar 2  38             sec
00081Br 2  A5 1E          lda BAS_SCRATCH2
00081Dr 2  E5 0A          sbc BAS_ACC
00081Fr 2  85 1C          sta BAS_SCRATCH
000821r 2  A5 1F          lda BAS_SCRATCH2 + 1
000823r 2  E5 0B          sbc BAS_ACC + 1
000825r 2               
000825r 2  90 08          bcc @DivNoSub
000827r 2               
000827r 2                 ; Subtraction succeeded — set quotient bit
000827r 2  85 1F          sta BAS_SCRATCH2 + 1
000829r 2  A5 1C          lda BAS_SCRATCH
00082Br 2  85 1E          sta BAS_SCRATCH2
00082Dr 2  E6 0C          inc BAS_AUX                    ; Set low bit of quotient
00082Fr 2               
00082Fr 2               @DivNoSub:
00082Fr 2  CA             dex
000830r 2  D0 E0          bne @DivLoop
000832r 2               
000832r 2                 ; Quotient is in AUX, remainder in SCRATCH2
000832r 2  A5 0C          lda BAS_AUX
000834r 2  85 0A          sta BAS_ACC
000836r 2  A5 0D          lda BAS_AUX + 1
000838r 2  85 0B          sta BAS_ACC + 1
00083Ar 2               
00083Ar 2                 ; Apply sign to quotient
00083Ar 2  A5 20          lda BAS_SIGN
00083Cr 2  10 03          bpl @DivQuotPos
00083Er 2  20 rr rr       jsr BasMathNeg
000841r 2               @DivQuotPos:
000841r 2                 ; Apply sign to remainder (same sign as dividend)
000841r 2  68             pla                            ; Remainder sign (was dividend's high byte)
000842r 2  10 0D          bpl @DivDone
000844r 2                 ; Negate remainder
000844r 2  38             sec
000845r 2  A9 00          lda #$00
000847r 2  E5 1E          sbc BAS_SCRATCH2
000849r 2  85 1E          sta BAS_SCRATCH2
00084Br 2  A9 00          lda #$00
00084Dr 2  E5 1F          sbc BAS_SCRATCH2 + 1
00084Fr 2  85 1F          sta BAS_SCRATCH2 + 1
000851r 2               @DivDone:
000851r 2  60             rts
000852r 2               
000852r 2               ; ============================================================================
000852r 2               ; Expression Evaluator — Recursive Descent
000852r 2               ; ============================================================================
000852r 2               ; Result always in BAS_ACC (16-bit signed).
000852r 2               ; TXTPTR is advanced past consumed tokens.
000852r 2               
000852r 2               ; BasExpr — Top level: handle OR
000852r 2               BasExpr:
000852r 2  20 rr rr       jsr BasExprAnd
000855r 2               @OrLoop:
000855r 2  20 rr rr       jsr BasSkipSpaces
000858r 2  20 rr rr       jsr BasGetTokChar
00085Br 2  C9 98          cmp #TOK_OR
00085Dr 2  D0 2E          bne @OrDone
00085Fr 2  20 rr rr       jsr BasAdvTxtPtr
000862r 2  A5 0A          lda BAS_ACC
000864r 2  48             pha
000865r 2  A5 0B          lda BAS_ACC + 1
000867r 2  48             pha
000868r 2  20 rr rr       jsr BasExprAnd
00086Br 2                 ; Pop left operand into AUX
00086Br 2  68             pla
00086Cr 2  85 0D          sta BAS_AUX + 1
00086Er 2  68             pla
00086Fr 2  85 0C          sta BAS_AUX
000871r 2                 ; OR: result = (AUX != 0) || (ACC != 0) ? 1 : 0
000871r 2  A5 0C          lda BAS_AUX
000873r 2  05 0D          ora BAS_AUX + 1
000875r 2  F0 04          beq @OrRight
000877r 2  A9 01          lda #$01
000879r 2  80 0C          bra @OrStore
00087Br 2               @OrRight:
00087Br 2  A5 0A          lda BAS_ACC
00087Dr 2  05 0B          ora BAS_ACC + 1
00087Fr 2  F0 04          beq @OrFalse
000881r 2  A9 01          lda #$01
000883r 2  80 02          bra @OrStore
000885r 2               @OrFalse:
000885r 2  A9 00          lda #$00
000887r 2               @OrStore:
000887r 2  85 0A          sta BAS_ACC
000889r 2  64 0B          stz BAS_ACC + 1
00088Br 2  80 C8          bra @OrLoop
00088Dr 2               @OrDone:
00088Dr 2  60             rts
00088Er 2               
00088Er 2               ; BasExprAnd — Handle AND
00088Er 2               BasExprAnd:
00088Er 2  20 rr rr       jsr BasExprNot
000891r 2               @AndLoop:
000891r 2  20 rr rr       jsr BasSkipSpaces
000894r 2  20 rr rr       jsr BasGetTokChar
000897r 2  C9 97          cmp #TOK_AND
000899r 2  D0 2C          bne @AndDone
00089Br 2  20 rr rr       jsr BasAdvTxtPtr
00089Er 2  A5 0A          lda BAS_ACC
0008A0r 2  48             pha
0008A1r 2  A5 0B          lda BAS_ACC + 1
0008A3r 2  48             pha
0008A4r 2  20 rr rr       jsr BasExprNot
0008A7r 2  68             pla
0008A8r 2  85 0D          sta BAS_AUX + 1
0008AAr 2  68             pla
0008ABr 2  85 0C          sta BAS_AUX
0008ADr 2                 ; AND: both nonzero = 1, else 0
0008ADr 2  A5 0C          lda BAS_AUX
0008AFr 2  05 0D          ora BAS_AUX + 1
0008B1r 2  F0 0E          beq @AndFalse
0008B3r 2  A5 0A          lda BAS_ACC
0008B5r 2  05 0B          ora BAS_ACC + 1
0008B7r 2  F0 08          beq @AndFalse
0008B9r 2  A9 01          lda #$01
0008BBr 2  64 0B          stz BAS_ACC + 1
0008BDr 2  85 0A          sta BAS_ACC
0008BFr 2  80 D0          bra @AndLoop
0008C1r 2               @AndFalse:
0008C1r 2  64 0A          stz BAS_ACC
0008C3r 2  64 0B          stz BAS_ACC + 1
0008C5r 2  80 CA          bra @AndLoop
0008C7r 2               @AndDone:
0008C7r 2  60             rts
0008C8r 2               
0008C8r 2               ; BasExprNot — Handle NOT (unary prefix)
0008C8r 2               BasExprNot:
0008C8r 2  20 rr rr       jsr BasSkipSpaces
0008CBr 2  20 rr rr       jsr BasGetTokChar
0008CEr 2  C9 96          cmp #TOK_NOT
0008D0r 2  D0 18          bne @NotSkip
0008D2r 2  20 rr rr       jsr BasAdvTxtPtr
0008D5r 2  20 rr rr       jsr BasExprCmp
0008D8r 2                 ; NOT: 0 -> 1, nonzero -> 0
0008D8r 2  A5 0A          lda BAS_ACC
0008DAr 2  05 0B          ora BAS_ACC + 1
0008DCr 2  F0 05          beq @NotTrue
0008DEr 2  64 0A          stz BAS_ACC
0008E0r 2  64 0B          stz BAS_ACC + 1
0008E2r 2  60             rts
0008E3r 2               @NotTrue:
0008E3r 2  A9 01          lda #$01
0008E5r 2  85 0A          sta BAS_ACC
0008E7r 2  64 0B          stz BAS_ACC + 1
0008E9r 2  60             rts
0008EAr 2               @NotSkip:
0008EAr 2  4C rr rr       jmp BasExprCmp
0008EDr 2               
0008EDr 2               ; BasExprCmp — Handle comparison: =, <>, <, >, <=, >=
0008EDr 2               BasExprCmp:
0008EDr 2  20 rr rr       jsr BasExprAdd
0008F0r 2  20 rr rr       jsr BasSkipSpaces
0008F3r 2  20 rr rr       jsr BasGetTokChar
0008F6r 2               
0008F6r 2                 ; Check each comparison operator
0008F6r 2  C9 3D          cmp #CH_EQUALS
0008F8r 2  F0 15          beq @CmpEQ
0008FAr 2  C9 3C          cmp #CH_LESS
0008FCr 2  F0 39          beq @CmpLT
0008FEr 2  C9 3E          cmp #CH_GREATER
000900r 2  F0 42          beq @CmpGT
000902r 2  C9 9C          cmp #TOK_NE
000904r 2  F0 1D          beq @CmpNE
000906r 2  C9 9B          cmp #TOK_LE
000908r 2  F0 49          beq @CmpLE
00090Ar 2  C9 9A          cmp #TOK_GE
00090Cr 2  F0 54          beq @CmpGE
00090Er 2  60             rts                            ; No comparison operator
00090Fr 2               
00090Fr 2               @CmpEQ:
00090Fr 2  20 rr rr       jsr BasAdvTxtPtr
000912r 2  20 rr rr       jsr @CmpPushEvalRight
000915r 2                 ; Equal: ACC == AUX
000915r 2  A5 0A          lda BAS_ACC
000917r 2  C5 0C          cmp BAS_AUX
000919r 2  D0 5B          bne @CmpSetFalse
00091Br 2  A5 0B          lda BAS_ACC + 1
00091Dr 2  C5 0D          cmp BAS_AUX + 1
00091Fr 2  D0 55          bne @CmpSetFalse
000921r 2  80 4C          bra @CmpSetTrue
000923r 2               
000923r 2               @CmpNE:
000923r 2  20 rr rr       jsr BasAdvTxtPtr
000926r 2  20 rr rr       jsr @CmpPushEvalRight
000929r 2  A5 0A          lda BAS_ACC
00092Br 2  C5 0C          cmp BAS_AUX
00092Dr 2  D0 40          bne @CmpSetTrue
00092Fr 2  A5 0B          lda BAS_ACC + 1
000931r 2  C5 0D          cmp BAS_AUX + 1
000933r 2  D0 3A          bne @CmpSetTrue
000935r 2  80 3F          bra @CmpSetFalse
000937r 2               
000937r 2               @CmpLT:
000937r 2  20 rr rr       jsr BasAdvTxtPtr
00093Ar 2  20 rr rr       jsr @CmpPushEvalRight
00093Dr 2  20 rr rr       jsr BasCmpAuxAcc
000940r 2  30 2D          bmi @CmpSetTrue
000942r 2  80 32          bra @CmpSetFalse
000944r 2               
000944r 2               @CmpGT:
000944r 2  20 rr rr       jsr BasAdvTxtPtr
000947r 2  20 rr rr       jsr @CmpPushEvalRight
00094Ar 2  20 rr rr       jsr BasCmpAuxAcc
00094Dr 2  F0 27          beq @CmpSetFalse
00094Fr 2  10 1E          bpl @CmpSetTrue
000951r 2  80 23          bra @CmpSetFalse
000953r 2               
000953r 2               @CmpLE:
000953r 2  20 rr rr       jsr BasAdvTxtPtr
000956r 2  20 rr rr       jsr @CmpPushEvalRight
000959r 2  20 rr rr       jsr BasCmpAuxAcc
00095Cr 2  30 11          bmi @CmpSetTrue
00095Er 2  F0 0F          beq @CmpSetTrue
000960r 2  80 14          bra @CmpSetFalse
000962r 2               
000962r 2               @CmpGE:
000962r 2  20 rr rr       jsr BasAdvTxtPtr
000965r 2  20 rr rr       jsr @CmpPushEvalRight
000968r 2  20 rr rr       jsr BasCmpAuxAcc
00096Br 2  10 02          bpl @CmpSetTrue
00096Dr 2  80 07          bra @CmpSetFalse
00096Fr 2               
00096Fr 2               @CmpSetTrue:
00096Fr 2  A9 01          lda #$01
000971r 2  85 0A          sta BAS_ACC
000973r 2  64 0B          stz BAS_ACC + 1
000975r 2  60             rts
000976r 2               @CmpSetFalse:
000976r 2  64 0A          stz BAS_ACC
000978r 2  64 0B          stz BAS_ACC + 1
00097Ar 2  60             rts
00097Br 2               
00097Br 2               ; Helper: push left, evaluate right into ACC, pop left into AUX
00097Br 2               @CmpPushEvalRight:
00097Br 2  A5 0A          lda BAS_ACC
00097Dr 2  48             pha
00097Er 2  A5 0B          lda BAS_ACC + 1
000980r 2  48             pha
000981r 2  20 rr rr       jsr BasExprAdd
000984r 2  68             pla
000985r 2  85 0D          sta BAS_AUX + 1
000987r 2  68             pla
000988r 2  85 0C          sta BAS_AUX
00098Ar 2  60             rts
00098Br 2               
00098Br 2               ; BasCmpAuxAcc — Signed compare AUX vs ACC
00098Br 2               ; Returns: N flag set if AUX < ACC, Z if equal, N clear & Z clear if AUX > ACC
00098Br 2               BasCmpAuxAcc:
00098Br 2                 ; Compare high bytes first (signed)
00098Br 2  A5 0D          lda BAS_AUX + 1
00098Dr 2  38             sec
00098Er 2  E5 0B          sbc BAS_ACC + 1
000990r 2  50 02          bvc @CmpNoOvf
000992r 2  49 80          eor #$80                       ; Fix sign on overflow
000994r 2               @CmpNoOvf:
000994r 2  30 0D          bmi @CmpLess
000996r 2  D0 08          bne @CmpGreater
000998r 2                 ; High bytes equal — compare low bytes (unsigned)
000998r 2  A5 0C          lda BAS_AUX
00099Ar 2  C5 0A          cmp BAS_ACC
00099Cr 2  F0 08          beq @CmpEqual
00099Er 2  90 03          bcc @CmpLess
0009A0r 2               @CmpGreater:
0009A0r 2  A9 01          lda #$01                       ; Positive, non-zero
0009A2r 2  60             rts
0009A3r 2               @CmpLess:
0009A3r 2  A9 FF          lda #$FF                       ; Negative
0009A5r 2  60             rts
0009A6r 2               @CmpEqual:
0009A6r 2  A9 00          lda #$00                       ; Zero
0009A8r 2  60             rts
0009A9r 2               
0009A9r 2               ; BasExprAdd — Handle + and -
0009A9r 2               BasExprAdd:
0009A9r 2  20 rr rr       jsr BasExprMul
0009ACr 2               @AddLoop:
0009ACr 2  20 rr rr       jsr BasSkipSpaces
0009AFr 2  20 rr rr       jsr BasGetTokChar
0009B2r 2  C9 2B          cmp #CH_PLUS
0009B4r 2  F0 05          beq @DoAdd
0009B6r 2  C9 2D          cmp #CH_MINUS
0009B8r 2  F0 19          beq @DoSub
0009BAr 2  60             rts
0009BBr 2               
0009BBr 2               @DoAdd:
0009BBr 2  20 rr rr       jsr BasAdvTxtPtr
0009BEr 2  A5 0A          lda BAS_ACC
0009C0r 2  48             pha
0009C1r 2  A5 0B          lda BAS_ACC + 1
0009C3r 2  48             pha
0009C4r 2  20 rr rr       jsr BasExprMul
0009C7r 2  68             pla
0009C8r 2  85 0D          sta BAS_AUX + 1
0009CAr 2  68             pla
0009CBr 2  85 0C          sta BAS_AUX
0009CDr 2  20 rr rr       jsr BasMathAdd
0009D0r 2  4C rr rr       jmp @AddLoop
0009D3r 2               
0009D3r 2               @DoSub:
0009D3r 2  20 rr rr       jsr BasAdvTxtPtr
