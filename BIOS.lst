000000r 1               
000000r 1               .segment "KERNAL"
000000r 1               .include "Kernal.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   KERNAL    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; === Kernal Jump Table ($A000-$A0FF) ===
000000r 2               ; 85 slots of 3-byte JMP instructions plus 1 padding byte
000000r 2               ; Provides stable entry points for external code and cartridges
000000r 2               
000000r 2               ; --- Character I/O ---
000000r 2  4C rr rr     Chrout:         jmp ChroutDispatch      ; $A000 - Output char (dispatched by IO_MODE)
000003r 2  4C rr rr     Chrin:          jmp ChrinImpl           ; $A003 - Input char from buffer
000006r 2  4C rr rr     WriteBuffer:    jmp WriteBufferImpl     ; $A006 - Write byte to input buffer
000009r 2  4C rr rr     ReadBuffer:     jmp ReadBufferImpl      ; $A009 - Read byte from input buffer
00000Cr 2  4C rr rr     BufferSize:     jmp BufferSizeImpl      ; $A00C - Get buffer count
00000Fr 2               ; --- IO Mode ---
00000Fr 2  4C rr rr     SetIOMode:      jmp SetIOModeImpl       ; $A00F - Set IO_MODE
000012r 2  4C rr rr     GetIOMode:      jmp GetIOModeImpl       ; $A012 - Get IO_MODE
000015r 2               ; --- Video (TMS9918) ---
000015r 2  4C rr rr     InitVideo:      jmp InitVideoImpl       ; $A015 - Initialize TMS9918
000018r 2  4C rr rr     VideoClear:     jmp VideoClearImpl      ; $A018 - Clear video screen
00001Br 2  4C rr rr     VideoPutChar:   jmp VideoPutCharImpl    ; $A01B - Write char at cursor
00001Er 2  4C rr rr     VideoSetCursor: jmp VideoSetCursorImpl  ; $A01E - Set cursor (X=col, Y=row)
000021r 2  4C rr rr     VideoGetCursor: jmp VideoGetCursorImpl  ; $A021 - Get cursor position
000024r 2  4C rr rr     VideoScroll:    jmp VideoScrollImpl     ; $A024 - Scroll screen up one line
000027r 2  4C rr rr     VideoSetColor:  jmp VideoSetColorImpl   ; $A027 - Set TMS9918 text color (A=reg7 byte: hi=fg, lo=bg)
00002Ar 2  4C rr rr     VideoChroutRaw: jmp VideoChroutRawImpl  ; $A02A - Output char to video (raw, no control-code handling)
00002Dr 2               ; --- Sound (SID) ---
00002Dr 2  4C rr rr     InitSID:        jmp InitSIDImpl         ; $A02D - Initialize SID
000030r 2  4C rr rr     Beep:           jmp BeepImpl            ; $A030 - Play beep tone
000033r 2  4C rr rr     SidPlayNote:    jmp SidPlayNoteImpl     ; $A033 - Play note (A=voice, X=freqLo, Y=freqHi)
000036r 2  4C rr rr     SidSilence:     jmp SidSilenceImpl      ; $A036 - Silence all voices
000039r 2  4C rr rr     SidSetVolume:   jmp SidSetVolumeImpl    ; $A039 - Set SID master volume (A=0-15)
00003Cr 2               ; --- Filesystem ---
00003Cr 2  4C rr rr     FsLoadFile:     jmp FsLoadFileImpl      ; $A03C - Load file from CF
00003Fr 2  4C rr rr     FsSaveFile:     jmp FsSaveFileImpl      ; $A03F - Save file to CF
000042r 2  4C rr rr     FsDeleteFile:   jmp FsDeleteFileImpl    ; $A042 - Delete file from CF
000045r 2               ; --- Keyboard / GPIO ---
000045r 2  4C rr rr     InitKB:         jmp InitKBImpl          ; $A045 - Initialize GPIO/VIA keyboard
000048r 2  4C rr rr     ReadJoystick1:  jmp ReadJoystick1Impl   ; $A048 - Read joystick 1
00004Br 2  4C rr rr     ReadJoystick2:  jmp ReadJoystick2Impl   ; $A04B - Read joystick 2
00004Er 2               ; --- Serial (6551) ---
00004Er 2  4C rr rr     InitSC:         jmp InitSCImpl          ; $A04E - Initialize serial 6551
000051r 2  4C rr rr     SerialChrout:   jmp SerialChroutImpl    ; $A051 - Direct serial output (bypass IO_MODE)
000054r 2  4C rr rr     AsciiLoad:      jmp AsciiLoadImpl       ; $A054 - Load raw binary via serial
000057r 2  4C rr rr     AsciiSave:      jmp AsciiSaveImpl       ; $A057 - Save raw binary via serial
00005Ar 2               ; --- RTC (DS1511Y) ---
00005Ar 2  4C rr rr     RtcReadTime:    jmp RtcReadTimeImpl     ; $A05A - Read RTC time
00005Dr 2  4C rr rr     RtcReadDate:    jmp RtcReadDateImpl     ; $A05D - Read RTC date
000060r 2  4C rr rr     RtcWriteTime:   jmp RtcWriteTimeImpl    ; $A060 - Set RTC time
000063r 2  4C rr rr     RtcWriteDate:   jmp RtcWriteDateImpl    ; $A063 - Set RTC date
000066r 2  4C rr rr     RtcReadNVRAM:   jmp RtcReadNVRAMImpl    ; $A066 - Read NVRAM byte
000069r 2  4C rr rr     RtcWriteNVRAM:  jmp RtcWriteNVRAMImpl   ; $A069 - Write NVRAM byte
00006Cr 2               ; --- CompactFlash Storage ---
00006Cr 2  4C rr rr     StReadSector:   jmp StReadSectorImpl    ; $A06C - Read CF sector
00006Fr 2  4C rr rr     StWriteSector:  jmp StWriteSectorImpl   ; $A06F - Write CF sector
000072r 2  4C rr rr     StWaitReady:    jmp StWaitReadyImpl     ; $A072 - Wait CF ready
000075r 2               ; --- System ---
000075r 2  4C rr rr     SysDelay:       jmp SysDelayImpl        ; $A075 - Delay A=cnt_lo, X=cnt_hi centiseconds
000078r 2  4C rr rr     KernalInit:     jmp KernalInitImpl      ; $A078 - Initialize all hardware (caller must reset SP; no cli, no splash); rts when done
00007Br 2  4C rr rr     KernalVersion:  jmp KernalVersionImpl   ; $A07B - Get BIOS version (A=major, X=minor)
00007Er 2               
00007Er 2               ; Reserved entries ($A07E-$A0FE)
00007Er 2  4C rr rr 4C  .repeat 43
000082r 2  rr rr 4C rr  
000086r 2  rr 4C rr rr  
0000FFr 2                               jmp UnimplementedStub
0000FFr 2               .endrepeat
0000FFr 2  00           .byte $00                             ; Pad to 256 bytes ($A0FF)
000100r 2               
000100r 2               ; === Kernal Implementation ===
000100r 2               
000100r 2               ; Stub for unimplemented jump table entries
000100r 2               UnimplementedStub:
000100r 2  60             rts
000101r 2               
000101r 2               ; Chrout dispatcher — routes output based on IO_MODE
000101r 2               ; Input: A = character to output
000101r 2               ; Modifies: Flags
000101r 2               ChroutDispatch:
000101r 2  48             pha
000102r 2  AD 06 03       lda IO_MODE
000105r 2  29 01          and #$01                      ; Bit 0: 0=video, 1=serial
000107r 2  D0 04          bne @Serial
000109r 2  68             pla
00010Ar 2  4C rr rr       jmp VideoChroutImpl
00010Dr 2               @Serial:
00010Dr 2  68             pla
00010Er 2  4C rr rr       jmp SerialChroutImpl
000111r 2               
000111r 2               ; Set IO_MODE
000111r 2               ; Input: A = mode (bit 0: 0=video, 1=serial)
000111r 2               SetIOModeImpl:
000111r 2  8D 06 03       sta IO_MODE
000114r 2  60             rts
000115r 2               
000115r 2               ; Get IO_MODE
000115r 2               ; Output: A = current IO_MODE
000115r 2               GetIOModeImpl:
000115r 2  AD 06 03       lda IO_MODE
000118r 2  60             rts
000119r 2               
000119r 2               ; === TMS9918 Video Driver ===
000119r 2               
000119r 2               ; VideoClear — Fill name table (960 bytes at VRAM $0000) with spaces, reset cursor to (0,0)
000119r 2               ; Modifies: Flags, A, X, Y
000119r 2               VideoClearImpl:
000119r 2                 ; Set VRAM write address to $0000 (name table base)
000119r 2  A9 00          lda #$00
00011Br 2  8D 01 9C       sta VC_REG
00011Er 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
000120r 2  8D 01 9C       sta VC_REG
000123r 2                 ; Fill 960 bytes with space ($20) — 3 full pages + 192 bytes
000123r 2  A9 20          lda #$20
000125r 2  A0 00          ldy #$00
000127r 2  A2 03          ldx #$03                      ; 3 full pages (768 bytes)
000129r 2               @VideoClearPage:
000129r 2  8D 00 9C       sta VC_DATA
00012Cr 2  C8             iny
00012Dr 2  D0 FA          bne @VideoClearPage
00012Fr 2  CA             dex
000130r 2  D0 F7          bne @VideoClearPage
000132r 2                 ; Remaining 192 bytes (960 - 768)
000132r 2  A0 C0          ldy #192
000134r 2               @VideoClearRem:
000134r 2  8D 00 9C       sta VC_DATA
000137r 2  88             dey
000138r 2  D0 FA          bne @VideoClearRem
00013Ar 2                 ; Reset cursor to (0,0)
00013Ar 2  9C 07 03       stz VID_CURSOR_X
00013Dr 2  9C 08 03       stz VID_CURSOR_Y
000140r 2  9C 09 03       stz VID_CURSOR_ADDR
000143r 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
000146r 2  60             rts
000147r 2               
000147r 2               ; VideoSetCursor — Set cursor position
000147r 2               ; Input: X = column (0-39), Y = row (0-23)
000147r 2               ; Calculates VRAM address = Y * 40 + X and stores in VID_CURSOR_ADDR
000147r 2               ; Modifies: Flags, A
000147r 2               VideoSetCursorImpl:
000147r 2  8E 07 03       stx VID_CURSOR_X
00014Ar 2  8C 08 03       sty VID_CURSOR_Y
00014Dr 2                 ; Calculate VRAM address = Y * 40 + X
00014Dr 2                 ; Y * 40 = Y * 32 + Y * 8
00014Dr 2  A9 00          lda #$00
00014Fr 2  8D 0A 03       sta VID_CURSOR_ADDR + 1       ; Clear high byte
000152r 2  98             tya                           ; A = row
000153r 2                 ; Multiply by 8: shift left 3
000153r 2  0A             asl a
000154r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000157r 2  0A             asl a
000158r 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Br 2  0A             asl a
00015Cr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00015Fr 2  8D 09 03       sta VID_CURSOR_ADDR           ; Store Y*8 low byte
000162r 2                 ; Save Y*8 for later addition
000162r 2  48             pha
000163r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
000166r 2  48             pha
000167r 2                 ; Multiply original row by 32: shift left 5 total (Y*8 << 2)
000167r 2  AD 09 03       lda VID_CURSOR_ADDR
00016Ar 2  0A             asl a
00016Br 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
00016Er 2  0A             asl a
00016Fr 2  2E 0A 03       rol VID_CURSOR_ADDR + 1
000172r 2  8D 09 03       sta VID_CURSOR_ADDR           ; Now holds Y*32 low byte
000175r 2                 ; Add Y*8 + Y*32
000175r 2  68             pla                           ; Restore Y*8 high byte
000176r 2  6D 0A 03       adc VID_CURSOR_ADDR + 1       ; Carry still valid from last rol
000179r 2  8D 0A 03       sta VID_CURSOR_ADDR + 1
00017Cr 2  68             pla                           ; Restore Y*8 low byte
00017Dr 2  18             clc
00017Er 2  6D 09 03       adc VID_CURSOR_ADDR
000181r 2  8D 09 03       sta VID_CURSOR_ADDR
000184r 2  90 03          bcc @NoCarry
000186r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000189r 2               @NoCarry:
000189r 2                 ; Add X (column)
000189r 2  8A             txa
00018Ar 2  18             clc
00018Br 2  6D 09 03       adc VID_CURSOR_ADDR
00018Er 2  8D 09 03       sta VID_CURSOR_ADDR
000191r 2  90 03          bcc @SetCursorDone
000193r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000196r 2               @SetCursorDone:
000196r 2  60             rts
000197r 2               
000197r 2               ; VideoGetCursor — Get cursor position
000197r 2               ; Output: X = column (0-39), Y = row (0-23)
000197r 2               ; Modifies: Flags
000197r 2               VideoGetCursorImpl:
000197r 2  AE 07 03       ldx VID_CURSOR_X
00019Ar 2  AC 08 03       ldy VID_CURSOR_Y
00019Dr 2  60             rts
00019Er 2               
00019Er 2               ; VideoPutChar — Write a single character to VRAM at VID_CURSOR_ADDR
00019Er 2               ; Input: A = character to write
00019Er 2               ; Modifies: Flags
00019Er 2               VideoPutCharImpl:
00019Er 2  48             pha
00019Fr 2                 ; Set VRAM write address from VID_CURSOR_ADDR
00019Fr 2  AD 09 03       lda VID_CURSOR_ADDR
0001A2r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
0001A5r 2  AD 0A 03       lda VID_CURSOR_ADDR + 1
0001A8r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001AAr 2  8D 01 9C       sta VC_REG                    ; High byte with write flag
0001ADr 2  68             pla
0001AEr 2  8D 00 9C       sta VC_DATA                   ; Write character to VRAM
0001B1r 2  60             rts
0001B2r 2               
0001B2r 2               ; VideoScroll — Scroll screen up one line
0001B2r 2               ; Copies VRAM rows 1-23 to rows 0-22 (920 bytes), clears row 23 with spaces
0001B2r 2               ; Uses SCROLL_BUF ($0320, 40 bytes) as temporary storage
0001B2r 2               ; Modifies: Flags, A, X, Y
0001B2r 2               VideoScrollImpl:
0001B2r 2                 ; Save STR_PTR (may be in use by caller, e.g. VideoPrintStr)
0001B2r 2  A5 02          lda STR_PTR
0001B4r 2  48             pha
0001B5r 2  A5 03          lda STR_PTR + 1
0001B7r 2  48             pha
0001B8r 2                 ; Source starts at row 1 (VRAM offset 40=$28), dest at row 0 (offset 0)
0001B8r 2                 ; We process 23 rows, copying each row up by one
0001B8r 2  A9 28          lda #<40                      ; Source address low = 40 (row 1)
0001BAr 2  85 02          sta STR_PTR
0001BCr 2  A9 00          lda #>40
0001BEr 2  85 03          sta STR_PTR + 1
0001C0r 2               
0001C0r 2  A2 17          ldx #23                       ; 23 rows to copy
0001C2r 2               @ScrollRowLoop:
0001C2r 2  DA             phx                           ; Save row counter
0001C3r 2               
0001C3r 2                 ; Set VRAM read address (source row)
0001C3r 2  A5 02          lda STR_PTR
0001C5r 2  8D 01 9C       sta VC_REG
0001C8r 2  A5 03          lda STR_PTR + 1
0001CAr 2  8D 01 9C       sta VC_REG                    ; Bit 6 clear = read mode
0001CDr 2                 ; Read 40 bytes into SCROLL_BUF
0001CDr 2  A0 00          ldy #$00
0001CFr 2               @ScrollRead:
0001CFr 2  AD 00 9C       lda VC_DATA
0001D2r 2  99 20 03       sta SCROLL_BUF,y
0001D5r 2  C8             iny
0001D6r 2  C0 28          cpy #40
0001D8r 2  D0 F5          bne @ScrollRead
0001DAr 2               
0001DAr 2                 ; Set VRAM write address (dest = source - 40)
0001DAr 2  A5 02          lda STR_PTR
0001DCr 2  38             sec
0001DDr 2  E9 28          sbc #40
0001DFr 2  8D 01 9C       sta VC_REG                    ; Dest address low
0001E2r 2  A5 03          lda STR_PTR + 1
0001E4r 2  E9 00          sbc #$00
0001E6r 2  09 40          ora #$40                      ; Set bit 6 for write mode
0001E8r 2  8D 01 9C       sta VC_REG                    ; Dest address high
0001EBr 2               
0001EBr 2                 ; Write 40 bytes from SCROLL_BUF
0001EBr 2  A0 00          ldy #$00
0001EDr 2               @ScrollWrite:
0001EDr 2  B9 20 03       lda SCROLL_BUF,y
0001F0r 2  8D 00 9C       sta VC_DATA
0001F3r 2  C8             iny
0001F4r 2  C0 28          cpy #40
0001F6r 2  D0 F5          bne @ScrollWrite
0001F8r 2               
0001F8r 2                 ; Advance source pointer by 40 for next row
0001F8r 2  A5 02          lda STR_PTR
0001FAr 2  18             clc
0001FBr 2  69 28          adc #40
0001FDr 2  85 02          sta STR_PTR
0001FFr 2  90 02          bcc @ScrollNoCarry
000201r 2  E6 03          inc STR_PTR + 1
000203r 2               @ScrollNoCarry:
000203r 2  FA             plx                           ; Restore row counter
000204r 2  CA             dex
000205r 2  D0 BB          bne @ScrollRowLoop
000207r 2               
000207r 2                 ; Clear bottom row (row 23) with spaces
000207r 2                 ; Row 23 address = 23 * 40 = 920 = $0398
000207r 2  A9 98          lda #$98                      ; Low byte of $0398
000209r 2  8D 01 9C       sta VC_REG
00020Cr 2  A9 03          lda #$03
00020Er 2  09 40          ora #$40                      ; Write mode
000210r 2  8D 01 9C       sta VC_REG
000213r 2  A9 20          lda #$20                      ; Space character
000215r 2  A0 28          ldy #40
000217r 2               @ScrollClearBottom:
000217r 2  8D 00 9C       sta VC_DATA
00021Ar 2  88             dey
00021Br 2  D0 FA          bne @ScrollClearBottom
00021Dr 2                 ; Restore STR_PTR
00021Dr 2  68             pla
00021Er 2  85 03          sta STR_PTR + 1
000220r 2  68             pla
000221r 2  85 02          sta STR_PTR
000223r 2  60             rts
000224r 2               
000224r 2               ; VideoChrout — Output character to video display
000224r 2               ; Handles control characters: CR ($0D), LF ($0A), BS ($08), BEL ($07)
000224r 2               ; Auto-wraps at column 40, auto-scrolls at row 24
000224r 2               ; Input: A = character to output
000224r 2               ; Preserves: A, X, Y (callers like ChrinImpl, BasPrintStr and Wozmon depend on this)
000224r 2               ; Modifies: Flags
000224r 2               VideoChroutImpl:
000224r 2  48             pha
000225r 2  DA             phx
000226r 2  5A             phy
000227r 2  C9 0D          cmp #$0D                      ; Carriage Return?
000229r 2  F0 43          beq @VideoCR
00022Br 2  C9 0A          cmp #$0A                      ; Line Feed?
00022Dr 2  F0 4C          beq @VideoLF
00022Fr 2  C9 08          cmp #$08                      ; Backspace?
000231r 2  F0 65          beq @VideoBS
000233r 2  C9 07          cmp #$07                      ; Bell?
000235r 2  F0 79          beq @VideoBEL
000237r 2                 ; Regular printable character — write at cursor and advance
000237r 2  20 rr rr       jsr VideoPutChar              ; Write char to VRAM at cursor
00023Ar 2                 ; Advance cursor
00023Ar 2  EE 07 03       inc VID_CURSOR_X
00023Dr 2                 ; Increment VRAM address
00023Dr 2  EE 09 03       inc VID_CURSOR_ADDR
000240r 2  D0 03          bne @CheckWrap
000242r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
000245r 2               @CheckWrap:
000245r 2  AD 07 03       lda VID_CURSOR_X
000248r 2  C9 28          cmp #40                       ; Past last column?
00024Ar 2  90 1E          bcc @VideoChroutDone          ; No, done
00024Cr 2                 ; Auto-wrap: CR + LF
00024Cr 2  9C 07 03       stz VID_CURSOR_X
00024Fr 2  EE 08 03       inc VID_CURSOR_Y
000252r 2  AD 08 03       lda VID_CURSOR_Y
000255r 2  C9 18          cmp #24                       ; Past last row?
000257r 2  90 08          bcc @WrapRecalc
000259r 2                 ; Need to scroll
000259r 2  20 rr rr       jsr VideoScroll
00025Cr 2  A9 17          lda #23
00025Er 2  8D 08 03       sta VID_CURSOR_Y
000261r 2               @WrapRecalc:
000261r 2  AE 07 03       ldx VID_CURSOR_X
000264r 2  AC 08 03       ldy VID_CURSOR_Y
000267r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
00026Ar 2               @VideoChroutDone:
00026Ar 2  7A             ply
00026Br 2  FA             plx
00026Cr 2  68             pla
00026Dr 2  60             rts
00026Er 2               
00026Er 2               @VideoCR:
00026Er 2  9C 07 03       stz VID_CURSOR_X              ; Column = 0
000271r 2  A2 00          ldx #$00
000273r 2  AC 08 03       ldy VID_CURSOR_Y
000276r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
000279r 2  80 EF          bra @VideoChroutDone
00027Br 2               
00027Br 2               @VideoLF:
00027Br 2  EE 08 03       inc VID_CURSOR_Y
00027Er 2  AD 08 03       lda VID_CURSOR_Y
000281r 2  C9 18          cmp #24                       ; Past last row?
000283r 2  90 08          bcc @LFRecalc
000285r 2  20 rr rr       jsr VideoScroll
000288r 2  A9 17          lda #23
00028Ar 2  8D 08 03       sta VID_CURSOR_Y
00028Dr 2               @LFRecalc:
00028Dr 2  AE 07 03       ldx VID_CURSOR_X
000290r 2  AC 08 03       ldy VID_CURSOR_Y
000293r 2  20 rr rr       jsr VideoSetCursor
000296r 2  80 D2          bra @VideoChroutDone
000298r 2               
000298r 2               @VideoBS:
000298r 2  AD 07 03       lda VID_CURSOR_X
00029Br 2  F0 CD          beq @VideoChroutDone          ; Already at column 0, ignore
00029Dr 2  CE 07 03       dec VID_CURSOR_X
0002A0r 2  AE 07 03       ldx VID_CURSOR_X
0002A3r 2  AC 08 03       ldy VID_CURSOR_Y
0002A6r 2  20 rr rr       jsr VideoSetCursor            ; Recalculate VRAM address
0002A9r 2  A9 20          lda #$20                      ; Write space to erase character
0002ABr 2  20 rr rr       jsr VideoPutChar
0002AEr 2  80 BA          bra @VideoChroutDone
0002B0r 2               
0002B0r 2               @VideoBEL:
0002B0r 2  20 rr rr       jsr Beep
0002B3r 2  80 B5          bra @VideoChroutDone
0002B5r 2               
0002B5r 2               ; VideoChroutRaw — Output character to video (raw, no control-code handling)
0002B5r 2               ; Always writes the character glyph at the cursor position and advances.
0002B5r 2               ; Input: A = character code (0-255)
0002B5r 2               ; Preserves: A, X, Y
0002B5r 2               ; Modifies: Flags
0002B5r 2               VideoChroutRawImpl:
0002B5r 2  48             pha
0002B6r 2  DA             phx
0002B7r 2  5A             phy
0002B8r 2  20 rr rr       jsr VideoPutChar              ; Write char to VRAM at cursor
0002BBr 2  EE 07 03       inc VID_CURSOR_X
0002BEr 2  EE 09 03       inc VID_CURSOR_ADDR
0002C1r 2  D0 03          bne @RawCheckWrap
0002C3r 2  EE 0A 03       inc VID_CURSOR_ADDR + 1
0002C6r 2               @RawCheckWrap:
0002C6r 2  AD 07 03       lda VID_CURSOR_X
0002C9r 2  C9 28          cmp #40                       ; Past last column?
0002CBr 2  90 1E          bcc @RawDone
0002CDr 2  9C 07 03       stz VID_CURSOR_X
0002D0r 2  EE 08 03       inc VID_CURSOR_Y
0002D3r 2  AD 08 03       lda VID_CURSOR_Y
0002D6r 2  C9 18          cmp #24                       ; Past last row?
0002D8r 2  90 08          bcc @RawRecalc
0002DAr 2  20 rr rr       jsr VideoScroll
0002DDr 2  A9 17          lda #23
0002DFr 2  8D 08 03       sta VID_CURSOR_Y
0002E2r 2               @RawRecalc:
0002E2r 2  AE 07 03       ldx VID_CURSOR_X
0002E5r 2  AC 08 03       ldy VID_CURSOR_Y
0002E8r 2  20 rr rr       jsr VideoSetCursor
0002EBr 2               @RawDone:
0002EBr 2  7A             ply
0002ECr 2  FA             plx
0002EDr 2  68             pla
0002EEr 2  60             rts
0002EFr 2               
0002EFr 2               ; VideoPrintStr — Print null-terminated string to video
0002EFr 2               ; Input: STR_PTR ($02-$03) points to string
0002EFr 2               ; Modifies: Flags, A, X, Y
0002EFr 2               VideoPrintStrImpl:
0002EFr 2  A0 00          ldy #$00
0002F1r 2               @VideoPrintStrLoop:
0002F1r 2  B1 02          lda (STR_PTR),y
0002F3r 2  F0 08          beq @VideoPrintStrDone        ; Exit on null terminator
0002F5r 2  5A             phy
0002F6r 2  20 rr rr       jsr VideoChroutImpl           ; Output character via video
0002F9r 2  7A             ply
0002FAr 2  C8             iny
0002FBr 2  D0 F4          bne @VideoPrintStrLoop        ; Max 256 chars per string
0002FDr 2               @VideoPrintStrDone:
0002FDr 2  60             rts
0002FEr 2               
0002FEr 2               ; KernalInit — Initialize RAM variables, probe & init all hardware
0002FEr 2               ; Sets HW_PRESENT, IO_MODE, IRQ/BRK/NMI pointers, BOOT_VECTOR=0
0002FEr 2               ; Does NOT enable interrupts (caller must cli)
0002FEr 2               ; Does NOT reset the stack pointer (caller should do this before JSR)
0002FEr 2               ; Does NOT display splash or enter boot menu
0002FEr 2               ; Modifies: All registers, flags
0002FEr 2               KernalInitImpl:
0002FEr 2  D8             cld                           ; Clear decimal mode
0002FFr 2  78             sei                           ; Disable interrupts
000300r 2               
000300r 2  A9 rr          lda #<Irq                     ; Initialize the IRQ pointer
000302r 2  8D 00 03       sta IRQ_PTR
000305r 2  A9 rr          lda #>Irq
000307r 2  8D 01 03       sta IRQ_PTR + 1
00030Ar 2               
00030Ar 2  A9 rr          lda #<Break                   ; Initialize the BRK pointer
00030Cr 2  8D 02 03       sta BRK_PTR
00030Fr 2  A9 rr          lda #>Break
000311r 2  8D 03 03       sta BRK_PTR + 1
000314r 2               
000314r 2  A9 rr          lda #<Nmi                     ; Initialize the NMI pointer
000316r 2  8D 04 03       sta NMI_PTR
000319r 2  A9 rr          lda #>Nmi
00031Br 2  8D 05 03       sta NMI_PTR + 1
00031Er 2               
00031Er 2  9C 0D 03       stz HW_PRESENT                ; Clear all hardware flags
000321r 2  9C 5B 03       stz BOOT_VECTOR               ; Clear boot redirect vector
000324r 2  9C 5C 03       stz BOOT_VECTOR + 1
000327r 2               
000327r 2  20 rr rr       jsr InitBuffer                ; Initialize the input buffer (RAM-only, no hardware)
00032Ar 2               
00032Ar 2  20 rr rr       jsr ProbeRAM                  ; Sets HW_RAM_L / HW_RAM_H if present (no init needed)
00032Dr 2               
00032Dr 2  20 rr rr       jsr ProbeRTC                  ; Sets HW_RTC if present (no init needed)
000330r 2               
000330r 2  20 rr rr       jsr StInit                    ; CF: timeout will handle absent card in Phase 3, sets HW_CF on success
000333r 2               
000333r 2  20 rr rr       jsr ProbeSerial               ; Sets HW_SC if present
000336r 2  AD 0D 03       lda HW_PRESENT
000339r 2  29 10          and #HW_SC
00033Br 2  F0 03          beq @SkipSerial
00033Dr 2  20 rr rr       jsr InitSCImpl
000340r 2               @SkipSerial:
000340r 2               
000340r 2  20 rr rr       jsr ProbeGPIO                 ; Sets HW_GPIO if present
000343r 2  AD 0D 03       lda HW_PRESENT
000346r 2  29 20          and #HW_GPIO
000348r 2  F0 03          beq @SkipGPIO
00034Ar 2  20 rr rr       jsr InitKBImpl
00034Dr 2               @SkipGPIO:
00034Dr 2               
00034Dr 2  20 rr rr       jsr ProbeSID                  ; Sets HW_SID if present
000350r 2  AD 0D 03       lda HW_PRESENT
000353r 2  29 40          and #HW_SID
000355r 2  F0 03          beq @SkipSID
000357r 2  20 rr rr       jsr InitSIDImpl
00035Ar 2               @SkipSID:
00035Ar 2               
00035Ar 2  20 rr rr       jsr ProbeVideo                ; Sets HW_VID if present
00035Dr 2  AD 0D 03       lda HW_PRESENT
000360r 2  29 80          and #HW_VID
000362r 2  F0 06          beq @SkipVideo
000364r 2  20 rr rr       jsr InitVideoImpl
000367r 2  20 rr rr       jsr InitCharacters
00036Ar 2               @SkipVideo:
00036Ar 2               
00036Ar 2                 ; Console auto-detection — determine IO_MODE from available hardware
00036Ar 2  AD 0D 03       lda HW_PRESENT
00036Dr 2  29 80          and #HW_VID
00036Fr 2  D0 09          bne @ConsoleVideo             ; Video present — use it
000371r 2  AD 0D 03       lda HW_PRESENT
000374r 2  29 10          and #HW_SC
000376r 2  D0 15          bne @ConsoleSerial            ; Serial present — use it
000378r 2                 ; Neither video nor serial — IO_MODE left as-is (no console)
000378r 2  80 18          bra @ConsoleDone
00037Ar 2               
00037Ar 2               @ConsoleVideo:
00037Ar 2  A9 00          lda #$00                      ; IO_MODE = video
00037Cr 2  8D 06 03       sta IO_MODE
00037Fr 2  9C 07 03       stz VID_CURSOR_X
000382r 2  9C 08 03       stz VID_CURSOR_Y
000385r 2  9C 09 03       stz VID_CURSOR_ADDR
000388r 2  9C 0A 03       stz VID_CURSOR_ADDR + 1
00038Br 2  80 05          bra @ConsoleDone
00038Dr 2               
00038Dr 2               @ConsoleSerial:
00038Dr 2  A9 01          lda #$01                      ; IO_MODE = serial
00038Fr 2  8D 06 03       sta IO_MODE
000392r 2               
000392r 2               @ConsoleDone:
000392r 2  60             rts
000393r 2               
000393r 2               ; KernalVersion — Return BIOS version in registers
000393r 2               ; Output: A = major version, X = minor version
000393r 2               ; Modifies: A, X
000393r 2               KernalVersionImpl:
000393r 2  A9 01          lda #BIOS_VERSION_MAJOR
000395r 2  A2 00          ldx #BIOS_VERSION_MINOR
000397r 2  60             rts
000398r 2               
000398r 2               ; Reset — Full system startup: init hardware, beep, check boot vector, splash, boot menu
000398r 2               Reset:
000398r 2  A2 FF          ldx #$ff
00039Ar 2  9A             txs                           ; Reset the stack pointer
00039Br 2  20 rr rr       jsr KernalInitImpl            ; Initialize all hardware (leaves interrupts disabled)
00039Er 2               
00039Er 2  20 rr rr       jsr Beep                      ; Play the startup beep (guarded — skips if no SID)
0003A1r 2               
0003A1r 2                 ; Check boot redirect vector — cartridges set this before jumping to Reset
0003A1r 2  AD 5B 03       lda BOOT_VECTOR
0003A4r 2  0D 5C 03       ora BOOT_VECTOR + 1
0003A7r 2  F0 03          beq @NormalBoot               ; Zero — continue normal boot
0003A9r 2  6C 5B 03       jmp (BOOT_VECTOR)             ; Non-zero — jump to cartridge/external program
0003ACr 2               
0003ACr 2               @NormalBoot:
0003ACr 2                 ; Verify console is available for interactive boot
0003ACr 2  AD 0D 03       lda HW_PRESENT
0003AFr 2  29 90          and #(HW_VID | HW_SC)
0003B1r 2  D0 02          bne @HasConsole
0003B3r 2                 ; Neither video nor serial — halt (no console for interactive boot)
0003B3r 2               @Halt:
0003B3r 2  80 FE          bra @Halt
0003B5r 2               
0003B5r 2               @HasConsole:
0003B5r 2  20 rr rr       jsr Splash                    ; Draw the splash screen (guarded — skips if no video)
0003B8r 2               
0003B8r 2  58             cli                           ; Enable interrupts
0003B9r 2               
0003B9r 2                 ; Boot menu — wait for keypress with ~5-second timeout
0003B9r 2                 ; Each iteration delays 100ms then checks for a key. 50 iterations = 5 seconds.
0003B9r 2  A2 32          ldx #50                       ; Timeout counter: 50 × 100ms = 5 seconds
0003BBr 2               @BootWait:
0003BBr 2  DA             phx                           ; Save timeout counter
0003BCr 2  A9 0A          lda #10                       ; 10 centiseconds (100ms)
0003BEr 2  A2 00          ldx #$00                      ; High byte = 0
0003C0r 2  20 rr rr       jsr SysDelay
0003C3r 2  20 rr rr       jsr BufferSize                ; A = bytes in buffer
0003C6r 2  FA             plx                           ; Restore timeout counter (clobbers Z flag)
0003C7r 2  C9 00          cmp #$00                      ; Re-test buffer size — plx overwrote Z
0003C9r 2  D0 05          bne @BootGotKey               ; Key available — process it
0003CBr 2  CA             dex
0003CCr 2  D0 ED          bne @BootWait                 ; No key yet — keep waiting
0003CEr 2  80 10          bra @BootBASIC                ; Timeout — auto-boot BASIC
0003D0r 2               
0003D0r 2               @BootGotKey:
0003D0r 2  20 rr rr       jsr ReadBuffer                ; Read the keypress
0003D3r 2  C9 0D          cmp #$0D                      ; ENTER?
0003D5r 2  F0 09          beq @BootBASIC
0003D7r 2  C9 1B          cmp #$1B                      ; ESC?
0003D9r 2  F0 0B          beq @BootMonitor
0003DBr 2  CA             dex                           ; Consumed a non-menu key — decrement counter
0003DCr 2  D0 DD          bne @BootWait                 ; Keep waiting if time remains
0003DEr 2  80 00          bra @BootBASIC                ; Timeout — auto-boot BASIC
0003E0r 2               
0003E0r 2               @BootBASIC:
0003E0r 2  20 rr rr       jsr VideoClear                ; Clear screen (harmless if no video)
0003E3r 2  4C rr rr       jmp BasEntry
0003E6r 2               @BootMonitor:
0003E6r 2  00             brk                           ; Enter monitor through BRK vector (saves/displays registers)
0003E7r 2               
0003E7r 2               ; Initialize the Keyboard via VIA (IO 6)
0003E7r 2               ; Configures Port B (matrix) and Port A (PS/2) as inputs
0003E7r 2               ; CB2 low (enable matrix encoder), CA2 low (enable PS/2 encoder)
0003E7r 2               ; CB1 and CA1 falling-edge IRQs enabled
0003E7r 2               ; Modifies: Flags, A
0003E7r 2               InitKBImpl:
0003E7r 2  A9 00          lda #$00                      ; Port B all inputs (matrix keyboard data bus)
0003E9r 2  8D 02 94       sta GPIO_DDRB
0003ECr 2  A9 00          lda #$00                      ; Port A all inputs (PS/2 keyboard data bus)
0003EEr 2  8D 03 94       sta GPIO_DDRA
0003F1r 2                 ; PCR: CB2 low + CB1 neg + CA2 low + CA1 neg
0003F1r 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0003F3r 2  8D 0C 94       sta GPIO_PCR
0003F6r 2                 ; Enable both CB1 and CA1 interrupts
0003F6r 2  A9 92          lda #(GPIO_IER_SET | GPIO_INT_CB1 | GPIO_INT_CA1)
0003F8r 2  8D 0E 94       sta GPIO_IER
0003FBr 2  60             rts
0003FCr 2               
0003FCr 2               ; Initialize the Serial Card (6551)
0003FCr 2               ; Modifies: Flags, A
0003FCr 2               InitSCImpl:
0003FCr 2  A9 1F          lda     #$1F                  ; 8-N-1, 19200 baud
0003FEr 2  8D 03 90       sta     SC_CTRL
000401r 2  A9 09          lda     #$09                  ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
000403r 2  8D 02 90       sta     SC_CMD
000406r 2  60             rts
000407r 2               
000407r 2               ; Initialze the Sound Card (6581)
000407r 2               ; Modifies: Flags, A, X
000407r 2               InitSIDImpl:
000407r 2  A9 00          lda #$00
000409r 2  A2 1D          ldx #$1D                      ; Clear all 29 SID registers
00040Br 2               @InitSIDLoop:
00040Br 2  9D 00 98       sta SID_V1_FREQ_LO,x          ; Clear register
00040Er 2  CA             dex
00040Fr 2  10 FA          bpl @InitSIDLoop              ; Loop until all registers cleared
000411r 2  A9 0F          lda #$0F                      ; Set volume to maximum
000413r 2  8D 18 98       sta SID_MODE_VOL
000416r 2  60             rts
000417r 2               
000417r 2               ; Initialize the Video Card (TMS9918)
000417r 2               ; Modifies: Flags, A, X
000417r 2               InitVideoImpl:
000417r 2  A2 00          ldx #$00                      ; Start with register 0
000419r 2               @InitVideoLoop:
000419r 2  BD rr rr       lda @InitVideoRegData,x       ; Load register value
00041Cr 2  8D 01 9C       sta VC_REG                    ; Write data byte
00041Fr 2  8A             txa
000420r 2  09 80          ora #$80                      ; Set bit 7 to indicate register write
000422r 2  8D 01 9C       sta VC_REG                    ; Write register number
000425r 2  E8             inx
000426r 2  E0 08          cpx #$08                      ; Check if all 8 registers written
000428r 2  D0 EF          bne @InitVideoLoop            ; Continue until done
00042Ar 2  60             rts
00042Br 2               @InitVideoRegData:
00042Br 2  00             .byte $00                     ; R0: Mode control (no external video)
00042Cr 2  D0             .byte $D0                     ; R1: 16K, display on, interrupt off, text mode M1
00042Dr 2  00             .byte $00                     ; R2: Name table at $0000 (0x00 * 0x400)
00042Er 2  00             .byte $00                     ; R3: Color table (not used in text mode)
00042Fr 2  01             .byte $01                     ; R4: Pattern table at $0800 (0x01 * 0x800)
000430r 2  00             .byte $00                     ; R5: Sprite attribute table (not used in text mode)
000431r 2  00             .byte $00                     ; R6: Sprite pattern table (not used in text mode)
000432r 2  1F             .byte $1F                     ; R7: Black text on white background
000433r 2               
000433r 2               ; Initialize the character set
000433r 2               ; Modifies: Flags, A, X, Y
000433r 2               InitCharacters:
000433r 2                 ; Set VRAM write address to $0800 (pattern table base)
000433r 2  A9 00          lda #$00                      ; Low byte of address
000435r 2  8D 01 9C       sta VC_REG
000438r 2  A9 48          lda #$48                      ; High byte ($08) OR $40 for write mode
00043Ar 2  8D 01 9C       sta VC_REG
00043Dr 2                 ; Set up source pointer
00043Dr 2  A9 rr          lda #<CharacterSet
00043Fr 2  85 02          sta STR_PTR                   ; Use STR_PTR ($02-$03) for character set pointer
000441r 2  A9 rr          lda #>CharacterSet
000443r 2  85 03          sta STR_PTR + 1
000445r 2                 ; Copy 2048 bytes (8 pages of 256 bytes each)
000445r 2  A2 08          ldx #$08                      ; 8 pages to copy
000447r 2  A0 00          ldy #$00                      ; Byte counter within page
000449r 2               @InitCharPageLoop:
000449r 2  B1 02          lda (STR_PTR),y               ; Load from character set
00044Br 2  8D 00 9C       sta VC_DATA                   ; Write to VRAM
00044Er 2  C8             iny
00044Fr 2  D0 F8          bne @InitCharPageLoop         ; Loop until page complete (256 bytes)
000451r 2  E6 03          inc STR_PTR + 1               ; Move to next page
000453r 2  CA             dex
000454r 2  D0 F3          bne @InitCharPageLoop         ; Loop for all 8 pages
000456r 2  60             rts
000457r 2               
000457r 2               ; Initialize the INPUT_BUFFER
000457r 2               ; Modifies: Flags, A
000457r 2               InitBuffer:
000457r 2  A9 00          lda #$00
000459r 2  85 00          sta READ_PTR                  ; Init read and write pointers
00045Br 2  85 01          sta WRITE_PTR
00045Dr 2  60             rts
00045Er 2               
00045Er 2               ; Write a character from the A register to the INPUT_BUFFER
00045Er 2               ; Modifies: Flags, X
00045Er 2               WriteBufferImpl:
00045Er 2  A6 01          ldx WRITE_PTR
000460r 2  9D 00 02       sta INPUT_BUFFER,x
000463r 2  E6 01          inc WRITE_PTR
000465r 2  60             rts
000466r 2               
000466r 2               ; Read a character from the INPUT_BUFFER and store it in A register
000466r 2               ; Modifies: Flags, X, A
000466r 2               ReadBufferImpl:
000466r 2  A6 00          ldx READ_PTR
000468r 2  BD 00 02       lda INPUT_BUFFER,x
00046Br 2  E6 00          inc READ_PTR
00046Dr 2  60             rts
00046Er 2               
00046Er 2               ; Return in A register the number of unread bytes in the INPUT_BUFFER
00046Er 2               ; Modifies: Flags, A
00046Er 2               BufferSizeImpl:
00046Er 2  A5 01          lda WRITE_PTR
000470r 2  38             sec
000471r 2  E5 00          sbc READ_PTR
000473r 2  60             rts
000474r 2               
000474r 2               ; Get a character from the INPUT_BUFFER if available
000474r 2               ; On return, carry flag indicates whether a character was available
000474r 2               ; If character available the character will be in the A register
000474r 2               ; Modifies: Flags, A
000474r 2               ChrinImpl:
000474r 2  DA             phx
000475r 2  20 rr rr       jsr BufferSize                ; Check for character available
000478r 2  F0 2C          beq @ChrinNoChar              ; Branch if no character available
00047Ar 2  20 rr rr       jsr ReadBuffer                ; Read the character from the buffer
00047Dr 2  20 rr rr       jsr Chrout                    ; Echo
000480r 2  48             pha
000481r 2  20 rr rr       jsr BufferSize
000484r 2  C9 B0          cmp #$B0                      ; Check if buffer is mostly full
000486r 2  90 0E          bcc @ChrinNotFull             ; Branch if buffer size < $B0
000488r 2                 ; Only touch SC_CMD if serial is present
000488r 2  AD 0D 03       lda HW_PRESENT
00048Br 2  29 10          and #HW_SC
00048Dr 2  F0 13          beq @ChrinExit
00048Fr 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
000491r 2  8D 02 90       sta SC_CMD
000494r 2  80 0C          bra @ChrinExit
000496r 2               @ChrinNotFull:
000496r 2  AD 0D 03       lda HW_PRESENT
000499r 2  29 10          and #HW_SC
00049Br 2  F0 05          beq @ChrinExit
00049Dr 2  A9 09          lda #$09                      ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
00049Fr 2  8D 02 90       sta SC_CMD
0004A2r 2               @ChrinExit:
0004A2r 2  68             pla
0004A3r 2  FA             plx
0004A4r 2  38             sec
0004A5r 2  60             rts
0004A6r 2               @ChrinNoChar:
0004A6r 2  FA             plx
0004A7r 2  18             clc
0004A8r 2  60             rts
0004A9r 2               
0004A9r 2               ; Output a character from the A register to the Serial Card
0004A9r 2               ; Modifies: Flags
0004A9r 2               SerialChroutImpl:
0004A9r 2  8D 00 90       sta SC_DATA
0004ACr 2  48             pha
0004ADr 2               @ChroutWait:
0004ADr 2  AD 01 90       lda SC_STATUS
0004B0r 2  29 10          and #SC_STATUS_TDRE           ; Check if TX buffer not empty
0004B2r 2  F0 F9          beq @ChroutWait               ; Loop if TX buffer not empty
0004B4r 2  68             pla
0004B5r 2  60             rts
0004B6r 2               
0004B6r 2               ; SidPlayNote — Play a note on a SID voice
0004B6r 2               ; Input: A = voice (0-2), X = frequency low byte, Y = frequency high byte
0004B6r 2               ; Uses triangle waveform with standard ADSR (Attack=0, Decay=9, Sustain=A, Release=2)
0004B6r 2               ; Modifies: Flags, A
0004B6r 2               SidPlayNoteImpl:
0004B6r 2  C9 01          cmp #$01
0004B8r 2  F0 1A          beq @Voice2
0004BAr 2  C9 02          cmp #$02
0004BCr 2  F0 2C          beq @Voice3
0004BEr 2                 ; Voice 0
0004BEr 2  8E 00 98       stx SID_V1_FREQ_LO
0004C1r 2  8C 01 98       sty SID_V1_FREQ_HI
0004C4r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
0004C6r 2  8D 05 98       sta SID_V1_AD
0004C9r 2  A9 A2          lda #$A2                      ; Sustain = A, Release = 2
0004CBr 2  8D 06 98       sta SID_V1_SR
0004CEr 2  A9 11          lda #$11                      ; Triangle wave + Gate on
0004D0r 2  8D 04 98       sta SID_V1_CTRL
0004D3r 2  60             rts
0004D4r 2               @Voice2:
0004D4r 2  8E 07 98       stx SID_V2_FREQ_LO
0004D7r 2  8C 08 98       sty SID_V2_FREQ_HI
0004DAr 2  A9 09          lda #$09
0004DCr 2  8D 0C 98       sta SID_V2_AD
0004DFr 2  A9 A2          lda #$A2
0004E1r 2  8D 0D 98       sta SID_V2_SR
0004E4r 2  A9 11          lda #$11
0004E6r 2  8D 0B 98       sta SID_V2_CTRL
0004E9r 2  60             rts
0004EAr 2               @Voice3:
0004EAr 2  8E 0E 98       stx SID_V3_FREQ_LO
0004EDr 2  8C 0F 98       sty SID_V3_FREQ_HI
0004F0r 2  A9 09          lda #$09
0004F2r 2  8D 13 98       sta SID_V3_AD
0004F5r 2  A9 A2          lda #$A2
0004F7r 2  8D 14 98       sta SID_V3_SR
0004FAr 2  A9 11          lda #$11
0004FCr 2  8D 12 98       sta SID_V3_CTRL
0004FFr 2  60             rts
000500r 2               
000500r 2               ; SidSilence — Silence all 3 SID voices
000500r 2               ; Gates off all voices and zeros their frequencies
000500r 2               ; Modifies: Flags, A
000500r 2               SidSilenceImpl:
000500r 2  A9 10          lda #$10                      ; Triangle wave, Gate off
000502r 2  8D 04 98       sta SID_V1_CTRL
000505r 2  8D 0B 98       sta SID_V2_CTRL
000508r 2  8D 12 98       sta SID_V3_CTRL
00050Br 2  A9 00          lda #$00
00050Dr 2  8D 00 98       sta SID_V1_FREQ_LO
000510r 2  8D 01 98       sta SID_V1_FREQ_HI
000513r 2  8D 07 98       sta SID_V2_FREQ_LO
000516r 2  8D 08 98       sta SID_V2_FREQ_HI
000519r 2  8D 0E 98       sta SID_V3_FREQ_LO
00051Cr 2  8D 0F 98       sta SID_V3_FREQ_HI
00051Fr 2  60             rts
000520r 2               
000520r 2               ; Play a short beep sound
000520r 2               ; Uses SidPlayNote on voice 0 with ~475 Hz tone, then silences
000520r 2               ; Skips silently if SID is absent
000520r 2               ; Modifies: Flags, A, X, Y
000520r 2               BeepImpl:
000520r 2  AD 0D 03       lda HW_PRESENT
000523r 2  29 40          and #HW_SID
000525r 2  D0 01          bne @BeepStart
000527r 2  60             rts                           ; No SID — skip silently
000528r 2               @BeepStart:
000528r 2  A9 00          lda #$00                      ; Voice 0
00052Ar 2  A2 20          ldx #$20                      ; Frequency low byte (~475 Hz)
00052Cr 2  A0 1F          ldy #$1F                      ; Frequency high byte
00052Er 2  20 rr rr       jsr SidPlayNote
000531r 2                 ; Override ADSR for beep: fast decay, no sustain
000531r 2  A9 09          lda #$09                      ; Attack = 0, Decay = 9
000533r 2  8D 05 98       sta SID_V1_AD
000536r 2  A9 00          lda #$00                      ; Sustain = 0, Release = 0
000538r 2  8D 06 98       sta SID_V1_SR
00053Br 2                 ; Delay for beep duration
00053Br 2  A2 F0          ldx #$F0                      ; Outer loop counter
00053Dr 2               @BeepDelay1:
00053Dr 2  A0 FF          ldy #$FF                      ; Inner loop counter
00053Fr 2               @BeepDelay2:
00053Fr 2  88             dey
000540r 2  D0 FD          bne @BeepDelay2
000542r 2  CA             dex
000543r 2  D0 F8          bne @BeepDelay1
000545r 2  20 rr rr       jsr SidSilence                ; Gate off all voices
000548r 2  60             rts
000549r 2               
000549r 2               ; SysDelay — Delay for a specified number of centiseconds
000549r 2               ; Input: A = count low byte, X = count high byte
000549r 2               ; Uses VIA T1 in one-shot mode. 9999 cycles @ 1MHz = ~10ms per tick.
000549r 2               ; Modifies: Flags, A
000549r 2               SysDelayImpl:
000549r 2  85 2C          sta DELAY_CNT
00054Br 2  86 2D          stx DELAY_CNT + 1
00054Dr 2                 ; Return immediately if count is zero
00054Dr 2  05 2D          ora DELAY_CNT + 1
00054Fr 2  F0 4F          beq @DelayDone
000551r 2                 ; Check if VIA is present for hardware timer
000551r 2  AD 0D 03       lda HW_PRESENT
000554r 2  29 20          and #HW_GPIO
000556r 2  D0 19          bne @DelayHardware
000558r 2                 ; Software fallback — calibrated busy loop (~10ms per centisecond at 1MHz)
000558r 2                 ; Inner loop: 5 cycles × 256 iterations × 8 = ~10240 cycles ≈ 10ms
000558r 2               @DelaySoftLoop:
000558r 2  A0 00          ldy #$00                      ; 256 outer iterations
00055Ar 2  A2 08          ldx #8
00055Cr 2               @DelaySoftInner:
00055Cr 2  88             dey
00055Dr 2  D0 FD          bne @DelaySoftInner
00055Fr 2  CA             dex
000560r 2  D0 FA          bne @DelaySoftInner
000562r 2                 ; 16-bit decrement of DELAY_CNT
000562r 2  A5 2C          lda DELAY_CNT
000564r 2  D0 02          bne @SoftDecLo
000566r 2  C6 2D          dec DELAY_CNT + 1
000568r 2               @SoftDecLo:
000568r 2  C6 2C          dec DELAY_CNT
00056Ar 2  A5 2C          lda DELAY_CNT
00056Cr 2  05 2D          ora DELAY_CNT + 1
00056Er 2  D0 E8          bne @DelaySoftLoop
000570r 2  60             rts
000571r 2               @DelayHardware:
000571r 2                 ; Configure T1 one-shot mode: clear ACR bit 6
000571r 2  AD 0B 94       lda GPIO_ACR
000574r 2  29 BF          and #%10111111
000576r 2  8D 0B 94       sta GPIO_ACR
000579r 2               @DelayLoop:
000579r 2                 ; Load T1 latch: 9999 = $270F
000579r 2  A9 0F          lda #$0F
00057Br 2  8D 06 94       sta GPIO_T1LL
00057Er 2  A9 27          lda #$27
000580r 2  8D 07 94       sta GPIO_T1LH
000583r 2                 ; Write T1CH to start countdown (also clears IFR T1 flag)
000583r 2  A9 27          lda #$27
000585r 2  8D 05 94       sta GPIO_T1CH
000588r 2               @DelayPoll:
000588r 2  AD 0D 94       lda GPIO_IFR
00058Br 2  29 40          and #%01000000                ; T1 timeout flag
00058Dr 2  F0 F9          beq @DelayPoll
00058Fr 2                 ; Clear flag by reading T1CL
00058Fr 2  AD 04 94       lda GPIO_T1CL
000592r 2                 ; 16-bit decrement
000592r 2  A5 2C          lda DELAY_CNT
000594r 2  D0 02          bne @DelayDecLo
000596r 2  C6 2D          dec DELAY_CNT + 1
000598r 2               @DelayDecLo:
000598r 2  C6 2C          dec DELAY_CNT
00059Ar 2                 ; Loop until both bytes zero
00059Ar 2  A5 2C          lda DELAY_CNT
00059Cr 2  05 2D          ora DELAY_CNT + 1
00059Er 2  D0 D9          bne @DelayLoop
0005A0r 2               @DelayDone:
0005A0r 2  60             rts
0005A1r 2               
0005A1r 2               ; SidSetVolume — Set SID master volume
0005A1r 2               ; Input: A = volume (0-15); upper nibble of SID_MODE_VOL is cleared (no filter)
0005A1r 2               ; Modifies: Flags, A
0005A1r 2               SidSetVolumeImpl:
0005A1r 2  29 0F          and #$0F
0005A3r 2  8D 18 98       sta SID_MODE_VOL
0005A6r 2  60             rts
0005A7r 2               
0005A7r 2               ; VideoSetColor — Set TMS9918 text color register
0005A7r 2               ; Input: A = color byte (high nibble = fg color, low nibble = bg color)
0005A7r 2               ; Modifies: Flags, A
0005A7r 2               VideoSetColorImpl:
0005A7r 2  8D 01 9C       sta VC_REG                    ; Data byte
0005AAr 2  A9 87          lda #$87                      ; Register 7 | $80 (write mode flag)
0005ACr 2  8D 01 9C       sta VC_REG
0005AFr 2  60             rts
0005B0r 2               
0005B0r 2               ; KBDisable — Disable both keyboard encoders for raw port access
0005B0r 2               ; Sets CB2 high (disable matrix encoder) and CA2 high (disable PS/2 encoder)
0005B0r 2               ; Modifies: Flags, A
0005B0r 2               KBDisable:
0005B0r 2  A9 EE          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0005B2r 2  8D 0C 94       sta GPIO_PCR
0005B5r 2  60             rts
0005B6r 2               
0005B6r 2               ; KBEnable — Re-enable both keyboard encoders
0005B6r 2               ; Sets CB2 low (enable matrix encoder) and CA2 low (enable PS/2 encoder)
0005B6r 2               ; Modifies: Flags, A
0005B6r 2               KBEnable:
0005B6r 2  A9 CC          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0005B8r 2  8D 0C 94       sta GPIO_PCR
0005BBr 2  60             rts
0005BCr 2               
0005BCr 2               ; ReadJoystick1 — Read joystick 1 on Port B
0005BCr 2               ; Temporarily disables matrix keyboard encoder (CB2 high) to read raw port data
0005BCr 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
0005BCr 2               ; Modifies: Flags, A
0005BCr 2               ReadJoystick1Impl:
0005BCr 2  78             sei                           ; Disable interrupts during raw port read
0005BDr 2  AD 0C 94       lda GPIO_PCR
0005C0r 2  48             pha                           ; Save current PCR state
0005C1r 2                 ; Set CB2 high to disable matrix encoder, preserve CA2 state
0005C1r 2  A9 EC          lda #(GPIO_PCR_CB2_HI | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_LO | GPIO_PCR_CA1_NEG)
0005C3r 2  8D 0C 94       sta GPIO_PCR
0005C6r 2  AD 00 94       lda GPIO_PORTB                ; Read raw joystick data from Port B
0005C9r 2  AA             tax                           ; Save result in X
0005CAr 2  68             pla                           ; Restore original PCR state
0005CBr 2  8D 0C 94       sta GPIO_PCR
0005CEr 2  8A             txa                           ; Return result in A
0005CFr 2  58             cli                           ; Re-enable interrupts
0005D0r 2  60             rts
0005D1r 2               
0005D1r 2               ; ReadJoystick2 — Read joystick 2 on Port A
0005D1r 2               ; Temporarily disables PS/2 keyboard encoder (CA2 high) to read raw port data
0005D1r 2               ; Output: A = joystick bitmask (bits: R-L-D-U-Y-X-B-A)
0005D1r 2               ; Modifies: Flags, A
0005D1r 2               ReadJoystick2Impl:
0005D1r 2  78             sei                           ; Disable interrupts during raw port read
0005D2r 2  AD 0C 94       lda GPIO_PCR
0005D5r 2  48             pha                           ; Save current PCR state
0005D6r 2                 ; Set CA2 high to disable PS/2 encoder, preserve CB2 state
0005D6r 2  A9 CE          lda #(GPIO_PCR_CB2_LO | GPIO_PCR_CB1_NEG | GPIO_PCR_CA2_HI | GPIO_PCR_CA1_NEG)
0005D8r 2  8D 0C 94       sta GPIO_PCR
0005DBr 2  AD 01 94       lda GPIO_PORTA                ; Read raw joystick data from Port A
0005DEr 2  AA             tax                           ; Save result in X
0005DFr 2  68             pla                           ; Restore original PCR state
0005E0r 2  8D 0C 94       sta GPIO_PCR
0005E3r 2  8A             txa                           ; Return result in A
0005E4r 2  58             cli                           ; Re-enable interrupts
0005E5r 2  60             rts
0005E6r 2               
0005E6r 2               ; === BCD Conversion Helpers ===
0005E6r 2               
0005E6r 2               ; BcdToBin — Convert BCD byte to binary
0005E6r 2               ; Input: A = BCD value (e.g. $35 represents 35)
0005E6r 2               ; Output: A = binary value (e.g. 35 = $23)
0005E6r 2               ; Modifies: Flags
0005E6r 2               BcdToBin:
0005E6r 2  48             pha
0005E7r 2  4A             lsr a                         ; Shift tens digit to low nibble
0005E8r 2  4A             lsr a
0005E9r 2  4A             lsr a
0005EAr 2  4A             lsr a                         ; A = tens digit (0-9)
0005EBr 2  0A             asl a                         ; A = tens * 2
0005ECr 2  8D 0C 03       sta RTC_TMP
0005EFr 2  0A             asl a                         ; A = tens * 4
0005F0r 2  0A             asl a                         ; A = tens * 8
0005F1r 2  18             clc
0005F2r 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 (8 + 2)
0005F5r 2  8D 0C 03       sta RTC_TMP
0005F8r 2  68             pla
0005F9r 2  29 0F          and #$0F                      ; A = ones digit
0005FBr 2  18             clc
0005FCr 2  6D 0C 03       adc RTC_TMP                   ; A = tens * 10 + ones = binary
0005FFr 2  60             rts
000600r 2               
000600r 2               ; BinToBcd — Convert binary byte to BCD
000600r 2               ; Input: A = binary value (0-99)
000600r 2               ; Output: A = BCD value
000600r 2               ; Modifies: Flags, X
000600r 2               BinToBcd:
000600r 2  A2 FF          ldx #$FF                      ; Tens counter (starts at -1)
000602r 2               @BinToBcdLoop:
000602r 2  E8             inx
000603r 2  38             sec
000604r 2  E9 0A          sbc #10
000606r 2  B0 FA          bcs @BinToBcdLoop             ; Count tens
000608r 2  69 0A          adc #10                       ; Restore ones (carry clear, so adds 10 + 0)
00060Ar 2  8D 0C 03       sta RTC_TMP                   ; Save ones digit
00060Dr 2  8A             txa                           ; A = tens digit
00060Er 2  0A             asl a
00060Fr 2  0A             asl a
000610r 2  0A             asl a
000611r 2  0A             asl a                         ; Shift tens to high nibble
000612r 2  0D 0C 03       ora RTC_TMP                   ; Combine with ones
000615r 2  60             rts
000616r 2               
000616r 2               ; === DS1511Y RTC Routines ===
000616r 2               
000616r 2               ; RtcReadTime — Read current time from DS1511Y
000616r 2               ; Output: A = hours (binary), X = minutes (binary), Y = seconds (binary)
000616r 2               ; Modifies: Flags
000616r 2               RtcReadTimeImpl:
000616r 2  AD 02 88       lda RTC_HR
000619r 2  20 rr rr       jsr BcdToBin
00061Cr 2  48             pha                           ; Save hours
00061Dr 2  AD 01 88       lda RTC_MIN
000620r 2  20 rr rr       jsr BcdToBin
000623r 2  AA             tax                           ; X = minutes
000624r 2  AD 00 88       lda RTC_SEC
000627r 2  20 rr rr       jsr BcdToBin
00062Ar 2  A8             tay                           ; Y = seconds
00062Br 2  68             pla                           ; A = hours
00062Cr 2  60             rts
00062Dr 2               
00062Dr 2               ; RtcReadDate — Read current date from DS1511Y
00062Dr 2               ; Output: A = day of month (binary), X = month (binary), Y = year (binary)
00062Dr 2               ;         RTC_BUF_CENT = century (binary)
00062Dr 2               ; Modifies: Flags
00062Dr 2               RtcReadDateImpl:
00062Dr 2  AD 07 88       lda RTC_CENT
000630r 2  20 rr rr       jsr BcdToBin
000633r 2  8D 0B 03       sta RTC_BUF_CENT              ; Store century in buffer
000636r 2  AD 05 88       lda RTC_MON
000639r 2  20 rr rr       jsr BcdToBin
00063Cr 2  AA             tax                           ; X = month
00063Dr 2  AD 06 88       lda RTC_YR
000640r 2  20 rr rr       jsr BcdToBin
000643r 2  A8             tay                           ; Y = year
000644r 2  AD 04 88       lda RTC_DATE
000647r 2  20 rr rr       jsr BcdToBin                  ; A = day of month
00064Ar 2  60             rts
00064Br 2               
00064Br 2               ; RtcWriteTime — Set DS1511Y time
00064Br 2               ; Input: A = hours (binary), X = minutes (binary), Y = seconds (binary)
00064Br 2               ; Modifies: Flags, A, X
00064Br 2               RtcWriteTimeImpl:
00064Br 2  48             pha                           ; Save hours
00064Cr 2  DA             phx                           ; Save minutes
00064Dr 2  5A             phy                           ; Save seconds
00064Er 2                 ; Set TE bit to inhibit update transfers
00064Er 2  AD 0F 88       lda RTC_CTRL_B
000651r 2  09 80          ora #RTC_CTRL_B_TE
000653r 2  8D 0F 88       sta RTC_CTRL_B
000656r 2                 ; Write seconds
000656r 2  68             pla                           ; A = seconds
000657r 2  20 rr rr       jsr BinToBcd
00065Ar 2  8D 00 88       sta RTC_SEC
00065Dr 2                 ; Write minutes
00065Dr 2  68             pla                           ; A = minutes
00065Er 2  20 rr rr       jsr BinToBcd
000661r 2  8D 01 88       sta RTC_MIN
000664r 2                 ; Write hours
000664r 2  68             pla                           ; A = hours
000665r 2  20 rr rr       jsr BinToBcd
000668r 2  8D 02 88       sta RTC_HR
00066Br 2                 ; Clear TE bit to resume updates
00066Br 2  AD 0F 88       lda RTC_CTRL_B
00066Er 2  29 7F          and #<~RTC_CTRL_B_TE
000670r 2  8D 0F 88       sta RTC_CTRL_B
000673r 2  60             rts
000674r 2               
000674r 2               ; RtcWriteDate — Set DS1511Y date
000674r 2               ; Input: A = day of month (binary), X = month (binary), Y = year (binary)
000674r 2               ;        RTC_BUF_CENT = century (binary)
000674r 2               ; Modifies: Flags, A, X
000674r 2               RtcWriteDateImpl:
000674r 2  48             pha                           ; Save day
000675r 2  DA             phx                           ; Save month
000676r 2  5A             phy                           ; Save year
000677r 2                 ; Set TE bit to inhibit update transfers
000677r 2  AD 0F 88       lda RTC_CTRL_B
00067Ar 2  09 80          ora #RTC_CTRL_B_TE
00067Cr 2  8D 0F 88       sta RTC_CTRL_B
00067Fr 2                 ; Write century
00067Fr 2  AD 0B 03       lda RTC_BUF_CENT
000682r 2  20 rr rr       jsr BinToBcd
000685r 2  8D 07 88       sta RTC_CENT
000688r 2                 ; Write year
000688r 2  68             pla                           ; A = year
000689r 2  20 rr rr       jsr BinToBcd
00068Cr 2  8D 06 88       sta RTC_YR
00068Fr 2                 ; Write month
00068Fr 2  68             pla                           ; A = month
000690r 2  20 rr rr       jsr BinToBcd
000693r 2  8D 05 88       sta RTC_MON
000696r 2                 ; Write day
000696r 2  68             pla                           ; A = day
000697r 2  20 rr rr       jsr BinToBcd
00069Ar 2  8D 04 88       sta RTC_DATE
00069Dr 2                 ; Clear TE bit to resume updates
00069Dr 2  AD 0F 88       lda RTC_CTRL_B
0006A0r 2  29 7F          and #<~RTC_CTRL_B_TE
0006A2r 2  8D 0F 88       sta RTC_CTRL_B
0006A5r 2  60             rts
0006A6r 2               
0006A6r 2               ; RtcReadNVRAM — Read a byte from DS1511Y NVRAM
0006A6r 2               ; Input: X = NVRAM address ($00-$FF)
0006A6r 2               ; Output: A = data byte
0006A6r 2               ; Modifies: Flags
0006A6r 2               RtcReadNVRAMImpl:
0006A6r 2  8E 10 88       stx RTC_RAM_ADDR
0006A9r 2  AD 13 88       lda RTC_RAM_DATA
0006ACr 2  60             rts
0006ADr 2               
0006ADr 2               ; RtcWriteNVRAM — Write a byte to DS1511Y NVRAM
0006ADr 2               ; Input: X = NVRAM address ($00-$FF), A = data byte
0006ADr 2               ; Modifies: Flags
0006ADr 2               RtcWriteNVRAMImpl:
0006ADr 2  8E 10 88       stx RTC_RAM_ADDR
0006B0r 2  8D 13 88       sta RTC_RAM_DATA
0006B3r 2  60             rts
0006B4r 2               
0006B4r 2               ; === Hardware Probes ===
0006B4r 2               
0006B4r 2               ; ProbeRAM — Test for banked SRAM on IO 1 and IO 2
0006B4r 2               ; Two-pattern read-back test ($A5 then $5A) on bank 0 data byte
0006B4r 2               ; Sets HW_RAM_L / HW_RAM_H in HW_PRESENT on success
0006B4r 2               ; Modifies: Flags, A
0006B4r 2               ProbeRAM:
0006B4r 2                 ; --- Probe RAM Low (IO 1) ---
0006B4r 2  9C FF 83       stz RAM_BANK_L                ; Select bank 0
0006B7r 2  AD 00 80       lda RAM_DATA_L                ; Save existing value
0006BAr 2  48             pha
0006BBr 2  A9 A5          lda #$A5
0006BDr 2  8D 00 80       sta RAM_DATA_L
0006C0r 2  CD 00 80       cmp RAM_DATA_L
0006C3r 2  D0 12          bne @RAMLDone                 ; First pattern failed
0006C5r 2  A9 5A          lda #$5A
0006C7r 2  8D 00 80       sta RAM_DATA_L
0006CAr 2  CD 00 80       cmp RAM_DATA_L
0006CDr 2  D0 08          bne @RAMLDone                 ; Second pattern failed
0006CFr 2  AD 0D 03       lda HW_PRESENT
0006D2r 2  09 01          ora #HW_RAM_L
0006D4r 2  8D 0D 03       sta HW_PRESENT
0006D7r 2               @RAMLDone:
0006D7r 2  68             pla
0006D8r 2  8D 00 80       sta RAM_DATA_L                ; Restore original value
0006DBr 2                 ; --- Probe RAM High (IO 2) ---
0006DBr 2  9C FF 87       stz RAM_BANK_H                ; Select bank 0
0006DEr 2  AD 00 84       lda RAM_DATA_H                ; Save existing value
0006E1r 2  48             pha
0006E2r 2  A9 A5          lda #$A5
0006E4r 2  8D 00 84       sta RAM_DATA_H
0006E7r 2  CD 00 84       cmp RAM_DATA_H
0006EAr 2  D0 12          bne @RAMHDone                 ; First pattern failed
0006ECr 2  A9 5A          lda #$5A
0006EEr 2  8D 00 84       sta RAM_DATA_H
0006F1r 2  CD 00 84       cmp RAM_DATA_H
0006F4r 2  D0 08          bne @RAMHDone                 ; Second pattern failed
0006F6r 2  AD 0D 03       lda HW_PRESENT
0006F9r 2  09 02          ora #HW_RAM_H
0006FBr 2  8D 0D 03       sta HW_PRESENT
0006FEr 2               @RAMHDone:
0006FEr 2  68             pla
0006FFr 2  8D 00 84       sta RAM_DATA_H                ; Restore original value
000702r 2  60             rts
000703r 2               
000703r 2               ; ProbeVideo — TMS9918 VRAM read-back test
000703r 2               ; Writes $A5 to VRAM address $0000, reads it back
000703r 2               ; Sets HW_VID in HW_PRESENT on success
000703r 2               ; Modifies: Flags, A
000703r 2               ProbeVideo:
000703r 2                 ; Write $A5 to VRAM $0000
000703r 2  A9 00          lda #$00
000705r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
000708r 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
00070Ar 2  8D 01 9C       sta VC_REG
00070Dr 2  A9 A5          lda #$A5
00070Fr 2  8D 00 9C       sta VC_DATA                   ; Write data byte
000712r 2                 ; Read back from VRAM $0000
000712r 2  A9 00          lda #$00
000714r 2  8D 01 9C       sta VC_REG                    ; Low byte of address
000717r 2  A9 00          lda #$00                      ; High byte $00, bit 6 clear for read mode
000719r 2  8D 01 9C       sta VC_REG
00071Cr 2  AD 00 9C       lda VC_DATA                   ; Read data byte
00071Fr 2  C9 A5          cmp #$A5
000721r 2  D0 17          bne @ProbeVideoDone
000723r 2  AD 0D 03       lda HW_PRESENT
000726r 2  09 80          ora #HW_VID
000728r 2  8D 0D 03       sta HW_PRESENT
00072Br 2                 ; Clean up probe byte — write $00 back to VRAM $0000
00072Br 2  A9 00          lda #$00
00072Dr 2  8D 01 9C       sta VC_REG                    ; Low byte of address
000730r 2  A9 40          lda #$40                      ; High byte $00 OR $40 for write mode
000732r 2  8D 01 9C       sta VC_REG
000735r 2  A9 00          lda #$00
000737r 2  8D 00 9C       sta VC_DATA
00073Ar 2               @ProbeVideoDone:
00073Ar 2  60             rts
00073Br 2               
00073Br 2               ; ProbeGPIO — VIA DDR register read-back test
00073Br 2               ; Writes $AA to GPIO_DDRB, reads it back
00073Br 2               ; Sets HW_GPIO in HW_PRESENT on success
00073Br 2               ; Restores GPIO_DDRB to $00 afterward
00073Br 2               ; Modifies: Flags, A
00073Br 2               ProbeGPIO:
00073Br 2  A9 AA          lda #$AA
00073Dr 2  8D 02 94       sta GPIO_DDRB
000740r 2  CD 02 94       cmp GPIO_DDRB
000743r 2  D0 08          bne @ProbeGPIODone
000745r 2  AD 0D 03       lda HW_PRESENT
000748r 2  09 20          ora #HW_GPIO
00074Ar 2  8D 0D 03       sta HW_PRESENT
00074Dr 2               @ProbeGPIODone:
00074Dr 2  9C 02 94       stz GPIO_DDRB                 ; Restore to inputs (InitKBImpl will configure properly)
000750r 2  60             rts
000751r 2               
000751r 2               ; ProbeSerial — R65C51 CMD register write/read-back test
000751r 2               ; Issues programmatic reset, writes test value to CMD, reads back
000751r 2               ; Open bus will not match — prevents false detection
000751r 2               ; Sets HW_SC in HW_PRESENT on success
000751r 2               ; Modifies: Flags, A
000751r 2               ProbeSerial:
000751r 2  9C 01 90       stz SC_RESET                  ; Programmatic reset (write any value)
000754r 2  A9 0A          lda #$0A                      ; Test value (bits within CMD writable range)
000756r 2  8D 02 90       sta SC_CMD                    ; Write to Command Register
000759r 2  CD 02 90       cmp SC_CMD                    ; Read back — should match if real hardware
00075Cr 2  D0 08          bne @ProbeSerialDone          ; Mismatch = open bus, no card present
00075Er 2  AD 0D 03       lda HW_PRESENT
000761r 2  09 10          ora #HW_SC
000763r 2  8D 0D 03       sta HW_PRESENT
000766r 2               @ProbeSerialDone:
000766r 2  60             rts
000767r 2               
000767r 2               ; ProbeSID — Active oscillator test using voice 3
000767r 2               ; Configures voice 3 noise waveform, brief delay, reads SID_OSC3
000767r 2               ; Non-zero and non-$FF result indicates SID present
000767r 2               ; Sets HW_SID in HW_PRESENT on success
000767r 2               ; Modifies: Flags, A, X, Y
000767r 2               ProbeSID:
000767r 2                 ; Set voice 3 frequency to a fast value
000767r 2  A9 FF          lda #$FF
000769r 2  8D 0E 98       sta SID_V3_FREQ_LO
00076Cr 2  8D 0F 98       sta SID_V3_FREQ_HI
00076Fr 2                 ; Gate on + noise waveform
00076Fr 2  A9 81          lda #(SID_CTRL_GATE | SID_CTRL_NOISE)
000771r 2  8D 12 98       sta SID_V3_CTRL
000774r 2                 ; Brief software delay for oscillator to run
000774r 2  A0 00          ldy #$00
000776r 2               @ProbeSIDDelay:
000776r 2  88             dey
000777r 2  D0 FD          bne @ProbeSIDDelay            ; ~1280 cycles
000779r 2                 ; Read oscillator 3 output
000779r 2  AD 1B 98       lda SID_OSC3
00077Cr 2  F0 0E          beq @ProbeSIDCleanup          ; Zero → no SID
00077Er 2  C9 FF          cmp #$FF
000780r 2  F0 0A          beq @ProbeSIDCleanup          ; $FF → likely floating bus
000782r 2                 ; SID detected
000782r 2  48             pha
000783r 2  AD 0D 03       lda HW_PRESENT
000786r 2  09 40          ora #HW_SID
000788r 2  8D 0D 03       sta HW_PRESENT
00078Br 2  68             pla
00078Cr 2               @ProbeSIDCleanup:
00078Cr 2                 ; Silence voice 3
00078Cr 2  9C 12 98       stz SID_V3_CTRL
00078Fr 2  9C 0E 98       stz SID_V3_FREQ_LO
000792r 2  9C 0F 98       stz SID_V3_FREQ_HI
000795r 2  60             rts
000796r 2               
000796r 2               ; ProbeRTC — DS1511Y NVRAM read-back test
000796r 2               ; Writes test pattern to NVRAM address 0, reads it back
000796r 2               ; Sets HW_RTC in HW_PRESENT on success
000796r 2               ; Restores original NVRAM value afterward
000796r 2               ; Modifies: Flags, A
000796r 2               ProbeRTC:
000796r 2  9C 10 88       stz RTC_RAM_ADDR              ; Select NVRAM address 0
000799r 2  AD 13 88       lda RTC_RAM_DATA              ; Save existing value
00079Cr 2  48             pha
00079Dr 2  A9 A5          lda #$A5
00079Fr 2  8D 13 88       sta RTC_RAM_DATA              ; Write test pattern
0007A2r 2  CD 13 88       cmp RTC_RAM_DATA              ; Read back
0007A5r 2  D0 08          bne @ProbeRTCDone
0007A7r 2  AD 0D 03       lda HW_PRESENT
0007AAr 2  09 04          ora #HW_RTC
0007ACr 2  8D 0D 03       sta HW_PRESENT
0007AFr 2               @ProbeRTCDone:
0007AFr 2  68             pla
0007B0r 2  8D 13 88       sta RTC_RAM_DATA              ; Restore original value
0007B3r 2  60             rts
0007B4r 2               
0007B4r 2               ; === CompactFlash Storage Driver (True 8-bit IDE Mode) ===
0007B4r 2               
0007B4r 2               ; StWaitReady — Wait for CompactFlash to become ready
0007B4r 2               ; Polls ST_STATUS until BSY=0 and RDY=1, with X/Y timeout (~65536 iterations)
0007B4r 2               ; Output: Carry clear = ready, Carry set = error or timeout
0007B4r 2               ; Modifies: Flags, A, X, Y
0007B4r 2               StWaitReadyImpl:
0007B4r 2  A2 00          ldx #$00                      ; Outer timeout counter (256 × 256 = 65536 iterations)
0007B6r 2  A0 00          ldy #$00
0007B8r 2               @StWaitBsy:
0007B8r 2  AD 07 8C       lda ST_STATUS
0007BBr 2  29 80          and #ST_STATUS_BSY            ; Check BSY bit
0007BDr 2  F0 08          beq @StCheckRdy               ; BSY clear — check RDY
0007BFr 2  88             dey
0007C0r 2  D0 F6          bne @StWaitBsy
0007C2r 2  CA             dex
0007C3r 2  D0 F3          bne @StWaitBsy
0007C5r 2  38             sec                           ; Timed out — no device
0007C6r 2  60             rts
0007C7r 2               @StCheckRdy:
0007C7r 2  AD 07 8C       lda ST_STATUS
0007CAr 2  29 40          and #ST_STATUS_RDY            ; Check RDY bit
0007CCr 2  D0 08          bne @StCheckErr               ; RDY set — check for errors
0007CEr 2  88             dey
0007CFr 2  D0 E7          bne @StWaitBsy
0007D1r 2  CA             dex
0007D2r 2  D0 E4          bne @StWaitBsy
0007D4r 2  38             sec                           ; Timed out
0007D5r 2  60             rts
0007D6r 2               @StCheckErr:
0007D6r 2  AD 07 8C       lda ST_STATUS
0007D9r 2  29 01          and #ST_STATUS_ERR            ; Check ERR bit
0007DBr 2  D0 02          bne @StWaitErr
0007DDr 2  18             clc                           ; Ready, no error
0007DEr 2  60             rts
0007DFr 2               @StWaitErr:
0007DFr 2  38             sec                           ; Error condition
0007E0r 2  60             rts
0007E1r 2               
0007E1r 2               ; StWaitDrq — Wait for CompactFlash data request
0007E1r 2               ; Polls ST_STATUS until BSY=0 and DRQ=1, with X/Y timeout (~65536 iterations)
0007E1r 2               ; Output: Carry clear = DRQ active, Carry set = error or timeout
0007E1r 2               ; Modifies: Flags, A, X, Y
0007E1r 2               StWaitDrq:
0007E1r 2  A2 00          ldx #$00                      ; Outer timeout counter (256 × 256 = 65536 iterations)
0007E3r 2  A0 00          ldy #$00
0007E5r 2               @StDrqBsy:
0007E5r 2  AD 07 8C       lda ST_STATUS
0007E8r 2  29 80          and #ST_STATUS_BSY
0007EAr 2  F0 08          beq @StDrqCheckDrq            ; BSY clear — check DRQ
0007ECr 2  88             dey
0007EDr 2  D0 F6          bne @StDrqBsy
0007EFr 2  CA             dex
0007F0r 2  D0 F3          bne @StDrqBsy
0007F2r 2  38             sec                           ; Timed out — no device
0007F3r 2  60             rts
0007F4r 2               @StDrqCheckDrq:
0007F4r 2  AD 07 8C       lda ST_STATUS
0007F7r 2  29 01          and #ST_STATUS_ERR
0007F9r 2  D0 11          bne @StDrqErr
0007FBr 2  AD 07 8C       lda ST_STATUS
0007FEr 2  29 08          and #ST_STATUS_DRQ
000800r 2  D0 08          bne @StDrqOk                  ; DRQ set — ready for data
000802r 2  88             dey
000803r 2  D0 E0          bne @StDrqBsy
000805r 2  CA             dex
000806r 2  D0 DD          bne @StDrqBsy
000808r 2  38             sec                           ; Timed out
000809r 2  60             rts
00080Ar 2               @StDrqOk:
00080Ar 2  18             clc
00080Br 2  60             rts
00080Cr 2               @StDrqErr:
00080Cr 2  38             sec
00080Dr 2  60             rts
00080Er 2               
00080Er 2               ; StInit — Initialize CompactFlash for 8-bit data transfers
00080Er 2               ; Issues Set Features command with subcommand $01 (enable 8-bit I/O)
00080Er 2               ; Output: Carry clear = success, Carry set = error
00080Er 2               ; Modifies: Flags, A
00080Er 2               StInit:
00080Er 2  20 rr rr       jsr StWaitReady
000811r 2  B0 15          bcs @StInitDone               ; Timeout or error — CF not present
000813r 2                 ; CF responded — set presence flag
000813r 2  AD 0D 03       lda HW_PRESENT
000816r 2  09 08          ora #HW_CF
000818r 2  8D 0D 03       sta HW_PRESENT
00081Br 2  A9 01          lda #ST_FEAT_8BIT             ; Feature: enable 8-bit data I/O
00081Dr 2  8D 01 8C       sta ST_FEATURE
000820r 2  A9 EF          lda #ST_CMD_SET_FEAT          ; Set Features command
000822r 2  8D 07 8C       sta ST_CMD
000825r 2  20 rr rr       jsr StWaitReady               ; Wait for command completion
000828r 2               @StInitDone:
000828r 2  60             rts
000829r 2               
000829r 2               ; StSetupLba — Set up LBA registers from CF_LBA zero page variables
000829r 2               ; Also sets sector count to 1 and selects master drive in LBA mode
000829r 2               ; Modifies: Flags, A
000829r 2               StSetupLba:
000829r 2  A9 01          lda #$01
00082Br 2  8D 02 8C       sta ST_SECT_CNT               ; Always 1 sector
00082Er 2  A5 26          lda CF_LBA
000830r 2  8D 03 8C       sta ST_LBA_0                  ; LBA bits 0-7
000833r 2  A5 27          lda CF_LBA + 1
000835r 2  8D 04 8C       sta ST_LBA_1                  ; LBA bits 8-15
000838r 2  A5 28          lda CF_LBA + 2
00083Ar 2  8D 05 8C       sta ST_LBA_2                  ; LBA bits 16-23
00083Dr 2  A5 29          lda CF_LBA + 3
00083Fr 2  29 0F          and #$0F                      ; Mask to 4 bits (LBA 24-27)
000841r 2  09 E0          ora #ST_LBA3_MASTER           ; LBA mode, master drive
000843r 2  8D 06 8C       sta ST_LBA_3
000846r 2  60             rts
000847r 2               
000847r 2               ; StReadSector — Read one 512-byte sector from CompactFlash
000847r 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = destination pointer
000847r 2               ; Output: Carry clear = success, Carry set = error
000847r 2               ;         CF_BUF_PTR advanced by 512 bytes on success
000847r 2               ; Modifies: Flags, A, X, Y
000847r 2               StReadSectorImpl:
000847r 2  20 rr rr       jsr StWaitReady
00084Ar 2  B0 1F          bcs @StReadDone
00084Cr 2  20 rr rr       jsr StSetupLba
00084Fr 2  A9 20          lda #ST_CMD_READ              ; Issue read command
000851r 2  8D 07 8C       sta ST_CMD
000854r 2  20 rr rr       jsr StWaitDrq                 ; Wait for data ready
000857r 2  B0 12          bcs @StReadDone
000859r 2                 ; Read 512 bytes: 2 pages of 256 bytes
000859r 2  A0 00          ldy #$00
00085Br 2  A2 02          ldx #$02                      ; 2 pages
00085Dr 2               @StReadPage:
00085Dr 2  AD 00 8C       lda ST_DATA                   ; Read byte from CF
000860r 2  91 24          sta (CF_BUF_PTR),y            ; Store to destination
000862r 2  C8             iny
000863r 2  D0 F8          bne @StReadPage               ; Loop for 256 bytes
000865r 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
000867r 2  CA             dex
000868r 2  D0 F3          bne @StReadPage
00086Ar 2  18             clc                           ; Success
00086Br 2               @StReadDone:
00086Br 2  60             rts
00086Cr 2               
00086Cr 2               ; StWriteSector — Write one 512-byte sector to CompactFlash
00086Cr 2               ; Input: CF_LBA ($26-$29) = LBA address, CF_BUF_PTR ($24-$25) = source pointer
00086Cr 2               ; Output: Carry clear = success, Carry set = error
00086Cr 2               ;         CF_BUF_PTR advanced by 512 bytes on success
00086Cr 2               ; Modifies: Flags, A, X, Y
00086Cr 2               StWriteSectorImpl:
00086Cr 2  20 rr rr       jsr StWaitReady
00086Fr 2  B0 21          bcs @StWriteDone
000871r 2  20 rr rr       jsr StSetupLba
000874r 2  A9 30          lda #ST_CMD_WRITE             ; Issue write command
000876r 2  8D 07 8C       sta ST_CMD
000879r 2  20 rr rr       jsr StWaitDrq                 ; Wait for data request
00087Cr 2  B0 14          bcs @StWriteDone
00087Er 2                 ; Write 512 bytes: 2 pages of 256 bytes
00087Er 2  A0 00          ldy #$00
000880r 2  A2 02          ldx #$02                      ; 2 pages
000882r 2               @StWritePage:
000882r 2  B1 24          lda (CF_BUF_PTR),y            ; Load from source
000884r 2  8D 00 8C       sta ST_DATA                   ; Write byte to CF
000887r 2  C8             iny
000888r 2  D0 F8          bne @StWritePage              ; Loop for 256 bytes
00088Ar 2  E6 25          inc CF_BUF_PTR + 1            ; Next page
00088Cr 2  CA             dex
00088Dr 2  D0 F3          bne @StWritePage
00088Fr 2  20 rr rr       jsr StWaitReady               ; Wait for write to complete
000892r 2               @StWriteDone:
000892r 2  60             rts
000893r 2               
000893r 2               ; === Simple Custom Filesystem ===
000893r 2               ; Directory at LBA 0: 16 entries x 32 bytes = 512 bytes
000893r 2               ; Entry format:
000893r 2               ;   $00-$07: 8-byte filename (space-padded)
000893r 2               ;   $08-$0A: 3-byte extension (space-padded)
000893r 2               ;   $0B:     flags (bit 0 = in use)
000893r 2               ;   $0C-$0D: start sector (little-endian)
000893r 2               ;   $0E-$0F: file size in bytes (little-endian)
000893r 2               ;   $10-$1F: reserved (16 bytes)
000893r 2               
000893r 2               ; FsParseName — Parse null-terminated filename at STR_PTR into FS_FNAME_BUF
000893r 2               ; Converts "NAME.EXT" into 8+3 space-padded format
000893r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000893r 2               ; Output: FS_FNAME_BUF filled with padded 8+3 name
000893r 2               ; Modifies: Flags, A, X, Y
000893r 2               FsParseName:
000893r 2                 ; Fill FS_FNAME_BUF with spaces
000893r 2  A9 20          lda #$20
000895r 2  A2 0A          ldx #10
000897r 2               @FsParseClr:
000897r 2  9D 50 03       sta FS_FNAME_BUF,x
00089Ar 2  CA             dex
00089Br 2  10 FA          bpl @FsParseClr
00089Dr 2                 ; Copy name part (up to 8 chars, stop at '.' or null)
00089Dr 2  A0 00          ldy #$00                      ; Source index
00089Fr 2  A2 00          ldx #$00                      ; Dest index (name portion)
0008A1r 2               @FsParseName:
0008A1r 2  B1 02          lda (STR_PTR),y
0008A3r 2  F0 35          beq @FsParseDone              ; Null terminator — no extension
0008A5r 2  C9 2E          cmp #'.'
0008A7r 2  F0 15          beq @FsParseExt               ; Found dot — start extension
0008A9r 2  E0 08          cpx #$08
0008ABr 2  B0 0E          bcs @FsParseSkipName          ; Already 8 chars, skip extras
0008ADr 2                 ; Convert lowercase to uppercase
0008ADr 2  C9 61          cmp #'a'
0008AFr 2  90 06          bcc @FsStoreNameChar
0008B1r 2  C9 7B          cmp #'z' + 1
0008B3r 2  B0 02          bcs @FsStoreNameChar
0008B5r 2  29 DF          and #$DF                      ; Clear bit 5 to uppercase
0008B7r 2               @FsStoreNameChar:
0008B7r 2  9D 50 03       sta FS_FNAME_BUF,x
0008BAr 2  E8             inx
0008BBr 2               @FsParseSkipName:
0008BBr 2  C8             iny
0008BCr 2  80 E3          bra @FsParseName
0008BEr 2               @FsParseExt:
0008BEr 2  C8             iny                           ; Skip the dot
0008BFr 2  A2 08          ldx #$08                      ; Extension starts at offset 8
0008C1r 2               @FsParseExtLoop:
0008C1r 2  B1 02          lda (STR_PTR),y
0008C3r 2  F0 15          beq @FsParseDone              ; Null terminator
0008C5r 2  E0 0B          cpx #$0B
0008C7r 2  B0 11          bcs @FsParseDone              ; Max 3 ext chars
0008C9r 2                 ; Convert lowercase to uppercase
0008C9r 2  C9 61          cmp #'a'
0008CBr 2  90 06          bcc @FsStoreExtChar
0008CDr 2  C9 7B          cmp #'z' + 1
0008CFr 2  B0 02          bcs @FsStoreExtChar
0008D1r 2  29 DF          and #$DF
0008D3r 2               @FsStoreExtChar:
0008D3r 2  9D 50 03       sta FS_FNAME_BUF,x
0008D6r 2  E8             inx
0008D7r 2  C8             iny
0008D8r 2  80 E7          bra @FsParseExtLoop
0008DAr 2               @FsParseDone:
0008DAr 2  60             rts
0008DBr 2               
0008DBr 2               ; FsReadDir — Read directory sector (LBA 0) into FS_SECTOR_BUF
0008DBr 2               ; Output: Carry clear = success, Carry set = error
0008DBr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
0008DBr 2               FsReadDir:
0008DBr 2  64 26          stz CF_LBA                    ; LBA = 0 (directory sector)
0008DDr 2  64 27          stz CF_LBA + 1
0008DFr 2  64 28          stz CF_LBA + 2
0008E1r 2  64 29          stz CF_LBA + 3
0008E3r 2  A9 00          lda #<FS_SECTOR_BUF
0008E5r 2  85 24          sta CF_BUF_PTR
0008E7r 2  A9 06          lda #>FS_SECTOR_BUF
0008E9r 2  85 25          sta CF_BUF_PTR + 1
0008EBr 2  4C rr rr       jmp StReadSector
0008EEr 2               
0008EEr 2               ; FsWriteDir — Write directory sector from FS_SECTOR_BUF to LBA 0
0008EEr 2               ; Output: Carry clear = success, Carry set = error
0008EEr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
0008EEr 2               FsWriteDir:
0008EEr 2  64 26          stz CF_LBA
0008F0r 2  64 27          stz CF_LBA + 1
0008F2r 2  64 28          stz CF_LBA + 2
0008F4r 2  64 29          stz CF_LBA + 3
0008F6r 2  A9 00          lda #<FS_SECTOR_BUF
0008F8r 2  85 24          sta CF_BUF_PTR
0008FAr 2  A9 06          lda #>FS_SECTOR_BUF
0008FCr 2  85 25          sta CF_BUF_PTR + 1
0008FEr 2  4C rr rr       jmp StWriteSector
000901r 2               
000901r 2               ; FsFindFile — Search directory for filename in FS_FNAME_BUF
000901r 2               ; Must call FsReadDir first to load directory into FS_SECTOR_BUF
000901r 2               ; Output: Carry clear = found, X = entry index (0-15), CF_BUF_PTR points to entry
000901r 2               ;         Carry set = not found
000901r 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
000901r 2               FsFindFile:
000901r 2  A9 00          lda #<FS_SECTOR_BUF
000903r 2  85 24          sta CF_BUF_PTR
000905r 2  A9 06          lda #>FS_SECTOR_BUF
000907r 2  85 25          sta CF_BUF_PTR + 1
000909r 2  A2 00          ldx #$00                      ; Entry index
00090Br 2               @FsFindLoop:
00090Br 2                 ; Check if entry is in use
00090Br 2  A0 0B          ldy #FS_ENTRY_FLAGS
00090Dr 2  B1 24          lda (CF_BUF_PTR),y
00090Fr 2  29 01          and #FS_FLAG_USED
000911r 2  F0 13          beq @FsFindNext               ; Skip unused entries
000913r 2                 ; Compare 11-byte filename
000913r 2  A0 00          ldy #$00
000915r 2               @FsFindCmp:
000915r 2  B1 24          lda (CF_BUF_PTR),y
000917r 2  D9 50 03       cmp FS_FNAME_BUF,y
00091Ar 2  D0 0A          bne @FsFindNext               ; Mismatch
00091Cr 2  C8             iny
00091Dr 2  C0 0B          cpy #11
00091Fr 2  D0 F4          bne @FsFindCmp
000921r 2                 ; Match found
000921r 2  8E 4D 03       stx FS_DIR_IDX
000924r 2  18             clc
000925r 2  60             rts
000926r 2               @FsFindNext:
000926r 2                 ; Advance CF_BUF_PTR by 32 (FS_ENTRY_SIZE)
000926r 2  A5 24          lda CF_BUF_PTR
000928r 2  18             clc
000929r 2  69 20          adc #FS_ENTRY_SIZE
00092Br 2  85 24          sta CF_BUF_PTR
00092Dr 2  90 02          bcc @FsFindNoCarry
00092Fr 2  E6 25          inc CF_BUF_PTR + 1
000931r 2               @FsFindNoCarry:
000931r 2  E8             inx
000932r 2  E0 10          cpx #FS_MAX_FILES
000934r 2  D0 D5          bne @FsFindLoop
000936r 2  38             sec                           ; Not found
000937r 2  60             rts
000938r 2               
000938r 2               ; FsFindFree — Find first free directory entry
000938r 2               ; Must call FsReadDir first
000938r 2               ; Output: Carry clear = found, X = entry index, CF_BUF_PTR points to entry
000938r 2               ;         Carry set = directory full
000938r 2               ; Modifies: Flags, A, X, Y, CF_BUF_PTR
000938r 2               FsFindFree:
000938r 2  A9 00          lda #<FS_SECTOR_BUF
00093Ar 2  85 24          sta CF_BUF_PTR
00093Cr 2  A9 06          lda #>FS_SECTOR_BUF
00093Er 2  85 25          sta CF_BUF_PTR + 1
000940r 2  A2 00          ldx #$00
000942r 2               @FsFreeLoop:
000942r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000944r 2  B1 24          lda (CF_BUF_PTR),y
000946r 2  29 01          and #FS_FLAG_USED
000948r 2  F0 12          beq @FsFreeFound              ; Found unused entry
00094Ar 2                 ; Advance by 32
00094Ar 2  A5 24          lda CF_BUF_PTR
00094Cr 2  18             clc
00094Dr 2  69 20          adc #FS_ENTRY_SIZE
00094Fr 2  85 24          sta CF_BUF_PTR
000951r 2  90 02          bcc @FsFreeNoCarry
000953r 2  E6 25          inc CF_BUF_PTR + 1
000955r 2               @FsFreeNoCarry:
000955r 2  E8             inx
000956r 2  E0 10          cpx #FS_MAX_FILES
000958r 2  D0 E8          bne @FsFreeLoop
00095Ar 2  38             sec                           ; Directory full
00095Br 2  60             rts
00095Cr 2               @FsFreeFound:
00095Cr 2  8E 4D 03       stx FS_DIR_IDX
00095Fr 2  18             clc
000960r 2  60             rts
000961r 2               
000961r 2               ; FsCalcNextSec — Calculate next free sector by scanning all directory entries
000961r 2               ; Must call FsReadDir first
000961r 2               ; Output: FS_NEXT_SEC = first free sector after all used files
000961r 2               ; Modifies: Flags, A, X, Y
000961r 2               FsCalcNextSec:
000961r 2  A9 01          lda #<FS_DATA_START           ; Start with first data sector
000963r 2  8D 4E 03       sta FS_NEXT_SEC
000966r 2  A9 00          lda #>FS_DATA_START
000968r 2  8D 4F 03       sta FS_NEXT_SEC + 1
00096Br 2                 ; Scan all entries to find highest used sector + file sector count
00096Br 2  A9 00          lda #<FS_SECTOR_BUF
00096Dr 2  85 24          sta CF_BUF_PTR
00096Fr 2  A9 06          lda #>FS_SECTOR_BUF
000971r 2  85 25          sta CF_BUF_PTR + 1
000973r 2  A2 00          ldx #$00
000975r 2               @FsCalcLoop:
000975r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000977r 2  B1 24          lda (CF_BUF_PTR),y
000979r 2  29 01          and #FS_FLAG_USED
00097Br 2  F0 51          beq @FsCalcNext               ; Skip unused
00097Dr 2                 ; Get start sector + ceil(size/512)
00097Dr 2  A0 0C          ldy #FS_ENTRY_START
00097Fr 2  B1 24          lda (CF_BUF_PTR),y
000981r 2  8D 48 03       sta FS_START_SEC
000984r 2  C8             iny
000985r 2  B1 24          lda (CF_BUF_PTR),y
000987r 2  8D 49 03       sta FS_START_SEC + 1
00098Ar 2                 ; Get file size
00098Ar 2  A0 0E          ldy #FS_ENTRY_FSIZE
00098Cr 2  B1 24          lda (CF_BUF_PTR),y
00098Er 2  8D 4A 03       sta FS_FILE_SIZE
000991r 2  C8             iny
000992r 2  B1 24          lda (CF_BUF_PTR),y
000994r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000997r 2                 ; Calculate sectors used = (size + 511) / 512 = (size + 511) >> 9
000997r 2                 ; = (size_hi + 1) if size_lo > 0, else size_hi / 2... simplify:
000997r 2                 ; sectors = (size >> 9) rounded up = high_byte >> 1, plus 1 if any remainder
000997r 2  AD 4B 03       lda FS_FILE_SIZE + 1          ; High byte of size
00099Ar 2  4A             lsr a                         ; Divide by 2 (each sector = 512 = 2 pages)
00099Br 2  8D 4C 03       sta FS_SEC_COUNT
00099Er 2                 ; Check if there's a remainder (low byte != 0 or high byte bit 0 was set)
00099Er 2  AD 4B 03       lda FS_FILE_SIZE + 1
0009A1r 2  29 01          and #$01                      ; Was high byte odd?
0009A3r 2  D0 05          bne @FsCalcRound
0009A5r 2  AD 4A 03       lda FS_FILE_SIZE              ; Low byte non-zero?
0009A8r 2  F0 03          beq @FsCalcNoRound
0009AAr 2               @FsCalcRound:
0009AAr 2  EE 4C 03       inc FS_SEC_COUNT              ; Round up
0009ADr 2               @FsCalcNoRound:
0009ADr 2                 ; End sector = start + sector count
0009ADr 2  AD 48 03       lda FS_START_SEC
0009B0r 2  18             clc
0009B1r 2  6D 4C 03       adc FS_SEC_COUNT
0009B4r 2  48             pha
0009B5r 2  AD 49 03       lda FS_START_SEC + 1
0009B8r 2  69 00          adc #$00
0009BAr 2  AA             tax                           ; X = end sector high
0009BBr 2  68             pla                           ; A = end sector low
0009BCr 2                 ; Compare with FS_NEXT_SEC — keep the larger value
0009BCr 2  EC 4F 03       cpx FS_NEXT_SEC + 1
0009BFr 2  90 0D          bcc @FsCalcNext               ; End < FS_NEXT_SEC, skip
0009C1r 2  D0 05          bne @FsCalcUpdate             ; End high > FS_NEXT_SEC high, update
0009C3r 2  CD 4E 03       cmp FS_NEXT_SEC
0009C6r 2  90 06          bcc @FsCalcNext               ; End low < FS_NEXT_SEC low
0009C8r 2               @FsCalcUpdate:
0009C8r 2  8D 4E 03       sta FS_NEXT_SEC
0009CBr 2  8E 4F 03       stx FS_NEXT_SEC + 1
0009CEr 2               @FsCalcNext:
0009CEr 2                 ; Advance CF_BUF_PTR by 32
0009CEr 2  A5 24          lda CF_BUF_PTR
0009D0r 2  18             clc
0009D1r 2  69 20          adc #FS_ENTRY_SIZE
0009D3r 2  85 24          sta CF_BUF_PTR
0009D5r 2  90 02          bcc @FsCalcNoCarry
0009D7r 2  E6 25          inc CF_BUF_PTR + 1
0009D9r 2               @FsCalcNoCarry:
0009D9r 2  E8             inx
0009DAr 2  E0 10          cpx #FS_MAX_FILES
0009DCr 2  D0 97          bne @FsCalcLoop
0009DEr 2  60             rts
0009DFr 2               
0009DFr 2               ; FsDirectory — Print directory listing of all used entries
0009DFr 2               ; Output via Chrout (respects current IO_MODE)
0009DFr 2               ; Modifies: Flags, A, X, Y
0009DFr 2               FsDirectory:
0009DFr 2  20 rr rr       jsr FsReadDir                 ; Load directory sector
0009E2r 2  90 01          bcc @FsDirStart
0009E4r 2  60             rts                           ; Error reading directory
0009E5r 2               @FsDirStart:
0009E5r 2  A9 00          lda #<FS_SECTOR_BUF
0009E7r 2  85 24          sta CF_BUF_PTR
0009E9r 2  A9 06          lda #>FS_SECTOR_BUF
0009EBr 2  85 25          sta CF_BUF_PTR + 1
0009EDr 2  A2 00          ldx #$00                      ; Entry counter
0009EFr 2               @FsDirLoop:
0009EFr 2  DA             phx
0009F0r 2  A0 0B          ldy #FS_ENTRY_FLAGS
0009F2r 2  B1 24          lda (CF_BUF_PTR),y
0009F4r 2  29 01          and #FS_FLAG_USED
0009F6r 2  F0 3A          beq @FsDirNext                ; Skip unused entries
0009F8r 2                 ; Print filename (8 chars)
0009F8r 2  A0 00          ldy #$00
0009FAr 2               @FsDirName:
0009FAr 2  B1 24          lda (CF_BUF_PTR),y
0009FCr 2  20 rr rr       jsr Chrout
0009FFr 2  C8             iny
000A00r 2  C0 08          cpy #$08
000A02r 2  D0 F6          bne @FsDirName
000A04r 2                 ; Print dot separator
000A04r 2  A9 2E          lda #'.'
000A06r 2  20 rr rr       jsr Chrout
000A09r 2                 ; Print extension (3 chars)
000A09r 2               @FsDirExt:
000A09r 2  B1 24          lda (CF_BUF_PTR),y
000A0Br 2  20 rr rr       jsr Chrout
000A0Er 2  C8             iny
000A0Fr 2  C0 0B          cpy #$0B
000A11r 2  D0 F6          bne @FsDirExt
000A13r 2                 ; Print space
000A13r 2  A9 20          lda #' '
000A15r 2  20 rr rr       jsr Chrout
000A18r 2                 ; Print file size in decimal
000A18r 2  A0 0E          ldy #FS_ENTRY_FSIZE
000A1Ar 2  B1 24          lda (CF_BUF_PTR),y
000A1Cr 2  8D 4A 03       sta FS_FILE_SIZE
000A1Fr 2  C8             iny
000A20r 2  B1 24          lda (CF_BUF_PTR),y
000A22r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000A25r 2  20 rr rr       jsr FsPrintSize
000A28r 2                 ; Print newline
000A28r 2  A9 0D          lda #$0D
000A2Ar 2  20 rr rr       jsr Chrout
000A2Dr 2  A9 0A          lda #$0A
000A2Fr 2  20 rr rr       jsr Chrout
000A32r 2               @FsDirNext:
000A32r 2                 ; Advance CF_BUF_PTR by 32
000A32r 2  A5 24          lda CF_BUF_PTR
000A34r 2  18             clc
000A35r 2  69 20          adc #FS_ENTRY_SIZE
000A37r 2  85 24          sta CF_BUF_PTR
000A39r 2  90 02          bcc @FsDirNoCarry
000A3Br 2  E6 25          inc CF_BUF_PTR + 1
000A3Dr 2               @FsDirNoCarry:
000A3Dr 2  FA             plx
000A3Er 2  E8             inx
000A3Fr 2  E0 10          cpx #FS_MAX_FILES
000A41r 2  D0 AC          bne @FsDirLoop
000A43r 2  60             rts
000A44r 2               
000A44r 2               ; FsPrintSize — Print 16-bit value in FS_FILE_SIZE as decimal
000A44r 2               ; Modifies: Flags, A, X, Y
000A44r 2               FsPrintSize:
000A44r 2                 ; Convert 16-bit value to decimal digits (up to 5 digits for 0-65535)
000A44r 2                 ; Use successive subtraction of powers of 10
000A44r 2  A2 00          ldx #$00                      ; Digit index / leading zero suppression
000A46r 2  A0 00          ldy #$00                      ; Power-of-10 table index
000A48r 2               @FsPrintSizeLoop:
000A48r 2  A9 2F          lda #'0' - 1                  ; Start character below '0'
000A4Ar 2  8D 4D 03       sta FS_DIR_IDX                ; Reuse as digit scratch
000A4Dr 2               @FsPrintSub:
000A4Dr 2  EE 4D 03       inc FS_DIR_IDX
000A50r 2  AD 4A 03       lda FS_FILE_SIZE
000A53r 2  38             sec
000A54r 2  F9 rr rr       sbc @FsPow10Lo,y
000A57r 2  48             pha
000A58r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000A5Br 2  F9 rr rr       sbc @FsPow10Hi,y
000A5Er 2  90 09          bcc @FsPrintSizeDig           ; Underflow — done subtracting
000A60r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000A63r 2  68             pla
000A64r 2  8D 4A 03       sta FS_FILE_SIZE
000A67r 2  80 E4          bra @FsPrintSub
000A69r 2               @FsPrintSizeDig:
000A69r 2  68             pla                           ; Discard underflowed low byte
000A6Ar 2  AD 4D 03       lda FS_DIR_IDX
000A6Dr 2  C9 30          cmp #'0'
000A6Fr 2  D0 04          bne @FsPrintSizeOut           ; Non-zero digit
000A71r 2  E0 00          cpx #$00
000A73r 2  F0 04          beq @FsPrintSizeSkip          ; Suppress leading zeros
000A75r 2               @FsPrintSizeOut:
000A75r 2  20 rr rr       jsr Chrout
000A78r 2  E8             inx                           ; Mark that we've printed a digit
000A79r 2               @FsPrintSizeSkip:
000A79r 2  C8             iny
000A7Ar 2  C0 04          cpy #$04                      ; 4 powers of 10 (10000, 1000, 100, 10)
000A7Cr 2  D0 CA          bne @FsPrintSizeLoop
000A7Er 2                 ; Always print ones digit
000A7Er 2  AD 4A 03       lda FS_FILE_SIZE
000A81r 2  09 30          ora #'0'                      ; Low byte is 0-9 at this point
000A83r 2  20 rr rr       jsr Chrout
000A86r 2  60             rts
000A87r 2  10 E8 64 0A  @FsPow10Lo: .byte <10000, <1000, <100, <10
000A8Br 2  27 03 00 00  @FsPow10Hi: .byte >10000, >1000, >100, >10
000A8Fr 2               
000A8Fr 2               ; FsLoadFileImpl — Load file from CF into PROGRAM_START ($0800)
000A8Fr 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000A8Fr 2               ; Output: Carry clear = success, FS_FILE_SIZE = bytes loaded
000A8Fr 2               ;         Carry set = file not found or read error
000A8Fr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000A8Fr 2               FsLoadFileImpl:
000A8Fr 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000A92r 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000A95r 2  B0 63          bcs @FsLoadErr
000A97r 2  20 rr rr       jsr FsFindFile                ; Search for filename
000A9Ar 2  B0 5E          bcs @FsLoadErr                ; Not found
000A9Cr 2                 ; Read file metadata from entry
000A9Cr 2  A0 0C          ldy #FS_ENTRY_START
000A9Er 2  B1 24          lda (CF_BUF_PTR),y
000AA0r 2  8D 48 03       sta FS_START_SEC
000AA3r 2  C8             iny
000AA4r 2  B1 24          lda (CF_BUF_PTR),y
000AA6r 2  8D 49 03       sta FS_START_SEC + 1
000AA9r 2  A0 0E          ldy #FS_ENTRY_FSIZE
000AABr 2  B1 24          lda (CF_BUF_PTR),y
000AADr 2  8D 4A 03       sta FS_FILE_SIZE
000AB0r 2  C8             iny
000AB1r 2  B1 24          lda (CF_BUF_PTR),y
000AB3r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000AB6r 2                 ; Calculate number of sectors to read
000AB6r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000AB9r 2  4A             lsr a
000ABAr 2  8D 4C 03       sta FS_SEC_COUNT
000ABDr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000AC0r 2  29 01          and #$01
000AC2r 2  D0 05          bne @FsLoadRound
000AC4r 2  AD 4A 03       lda FS_FILE_SIZE
000AC7r 2  F0 03          beq @FsLoadNoRound
000AC9r 2               @FsLoadRound:
000AC9r 2  EE 4C 03       inc FS_SEC_COUNT
000ACCr 2               @FsLoadNoRound:
000ACCr 2                 ; Set up LBA starting at file's start sector
000ACCr 2  AD 48 03       lda FS_START_SEC
000ACFr 2  85 26          sta CF_LBA
000AD1r 2  AD 49 03       lda FS_START_SEC + 1
000AD4r 2  85 27          sta CF_LBA + 1
000AD6r 2  64 28          stz CF_LBA + 2
000AD8r 2  64 29          stz CF_LBA + 3
000ADAr 2                 ; Set destination pointer to PROGRAM_START
000ADAr 2  A9 00          lda #<PROGRAM_START
000ADCr 2  85 24          sta CF_BUF_PTR
000ADEr 2  A9 08          lda #>PROGRAM_START
000AE0r 2  85 25          sta CF_BUF_PTR + 1
000AE2r 2                 ; Read sectors
000AE2r 2  AE 4C 03       ldx FS_SEC_COUNT
000AE5r 2  F0 10          beq @FsLoadOk                 ; Zero-size file
000AE7r 2               @FsLoadSec:
000AE7r 2  DA             phx
000AE8r 2  20 rr rr       jsr StReadSector              ; Read sector (advances CF_BUF_PTR by 512)
000AEBr 2  B0 0C          bcs @FsLoadSecErr
000AEDr 2                 ; Increment LBA
000AEDr 2  E6 26          inc CF_LBA
000AEFr 2  D0 02          bne @FsLoadSecNext
000AF1r 2  E6 27          inc CF_LBA + 1
000AF3r 2               @FsLoadSecNext:
000AF3r 2  FA             plx
000AF4r 2  CA             dex
000AF5r 2  D0 F0          bne @FsLoadSec
000AF7r 2               @FsLoadOk:
000AF7r 2  18             clc
000AF8r 2  60             rts
000AF9r 2               @FsLoadSecErr:
000AF9r 2  FA             plx                           ; Balance stack
000AFAr 2               @FsLoadErr:
000AFAr 2  38             sec
000AFBr 2  60             rts
000AFCr 2               
000AFCr 2               ; FsSaveFileImpl — Save data from PROGRAM_START to CF
000AFCr 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000AFCr 2               ;        FS_FILE_SIZE ($034A-$034B) = number of bytes to save
000AFCr 2               ; Output: Carry clear = success, Carry set = error (directory full or write error)
000AFCr 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000AFCr 2               FsSaveFileImpl:
000AFCr 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000AFFr 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000B02r 2  90 03          bcc @FsSaveReadOk
000B04r 2  4C rr rr       jmp @FsSaveErr
000B07r 2               @FsSaveReadOk:
000B07r 2                 ; Try to find existing file with same name
000B07r 2  20 rr rr       jsr FsFindFile
000B0Ar 2  90 08          bcc @FsSaveOverwrite
000B0Cr 2                 ; Not found — find a free slot
000B0Cr 2  20 rr rr       jsr FsFindFree
000B0Fr 2  90 11          bcc @FsSaveAlloc
000B11r 2  4C rr rr       jmp @FsSaveErr                ; Directory full
000B14r 2               @FsSaveOverwrite:
000B14r 2                 ; CF_BUF_PTR already points to the existing entry — clear old flags
000B14r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000B16r 2  A9 00          lda #$00
000B18r 2  91 24          sta (CF_BUF_PTR),y            ; Mark old entry as free
000B1Ar 2                 ; Find a free slot (could be the one we just freed or another)
000B1Ar 2  20 rr rr       jsr FsFindFree
000B1Dr 2  90 03          bcc @FsSaveAlloc
000B1Fr 2  4C rr rr       jmp @FsSaveErr
000B22r 2               @FsSaveAlloc:
000B22r 2                 ; Save CF_BUF_PTR (points to free entry from FsFindFree)
000B22r 2  A5 24          lda CF_BUF_PTR
000B24r 2  48             pha
000B25r 2  A5 25          lda CF_BUF_PTR + 1
000B27r 2  48             pha
000B28r 2                 ; Save FS_FILE_SIZE (FsCalcNextSec clobbers it while scanning entries)
000B28r 2  AD 4A 03       lda FS_FILE_SIZE
000B2Br 2  48             pha
000B2Cr 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B2Fr 2  48             pha
000B30r 2                 ; Calculate next free sector (clobbers CF_BUF_PTR and FS_FILE_SIZE)
000B30r 2  20 rr rr       jsr FsCalcNextSec
000B33r 2                 ; Restore FS_FILE_SIZE
000B33r 2  68             pla
000B34r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000B37r 2  68             pla
000B38r 2  8D 4A 03       sta FS_FILE_SIZE
000B3Br 2                 ; Restore CF_BUF_PTR to the free directory entry
000B3Br 2  68             pla
000B3Cr 2  85 25          sta CF_BUF_PTR + 1
000B3Er 2  68             pla
000B3Fr 2  85 24          sta CF_BUF_PTR
000B41r 2                 ; Calculate sectors needed
000B41r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B44r 2  4A             lsr a
000B45r 2  8D 4C 03       sta FS_SEC_COUNT
000B48r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B4Br 2  29 01          and #$01
000B4Dr 2  D0 05          bne @FsSaveRound
000B4Fr 2  AD 4A 03       lda FS_FILE_SIZE
000B52r 2  F0 03          beq @FsSaveNoRound
000B54r 2               @FsSaveRound:
000B54r 2  EE 4C 03       inc FS_SEC_COUNT
000B57r 2               @FsSaveNoRound:
000B57r 2                 ; Fill in directory entry at CF_BUF_PTR
000B57r 2                 ; Copy filename (11 bytes)
000B57r 2  A0 00          ldy #$00
000B59r 2               @FsSaveCopyName:
000B59r 2  B9 50 03       lda FS_FNAME_BUF,y
000B5Cr 2  91 24          sta (CF_BUF_PTR),y
000B5Er 2  C8             iny
000B5Fr 2  C0 0B          cpy #11
000B61r 2  D0 F6          bne @FsSaveCopyName
000B63r 2                 ; Set flags = in use
000B63r 2  A9 01          lda #FS_FLAG_USED
000B65r 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
000B67r 2                 ; Set start sector
000B67r 2  A0 0C          ldy #FS_ENTRY_START
000B69r 2  AD 4E 03       lda FS_NEXT_SEC
000B6Cr 2  91 24          sta (CF_BUF_PTR),y
000B6Er 2  8D 48 03       sta FS_START_SEC
000B71r 2  C8             iny
000B72r 2  AD 4F 03       lda FS_NEXT_SEC + 1
000B75r 2  91 24          sta (CF_BUF_PTR),y
000B77r 2  8D 49 03       sta FS_START_SEC + 1
000B7Ar 2                 ; Set file size
000B7Ar 2  A0 0E          ldy #FS_ENTRY_FSIZE
000B7Cr 2  AD 4A 03       lda FS_FILE_SIZE
000B7Fr 2  91 24          sta (CF_BUF_PTR),y
000B81r 2  C8             iny
000B82r 2  AD 4B 03       lda FS_FILE_SIZE + 1
000B85r 2  91 24          sta (CF_BUF_PTR),y
000B87r 2                 ; Clear reserved bytes
000B87r 2  A0 10          ldy #$10
000B89r 2  A9 00          lda #$00
000B8Br 2               @FsSaveClearRsv:
000B8Br 2  91 24          sta (CF_BUF_PTR),y
000B8Dr 2  C8             iny
000B8Er 2  C0 20          cpy #FS_ENTRY_SIZE
000B90r 2  D0 F9          bne @FsSaveClearRsv
000B92r 2                 ; Write updated directory back to CF
000B92r 2  20 rr rr       jsr FsWriteDir
000B95r 2  B0 2E          bcs @FsSaveErr
000B97r 2                 ; Now write file data sectors
000B97r 2  AD 48 03       lda FS_START_SEC
000B9Ar 2  85 26          sta CF_LBA
000B9Cr 2  AD 49 03       lda FS_START_SEC + 1
000B9Fr 2  85 27          sta CF_LBA + 1
000BA1r 2  64 28          stz CF_LBA + 2
000BA3r 2  64 29          stz CF_LBA + 3
000BA5r 2                 ; Source = PROGRAM_START
000BA5r 2  A9 00          lda #<PROGRAM_START
000BA7r 2  85 24          sta CF_BUF_PTR
000BA9r 2  A9 08          lda #>PROGRAM_START
000BABr 2  85 25          sta CF_BUF_PTR + 1
000BADr 2  AE 4C 03       ldx FS_SEC_COUNT
000BB0r 2  F0 10          beq @FsSaveOk                 ; Zero-size file
000BB2r 2               @FsSaveSec:
000BB2r 2  DA             phx
000BB3r 2  20 rr rr       jsr StWriteSector             ; Write sector (advances CF_BUF_PTR by 512)
000BB6r 2  B0 0C          bcs @FsSaveSecErr
000BB8r 2                 ; Increment LBA
000BB8r 2  E6 26          inc CF_LBA
000BBAr 2  D0 02          bne @FsSaveSecNext
000BBCr 2  E6 27          inc CF_LBA + 1
000BBEr 2               @FsSaveSecNext:
000BBEr 2  FA             plx
000BBFr 2  CA             dex
000BC0r 2  D0 F0          bne @FsSaveSec
000BC2r 2               @FsSaveOk:
000BC2r 2  18             clc
000BC3r 2  60             rts
000BC4r 2               @FsSaveSecErr:
000BC4r 2  FA             plx                           ; Balance stack
000BC5r 2               @FsSaveErr:
000BC5r 2  38             sec
000BC6r 2  60             rts
000BC7r 2               
000BC7r 2               ; FsDeleteFile — Delete a file from the CompactFlash filesystem
000BC7r 2               ; Input: STR_PTR ($02-$03) points to null-terminated filename
000BC7r 2               ; Output: Carry clear = success, Carry set = file not found or error
000BC7r 2               ; Modifies: Flags, A, X, Y, CF_LBA, CF_BUF_PTR
000BC7r 2               FsDeleteFileImpl:
000BC7r 2  20 rr rr       jsr FsParseName               ; Parse filename into FS_FNAME_BUF
000BCAr 2  20 rr rr       jsr FsReadDir                 ; Read directory sector
000BCDr 2  B0 0F          bcs @FsDelErr
000BCFr 2  20 rr rr       jsr FsFindFile                ; Search for filename
000BD2r 2  B0 0A          bcs @FsDelErr                 ; Not found
000BD4r 2                 ; Clear the flags byte to mark entry as unused
000BD4r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000BD6r 2  A9 00          lda #$00
000BD8r 2  91 24          sta (CF_BUF_PTR),y
000BDAr 2                 ; Write updated directory back to CF
000BDAr 2  20 rr rr       jsr FsWriteDir
000BDDr 2                 ; Carry already set/clear from FsWriteDir
000BDDr 2  60             rts
000BDEr 2               @FsDelErr:
000BDEr 2  38             sec
000BDFr 2  60             rts
000BE0r 2               
000BE0r 2               ; === Serial ASCII LOAD/SAVE ===
000BE0r 2               ; Plain binary transfer protocol over serial
000BE0r 2               ; Load: receives 2-byte size (lo/hi) then raw data bytes into PROGRAM_START
000BE0r 2               ; Save: sends 2-byte size (lo/hi) then raw data bytes from PROGRAM_START
000BE0r 2               
000BE0r 2               ; --- ASCII Load ---
000BE0r 2               
000BE0r 2               ; AsciiLoadImpl — Receive raw binary data via serial into program memory
000BE0r 2               ; Switches IO_MODE to serial, receives 2-byte size then raw data bytes
000BE0r 2               ; Data is written starting at PROGRAM_START ($0800)
000BE0r 2               ; Output: Carry clear = success, XFER_PTR points past last byte written
000BE0r 2               ; Modifies: Flags, A, X, Y
000BE0r 2               AsciiLoadImpl:
000BE0r 2                 ; Save and switch IO_MODE to serial
000BE0r 2  AD 06 03       lda IO_MODE
000BE3r 2  8D 19 03       sta XFER_IO_SAVE
000BE6r 2  A9 01          lda #$01                      ; Serial mode
000BE8r 2  8D 06 03       sta IO_MODE
000BEBr 2                 ; Print prompt
000BEBr 2  A9 0D          lda #$0D
000BEDr 2  20 rr rr       jsr SerialChrout
000BF0r 2  A9 0A          lda #$0A
000BF2r 2  20 rr rr       jsr SerialChrout
000BF5r 2  A9 rr          lda #<@AsciiLoadMsg
000BF7r 2  85 02          sta STR_PTR
000BF9r 2  A9 rr          lda #>@AsciiLoadMsg
000BFBr 2  85 03          sta STR_PTR + 1
000BFDr 2  20 rr rr       jsr @SerialPrintStr
000C00r 2                 ; Read 2-byte size (low byte first)
000C00r 2               @AsciiWaitSzLo:
000C00r 2  20 rr rr       jsr BufferSize
000C03r 2  F0 FB          beq @AsciiWaitSzLo
000C05r 2  20 rr rr       jsr ReadBuffer
000C08r 2  8D 17 03       sta XFER_REMAIN
000C0Br 2               @AsciiWaitSzHi:
000C0Br 2  20 rr rr       jsr BufferSize
000C0Er 2  F0 FB          beq @AsciiWaitSzHi
000C10r 2  20 rr rr       jsr ReadBuffer
000C13r 2  8D 18 03       sta XFER_REMAIN + 1
000C16r 2                 ; Initialize write pointer to PROGRAM_START
000C16r 2  A9 00          lda #<PROGRAM_START
000C18r 2  85 2A          sta XFER_PTR
000C1Ar 2  A9 08          lda #>PROGRAM_START
000C1Cr 2  85 2B          sta XFER_PTR + 1
000C1Er 2                 ; Check for zero-length transfer
000C1Er 2  AD 17 03       lda XFER_REMAIN
000C21r 2  0D 18 03       ora XFER_REMAIN + 1
000C24r 2  F0 25          beq @AsciiLoadOk
000C26r 2                 ; Receive data bytes (Y stays 0, pointer is advanced each byte)
000C26r 2  A0 00          ldy #$00
000C28r 2               @AsciiLoadByte:
000C28r 2  20 rr rr       jsr BufferSize
000C2Br 2  F0 FB          beq @AsciiLoadByte
000C2Dr 2  20 rr rr       jsr ReadBuffer
000C30r 2  91 2A          sta (XFER_PTR),y              ; Write byte to target address
000C32r 2                 ; Advance write pointer
000C32r 2  E6 2A          inc XFER_PTR
000C34r 2  D0 02          bne @AsciiLoadNoPage
000C36r 2  E6 2B          inc XFER_PTR + 1
000C38r 2               @AsciiLoadNoPage:
000C38r 2                 ; Decrement remaining count
000C38r 2  AD 17 03       lda XFER_REMAIN
000C3Br 2  D0 03          bne @AsciiLoadDecLo
000C3Dr 2  CE 18 03       dec XFER_REMAIN + 1
000C40r 2               @AsciiLoadDecLo:
000C40r 2  CE 17 03       dec XFER_REMAIN
000C43r 2                 ; Check if done
000C43r 2  AD 17 03       lda XFER_REMAIN
000C46r 2  0D 18 03       ora XFER_REMAIN + 1
000C49r 2  D0 DD          bne @AsciiLoadByte
000C4Br 2               @AsciiLoadOk:
000C4Br 2                 ; XFER_PTR now points past last byte written
000C4Br 2                 ; Print success message
000C4Br 2  A9 0D          lda #$0D
000C4Dr 2  20 rr rr       jsr SerialChrout
000C50r 2  A9 0A          lda #$0A
000C52r 2  20 rr rr       jsr SerialChrout
000C55r 2  A9 rr          lda #<@AsciiOkMsg
000C57r 2  85 02          sta STR_PTR
000C59r 2  A9 rr          lda #>@AsciiOkMsg
000C5Br 2  85 03          sta STR_PTR + 1
000C5Dr 2  20 rr rr       jsr @SerialPrintStr
000C60r 2                 ; Restore IO_MODE
000C60r 2  AD 19 03       lda XFER_IO_SAVE
000C63r 2  8D 06 03       sta IO_MODE
000C66r 2  18             clc                           ; Success
000C67r 2  60             rts
000C68r 2               
000C68r 2               ; Internal: print null-terminated string via serial
000C68r 2               ; Input: STR_PTR points to string
000C68r 2               @SerialPrintStr:
000C68r 2  A0 00          ldy #$00
000C6Ar 2               @SerialPrintLoop:
000C6Ar 2  B1 02          lda (STR_PTR),y
000C6Cr 2  F0 06          beq @SerialPrintDone
000C6Er 2  20 rr rr       jsr SerialChrout
000C71r 2  C8             iny
000C72r 2  D0 F6          bne @SerialPrintLoop
000C74r 2               @SerialPrintDone:
000C74r 2  60             rts
000C75r 2               
000C75r 2  52 45 41 44  @AsciiLoadMsg: .asciiz "READY TO RECEIVE"
000C79r 2  59 20 54 4F  
000C7Dr 2  20 52 45 43  
000C86r 2  4F 4B 00     @AsciiOkMsg:   .asciiz "OK"
000C89r 2               
000C89r 2               ; --- ASCII Save ---
000C89r 2               
000C89r 2               ; AsciiSaveImpl — Transmit program memory as raw binary via serial
000C89r 2               ; Sends 2-byte size (lo/hi) then raw data bytes from PROGRAM_START to BAS_PRGEND
000C89r 2               ; Output: Carry clear = success
000C89r 2               ; Modifies: Flags, A, X, Y
000C89r 2               AsciiSaveImpl:
000C89r 2                 ; Save and switch IO_MODE to serial
000C89r 2  AD 06 03       lda IO_MODE
000C8Cr 2  8D 19 03       sta XFER_IO_SAVE
000C8Fr 2  A9 01          lda #$01
000C91r 2  8D 06 03       sta IO_MODE
000C94r 2                 ; Initialize save pointer
000C94r 2  A9 00          lda #<PROGRAM_START
000C96r 2  85 2A          sta XFER_PTR
000C98r 2  A9 08          lda #>PROGRAM_START
000C9Ar 2  85 2B          sta XFER_PTR + 1
000C9Cr 2                 ; Calculate remaining bytes = BAS_PRGEND - PROGRAM_START
000C9Cr 2  A5 12          lda z:BAS_PRGEND
000C9Er 2  38             sec
000C9Fr 2  E9 00          sbc #<PROGRAM_START
000CA1r 2  8D 17 03       sta XFER_REMAIN
000CA4r 2  A5 13          lda z:BAS_PRGEND + 1
000CA6r 2  E9 08          sbc #>PROGRAM_START
000CA8r 2  8D 18 03       sta XFER_REMAIN + 1
000CABr 2                 ; Send 2-byte size (low byte first)
000CABr 2  AD 17 03       lda XFER_REMAIN
000CAEr 2  20 rr rr       jsr SerialChrout
000CB1r 2  AD 18 03       lda XFER_REMAIN + 1
000CB4r 2  20 rr rr       jsr SerialChrout
000CB7r 2                 ; Check for zero-length program
000CB7r 2  AD 17 03       lda XFER_REMAIN
000CBAr 2  0D 18 03       ora XFER_REMAIN + 1
000CBDr 2  F0 20          beq @AsciiSaveDone
000CBFr 2                 ; Send data bytes (Y stays 0, pointer is advanced each byte)
000CBFr 2  A0 00          ldy #$00
000CC1r 2               @AsciiSaveByte:
000CC1r 2  B1 2A          lda (XFER_PTR),y
000CC3r 2  20 rr rr       jsr SerialChrout
000CC6r 2                 ; Advance read pointer
000CC6r 2  E6 2A          inc XFER_PTR
000CC8r 2  D0 02          bne @AsciiSaveNoPage
000CCAr 2  E6 2B          inc XFER_PTR + 1
000CCCr 2               @AsciiSaveNoPage:
000CCCr 2                 ; Decrement remaining count
000CCCr 2  AD 17 03       lda XFER_REMAIN
000CCFr 2  D0 03          bne @AsciiSaveDecLo
000CD1r 2  CE 18 03       dec XFER_REMAIN + 1
000CD4r 2               @AsciiSaveDecLo:
000CD4r 2  CE 17 03       dec XFER_REMAIN
000CD7r 2                 ; Check if done
000CD7r 2  AD 17 03       lda XFER_REMAIN
000CDAr 2  0D 18 03       ora XFER_REMAIN + 1
000CDDr 2  D0 E2          bne @AsciiSaveByte
000CDFr 2               @AsciiSaveDone:
000CDFr 2                 ; Restore IO_MODE
000CDFr 2  AD 19 03       lda XFER_IO_SAVE
000CE2r 2  8D 06 03       sta IO_MODE
000CE5r 2  18             clc                           ; Success
000CE6r 2  60             rts
000CE7r 2               
000CE7r 2               ; Draw the splash screen
000CE7r 2               ; Uses video output to display centered title and boot menu
000CE7r 2               ; Skips if video card is absent
000CE7r 2               ; Modifies: Flags, A, X, Y
000CE7r 2               Splash:
000CE7r 2  AD 0D 03       lda HW_PRESENT
000CEAr 2  29 80          and #HW_VID
000CECr 2  D0 01          bne @SplashStart
000CEEr 2  60             rts                           ; No video — skip
000CEFr 2               @SplashStart:
000CEFr 2  20 rr rr       jsr VideoClear                ; Clear the video screen
000CF2r 2                 ; Position cursor at row 10, col 10 for title
000CF2r 2  A2 0A          ldx #10
000CF4r 2  A0 0A          ldy #10
000CF6r 2  20 rr rr       jsr VideoSetCursor
000CF9r 2  A9 rr          lda #<@SplashTitle
000CFBr 2  85 02          sta STR_PTR
000CFDr 2  A9 rr          lda #>@SplashTitle
000CFFr 2  85 03          sta STR_PTR + 1
000D01r 2  20 rr rr       jsr VideoPrintStrImpl
000D04r 2                 ; Position cursor at row 12, col 8 for boot menu (centered: (40-24)/2 = 8)
000D04r 2  A2 08          ldx #8
000D06r 2  A0 0C          ldy #12
000D08r 2  20 rr rr       jsr VideoSetCursor
000D0Br 2  A9 rr          lda #<@SplashMenu
000D0Dr 2  85 02          sta STR_PTR
000D0Fr 2  A9 rr          lda #>@SplashMenu
000D11r 2  85 03          sta STR_PTR + 1
000D13r 2  20 rr rr       jsr VideoPrintStrImpl
000D16r 2  60             rts
000D17r 2  2D 2D 20 36  @SplashTitle: .asciiz "-- 6502 BIOS v1.0 --"
000D1Br 2  35 30 32 20  
000D1Fr 2  42 49 4F 53  
000D2Cr 2  45 4E 54 45  @SplashMenu:  .asciiz "ENTER=BASIC  ESC=MONITOR"
000D30r 2  52 3D 42 41  
000D34r 2  53 49 43 20  
000D45r 2               
000D45r 2               ; NMI Handler
000D45r 2               Nmi:
000D45r 2  40             rti
000D46r 2               
000D46r 2               ; BRK Handler — saves full CPU state and enters monitor
000D46r 2               ; On entry from @IrqBrk: A/X/Y are the user's original values (restored by IRQ handler).
000D46r 2               ; The CPU's hardware push left P/PCL/PCH on the stack.
000D46r 2               Break:
000D46r 2  8D 13 03       sta BRK_A                     ; Save user's A register
000D49r 2  8E 14 03       stx BRK_X                     ; Save user's X register
000D4Cr 2  8C 15 03       sty BRK_Y                     ; Save user's Y register
000D4Fr 2  BA             tsx                           ; Get current SP
000D50r 2  8E 16 03       stx BRK_SP                   ; Save SP (points below P/PCL/PCH on stack)
000D53r 2  68             pla                           ; Pull saved P
000D54r 2  8D 10 03       sta BRK_P
000D57r 2  68             pla                           ; Pull saved PCL (PC+2)
000D58r 2  8D 11 03       sta BRK_PCL
000D5Br 2  68             pla                           ; Pull saved PCH
000D5Cr 2  8D 12 03       sta BRK_PCH
000D5Fr 2  4C rr rr       jmp MonitorBrkEntry
000D62r 2               
000D62r 2               ; IRQ Handler
000D62r 2               Irq:
000D62r 2  48             pha
000D63r 2  5A             phy
000D64r 2  DA             phx
000D65r 2  BA             tsx                           ; Get stack pointer to check saved status register
000D66r 2  BD 04 01       lda $104,x                    ; Load saved P (SP+4: past X, Y, A we pushed)
000D69r 2  29 10          and #$10                      ; Test B flag — set by BRK, clear by hardware IRQ
000D6Br 2  D0 47          bne @IrqBrk                   ; Branch if this was a BRK instruction
000D6Dr 2               @IrqSc:
000D6Dr 2  AD 0D 03       lda HW_PRESENT
000D70r 2  29 10          and #HW_SC
000D72r 2  F0 19          beq @IrqCheckKB               ; Serial not present — skip
000D74r 2  AD 01 90       lda SC_STATUS
000D77r 2  29 80          and #SC_STATUS_IRQ            ; Check if serial data caused the interrupt
000D79r 2  F0 12          beq @IrqCheckKB               ; If not, check keyboard
000D7Br 2  AD 00 90       lda SC_DATA                   ; Read the data from serial register
000D7Er 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000D81r 2  20 rr rr       jsr BufferSize
000D84r 2  C9 F0          cmp #$F0                      ; Is the buffer almost full?
000D86r 2  90 05          bcc @IrqCheckKB               ; If not, also check keyboard
000D88r 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
000D8Ar 2  8D 02 90       sta SC_CMD                    ; Otherwise, signal not ready for receiving (RTSB high)
000D8Dr 2                                               ; Fall through to check keyboard — always clear VIA flags
000D8Dr 2               @IrqCheckKB:
000D8Dr 2  AD 0D 03       lda HW_PRESENT
000D90r 2  29 20          and #HW_GPIO
000D92r 2  F0 1C          beq @IrqExit                  ; GPIO not present — skip
000D94r 2  AD 0D 94       lda GPIO_IFR
000D97r 2  29 10          and #GPIO_INT_CB1             ; Check if CB1 (matrix keyboard data ready) caused the interrupt
000D99r 2  F0 08          beq @IrqCheckPS2              ; If not, check PS/2 keyboard
000D9Br 2  AD 00 94       lda GPIO_PORTB                ; Read ASCII byte from matrix keyboard (also clears CB1 IFR flag)
000D9Er 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000DA1r 2  80 0D          bra @IrqExit
000DA3r 2               @IrqCheckPS2:
000DA3r 2  AD 0D 94       lda GPIO_IFR
000DA6r 2  29 02          and #GPIO_INT_CA1             ; Check if CA1 (PS/2 keyboard data ready) caused the interrupt
000DA8r 2  F0 06          beq @IrqExit                  ; If not, exit
000DAAr 2  AD 01 94       lda GPIO_PORTA                ; Read ASCII byte from PS/2 keyboard (also clears CA1 IFR flag)
000DADr 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
000DB0r 2               @IrqExit:
000DB0r 2  FA             plx
000DB1r 2  7A             ply
000DB2r 2  68             pla
000DB3r 2  40             rti
000DB4r 2               @IrqBrk:
000DB4r 2  FA             plx                           ; Restore saved registers
000DB5r 2  7A             ply
000DB6r 2  68             pla
000DB7r 2  58             cli                           ; Re-enable interrupts — abandoning interrupt context
000DB8r 2  6C 02 03       jmp (BRK_PTR)                 ; BRK — dispatch with P/PCL/PCH still on stack
000DBBr 2               
000DBBr 2               ; NMI Vector
000DBBr 2               NmiVec:
000DBBr 2  6C 04 03       jmp (NMI_PTR)                 ; Indirect jump through NMI pointer to the NMI handler
000DBEr 2               
000DBEr 2               ; Reset Vector
000DBEr 2               ResetVec:
000DBEr 2  4C rr rr       jmp Reset                     ; Initialize the system
000DC1r 2               
000DC1r 2               ; IRQ Vector
000DC1r 2               IrqVec:
000DC1r 2  6C 00 03       jmp (IRQ_PTR)                 ; Indirect jump through IRQ pointer to the IRQ handler
000DC4r 2               
000DC4r 1               .segment "CHARS"
000000r 1               .include "Chars.asm"
000000r 2               ; IBM Code Page 437 Character Set
000000r 2               ; 5x8 pixel font in 8x8 area, 8 bytes per character (256 characters total)
000000r 2               ; Each byte represents one horizontal row of pixels (5 pixels left-aligned in 8-bit space)
000000r 2               
000000r 2               CharacterSet:
000000r 2                   ; Character $00 - NULL (blank)
000000r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $00, $00, $00
000004r 2  00 00 00 00  
