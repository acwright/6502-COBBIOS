0008C7r 2  F0 05          beq @DoAdd
0008C9r 2  C9 2D          cmp #CH_MINUS
0008CBr 2  F0 19          beq @DoSub
0008CDr 2  60             rts
0008CEr 2               
0008CEr 2               @DoAdd:
0008CEr 2  20 rr rr       jsr BasAdvTxtPtr
0008D1r 2  A5 0A          lda BAS_ACC
0008D3r 2  48             pha
0008D4r 2  A5 0B          lda BAS_ACC + 1
0008D6r 2  48             pha
0008D7r 2  20 rr rr       jsr BasExprMul
0008DAr 2  68             pla
0008DBr 2  85 0D          sta BAS_AUX + 1
0008DDr 2  68             pla
0008DEr 2  85 0C          sta BAS_AUX
