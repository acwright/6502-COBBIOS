0021D5r 2               ; ---------------------------------------------------------------------------
0021D5r 2               ; Statement: IF expr THEN (linenum | stmt) [ELSE stmt]
0021D5r 2               ;   IF expr GOTO linenum is also accepted.
0021D5r 2               ;   If expr is false, skip rest of line (REM-style).
0021D5r 2               ;   ELSE: scan ahead for TOK_ELSE on this line.
0021D5r 2               ; ---------------------------------------------------------------------------
0021D5r 2               BasCmdIf:
0021D5r 2  20 rr rr             jsr     FrmEvl
0021D8r 2  20 rr rr             jsr     ChrGot
