00096Fr 2               
00096Fr 2                 ; Variable A-Z?
00096Fr 2  C9 41          cmp #'A'
000971r 2  90 16          bcc @NotVar
000973r 2  C9 5B          cmp #'Z' + 1
000975r 2  B0 12          bcs @NotVar
000977r 2                 ; Variable — compute address: BAS_VARS + (ch - 'A') * 2
000977r 2  38             sec
000978r 2  E9 41          sbc #'A'
00097Ar 2  0A             asl                            ; ×2 for 16-bit
00097Br 2  AA             tax
00097Cr 2  BD 00 04       lda BAS_VARS,x
00097Fr 2  85 0A          sta BAS_ACC
000981r 2  BD 01 04       lda BAS_VARS + 1,x
000984r 2  85 0B          sta BAS_ACC + 1
000986r 2  4C rr rr       jmp BasAdvTxtPtr               ; Skip variable letter
000989r 2               @NotVar:
000989r 2               
000989r 2                 ; Parenthesized expression?
000989r 2  C9 28          cmp #CH_LPAREN
00098Br 2  D0 0B          bne @NotParen
00098Dr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
000990r 2  20 rr rr       jsr BasExpr
000993r 2  A9 29          lda #CH_RPAREN
000995r 2  4C rr rr       jmp BasExpectChar              ; Expect and skip ')'
000998r 2               @NotParen:
000998r 2               
000998r 2                 ; PEEK(expr)?
000998r 2  C9 92          cmp #TOK_PEEK
00099Ar 2  D0 21          bne @NotPeek
00099Cr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip PEEK token
00099Fr 2  A9 28          lda #CH_LPAREN
0009A1r 2  20 rr rr       jsr BasExpectChar
0009A4r 2  20 rr rr       jsr BasExpr
0009A7r 2  A9 29          lda #CH_RPAREN
0009A9r 2  20 rr rr       jsr BasExpectChar
0009ACr 2                 ; Load byte from address in ACC
0009ACr 2  A5 0A          lda BAS_ACC
0009AEr 2  85 10          sta BAS_TMP2
0009B0r 2  A5 0B          lda BAS_ACC + 1
0009B2r 2  85 11          sta BAS_TMP2 + 1
0009B4r 2  A0 00          ldy #$00
0009B6r 2  B1 10          lda (BAS_TMP2),y
0009B8r 2  85 0A          sta BAS_ACC
0009BAr 2  64 0B          stz BAS_ACC + 1
0009BCr 2  60             rts
0009BDr 2               @NotPeek:
0009BDr 2               
0009BDr 2                 ; ABS(expr)?
0009BDr 2  C9 94          cmp #TOK_ABS
0009BFr 2  D0 13          bne @NotAbs
0009C1r 2  20 rr rr       jsr BasAdvTxtPtr
0009C4r 2  A9 28          lda #CH_LPAREN
0009C6r 2  20 rr rr       jsr BasExpectChar
0009C9r 2  20 rr rr       jsr BasExpr
0009CCr 2  A9 29          lda #CH_RPAREN
0009CEr 2  20 rr rr       jsr BasExpectChar
0009D1r 2  4C rr rr       jmp BasMathAbs
0009D4r 2               @NotAbs:
0009D4r 2               
0009D4r 2                 ; RND(expr)?
0009D4r 2  C9 95          cmp #TOK_RND
0009D6r 2  D0 50          bne @NotRnd
0009D8r 2  20 rr rr       jsr BasAdvTxtPtr
0009DBr 2  A9 28          lda #CH_LPAREN
0009DDr 2  20 rr rr       jsr BasExpectChar
0009E0r 2  20 rr rr       jsr BasExpr
0009E3r 2  A9 29          lda #CH_RPAREN
0009E5r 2  20 rr rr       jsr BasExpectChar
0009E8r 2                 ; Save modulus (ACC) and generate random number
0009E8r 2  A5 0A          lda BAS_ACC
0009EAr 2  48             pha
0009EBr 2  A5 0B          lda BAS_ACC + 1
0009EDr 2  48             pha
0009EEr 2                 ; Galois LFSR step
0009EEr 2  A5 18          lda BAS_RNDSEED
0009F0r 2  0A             asl
0009F1r 2  26 19          rol BAS_RNDSEED + 1
0009F3r 2  90 02          bcc @RndNoTap
0009F5r 2  49 2D          eor #$2D                      ; Tap polynomial
0009F7r 2               @RndNoTap:
0009F7r 2  85 18          sta BAS_RNDSEED
0009F9r 2                 ; Use seed as raw random value
0009F9r 2  A5 18          lda BAS_RNDSEED
0009FBr 2  85 0C          sta BAS_AUX
0009FDr 2  A5 19          lda BAS_RNDSEED + 1
0009FFr 2                 ; Make positive
0009FFr 2  29 7F          and #$7F
000A01r 2  85 0D          sta BAS_AUX + 1
000A03r 2                 ; Restore modulus
000A03r 2  68             pla
000A04r 2  85 0B          sta BAS_ACC + 1
000A06r 2  68             pla
000A07r 2  85 0A          sta BAS_ACC
000A09r 2                 ; If modulus <= 0, just return raw number
000A09r 2  A5 0A          lda BAS_ACC
000A0Br 2  05 0B          ora BAS_ACC + 1
000A0Dr 2  F0 10          beq @RndRaw
000A0Fr 2  A5 0B          lda BAS_ACC + 1
000A11r 2  30 0C          bmi @RndRaw
000A13r 2                 ; ACC = AUX MOD ACC
000A13r 2  20 rr rr       jsr BasMathDiv
000A16r 2  A5 1E          lda BAS_SCRATCH2
000A18r 2  85 0A          sta BAS_ACC
000A1Ar 2  A5 1F          lda BAS_SCRATCH2 + 1
000A1Cr 2  85 0B          sta BAS_ACC + 1
000A1Er 2  60             rts
000A1Fr 2               @RndRaw:
000A1Fr 2  A5 0C          lda BAS_AUX
000A21r 2  85 0A          sta BAS_ACC
000A23r 2  A5 0D          lda BAS_AUX + 1
000A25r 2  85 0B          sta BAS_ACC + 1
000A27r 2  60             rts
000A28r 2               @NotRnd:
000A28r 2               
000A28r 2                 ; Try parsing as a number
000A28r 2               @IsNum:
000A28r 2  4C rr rr       jmp BasParseInt                ; Parse decimal, result in ACC
000A2Br 2               
000A2Br 2               ; ============================================================================
000A2Br 2               ; Command Dispatch and Execution
000A2Br 2               ; ============================================================================
000A2Br 2               
000A2Br 2               ; BasExecLine — Execute one tokenized line starting at TXTPTR
000A2Br 2               BasExecLine:
000A2Br 2  20 rr rr       jsr BasSkipSpaces
000A2Er 2  20 rr rr       jsr BasGetTokChar
000A31r 2  D0 01          bne @ExecNotNull
000A33r 2  60             rts                            ; Null = end of line
000A34r 2               @ExecNotNull:
000A34r 2               
000A34r 2                 ; Dispatch based on token/character
000A34r 2  C9 80          cmp #TOK_PRINT
000A36r 2  D0 03          bne :+
000A38r 2  4C rr rr       jmp @JmpPrint
000A3Br 2  C9 81        : cmp #TOK_INPUT
000A3Dr 2  D0 03          bne :+
000A3Fr 2  4C rr rr       jmp @JmpInput
000A42r 2  C9 83        : cmp #TOK_GOTO
000A44r 2  D0 03          bne :+
000A46r 2  4C rr rr       jmp @JmpGoto
000A49r 2  C9 84        : cmp #TOK_GOSUB
000A4Br 2  D0 03          bne :+
000A4Dr 2  4C rr rr       jmp @JmpGosub
000A50r 2  C9 85        : cmp #TOK_RETURN
000A52r 2  D0 03          bne :+
000A54r 2  4C rr rr       jmp @JmpReturn
000A57r 2  C9 86        : cmp #TOK_IF
000A59r 2  D0 03          bne :+
000A5Br 2  4C rr rr       jmp @JmpIf
000A5Er 2  C9 88        : cmp #TOK_FOR
000A60r 2  D0 03          bne :+
000A62r 2  4C rr rr       jmp @JmpFor
000A65r 2  C9 8B        : cmp #TOK_NEXT
000A67r 2  D0 03          bne :+
000A69r 2  4C rr rr       jmp @JmpNext
000A6Cr 2  C9 8C        : cmp #TOK_REM
000A6Er 2  D0 01          bne @NotRem
000A70r 2  60             rts                            ; REM — skip rest of line
000A71r 2               @NotRem:
000A71r 2  C9 8D          cmp #TOK_END
000A73r 2  D0 03          bne @NotEnd
000A75r 2  4C rr rr       jmp @JmpEnd
000A78r 2               @NotEnd:
000A78r 2  C9 8E          cmp #TOK_LIST
000A7Ar 2  D0 03          bne @NotList
000A7Cr 2  4C rr rr       jmp @JmpList
000A7Fr 2               @NotList:
000A7Fr 2  C9 8F          cmp #TOK_RUN
000A81r 2  D0 03          bne @NotRun
000A83r 2  4C rr rr       jmp @JmpRun
000A86r 2               @NotRun:
000A86r 2  C9 90          cmp #TOK_NEW
000A88r 2  D0 03          bne @NotNew
000A8Ar 2  4C rr rr       jmp @JmpNew
000A8Dr 2               @NotNew:
000A8Dr 2  C9 91          cmp #TOK_CLR
000A8Fr 2  D0 03          bne @NotClr
000A91r 2  4C rr rr       jmp @JmpClrCmd
000A94r 2               @NotClr:
000A94r 2  C9 93          cmp #TOK_POKE
000A96r 2  D0 03          bne @NotPoke
000A98r 2  4C rr rr       jmp @JmpPoke
000A9Br 2               @NotPoke:
000A9Br 2  C9 82          cmp #TOK_LET
000A9Dr 2  D0 03          bne @NotLet
000A9Fr 2  4C rr rr       jmp @JmpLet
000AA2r 2               @NotLet:
000AA2r 2  C9 9D          cmp #TOK_BRK
000AA4r 2  D0 03          bne @NotBrk
000AA6r 2  4C rr rr       jmp @JmpBrk
000AA9r 2               @NotBrk:
000AA9r 2  C9 9E          cmp #TOK_SYS
000AABr 2  D0 03          bne @NotSys
000AADr 2  4C rr rr       jmp @JmpSys
000AB0r 2               @NotSys:
000AB0r 2  C9 9F          cmp #TOK_LOAD
000AB2r 2  D0 03          bne @NotLoad
000AB4r 2  4C rr rr       jmp @JmpLoad
000AB7r 2               @NotLoad:
000AB7r 2  C9 A0          cmp #TOK_SAVE
000AB9r 2  D0 03          bne @NotSave
000ABBr 2  4C rr rr       jmp @JmpSave
000ABEr 2               @NotSave:
000ABEr 2  C9 A1          cmp #TOK_DIR
000AC0r 2  D0 03          bne @NotDir
000AC2r 2  4C rr rr       jmp @JmpDir
000AC5r 2               @NotDir:
000AC5r 2               
000AC5r 2                 ; Check for implicit LET: A-Z followed by =
000AC5r 2  C9 41          cmp #'A'
000AC7r 2  90 07          bcc @ExecSyntaxErr
000AC9r 2  C9 5B          cmp #'Z' + 1
000ACBr 2  B0 03          bcs @ExecSyntaxErr
000ACDr 2                 ; Don't consume the variable letter — BasCmdLet will read it
000ACDr 2  4C rr rr       jmp BasCmdLet
000AD0r 2               
000AD0r 2               @ExecSyntaxErr:
000AD0r 2  A9 00          lda #ERR_SYNTAX
000AD2r 2  4C rr rr       jmp BasError
000AD5r 2               
000AD5r 2               @JmpPrint:
000AD5r 2  20 rr rr       jsr BasAdvTxtPtr
000AD8r 2  20 rr rr       jsr BasCmdPrint
000ADBr 2  80 78          bra @ExecCheckMore
000ADDr 2               @JmpInput:
000ADDr 2  20 rr rr       jsr BasAdvTxtPtr
000AE0r 2  20 rr rr       jsr BasCmdInput
000AE3r 2  80 70          bra @ExecCheckMore
000AE5r 2               @JmpGoto:
000AE5r 2  20 rr rr       jsr BasAdvTxtPtr
000AE8r 2  4C rr rr       jmp BasCmdGoto                 ; Goto changes TXTPTR, don't check for ':'
000AEBr 2               @JmpGosub:
000AEBr 2  20 rr rr       jsr BasAdvTxtPtr
000AEEr 2  4C rr rr       jmp BasCmdGosub
000AF1r 2               @JmpReturn:
000AF1r 2  20 rr rr       jsr BasAdvTxtPtr
000AF4r 2  4C rr rr       jmp BasCmdReturn
000AF7r 2               @JmpIf:
000AF7r 2  20 rr rr       jsr BasAdvTxtPtr
000AFAr 2  4C rr rr       jmp BasCmdIf
000AFDr 2               @JmpFor:
000AFDr 2  20 rr rr       jsr BasAdvTxtPtr
000B00r 2  4C rr rr       jmp BasCmdFor
000B03r 2               @JmpNext:
000B03r 2  20 rr rr       jsr BasAdvTxtPtr
000B06r 2  4C rr rr       jmp BasCmdNext
000B09r 2               @JmpEnd:
000B09r 2  4C rr rr       jmp BasCmdEnd
000B0Cr 2               @JmpList:
000B0Cr 2  20 rr rr       jsr BasAdvTxtPtr
000B0Fr 2  20 rr rr       jsr BasCmdList
000B12r 2  80 41          bra @ExecCheckMore
000B14r 2               @JmpRun:
000B14r 2  4C rr rr       jmp BasCmdRun
000B17r 2               @JmpNew:
000B17r 2  4C rr rr       jmp BasCmdNew
000B1Ar 2               @JmpClrCmd:
000B1Ar 2  20 rr rr       jsr BasAdvTxtPtr
000B1Dr 2  20 rr rr       jsr BasCmdClr
000B20r 2  80 33          bra @ExecCheckMore
000B22r 2               @JmpPoke:
000B22r 2  20 rr rr       jsr BasAdvTxtPtr
000B25r 2  20 rr rr       jsr BasCmdPoke
000B28r 2  80 2B          bra @ExecCheckMore
000B2Ar 2               @JmpLet:
000B2Ar 2  20 rr rr       jsr BasAdvTxtPtr
000B2Dr 2  20 rr rr       jsr BasCmdLet
000B30r 2  80 23          bra @ExecCheckMore
000B32r 2               @JmpBrk:
000B32r 2  4C rr rr       jmp BasCmdBrk
000B35r 2               @JmpSys:
000B35r 2  20 rr rr       jsr BasAdvTxtPtr
000B38r 2  20 rr rr       jsr BasCmdSys
000B3Br 2  80 18          bra @ExecCheckMore
000B3Dr 2               @JmpLoad:
000B3Dr 2  20 rr rr       jsr BasAdvTxtPtr
000B40r 2  20 rr rr       jsr BasCmdLoad
000B43r 2  80 10          bra @ExecCheckMore
000B45r 2               @JmpSave:
000B45r 2  20 rr rr       jsr BasAdvTxtPtr
000B48r 2  20 rr rr       jsr BasCmdSave
000B4Br 2  80 08          bra @ExecCheckMore
000B4Dr 2               @JmpDir:
000B4Dr 2  20 rr rr       jsr BasAdvTxtPtr
000B50r 2  20 rr rr       jsr BasCmdDir
000B53r 2  80 00          bra @ExecCheckMore
000B55r 2               
000B55r 2               @ExecCheckMore:
000B55r 2                 ; Check for ':' statement separator
000B55r 2  20 rr rr       jsr BasSkipSpaces
000B58r 2  20 rr rr       jsr BasGetTokChar
000B5Br 2  C9 3A          cmp #CH_COLON
000B5Dr 2  D0 06          bne @ExecDone
000B5Fr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ':'
000B62r 2  4C rr rr       jmp BasExecLine                ; Execute next statement
000B65r 2               @ExecDone:
000B65r 2  60             rts
000B66r 2               
000B66r 2               ; ============================================================================
000B66r 2               ; RUN — Execute program from first line
000B66r 2               ; ============================================================================
000B66r 2               
000B66r 2               BasCmdRun:
000B66r 2  20 rr rr       jsr BasCmdClr
000B69r 2  A9 01          lda #BAS_FLAG_RUN
000B6Br 2  85 17          sta BAS_FLAGS
000B6Dr 2               
000B6Dr 2                 ; Start at first program line
000B6Dr 2  A9 00          lda #<BAS_PRG_START
000B6Fr 2  85 06          sta BAS_CURLINE
000B71r 2  A9 08          lda #>BAS_PRG_START
000B73r 2  85 07          sta BAS_CURLINE + 1
000B75r 2               
000B75r 2               BasRunLoop:
000B75r 2                 ; Check if at end of program (CURLINE == PRGEND)
000B75r 2  A5 06          lda BAS_CURLINE
000B77r 2  C5 12          cmp BAS_PRGEND
000B79r 2  D0 06          bne @RunNotEnd
000B7Br 2  A5 07          lda BAS_CURLINE + 1
000B7Dr 2  C5 13          cmp BAS_PRGEND + 1
000B7Fr 2  F0 51          beq BasRunDone
000B81r 2               @RunNotEnd:
000B81r 2               
000B81r 2                 ; Check for Ctrl+C break
000B81r 2  20 rr rr       jsr BasCheckBreak
000B84r 2               
000B84r 2                 ; Get line number
000B84r 2  A0 02          ldy #LINE_NUM
000B86r 2  B1 06          lda (BAS_CURLINE),y
000B88r 2  85 08          sta BAS_LINENUM
000B8Ar 2  C8             iny
000B8Br 2  B1 06          lda (BAS_CURLINE),y
000B8Dr 2  85 09          sta BAS_LINENUM + 1
000B8Fr 2               
000B8Fr 2                 ; Save CURLINE before execution for GOTO/GOSUB detection
000B8Fr 2  A5 06          lda BAS_CURLINE
000B91r 2  85 14          sta BAS_VARPTR
000B93r 2  A5 07          lda BAS_CURLINE + 1
000B95r 2  85 15          sta BAS_VARPTR + 1
000B97r 2               
000B97r 2                 ; Set TXTPTR to payload
000B97r 2  18             clc
000B98r 2  A5 06          lda BAS_CURLINE
000B9Ar 2  69 04          adc #LINE_PAYLOAD
000B9Cr 2  85 04          sta BAS_TXTPTR
000B9Er 2  A5 07          lda BAS_CURLINE + 1
000BA0r 2  69 00          adc #$00
000BA2r 2  85 05          sta BAS_TXTPTR + 1
000BA4r 2               
000BA4r 2                 ; Execute the line
000BA4r 2  20 rr rr       jsr BasExecLine
000BA7r 2               
000BA7r 2                 ; Check if END was executed (flags cleared)
000BA7r 2  A5 17          lda BAS_FLAGS
000BA9r 2  29 01          and #BAS_FLAG_RUN
000BABr 2  F0 25          beq BasRunDone
000BADr 2               
000BADr 2                 ; Check if GOTO/GOSUB changed CURLINE
000BADr 2  A5 06          lda BAS_CURLINE
000BAFr 2  C5 14          cmp BAS_VARPTR
000BB1r 2  D0 C2          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
000BB3r 2  A5 07          lda BAS_CURLINE + 1
000BB5r 2  C5 15          cmp BAS_VARPTR + 1
000BB7r 2  D0 BC          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
000BB9r 2               
000BB9r 2                 ; Advance to next line by scanning for end of current line
000BB9r 2  A0 04          ldy #LINE_PAYLOAD
000BBBr 2               @RunScanNull:
000BBBr 2  B1 06          lda (BAS_CURLINE),y
000BBDr 2  F0 03          beq @RunFoundNull
000BBFr 2  C8             iny
000BC0r 2  80 F9          bra @RunScanNull
000BC2r 2               @RunFoundNull:
000BC2r 2  C8             iny                            ; Past null terminator
000BC3r 2  98             tya
000BC4r 2  18             clc
000BC5r 2  65 06          adc BAS_CURLINE
000BC7r 2  85 06          sta BAS_CURLINE
000BC9r 2  A9 00          lda #$00
000BCBr 2  65 07          adc BAS_CURLINE + 1
000BCDr 2  85 07          sta BAS_CURLINE + 1
000BCFr 2  4C rr rr       jmp BasRunLoop
000BD2r 2               
000BD2r 2               BasRunDone:
000BD2r 2  64 17          stz BAS_FLAGS
000BD4r 2  60             rts
000BD5r 2               
000BD5r 2               ; ============================================================================
000BD5r 2               ; Statement Handlers
000BD5r 2               ; ============================================================================
000BD5r 2               
000BD5r 2               ; --- PRINT ---
000BD5r 2               BasCmdPrint:
000BD5r 2  20 rr rr       jsr BasSkipSpaces
000BD8r 2  20 rr rr       jsr BasGetTokChar
000BDBr 2  F0 5E          beq @PrintNewline              ; Empty PRINT — just newline
000BDDr 2  C9 3A          cmp #CH_COLON
000BDFr 2  F0 5A          beq @PrintNewline              ; PRINT: — newline then next statement
000BE1r 2               
000BE1r 2               @PrintLoop:
000BE1r 2  20 rr rr       jsr BasSkipSpaces
000BE4r 2  20 rr rr       jsr BasGetTokChar
000BE7r 2  F0 55          beq @PrintEnd                  ; End of line
000BE9r 2  C9 3A          cmp #CH_COLON
000BEBr 2  F0 51          beq @PrintEnd
000BEDr 2               
000BEDr 2                 ; String literal?
000BEDr 2  C9 22          cmp #CH_QUOTE
000BEFr 2  F0 08          beq @PrintString
000BF1r 2               
000BF1r 2                 ; Otherwise evaluate expression and print number
000BF1r 2  20 rr rr       jsr BasExpr
000BF4r 2  20 rr rr       jsr BasPrintInt
000BF7r 2  80 17          bra @PrintSep
000BF9r 2               
000BF9r 2               @PrintString:
000BF9r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
000BFCr 2               @PrintStrCh:
000BFCr 2  20 rr rr       jsr BasGetTokChar
000BFFr 2  F0 3D          beq @PrintEnd                  ; Unterminated string
000C01r 2  C9 22          cmp #CH_QUOTE
000C03r 2  F0 08          beq @PrintStrEnd
000C05r 2  20 rr rr       jsr Chrout
000C08r 2  20 rr rr       jsr BasAdvTxtPtr
000C0Br 2  80 EF          bra @PrintStrCh
000C0Dr 2               @PrintStrEnd:
000C0Dr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
000C10r 2               
000C10r 2               @PrintSep:
000C10r 2  20 rr rr       jsr BasSkipSpaces
000C13r 2  20 rr rr       jsr BasGetTokChar
