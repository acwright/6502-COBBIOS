000C18r 2  F0 06          beq @PrintSemicolon
000C1Ar 2  C9 2C          cmp #CH_COMMA
000C1Cr 2  F0 13          beq @PrintComma
000C1Er 2                 ; No separator — done, print newline
000C1Er 2  80 1B          bra @PrintNewline
000C20r 2               
000C20r 2               @PrintSemicolon:
000C20r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ';'
000C23r 2                 ; Check if end of statement (suppress newline)
000C23r 2  20 rr rr       jsr BasSkipSpaces
000C26r 2  20 rr rr       jsr BasGetTokChar
000C29r 2  F0 13          beq @PrintDone                 ; End of line — suppress newline
000C2Br 2  C9 3A          cmp #CH_COLON
000C2Dr 2  F0 0F          beq @PrintDone                 ; Colon — suppress newline
000C2Fr 2  80 B0          bra @PrintLoop
000C31r 2               
000C31r 2               @PrintComma:
000C31r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
000C34r 2                 ; Print a tab (8 spaces approximated as a tab char)
000C34r 2  A9 09          lda #$09
000C36r 2  20 rr rr       jsr Chrout
000C39r 2  80 A6          bra @PrintLoop
000C3Br 2               
000C3Br 2               @PrintNewline:
000C3Br 2  20 rr rr       jsr BasPrintCRLF
000C3Er 2               @PrintDone:
000C3Er 2               @PrintEnd:
000C3Er 2  60             rts
000C3Fr 2               
000C3Fr 2               ; --- INPUT ---
000C3Fr 2               BasCmdInput:
000C3Fr 2  20 rr rr       jsr BasSkipSpaces
000C42r 2  20 rr rr       jsr BasGetTokChar
000C45r 2               
000C45r 2                 ; Check for optional prompt string
000C45r 2  C9 22          cmp #CH_QUOTE
000C47r 2  D0 3B          bne @InputNoPrompt
000C49r 2               
000C49r 2                 ; Print prompt string
000C49r 2  20 rr rr       jsr BasAdvTxtPtr
000C4Cr 2               @InputPromptCh:
000C4Cr 2  20 rr rr       jsr BasGetTokChar
000C4Fr 2  F0 0F          beq @InputPromptDone
000C51r 2  C9 22          cmp #CH_QUOTE
000C53r 2  F0 08          beq @InputPromptEnd
000C55r 2  20 rr rr       jsr Chrout
000C58r 2  20 rr rr       jsr BasAdvTxtPtr
000C5Br 2  80 EF          bra @InputPromptCh
000C5Dr 2               @InputPromptEnd:
000C5Dr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
000C60r 2               @InputPromptDone:
000C60r 2                 ; Expect semicolon or comma after prompt
000C60r 2  20 rr rr       jsr BasSkipSpaces
000C63r 2  20 rr rr       jsr BasGetTokChar
000C66r 2  C9 3B          cmp #CH_SEMICOL
000C68r 2  F0 06          beq @InputSemiSep
000C6Ar 2  C9 2C          cmp #CH_COMMA
000C6Cr 2  F0 11          beq @InputCommaSep
000C6Er 2  80 1E          bra @InputGetVar
000C70r 2               
000C70r 2               @InputSemiSep:
000C70r 2  20 rr rr       jsr BasAdvTxtPtr
000C73r 2                 ; Print "? " after semicolon-style prompt
000C73r 2  A9 3F          lda #'?'
000C75r 2  20 rr rr       jsr Chrout
000C78r 2  A9 20          lda #CH_SPACE
000C7Ar 2  20 rr rr       jsr Chrout
000C7Dr 2  80 0F          bra @InputGetVar
000C7Fr 2               
000C7Fr 2               @InputCommaSep:
000C7Fr 2  20 rr rr       jsr BasAdvTxtPtr
000C82r 2                 ; No "? " with comma separator
000C82r 2  80 0A          bra @InputGetVar
000C84r 2               
000C84r 2               @InputNoPrompt:
000C84r 2                 ; Print default "? " prompt
000C84r 2  A9 3F          lda #'?'
000C86r 2  20 rr rr       jsr Chrout
000C89r 2  A9 20          lda #CH_SPACE
000C8Br 2  20 rr rr       jsr Chrout
000C8Er 2               
000C8Er 2               @InputGetVar:
000C8Er 2  20 rr rr       jsr BasSkipSpaces
000C91r 2  20 rr rr       jsr BasGetTokChar
000C94r 2               
000C94r 2                 ; Must be a variable A-Z
000C94r 2  C9 41          cmp #'A'
000C96r 2  90 5D          bcc @InputErr
000C98r 2  C9 5B          cmp #'Z' + 1
000C9Ar 2  B0 59          bcs @InputErr
000C9Cr 2               
000C9Cr 2                 ; Save variable index
000C9Cr 2  38             sec
000C9Dr 2  E9 41          sbc #'A'
000C9Fr 2  0A             asl
000CA0r 2  85 21          sta BAS_TEMP                   ; Variable offset
000CA2r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000CA5r 2               
000CA5r 2                 ; Save TXTPTR (points into tokenized program line)
000CA5r 2  A5 04          lda BAS_TXTPTR
000CA7r 2  48             pha
000CA8r 2  A5 05          lda BAS_TXTPTR + 1
000CAAr 2  48             pha
000CABr 2               
000CABr 2               @InputRetry:
000CABr 2                 ; Read a line of input
000CABr 2  20 rr rr       jsr BasReadLine
000CAEr 2               
000CAEr 2                 ; Point TXTPTR at input buffer for parsing
000CAEr 2  A9 34          lda #<BAS_LINBUF
000CB0r 2  85 04          sta BAS_TXTPTR
000CB2r 2  A9 04          lda #>BAS_LINBUF
000CB4r 2  85 05          sta BAS_TXTPTR + 1
000CB6r 2               
000CB6r 2                 ; Handle optional negative sign
000CB6r 2  64 20          stz BAS_SIGN
000CB8r 2  20 rr rr       jsr BasSkipSpaces
000CBBr 2  20 rr rr       jsr BasGetTokChar
000CBEr 2  C9 2D          cmp #CH_MINUS
000CC0r 2  D0 07          bne @InputParse
000CC2r 2  A9 FF          lda #$FF
000CC4r 2  85 20          sta BAS_SIGN
000CC6r 2  20 rr rr       jsr BasAdvTxtPtr
000CC9r 2               
000CC9r 2               @InputParse:
000CC9r 2  20 rr rr       jsr BasParseInt
000CCCr 2  B0 1A          bcs @InputBadNum               ; No digits found
000CCEr 2               
000CCEr 2                 ; Negate if minus was present
000CCEr 2  A5 20          lda BAS_SIGN
000CD0r 2  F0 03          beq @InputStore
000CD2r 2  20 rr rr       jsr BasMathNeg
000CD5r 2               
000CD5r 2               @InputStore:
000CD5r 2                 ; Store in variable
000CD5r 2  A6 21          ldx BAS_TEMP
000CD7r 2  A5 0A          lda BAS_ACC
000CD9r 2  9D 00 04       sta BAS_VARS,x
000CDCr 2  A5 0B          lda BAS_ACC + 1
000CDEr 2  9D 01 04       sta BAS_VARS + 1,x
000CE1r 2               
000CE1r 2                 ; Restore TXTPTR to tokenized program line
000CE1r 2  68             pla
000CE2r 2  85 05          sta BAS_TXTPTR + 1
000CE4r 2  68             pla
000CE5r 2  85 04          sta BAS_TXTPTR
000CE7r 2  60             rts
000CE8r 2               
000CE8r 2               @InputBadNum:
000CE8r 2  A9 rr          lda #<BasStrRedo
000CEAr 2  85 0E          sta BAS_TMP1
000CECr 2  A9 rr          lda #>BasStrRedo
000CEEr 2  85 0F          sta BAS_TMP1 + 1
000CF0r 2  20 rr rr       jsr BasPrintStr
000CF3r 2  80 B6          bra @InputRetry
000CF5r 2               
000CF5r 2               @InputErr:
000CF5r 2  A9 00          lda #ERR_SYNTAX
000CF7r 2  4C rr rr       jmp BasError
000CFAr 2               
000CFAr 2               ; --- LET (also implicit assignment) ---
000CFAr 2               BasCmdLet:
000CFAr 2  20 rr rr       jsr BasSkipSpaces
000CFDr 2  20 rr rr       jsr BasGetTokChar
000D00r 2               
000D00r 2                 ; Must be a variable A-Z
000D00r 2  C9 41          cmp #'A'
000D02r 2  90 25          bcc @LetErr
000D04r 2  C9 5B          cmp #'Z' + 1
000D06r 2  B0 21          bcs @LetErr
000D08r 2               
000D08r 2  38             sec
000D09r 2  E9 41          sbc #'A'
000D0Br 2  0A             asl
000D0Cr 2  85 21          sta BAS_TEMP                   ; Variable offset
000D0Er 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000D11r 2               
000D11r 2  20 rr rr       jsr BasSkipSpaces
000D14r 2  A9 3D          lda #CH_EQUALS
000D16r 2  20 rr rr       jsr BasExpectChar              ; Expect '='
000D19r 2               
000D19r 2  20 rr rr       jsr BasExpr                    ; Evaluate RHS
000D1Cr 2               
000D1Cr 2                 ; Store result in variable
000D1Cr 2  A6 21          ldx BAS_TEMP
000D1Er 2  A5 0A          lda BAS_ACC
000D20r 2  9D 00 04       sta BAS_VARS,x
000D23r 2  A5 0B          lda BAS_ACC + 1
000D25r 2  9D 01 04       sta BAS_VARS + 1,x
000D28r 2  60             rts
000D29r 2               
000D29r 2               @LetErr:
000D29r 2  A9 00          lda #ERR_SYNTAX
000D2Br 2  4C rr rr       jmp BasError
000D2Er 2               
000D2Er 2               ; --- GOTO ---
000D2Er 2               BasCmdGoto:
000D2Er 2  20 rr rr       jsr BasExpr                    ; Evaluate target line number
000D31r 2  A5 0A          lda BAS_ACC
000D33r 2  85 08          sta BAS_LINENUM
000D35r 2  A5 0B          lda BAS_ACC + 1
000D37r 2  85 09          sta BAS_LINENUM + 1
000D39r 2  20 rr rr       jsr BasFindLine
000D3Cr 2  90 09          bcc @GotoErr
000D3Er 2               
000D3Er 2                 ; Set CURLINE to the found line — run loop will detect the change
000D3Er 2  A5 0E          lda BAS_TMP1
000D40r 2  85 06          sta BAS_CURLINE
000D42r 2  A5 0F          lda BAS_TMP1 + 1
000D44r 2  85 07          sta BAS_CURLINE + 1
000D46r 2  60             rts
000D47r 2               
000D47r 2               @GotoErr:
000D47r 2  A9 01          lda #ERR_UNDEF_LINE
000D49r 2  4C rr rr       jmp BasError
000D4Cr 2               
000D4Cr 2               ; --- GOSUB ---
000D4Cr 2               BasCmdGosub:
000D4Cr 2                 ; Push current CURLINE onto GOSUB stack (2 bytes per entry)
000D4Cr 2  A6 1A          ldx BAS_GOSUBSP
000D4Er 2  8A             txa
000D4Fr 2  18             clc
000D50r 2  69 02          adc #BAS_GOSUB_ENTRY
000D52r 2  C9 81          cmp #BAS_GOSUBSTK_SIZE + 1
000D54r 2  B0 13          bcs @GosubFull
000D56r 2               
000D56r 2  A5 06          lda BAS_CURLINE
000D58r 2  9D 00 05       sta BAS_GOSUBSTK,x
000D5Br 2  A5 07          lda BAS_CURLINE + 1
000D5Dr 2  9D 01 05       sta BAS_GOSUBSTK + 1,x
000D60r 2  8A             txa
000D61r 2  18             clc
000D62r 2  69 02          adc #BAS_GOSUB_ENTRY
000D64r 2  85 1A          sta BAS_GOSUBSP
000D66r 2               
000D66r 2                 ; Now do GOTO (sets CURLINE to target)
000D66r 2  4C rr rr       jmp BasCmdGoto
000D69r 2               
000D69r 2               @GosubFull:
000D69r 2  A9 03          lda #ERR_OUT_OF_MEM
000D6Br 2  4C rr rr       jmp BasError
000D6Er 2               
000D6Er 2               ; --- RETURN ---
000D6Er 2               BasCmdReturn:
000D6Er 2  A6 1A          ldx BAS_GOSUBSP
000D70r 2  F0 25          beq @RetErr
000D72r 2               
000D72r 2                 ; Pop CURLINE from GOSUB stack
000D72r 2  CA             dex
000D73r 2  CA             dex
000D74r 2  BD 00 05       lda BAS_GOSUBSTK,x
000D77r 2  85 06          sta BAS_CURLINE
000D79r 2  BD 01 05       lda BAS_GOSUBSTK + 1,x
000D7Cr 2  85 07          sta BAS_CURLINE + 1
000D7Er 2  86 1A          stx BAS_GOSUBSP
000D80r 2               
000D80r 2                 ; Advance CURLINE to the line AFTER the GOSUB line
000D80r 2                 ; so the run loop continues from there
000D80r 2  A0 04          ldy #LINE_PAYLOAD
000D82r 2               @RetScan:
000D82r 2  B1 06          lda (BAS_CURLINE),y
000D84r 2  F0 03          beq @RetScanDone
000D86r 2  C8             iny
000D87r 2  80 F9          bra @RetScan
000D89r 2               @RetScanDone:
000D89r 2  C8             iny                            ; Past null
000D8Ar 2  98             tya
000D8Br 2  18             clc
000D8Cr 2  65 06          adc BAS_CURLINE
000D8Er 2  85 06          sta BAS_CURLINE
000D90r 2  A9 00          lda #$00
000D92r 2  65 07          adc BAS_CURLINE + 1
000D94r 2  85 07          sta BAS_CURLINE + 1
000D96r 2                 ; CURLINE now differs from saved VARPTR, so run loop re-executes
000D96r 2  60             rts
000D97r 2               
000D97r 2               @RetErr:
000D97r 2  A9 04          lda #ERR_RET_NO_GOSUB
000D99r 2  4C rr rr       jmp BasError
000D9Cr 2               
000D9Cr 2               ; --- IF...THEN ---
000D9Cr 2               BasCmdIf:
000D9Cr 2  20 rr rr       jsr BasExpr                    ; Evaluate condition
000D9Fr 2  20 rr rr       jsr BasSkipSpaces
000DA2r 2               
000DA2r 2                 ; Expect THEN
000DA2r 2  20 rr rr       jsr BasGetTokChar
000DA5r 2  C9 87          cmp #TOK_THEN
000DA7r 2  D0 1E          bne @IfSyntax
000DA9r 2  20 rr rr       jsr BasAdvTxtPtr
000DACr 2               
000DACr 2                 ; Check condition: 0 = false, nonzero = true
000DACr 2  A5 0A          lda BAS_ACC
000DAEr 2  05 0B          ora BAS_ACC + 1
000DB0r 2  F0 14          beq @IfFalse
000DB2r 2               
000DB2r 2                 ; True — check if THEN is followed by a line number (implicit GOTO)
000DB2r 2  20 rr rr       jsr BasSkipSpaces
000DB5r 2  20 rr rr       jsr BasGetTokChar
000DB8r 2  C9 30          cmp #'0'
000DBAr 2  90 07          bcc @IfExecRest
000DBCr 2  C9 3A          cmp #'9' + 1
000DBEr 2  B0 03          bcs @IfExecRest
000DC0r 2                 ; It's a digit — treat as GOTO line number
000DC0r 2  4C rr rr       jmp BasCmdGoto
000DC3r 2               
000DC3r 2               @IfExecRest:
000DC3r 2                 ; Execute rest of line as statement(s)
000DC3r 2  4C rr rr       jmp BasExecLine
000DC6r 2               
000DC6r 2               @IfFalse:
000DC6r 2                 ; Skip rest of line (don't execute THEN clause)
000DC6r 2  60             rts
000DC7r 2               
000DC7r 2               @IfSyntax:
000DC7r 2  A9 00          lda #ERR_SYNTAX
000DC9r 2  4C rr rr       jmp BasError
000DCCr 2               
000DCCr 2               ; --- FOR ---
000DCCr 2               BasCmdFor:
000DCCr 2  20 rr rr       jsr BasSkipSpaces
000DCFr 2  20 rr rr       jsr BasGetTokChar
000DD2r 2               
000DD2r 2                 ; Must be a variable
000DD2r 2  C9 41          cmp #'A'
000DD4r 2  B0 03          bcs @ForVarOk1
000DD6r 2  4C rr rr       jmp @ForErr
000DD9r 2               @ForVarOk1:
000DD9r 2  C9 5B          cmp #'Z' + 1
000DDBr 2  90 03          bcc @ForVarOk2
000DDDr 2  4C rr rr       jmp @ForErr
000DE0r 2               @ForVarOk2:
000DE0r 2               
000DE0r 2  38             sec
000DE1r 2  E9 41          sbc #'A'
000DE3r 2  0A             asl
000DE4r 2  85 21          sta BAS_TEMP                   ; Variable offset
000DE6r 2  20 rr rr       jsr BasAdvTxtPtr
000DE9r 2               
000DE9r 2                 ; Expect '='
000DE9r 2  20 rr rr       jsr BasSkipSpaces
000DECr 2  A9 3D          lda #CH_EQUALS
000DEEr 2  20 rr rr       jsr BasExpectChar
000DF1r 2               
000DF1r 2                 ; Evaluate initial value and store in variable
000DF1r 2  20 rr rr       jsr BasExpr
000DF4r 2  A6 21          ldx BAS_TEMP
000DF6r 2  A5 0A          lda BAS_ACC
000DF8r 2  9D 00 04       sta BAS_VARS,x
000DFBr 2  A5 0B          lda BAS_ACC + 1
000DFDr 2  9D 01 04       sta BAS_VARS + 1,x
000E00r 2               
000E00r 2                 ; Expect TO
000E00r 2  20 rr rr       jsr BasSkipSpaces
000E03r 2  20 rr rr       jsr BasGetTokChar
000E06r 2  C9 89          cmp #TOK_TO
000E08r 2  D0 75          bne @ForErr
000E0Ar 2  20 rr rr       jsr BasAdvTxtPtr
000E0Dr 2               
000E0Dr 2                 ; Evaluate limit — store temporarily in SCRATCH
000E0Dr 2  20 rr rr       jsr BasExpr
000E10r 2  A5 0A          lda BAS_ACC
000E12r 2  85 1C          sta BAS_SCRATCH
000E14r 2  A5 0B          lda BAS_ACC + 1
000E16r 2  85 1D          sta BAS_SCRATCH + 1
000E18r 2               
000E18r 2                 ; Check for optional STEP — default is 1
000E18r 2  A9 01          lda #$01
000E1Ar 2  85 1E          sta BAS_SCRATCH2
000E1Cr 2  64 1F          stz BAS_SCRATCH2 + 1
000E1Er 2               
000E1Er 2  20 rr rr       jsr BasSkipSpaces
000E21r 2  20 rr rr       jsr BasGetTokChar
000E24r 2  C9 8A          cmp #TOK_STEP
000E26r 2  D0 0E          bne @ForNoStep
000E28r 2  20 rr rr       jsr BasAdvTxtPtr
000E2Br 2  20 rr rr       jsr BasExpr
000E2Er 2  A5 0A          lda BAS_ACC
000E30r 2  85 1E          sta BAS_SCRATCH2
000E32r 2  A5 0B          lda BAS_ACC + 1
000E34r 2  85 1F          sta BAS_SCRATCH2 + 1
000E36r 2               @ForNoStep:
000E36r 2               
000E36r 2                 ; Check room on FOR stack
000E36r 2  A6 1B          ldx BAS_FORSP
000E38r 2  8A             txa
000E39r 2  18             clc
000E3Ar 2  69 10          adc #BAS_FOR_ENTRY
000E3Cr 2  C9 81          cmp #BAS_FORSTK_SIZE + 1
000E3Er 2  B0 3A          bcs @ForStackFull
000E40r 2               
000E40r 2                 ; Build FOR stack entry (16 bytes per entry):
000E40r 2                 ;  +0: var_offset (1)
000E40r 2                 ;  +1: limit_lo (1)
000E40r 2                 ;  +2: limit_hi (1)
000E40r 2                 ;  +3: step_lo (1)
000E40r 2                 ;  +4: step_hi (1)
000E40r 2                 ;  +5: body_start_lo (1) — first line of loop body (next line after FOR)
000E40r 2                 ;  +6: body_start_hi (1)
000E40r 2                 ; +7..+15: unused padding
000E40r 2               
000E40r 2  A5 21          lda BAS_TEMP
000E42r 2  9D 80 05       sta BAS_FORSTK,x               ; +0: var offset
000E45r 2  A5 1C          lda BAS_SCRATCH
000E47r 2  9D 81 05       sta BAS_FORSTK + 1,x           ; +1: limit lo
000E4Ar 2  A5 1D          lda BAS_SCRATCH + 1
000E4Cr 2  9D 82 05       sta BAS_FORSTK + 2,x           ; +2: limit hi
000E4Fr 2  A5 1E          lda BAS_SCRATCH2
000E51r 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo
000E54r 2  A5 1F          lda BAS_SCRATCH2 + 1
000E56r 2  9D 84 05       sta BAS_FORSTK + 4,x           ; +4: step hi
000E59r 2                 ; body_start = next line after the FOR line (scan for null)
000E59r 2  A0 04          ldy #LINE_PAYLOAD
000E5Br 2               @ForScanBody:
000E5Br 2  B1 06          lda (BAS_CURLINE),y
000E5Dr 2  F0 03          beq @ForScanDone
000E5Fr 2  C8             iny
000E60r 2  80 F9          bra @ForScanBody
000E62r 2               @ForScanDone:
000E62r 2  C8             iny                            ; Past null terminator
000E63r 2  98             tya
000E64r 2  18             clc
000E65r 2  65 06          adc BAS_CURLINE
000E67r 2  48             pha
000E68r 2  A9 00          lda #$00
000E6Ar 2  65 07          adc BAS_CURLINE + 1
000E6Cr 2  9D 86 05       sta BAS_FORSTK + 6,x           ; +6: body_start hi
000E6Fr 2  68             pla
000E70r 2  9D 85 05       sta BAS_FORSTK + 5,x           ; +5: body_start lo
000E73r 2               
000E73r 2  8A             txa
000E74r 2  18             clc
000E75r 2  69 10          adc #BAS_FOR_ENTRY
000E77r 2  85 1B          sta BAS_FORSP
000E79r 2  60             rts
000E7Ar 2               
000E7Ar 2               @ForStackFull:
000E7Ar 2  A9 03          lda #ERR_OUT_OF_MEM
000E7Cr 2  4C rr rr       jmp BasError
000E7Fr 2               
000E7Fr 2               @ForErr:
000E7Fr 2  A9 00          lda #ERR_SYNTAX
000E81r 2  4C rr rr       jmp BasError
000E84r 2               
000E84r 2               ; --- NEXT ---
000E84r 2               BasCmdNext:
000E84r 2  20 rr rr       jsr BasSkipSpaces
000E87r 2  20 rr rr       jsr BasGetTokChar
000E8Ar 2               
000E8Ar 2                 ; Must be a variable
000E8Ar 2  C9 41          cmp #'A'
000E8Cr 2  B0 03          bcs @NextVarOk1
000E8Er 2  4C rr rr       jmp @NextErr
000E91r 2               @NextVarOk1:
000E91r 2  C9 5B          cmp #'Z' + 1
000E93r 2  90 03          bcc @NextVarOk2
000E95r 2  4C rr rr       jmp @NextErr
000E98r 2               @NextVarOk2:
000E98r 2               
000E98r 2  38             sec
000E99r 2  E9 41          sbc #'A'
000E9Br 2  0A             asl
000E9Cr 2  85 21          sta BAS_TEMP                   ; Variable offset
000E9Er 2  20 rr rr       jsr BasAdvTxtPtr
000EA1r 2               
000EA1r 2                 ; Search FOR stack from top for matching variable
000EA1r 2  A6 1B          ldx BAS_FORSP
000EA3r 2  F0 63          beq @NextNoFor
000EA5r 2               
000EA5r 2               @NextSearch:
000EA5r 2  CA             dex                            ; Back up past padding and entries
000EA6r 2  8A             txa
000EA7r 2  38             sec
000EA8r 2  E9 0F          sbc #BAS_FOR_ENTRY - 1         ; Point to start of this entry
000EAAr 2  AA             tax
000EABr 2  30 5B          bmi @NextNoFor
000EADr 2  BD 80 05       lda BAS_FORSTK,x               ; var_offset
000EB0r 2  C5 21          cmp BAS_TEMP
000EB2r 2  F0 02          beq @NextFound
000EB4r 2                 ; Not this entry — keep searching
000EB4r 2  80 EF          bra @NextSearch
000EB6r 2               
000EB6r 2               @NextFound:
000EB6r 2                 ; Add step to variable
000EB6r 2  BD 83 05       lda BAS_FORSTK + 3,x           ; step lo
000EB9r 2  85 0C          sta BAS_AUX
000EBBr 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
000EBEr 2  85 0D          sta BAS_AUX + 1
000EC0r 2               
000EC0r 2  A4 21          ldy BAS_TEMP                   ; var offset
000EC2r 2  18             clc
000EC3r 2  B9 00 04       lda BAS_VARS,y
000EC6r 2  65 0C          adc BAS_AUX
000EC8r 2  99 00 04       sta BAS_VARS,y
000ECBr 2  85 0A          sta BAS_ACC
000ECDr 2  B9 01 04       lda BAS_VARS + 1,y
000ED0r 2  65 0D          adc BAS_AUX + 1
000ED2r 2  99 01 04       sta BAS_VARS + 1,y
000ED5r 2  85 0B          sta BAS_ACC + 1
000ED7r 2               
000ED7r 2                 ; Load limit into AUX for comparison
000ED7r 2  BD 81 05       lda BAS_FORSTK + 1,x           ; limit lo
000EDAr 2  85 0C          sta BAS_AUX
000EDCr 2  BD 82 05       lda BAS_FORSTK + 2,x           ; limit hi
000EDFr 2  85 0D          sta BAS_AUX + 1
000EE1r 2               
000EE1r 2                 ; Check if loop is done:
000EE1r 2                 ; If step > 0: done when var > limit (AUX)
000EE1r 2                 ; If step < 0: done when var < limit (AUX)
000EE1r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
000EE4r 2  30 07          bmi @NextStepNeg
000EE6r 2               
000EE6r 2                 ; Step positive: compare var (ACC) vs limit (AUX)
000EE6r 2                 ; Done if ACC > AUX (i.e., AUX < ACC)
000EE6r 2  20 rr rr       jsr BasCmpAuxAcc
000EE9r 2  30 1A          bmi @NextDone                  ; AUX < ACC means var > limit
000EEBr 2  80 07          bra @NextLoop                  ; Continue loop
000EEDr 2               
000EEDr 2               @NextStepNeg:
000EEDr 2                 ; Step negative: done if var < limit
000EEDr 2                 ; Done if ACC < AUX (i.e., AUX > ACC)
000EEDr 2  20 rr rr       jsr BasCmpAuxAcc
000EF0r 2  F0 02          beq @NextLoop
000EF2r 2  10 11          bpl @NextDone                  ; AUX > ACC means var < limit
000EF4r 2               
000EF4r 2               @NextLoop:
000EF4r 2                 ; Continue loop — set CURLINE to body start
000EF4r 2                 ; Keep the FOR entry on the stack (FORSP stays where it is)
000EF4r 2  BD 85 05       lda BAS_FORSTK + 5,x           ; body_start lo
000EF7r 2  85 06          sta BAS_CURLINE
000EF9r 2  BD 86 05       lda BAS_FORSTK + 6,x           ; body_start hi
000EFCr 2  85 07          sta BAS_CURLINE + 1
000EFEr 2                 ; Invalidate saved CURLINE so run loop always detects the change,
000EFEr 2                 ; even when body_start == current line (empty loop body / NEXT on next line)
000EFEr 2  A9 FF          lda #$FF
000F00r 2  85 14          sta BAS_VARPTR
000F02r 2  85 15          sta BAS_VARPTR + 1
000F04r 2  60             rts
000F05r 2               
000F05r 2               @NextDone:
000F05r 2                 ; Loop complete — remove this FOR entry from stack
000F05r 2  86 1B          stx BAS_FORSP                  ; Pop down to this entry (removes it)
000F07r 2  60             rts
000F08r 2               
000F08r 2               @NextNoFor:
000F08r 2               @NextErr:
000F08r 2  A9 05          lda #ERR_NEXT_NO_FOR
000F0Ar 2  4C rr rr       jmp BasError
000F0Dr 2               
000F0Dr 2               ; --- END ---
000F0Dr 2               BasCmdEnd:
000F0Dr 2  64 17          stz BAS_FLAGS                  ; Clear run flag
000F0Fr 2  60             rts                            ; Returns to BasRunLoop which checks flags
000F10r 2               
000F10r 2               ; --- SYS ---
000F10r 2               ; SYS <address> — Call machine code at 16-bit address, RTS returns to BASIC
000F10r 2               BasCmdSys:
000F10r 2  20 rr rr       jsr BasExpr                    ; Evaluate address expression → BAS_ACC
000F13r 2                 ; Use BAS_TMP2 as the indirect jump target
000F13r 2  A5 0A          lda BAS_ACC
000F15r 2  85 10          sta BAS_TMP2
000F17r 2  A5 0B          lda BAS_ACC + 1
000F19r 2  85 11          sta BAS_TMP2 + 1
000F1Br 2  6C 10 00       jmp (BAS_TMP2)                 ; JSR-like: callee RTSes back to caller
000F1Er 2               
000F1Er 2               ; --- LOAD ---
000F1Er 2               ; LOAD "filename" — Load from CF filesystem
000F1Er 2               ; LOAD (no arg)   — Load via serial ASCII transfer
000F1Er 2               BasCmdLoad:
000F1Er 2  20 rr rr       jsr BasSkipSpaces
000F21r 2  20 rr rr       jsr BasGetTokChar
000F24r 2  C9 22          cmp #CH_QUOTE
000F26r 2  F0 0E          beq @LoadCF
000F28r 2               
000F28r 2                 ; No filename — serial ASCII load
000F28r 2  20 rr rr       jsr AsciiLoad
000F2Br 2  B0 40          bcs @LoadErr
000F2Dr 2                 ; Update BAS_PRGEND from XFER_PTR (points past last byte written)
000F2Dr 2  A5 2A          lda XFER_PTR
000F2Fr 2  85 12          sta BAS_PRGEND
000F31r 2  A5 2B          lda XFER_PTR + 1
000F33r 2  85 13          sta BAS_PRGEND + 1
000F35r 2  60             rts
000F36r 2               
000F36r 2               @LoadCF:
000F36r 2                 ; Parse quoted filename into STR_PTR for FsLoadFile
000F36r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
000F39r 2                 ; Point STR_PTR at current position in tokenized text
000F39r 2  A5 04          lda BAS_TXTPTR
000F3Br 2  85 02          sta STR_PTR
000F3Dr 2  A5 05          lda BAS_TXTPTR + 1
000F3Fr 2  85 03          sta STR_PTR + 1
000F41r 2                 ; Advance TXTPTR past the filename to closing quote
000F41r 2               @LoadScanName:
000F41r 2  20 rr rr       jsr BasGetTokChar
000F44r 2  F0 12          beq @LoadNameDone              ; End of line (unterminated — use what we have)
000F46r 2  C9 22          cmp #CH_QUOTE
000F48r 2  F0 05          beq @LoadNameEnd
000F4Ar 2  20 rr rr       jsr BasAdvTxtPtr
000F4Dr 2  80 F2          bra @LoadScanName
000F4Fr 2               @LoadNameEnd:
000F4Fr 2                 ; Null-terminate the filename in the token buffer (overwrite closing quote)
000F4Fr 2  A0 00          ldy #$00
000F51r 2  A9 00          lda #$00
000F53r 2  91 04          sta (BAS_TXTPTR),y
000F55r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
000F58r 2               @LoadNameDone:
000F58r 2                 ; Call filesystem load
000F58r 2  20 rr rr       jsr FsLoadFile
000F5Br 2  B0 10          bcs @LoadErr
000F5Dr 2                 ; Update BAS_PRGEND: PROGRAM_START + FS_FILE_SIZE
000F5Dr 2  A9 00          lda #<PROGRAM_START
000F5Fr 2  18             clc
000F60r 2  6D 4A 03       adc FS_FILE_SIZE
000F63r 2  85 12          sta BAS_PRGEND
000F65r 2  A9 08          lda #>PROGRAM_START
000F67r 2  6D 4B 03       adc FS_FILE_SIZE + 1
000F6Ar 2  85 13          sta BAS_PRGEND + 1
000F6Cr 2  60             rts
000F6Dr 2               
000F6Dr 2               @LoadErr:
000F6Dr 2  A9 rr          lda #<BasStrLoadErr
000F6Fr 2  85 0E          sta BAS_TMP1
000F71r 2  A9 rr          lda #>BasStrLoadErr
000F73r 2  85 0F          sta BAS_TMP1 + 1
000F75r 2  20 rr rr       jsr BasPrintStr
000F78r 2  60             rts
000F79r 2               
000F79r 2               ; --- SAVE ---
000F79r 2               ; SAVE "filename" — Save to CF filesystem
000F79r 2               ; SAVE (no arg)   — Save via serial ASCII transfer
000F79r 2               BasCmdSave:
000F79r 2  20 rr rr       jsr BasSkipSpaces
000F7Cr 2  20 rr rr       jsr BasGetTokChar
000F7Fr 2  C9 22          cmp #CH_QUOTE
000F81r 2  F0 04          beq @SaveCF
000F83r 2               
000F83r 2                 ; No filename — serial ASCII save
000F83r 2  20 rr rr       jsr AsciiSave
000F86r 2  60             rts
000F87r 2               
000F87r 2               @SaveCF:
000F87r 2                 ; Parse quoted filename into STR_PTR for FsSaveFile
000F87r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
000F8Ar 2  A5 04          lda BAS_TXTPTR
000F8Cr 2  85 02          sta STR_PTR
000F8Er 2  A5 05          lda BAS_TXTPTR + 1
000F90r 2  85 03          sta STR_PTR + 1
000F92r 2                 ; Advance TXTPTR past the filename to closing quote
000F92r 2               @SaveScanName:
000F92r 2  20 rr rr       jsr BasGetTokChar
000F95r 2  F0 12          beq @SaveNameDone
000F97r 2  C9 22          cmp #CH_QUOTE
000F99r 2  F0 05          beq @SaveNameEnd
000F9Br 2  20 rr rr       jsr BasAdvTxtPtr
000F9Er 2  80 F2          bra @SaveScanName
000FA0r 2               @SaveNameEnd:
000FA0r 2  A0 00          ldy #$00
000FA2r 2  A9 00          lda #$00
000FA4r 2  91 04          sta (BAS_TXTPTR),y
000FA6r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
000FA9r 2               @SaveNameDone:
000FA9r 2                 ; Calculate file size = BAS_PRGEND - PROGRAM_START
000FA9r 2  A5 12          lda BAS_PRGEND
000FABr 2  38             sec
000FACr 2  E9 00          sbc #<PROGRAM_START
000FAEr 2  8D 4A 03       sta FS_FILE_SIZE
000FB1r 2  A5 13          lda BAS_PRGEND + 1
000FB3r 2  E9 08          sbc #>PROGRAM_START
000FB5r 2  8D 4B 03       sta FS_FILE_SIZE + 1
000FB8r 2                 ; Call filesystem save
000FB8r 2  20 rr rr       jsr FsSaveFile
000FBBr 2  B0 01          bcs @SaveErr
000FBDr 2  60             rts
000FBEr 2               
000FBEr 2               @SaveErr:
000FBEr 2  A9 rr          lda #<BasStrSaveErr
000FC0r 2  85 0E          sta BAS_TMP1
000FC2r 2  A9 rr          lda #>BasStrSaveErr
000FC4r 2  85 0F          sta BAS_TMP1 + 1
000FC6r 2  20 rr rr       jsr BasPrintStr
000FC9r 2  60             rts
000FCAr 2               
000FCAr 2               ; --- DIR ---
000FCAr 2               ; DIR — Print directory listing from CF
000FCAr 2               BasCmdDir:
000FCAr 2  20 rr rr       jsr FsDirectory
000FCDr 2  60             rts
000FCEr 2               
000FCEr 2               ; --- BRK ---
000FCEr 2               BasCmdBrk:
000FCEr 2  64 17          stz BAS_FLAGS                  ; Clear run flag
000FD0r 2  00             brk                            ; Trigger BRK → IRQ vector → Wozmon
000FD1r 2               
000FD1r 2               ; --- NEW ---
000FD1r 2               BasCmdNew:
000FD1r 2                 ; Set program end to program start (empty program)
000FD1r 2  A9 00          lda #<BAS_PRG_START
000FD3r 2  85 12          sta BAS_PRGEND
000FD5r 2  A9 08          lda #>BAS_PRG_START
000FD7r 2  85 13          sta BAS_PRGEND + 1
000FD9r 2                 ; Write end marker
000FD9r 2  A0 00          ldy #LINE_NEXT
000FDBr 2  A9 00          lda #$00
000FDDr 2  91 12          sta (BAS_PRGEND),y
000FDFr 2  C8             iny
000FE0r 2  91 12          sta (BAS_PRGEND),y
000FE2r 2                 ; Clear variables
000FE2r 2  20 rr rr       jsr BasCmdClr
000FE5r 2  64 17          stz BAS_FLAGS
000FE7r 2  4C rr rr       jmp BasMainLoop
000FEAr 2               
000FEAr 2               ; --- LIST ---
000FEAr 2               BasCmdList:
000FEAr 2                 ; Start at beginning of program
000FEAr 2  A9 00          lda #<BAS_PRG_START
000FECr 2  85 0E          sta BAS_TMP1
000FEEr 2  A9 08          lda #>BAS_PRG_START
000FF0r 2  85 0F          sta BAS_TMP1 + 1
000FF2r 2               
000FF2r 2               @ListLoop:
000FF2r 2                 ; Check if at end of program (TMP1 == PRGEND)
000FF2r 2  A5 0E          lda BAS_TMP1
000FF4r 2  C5 12          cmp BAS_PRGEND
000FF6r 2  D0 06          bne @ListNotEnd
000FF8r 2  A5 0F          lda BAS_TMP1 + 1
000FFAr 2  C5 13          cmp BAS_PRGEND + 1
000FFCr 2  F0 42          beq @ListDone
000FFEr 2               @ListNotEnd:
000FFEr 2               
000FFEr 2                 ; Check for Ctrl+C break
000FFEr 2  20 rr rr       jsr BasCheckBreak
001001r 2               
001001r 2                 ; Print line number
001001r 2  A0 02          ldy #LINE_NUM
001003r 2  B1 0E          lda (BAS_TMP1),y
001005r 2  85 0A          sta BAS_ACC
001007r 2  C8             iny
001008r 2  B1 0E          lda (BAS_TMP1),y
00100Ar 2  85 0B          sta BAS_ACC + 1
00100Cr 2  20 rr rr       jsr BasPrintInt
00100Fr 2               
00100Fr 2                 ; Print space
00100Fr 2  A9 20          lda #CH_SPACE
001011r 2  20 rr rr       jsr Chrout
001014r 2               
001014r 2                 ; Detokenize and print the payload
001014r 2                 ; Set TXTPTR to payload
001014r 2  18             clc
001015r 2  A5 0E          lda BAS_TMP1
001017r 2  69 04          adc #LINE_PAYLOAD
001019r 2  85 04          sta BAS_TXTPTR
00101Br 2  A5 0F          lda BAS_TMP1 + 1
00101Dr 2  69 00          adc #$00
00101Fr 2  85 05          sta BAS_TXTPTR + 1
001021r 2               
001021r 2  20 rr rr       jsr BasDetokenize
001024r 2               
001024r 2                 ; Print CRLF
001024r 2  20 rr rr       jsr BasPrintCRLF
001027r 2               
001027r 2                 ; Advance to next line by scanning for null terminator
001027r 2  A0 04          ldy #LINE_PAYLOAD
001029r 2               @ListScan:
001029r 2  B1 0E          lda (BAS_TMP1),y
00102Br 2  F0 03          beq @ListScanDone
00102Dr 2  C8             iny
00102Er 2  80 F9          bra @ListScan
001030r 2               @ListScanDone:
001030r 2  C8             iny                            ; Past null
001031r 2  98             tya
001032r 2  18             clc
001033r 2  65 0E          adc BAS_TMP1
001035r 2  85 0E          sta BAS_TMP1
001037r 2  A9 00          lda #$00
001039r 2  65 0F          adc BAS_TMP1 + 1
00103Br 2  85 0F          sta BAS_TMP1 + 1
00103Dr 2  4C rr rr       jmp @ListLoop
001040r 2               
001040r 2               @ListDone:
001040r 2  60             rts
001041r 2               
001041r 2               ; --- POKE addr, value ---
001041r 2               BasCmdPoke:
001041r 2  20 rr rr       jsr BasExpr                    ; Evaluate address
001044r 2  A5 0A          lda BAS_ACC
001046r 2  85 10          sta BAS_TMP2
001048r 2  A5 0B          lda BAS_ACC + 1
00104Ar 2  85 11          sta BAS_TMP2 + 1
00104Cr 2               
00104Cr 2                 ; Expect comma
00104Cr 2  20 rr rr       jsr BasSkipSpaces
00104Fr 2  20 rr rr       jsr BasGetTokChar
001052r 2  C9 2C          cmp #CH_COMMA
001054r 2  D0 0D          bne @PokeErr
001056r 2  20 rr rr       jsr BasAdvTxtPtr
001059r 2               
001059r 2  20 rr rr       jsr BasExpr                    ; Evaluate value (low byte used)
00105Cr 2  A5 0A          lda BAS_ACC
00105Er 2  A0 00          ldy #$00
001060r 2  91 10          sta (BAS_TMP2),y
001062r 2  60             rts
001063r 2               
001063r 2               @PokeErr:
001063r 2  A9 00          lda #ERR_SYNTAX
001065r 2  4C rr rr       jmp BasError
001068r 2               
001068r 2               ; ============================================================================
001068r 2               ; Keyword Table
001068r 2               ; ============================================================================
001068r 2               ; Format: null-terminated keyword string, then token byte.
001068r 2               ; Longer keywords first to prevent partial matches (e.g. GOSUB before GOTO).
001068r 2               ; Table terminated by a lone $00.
001068r 2               
001068r 2               BasKeywordTable:
001068r 2  52 45 54 55    .byte "RETURN", $00, TOK_RETURN
00106Cr 2  52 4E 00 85  
001070r 2  50 52 49 4E    .byte "PRINT",  $00, TOK_PRINT
001074r 2  54 00 80     
001077r 2  49 4E 50 55    .byte "INPUT",  $00, TOK_INPUT
00107Br 2  54 00 81     
00107Er 2  47 4F 53 55    .byte "GOSUB",  $00, TOK_GOSUB
001082r 2  42 00 84     
001085r 2  47 4F 54 4F    .byte "GOTO",   $00, TOK_GOTO
001089r 2  00 83        
00108Br 2  54 48 45 4E    .byte "THEN",   $00, TOK_THEN
00108Fr 2  00 87        
001091r 2  53 54 45 50    .byte "STEP",   $00, TOK_STEP
001095r 2  00 8A        
001097r 2  4E 45 58 54    .byte "NEXT",   $00, TOK_NEXT
00109Br 2  00 8B        
00109Dr 2  50 45 45 4B    .byte "PEEK",   $00, TOK_PEEK
0010A1r 2  00 92        
0010A3r 2  50 4F 4B 45    .byte "POKE",   $00, TOK_POKE
0010A7r 2  00 93        
0010A9r 2  53 41 56 45    .byte "SAVE",   $00, TOK_SAVE
0010ADr 2  00 A0        
0010AFr 2  4C 4F 41 44    .byte "LOAD",   $00, TOK_LOAD
0010B3r 2  00 9F        
0010B5r 2  4C 49 53 54    .byte "LIST",   $00, TOK_LIST
0010B9r 2  00 8E        
0010BBr 2  4C 45 54 00    .byte "LET",    $00, TOK_LET
0010BFr 2  82           
0010C0r 2  46 4F 52 00    .byte "FOR",    $00, TOK_FOR
0010C4r 2  88           
0010C5r 2  52 45 4D 00    .byte "REM",    $00, TOK_REM
0010C9r 2  8C           
0010CAr 2  45 4E 44 00    .byte "END",    $00, TOK_END
0010CEr 2  8D           
0010CFr 2  52 55 4E 00    .byte "RUN",    $00, TOK_RUN
0010D3r 2  8F           
0010D4r 2  4E 45 57 00    .byte "NEW",    $00, TOK_NEW
0010D8r 2  90           
0010D9r 2  43 4C 52 00    .byte "CLR",    $00, TOK_CLR
0010DDr 2  91           
0010DEr 2  41 42 53 00    .byte "ABS",    $00, TOK_ABS
0010E2r 2  94           
0010E3r 2  52 4E 44 00    .byte "RND",    $00, TOK_RND
0010E7r 2  95           
0010E8r 2  4E 4F 54 00    .byte "NOT",    $00, TOK_NOT
0010ECr 2  96           
0010EDr 2  41 4E 44 00    .byte "AND",    $00, TOK_AND
0010F1r 2  97           
0010F2r 2  4D 4F 44 00    .byte "MOD",    $00, TOK_MOD
0010F6r 2  99           
0010F7r 2  53 59 53 00    .byte "SYS",    $00, TOK_SYS
0010FBr 2  9E           
0010FCr 2  44 49 52 00    .byte "DIR",    $00, TOK_DIR
001100r 2  A1           
001101r 2  42 52 4B 00    .byte "BRK",    $00, TOK_BRK
001105r 2  9D           
001106r 2  49 46 00 86    .byte "IF",     $00, TOK_IF
00110Ar 2  54 4F 00 89    .byte "TO",     $00, TOK_TO
00110Er 2  4F 52 00 98    .byte "OR",     $00, TOK_OR
001112r 2  00             .byte $00                       ; End of table sentinel
001113r 2               
001113r 2               ; ============================================================================
001113r 2               ; String Data
001113r 2               ; ============================================================================
001113r 2               
001113r 2  0D 0A 43 4F  BasStrWelcome:  .byte CH_CR, CH_LF, "COB BASIC v1.0", CH_CR, CH_LF, $00
001117r 2  42 20 42 41  
00111Br 2  53 49 43 20  
001126r 2  0D 0A 4F 4B  BasStrOK:       .byte CH_CR, CH_LF, "OK", CH_CR, CH_LF, $00
00112Ar 2  0D 0A 00     
00112Dr 2  20 42 59 54  BasStrFree:     .byte " BYTES FREE", $00
001131r 2  45 53 20 46  
001135r 2  52 45 45 00  
001139r 2  20 45 52 52  BasStrError:    .byte " ERROR", $00
00113Dr 2  4F 52 00     
001140r 2  20 49 4E 20  BasStrIn:       .byte " IN ", $00
001144r 2  00           
001145r 2  3F 52 45 44  BasStrRedo:     .byte "?REDO", CH_CR, CH_LF, $00
001149r 2  4F 0D 0A 00  
00114Dr 2  3F 20 00     BasStrPrompt:   .byte "? ", $00
001150r 2  0D 0A 3F 4C  BasStrLoadErr:  .byte CH_CR, CH_LF, "?LOAD ERROR", CH_CR, CH_LF, $00
001154r 2  4F 41 44 20  
001158r 2  45 52 52 4F  
001160r 2  0D 0A 3F 53  BasStrSaveErr:  .byte CH_CR, CH_LF, "?SAVE ERROR", CH_CR, CH_LF, $00
001164r 2  41 56 45 20  
001168r 2  45 52 52 4F  
001170r 2               
001170r 2               
001170r 1               .segment "WOZMON"
000000r 1               .include "Wozmon.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   WOZMON    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               WOZ_XAML  = $24               ; Last "opened" location Low
000000r 2               WOZ_XAMH  = $25               ; Last "opened" location High
000000r 2               WOZ_STL   = $26               ; Store address Low
000000r 2               WOZ_STH   = $27               ; Store address High
000000r 2               WOZ_L     = $28               ; Hex value parsing Low
000000r 2               WOZ_H     = $29               ; Hex value parsing High
000000r 2               WOZ_YSAV  = $2A               ; Used to see if hex value is given
000000r 2               WOZ_MODE  = $2B               ; $00=XAM, $7F=STOR, $AE=BLOCK XAM
000000r 2               WOZ_IN    = USER_VARS         ; Input buffer
000000r 2               
000000r 2               WozMon:
000000r 2  A9 1B          lda     #$1B                ; Begin with escape
000002r 2               
000002r 2               WozNotCr:
000002r 2  C9 08          cmp     #$08                ; Backspace key?
000004r 2  F0 18          beq     WozBackspace        ; Yes
000006r 2  C9 1B          cmp     #$1B                ; ESC?
000008r 2  F0 03          beq     WozEscape           ; Yes
00000Ar 2  C8             iny                         ; Advance text index
00000Br 2  10 14          bpl     WozNextchar         ; Auto ESC if line longer than 127
00000Dr 2               
00000Dr 2               WozEscape:
00000Dr 2  A9 5C          lda     #$5C                ; "\"
00000Fr 2  20 rr rr       jsr     WozEcho             ; Output it
000012r 2               
000012r 2               WozGetline:
000012r 2  A9 0D          lda     #$0D                ; Send CR
000014r 2  20 rr rr       jsr     WozEcho
000017r 2  A9 0A          lda     #$0A                ; Send LF
000019r 2  20 rr rr       jsr     WozEcho
00001Cr 2               
00001Cr 2  A0 01          ldy     #$01                ; Initialize text index
00001Er 2               WozBackspace:
00001Er 2  88             dey                         ; Back up text index
00001Fr 2  30 F1          bmi     WozGetline          ; Beyond start of line, reinitialize
000021r 2               
000021r 2               WozNextchar:
000021r 2  20 rr rr       jsr     Chrin               ; Get next character
000024r 2  90 FB          bcc     WozNextchar         ; No character found
000026r 2  99 00 04       sta     WOZ_IN,y            ; Add to text buffer
000029r 2  C9 0D          cmp     #$0D                ; CR?
00002Br 2  D0 D5          bne     WozNotCr            ; No
00002Dr 2               
00002Dr 2  A0 FF          ldy     #$FF                ; Reset text index
00002Fr 2  A9 00          lda     #$00                ; For XAM mode
000031r 2  AA             tax                         ; X=0
000032r 2               WozSetblock:
000032r 2  0A             asl
000033r 2               WozSetstor:
000033r 2  0A             asl                         ; Leaves $7B if setting STOR mode
000034r 2  85 2B          sta     WOZ_MODE            ; $00 = XAM, $74 = STOR, $B8 = BLOK XAM
000036r 2               WozBlskip:
000036r 2  C8             iny                         ; Advance text index
000037r 2               WozNextitem:
000037r 2  B9 00 04       lda     WOZ_IN,y            ; Get character
00003Ar 2  C9 0D          cmp     #$0D                ; CR?
00003Cr 2  F0 D4          beq     WozGetline          ; Yes, done this line
00003Er 2  C9 2E          cmp     #$2E                ; "."?
000040r 2  90 F4          bcc     WozBlskip           ; Skip delimiter
000042r 2  F0 EE          beq     WozSetblock         ; Set BLOCK XAM mode
000044r 2  C9 3A          cmp     #$3A                ; ":"?
000046r 2  F0 EB          beq     WozSetstor          ; Yes, set STOR mode
000048r 2  C9 52          cmp     #$52                ; "R"?
00004Ar 2  F0 3B          beq     WozRun              ; Yes, run user program
00004Cr 2  86 28          stx     WOZ_L               ; $00 -> L
00004Er 2  86 29          stx     WOZ_H               ;    and H
000050r 2  84 2A          sty     WOZ_YSAV            ; Save Y for comparison
000052r 2               
000052r 2               WozNexthex:
000052r 2  B9 00 04       lda     WOZ_IN,y            ; Get character for hex test
000055r 2  49 30          eor     #$30                ; Map digits to $0-9
000057r 2  C9 0A          cmp     #$0A                ; Digit?
000059r 2  90 06          bcc     WozDig              ; Yes
00005Br 2  69 88          adc     #$88                ; Map letter "A"-"F" to $FA-FF
00005Dr 2  C9 FA          cmp     #$FA                ; Hex letter?
00005Fr 2  90 11          bcc     WozNothex           ; No, character not hex
000061r 2               WozDig:
000061r 2  0A             asl
000062r 2  0A             asl                         ; Hex digit to MSD of A
000063r 2  0A             asl
000064r 2  0A             asl
000065r 2               
000065r 2  A2 04          ldx     #$04                ; Shift count
000067r 2               WozHexshift:
000067r 2  0A             asl                         ; Hex digit left, MSB to carry
000068r 2  26 28          rol     WOZ_L               ; Rotate into LSD
00006Ar 2  26 29          rol     WOZ_H               ; Rotate into MSD's
00006Cr 2  CA             dex                         ; Done 4 shifts?
00006Dr 2  D0 F8          bne     WozHexshift         ; No, loop
00006Fr 2  C8             iny                         ; Advance text index
000070r 2  D0 E0          bne     WozNexthex          ; Always taken. Check next character for hex
000072r 2               
000072r 2               WozNothex:
000072r 2  C4 2A          cpy     WOZ_YSAV            ; Check if L, H empty (no hex digits)
000074r 2  F0 97          beq     WozEscape           ; Yes, generate ESC sequence
000076r 2               
000076r 2  24 2B          bit     WOZ_MODE            ; Test MODE byte
000078r 2  50 16          bvc     WozNotstor          ; B6=0 is STOR, 1 is XAM and BLOCK XAM
00007Ar 2               
00007Ar 2  A5 28          lda     WOZ_L               ; LSD's of hex data
00007Cr 2  81 26          sta     (WOZ_STL,x)         ; Store current 'store index'
00007Er 2  E6 26          inc     WOZ_STL             ; Increment store index
000080r 2  D0 B5          bne     WozNextitem         ; Get next item (no carry)
000082r 2  E6 27          inc     WOZ_STH             ; Add carry to 'store index' high order
000084r 2               WozTonextitem:
000084r 2  4C rr rr       jmp     WozNextitem         ; Get next command item
000087r 2               
000087r 2               WozRun:
000087r 2  20 rr rr       jsr     WozJump             ; Begin executing at XAM index
00008Ar 2  4C rr rr       jmp     WozMon              ; After returning we reset
00008Dr 2               WozJump:
00008Dr 2  6C 24 00       jmp     (WOZ_XAML)          ; Run at current XAM index
000090r 2               
000090r 2               WozNotstor:
000090r 2  30 30          bmi     WozXamnext          ; B7 = 0 for XAM, 1 for BLOCK XAM
000092r 2               
000092r 2  A2 02          ldx     #$02                ; Byte count
000094r 2               WozSetadr:
000094r 2  B5 27          lda     WOZ_L-1,x           ; Copy hex data to
000096r 2  95 25          sta     WOZ_STL-1,x         ;  'store index'
000098r 2  95 23          sta     WOZ_XAML-1,x        ; And to 'XAM index'
00009Ar 2  CA             dex                         ; Next of 2 bytes
00009Br 2  D0 F7          bne     WozSetadr           ; Loop unless X = 0
00009Dr 2               
00009Dr 2               WozNxtprnt:
00009Dr 2  D0 19          bne     WozPrdata           ; NE means no address to print
00009Fr 2  A9 0D          lda     #$0D                ; CR
0000A1r 2  20 rr rr       jsr     WozEcho             ; Output it
0000A4r 2  A9 0A          lda     #$0A                ; LF
0000A6r 2  20 rr rr       jsr     WozEcho             ; Output it
0000A9r 2  A5 25          lda     WOZ_XAMH            ; 'Examine index' high-order byte
0000ABr 2  20 rr rr       jsr     WozPrbyte           ; Output it in hex format
0000AEr 2  A5 24          lda     WOZ_XAML            ; Low-order 'examine index' byte
0000B0r 2  20 rr rr       jsr     WozPrbyte           ; Output it in hex format
0000B3r 2  A9 3A          lda     #$3A                ; ":"
0000B5r 2  20 rr rr       jsr     WozEcho             ; Output it
0000B8r 2               
0000B8r 2               WozPrdata:
0000B8r 2  A9 20          lda     #$20                ; Blank
0000BAr 2  20 rr rr       jsr     WozEcho             ; Output it
0000BDr 2  A1 24          lda     (WOZ_XAML,x)        ; Get data byte at 'examine index'
0000BFr 2  20 rr rr       jsr     WozPrbyte           ; Output it in hex format
0000C2r 2               WozXamnext:
0000C2r 2  86 2B          stx     WOZ_MODE            ; 0 -> MODE (XAM mode)
0000C4r 2  A5 24          lda     WOZ_XAML
0000C6r 2  C5 28          cmp     WOZ_L               ; Compare 'examine index' to hex data
0000C8r 2  A5 25          lda     WOZ_XAMH
0000CAr 2  E5 29          sbc     WOZ_H
0000CCr 2  B0 B6          bcs     WozTonextitem       ; Not less, so no more data to output
0000CEr 2               
0000CEr 2  E6 24          inc     WOZ_XAML
0000D0r 2  D0 02          bne     WozMod8chk          ; Increment 'examine index'
0000D2r 2  E6 25          inc     WOZ_XAMH
0000D4r 2               
0000D4r 2               WozMod8chk:
0000D4r 2  A5 24          lda     WOZ_XAML            ; Check low-order 'examine index' byte
0000D6r 2  29 07          and     #$07                ; For MOD 8 = 0
0000D8r 2  10 C3          bpl     WozNxtprnt          ; Always taken
0000DAr 2               
0000DAr 2               WozPrbyte:
0000DAr 2  48             pha                         ; Save A for LSD
0000DBr 2  4A             lsr
0000DCr 2  4A             lsr
0000DDr 2  4A             lsr                         ; MSD to LSD position
0000DEr 2  4A             lsr
0000DFr 2  20 rr rr       jsr     WozPrhex            ; Output hex digit
0000E2r 2  68             pla                         ; Restore A
0000E3r 2               
0000E3r 2               WozPrhex:
0000E3r 2  29 0F          and     #$0F                ; Mask LSD for hex print
0000E5r 2  09 30          ora     #$30                ; Add "0"
0000E7r 2  C9 3A          cmp     #$3A                ; Digit?
0000E9r 2  90 02          bcc     WozEcho             ; Yes, output it
0000EBr 2  69 06          adc     #$06                ; Add offset for letter
0000EDr 2               
0000EDr 2               WozEcho:
0000EDr 2  20 rr rr       jsr Chrout                  ; Output the character
0000F0r 2  60             rts                         ; Return
0000F1r 2               
0000F1r 1               .segment "VECTORS"
000000r 1               .include "Vectors.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   VECTORS   ***
000000r 2               ; ***             ***
000000r 2               
000000r 2  rr rr        .word   NmiVec           ; NMI vector
000002r 2  rr rr        .word   ResetVec         ; RESET vector
000004r 2  rr rr        .word   IrqVec           ; IRQ vector
000006r 2               
000006r 1               
