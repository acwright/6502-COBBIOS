001E3Fr 2               
001E3Fr 2               ; ============================================================================
001E3Fr 2               ; BasPrintNoDevice — Print "?NO DEVICE" and return
001E3Fr 2               ; Used by hardware-guarded commands when device is absent
001E3Fr 2               ; ============================================================================
001E3Fr 2               BasPrintNoDevice:
001E3Fr 2  A9 rr          lda #<BasStrNoDevice
001E41r 2  85 0E          sta BAS_TMP1
001E43r 2  A9 rr          lda #>BasStrNoDevice
001E45r 2  85 0F          sta BAS_TMP1 + 1
001E47r 2  20 rr rr       jsr BasPrintStr
001E4Ar 2  60             rts
001E4Br 2               
001E4Br 2               ; ============================================================================
001E4Br 2               ; String Data
001E4Br 2               ; ============================================================================
001E4Br 2               
001E4Br 2  0D 0A 36 35  BasStrWelcome:  .byte CH_CR, CH_LF, "6502 BASIC v1.0", CH_CR, CH_LF, $00
001E4Fr 2  30 32 20 42  
001E53r 2  41 53 49 43  
