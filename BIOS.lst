001D60r 2  00 8B        
001D62r 2  50 45 45 4B    .byte "PEEK",   $00, TOK_PEEK
001D66r 2  00 92        
001D68r 2  50 4F 4B 45    .byte "POKE",   $00, TOK_POKE
001D6Cr 2  00 93        
001D6Er 2  53 41 56 45    .byte "SAVE",   $00, TOK_SAVE
001D72r 2  00 A0        
001D74r 2  4C 4F 41 44    .byte "LOAD",   $00, TOK_LOAD
001D78r 2  00 9F        
001D7Ar 2  4C 49 53 54    .byte "LIST",   $00, TOK_LIST
001D7Er 2  00 8E        
001D80r 2  42 41 4E 4B    .byte "BANK",   $00, TOK_BANK
001D84r 2  00 AD        
001D86r 2  57 41 49 54    .byte "WAIT",   $00, TOK_WAIT
001D8Ar 2  00 AB        
001D8Cr 2  54 49 4D 45    .byte "TIME",   $00, TOK_TIME
001D90r 2  00 A9        
001D92r 2  44 41 54 45    .byte "DATE",   $00, TOK_DATE
001D96r 2  00 AA        
001D98r 2  4C 45 54 00    .byte "LET",    $00, TOK_LET
001D9Cr 2  82           
001D9Dr 2  46 4F 52 00    .byte "FOR",    $00, TOK_FOR
001DA1r 2  88           
001DA2r 2  52 45 4D 00    .byte "REM",    $00, TOK_REM
001DA6r 2  8C           
