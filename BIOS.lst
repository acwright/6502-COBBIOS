000CFDr 2  B0 12          bcs @HexDone
000CFFr 2                 ; Shift NUMTMP left 4 bits
000CFFr 2  A0 04          ldy #4
000D01r 2               @HexShift:
000D01r 2  06 22          asl BAS_NUMTMP
000D03r 2  26 23          rol BAS_NUMTMP + 1
000D05r 2  88             dey
000D06r 2  D0 F9          bne @HexShift
000D08r 2  05 22          ora BAS_NUMTMP
000D0Ar 2  85 22          sta BAS_NUMTMP
