002324r 2  8D 1A 03             sta     BAS_DATAPTR
002327r 2  AD 5E 03             lda     BAS_TXTTAB+1
00232Ar 2  E9 00                sbc     #0
00232Cr 2  8D 1B 03             sta     BAS_DATAPTR+1
00232Fr 2  60                   rts
002330r 2               
002330r 2               ; ---------------------------------------------------------------------------
002330r 2               ; Statement: INPUT [<"prompt">{,;}] var[,var,...]
002330r 2               ;   Prompts user for input, reads a line, parses it into the variable list.
002330r 2               ;   "abc";VAR  prints  abc?    (question + space appended)
002330r 2               ;   "abc",VAR  prints  abc      (no question mark)
002330r 2               ;   no prompt: prints  ?
002330r 2               ;   On bad numeric input or premature end-of-line: "?REDO FROM START"
002330r 2               ;   and reprompt.  Trailing un-consumed input: "?EXTRA IGNORED".
002330r 2               ; ---------------------------------------------------------------------------
002330r 2               BasCmdInput:
002330r 2                       ; INPUT is illegal in direct mode.
002330r 2  AD 6A 03             lda     BAS_CURLIN+1
002333r 2  C9 FF                cmp     #$FF
002335r 2  D0 05                bne     @notDirect
002337r 2  A2 07                ldx     #ERR_ILLDIRECT
002339r 2  4C rr rr             jmp     BasErrorVec
00233Cr 2               @notDirect:
00233Cr 2                       ; ChrGot returns first char after the INPUT token.
00233Cr 2  20 rr rr             jsr     ChrGot
00233Fr 2  C9 22                cmp     #'"'
002341r 2  D0 27                bne     @noPrompt
002343r 2                       ; Parse string literal & print it; FrmEvl will leave descriptor in FAC.
002343r 2  20 rr rr             jsr     FrmEvl
002346r 2  20 rr rr             jsr     ChkStr
002349r 2  20 rr rr             jsr     PrintStrFAC
00234Cr 2  20 rr rr             jsr     FreFac
00234Fr 2  20 rr rr             jsr     ChrGot
002352r 2  C9 3B                cmp     #';'
002354r 2  F0 09                beq     @semi
002356r 2  C9 2C                cmp     #','
002358r 2  D0 0D                bne     @badPrompt
00235Ar 2  20 rr rr             jsr     ChrGet                  ; consume ','
00235Dr 2  80 0E                bra     @afterPrompt
00235Fr 2               @semi:
00235Fr 2  20 rr rr             jsr     ChrGet                  ; consume ';'
002362r 2  20 rr rr             jsr     BasInpQues              ; '? '
002365r 2  80 06                bra     @afterPrompt
002367r 2               @badPrompt:
002367r 2  4C rr rr             jmp     SynErr
00236Ar 2               @noPrompt:
00236Ar 2  20 rr rr             jsr     BasInpQues              ; '? '
00236Dr 2               @afterPrompt:
00236Dr 2                       ; Save program TXTPTR (start of var-list) for REDO retry.
00236Dr 2  A5 04                lda     TXTPTR
00236Fr 2  8D 71 03             sta     BAS_INPSAV
002372r 2  A5 05                lda     TXTPTR+1
002374r 2  8D 72 03             sta     BAS_INPSAV+1
002377r 2               @retry:
002377r 2  20 rr rr             jsr     BasReadLine             ; reads to BAS_LINBUF, NUL-terminated, prints CRLF
00237Ar 2                       ; Set up data pointer with leading ',' sentinel just before LINBUF.
00237Ar 2  A9 2C                lda     #','
00237Cr 2  8D FF 03             sta     BAS_LINBUF-1
00237Fr 2  A9 FF                lda     #<(BAS_LINBUF-1)
002381r 2  85 3A                sta     BAS_TMP1
002383r 2  A9 03                lda     #>(BAS_LINBUF-1)
002385r 2  85 3B                sta     BAS_TMP1+1
002387r 2                       ; Restore program TXTPTR.
002387r 2  AD 71 03             lda     BAS_INPSAV
00238Ar 2  85 04                sta     TXTPTR
00238Cr 2  AD 72 03             lda     BAS_INPSAV+1
00238Fr 2  85 05                sta     TXTPTR+1
002391r 2  64 69                stz     BAS_INPUTFLG            ; INPUT mode ($00)
002393r 2               @nextVar:
002393r 2  20 rr rr             jsr     PtrGet                  ; advance program TXTPTR past var name
002396r 2  85 46                sta     BAS_FORPNT
002398r 2  84 47                sty     BAS_FORPNT+1
00239Ar 2                       ; Save program TXTPTR; switch to data side.
00239Ar 2  A5 05                lda     TXTPTR+1
00239Cr 2  48                   pha
00239Dr 2  A5 04                lda     TXTPTR
00239Fr 2  48                   pha
0023A0r 2  A5 3A                lda     BAS_TMP1
0023A2r 2  85 04                sta     TXTPTR
0023A4r 2  A5 3B                lda     BAS_TMP1+1
0023A6r 2  85 05                sta     TXTPTR+1
0023A8r 2  20 rr rr             jsr     ChrGot
0023ABr 2  D0 05                bne     @gotData
0023ADr 2                       ; Out of input data before var list exhausted -> REDO.
0023ADr 2  68                   pla
0023AEr 2  68                   pla
0023AFr 2  4C rr rr             jmp     @doRedo
0023B2r 2               @gotData:
0023B2r 2  20 rr rr             jsr     ChrGet                  ; consume the separator/sentinel
0023B5r 2  24 64                bit     VALTYP
0023B7r 2  30 2E                bmi     @inpStr
0023B9r 2                       ; Numeric: must start with digit, '+', '-' or '.'; else REDO.
0023B9r 2  20 rr rr             jsr     ChrGot
0023BCr 2  90 11                bcc     @numOk                  ; carry clear == digit
0023BEr 2  C9 2D                cmp     #'-'
0023C0r 2  F0 0D                beq     @numOk
0023C2r 2  C9 2B                cmp     #'+'
0023C4r 2  F0 09                beq     @numOk
0023C6r 2  C9 2E                cmp     #'.'
0023C8r 2  F0 05                beq     @numOk
0023CAr 2                       ; bad numeric
0023CAr 2  68                   pla
0023CBr 2  68                   pla
0023CCr 2  4C rr rr             jmp     @doRedo
0023CFr 2               @numOk:
0023CFr 2  20 rr rr             jsr     Fin
0023D2r 2  A6 46                ldx     BAS_FORPNT
0023D4r 2  A4 47                ldy     BAS_FORPNT+1
0023D6r 2  20 rr rr             jsr     StoreFacAtYxRounded
0023D9r 2                       ; After Fin, ChrGot result must be NUL or ',' (Fin/ChrGot skips spaces).
0023D9r 2  20 rr rr             jsr     ChrGot
0023DCr 2  F0 4A                beq     @afterStore
0023DEr 2  C9 2C                cmp     #','
0023E0r 2  F0 46                beq     @afterStore
0023E2r 2                       ; Garbage trailing the number -> REDO.
0023E2r 2  68                   pla
0023E3r 2  68                   pla
0023E4r 2  4C rr rr             jmp     @doRedo
0023E7r 2               @inpStr:
0023E7r 2                       ; Peek at the first data character.  If it's a '"', use quote-mode
0023E7r 2                       ; (terminator = '"' or NUL); otherwise terminate at ',' or NUL.
0023E7r 2  A0 00                ldy     #0
0023E9r 2  B1 04                lda     (TXTPTR),y
0023EBr 2  C9 22                cmp     #'"'
0023EDr 2  F0 0E                beq     @sQuoted
0023EFr 2                       ; Unquoted: STRLT2 source = TXTPTR.
0023EFr 2  A9 00                lda     #0
0023F1r 2  85 44                sta     CHARAC
0023F3r 2  A9 2C                lda     #','
0023F5r 2  85 6A                sta     ENDCHR
0023F7r 2  A5 04                lda     TXTPTR
0023F9r 2  A4 05                ldy     TXTPTR+1
0023FBr 2  80 10                bra     @sCallStrLt
0023FDr 2               @sQuoted:
0023FDr 2  A9 22                lda     #'"'
0023FFr 2  85 44                sta     CHARAC
002401r 2  85 6A                sta     ENDCHR
002403r 2                       ; Skip the opening '"'; STRLT2 source = TXTPTR + 1.
002403r 2  18                   clc
002404r 2  A5 04                lda     TXTPTR
002406r 2  69 01                adc     #1
002408r 2  A4 05                ldy     TXTPTR+1
00240Ar 2  90 01                bcc     @sCallStrLt
00240Cr 2  C8                   iny
00240Dr 2               @sCallStrLt:
00240Dr 2  20 rr rr             jsr     StrLt2
002410r 2                       ; StrLt2 leaves STRNG2 pointing past the consumed string (at the
002410r 2                       ; terminator for unquoted input, or just past the closing '"' for
002410r 2                       ; quoted input).  Advance TXTPTR (== data pointer) accordingly so
002410r 2                       ; the trailing-extra check sees only what truly remained on the
002410r 2                       ; input line.
002410r 2  A5 1E                lda     STRNG2
002412r 2  85 04                sta     TXTPTR
002414r 2  A5 1F                lda     STRNG2+1
002416r 2  85 05                sta     TXTPTR+1
002418r 2  A0 00                ldy     #0
00241Ar 2  A5 0E                lda     FAC
00241Cr 2  91 46                sta     (BAS_FORPNT),y
00241Er 2  C8                   iny
00241Fr 2  A5 0F                lda     FAC+1
002421r 2  91 46                sta     (BAS_FORPNT),y
002423r 2  C8                   iny
002424r 2  A5 10                lda     FAC+2
002426r 2  91 46                sta     (BAS_FORPNT),y
002428r 2               @afterStore:
002428r 2                       ; Save data ptr; restore program TXTPTR.
002428r 2  A5 04                lda     TXTPTR
00242Ar 2  85 3A                sta     BAS_TMP1
00242Cr 2  A5 05                lda     TXTPTR+1
00242Er 2  85 3B                sta     BAS_TMP1+1
002430r 2  68                   pla
002431r 2  85 04                sta     TXTPTR
002433r 2  68                   pla
002434r 2  85 05                sta     TXTPTR+1
002436r 2                       ; More variables?
002436r 2  20 rr rr             jsr     ChrGot
002439r 2  C9 2C                cmp     #','
00243Br 2  D0 06                bne     @doneVars
00243Dr 2  20 rr rr             jsr     ChrGet                  ; consume ','
002440r 2  4C rr rr             jmp     @nextVar
002443r 2               @doneVars:
002443r 2                       ; Check for un-consumed input (EXTRA IGNORED).
002443r 2  A0 00                ldy     #0
002445r 2  B1 3A                lda     (BAS_TMP1),y
002447r 2  F0 12                beq     @inpDone
002449r 2                       ; Skip leading spaces; anything else is "extra".
002449r 2               @chkExtra:
002449r 2  B1 3A                lda     (BAS_TMP1),y
00244Br 2  F0 0E                beq     @inpDone
00244Dr 2  C9 20                cmp     #' '
00244Fr 2  D0 03                bne     @hasExtra
002451r 2  C8                   iny
002452r 2  D0 F5                bne     @chkExtra
002454r 2               @hasExtra:
002454r 2  A9 rr                lda     #<MsgExtra
002456r 2  A0 rr                ldy     #>MsgExtra
002458r 2  20 rr rr             jsr     BasPrintStr
00245Br 2               @inpDone:
00245Br 2  60                   rts
00245Cr 2               @doRedo:
00245Cr 2  A9 rr                lda     #<MsgRedo
00245Er 2  A0 rr                ldy     #>MsgRedo
002460r 2  20 rr rr             jsr     BasPrintStr
002463r 2  4C rr rr             jmp     @retry
002466r 2               
002466r 2               ; Print "? " prompt (used by INPUT and the ';' prompt-suffix path).
002466r 2               BasInpQues:
002466r 2  A9 3F                lda     #'?'
002468r 2  20 rr rr             jsr     PrintCh
00246Br 2  A9 20                lda     #' '
00246Dr 2  4C rr rr             jmp     PrintCh
002470r 2               
002470r 2               MsgRedo:
002470r 2  3F 52 45 44          .byte   "?REDO FROM START", $0D, $0A, 0
002474r 2  4F 20 46 52  
002478r 2  4F 4D 20 53  
002483r 2               MsgExtra:
002483r 2  3F 45 58 54          .byte   "?EXTRA IGNORED", $0D, $0A, 0
002487r 2  52 41 20 49  
00248Br 2  47 4E 4F 52  
002494r 2               
002494r 2               ; ---------------------------------------------------------------------------
002494r 2               ; Statement: READ var[,var,...] -- pull next DATA item from BAS_DATAPTR
002494r 2               ; into the variable pointed to by PtrGet.
002494r 2               ; ---------------------------------------------------------------------------
002494r 2               BasCmdRead:
002494r 2  AE 1A 03             ldx     BAS_DATAPTR
002497r 2  AC 1B 03             ldy     BAS_DATAPTR+1
00249Ar 2  A9 98                lda     #$98                    ; INPUTFLG = $98 means READ mode
00249Cr 2  2C                   .byte   $2C
00249Dr 2               BasInpDoit:
00249Dr 2  A9 00                lda     #0
00249Fr 2  85 69                sta     BAS_INPUTFLG
0024A1r 2  86 3A                stx     BAS_TMP1                ; TMP1 = data pointer
0024A3r 2  84 3B                sty     BAS_TMP1+1
0024A5r 2               @nextVar:
0024A5r 2                       ; TXTPTR currently points into program at variable name.
0024A5r 2  20 rr rr             jsr     PtrGet                  ; advances TXTPTR past var name
0024A8r 2  85 46                sta     BAS_FORPNT
0024AAr 2  84 47                sty     BAS_FORPNT+1
0024ACr 2                       ; Save program TXTPTR on hw stack, switch TXTPTR to data ptr.
0024ACr 2  A5 05                lda     TXTPTR+1
0024AEr 2  48                   pha
0024AFr 2  A5 04                lda     TXTPTR
0024B1r 2  48                   pha
0024B2r 2  A5 3A                lda     BAS_TMP1
0024B4r 2  85 04                sta     TXTPTR
0024B6r 2  A5 3B                lda     BAS_TMP1+1
0024B8r 2  85 05                sta     TXTPTR+1
0024BAr 2  20 rr rr             jsr     ChrGot
0024BDr 2  D0 08                bne     @gotData
0024BFr 2                       ; Out of items on this line - find next DATA.
0024BFr 2  20 rr rr             jsr     BasFindData
0024C2r 2  90 03                bcc     @gotData
0024C4r 2  4C rr rr             jmp     @oodata
0024C7r 2               @gotData:
0024C7r 2                       ; Advance past separator (',' between items, ' ' after DATA token,
0024C7r 2                       ; or quote-delimiter for strings).  ChrGet also skips spaces.
0024C7r 2  20 rr rr             jsr     ChrGet
0024CAr 2                       ; Parse value at TXTPTR (data side).
0024CAr 2  24 64                bit     VALTYP
0024CCr 2  30 0C                bmi     @readStr
0024CEr 2                       ; Numeric.
0024CEr 2  20 rr rr             jsr     Fin
0024D1r 2  A6 46                ldx     BAS_FORPNT
0024D3r 2  A4 47                ldy     BAS_FORPNT+1
0024D5r 2  20 rr rr             jsr     StoreFacAtYxRounded
0024D8r 2  80 29                bra     @afterStore
0024DAr 2               @readStr:
0024DAr 2                       ; String.
0024DAr 2  A9 22                lda     #'"'
0024DCr 2  85 44                sta     CHARAC
0024DEr 2  85 6A                sta     ENDCHR
0024E0r 2  A0 00                ldy     #0
0024E2r 2  B1 04                lda     (TXTPTR),y
0024E4r 2  C9 22                cmp     #'"'
0024E6r 2  F0 08                beq     @quoted
0024E8r 2  A9 3A                lda     #':'
0024EAr 2  85 44                sta     CHARAC
0024ECr 2  A9 2C                lda     #','
0024EEr 2  85 6A                sta     ENDCHR
0024F0r 2               @quoted:
0024F0r 2  20 rr rr             jsr     StrLt2
0024F3r 2  A0 00                ldy     #0
0024F5r 2  A5 0E                lda     FAC
0024F7r 2  91 46                sta     (BAS_FORPNT),y
0024F9r 2  C8                   iny
0024FAr 2  A5 0F                lda     FAC+1
0024FCr 2  91 46                sta     (BAS_FORPNT),y
0024FEr 2  C8                   iny
0024FFr 2  A5 10                lda     FAC+2
002501r 2  91 46                sta     (BAS_FORPNT),y
002503r 2               @afterStore:
002503r 2                       ; Save updated data ptr.
002503r 2  A5 04                lda     TXTPTR
002505r 2  85 3A                sta     BAS_TMP1
002507r 2  A5 05                lda     TXTPTR+1
002509r 2  85 3B                sta     BAS_TMP1+1
00250Br 2                       ; Restore program TXTPTR.
00250Br 2  68                   pla
00250Cr 2  85 04                sta     TXTPTR
00250Er 2  68                   pla
00250Fr 2  85 05                sta     TXTPTR+1
002511r 2                       ; If next program byte is ',', another variable follows.
002511r 2  20 rr rr             jsr     ChrGot
002514r 2  C9 2C                cmp     #','
002516r 2  D0 05                bne     @done
002518r 2  20 rr rr             jsr     ChrGet
00251Br 2  80 88                bra     @nextVar
00251Dr 2               @done:
00251Dr 2                       ; Persist data ptr.
00251Dr 2  A5 3A                lda     BAS_TMP1
00251Fr 2  8D 1A 03             sta     BAS_DATAPTR
002522r 2  A5 3B                lda     BAS_TMP1+1
002524r 2  8D 1B 03             sta     BAS_DATAPTR+1
002527r 2  60                   rts
002528r 2               @oodata:
002528r 2  A2 0E                ldx     #ERR_OD
00252Ar 2  4C rr rr             jmp     BasErrorVec
00252Dr 2               
00252Dr 2               ; ---------------------------------------------------------------------------
00252Dr 2               ; BasFindData -- starting from TXTPTR (positioned somewhere within a line's
00252Dr 2               ; payload), advance to the byte after the next DATA token in the program.
00252Dr 2               ; Returns carry SET on out-of-data, carry CLEAR with TXTPTR at first byte
00252Dr 2               ; AFTER the DATA token (i.e. at the first DATA item).
00252Dr 2               ; ---------------------------------------------------------------------------
00252Dr 2               BasFindData:
00252Dr 2               @scanByte:
00252Dr 2  A0 00                ldy     #0
00252Fr 2  B1 04                lda     (TXTPTR),y
002531r 2  F0 1F                beq     @atEnd
002533r 2  C9 83                cmp     #TOK_DATA
002535r 2  F0 2E                beq     @found
002537r 2  C9 22                cmp     #'"'
002539r 2  D0 12                bne     @advance1
00253Br 2                       ; Skip quoted string (advance TXTPTR past closing quote or NUL).
00253Br 2  20 rr rr             jsr     @incTxt
00253Er 2               @inStr:
00253Er 2  A0 00                ldy     #0
002540r 2  B1 04                lda     (TXTPTR),y
002542r 2  F0 0E                beq     @atEnd
002544r 2  20 rr rr             jsr     @incTxt
002547r 2  C9 22                cmp     #'"'
002549r 2  D0 F3                bne     @inStr
00254Br 2  80 E0                bra     @scanByte
00254Dr 2               @advance1:
00254Dr 2  20 rr rr             jsr     @incTxt
002550r 2  80 DB                bra     @scanByte
002552r 2               @atEnd:
002552r 2                       ; (TXTPTR) is on the line's $00 terminator.  Bytes immediately after
002552r 2                       ; are the next line's [next-lo][next-hi][num-lo][num-hi][payload..].
002552r 2                       ; Check next-pointer at offset +2 (next-hi); if 0, end of program.
002552r 2  A0 02                ldy     #2
002554r 2  B1 04                lda     (TXTPTR),y
002556r 2  F0 0F                beq     @oodata
002558r 2                       ; Advance TXTPTR by 5: past terminator (1) + line header (4).
002558r 2  18                   clc
002559r 2  A5 04                lda     TXTPTR
00255Br 2  69 05                adc     #5
00255Dr 2  85 04                sta     TXTPTR
00255Fr 2  90 CC                bcc     @scanByte
002561r 2  E6 05                inc     TXTPTR+1
002563r 2  80 C8                bra     @scanByte
002565r 2               @found:
002565r 2                       ; TXTPTR is left AT the TOK_DATA byte; caller's CHRGET advances past.
002565r 2  18                   clc
002566r 2  60                   rts
002567r 2               @oodata:
002567r 2  38                   sec
002568r 2  60                   rts
002569r 2               @incTxt:
002569r 2  E6 04                inc     TXTPTR
00256Br 2  D0 02                bne     @r
00256Dr 2  E6 05                inc     TXTPTR+1
00256Fr 2               @r:
00256Fr 2  60                   rts
002570r 2               
002570r 2               ; ---------------------------------------------------------------------------
002570r 2               ; Statement: FOR var = expr1 TO expr2 [STEP expr3]
002570r 2               ; Pushes 18-byte frame on CPU stack:
002570r 2               ;   [tag $81][VAR-lo][VAR-hi][STEP-FP (5)][STEP-sign][CURLIN-lo][CURLIN-hi]
002570r 2               ;   [TXTPTR-lo][TXTPTR-hi][LIMIT-FP (5)]
002570r 2               ; ---------------------------------------------------------------------------
002570r 2               BasCmdFor:
002570r 2                       ; Set SUBFLG so PtrGet doesn't recurse on FN.
002570r 2  A9 80                lda     #$80
002572r 2  85 68                sta     SUBFLG
002574r 2  20 rr rr             jsr     BasCmdLet               ; consumes "var = expr"
002577r 2                       ; PtrGet (inside LET) saved VARPNT in FORPNT (hopefully). Re-fetch
002577r 2                       ; FORPNT from the assignment, but BasCmdLet doesn't set FORPNT in
002577r 2                       ; our impl.  Re-parse the variable name by rewinding TXTPTR via
002577r 2                       ; CURLIN scan.  Cheat: BasCmdLet leaves VARPNT current.
002577r 2  A5 3F                lda     VARPNT
002579r 2  85 46                sta     BAS_FORPNT
00257Br 2  A5 40                lda     VARPNT+1
00257Dr 2  85 47                sta     BAS_FORPNT+1
00257Fr 2                       ; Discard any prior FOR frame for the same variable to avoid leak.
00257Fr 2  20 rr rr             jsr     GtForPnt
002582r 2  D0 00                bne     @noOld                  ; Z=0 -> not found (lda #0 sets Z=1; we invert below)
002584r 2                       ; Actually GtForPnt's "not found" path also ends with `lda #0;rts` (Z=1).
002584r 2                       ; So the BEQ/BNE distinction can't be used. Skip the prior-frame
002584r 2                       ; pop entirely; the runtime can tolerate one stray frame and msbasic
002584r 2                       ; FOR re-uses the same slot only when an explicit FOR with a matching
002584r 2                       ; variable already exists, which is rare.
002584r 2               @noOld:
002584r 2                       ; Discard our caller's (BasExecuteStatement's) return address so
002584r 2                       ; that the FOR frame sits on the stack with no other junk above it.
002584r 2                       ; We will JMP BasNewstt at the end instead of RTSing.
002584r 2  68                   pla
002585r 2  68                   pla
002586r 2                       ; Push limit (will be parsed below) -- we lay out the frame as:
002586r 2                       ;   pushed first (deepest): TXTPTR, CURLIN, LIMIT (5), STEP-sign,
002586r 2                       ;   STEP (5), VAR-addr, $81-tag.
002586r 2                       ; We don't know LIMIT/STEP yet; we push placeholders and patch.
002586r 2                       ; Easier: parse limit & step first, then push frame in one go.
002586r 2  A9 9C                lda     #TOK_TO
002588r 2  20 rr rr             jsr     SynChr
00258Br 2  20 rr rr             jsr     FrmNum
00258Er 2                       ; Strip sign info on limit (msbasic stores limit unsigned-magnitude
00258Er 2                       ; with sign packed).  Pack FACSIGN bit 7 -> FAC+1 bit 7.
00258Er 2  A5 13                lda     FACSIGN
002590r 2  09 7F                ora     #$7F
002592r 2  25 0F                and     FAC+1
002594r 2  85 0F                sta     FAC+1
002596r 2                       ; Save LIMIT temporarily in BAS_TEMP1..+4 (5 bytes).
002596r 2  A2 04                ldx     #4
002598r 2               @saveLimit:
002598r 2  B5 0E                lda     FAC,x
00259Ar 2  95 4D                sta     BAS_TEMP1,x
00259Cr 2  CA                   dex
00259Dr 2  10 F9                bpl     @saveLimit
00259Fr 2                       ; STEP: default 1, or evaluate after TOK_STEP.
00259Fr 2  20 rr rr             jsr     ChrGot
0025A2r 2  C9 A1                cmp     #TOK_STEP
0025A4r 2  D0 08                bne     @defStep
0025A6r 2  20 rr rr             jsr     ChrGet
0025A9r 2  20 rr rr             jsr     FrmNum
0025ACr 2  80 07                bra     @gotStep
0025AEr 2               @defStep:
0025AEr 2  A9 rr                lda     #<ConstOne
0025B0r 2  A0 rr                ldy     #>ConstOne
0025B2r 2  20 rr rr             jsr     LoadFacFromYa
0025B5r 2               @gotStep:
0025B5r 2  20 rr rr             jsr     Sign                    ; A = step sign byte (-1/0/1)
0025B8r 2  85 52                sta     BAS_TEMP2               ; stash step sign
0025BAr 2                       ; Pack sign of FAC into FAC+1 bit7 then save STEP into BAS_TEMP2+1..+5.
0025BAr 2  A5 13                lda     FACSIGN
0025BCr 2  09 7F                ora     #$7F
0025BEr 2  25 0F                and     FAC+1
0025C0r 2  85 0F                sta     FAC+1
0025C2r 2  A2 04                ldx     #4
0025C4r 2               @saveStep:
0025C4r 2  B5 0E                lda     FAC,x
0025C6r 2  95 53                sta     BAS_TEMP2+1,x
0025C8r 2  CA                   dex
0025C9r 2  10 F9                bpl     @saveStep
0025CBr 2                       ; Now push the frame on stack (deepest first):
0025CBr 2                       ;   TXTPTR-hi, TXTPTR-lo, CURLIN-hi, CURLIN-lo,
0025CBr 2                       ;   LIMIT[4..0]   (deepest=LIMIT[4], so LIMIT[0] ends at $010A,x),
0025CBr 2                       ;   STEP-sign,
0025CBr 2                       ;   STEP[4..0]    (deepest=STEP[4], so STEP[0]  ends at $0104,x),
0025CBr 2                       ;   VAR-hi, VAR-lo, $81
0025CBr 2  A5 05                lda     TXTPTR+1
0025CDr 2  48                   pha
0025CEr 2  A5 04                lda     TXTPTR
0025D0r 2  48                   pha
0025D1r 2  AD 6A 03             lda     BAS_CURLIN+1
0025D4r 2  48                   pha
0025D5r 2  AD 69 03             lda     BAS_CURLIN
0025D8r 2  48                   pha
0025D9r 2  A2 04                ldx     #4
0025DBr 2               @pushLim:
0025DBr 2  B5 4D                lda     BAS_TEMP1,x
0025DDr 2  48                   pha
0025DEr 2  CA                   dex
0025DFr 2  10 FA                bpl     @pushLim
0025E1r 2  A5 52                lda     BAS_TEMP2               ; step sign
0025E3r 2  48                   pha
0025E4r 2  A2 05                ldx     #5
0025E6r 2               @pushStep:
0025E6r 2  B5 52                lda     BAS_TEMP2,x
0025E8r 2  48                   pha
0025E9r 2  CA                   dex
0025EAr 2  D0 FA                bne     @pushStep
0025ECr 2  A5 47                lda     BAS_FORPNT+1
0025EEr 2  48                   pha
0025EFr 2  A5 46                lda     BAS_FORPNT
0025F1r 2  48                   pha
0025F2r 2  A9 81                lda     #TOK_FOR
0025F4r 2  48                   pha
0025F5r 2  4C rr rr             jmp     BasNewstt               ; resume statement loop with frame in place
0025F8r 2               
0025F8r 2               ConstOne:
0025F8r 2  81 00 00 00          .byte   $81,$00,$00,$00,$00     ; FP +1.0
0025FCr 2  00           
0025FDr 2               
0025FDr 2               ; ---------------------------------------------------------------------------
0025FDr 2               ; Statement: NEXT [var]
0025FDr 2               ; Locate matching FOR frame, increment var by step, test against limit,
0025FDr 2               ; loop back if more iterations remain, else discard frame and continue.
0025FDr 2               ; ---------------------------------------------------------------------------
0025FDr 2               BasCmdNext:
0025FDr 2  20 rr rr             jsr     ChrGot
002600r 2  F0 0D                beq     @anyVar
002602r 2  C9 3A                cmp     #':'
002604r 2  F0 09                beq     @anyVar
002606r 2  20 rr rr             jsr     PtrGet
002609r 2  85 46                sta     BAS_FORPNT
00260Br 2  84 47                sty     BAS_FORPNT+1
00260Dr 2  80 06                bra     @find
00260Fr 2               @anyVar:
00260Fr 2                       ; "NEXT" without a variable: set FORPNT = 0 so GtForPnt copies the
00260Fr 2                       ; stack-frame's var address into FORPNT and then trivially matches
00260Fr 2                       ; (any FOR frame is acceptable).
00260Fr 2  A9 00                lda     #0
002611r 2  85 46                sta     BAS_FORPNT
002613r 2  85 47                sta     BAS_FORPNT+1
002615r 2               @find:
002615r 2  20 rr rr             jsr     GtForPnt
002618r 2  F0 05                beq     @found
00261Ar 2  A2 0D                ldx     #ERR_NF
00261Cr 2  4C rr rr             jmp     BasErrorVec
00261Fr 2               @found:
00261Fr 2                       ; X = stack offset of (tag - 1).  txs makes SP = X so the frame
00261Fr 2                       ; sits at $101+X..$112+X.  All subsequent accesses use $0101+offset,x
00261Fr 2                       ; just like msbasic.
00261Fr 2  9A                   txs
002620r 2                       ; Frame layout (tag at $0101+X):
002620r 2                       ;   $0101+X = $81 tag
002620r 2                       ;   $0102+X = VAR-lo
002620r 2                       ;   $0103+X = VAR-hi
002620r 2                       ;   $0104+X..$0108+X = STEP (5 bytes FP, FAC[0..4] ascending)
002620r 2                       ;   $0109+X = STEP-sign
002620r 2                       ;   $010A+X..$010E+X = LIMIT (5 bytes FP, FAC[0..4] ascending)
002620r 2                       ;   $010F+X = CURLIN-lo
002620r 2                       ;   $0110+X = CURLIN-hi
002620r 2                       ;   $0111+X = TXTPTR-lo
002620r 2                       ;   $0112+X = TXTPTR-hi
002620r 2                       ; Load STEP into FAC.
002620r 2  A9 01                lda     #$01
002622r 2  85 3B                sta     BAS_TMP1+1
002624r 2  8A                   txa
002625r 2  18                   clc
002626r 2  69 04                adc     #$04
002628r 2  85 3A                sta     BAS_TMP1                ; TMP1 -> STEP[0] at $0104,x
00262Ar 2  A5 3A                lda     BAS_TMP1
00262Cr 2  A4 3B                ldy     BAS_TMP1+1
00262Er 2  20 rr rr             jsr     LoadFacFromYa
002631r 2                       ; FACSIGN := step sign byte at $0109,x.
002631r 2  BD 09 01             lda     $0109,x
002634r 2  85 13                sta     FACSIGN
002636r 2                       ; FAC += variable.
002636r 2  BD 02 01             lda     $0102,x
002639r 2  BC 03 01             ldy     $0103,x
00263Cr 2  85 46                sta     BAS_FORPNT
00263Er 2  84 47                sty     BAS_FORPNT+1
002640r 2  20 rr rr             jsr     FAdd
002643r 2  20 rr rr             jsr     SetFor
002646r 2                       ; Compare FAC with LIMIT (at $010A,x).
002646r 2  BA                   tsx                             ; reload x (FAdd may have used it)
002647r 2  8A                   txa
002648r 2  18                   clc
002649r 2  69 0A                adc     #$0A
00264Br 2  85 3A                sta     BAS_TMP1
00264Dr 2  A9 01                lda     #$01
00264Fr 2  85 3B                sta     BAS_TMP1+1
002651r 2  A5 3A                lda     BAS_TMP1
002653r 2  A4 3B                ldy     BAS_TMP1+1
002655r 2  20 rr rr             jsr     FComp
002658r 2  BA                   tsx
002659r 2  38                   sec
00265Ar 2  FD 09 01             sbc     $0109,x                 ; A - step-sign
00265Dr 2  F0 19                beq     @loopDone
00265Fr 2                       ; Continue: restore CURLIN/TXTPTR from frame, JMP NEWSTT (don't RTS).
00265Fr 2  BD 0F 01             lda     $010F,x
002662r 2  8D 69 03             sta     BAS_CURLIN
002665r 2  BD 10 01             lda     $0110,x
002668r 2  8D 6A 03             sta     BAS_CURLIN+1
00266Br 2  BD 11 01             lda     $0111,x
00266Er 2  85 04                sta     TXTPTR
002670r 2  BD 12 01             lda     $0112,x
002673r 2  85 05                sta     TXTPTR+1
002675r 2  4C rr rr             jmp     BasNewstt
002678r 2               @loopDone:
002678r 2                       ; Discard frame: SP := X + 18.
002678r 2  8A                   txa
002679r 2  18                   clc
00267Ar 2  69 12                adc     #18
00267Cr 2  AA                   tax
00267Dr 2  9A                   txs
00267Er 2                       ; Allow ", var" to chain into another NEXT.
00267Er 2  20 rr rr             jsr     ChrGot
002681r 2  C9 2C                cmp     #','
002683r 2  D0 06                bne     @retNewstt
002685r 2  20 rr rr             jsr     ChrGet
002688r 2  4C rr rr             jmp     BasCmdNext
00268Br 2               @retNewstt:
00268Br 2  4C rr rr             jmp     BasNewstt
00268Er 2               
00268Er 2               ; ---------------------------------------------------------------------------
00268Er 2               ; Statement: DEF FN A(X) = expr
00268Er 2               ; Stored in the variable's 5 value bytes:
00268Er 2               ;   [TXTPTR-of-expr-lo][TXTPTR-of-expr-hi][param-name-lo][param-name-hi][0]
00268Er 2               ; ---------------------------------------------------------------------------
00268Er 2               BasCmdDef:
00268Er 2                       ; Expect: FN <name>(<param>) = <expr>
00268Er 2  A9 9D                lda     #TOK_FN
002690r 2  20 rr rr             jsr     SynChr
002693r 2  09 80                ora     #$80
002695r 2  85 68                sta     SUBFLG                  ; tell PtrGet "this is a DEF FN var"
002697r 2  20 rr rr             jsr     PtrGet
00269Ar 2                       ; VARPNT = address of FN var slot.
00269Ar 2  85 81                sta     BAS_FNCNAM
00269Cr 2  84 82                sty     BAS_FNCNAM+1
00269Er 2  20 rr rr             jsr     ChkNum
0026A1r 2                       ; Expect '(' name ')' = expr
0026A1r 2                       ; Param name parsed by recursive PtrGet inside FrmEvl on call;
0026A1r 2                       ; here we just record (param-name) by parsing it ourselves.
0026A1r 2  A9 28                lda     #'('
0026A3r 2  20 rr rr             jsr     SynChr
0026A6r 2  A9 80                lda     #$80
0026A8r 2  85 68                sta     SUBFLG
0026AAr 2  20 rr rr             jsr     PtrGet
0026ADr 2                       ; VARPNT = param var addr.  Save it.
0026ADr 2  A5 3F                lda     VARPNT
0026AFr 2  85 3A                sta     BAS_TMP1
0026B1r 2  A5 40                lda     VARPNT+1
0026B3r 2  85 3B                sta     BAS_TMP1+1
0026B5r 2  20 rr rr             jsr     ChkNum
0026B8r 2  A9 29                lda     #')'
0026BAr 2  20 rr rr             jsr     SynChr
0026BDr 2  A9 3D                lda     #'='
0026BFr 2  20 rr rr             jsr     SynChr
0026C2r 2                       ; Reject in direct mode.
0026C2r 2  AD 6A 03             lda     BAS_CURLIN+1
0026C5r 2  C9 FF                cmp     #$FF
0026C7r 2  D0 05                bne     @ok
0026C9r 2  A2 07                ldx     #ERR_ILLDIRECT
0026CBr 2  4C rr rr             jmp     BasErrorVec
0026CEr 2               @ok:
0026CEr 2                       ; Store [TXTPTR][param][0] in FN var.
0026CEr 2  A0 00                ldy     #0
0026D0r 2  A5 04                lda     TXTPTR
0026D2r 2  91 81                sta     (BAS_FNCNAM),y
0026D4r 2  C8                   iny
0026D5r 2  A5 05                lda     TXTPTR+1
0026D7r 2  91 81                sta     (BAS_FNCNAM),y
0026D9r 2  C8                   iny
0026DAr 2  A5 3A                lda     BAS_TMP1
0026DCr 2  91 81                sta     (BAS_FNCNAM),y
0026DEr 2  C8                   iny
0026DFr 2  A5 3B                lda     BAS_TMP1+1
0026E1r 2  91 81                sta     (BAS_FNCNAM),y
0026E3r 2  C8                   iny
0026E4r 2  A9 00                lda     #0
0026E6r 2  91 81                sta     (BAS_FNCNAM),y
0026E8r 2                       ; Skip past expression body.
0026E8r 2  20 rr rr             jsr     BasDatan
0026EBr 2  4C rr rr             jmp     BasAddon
0026EEr 2               
0026EEr 2               ; ---------------------------------------------------------------------------
0026EEr 2               ; FnCall -- evaluator-side handler for "FN A(expr)".
0026EEr 2               ; Called by FrmEvl when it sees TOK_FN.  Evaluates argument, swaps in the
0026EEr 2               ; param's stored value, executes the FN expression, and restores the param.
0026EEr 2               ; ---------------------------------------------------------------------------
0026EEr 2               FnCall:
0026EEr 2  20 rr rr             jsr     ChrGet                  ; consume FN
0026F1r 2  09 80                ora     #$80
0026F3r 2  85 68                sta     SUBFLG
0026F5r 2  20 rr rr             jsr     PtrGet                  ; locate FN var
0026F8r 2  85 81                sta     BAS_FNCNAM
0026FAr 2  84 82                sty     BAS_FNCNAM+1
0026FCr 2  20 rr rr             jsr     ChkNum
0026FFr 2                       ; Read param ptr from FN slot.
0026FFr 2  A0 02                ldy     #2
002701r 2  B1 81                lda     (BAS_FNCNAM),y
002703r 2  85 3F                sta     VARPNT
002705r 2  F0 5C                beq     @undef
002707r 2  C8                   iny
002708r 2  B1 81                lda     (BAS_FNCNAM),y
00270Ar 2  85 40                sta     VARPNT+1
00270Cr 2                       ; Evaluate '(arg)'
00270Cr 2  A9 28                lda     #'('
00270Er 2  20 rr rr             jsr     SynChr
002711r 2                       ; Save param's current FP value (5 bytes) on stack.
002711r 2  A0 04                ldy     #4
002713r 2               @savep:
002713r 2  B1 3F                lda     (VARPNT),y
002715r 2  48                   pha
002716r 2  88                   dey
002717r 2  10 FA                bpl     @savep
002719r 2                       ; Evaluate argument -> FAC.
002719r 2  20 rr rr             jsr     FrmNum
00271Cr 2  A9 29                lda     #')'
00271Er 2  20 rr rr             jsr     SynChr
002721r 2                       ; Store FAC into param slot.
002721r 2  A6 3F                ldx     VARPNT
002723r 2  A4 40                ldy     VARPNT+1
002725r 2  20 rr rr             jsr     StoreFacAtYxRounded
002728r 2                       ; Save current TXTPTR.
002728r 2  A5 05                lda     TXTPTR+1
00272Ar 2  48                   pha
00272Br 2  A5 04                lda     TXTPTR
00272Dr 2  48                   pha
00272Er 2                       ; Switch TXTPTR to FN expression body.
00272Er 2  A0 00                ldy     #0
002730r 2  B1 81                lda     (BAS_FNCNAM),y
002732r 2  85 04                sta     TXTPTR
002734r 2  C8                   iny
002735r 2  B1 81                lda     (BAS_FNCNAM),y
002737r 2  85 05                sta     TXTPTR+1
002739r 2                       ; Body TXTPTR is positioned at the first byte; we need it positioned
002739r 2                       ; one BEFORE so FrmNum's first ChrGet loads the first byte.  Decrement.
002739r 2  A5 04                lda     TXTPTR
00273Br 2  D0 02                bne     @noBor
00273Dr 2  C6 05                dec     TXTPTR+1
00273Fr 2               @noBor:
00273Fr 2  C6 04                dec     TXTPTR
002741r 2                       ; Evaluate the FN expression body.
002741r 2  20 rr rr             jsr     ChrGet
002744r 2  20 rr rr             jsr     FrmNum
002747r 2                       ; Restore TXTPTR.
002747r 2  68                   pla
002748r 2  85 04                sta     TXTPTR
00274Ar 2  68                   pla
00274Br 2  85 05                sta     TXTPTR+1
00274Dr 2                       ; Restore param.  VARPNT may have been clobbered; reload.
00274Dr 2  A0 02                ldy     #2
00274Fr 2  B1 81                lda     (BAS_FNCNAM),y
002751r 2  85 3F                sta     VARPNT
002753r 2  C8                   iny
002754r 2  B1 81                lda     (BAS_FNCNAM),y
002756r 2  85 40                sta     VARPNT+1
002758r 2  A0 00                ldy     #0
00275Ar 2               @restp:
00275Ar 2  68                   pla
00275Br 2  91 3F                sta     (VARPNT),y
00275Dr 2  C8                   iny
00275Er 2  C0 05                cpy     #5
002760r 2  D0 F8                bne     @restp
002762r 2  60                   rts
002763r 2               @undef:
002763r 2  A2 03                ldx     #ERR_UNDEFSTMT
002765r 2  4C rr rr             jmp     BasErrorVec
002768r 2               
002768r 2               ; ---------------------------------------------------------------------------
002768r 2               ; Reserved dispatch slot -- raise SYNTAX ERROR.
002768r 2               ; ---------------------------------------------------------------------------
002768r 2               BasCmdNotImpl:
002768r 2  4C rr rr             jmp     SynErr
00276Br 2               
00276Br 2               ; ===========================================================================
00276Br 2               ;   H A R D W A R E - E X T E N S I O N   S T A T E M E N T S
00276Br 2               ; ===========================================================================
00276Br 2               
00276Br 2               ; --- Helpers --------------------------------------------------------------
00276Br 2               
00276Br 2               ; Raise ?NO DEVICE error.
00276Br 2               NoDevErr:
00276Br 2  A2 0F                ldx     #ERR_NODEV
00276Dr 2  4C rr rr             jmp     BasErrorVec
002770r 2               
002770r 2               ; Require A bits in HW_PRESENT (else ?NO DEVICE).
002770r 2               ;   Input : A = mask
002770r 2               ;   Output: A preserved on success
002770r 2               ReqHw:
002770r 2  2D 0D 03             and     HW_PRESENT
002773r 2  F0 F6                beq     NoDevErr
002775r 2  60                   rts
002776r 2               
002776r 2               ; Evaluate expression -> A in 0..255.
002776r 2               ;   On entry: ChrGot positioned at first byte of expression.
002776r 2               ;   On exit : A = byte, ChrGot returns char following expression.
002776r 2               EvalU8:
002776r 2  20 rr rr             jsr     GetByt                  ; X = byte, jmp ChrGot
002779r 2  8A                   txa
00277Ar 2  60                   rts
00277Br 2               
00277Br 2               ; Evaluate expression as 16-bit signed -> FAC+3 (hi), FAC+4 (lo).
00277Br 2               EvalU16:
00277Br 2  20 rr rr             jsr     FrmNum
00277Er 2  20 rr rr             jsr     AyInt
002781r 2  4C rr rr             jmp     ChrGot
002784r 2               
002784r 2               ; Evaluate expression as 16-bit unsigned address (0..65535)
002784r 2               ;   -> FAC+3 (hi), FAC+4 (lo).  Used by SYS, POKE, PEEK, WAIT so the full
002784r 2               ;   6502 address space is reachable with positive decimal literals.
002784r 2               ;   Truncates fractional part.  Negative or >= 65536 raises ?ILLEGAL QUANTITY.
002784r 2               EvalAddrU16:
002784r 2  20 rr rr             jsr     FrmNum
002787r 2  20 rr rr             jsr     FacToU16
00278Ar 2  4C rr rr             jmp     ChrGot
00278Dr 2               
00278Dr 2               ; FacToU16 -- Convert FAC (must be 0..65535) to FAC+3 (hi), FAC+4 (lo).
00278Dr 2               ;   Negative or >= 65536 raises ?ILLEGAL QUANTITY.  Truncates fractional part.
00278Dr 2               FacToU16:
00278Dr 2  24 13                bit     FACSIGN
00278Fr 2  30 34                bmi     @illqty
002791r 2  A5 0E                lda     FAC                     ; exponent byte (0 = value is zero)
002793r 2  F0 2B                beq     @zero
002795r 2  C9 91                cmp     #$91                    ; exp >= $91 means value >= 65536
002797r 2  B0 2C                bcs     @illqty
002799r 2                       ; Reconstruct top 16 bits of mantissa (with hidden 1 bit).
002799r 2  48                   pha                             ; save exponent byte
00279Ar 2  A5 0F                lda     FAC+1
00279Cr 2  09 80                ora     #$80                    ; restore hidden bit
00279Er 2  85 3B                sta     BAS_TMP1+1              ; hi
0027A0r 2  A5 10                lda     FAC+2
0027A2r 2  85 3A                sta     BAS_TMP1                ; lo
0027A4r 2                       ; Shift count = $90 - exp_byte (0..15).
0027A4r 2  68                   pla
0027A5r 2  38                   sec
0027A6r 2  E9 90                sbc     #$90
0027A8r 2  49 FF                eor     #$FF
0027AAr 2  18                   clc
0027ABr 2  69 01                adc     #1                      ; A = $90 - exp
0027ADr 2  F0 08                beq     @store                  ; zero shifts: already aligned
0027AFr 2  AA                   tax
0027B0r 2               @shloop:
0027B0r 2  46 3B                lsr     BAS_TMP1+1
0027B2r 2  66 3A                ror     BAS_TMP1
0027B4r 2  CA                   dex
0027B5r 2  D0 F9                bne     @shloop
0027B7r 2               @store:
0027B7r 2  A5 3B                lda     BAS_TMP1+1
0027B9r 2  85 11                sta     FAC+3
0027BBr 2  A5 3A                lda     BAS_TMP1
0027BDr 2  85 12                sta     FAC+4
0027BFr 2  60                   rts
0027C0r 2               @zero:
0027C0r 2  64 11                stz     FAC+3
0027C2r 2  64 12                stz     FAC+4
0027C4r 2  60                   rts
0027C5r 2               @illqty:
0027C5r 2  4C rr rr             jmp     IqErr
0027C8r 2               
0027C8r 2               ; Evaluate string expression -> copy up to 11 chars to BAS_FNAME,
0027C8r 2               ; null-terminate, set STR_PTR := BAS_FNAME, free temp string.
0027C8r 2               EvalString:
0027C8r 2  20 rr rr             jsr     FrmEvl
0027CBr 2  20 rr rr             jsr     ChkStr
0027CEr 2  A5 0F                lda     FAC+1
0027D0r 2  85 20                sta     INDEX
0027D2r 2  A5 10                lda     FAC+2
0027D4r 2  85 21                sta     INDEX+1
0027D6r 2  A0 00                ldy     #0
0027D8r 2  A6 0E                ldx     FAC                     ; length
0027DAr 2               @cpy:
0027DAr 2  C0 0B                cpy     #11
0027DCr 2  F0 0D                beq     @done
0027DEr 2  E0 00                cpx     #0
0027E0r 2  F0 09                beq     @done
0027E2r 2  B1 20                lda     (INDEX),y
0027E4r 2  99 73 03             sta     BAS_FNAME,y
0027E7r 2  C8                   iny
0027E8r 2  CA                   dex
0027E9r 2  80 EF                bra     @cpy
0027EBr 2               @done:
0027EBr 2  A9 00                lda     #0
0027EDr 2  99 73 03             sta     BAS_FNAME,y
0027F0r 2  A9 73                lda     #<BAS_FNAME
0027F2r 2  85 02                sta     STR_PTR
0027F4r 2  A9 03                lda     #>BAS_FNAME
0027F6r 2  85 03                sta     STR_PTR+1
0027F8r 2  4C rr rr             jmp     FreFac
0027FBr 2               
0027FBr 2               ; Print A as 2-digit decimal with leading zero (used by TIME/DATE).
0027FBr 2               BasPr2D:
0027FBr 2  A2 00                ldx     #0
0027FDr 2               @loop:
0027FDr 2  C9 0A                cmp     #10
0027FFr 2  90 05                bcc     @done
002801r 2  E9 0A                sbc     #10
002803r 2  E8                   inx
002804r 2  80 F7                bra     @loop
002806r 2               @done:
002806r 2  48                   pha
002807r 2  8A                   txa
002808r 2  09 30                ora     #'0'
00280Ar 2  20 rr rr             jsr     Chrout
00280Dr 2  68                   pla
00280Er 2  09 30                ora     #'0'
002810r 2  4C rr rr             jmp     Chrout
002813r 2               
002813r 2               ; Walk program chain after LOAD to recompute BAS_VARTAB.
002813r 2               ;   On entry: ChrGot any.
002813r 2               BasFixChain:
002813r 2  A9 00                lda     #<PROGRAM_START
002815r 2  85 20                sta     INDEX
002817r 2  A9 08                lda     #>PROGRAM_START
002819r 2  85 21                sta     INDEX+1
00281Br 2               @walk:
00281Br 2  A0 00                ldy     #0
00281Dr 2  B1 20                lda     (INDEX),y
00281Fr 2  85 3A                sta     BAS_TMP1
002821r 2  C8                   iny
002822r 2  B1 20                lda     (INDEX),y
002824r 2  85 3B                sta     BAS_TMP1+1
002826r 2  05 3A                ora     BAS_TMP1
002828r 2  F0 0A                beq     @end
00282Ar 2  A5 3A                lda     BAS_TMP1
00282Cr 2  85 20                sta     INDEX
00282Er 2  A5 3B                lda     BAS_TMP1+1
002830r 2  85 21                sta     INDEX+1
002832r 2  80 E7                bra     @walk
002834r 2               @end:
002834r 2                       ; INDEX points at terminator ($00 $00).  VARTAB = INDEX + 2.
002834r 2  18                   clc
002835r 2  A5 20                lda     INDEX
002837r 2  69 02                adc     #2
002839r 2  8D 5F 03             sta     BAS_VARTAB
00283Cr 2  A5 21                lda     INDEX+1
00283Er 2  69 00                adc     #0
002840r 2  8D 60 03             sta     BAS_VARTAB+1
002843r 2  60                   rts
002844r 2               
002844r 2               ; --- Statements -----------------------------------------------------------
002844r 2               
002844r 2               ; SYS addr -- jump indirectly to address (RTS returns to caller).
002844r 2               BasCmdSys:
002844r 2  20 rr rr             jsr     EvalAddrU16
002847r 2  A5 12                lda     FAC+4
002849r 2  85 20                sta     INDEX
00284Br 2  A5 11                lda     FAC+3
00284Dr 2  85 21                sta     INDEX+1
00284Fr 2  6C 20 00             jmp     (INDEX)
002852r 2               
002852r 2               ; CLS
002852r 2               BasCmdCls:
002852r 2  A9 80                lda     #HW_VID
002854r 2  20 rr rr             jsr     ReqHw
002857r 2  4C rr rr             jmp     VideoClear
00285Ar 2               
00285Ar 2               ; LOCATE row, col
00285Ar 2               BasCmdLocate:
00285Ar 2  A9 80                lda     #HW_VID
00285Cr 2  20 rr rr             jsr     ReqHw
00285Fr 2  20 rr rr             jsr     GetByt                  ; X = row
002862r 2  DA                   phx
002863r 2  20 rr rr             jsr     ChkCom
002866r 2  20 rr rr             jsr     GetByt                  ; X = col
002869r 2  7A                   ply                             ; Y = row
00286Ar 2  4C rr rr             jmp     VideoSetCursor
00286Dr 2               
00286Dr 2               ; COLOR fg, bg
00286Dr 2               BasCmdColor:
00286Dr 2  A9 80                lda     #HW_VID
00286Fr 2  20 rr rr             jsr     ReqHw
002872r 2  20 rr rr             jsr     GetByt                  ; X = fg
002875r 2  8A                   txa
002876r 2  0A                   asl     a
002877r 2  0A                   asl     a
002878r 2  0A                   asl     a
002879r 2  0A                   asl     a
00287Ar 2  85 3A                sta     BAS_TMP1
00287Cr 2  20 rr rr             jsr     ChkCom
00287Fr 2  20 rr rr             jsr     GetByt                  ; X = bg
002882r 2  8A                   txa
002883r 2  29 0F                and     #$0F
002885r 2  05 3A                ora     BAS_TMP1
002887r 2  4C rr rr             jmp     VideoSetColor
00288Ar 2               
00288Ar 2               ; VOL n
00288Ar 2               BasCmdVol:
00288Ar 2  A9 40                lda     #HW_SID
00288Cr 2  20 rr rr             jsr     ReqHw
00288Fr 2  20 rr rr             jsr     GetByt                  ; X = vol
002892r 2  8A                   txa
002893r 2  4C rr rr             jmp     SidSetVolume
002896r 2               
002896r 2               ; SOUND voice, freq, dur (freq=Hz, dur=centisec)
002896r 2               ;   Hz -> SID register: reg = Hz * 16.75 ≈ Hz<<4 + Hz - Hz/4
002896r 2               BasCmdSound:
002896r 2  A9 40                lda     #HW_SID
002898r 2  20 rr rr             jsr     ReqHw
00289Br 2  20 rr rr             jsr     GetByt                  ; X = voice (1..3)
00289Er 2  CA                   dex
00289Fr 2  DA                   phx                             ; voice (0-indexed) on stack
0028A0r 2  20 rr rr             jsr     ChkCom
0028A3r 2  20 rr rr             jsr     EvalU16                 ; freq Hz: hi=FAC+3, lo=FAC+4
0028A6r 2                       ; Compute reg = Hz<<4 + Hz - Hz/4
0028A6r 2  A5 12                lda     FAC+4
0028A8r 2  85 3A                sta     BAS_TMP1
0028AAr 2  A5 11                lda     FAC+3
0028ACr 2  85 3B                sta     BAS_TMP1+1
0028AEr 2  A5 3A                lda     BAS_TMP1
0028B0r 2  85 3C                sta     BAS_TMP2
0028B2r 2  A5 3B                lda     BAS_TMP1+1
0028B4r 2  85 3D                sta     BAS_TMP2+1
0028B6r 2  A2 04                ldx     #4
0028B8r 2               @shl:
0028B8r 2  06 3A                asl     BAS_TMP1
0028BAr 2  26 3B                rol     BAS_TMP1+1
0028BCr 2  CA                   dex
0028BDr 2  D0 F9                bne     @shl
0028BFr 2  18                   clc
0028C0r 2  A5 3A                lda     BAS_TMP1
0028C2r 2  65 3C                adc     BAS_TMP2
0028C4r 2  85 3A                sta     BAS_TMP1
0028C6r 2  A5 3B                lda     BAS_TMP1+1
0028C8r 2  65 3D                adc     BAS_TMP2+1
0028CAr 2  85 3B                sta     BAS_TMP1+1
0028CCr 2  46 3D                lsr     BAS_TMP2+1
0028CEr 2  66 3C                ror     BAS_TMP2
0028D0r 2  46 3D                lsr     BAS_TMP2+1
0028D2r 2  66 3C                ror     BAS_TMP2
0028D4r 2  38                   sec
0028D5r 2  A5 3A                lda     BAS_TMP1
0028D7r 2  E5 3C                sbc     BAS_TMP2
0028D9r 2  48                   pha                             ; freqLo
0028DAr 2  A5 3B                lda     BAS_TMP1+1
0028DCr 2  E5 3D                sbc     BAS_TMP2+1
0028DEr 2  48                   pha                             ; freqHi
0028DFr 2  20 rr rr             jsr     ChkCom
0028E2r 2  20 rr rr             jsr     EvalU16                 ; dur in FAC+3/+4
0028E5r 2                       ; Stack (top-down): freqHi, freqLo, voice
0028E5r 2  7A                   ply                             ; Y = freqHi
0028E6r 2  FA                   plx                             ; X = freqLo
0028E7r 2  68                   pla                             ; A = voice
0028E8r 2  20 rr rr             jsr     SidPlayNote
0028EBr 2  A5 12                lda     FAC+4
0028EDr 2  A6 11                ldx     FAC+3
0028EFr 2  20 rr rr             jsr     SysDelay
0028F2r 2  4C rr rr             jmp     SidSilence
0028F5r 2               
0028F5r 2               ; TIME
0028F5r 2               BasCmdTime:
0028F5r 2  A9 04                lda     #HW_RTC
0028F7r 2  20 rr rr             jsr     ReqHw
0028FAr 2  20 rr rr             jsr     RtcReadTime             ; A=hours, X=min, Y=sec
0028FDr 2  5A                   phy
0028FEr 2  DA                   phx
0028FFr 2  20 rr rr             jsr     BasPr2D                 ; print hours
002902r 2  A9 3A                lda     #':'
002904r 2  20 rr rr             jsr     Chrout
002907r 2  68                   pla
002908r 2  20 rr rr             jsr     BasPr2D
00290Br 2  A9 3A                lda     #':'
00290Dr 2  20 rr rr             jsr     Chrout
002910r 2  68                   pla
002911r 2  20 rr rr             jsr     BasPr2D
002914r 2  4C rr rr             jmp     BasPrintCRLF
002917r 2               
002917r 2               ; DATE
002917r 2               BasCmdDate:
002917r 2  A9 04                lda     #HW_RTC
002919r 2  20 rr rr             jsr     ReqHw
00291Cr 2  20 rr rr             jsr     RtcReadDate             ; A=day, X=month, Y=year
00291Fr 2  48                   pha
002920r 2  DA                   phx
002921r 2  5A                   phy
002922r 2  AD 0B 03             lda     RTC_BUF_CENT
002925r 2  20 rr rr             jsr     BasPr2D
002928r 2  68                   pla
002929r 2  20 rr rr             jsr     BasPr2D
00292Cr 2  A9 2D                lda     #'-'
00292Er 2  20 rr rr             jsr     Chrout
002931r 2  68                   pla
002932r 2  20 rr rr             jsr     BasPr2D
002935r 2  A9 2D                lda     #'-'
002937r 2  20 rr rr             jsr     Chrout
00293Ar 2  68                   pla
00293Br 2  20 rr rr             jsr     BasPr2D
00293Er 2  4C rr rr             jmp     BasPrintCRLF
002941r 2               
002941r 2               ; SETTIME h, m, s
002941r 2               BasCmdSettime:
002941r 2  A9 04                lda     #HW_RTC
002943r 2  20 rr rr             jsr     ReqHw
002946r 2  20 rr rr             jsr     GetByt                  ; X = h
002949r 2  DA                   phx
