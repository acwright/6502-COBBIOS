001872r 2  80 0C          bra @ReadDataOk
001874r 2               
001874r 2               @ReadHaveData:
001874r 2                 ; Check for exhausted DATA sentinel ($FFFF)
001874r 2  AD 1B 03       lda BAS_DATAPTR + 1
001877r 2  C9 FF          cmp #$FF
001879r 2  D0 05          bne @ReadDataOk
00187Br 2  A9 0A          lda #ERR_OUT_OF_DATA
00187Dr 2  4C rr rr       jmp BasError
001880r 2               
001880r 2               @ReadDataOk:
001880r 2                 ; Parse variable name (A-Z)
001880r 2  20 rr rr       jsr BasSkipSpaces
001883r 2  20 rr rr       jsr BasGetTokChar
