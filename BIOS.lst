0007AAr 2  A5 0A          lda BAS_ACC
0007ACr 2  05 0B          ora BAS_ACC + 1
0007AEr 2  F0 08          beq @AndFalse
0007B0r 2  A9 01          lda #$01
0007B2r 2  64 0B          stz BAS_ACC + 1
0007B4r 2  85 0A          sta BAS_ACC
