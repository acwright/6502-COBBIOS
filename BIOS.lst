000800r 1               .segment "MONITOR"
000000r 1               .include "Monitor.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   MONITOR   ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; Machine Code Monitor — Supermon-style command set
000000r 2               ; Segment: $C000-$DFFF (8KB)
000000r 2               ;
000000r 2               ; Entry points:
000000r 2               ;   MonitorEntry    ($C000) — Cold entry from boot menu or X return
000000r 2               ;   MonitorBrkEntry ($C003) — BRK entry with register display
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Monitor Constants
000000r 2               ; ============================================================================
000000r 2               
000000r 2               MON_LINBUF          = BAS_LINBUF         ; Share BASIC's line buffer ($0434)
000000r 2               MON_LINBUF_SIZE     = 200                ; Max input line length
000000r 2               MON_PROMPT          = '.'                ; Supermon-style prompt character
000000r 2               
000000r 2               ; Mnemonic Indices (for disassembler)
000000r 2               MN_ADC = 0
000000r 2               MN_AND = 1
000000r 2               MN_ASL = 2
000000r 2               MN_BBR = 3
000000r 2               MN_BBS = 4
000000r 2               MN_BCC = 5
000000r 2               MN_BCS = 6
000000r 2               MN_BEQ = 7
000000r 2               MN_BIT = 8
000000r 2               MN_BMI = 9
000000r 2               MN_BNE = 10
