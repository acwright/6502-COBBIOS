000A1Cr 2  20 rr rr       jsr Chrout
000A1Fr 2  20 rr rr       jsr DisOpZp
000A22r 2  A9 2C          lda #','
000A24r 2  20 rr rr       jsr Chrout
000A27r 2  A9 58          lda #'X'
000A29r 2  20 rr rr       jsr Chrout
000A2Cr 2  A9 29          lda #')'
000A2Er 2  4C rr rr       jmp Chrout
000A31r 2               
000A31r 2               DisOpIzy:
000A31r 2  A9 28          lda #'('
000A33r 2  20 rr rr       jsr Chrout
000A36r 2  20 rr rr       jsr DisOpZp
000A39r 2  A9 29          lda #')'
000A3Br 2  20 rr rr       jsr Chrout
000A3Er 2  A9 2C          lda #','
000A40r 2  20 rr rr       jsr Chrout
000A43r 2  A9 59          lda #'Y'
000A45r 2  4C rr rr       jmp Chrout
000A48r 2               
000A48r 2               DisOpZpi:
000A48r 2  A9 28          lda #'('
000A4Ar 2  20 rr rr       jsr Chrout
000A4Dr 2  20 rr rr       jsr DisOpZp
000A50r 2  A9 29          lda #')'
000A52r 2  4C rr rr       jmp Chrout
000A55r 2               
000A55r 2               DisOpRel:
000A55r 2                 ; Target = current_addr + 2 + signed_offset
000A55r 2  A0 01          ldy #1
000A57r 2  B1 2E          lda (MON_ADDR),y              ; offset byte
000A59r 2  30 0D          bmi @Neg
000A5Br 2                 ; Positive offset
000A5Br 2  18             clc
000A5Cr 2  65 2E          adc MON_ADDR
000A5Er 2  85 32          sta MON_TMP
000A60r 2  A5 2F          lda MON_ADDR+1
000A62r 2  69 00          adc #0
000A64r 2  85 33          sta MON_TMP+1
000A66r 2  80 0B          bra @Add2
000A68r 2               @Neg:
000A68r 2  18             clc
000A69r 2  65 2E          adc MON_ADDR
000A6Br 2  85 32          sta MON_TMP
000A6Dr 2  A5 2F          lda MON_ADDR+1
000A6Fr 2  69 FF          adc #$FF                      ; sign extension
000A71r 2  85 33          sta MON_TMP+1
000A73r 2               @Add2:
000A73r 2  18             clc
000A74r 2  A5 32          lda MON_TMP
000A76r 2  69 02          adc #2
000A78r 2  85 32          sta MON_TMP
000A7Ar 2  A5 33          lda MON_TMP+1
000A7Cr 2  69 00          adc #0
000A7Er 2  85 33          sta MON_TMP+1
000A80r 2                 ; Print "$XXXX"
000A80r 2  A9 24          lda #'$'
000A82r 2  20 rr rr       jsr Chrout
000A85r 2  A5 33          lda MON_TMP+1
000A87r 2  20 rr rr       jsr MonPrintHex2
000A8Ar 2  A5 32          lda MON_TMP
000A8Cr 2  4C rr rr       jmp MonPrintHex2
000A8Fr 2               
000A8Fr 2               DisOpZpr:
000A8Fr 2                 ; ZP byte first
000A8Fr 2  A9 24          lda #'$'
000A91r 2  20 rr rr       jsr Chrout
000A94r 2  A0 01          ldy #1
000A96r 2  B1 2E          lda (MON_ADDR),y
000A98r 2  20 rr rr       jsr MonPrintHex2
000A9Br 2  A9 2C          lda #','
000A9Dr 2  20 rr rr       jsr Chrout
000AA0r 2                 ; Branch target = addr + 3 + signed_offset(byte 2)
000AA0r 2  A0 02          ldy #2
000AA2r 2  B1 2E          lda (MON_ADDR),y
000AA4r 2  30 0D          bmi @Neg
000AA6r 2  18             clc
000AA7r 2  65 2E          adc MON_ADDR
000AA9r 2  85 32          sta MON_TMP
000AABr 2  A5 2F          lda MON_ADDR+1
000AADr 2  69 00          adc #0
000AAFr 2  85 33          sta MON_TMP+1
000AB1r 2  80 0B          bra @Add3
000AB3r 2               @Neg:
000AB3r 2  18             clc
000AB4r 2  65 2E          adc MON_ADDR
000AB6r 2  85 32          sta MON_TMP
000AB8r 2  A5 2F          lda MON_ADDR+1
000ABAr 2  69 FF          adc #$FF
000ABCr 2  85 33          sta MON_TMP+1
000ABEr 2               @Add3:
000ABEr 2  18             clc
000ABFr 2  A5 32          lda MON_TMP
000AC1r 2  69 03          adc #3
000AC3r 2  85 32          sta MON_TMP
000AC5r 2  A5 33          lda MON_TMP+1
000AC7r 2  69 00          adc #0
000AC9r 2  85 33          sta MON_TMP+1
000ACBr 2  A9 24          lda #'$'
000ACDr 2  20 rr rr       jsr Chrout
000AD0r 2  A5 33          lda MON_TMP+1
000AD2r 2  20 rr rr       jsr MonPrintHex2
000AD5r 2  A5 32          lda MON_TMP
000AD7r 2  4C rr rr       jmp MonPrintHex2
000ADAr 2               
