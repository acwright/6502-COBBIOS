00219Fr 2               ; Sets Y to byte offset of terminator from current TXTPTR.  Honours quotes.
00219Fr 2               ; ---------------------------------------------------------------------------
00219Fr 2               BasDatan:
00219Fr 2  A2 3A                ldx     #':'
0021A1r 2  2C                   .byte   $2C                     ; BIT abs absorbs next 2-byte LDX
0021A2r 2               BasRemn:
