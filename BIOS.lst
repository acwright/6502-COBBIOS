0007E7r 2  20 rr rr       jsr BasSkipSpaces
0007EAr 2  20 rr rr       jsr BasGetTokChar
0007EDr 2               
0007EDr 2                 ; Check each comparison operator
0007EDr 2  C9 3D          cmp #CH_EQUALS
0007EFr 2  F0 15          beq @CmpEQ
0007F1r 2  C9 3C          cmp #CH_LESS
0007F3r 2  F0 39          beq @CmpLT
0007F5r 2  C9 3E          cmp #CH_GREATER
0007F7r 2  F0 42          beq @CmpGT
0007F9r 2  C9 9C          cmp #TOK_NE
0007FBr 2  F0 1D          beq @CmpNE
0007FDr 2  C9 9B          cmp #TOK_LE
0007FFr 2  F0 49          beq @CmpLE
000801r 2  C9 9A          cmp #TOK_GE
000803r 2  F0 54          beq @CmpGE
