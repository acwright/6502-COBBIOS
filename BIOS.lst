001ED6r 2               
001ED6r 2               
001ED6r 1               .segment "MONITOR"
000000r 1               .include "Monitor.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   MONITOR   ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; Machine Code Monitor — Supermon-style command set
000000r 2               ; Segment: $E800-$FEFF (~6KB)
000000r 2               ;
000000r 2               ; Entry points:
000000r 2               ;   MonitorEntry    ($E800) — Cold entry from boot menu or X return
000000r 2               ;   MonitorBrkEntry ($E803) — BRK entry with register display
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Monitor Constants
000000r 2               ; ============================================================================
000000r 2               
000000r 2               MON_LINBUF          = BAS_LINBUF         ; Share BASIC's line buffer ($0434)
000000r 2               MON_LINBUF_SIZE     = 200                ; Max input line length
000000r 2               MON_PROMPT          = '.'                ; Supermon-style prompt character
000000r 2               
000000r 2               ; Mnemonic Indices (for disassembler)
000000r 2               MN_ADC = 0
000000r 2               MN_AND = 1
000000r 2               MN_ASL = 2
000000r 2               MN_BBR = 3
000000r 2               MN_BBS = 4
000000r 2               MN_BCC = 5
000000r 2               MN_BCS = 6
000000r 2               MN_BEQ = 7
000000r 2               MN_BIT = 8
000000r 2               MN_BMI = 9
000000r 2               MN_BNE = 10
000000r 2               MN_BPL = 11
000000r 2               MN_BRA = 12
000000r 2               MN_BRK = 13
000000r 2               MN_BVC = 14
000000r 2               MN_BVS = 15
000000r 2               MN_CLC = 16
000000r 2               MN_CLD = 17
000000r 2               MN_CLI = 18
000000r 2               MN_CLV = 19
000000r 2               MN_CMP = 20
000000r 2               MN_CPX = 21
000000r 2               MN_CPY = 22
000000r 2               MN_DEC = 23
000000r 2               MN_DEX = 24
000000r 2               MN_DEY = 25
000000r 2               MN_EOR = 26
000000r 2               MN_INC = 27
000000r 2               MN_INX = 28
000000r 2               MN_INY = 29
000000r 2               MN_JMP = 30
000000r 2               MN_JSR = 31
000000r 2               MN_LDA = 32
000000r 2               MN_LDX = 33
000000r 2               MN_LDY = 34
000000r 2               MN_LSR = 35
000000r 2               MN_NOP = 36
000000r 2               MN_ORA = 37
000000r 2               MN_PHA = 38
000000r 2               MN_PHP = 39
000000r 2               MN_PHX = 40
000000r 2               MN_PHY = 41
000000r 2               MN_PLA = 42
000000r 2               MN_PLP = 43
000000r 2               MN_PLX = 44
000000r 2               MN_PLY = 45
000000r 2               MN_RMB = 46
000000r 2               MN_ROL = 47
000000r 2               MN_ROR = 48
000000r 2               MN_RTI = 49
000000r 2               MN_RTS = 50
000000r 2               MN_SBC = 51
000000r 2               MN_SEC = 52
000000r 2               MN_SED = 53
000000r 2               MN_SEI = 54
000000r 2               MN_SMB = 55
000000r 2               MN_STA = 56
000000r 2               MN_STP = 57
000000r 2               MN_STX = 58
000000r 2               MN_STY = 59
000000r 2               MN_STZ = 60
000000r 2               MN_TAX = 61
000000r 2               MN_TAY = 62
000000r 2               MN_TRB = 63
000000r 2               MN_TSB = 64
000000r 2               MN_TSX = 65
000000r 2               MN_TXA = 66
000000r 2               MN_TXS = 67
000000r 2               MN_TYA = 68
000000r 2               MN_WAI = 69
000000r 2               MN_UND = 70
000000r 2               
000000r 2               ; Addressing Mode Indices
000000r 2               AM_IMP = 0
000000r 2               AM_ACC = 1
000000r 2               AM_IMM = 2
000000r 2               AM_ZP  = 3
000000r 2               AM_ZPX = 4
000000r 2               AM_ZPY = 5
000000r 2               AM_ABS = 6
000000r 2               AM_ABX = 7
000000r 2               AM_ABY = 8
000000r 2               AM_IND = 9
000000r 2               AM_IZX = 10
000000r 2               AM_IZY = 11
000000r 2               AM_ZPI = 12
000000r 2               AM_REL = 13
000000r 2               AM_ZPR = 14
000000r 2               AM_AIX = 15
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Entry Points
000000r 2               ; ============================================================================
000000r 2               
000000r 2               MonitorEntry:
000000r 2  4C rr rr       jmp MonColdEntry              ; $E800 - Cold entry (boot menu / return)
000003r 2               
000003r 2               MonitorBrkEntry:
000003r 2  4C rr rr       jmp MonBrkEntry               ; $C003 - BRK entry (register display)
000006r 2               
000006r 2               ; ============================================================================
000006r 2               ; Cold Entry — print banner and enter command loop
000006r 2               ; ============================================================================
000006r 2               
000006r 2               MonColdEntry:
000006r 2  A2 FF          ldx #$FF
000008r 2  9A             txs                           ; Reset stack pointer
000009r 2  D8             cld                           ; Ensure binary mode
00000Ar 2  20 rr rr       jsr VideoClear                ; Clear screen
00000Dr 2  20 rr rr       jsr MonPrintBanner            ; Print "MONITOR" banner
000010r 2  4C rr rr       jmp MonCmdLoop
000013r 2               
000013r 2               ; ============================================================================
000013r 2               ; BRK Entry — print BRK address, display registers, enter command loop
000013r 2               ; ============================================================================
000013r 2               
000013r 2               MonBrkEntry:
000013r 2  A2 FF          ldx #$FF
000015r 2  9A             txs                           ; Reset stack pointer
000016r 2  D8             cld
000017r 2  20 rr rr       jsr VideoClear                ; Clear screen
00001Ar 2  20 rr rr       jsr MonPrintBanner            ; Print "MONITOR" banner
00001Dr 2                 ; Print "BRK AT $"
00001Dr 2  A2 00          ldx #0
00001Fr 2               @BrkMsgLoop:
00001Fr 2  BD rr rr       lda MonStrBrk,x
000022r 2  F0 06          beq @BrkMsgDone
000024r 2  20 rr rr       jsr Chrout
000027r 2  E8             inx
000028r 2  80 F5          bra @BrkMsgLoop
00002Ar 2               @BrkMsgDone:
00002Ar 2                 ; Print PC address (adjusted: BRK_PC points to BRK+2, subtract 2 for actual BRK location)
00002Ar 2  38             sec
00002Br 2  AD 11 03       lda BRK_PCL
00002Er 2  E9 02          sbc #2
000030r 2  85 2E          sta MON_ADDR
000032r 2  AD 12 03       lda BRK_PCH
000035r 2  E9 00          sbc #0
000037r 2  85 2F          sta MON_ADDR + 1
000039r 2  20 rr rr       jsr MonPrintHex4
00003Cr 2  20 rr rr       jsr MonPrintCRLF
00003Fr 2                 ; Display registers
00003Fr 2  20 rr rr       jsr MonShowRegs
000042r 2  4C rr rr       jmp MonCmdLoop
000045r 2               
000045r 2               ; ============================================================================
000045r 2               ; Command Loop — prompt, read, parse, dispatch
000045r 2               ; ============================================================================
000045r 2               
000045r 2               MonCmdLoop:
000045r 2                 ; Print prompt
000045r 2  A9 2E          lda #MON_PROMPT
000047r 2  20 rr rr       jsr Chrout
00004Ar 2  A9 20          lda #' '
00004Cr 2  20 rr rr       jsr Chrout
00004Fr 2               
00004Fr 2                 ; Read input line
00004Fr 2  20 rr rr       jsr MonReadLine
000052r 2               
000052r 2                 ; Parse and dispatch
000052r 2  20 rr rr       jsr MonParseLine
000055r 2               
000055r 2                 ; Loop back for next command
000055r 2  4C rr rr       jmp MonCmdLoop
000058r 2               
000058r 2               ; ============================================================================
000058r 2               ; MonReadLine — Read a line of input into MON_LINBUF
000058r 2               ; Returns: MON_LINBUF contains null-terminated input, Y = length
000058r 2               ; ============================================================================
000058r 2               
000058r 2               MonReadLine:
000058r 2  A0 00          ldy #0                        ; Index into line buffer
00005Ar 2               @ReadWait:
00005Ar 2  20 rr rr       jsr Chrin                     ; Try to read a character (carry set = got one)
00005Dr 2  90 FB          bcc @ReadWait                 ; No char available, keep waiting
00005Fr 2                 ; Got a character in A
00005Fr 2  C9 0D          cmp #$0D                      ; Carriage return?
000061r 2  F0 21          beq @ReadDone
000063r 2  C9 0A          cmp #$0A                      ; Line feed? (treat same as CR)
000065r 2  F0 1D          beq @ReadDone
000067r 2  C9 08          cmp #$08                      ; Backspace?
000069r 2  F0 12          beq @ReadBS
00006Br 2  C9 7F          cmp #$7F                      ; Delete? (treat as backspace)
00006Dr 2  F0 0E          beq @ReadBS
00006Fr 2                 ; Skip non-printable characters ($00-$1F)
00006Fr 2  C9 20          cmp #$20
000071r 2  90 E7          bcc @ReadWait
000073r 2                 ; Printable character — store if room
000073r 2  C0 C8          cpy #MON_LINBUF_SIZE
000075r 2  B0 E3          bcs @ReadWait                 ; Buffer full, ignore
000077r 2  99 34 04       sta MON_LINBUF,y
00007Ar 2  C8             iny
00007Br 2  80 DD          bra @ReadWait
00007Dr 2               @ReadBS:
00007Dr 2  C0 00          cpy #0                        ; Anything to delete?
00007Fr 2  F0 D9          beq @ReadWait                 ; No, ignore
000081r 2  88             dey                           ; Back up one position
000082r 2  80 D6          bra @ReadWait
000084r 2               @ReadDone:
000084r 2  A9 0D          lda #$0D                      ; Echo CR
000086r 2  20 rr rr       jsr Chrout
000089r 2  A9 0A          lda #$0A                      ; Echo LF
00008Br 2  20 rr rr       jsr Chrout
00008Er 2  A9 00          lda #0
000090r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate
000093r 2  60             rts
000094r 2               
000094r 2               ; ============================================================================
000094r 2               ; MonParseLine — Parse first char and dispatch to command handler
000094r 2               ; ============================================================================
000094r 2               
000094r 2               MonParseLine:
000094r 2  64 35          stz MON_IDX                   ; Reset parse index
000096r 2  20 rr rr       jsr MonSkipSpaces             ; Skip leading whitespace
000099r 2  A4 35          ldy MON_IDX
00009Br 2  B9 34 04       lda MON_LINBUF,y              ; Get command character
00009Er 2  F0 2A          beq @ParseDone                ; Empty line — just return
0000A0r 2                 ; Convert to uppercase
0000A0r 2  C9 61          cmp #'a'
0000A2r 2  90 06          bcc @ParseNoConv
0000A4r 2  C9 7B          cmp #'z'+1
0000A6r 2  B0 02          bcs @ParseNoConv
0000A8r 2  29 DF          and #$DF                      ; Convert lowercase to uppercase
0000AAr 2               @ParseNoConv:
0000AAr 2  E6 35          inc MON_IDX                   ; Advance past command char
0000ACr 2                 ; Search dispatch table
0000ACr 2  A2 00          ldx #0
0000AEr 2               @DispatchLoop:
0000AEr 2  BC rr rr       ldy MonCmdTable,x             ; Load command character from table
0000B1r 2  F0 14          beq @ParseError               ; End of table (null terminator) — unknown command
0000B3r 2  DD rr rr       cmp MonCmdTable,x             ; Compare with input character
0000B6r 2  F0 05          beq @DispatchFound
0000B8r 2  E8             inx                           ; Skip char
0000B9r 2  E8             inx                           ; Skip address low
0000BAr 2  E8             inx                           ; Skip address high
0000BBr 2  80 F1          bra @DispatchLoop
0000BDr 2               @DispatchFound:
0000BDr 2  E8             inx                           ; Point to address low byte
0000BEr 2  BD rr rr       lda MonCmdTable+1,x           ; Handler address high byte — push first (big-endian on stack)
0000C1r 2  48             pha
0000C2r 2  BD rr rr       lda MonCmdTable,x             ; Handler address low byte
0000C5r 2  48             pha
0000C6r 2  60             rts                           ; "Return" to handler address (RTS adds 1 to address)
0000C7r 2               @ParseError:
0000C7r 2  20 rr rr       jsr MonPrintError
0000CAr 2               @ParseDone:
0000CAr 2  60             rts
0000CBr 2               
0000CBr 2               ; ============================================================================
0000CBr 2               ; Command Dispatch Table
0000CBr 2               ; Format: command char (1 byte), handler address - 1 (2 bytes, low/high for RTS trick)
0000CBr 2               ; ============================================================================
0000CBr 2               
0000CBr 2               MonCmdTable:
0000CBr 2  58             .byte 'X'
0000CCr 2  rr rr          .word MonCmdX - 1
0000CEr 2  52             .byte 'R'
0000CFr 2  rr rr          .word MonCmdR - 1
0000D1r 2  4D             .byte 'M'
0000D2r 2  rr rr          .word MonCmdM - 1
0000D4r 2  44             .byte 'D'
0000D5r 2  rr rr          .word MonCmdD - 1
0000D7r 2  3E             .byte '>'
0000D8r 2  rr rr          .word MonCmdDeposit - 1
0000DAr 2  46             .byte 'F'
0000DBr 2  rr rr          .word MonCmdFill - 1
0000DDr 2  54             .byte 'T'
0000DEr 2  rr rr          .word MonCmdTransfer - 1
0000E0r 2  48             .byte 'H'
0000E1r 2  rr rr          .word MonCmdHunt - 1
0000E3r 2  43             .byte 'C'
0000E4r 2  rr rr          .word MonCmdCompare - 1
0000E6r 2  47             .byte 'G'
0000E7r 2  rr rr          .word MonCmdGo - 1
0000E9r 2  4A             .byte 'J'
0000EAr 2  rr rr          .word MonCmdJsr - 1
0000ECr 2  3B             .byte ';'
0000EDr 2  rr rr          .word MonCmdModRegs - 1
0000EFr 2  4C             .byte 'L'
0000F0r 2  rr rr          .word MonCmdLoad - 1
0000F2r 2  53             .byte 'S'
0000F3r 2  rr rr          .word MonCmdSave - 1
0000F5r 2  40             .byte '@'
0000F6r 2  rr rr          .word MonCmdDir - 1
0000F8r 2  4E             .byte 'N'
0000F9r 2  rr rr          .word MonCmdNum - 1
0000FBr 2  00             .byte 0                       ; End of table sentinel
0000FCr 2               
0000FCr 2               ; ============================================================================
0000FCr 2               ; MonCmdX — Exit to BASIC
0000FCr 2               ; ============================================================================
0000FCr 2               
0000FCr 2               MonCmdX:
0000FCr 2  20 rr rr       jsr VideoClear                ; Clear screen before entering BASIC
0000FFr 2  4C rr rr       jmp BasColdStart
000102r 2               
000102r 2               ; ============================================================================
000102r 2               ; MonCmdR — Display CPU registers
000102r 2               ; ============================================================================
000102r 2               
000102r 2               MonCmdR:
000102r 2  20 rr rr       jsr MonShowRegs
000105r 2  60             rts
000106r 2               
000106r 2               ; ============================================================================
000106r 2               ; MonCmdDeposit — Deposit (write) bytes to memory
000106r 2               ; Syntax: > ADDR XX [XX XX ...]
000106r 2               ; ============================================================================
000106r 2               
000106r 2               MonCmdDeposit:
000106r 2  20 rr rr       jsr MonSkipSpaces
000109r 2  20 rr rr       jsr MonParseHex4              ; Parse target address into MON_ADDR
00010Cr 2  90 16          bcc @DepError                 ; No address → error
00010Er 2  A0 00          ldy #0                        ; Byte offset from MON_ADDR
000110r 2               @DepLoop:
000110r 2  5A             phy                           ; Save byte offset (Y clobbered by parse routines)
000111r 2  20 rr rr       jsr MonSkipSpaces
000114r 2  20 rr rr       jsr MonParseHex2              ; Parse next byte into A
000117r 2  7A             ply                           ; Restore byte offset (PLY doesn't affect carry)
000118r 2  90 05          bcc @DepDone                  ; No more bytes → done
00011Ar 2  91 2E          sta (MON_ADDR),y
00011Cr 2  C8             iny
00011Dr 2  D0 F1          bne @DepLoop                  ; Up to 256 bytes (Y wraps)
00011Fr 2               @DepDone:
00011Fr 2  C0 00          cpy #0                        ; Did we deposit at least one byte?
000121r 2  F0 01          beq @DepError                 ; No bytes given → error
000123r 2  60             rts
000124r 2               @DepError:
000124r 2  4C rr rr       jmp MonPrintError
000127r 2               
000127r 2               ; ============================================================================
000127r 2               ; MonCmdFill — Fill memory range with a byte value
000127r 2               ; Syntax: F ADDR1 ADDR2 XX
000127r 2               ; ============================================================================
000127r 2               
000127r 2               MonCmdFill:
000127r 2  20 rr rr       jsr MonSkipSpaces
00012Ar 2  20 rr rr       jsr MonParseHex4              ; Parse start address → MON_ADDR
00012Dr 2  90 43          bcc @FillError
00012Fr 2  A5 2E          lda MON_ADDR
000131r 2  85 32          sta MON_TMP
000133r 2  A5 2F          lda MON_ADDR+1
000135r 2  85 33          sta MON_TMP+1                 ; Save start in MON_TMP
000137r 2  20 rr rr       jsr MonSkipSpaces
00013Ar 2  20 rr rr       jsr MonParseHex4              ; Parse end address → MON_ADDR
00013Dr 2  90 33          bcc @FillError
00013Fr 2  A5 2E          lda MON_ADDR
000141r 2  85 30          sta MON_END
000143r 2  A5 2F          lda MON_ADDR+1
000145r 2  85 31          sta MON_END+1                 ; Save end in MON_END
000147r 2                 ; Restore start into MON_ADDR
000147r 2  A5 32          lda MON_TMP
000149r 2  85 2E          sta MON_ADDR
00014Br 2  A5 33          lda MON_TMP+1
00014Dr 2  85 2F          sta MON_ADDR+1
00014Fr 2  20 rr rr       jsr MonSkipSpaces
000152r 2  20 rr rr       jsr MonParseHex2              ; Parse fill byte → A
000155r 2  90 1B          bcc @FillError
000157r 2                 ; A = fill byte, MON_ADDR = start, MON_END = end (inclusive)
000157r 2  A0 00          ldy #0
000159r 2               @FillLoop:
000159r 2  91 2E          sta (MON_ADDR),y
00015Br 2                 ; Check if MON_ADDR == MON_END
00015Br 2  A6 2F          ldx MON_ADDR+1
00015Dr 2  E4 31          cpx MON_END+1
00015Fr 2  D0 06          bne @FillNext
000161r 2  A6 2E          ldx MON_ADDR
000163r 2  E4 30          cpx MON_END
000165r 2  F0 0A          beq @FillDone
000167r 2               @FillNext:
000167r 2                 ; Advance MON_ADDR
000167r 2  48             pha                           ; Save fill byte
000168r 2  E6 2E          inc MON_ADDR
00016Ar 2  D0 02          bne @FillNoHi
00016Cr 2  E6 2F          inc MON_ADDR+1
00016Er 2               @FillNoHi:
00016Er 2  68             pla                           ; Restore fill byte
00016Fr 2  80 E8          bra @FillLoop
000171r 2               @FillDone:
000171r 2  60             rts
000172r 2               @FillError:
000172r 2  4C rr rr       jmp MonPrintError
000175r 2               
000175r 2               ; ============================================================================
000175r 2               ; MonCmdTransfer — Copy memory block (handles overlapping regions)
000175r 2               ; Syntax: T SRC_START SRC_END DEST
000175r 2               ; ============================================================================
000175r 2               
000175r 2               MonCmdTransfer:
000175r 2  20 rr rr       jsr MonSkipSpaces
000178r 2  20 rr rr       jsr MonParseHex4              ; Parse source start → MON_ADDR
00017Br 2  B0 03          bcs @XferGotStart
00017Dr 2  4C rr rr       jmp @XferError                ; No address → error
000180r 2               @XferGotStart:
000180r 2  A5 2E          lda MON_ADDR
000182r 2  85 32          sta MON_TMP
000184r 2  A5 2F          lda MON_ADDR+1
000186r 2  85 33          sta MON_TMP+1                 ; MON_TMP = source start
000188r 2  20 rr rr       jsr MonSkipSpaces
00018Br 2  20 rr rr       jsr MonParseHex4              ; Parse source end → MON_ADDR
00018Er 2  B0 03          bcs @XferGotEnd
000190r 2  4C rr rr       jmp @XferError
000193r 2               @XferGotEnd:
000193r 2  A5 2E          lda MON_ADDR
000195r 2  85 30          sta MON_END
000197r 2  A5 2F          lda MON_ADDR+1
000199r 2  85 31          sta MON_END+1                 ; MON_END = source end (inclusive)
00019Br 2  20 rr rr       jsr MonSkipSpaces
00019Er 2  20 rr rr       jsr MonParseHex4              ; Parse dest → MON_ADDR
0001A1r 2  B0 03          bcs @XferGotDest
0001A3r 2  4C rr rr       jmp @XferError
0001A6r 2               @XferGotDest:
0001A6r 2                 ; MON_ADDR = dest, MON_TMP = src start, MON_END = src end
0001A6r 2                 ; Determine copy direction: if dest > src_start, copy backward to handle overlap
0001A6r 2  A5 2F          lda MON_ADDR+1
0001A8r 2  C5 33          cmp MON_TMP+1
0001AAr 2  90 5C          bcc @CopyForward              ; dest < src → forward is safe
0001ACr 2  D0 08          bne @CopyBackward             ; dest > src → need backward
0001AEr 2  A5 2E          lda MON_ADDR
0001B0r 2  C5 32          cmp MON_TMP
0001B2r 2  90 54          bcc @CopyForward
0001B4r 2  F0 72          beq @XferDone                 ; dest == src → nothing to do
0001B6r 2               @CopyBackward:
0001B6r 2                 ; Compute offset = src_end - src_start
0001B6r 2  38             sec
0001B7r 2  A5 30          lda MON_END
0001B9r 2  E5 32          sbc MON_TMP
0001BBr 2  85 34          sta MON_BYTE                  ; low byte of offset
0001BDr 2  A5 31          lda MON_END+1
0001BFr 2  E5 33          sbc MON_TMP+1
0001C1r 2  85 35          sta MON_IDX                   ; high byte of offset (reuse MON_IDX as scratch)
0001C3r 2                 ; Point MON_TMP to src_end, MON_ADDR to dest + offset
0001C3r 2                 ; MON_TMP already needs to be src_end (currently src_start)
0001C3r 2                 ; Swap: MON_TMP = MON_END (src_end)
0001C3r 2  A5 30          lda MON_END
0001C5r 2  48             pha
0001C6r 2  A5 31          lda MON_END+1
0001C8r 2  48             pha
0001C9r 2                 ; MON_END = src_start (save for later comparison)
0001C9r 2  A5 32          lda MON_TMP
0001CBr 2  85 30          sta MON_END
0001CDr 2  A5 33          lda MON_TMP+1
0001CFr 2  85 31          sta MON_END+1
0001D1r 2                 ; MON_TMP = src_end
0001D1r 2  68             pla
0001D2r 2  85 33          sta MON_TMP+1
0001D4r 2  68             pla
0001D5r 2  85 32          sta MON_TMP
0001D7r 2                 ; dest_end = MON_ADDR + offset
0001D7r 2  18             clc
0001D8r 2  A5 2E          lda MON_ADDR
0001DAr 2  65 34          adc MON_BYTE
0001DCr 2  85 2E          sta MON_ADDR
0001DEr 2  A5 2F          lda MON_ADDR+1
0001E0r 2  65 35          adc MON_IDX
0001E2r 2  85 2F          sta MON_ADDR+1
0001E4r 2               @BackLoop:
0001E4r 2  A0 00          ldy #0
0001E6r 2  B1 32          lda (MON_TMP),y
0001E8r 2  91 2E          sta (MON_ADDR),y
0001EAr 2                 ; Check if MON_TMP == MON_END (src start, our stop address)
0001EAr 2  A5 33          lda MON_TMP+1
0001ECr 2  C5 31          cmp MON_END+1
0001EEr 2  D0 06          bne @BackDec
0001F0r 2  A5 32          lda MON_TMP
0001F2r 2  C5 30          cmp MON_END
0001F4r 2  F0 32          beq @XferDone
0001F6r 2               @BackDec:
0001F6r 2                 ; Decrement both pointers
0001F6r 2  A5 32          lda MON_TMP
0001F8r 2  D0 02          bne @BackDecTmpLo
0001FAr 2  C6 33          dec MON_TMP+1
0001FCr 2               @BackDecTmpLo:
0001FCr 2  C6 32          dec MON_TMP
0001FEr 2  A5 2E          lda MON_ADDR
000200r 2  D0 02          bne @BackDecDstLo
000202r 2  C6 2F          dec MON_ADDR+1
000204r 2               @BackDecDstLo:
000204r 2  C6 2E          dec MON_ADDR
000206r 2  80 DC          bra @BackLoop
000208r 2               
000208r 2               @CopyForward:
000208r 2                 ; Copy from MON_TMP (src) to MON_ADDR (dest), up to MON_END (src end)
000208r 2  A0 00          ldy #0
00020Ar 2               @FwdLoop:
00020Ar 2  B1 32          lda (MON_TMP),y
00020Cr 2  91 2E          sta (MON_ADDR),y
00020Er 2                 ; Check if MON_TMP == MON_END
00020Er 2  A5 33          lda MON_TMP+1
000210r 2  C5 31          cmp MON_END+1
000212r 2  D0 06          bne @FwdNext
000214r 2  A5 32          lda MON_TMP
000216r 2  C5 30          cmp MON_END
000218r 2  F0 0E          beq @XferDone
00021Ar 2               @FwdNext:
00021Ar 2                 ; Advance both pointers
00021Ar 2  E6 32          inc MON_TMP
00021Cr 2  D0 02          bne @FwdNoDstCarry
00021Er 2  E6 33          inc MON_TMP+1
000220r 2               @FwdNoDstCarry:
000220r 2  E6 2E          inc MON_ADDR
000222r 2  D0 E6          bne @FwdLoop
000224r 2  E6 2F          inc MON_ADDR+1
000226r 2  80 E2          bra @FwdLoop
000228r 2               
000228r 2               @XferDone:
000228r 2  60             rts
000229r 2               @XferError:
000229r 2  4C rr rr       jmp MonPrintError
00022Cr 2               
00022Cr 2               ; ============================================================================
00022Cr 2               ; MonCmdHunt — Search for byte pattern in memory range
00022Cr 2               ; Syntax: H ADDR1 ADDR2 XX [XX XX ...]
00022Cr 2               ; Prints address of each match on its own line.
00022Cr 2               ; ============================================================================
00022Cr 2               
00022Cr 2               ; Hunt uses a temp buffer at end of MON_LINBUF area for the pattern.
00022Cr 2               ; Pattern bytes stored at MON_LINBUF+128, max 64 pattern bytes.
00022Cr 2               MON_HUNT_PAT        = MON_LINBUF + 128
00022Cr 2               MON_HUNT_PAT_MAX    = 64
00022Cr 2               
00022Cr 2               MonCmdHunt:
00022Cr 2  20 rr rr       jsr MonSkipSpaces
00022Fr 2  20 rr rr       jsr MonParseHex4              ; Parse start address → MON_ADDR
000232r 2  90 65          bcc @HuntError
000234r 2  A5 2E          lda MON_ADDR
000236r 2  85 32          sta MON_TMP
000238r 2  A5 2F          lda MON_ADDR+1
00023Ar 2  85 33          sta MON_TMP+1                 ; MON_TMP = search start
00023Cr 2  20 rr rr       jsr MonSkipSpaces
00023Fr 2  20 rr rr       jsr MonParseHex4              ; Parse end address → MON_ADDR
000242r 2  90 55          bcc @HuntError
000244r 2  A5 2E          lda MON_ADDR
000246r 2  85 30          sta MON_END
000248r 2  A5 2F          lda MON_ADDR+1
00024Ar 2  85 31          sta MON_END+1                 ; MON_END = search end
00024Cr 2                 ; Restore start
00024Cr 2  A5 32          lda MON_TMP
00024Er 2  85 2E          sta MON_ADDR
000250r 2  A5 33          lda MON_TMP+1
000252r 2  85 2F          sta MON_ADDR+1
000254r 2                 ; Parse pattern bytes into MON_HUNT_PAT
000254r 2  A2 00          ldx #0                        ; Pattern length counter
000256r 2               @HuntParseByte:
000256r 2  DA             phx                           ; Save pattern counter (X clobbered by MonParseHex2)
000257r 2  20 rr rr       jsr MonSkipSpaces
00025Ar 2  20 rr rr       jsr MonParseHex2              ; Next byte → A
00025Dr 2  FA             plx                           ; Restore pattern counter (PLX doesn't affect carry)
00025Er 2  90 0A          bcc @HuntParseEnd
000260r 2  E0 40          cpx #MON_HUNT_PAT_MAX
000262r 2  B0 06          bcs @HuntParseEnd             ; Pattern buffer full
000264r 2  9D B4 04       sta MON_HUNT_PAT,x
000267r 2  E8             inx
000268r 2  80 EC          bra @HuntParseByte
00026Ar 2               @HuntParseEnd:
00026Ar 2  E0 00          cpx #0
00026Cr 2  F0 2B          beq @HuntError                ; No pattern bytes → error
00026Er 2  86 34          stx MON_BYTE                  ; MON_BYTE = pattern length
000270r 2                 ; Search: scan MON_ADDR to MON_END for pattern match
000270r 2               @HuntScanLoop:
000270r 2  A0 00          ldy #0                        ; Pattern match index
000272r 2               @HuntMatchLoop:
000272r 2  B1 2E          lda (MON_ADDR),y
000274r 2  D9 B4 04       cmp MON_HUNT_PAT,y
000277r 2  D0 0B          bne @HuntNoMatch
000279r 2  C8             iny
00027Ar 2  C4 34          cpy MON_BYTE                  ; Matched all pattern bytes?
00027Cr 2  90 F4          bcc @HuntMatchLoop
00027Er 2                 ; Full match — print address
00027Er 2  20 rr rr       jsr MonPrintHex4
000281r 2  20 rr rr       jsr MonPrintCRLF
000284r 2               @HuntNoMatch:
000284r 2                 ; Check if MON_ADDR == MON_END
000284r 2  A5 2F          lda MON_ADDR+1
000286r 2  C5 31          cmp MON_END+1
000288r 2  D0 06          bne @HuntAdvance
00028Ar 2  A5 2E          lda MON_ADDR
00028Cr 2  C5 30          cmp MON_END
00028Er 2  F0 08          beq @HuntDone
000290r 2               @HuntAdvance:
000290r 2  E6 2E          inc MON_ADDR
000292r 2  D0 DC          bne @HuntScanLoop
000294r 2  E6 2F          inc MON_ADDR+1
000296r 2  80 D8          bra @HuntScanLoop
000298r 2               @HuntDone:
000298r 2  60             rts
000299r 2               @HuntError:
000299r 2  4C rr rr       jmp MonPrintError
00029Cr 2               
00029Cr 2               ; ============================================================================
00029Cr 2               ; MonCmdCompare — Compare two memory regions
00029Cr 2               ; Syntax: C ADDR1 ADDR2 ADDR3
00029Cr 2               ; Compares [addr1,addr2] with block at addr3, prints differing addresses.
00029Cr 2               ; ============================================================================
00029Cr 2               
00029Cr 2               MonCmdCompare:
00029Cr 2  20 rr rr       jsr MonSkipSpaces
00029Fr 2  20 rr rr       jsr MonParseHex4              ; Parse addr1 (region1 start) → MON_ADDR
0002A2r 2  90 57          bcc @CmpError
0002A4r 2                 ; Save addr1 on stack
0002A4r 2  A5 2F          lda MON_ADDR+1
0002A6r 2  48             pha
0002A7r 2  A5 2E          lda MON_ADDR
0002A9r 2  48             pha
0002AAr 2  20 rr rr       jsr MonSkipSpaces
0002ADr 2  20 rr rr       jsr MonParseHex4              ; Parse addr2 (region1 end) → MON_ADDR
0002B0r 2  90 47          bcc @CmpErrorPop
0002B2r 2  A5 2E          lda MON_ADDR
0002B4r 2  85 30          sta MON_END
0002B6r 2  A5 2F          lda MON_ADDR+1
0002B8r 2  85 31          sta MON_END+1                 ; MON_END = region1 end (inclusive)
0002BAr 2  20 rr rr       jsr MonSkipSpaces
0002BDr 2  20 rr rr       jsr MonParseHex4              ; Parse addr3 (region2 base) → MON_ADDR
0002C0r 2  90 37          bcc @CmpErrorPop
0002C2r 2  A5 2E          lda MON_ADDR
0002C4r 2  85 32          sta MON_TMP
0002C6r 2  A5 2F          lda MON_ADDR+1
0002C8r 2  85 33          sta MON_TMP+1                 ; MON_TMP = region2 pointer
0002CAr 2                 ; Restore addr1 → MON_ADDR
0002CAr 2  68             pla
0002CBr 2  85 2E          sta MON_ADDR
0002CDr 2  68             pla
0002CEr 2  85 2F          sta MON_ADDR+1
0002D0r 2                 ; Compare loop: [MON_ADDR..MON_END] vs [MON_TMP..]
0002D0r 2  A0 00          ldy #0
0002D2r 2               @CmpLoop:
0002D2r 2  B1 2E          lda (MON_ADDR),y
0002D4r 2  D1 32          cmp (MON_TMP),y
0002D6r 2  F0 06          beq @CmpMatch
0002D8r 2                 ; Mismatch — print addr1 address
0002D8r 2  20 rr rr       jsr MonPrintHex4
0002DBr 2  20 rr rr       jsr MonPrintCRLF
0002DEr 2               @CmpMatch:
0002DEr 2                 ; Check if MON_ADDR == MON_END
0002DEr 2  A5 2F          lda MON_ADDR+1
0002E0r 2  C5 31          cmp MON_END+1
0002E2r 2  D0 06          bne @CmpNext
0002E4r 2  A5 2E          lda MON_ADDR
0002E6r 2  C5 30          cmp MON_END
0002E8r 2  F0 0E          beq @CmpDone
0002EAr 2               @CmpNext:
0002EAr 2                 ; Advance both pointers
0002EAr 2  E6 2E          inc MON_ADDR
0002ECr 2  D0 02          bne @CmpNoHi1
0002EEr 2  E6 2F          inc MON_ADDR+1
0002F0r 2               @CmpNoHi1:
0002F0r 2  E6 32          inc MON_TMP
0002F2r 2  D0 DE          bne @CmpLoop
0002F4r 2  E6 33          inc MON_TMP+1
0002F6r 2  80 DA          bra @CmpLoop
0002F8r 2               @CmpDone:
0002F8r 2  60             rts
0002F9r 2               @CmpErrorPop:
0002F9r 2  68             pla                           ; Clean up stack
0002FAr 2  68             pla
0002FBr 2               @CmpError:
0002FBr 2  4C rr rr       jmp MonPrintError
0002FEr 2               
0002FEr 2               ; ============================================================================
0002FEr 2               ; MonCmdGo — Go (JMP to address with full register restore via RTI)
0002FEr 2               ; Syntax: G [addr]
0002FEr 2               ; If addr given, sets BRK_PCL/PCH. Restores A, X, Y, P, SP via RTI.
0002FEr 2               ; Program runs until BRK returns to monitor or forever.
0002FEr 2               ; ============================================================================
0002FEr 2               
0002FEr 2               MonCmdGo:
0002FEr 2  20 rr rr       jsr MonSkipSpaces
000301r 2  20 rr rr       jsr MonParseHex4
000304r 2  90 0A          bcc @GoNoAddr
000306r 2                 ; Address given — store to BRK_PCL/PCH
000306r 2  A5 2E          lda MON_ADDR
000308r 2  8D 11 03       sta BRK_PCL
00030Br 2  A5 2F          lda MON_ADDR+1
00030Dr 2  8D 12 03       sta BRK_PCH
000310r 2               @GoNoAddr:
000310r 2  78             sei                           ; Disable interrupts during stack manipulation
000311r 2                 ; Restore user's stack pointer
000311r 2                 ; BRK_SP = SP at Break entry (user's original SP - 3 from BRK hardware push)
000311r 2                 ; We need SP = BRK_SP + 3 before our pushes, so RTI leaves SP at original
000311r 2  AE 16 03       ldx BRK_SP
000314r 2  E8             inx
000315r 2  E8             inx
000316r 2  E8             inx
000317r 2  9A             txs                           ; SP = user's original SP
000318r 2                 ; Push PCH, PCL, P for RTI (RTI pops P first, then PCL, PCH)
000318r 2  AD 12 03       lda BRK_PCH
00031Br 2  48             pha
00031Cr 2  AD 11 03       lda BRK_PCL
00031Fr 2  48             pha
000320r 2  AD 10 03       lda BRK_P
000323r 2  48             pha
000324r 2                 ; Restore registers
000324r 2  AC 15 03       ldy BRK_Y
000327r 2  AE 14 03       ldx BRK_X
00032Ar 2  AD 13 03       lda BRK_A
00032Dr 2  40             rti                           ; Pop P, PC → jump to target with full register state
00032Er 2               
00032Er 2               ; ============================================================================
00032Er 2               ; MonCmdJsr — Call subroutine and return to monitor on RTS
00032Er 2               ; Syntax: J [addr]
00032Er 2               ; Pushes monitor return address, restores A/X/Y, JMPs to target.
00032Er 2               ; When target does RTS, saves registers and re-enters monitor.
00032Er 2               ; ============================================================================
00032Er 2               
00032Er 2               MonCmdJsr:
00032Er 2  20 rr rr       jsr MonSkipSpaces
000331r 2  20 rr rr       jsr MonParseHex4
000334r 2  90 0A          bcc @JsrNoAddr
000336r 2                 ; Address given — store to BRK_PCL/PCH
000336r 2  A5 2E          lda MON_ADDR
000338r 2  8D 11 03       sta BRK_PCL
00033Br 2  A5 2F          lda MON_ADDR+1
00033Dr 2  8D 12 03       sta BRK_PCH
000340r 2               @JsrNoAddr:
000340r 2                 ; Push return address (MonJsrReturn - 1) for RTS trick
000340r 2  A9 rr          lda #>(MonJsrReturn - 1)
000342r 2  48             pha
000343r 2  A9 rr          lda #<(MonJsrReturn - 1)
000345r 2  48             pha
000346r 2                 ; Restore registers as inputs to subroutine
000346r 2  AC 15 03       ldy BRK_Y
000349r 2  AE 14 03       ldx BRK_X
00034Cr 2  AD 13 03       lda BRK_A
00034Fr 2  6C 11 03       jmp (BRK_PCL)                 ; Jump to target — its RTS returns to MonJsrReturn
000352r 2               
000352r 2               ; MonJsrReturn — Landing point when user's subroutine does RTS
000352r 2               MonJsrReturn:
000352r 2  8D 13 03       sta BRK_A                     ; Save returned A
000355r 2  8E 14 03       stx BRK_X                    ; Save returned X
000358r 2  8C 15 03       sty BRK_Y                    ; Save returned Y
00035Br 2  08             php                           ; Push current P
00035Cr 2  68             pla
00035Dr 2  8D 10 03       sta BRK_P                    ; Save processor status
000360r 2  BA             tsx
000361r 2  8E 16 03       stx BRK_SP                   ; Save current stack pointer
000364r 2                 ; Show registers and re-enter command loop
000364r 2  20 rr rr       jsr MonShowRegs
000367r 2  4C rr rr       jmp MonCmdLoop
00036Ar 2               
00036Ar 2               ; ============================================================================
00036Ar 2               ; MonCmdModRegs — Modify saved CPU registers
00036Ar 2               ; Syntax: ; PC xxxx A xx X xx Y xx SP xx P xx
00036Ar 2               ; Any subset, any order. Labels: PC, A, X, Y, SP, P
00036Ar 2               ; ============================================================================
00036Ar 2               
00036Ar 2               MonCmdModRegs:
00036Ar 2               @ModLoop:
00036Ar 2  20 rr rr       jsr MonSkipSpaces
00036Dr 2  A4 35          ldy MON_IDX
00036Fr 2  B9 34 04       lda MON_LINBUF,y
000372r 2  D0 03          bne @ModNotEnd
000374r 2  4C rr rr       jmp @ModDone                  ; End of line — trampoline (too far for beq)
000377r 2               @ModNotEnd:
000377r 2                 ; Convert to uppercase
000377r 2  C9 61          cmp #'a'
000379r 2  90 06          bcc @ModNoConv
00037Br 2  C9 7B          cmp #'z'+1
00037Dr 2  B0 02          bcs @ModNoConv
00037Fr 2  29 DF          and #$DF
000381r 2               @ModNoConv:
000381r 2  C9 50          cmp #'P'
000383r 2  F0 13          beq @ModCheckPCorP
000385r 2  C9 41          cmp #'A'
000387r 2  F0 4F          beq @ModA
000389r 2  C9 58          cmp #'X'
00038Br 2  F0 5E          beq @ModX
00038Dr 2  C9 59          cmp #'Y'
00038Fr 2  F0 6D          beq @ModY
000391r 2  C9 53          cmp #'S'
000393r 2  F0 7C          beq @ModCheckSP
000395r 2  4C rr rr       jmp @ModError                 ; Unknown label — trampoline (too far for bra)
000398r 2               
000398r 2               @ModCheckPCorP:
000398r 2                 ; Could be "PC" (program counter) or "P" (processor status)
000398r 2  E6 35          inc MON_IDX
00039Ar 2  A4 35          ldy MON_IDX
00039Cr 2  B9 34 04       lda MON_LINBUF,y
00039Fr 2                 ; Convert to uppercase
00039Fr 2  C9 61          cmp #'a'
0003A1r 2  90 06          bcc @ModPCNoConv
0003A3r 2  C9 7B          cmp #'z'+1
0003A5r 2  B0 02          bcs @ModPCNoConv
0003A7r 2  29 DF          and #$DF
0003A9r 2               @ModPCNoConv:
0003A9r 2  C9 43          cmp #'C'
0003ABr 2  F0 11          beq @ModPC
0003ADr 2                 ; It's just 'P' (processor status) — don't advance past the non-'C' char
0003ADr 2  20 rr rr       jsr MonSkipSpaces
0003B0r 2  20 rr rr       jsr MonParseHex2
0003B3r 2  B0 03          bcs @ModPOk
0003B5r 2  4C rr rr       jmp @ModError
0003B8r 2               @ModPOk:
0003B8r 2  8D 10 03       sta BRK_P
0003BBr 2  4C rr rr       jmp @ModLoop
0003BEr 2               
0003BEr 2               @ModPC:
0003BEr 2  E6 35          inc MON_IDX                   ; Advance past 'C'
0003C0r 2  20 rr rr       jsr MonSkipSpaces
0003C3r 2  20 rr rr       jsr MonParseHex4
0003C6r 2  B0 03          bcs @ModPCOk
0003C8r 2  4C rr rr       jmp @ModError
0003CBr 2               @ModPCOk:
0003CBr 2  A5 2E          lda MON_ADDR
0003CDr 2  8D 11 03       sta BRK_PCL
0003D0r 2  A5 2F          lda MON_ADDR+1
0003D2r 2  8D 12 03       sta BRK_PCH
0003D5r 2  4C rr rr       jmp @ModLoop
0003D8r 2               
0003D8r 2               @ModA:
0003D8r 2  E6 35          inc MON_IDX                   ; Advance past 'A'
0003DAr 2  20 rr rr       jsr MonSkipSpaces
0003DDr 2  20 rr rr       jsr MonParseHex2
0003E0r 2  B0 03          bcs @ModAOk
0003E2r 2  4C rr rr       jmp @ModError
0003E5r 2               @ModAOk:
0003E5r 2  8D 13 03       sta BRK_A
0003E8r 2  4C rr rr       jmp @ModLoop
0003EBr 2               
0003EBr 2               @ModX:
0003EBr 2  E6 35          inc MON_IDX                   ; Advance past 'X'
0003EDr 2  20 rr rr       jsr MonSkipSpaces
0003F0r 2  20 rr rr       jsr MonParseHex2
0003F3r 2  B0 03          bcs @ModXOk
0003F5r 2  4C rr rr       jmp @ModError
0003F8r 2               @ModXOk:
0003F8r 2  8D 14 03       sta BRK_X
0003FBr 2  4C rr rr       jmp @ModLoop
0003FEr 2               
0003FEr 2               @ModY:
0003FEr 2  E6 35          inc MON_IDX                   ; Advance past 'Y'
000400r 2  20 rr rr       jsr MonSkipSpaces
000403r 2  20 rr rr       jsr MonParseHex2
000406r 2  B0 03          bcs @ModYOk
000408r 2  4C rr rr       jmp @ModError
00040Br 2               @ModYOk:
00040Br 2  8D 15 03       sta BRK_Y
00040Er 2  4C rr rr       jmp @ModLoop
000411r 2               
000411r 2               @ModCheckSP:
000411r 2                 ; Expect "SP" — must see 'P' next
000411r 2  E6 35          inc MON_IDX
000413r 2  A4 35          ldy MON_IDX
000415r 2  B9 34 04       lda MON_LINBUF,y
000418r 2  C9 50          cmp #'P'
00041Ar 2  F0 07          beq @ModSPGotP
00041Cr 2  C9 70          cmp #'p'
00041Er 2  F0 03          beq @ModSPGotP
000420r 2  4C rr rr       jmp @ModError                 ; Just 'S' alone is invalid
000423r 2               @ModSPGotP:
000423r 2  E6 35          inc MON_IDX                   ; Advance past 'P'
000425r 2  20 rr rr       jsr MonSkipSpaces
000428r 2  20 rr rr       jsr MonParseHex2
00042Br 2  B0 03          bcs @ModSPOk
00042Dr 2  4C rr rr       jmp @ModError
000430r 2               @ModSPOk:
000430r 2  8D 16 03       sta BRK_SP
000433r 2  4C rr rr       jmp @ModLoop
000436r 2               
000436r 2               @ModError:
000436r 2  4C rr rr       jmp MonPrintError
000439r 2               @ModDone:
000439r 2                 ; Display updated registers
000439r 2  20 rr rr       jsr MonShowRegs
00043Cr 2  60             rts
00043Dr 2               
00043Dr 2               ; ============================================================================
00043Dr 2               ; MonCmdDir — Display CF directory listing
00043Dr 2               ; Syntax: @
00043Dr 2               ; ============================================================================
00043Dr 2               
00043Dr 2               MonCmdDir:
00043Dr 2  20 rr rr       jsr FsDirectory
000440r 2  60             rts
000441r 2               
000441r 2               ; ============================================================================
000441r 2               ; MonCmdNum — Number base conversion
000441r 2               ; Syntax: N $XXXX  or  N +DDDDD  or  N %BBBBBBBBBBBBBBBB
000441r 2               ; Output: $XXXX  +DDDDD  %BBBBBBBBBBBBBBBB
000441r 2               ; ============================================================================
000441r 2               
000441r 2               MonCmdNum:
000441r 2  20 rr rr       jsr MonSkipSpaces
000444r 2  A4 35          ldy MON_IDX
000446r 2  B9 34 04       lda MON_LINBUF,y
000449r 2  C9 24          cmp #'$'
00044Br 2  F0 0A          beq @NumHex
00044Dr 2  C9 2B          cmp #'+'
00044Fr 2  F0 10          beq @NumDec
000451r 2  C9 25          cmp #'%'
000453r 2  F0 16          beq @NumBin
000455r 2                 ; Default: try hex (no prefix)
000455r 2  80 02          bra @NumHexDirect
000457r 2               @NumHex:
000457r 2  E6 35          inc MON_IDX                   ; Skip '$'
000459r 2               @NumHexDirect:
000459r 2  20 rr rr       jsr MonParseHex4
00045Cr 2  B0 17          bcs @NumPrint
00045Er 2  4C rr rr       jmp MonPrintError
000461r 2               @NumDec:
000461r 2  E6 35          inc MON_IDX                   ; Skip '+'
000463r 2  20 rr rr       jsr MonParseDec16
000466r 2  B0 0D          bcs @NumPrint
000468r 2  4C rr rr       jmp MonPrintError
00046Br 2               @NumBin:
00046Br 2  E6 35          inc MON_IDX                   ; Skip '%'
00046Dr 2  20 rr rr       jsr MonParseBin16
000470r 2  B0 03          bcs @NumPrint
000472r 2  4C rr rr       jmp MonPrintError
000475r 2               @NumPrint:
000475r 2                 ; Value is in MON_ADDR
000475r 2  A9 24          lda #'$'
000477r 2  20 rr rr       jsr Chrout
00047Ar 2  20 rr rr       jsr MonPrintHex4
00047Dr 2  20 rr rr       jsr MonPrintSpace
000480r 2  20 rr rr       jsr MonPrintSpace
000483r 2  A9 2B          lda #'+'
000485r 2  20 rr rr       jsr Chrout
000488r 2  20 rr rr       jsr MonPrintDec16
00048Br 2  20 rr rr       jsr MonPrintSpace
00048Er 2  20 rr rr       jsr MonPrintSpace
000491r 2  A9 25          lda #'%'
000493r 2  20 rr rr       jsr Chrout
000496r 2  20 rr rr       jsr MonPrintBin16
000499r 2  20 rr rr       jsr MonPrintCRLF
00049Cr 2  60             rts
00049Dr 2               
00049Dr 2               ; ============================================================================
00049Dr 2               ; MonCmdLoad — Load from CF (with quoted filename) or serial (without)
00049Dr 2               ; Syntax: L ["FILE"] [ADDR]
00049Dr 2               ; CF path:     L "FILENAME" [ADDR] — load file to addr (default $0800)
00049Dr 2               ; Serial path: L [ADDR]            — receive binary to addr (default $0800)
00049Dr 2               ; ============================================================================
00049Dr 2               
00049Dr 2               MonCmdLoad:
00049Dr 2  20 rr rr       jsr MonSkipSpaces
0004A0r 2  A4 35          ldy MON_IDX
0004A2r 2  B9 34 04       lda MON_LINBUF,y
0004A5r 2  C9 22          cmp #'"'
0004A7r 2  D0 03          bne @LoadSerial
0004A9r 2  4C rr rr       jmp @LoadCF
0004ACr 2               
0004ACr 2                 ; --- Serial path ---
0004ACr 2               @LoadSerial:
0004ACr 2  20 rr rr       jsr MonParseHex4              ; Optional address
0004AFr 2  90 0A          bcc @LoadSerDefault
0004B1r 2                 ; Got address
0004B1r 2  A5 2E          lda MON_ADDR
0004B3r 2  85 2A          sta XFER_PTR
0004B5r 2  A5 2F          lda MON_ADDR+1
0004B7r 2  85 2B          sta XFER_PTR+1
0004B9r 2  80 08          bra @LoadSerStart
0004BBr 2               @LoadSerDefault:
0004BBr 2  A9 00          lda #<PROGRAM_START
0004BDr 2  85 2A          sta XFER_PTR
0004BFr 2  A9 08          lda #>PROGRAM_START
0004C1r 2  85 2B          sta XFER_PTR+1
0004C3r 2               @LoadSerStart:
0004C3r 2                 ; Save load address for success message
0004C3r 2  A5 2A          lda XFER_PTR
0004C5r 2  85 30          sta MON_END
0004C7r 2  A5 2B          lda XFER_PTR+1
0004C9r 2  85 31          sta MON_END+1
0004CBr 2                 ; Switch to serial I/O
0004CBr 2  AD 06 03       lda IO_MODE
0004CEr 2  8D 19 03       sta XFER_IO_SAVE
0004D1r 2  A9 01          lda #$01
0004D3r 2  8D 06 03       sta IO_MODE
0004D6r 2                 ; Print "READY TO RECEIVE" via serial
0004D6r 2  A9 rr          lda #<MonStrReady
0004D8r 2  85 02          sta STR_PTR
0004DAr 2  A9 rr          lda #>MonStrReady
0004DCr 2  85 03          sta STR_PTR+1
0004DEr 2  20 rr rr       jsr MonSerialPrintStr
0004E1r 2                 ; Read 2-byte size (lo/hi)
0004E1r 2               @SerWaitSzLo:
0004E1r 2  20 rr rr       jsr BufferSize
0004E4r 2  F0 FB          beq @SerWaitSzLo
0004E6r 2  20 rr rr       jsr ReadBuffer
0004E9r 2  8D 17 03       sta XFER_REMAIN
0004ECr 2               @SerWaitSzHi:
0004ECr 2  20 rr rr       jsr BufferSize
0004EFr 2  F0 FB          beq @SerWaitSzHi
0004F1r 2  20 rr rr       jsr ReadBuffer
0004F4r 2  8D 18 03       sta XFER_REMAIN+1
0004F7r 2                 ; Check for zero-length
0004F7r 2  AD 17 03       lda XFER_REMAIN
0004FAr 2  0D 18 03       ora XFER_REMAIN+1
0004FDr 2  F0 25          beq @LoadSerOk
0004FFr 2                 ; Receive data bytes
0004FFr 2  A0 00          ldy #0
000501r 2               @LoadSerByte:
000501r 2  20 rr rr       jsr BufferSize
000504r 2  F0 FB          beq @LoadSerByte
000506r 2  20 rr rr       jsr ReadBuffer
000509r 2  91 2A          sta (XFER_PTR),y
00050Br 2  E6 2A          inc XFER_PTR
00050Dr 2  D0 02          bne @LoadSerNoPage
00050Fr 2  E6 2B          inc XFER_PTR+1
000511r 2               @LoadSerNoPage:
000511r 2  AD 17 03       lda XFER_REMAIN
000514r 2  D0 03          bne @LoadSerDecLo
000516r 2  CE 18 03       dec XFER_REMAIN+1
000519r 2               @LoadSerDecLo:
000519r 2  CE 17 03       dec XFER_REMAIN
00051Cr 2  AD 17 03       lda XFER_REMAIN
00051Fr 2  0D 18 03       ora XFER_REMAIN+1
000522r 2  D0 DD          bne @LoadSerByte
000524r 2               @LoadSerOk:
000524r 2                 ; Restore IO_MODE
000524r 2  AD 19 03       lda XFER_IO_SAVE
000527r 2  8D 06 03       sta IO_MODE
00052Ar 2                 ; Calculate bytes loaded = XFER_PTR - MON_END
00052Ar 2  38             sec
00052Br 2  A5 2A          lda XFER_PTR
00052Dr 2  E5 30          sbc MON_END
00052Fr 2  85 2E          sta MON_ADDR
000531r 2  A5 2B          lda XFER_PTR+1
000533r 2  E5 31          sbc MON_END+1
000535r 2  85 2F          sta MON_ADDR+1
000537r 2  20 rr rr       jsr MonPrintLoaded            ; Print "LOADED nnnn BYTES AT $xxxx"
00053Ar 2  60             rts
00053Br 2               
00053Br 2                 ; --- CF path ---
00053Br 2               @LoadCF:
00053Br 2  E6 35          inc MON_IDX                   ; Skip opening quote
00053Dr 2                 ; Point STR_PTR into line buffer at the filename
00053Dr 2  A4 35          ldy MON_IDX
00053Fr 2  98             tya
000540r 2  18             clc
000541r 2  69 34          adc #<MON_LINBUF
000543r 2  85 02          sta STR_PTR
000545r 2  A9 04          lda #>MON_LINBUF
000547r 2  69 00          adc #0
000549r 2  85 03          sta STR_PTR+1
00054Br 2                 ; Find closing quote and null-terminate
00054Br 2               @LoadCFFindQ:
00054Br 2  B9 34 04       lda MON_LINBUF,y
00054Er 2  F0 0D          beq @LoadCFQDone              ; End of line — use as-is
000550r 2  C9 22          cmp #'"'
000552r 2  F0 03          beq @LoadCFGotQ
000554r 2  C8             iny
000555r 2  80 F4          bra @LoadCFFindQ
000557r 2               @LoadCFGotQ:
000557r 2  A9 00          lda #0
000559r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate at closing quote
00055Cr 2  C8             iny                           ; Advance past closing quote
00055Dr 2               @LoadCFQDone:
00055Dr 2  84 35          sty MON_IDX
00055Fr 2                 ; Parse filename into FS_FNAME_BUF
00055Fr 2  20 rr rr       jsr FsParseName
000562r 2                 ; Read directory
000562r 2  20 rr rr       jsr FsReadDir
000565r 2  90 03          bcc @LoadCFReadOk
000567r 2  4C rr rr       jmp @LoadCFErr
00056Ar 2               @LoadCFReadOk:
00056Ar 2                 ; Find file
00056Ar 2  20 rr rr       jsr FsFindFile
00056Dr 2  90 03          bcc @LoadCFFound
00056Fr 2  4C rr rr       jmp @LoadCFNotFound
000572r 2               @LoadCFFound:
000572r 2                 ; Read file metadata
000572r 2  A0 0C          ldy #FS_ENTRY_START
000574r 2  B1 24          lda (CF_BUF_PTR),y
000576r 2  8D 48 03       sta FS_START_SEC
000579r 2  C8             iny
00057Ar 2  B1 24          lda (CF_BUF_PTR),y
00057Cr 2  8D 49 03       sta FS_START_SEC+1
00057Fr 2  A0 0E          ldy #FS_ENTRY_FSIZE
000581r 2  B1 24          lda (CF_BUF_PTR),y
000583r 2  8D 4A 03       sta FS_FILE_SIZE
000586r 2  C8             iny
000587r 2  B1 24          lda (CF_BUF_PTR),y
000589r 2  8D 4B 03       sta FS_FILE_SIZE+1
00058Cr 2                 ; Calculate sector count = ceil(size / 512)
00058Cr 2  AD 4B 03       lda FS_FILE_SIZE+1
00058Fr 2  4A             lsr a
000590r 2  8D 4C 03       sta FS_SEC_COUNT
000593r 2  AD 4B 03       lda FS_FILE_SIZE+1
000596r 2  29 01          and #$01
000598r 2  D0 05          bne @LoadCFRound
00059Ar 2  AD 4A 03       lda FS_FILE_SIZE
00059Dr 2  F0 03          beq @LoadCFNoRound
00059Fr 2               @LoadCFRound:
00059Fr 2  EE 4C 03       inc FS_SEC_COUNT
0005A2r 2               @LoadCFNoRound:
0005A2r 2                 ; Parse optional load address
0005A2r 2  20 rr rr       jsr MonSkipSpaces
0005A5r 2  20 rr rr       jsr MonParseHex4
0005A8r 2  90 0A          bcc @LoadCFDefAddr
0005AAr 2                 ; Got address — use it
0005AAr 2  A5 2E          lda MON_ADDR
0005ACr 2  85 24          sta CF_BUF_PTR
0005AEr 2  A5 2F          lda MON_ADDR+1
0005B0r 2  85 25          sta CF_BUF_PTR+1
0005B2r 2  80 08          bra @LoadCFSetLBA
0005B4r 2               @LoadCFDefAddr:
0005B4r 2  A9 00          lda #<PROGRAM_START
0005B6r 2  85 24          sta CF_BUF_PTR
0005B8r 2  A9 08          lda #>PROGRAM_START
0005BAr 2  85 25          sta CF_BUF_PTR+1
0005BCr 2               @LoadCFSetLBA:
0005BCr 2                 ; Save load base address for message
0005BCr 2  A5 24          lda CF_BUF_PTR
0005BEr 2  85 30          sta MON_END
0005C0r 2  A5 25          lda CF_BUF_PTR+1
0005C2r 2  85 31          sta MON_END+1
0005C4r 2                 ; Set up LBA
0005C4r 2  AD 48 03       lda FS_START_SEC
0005C7r 2  85 26          sta CF_LBA
0005C9r 2  AD 49 03       lda FS_START_SEC+1
0005CCr 2  85 27          sta CF_LBA+1
0005CEr 2  64 28          stz CF_LBA+2
0005D0r 2  64 29          stz CF_LBA+3
0005D2r 2                 ; Read sectors
0005D2r 2  AE 4C 03       ldx FS_SEC_COUNT
0005D5r 2  F0 10          beq @LoadCFOk
0005D7r 2               @LoadCFSec:
0005D7r 2  DA             phx
0005D8r 2  20 rr rr       jsr StReadSector              ; Reads 512 bytes, advances CF_BUF_PTR
0005DBr 2  B0 18          bcs @LoadCFSecErr
0005DDr 2  E6 26          inc CF_LBA
0005DFr 2  D0 02          bne @LoadCFSecNext
0005E1r 2  E6 27          inc CF_LBA+1
0005E3r 2               @LoadCFSecNext:
0005E3r 2  FA             plx
0005E4r 2  CA             dex
0005E5r 2  D0 F0          bne @LoadCFSec
0005E7r 2               @LoadCFOk:
0005E7r 2                 ; Print success
0005E7r 2  AD 4A 03       lda FS_FILE_SIZE
0005EAr 2  85 2E          sta MON_ADDR
0005ECr 2  AD 4B 03       lda FS_FILE_SIZE+1
0005EFr 2  85 2F          sta MON_ADDR+1
0005F1r 2  20 rr rr       jsr MonPrintLoaded            ; Print "LOADED nnnn BYTES AT $xxxx"
0005F4r 2  60             rts
0005F5r 2               @LoadCFSecErr:
0005F5r 2  FA             plx                           ; Balance stack
0005F6r 2               @LoadCFErr:
0005F6r 2  20 rr rr       jsr MonPrintIOErr
0005F9r 2  60             rts
0005FAr 2               @LoadCFNotFound:
0005FAr 2  A2 00          ldx #0
0005FCr 2               @LoadCFNFLoop:
0005FCr 2  BD rr rr       lda MonStrNotFound,x
0005FFr 2  F0 06          beq @LoadCFNFDone
000601r 2  20 rr rr       jsr Chrout
000604r 2  E8             inx
000605r 2  80 F5          bra @LoadCFNFLoop
000607r 2               @LoadCFNFDone:
000607r 2  20 rr rr       jsr MonPrintCRLF
00060Ar 2  60             rts
00060Br 2               
00060Br 2               ; ============================================================================
00060Br 2               ; MonCmdSave — Save to CF (with quoted filename) or serial (without)
00060Br 2               ; Syntax: S ["FILE"] ADDR1 ADDR2
00060Br 2               ; CF path:     S "FILENAME" ADDR1 ADDR2 — save [addr1,addr2) to file
00060Br 2               ; Serial path: S ADDR1 ADDR2            — send [addr1,addr2) via serial
00060Br 2               ; ============================================================================
00060Br 2               
00060Br 2               MonCmdSave:
00060Br 2  20 rr rr       jsr MonSkipSpaces
00060Er 2  A4 35          ldy MON_IDX
000610r 2  B9 34 04       lda MON_LINBUF,y
000613r 2  C9 22          cmp #'"'
000615r 2  D0 03          bne @SaveSerial
000617r 2  4C rr rr       jmp @SaveCF
00061Ar 2               
00061Ar 2                 ; --- Serial path ---
00061Ar 2               @SaveSerial:
00061Ar 2  20 rr rr       jsr MonParseHex4              ; Parse start address
00061Dr 2  B0 03          bcs @SaveSerGotStart
00061Fr 2  4C rr rr       jmp @SaveError
000622r 2               @SaveSerGotStart:
000622r 2  A5 2E          lda MON_ADDR
000624r 2  85 2A          sta XFER_PTR
000626r 2  A5 2F          lda MON_ADDR+1
000628r 2  85 2B          sta XFER_PTR+1
00062Ar 2  20 rr rr       jsr MonSkipSpaces
00062Dr 2  20 rr rr       jsr MonParseHex4              ; Parse end address
000630r 2  B0 03          bcs @SaveSerGotEnd
000632r 2  4C rr rr       jmp @SaveError
000635r 2               @SaveSerGotEnd:
000635r 2                 ; Calculate size = end - start
000635r 2  38             sec
000636r 2  A5 2E          lda MON_ADDR
000638r 2  E5 2A          sbc XFER_PTR
00063Ar 2  8D 17 03       sta XFER_REMAIN
00063Dr 2  A5 2F          lda MON_ADDR+1
00063Fr 2  E5 2B          sbc XFER_PTR+1
000641r 2  8D 18 03       sta XFER_REMAIN+1
000644r 2                 ; Save size for message
000644r 2  AD 17 03       lda XFER_REMAIN
000647r 2  85 30          sta MON_END
000649r 2  AD 18 03       lda XFER_REMAIN+1
00064Cr 2  85 31          sta MON_END+1
00064Er 2                 ; Switch to serial I/O
00064Er 2  AD 06 03       lda IO_MODE
000651r 2  8D 19 03       sta XFER_IO_SAVE
000654r 2  A9 01          lda #$01
000656r 2  8D 06 03       sta IO_MODE
000659r 2                 ; Send 2-byte size (lo/hi)
000659r 2  AD 17 03       lda XFER_REMAIN
00065Cr 2  20 rr rr       jsr SerialChrout
00065Fr 2  AD 18 03       lda XFER_REMAIN+1
000662r 2  20 rr rr       jsr SerialChrout
000665r 2                 ; Check for zero-length
000665r 2  AD 17 03       lda XFER_REMAIN
000668r 2  0D 18 03       ora XFER_REMAIN+1
00066Br 2  F0 20          beq @SaveSerDone
00066Dr 2                 ; Send data bytes
00066Dr 2  A0 00          ldy #0
00066Fr 2               @SaveSerByte:
00066Fr 2  B1 2A          lda (XFER_PTR),y
000671r 2  20 rr rr       jsr SerialChrout
000674r 2  E6 2A          inc XFER_PTR
000676r 2  D0 02          bne @SaveSerNoPage
000678r 2  E6 2B          inc XFER_PTR+1
00067Ar 2               @SaveSerNoPage:
00067Ar 2  AD 17 03       lda XFER_REMAIN
00067Dr 2  D0 03          bne @SaveSerDecLo
00067Fr 2  CE 18 03       dec XFER_REMAIN+1
000682r 2               @SaveSerDecLo:
000682r 2  CE 17 03       dec XFER_REMAIN
000685r 2  AD 17 03       lda XFER_REMAIN
000688r 2  0D 18 03       ora XFER_REMAIN+1
00068Br 2  D0 E2          bne @SaveSerByte
00068Dr 2               @SaveSerDone:
00068Dr 2                 ; Restore IO_MODE
00068Dr 2  AD 19 03       lda XFER_IO_SAVE
000690r 2  8D 06 03       sta IO_MODE
000693r 2                 ; Print "SAVED nnnn BYTES"
000693r 2  A5 30          lda MON_END
000695r 2  85 2E          sta MON_ADDR
000697r 2  A5 31          lda MON_END+1
000699r 2  85 2F          sta MON_ADDR+1
00069Br 2  20 rr rr       jsr MonPrintSaved
00069Er 2  60             rts
00069Fr 2               
00069Fr 2                 ; --- CF path ---
00069Fr 2               @SaveCF:
00069Fr 2  E6 35          inc MON_IDX                   ; Skip opening quote
0006A1r 2                 ; Point STR_PTR into line buffer at the filename
0006A1r 2  A4 35          ldy MON_IDX
0006A3r 2  98             tya
0006A4r 2  18             clc
0006A5r 2  69 34          adc #<MON_LINBUF
0006A7r 2  85 02          sta STR_PTR
0006A9r 2  A9 04          lda #>MON_LINBUF
0006ABr 2  69 00          adc #0
0006ADr 2  85 03          sta STR_PTR+1
0006AFr 2                 ; Find closing quote and null-terminate
0006AFr 2               @SaveCFFindQ:
0006AFr 2  B9 34 04       lda MON_LINBUF,y
0006B2r 2  F0 0D          beq @SaveCFQDone
0006B4r 2  C9 22          cmp #'"'
0006B6r 2  F0 03          beq @SaveCFGotQ
0006B8r 2  C8             iny
0006B9r 2  80 F4          bra @SaveCFFindQ
0006BBr 2               @SaveCFGotQ:
0006BBr 2  A9 00          lda #0
0006BDr 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate at closing quote
0006C0r 2  C8             iny
0006C1r 2               @SaveCFQDone:
0006C1r 2  84 35          sty MON_IDX
0006C3r 2                 ; Parse filename
0006C3r 2  20 rr rr       jsr FsParseName
0006C6r 2                 ; Parse start address
0006C6r 2  20 rr rr       jsr MonSkipSpaces
0006C9r 2  20 rr rr       jsr MonParseHex4
0006CCr 2  B0 03          bcs @SaveCFGotStart
0006CEr 2  4C rr rr       jmp @SaveError
0006D1r 2               @SaveCFGotStart:
0006D1r 2  A5 2E          lda MON_ADDR
0006D3r 2  85 32          sta MON_TMP                   ; MON_TMP = start address
0006D5r 2  A5 2F          lda MON_ADDR+1
0006D7r 2  85 33          sta MON_TMP+1
0006D9r 2                 ; Parse end address
0006D9r 2  20 rr rr       jsr MonSkipSpaces
0006DCr 2  20 rr rr       jsr MonParseHex4
0006DFr 2  B0 03          bcs @SaveCFGotEnd
0006E1r 2  4C rr rr       jmp @SaveError
0006E4r 2               @SaveCFGotEnd:
0006E4r 2                 ; Calculate size = end - start
0006E4r 2  38             sec
0006E5r 2  A5 2E          lda MON_ADDR
0006E7r 2  E5 32          sbc MON_TMP
0006E9r 2  8D 4A 03       sta FS_FILE_SIZE
0006ECr 2  A5 2F          lda MON_ADDR+1
0006EEr 2  E5 33          sbc MON_TMP+1
0006F0r 2  8D 4B 03       sta FS_FILE_SIZE+1
0006F3r 2                 ; Read directory
0006F3r 2  20 rr rr       jsr FsReadDir
0006F6r 2  90 03          bcc @SaveCFReadOk
0006F8r 2  4C rr rr       jmp @SaveCFIOErr
0006FBr 2               @SaveCFReadOk:
0006FBr 2                 ; Try to find existing file with same name
0006FBr 2  20 rr rr       jsr FsFindFile
0006FEr 2  90 08          bcc @SaveCFOverwrite
000700r 2                 ; Not found — find a free slot
000700r 2  20 rr rr       jsr FsFindFree
000703r 2  90 11          bcc @SaveCFAlloc
000705r 2  4C rr rr       jmp @SaveCFDirFull
000708r 2               @SaveCFOverwrite:
000708r 2                 ; Clear old entry's flags
000708r 2  A0 0B          ldy #FS_ENTRY_FLAGS
00070Ar 2  A9 00          lda #$00
00070Cr 2  91 24          sta (CF_BUF_PTR),y
00070Er 2                 ; Find a free slot (could be the one we just freed)
00070Er 2  20 rr rr       jsr FsFindFree
000711r 2  90 03          bcc @SaveCFAllocOk
000713r 2  4C rr rr       jmp @SaveCFDirFull
000716r 2               @SaveCFAllocOk:
000716r 2               @SaveCFAlloc:
000716r 2                 ; Save CF_BUF_PTR (points to free entry)
000716r 2  A5 24          lda CF_BUF_PTR
000718r 2  48             pha
000719r 2  A5 25          lda CF_BUF_PTR+1
00071Br 2  48             pha
00071Cr 2                 ; Calculate next free sector
00071Cr 2  20 rr rr       jsr FsCalcNextSec
00071Fr 2                 ; Restore CF_BUF_PTR
00071Fr 2  68             pla
000720r 2  85 25          sta CF_BUF_PTR+1
000722r 2  68             pla
000723r 2  85 24          sta CF_BUF_PTR
000725r 2                 ; Calculate sectors needed
000725r 2  AD 4B 03       lda FS_FILE_SIZE+1
000728r 2  4A             lsr a
000729r 2  8D 4C 03       sta FS_SEC_COUNT
00072Cr 2  AD 4B 03       lda FS_FILE_SIZE+1
00072Fr 2  29 01          and #$01
000731r 2  D0 05          bne @SaveCFRound
000733r 2  AD 4A 03       lda FS_FILE_SIZE
000736r 2  F0 03          beq @SaveCFNoRound
000738r 2               @SaveCFRound:
000738r 2  EE 4C 03       inc FS_SEC_COUNT
00073Br 2               @SaveCFNoRound:
00073Br 2                 ; Fill in directory entry
00073Br 2                 ; Copy filename (11 bytes)
00073Br 2  A0 00          ldy #0
00073Dr 2               @SaveCFCopyName:
00073Dr 2  B9 50 03       lda FS_FNAME_BUF,y
000740r 2  91 24          sta (CF_BUF_PTR),y
000742r 2  C8             iny
000743r 2  C0 0B          cpy #11
000745r 2  D0 F6          bne @SaveCFCopyName
000747r 2                 ; Set flags = in use
000747r 2  A9 01          lda #FS_FLAG_USED
000749r 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
00074Br 2                 ; Set start sector
00074Br 2  A0 0C          ldy #FS_ENTRY_START
00074Dr 2  AD 4E 03       lda FS_NEXT_SEC
000750r 2  91 24          sta (CF_BUF_PTR),y
000752r 2  8D 48 03       sta FS_START_SEC
000755r 2  C8             iny
000756r 2  AD 4F 03       lda FS_NEXT_SEC+1
000759r 2  91 24          sta (CF_BUF_PTR),y
00075Br 2  8D 49 03       sta FS_START_SEC+1
00075Er 2                 ; Set file size
00075Er 2  A0 0E          ldy #FS_ENTRY_FSIZE
000760r 2  AD 4A 03       lda FS_FILE_SIZE
000763r 2  91 24          sta (CF_BUF_PTR),y
000765r 2  C8             iny
000766r 2  AD 4B 03       lda FS_FILE_SIZE+1
000769r 2  91 24          sta (CF_BUF_PTR),y
00076Br 2                 ; Clear reserved bytes
00076Br 2  A0 10          ldy #$10
00076Dr 2  A9 00          lda #$00
00076Fr 2               @SaveCFClrRsv:
00076Fr 2  91 24          sta (CF_BUF_PTR),y
000771r 2  C8             iny
000772r 2  C0 20          cpy #FS_ENTRY_SIZE
000774r 2  D0 F9          bne @SaveCFClrRsv
000776r 2                 ; Write updated directory
000776r 2  20 rr rr       jsr FsWriteDir
000779r 2  B0 3A          bcs @SaveCFIOErr
00077Br 2                 ; Write data sectors from user-specified start address (MON_TMP)
00077Br 2  AD 48 03       lda FS_START_SEC
00077Er 2  85 26          sta CF_LBA
000780r 2  AD 49 03       lda FS_START_SEC+1
000783r 2  85 27          sta CF_LBA+1
000785r 2  64 28          stz CF_LBA+2
000787r 2  64 29          stz CF_LBA+3
000789r 2                 ; Source = MON_TMP (start address)
000789r 2  A5 32          lda MON_TMP
00078Br 2  85 24          sta CF_BUF_PTR
00078Dr 2  A5 33          lda MON_TMP+1
00078Fr 2  85 25          sta CF_BUF_PTR+1
000791r 2  AE 4C 03       ldx FS_SEC_COUNT
000794r 2  F0 10          beq @SaveCFOk
000796r 2               @SaveCFSec:
000796r 2  DA             phx
000797r 2  20 rr rr       jsr StWriteSector             ; Writes 512 bytes, advances CF_BUF_PTR
00079Ar 2  B0 18          bcs @SaveCFSecErr
00079Cr 2  E6 26          inc CF_LBA
00079Er 2  D0 02          bne @SaveCFSecNext
0007A0r 2  E6 27          inc CF_LBA+1
0007A2r 2               @SaveCFSecNext:
0007A2r 2  FA             plx
0007A3r 2  CA             dex
0007A4r 2  D0 F0          bne @SaveCFSec
0007A6r 2               @SaveCFOk:
0007A6r 2  AD 4A 03       lda FS_FILE_SIZE
0007A9r 2  85 2E          sta MON_ADDR
0007ABr 2  AD 4B 03       lda FS_FILE_SIZE+1
0007AEr 2  85 2F          sta MON_ADDR+1
0007B0r 2  20 rr rr       jsr MonPrintSaved             ; Print "SAVED nnnn BYTES"
0007B3r 2  60             rts
0007B4r 2               @SaveCFSecErr:
0007B4r 2  FA             plx                           ; Balance stack
0007B5r 2               @SaveCFIOErr:
0007B5r 2  20 rr rr       jsr MonPrintIOErr
0007B8r 2  60             rts
0007B9r 2               @SaveCFDirFull:
0007B9r 2  A2 00          ldx #0
0007BBr 2               @SaveCFDFLoop:
0007BBr 2  BD rr rr       lda MonStrDirFull,x
0007BEr 2  F0 06          beq @SaveCFDFDone
0007C0r 2  20 rr rr       jsr Chrout
0007C3r 2  E8             inx
0007C4r 2  80 F5          bra @SaveCFDFLoop
0007C6r 2               @SaveCFDFDone:
0007C6r 2  20 rr rr       jsr MonPrintCRLF
0007C9r 2  60             rts
0007CAr 2               @SaveError:
0007CAr 2  4C rr rr       jmp MonPrintError
0007CDr 2               
0007CDr 2               ; ============================================================================
0007CDr 2               ; MonCmdM — Memory dump (hex + ASCII, 8 bytes/row)
0007CDr 2               ; Syntax: M [addr] [addr]
0007CDr 2               ; Default: 8 lines (64 bytes). Remembers position for continuation.
0007CDr 2               ; ============================================================================
0007CDr 2               
0007CDr 2               MonCmdM:
0007CDr 2  20 rr rr       jsr MonSkipSpaces
0007D0r 2  20 rr rr       jsr MonParseHex4
0007D3r 2  90 2A          bcc @UseDefault               ; No address given — use current MON_ADDR
0007D5r 2                 ; Got first address in MON_ADDR — save it
0007D5r 2  A5 2E          lda MON_ADDR
0007D7r 2  85 32          sta MON_TMP
0007D9r 2  A5 2F          lda MON_ADDR+1
0007DBr 2  85 33          sta MON_TMP+1
0007DDr 2  20 rr rr       jsr MonSkipSpaces
0007E0r 2  20 rr rr       jsr MonParseHex4
0007E3r 2  90 12          bcc @StartOnly
0007E5r 2                 ; Got second address (end) in MON_ADDR
0007E5r 2  A5 2E          lda MON_ADDR
0007E7r 2  85 30          sta MON_END
0007E9r 2  A5 2F          lda MON_ADDR+1
0007EBr 2  85 31          sta MON_END+1
0007EDr 2                 ; Restore start address
0007EDr 2  A5 32          lda MON_TMP
0007EFr 2  85 2E          sta MON_ADDR
0007F1r 2  A5 33          lda MON_TMP+1
0007F3r 2  85 2F          sta MON_ADDR+1
0007F5r 2  80 15          bra @DumpRange
0007F7r 2               @StartOnly:
0007F7r 2                 ; Only start address — restore from MON_TMP
0007F7r 2  A5 32          lda MON_TMP
0007F9r 2  85 2E          sta MON_ADDR
0007FBr 2  A5 33          lda MON_TMP+1
0007FDr 2  85 2F          sta MON_ADDR+1
0007FFr 2               @UseDefault:
0007FFr 2                 ; Set end = start + 63 (8 lines x 8 bytes)
0007FFr 2  18             clc
000800r 2  A5 2E          lda MON_ADDR
000802r 2  69 3F          adc #63
000804r 2  85 30          sta MON_END
000806r 2  A5 2F          lda MON_ADDR+1
000808r 2  69 00          adc #0
00080Ar 2  85 31          sta MON_END+1
00080Cr 2               @DumpRange:
00080Cr 2  20 rr rr       jsr MonDumpLine
00080Fr 2  B0 0E          bcs @DumpDone                 ; Carry set = address wrapped past $FFFF
000811r 2                 ; Check if MON_ADDR > MON_END
000811r 2  A5 31          lda MON_END+1
000813r 2  C5 2F          cmp MON_ADDR+1
000815r 2  90 08          bcc @DumpDone
000817r 2  D0 F3          bne @DumpRange
000819r 2  A5 30          lda MON_END
00081Br 2  C5 2E          cmp MON_ADDR
00081Dr 2  B0 ED          bcs @DumpRange
00081Fr 2               @DumpDone:
00081Fr 2  60             rts
000820r 2               
000820r 2               ; MonDumpLine — Dump 8 bytes at MON_ADDR as hex + ASCII, advance by 8
000820r 2               
000820r 2               MonDumpLine:
000820r 2                 ; Print ".:ADDR " (39 chars/line avoids 40-col auto-wrap + CRLF double-newline)
000820r 2  A9 2E          lda #'.'
000822r 2  20 rr rr       jsr Chrout
000825r 2  A9 3A          lda #':'
000827r 2  20 rr rr       jsr Chrout
00082Ar 2  20 rr rr       jsr MonPrintHex4
00082Dr 2  20 rr rr       jsr MonPrintSpace
000830r 2                 ; Print 8 hex bytes
000830r 2  A0 00          ldy #0
000832r 2               @HexLoop:
000832r 2  B1 2E          lda (MON_ADDR),y
000834r 2  5A             phy
000835r 2  20 rr rr       jsr MonPrintHex2
000838r 2  20 rr rr       jsr MonPrintSpace
00083Br 2  7A             ply
00083Cr 2  C8             iny
00083Dr 2  C0 08          cpy #8
00083Fr 2  90 F1          bcc @HexLoop
000841r 2                 ; Print 8 ASCII characters (no extra space — fits 40 cols)
000841r 2  A0 00          ldy #0
000843r 2               @AsciiLoop:
000843r 2  B1 2E          lda (MON_ADDR),y
000845r 2  C9 20          cmp #$20
000847r 2  90 04          bcc @NotPrint
000849r 2  C9 7F          cmp #$7F
00084Br 2  90 02          bcc @DoPrint
00084Dr 2               @NotPrint:
00084Dr 2  A9 2E          lda #'.'
00084Fr 2               @DoPrint:
00084Fr 2  5A             phy
000850r 2  20 rr rr       jsr Chrout
000853r 2  7A             ply
000854r 2  C8             iny
000855r 2  C0 08          cpy #8
000857r 2  90 EA          bcc @AsciiLoop
000859r 2                 ; Advance MON_ADDR by 8
000859r 2  18             clc
00085Ar 2  A5 2E          lda MON_ADDR
00085Cr 2  69 08          adc #8
00085Er 2  85 2E          sta MON_ADDR
000860r 2  90 04          bcc @NoCarry
000862r 2  E6 2F          inc MON_ADDR+1
000864r 2  F0 05          beq @Wrapped                  ; High byte became $00 = wrapped past $FFFF
000866r 2               @NoCarry:
000866r 2  20 rr rr       jsr MonPrintCRLF
000869r 2  18             clc                           ; Signal no overflow
00086Ar 2  60             rts
00086Br 2               @Wrapped:
00086Br 2  20 rr rr       jsr MonPrintCRLF
00086Er 2  38             sec                           ; Signal overflow
00086Fr 2  60             rts
000870r 2               
000870r 2               ; ============================================================================
000870r 2               ; MonCmdD — Disassemble 65C02 instructions
000870r 2               ; Syntax: D [addr] [addr]
000870r 2               ; Default: 20 lines. Remembers position for continuation.
000870r 2               ; ============================================================================
000870r 2               
000870r 2               MonCmdD:
000870r 2  20 rr rr       jsr MonSkipSpaces
000873r 2  20 rr rr       jsr MonParseHex4
000876r 2  90 2A          bcc @UseDefault
000878r 2                 ; Got first address
000878r 2  A5 2E          lda MON_ADDR
00087Ar 2  85 32          sta MON_TMP
00087Cr 2  A5 2F          lda MON_ADDR+1
00087Er 2  85 33          sta MON_TMP+1
000880r 2  20 rr rr       jsr MonSkipSpaces
000883r 2  20 rr rr       jsr MonParseHex4
000886r 2  90 12          bcc @StartOnly
000888r 2                 ; Got end address
000888r 2  A5 2E          lda MON_ADDR
00088Ar 2  85 30          sta MON_END
00088Cr 2  A5 2F          lda MON_ADDR+1
00088Er 2  85 31          sta MON_END+1
000890r 2  A5 32          lda MON_TMP
000892r 2  85 2E          sta MON_ADDR
000894r 2  A5 33          lda MON_TMP+1
000896r 2  85 2F          sta MON_ADDR+1
000898r 2  80 15          bra @DisRange
00089Ar 2               @StartOnly:
00089Ar 2  A5 32          lda MON_TMP
00089Cr 2  85 2E          sta MON_ADDR
00089Er 2  A5 33          lda MON_TMP+1
0008A0r 2  85 2F          sta MON_ADDR+1
0008A2r 2               @UseDefault:
0008A2r 2                 ; Disassemble 20 lines
0008A2r 2  A2 14          ldx #20
0008A4r 2               @DisCountLoop:
0008A4r 2  DA             phx
0008A5r 2  20 rr rr       jsr DisOneLine
0008A8r 2  FA             plx
0008A9r 2  B0 17          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
0008ABr 2  CA             dex
0008ACr 2  D0 F6          bne @DisCountLoop
0008AEr 2  60             rts
0008AFr 2               @DisRange:
0008AFr 2  20 rr rr       jsr DisOneLine
0008B2r 2  B0 0E          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
0008B4r 2                 ; Check if MON_ADDR > MON_END
0008B4r 2  A5 31          lda MON_END+1
0008B6r 2  C5 2F          cmp MON_ADDR+1
0008B8r 2  90 08          bcc @DisDone
0008BAr 2  D0 F3          bne @DisRange
0008BCr 2  A5 30          lda MON_END
0008BEr 2  C5 2E          cmp MON_ADDR
0008C0r 2  B0 ED          bcs @DisRange
0008C2r 2               @DisDone:
0008C2r 2  60             rts
0008C3r 2               
0008C3r 2               ; ============================================================================
0008C3r 2               ; DisOneLine — Disassemble one instruction at MON_ADDR
0008C3r 2               ; Prints line, advances MON_ADDR by instruction length.
0008C3r 2               ; Uses: MON_BYTE=opcode, MON_TMP=mnemonic idx, MON_TMP+1=mode
0008C3r 2               ;       Stack holds instruction length throughout.
0008C3r 2               ; ============================================================================
0008C3r 2               
0008C3r 2               DisOneLine:
0008C3r 2                 ; Read opcode and look up table
0008C3r 2  A0 00          ldy #0
0008C5r 2  B1 2E          lda (MON_ADDR),y
0008C7r 2  85 34          sta MON_BYTE                  ; save opcode
0008C9r 2  0A             asl a                         ; opcode * 2 for table index
0008CAr 2  AA             tax
0008CBr 2  90 0C          bcc @LowHalf                  ; carry clear = opcodes $00-$7F
0008CDr 2  BD rr rr       lda DisOpcodeTable+256,x      ; opcodes $80-$FF: offset by 256
0008D0r 2  85 32          sta MON_TMP                   ; mnemonic index
0008D2r 2  BD rr rr       lda DisOpcodeTable+257,x
0008D5r 2  85 33          sta MON_TMP+1                 ; addressing mode
0008D7r 2  80 0A          bra @GotEntry
0008D9r 2               @LowHalf:
0008D9r 2  BD rr rr       lda DisOpcodeTable,x
0008DCr 2  85 32          sta MON_TMP                   ; mnemonic index
0008DEr 2  BD rr rr       lda DisOpcodeTable+1,x
0008E1r 2  85 33          sta MON_TMP+1                 ; addressing mode
0008E3r 2               @GotEntry:
0008E3r 2                 ; Get instruction length from mode
0008E3r 2  A6 33          ldx MON_TMP+1
0008E5r 2  BD rr rr       lda DisModeSizes,x
0008E8r 2  1A             inc a                         ; +1 for opcode = total length
0008E9r 2  48             pha                           ; save on stack (stays until end)
0008EAr 2                 ; Print prefix ".,ADDR" (no space — consistent with M command's .:ADDR)
0008EAr 2  A9 2E          lda #'.'
0008ECr 2  20 rr rr       jsr Chrout
0008EFr 2  A9 2C          lda #','
0008F1r 2  20 rr rr       jsr Chrout
0008F4r 2                 ; Print address
0008F4r 2  20 rr rr       jsr MonPrintHex4
0008F7r 2  20 rr rr       jsr MonPrintSpace
0008FAr 2  20 rr rr       jsr MonPrintSpace
0008FDr 2                 ; Print opcode byte
0008FDr 2  A5 34          lda MON_BYTE
0008FFr 2  20 rr rr       jsr MonPrintHex2
000902r 2                 ; Print 2nd byte or padding
000902r 2  68             pla
000903r 2  48             pha                           ; peek at length
000904r 2  C9 02          cmp #2
000906r 2  90 0C          bcc @Pad1
000908r 2  20 rr rr       jsr MonPrintSpace
00090Br 2  A0 01          ldy #1
00090Dr 2  B1 2E          lda (MON_ADDR),y
00090Fr 2  20 rr rr       jsr MonPrintHex2
000912r 2  80 09          bra @Check3
000914r 2               @Pad1:
000914r 2  20 rr rr       jsr MonPrintSpace
000917r 2  20 rr rr       jsr MonPrintSpace
00091Ar 2  20 rr rr       jsr MonPrintSpace
00091Dr 2               @Check3:
00091Dr 2  68             pla
00091Er 2  48             pha
00091Fr 2  C9 03          cmp #3
000921r 2  90 0C          bcc @Pad2
000923r 2  20 rr rr       jsr MonPrintSpace
000926r 2  A0 02          ldy #2
000928r 2  B1 2E          lda (MON_ADDR),y
00092Ar 2  20 rr rr       jsr MonPrintHex2
00092Dr 2  80 09          bra @AfterBytes
00092Fr 2               @Pad2:
00092Fr 2  20 rr rr       jsr MonPrintSpace
000932r 2  20 rr rr       jsr MonPrintSpace
000935r 2  20 rr rr       jsr MonPrintSpace
000938r 2               @AfterBytes:
000938r 2                 ; Separator before mnemonic
000938r 2  20 rr rr       jsr MonPrintSpace
00093Br 2  20 rr rr       jsr MonPrintSpace
00093Er 2                 ; Print mnemonic (3 chars)
00093Er 2  20 rr rr       jsr DisPrintMnemonic
000941r 2                 ; For RMB/SMB/BBR/BBS, append bit number digit
000941r 2  A5 32          lda MON_TMP
000943r 2  C9 03          cmp #MN_BBR
000945r 2  F0 11          beq @BitNum
000947r 2  C9 04          cmp #MN_BBS
000949r 2  F0 0D          beq @BitNum
00094Br 2  C9 2E          cmp #MN_RMB
00094Dr 2  F0 09          beq @BitNum
00094Fr 2  C9 37          cmp #MN_SMB
000951r 2  F0 05          beq @BitNum
000953r 2  20 rr rr       jsr MonPrintSpace             ; normal mnemonic — space separator
000956r 2  80 11          bra @Operand
000958r 2               @BitNum:
000958r 2  A5 34          lda MON_BYTE                  ; opcode encodes bit in upper nibble
00095Ar 2  4A             lsr a
00095Br 2  4A             lsr a
00095Cr 2  4A             lsr a
00095Dr 2  4A             lsr a
00095Er 2  29 07          and #$07
000960r 2  18             clc
000961r 2  69 30          adc #'0'
000963r 2  20 rr rr       jsr Chrout
000966r 2  20 rr rr       jsr MonPrintSpace
000969r 2               @Operand:
000969r 2                 ; Print operand based on addressing mode
000969r 2  A5 33          lda MON_TMP+1
00096Br 2  20 rr rr       jsr DisPrintOperand
00096Er 2                 ; CRLF
00096Er 2  20 rr rr       jsr MonPrintCRLF
000971r 2                 ; Advance MON_ADDR by instruction length
000971r 2  68             pla                           ; length from stack
000972r 2  18             clc
000973r 2  65 2E          adc MON_ADDR
000975r 2  85 2E          sta MON_ADDR
000977r 2  90 04          bcc @NoWrap
000979r 2  E6 2F          inc MON_ADDR+1
00097Br 2  F0 02          beq @DisWrapped               ; High byte became $00 = wrapped past $FFFF
00097Dr 2               @NoWrap:
00097Dr 2  18             clc                           ; Signal no overflow
00097Er 2  60             rts
00097Fr 2               @DisWrapped:
00097Fr 2  38             sec                           ; Signal overflow
000980r 2  60             rts
000981r 2               
000981r 2               ; DisPrintMnemonic — Print 3-char mnemonic from MON_TMP index
000981r 2               
000981r 2               DisPrintMnemonic:
000981r 2  A5 32          lda MON_TMP                   ; mnemonic index
000983r 2  0A             asl a                         ; index * 2
000984r 2  18             clc
000985r 2  65 32          adc MON_TMP                   ; + index = index * 3
000987r 2  AA             tax
000988r 2  BD rr rr       lda DisMnemonics,x
00098Br 2  DA             phx
00098Cr 2  20 rr rr       jsr Chrout
00098Fr 2  FA             plx
000990r 2  BD rr rr       lda DisMnemonics+1,x
000993r 2  DA             phx
000994r 2  20 rr rr       jsr Chrout
000997r 2  FA             plx
000998r 2  BD rr rr       lda DisMnemonics+2,x
00099Br 2  4C rr rr       jmp Chrout
00099Er 2               
00099Er 2               ; DisPrintOperand — Dispatch to addressing mode operand printer
00099Er 2               ; Input: A = addressing mode index
00099Er 2               
00099Er 2               DisPrintOperand:
00099Er 2  0A             asl a                         ; mode * 2 for word table index
00099Fr 2  AA             tax
0009A0r 2  7C rr rr       jmp (DisOperandJmpTable,x)    ; handler does RTS to our caller
0009A3r 2               
