000C7Ar 2  F0 08          beq @InkeyNone                 ; No char available
000C7Cr 2  20 rr rr       jsr ReadBuffer                 ; Read without echo
000C7Fr 2  85 0A          sta BAS_ACC
000C81r 2  64 0B          stz BAS_ACC + 1
000C83r 2  60             rts
