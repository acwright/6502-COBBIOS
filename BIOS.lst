00134Fr 2  A9 01          lda #$01
001351r 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo (default 1)
001354r 2  9E 84 05       stz BAS_FORSTK + 4,x           ; +4: step hi (default 0)
