0009D8r 2  48             pha
0009D9r 2  A5 0B          lda BAS_ACC + 1
0009DBr 2  48             pha
0009DCr 2  20 rr rr       jsr BasExprMul
0009DFr 2  68             pla
0009E0r 2  85 0D          sta BAS_AUX + 1
0009E2r 2  68             pla
0009E3r 2  85 0C          sta BAS_AUX
0009E5r 2  20 rr rr       jsr BasMathSub
0009E8r 2  4C rr rr       jmp @AddLoop
0009EBr 2               
0009EBr 2               ; BasExprMul — Handle *, /, MOD
0009EBr 2               BasExprMul:
