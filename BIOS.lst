0012C6r 2                 ; Check condition: 0 = false, nonzero = true
0012C6r 2  A5 0A          lda BAS_ACC
0012C8r 2  05 0B          ora BAS_ACC + 1
0012CAr 2  F0 14          beq @IfFalse
0012CCr 2               
0012CCr 2                 ; True — check if THEN is followed by a line number (implicit GOTO)
0012CCr 2  20 rr rr       jsr BasSkipSpaces
0012CFr 2  20 rr rr       jsr BasGetTokChar
0012D2r 2  C9 30          cmp #'0'
