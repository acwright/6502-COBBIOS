00131Ar 2  20 rr rr       jsr BasSkipSpaces
00131Dr 2  20 rr rr       jsr BasGetTokChar
001320r 2  C9 89          cmp #TOK_TO
001322r 2  D0 6B          bne @ForErr
001324r 2  20 rr rr       jsr BasAdvTxtPtr
001327r 2               
001327r 2                 ; Evaluate limit — store temporarily in SCRATCH
001327r 2  20 rr rr       jsr BasExpr
00132Ar 2  A5 0A          lda BAS_ACC
00132Cr 2  85 1C          sta BAS_SCRATCH
00132Er 2  A5 0B          lda BAS_ACC + 1
001330r 2  85 1D          sta BAS_SCRATCH + 1
001332r 2               
001332r 2                 ; Check room on FOR stack
001332r 2  A6 1B          ldx BAS_FORSP
001334r 2  8A             txa
001335r 2  18             clc
001336r 2  69 10          adc #BAS_FOR_ENTRY
001338r 2  C9 81          cmp #BAS_FORSTK_SIZE + 1
00133Ar 2  B0 4E          bcs @ForStackFull
00133Cr 2               
00133Cr 2                 ; Build FOR stack entry (16 bytes per entry):
00133Cr 2                 ;  +0: var_offset (1)
00133Cr 2                 ;  +1: limit_lo (1)
00133Cr 2                 ;  +2: limit_hi (1)
00133Cr 2                 ;  +3: step_lo (1)
00133Cr 2                 ;  +4: step_hi (1)
00133Cr 2                 ;  +5: body_start_lo (1) — first line of loop body (next line after FOR)
00133Cr 2                 ;  +6: body_start_hi (1)
00133Cr 2                 ; +7..+15: unused padding
00133Cr 2               
00133Cr 2                 ; Save var offset and limit to stack entry NOW, before evaluating STEP,
00133Cr 2                 ; because BasExpr clobbers BAS_SCRATCH during number parsing.
00133Cr 2  A5 21          lda BAS_TEMP
00133Er 2  9D 80 05       sta BAS_FORSTK,x               ; +0: var offset
001341r 2  A5 1C          lda BAS_SCRATCH
001343r 2  9D 81 05       sta BAS_FORSTK + 1,x           ; +1: limit lo
001346r 2  A5 1D          lda BAS_SCRATCH + 1
001348r 2  9D 82 05       sta BAS_FORSTK + 2,x           ; +2: limit hi
00134Br 2               
00134Br 2                 ; Check for optional STEP — default is 1
00134Br 2  A9 01          lda #$01
00134Dr 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo (default 1)
001350r 2  9E 84 05       stz BAS_FORSTK + 4,x           ; +4: step hi (default 0)
001353r 2               
001353r 2  20 rr rr       jsr BasSkipSpaces
001356r 2  20 rr rr       jsr BasGetTokChar
001359r 2  C9 8A          cmp #TOK_STEP
00135Br 2  D0 12          bne @ForNoStep
00135Dr 2  20 rr rr       jsr BasAdvTxtPtr
001360r 2  DA             phx                            ; Preserve FOR stack index
001361r 2  20 rr rr       jsr BasExpr
001364r 2  FA             plx                            ; Restore FOR stack index
001365r 2  A5 0A          lda BAS_ACC
001367r 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo
00136Ar 2  A5 0B          lda BAS_ACC + 1
00136Cr 2  9D 84 05       sta BAS_FORSTK + 4,x           ; +4: step hi
00136Fr 2               @ForNoStep:
00136Fr 2                 ; Save loop body start: current line and TXTPTR
00136Fr 2                 ; (TXTPTR points right after the FOR statement — at ':' or end of line)
00136Fr 2  A5 06          lda BAS_CURLINE
001371r 2  9D 85 05       sta BAS_FORSTK + 5,x           ; +5: body_line lo
001374r 2  A5 07          lda BAS_CURLINE + 1
001376r 2  9D 86 05       sta BAS_FORSTK + 6,x           ; +6: body_line hi
001379r 2  A5 04          lda BAS_TXTPTR
00137Br 2  9D 87 05       sta BAS_FORSTK + 7,x           ; +7: body_txtptr lo
00137Er 2  A5 05          lda BAS_TXTPTR + 1
