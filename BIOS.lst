000C30r 2               
000C30r 2                 ; POW(b,e) — Integer exponentiation
000C30r 2  C9 B9          cmp #TOK_POW
000C32r 2  D0 2F          bne @NotPow
000C34r 2  20 rr rr       jsr BasAdvTxtPtr
