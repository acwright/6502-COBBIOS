0012B6r 2  00             brk                            ; Trigger BRK → IRQ vector → Wozmon
0012B7r 2               
0012B7r 2               ; --- NEW ---
0012B7r 2               BasCmdNew:
0012B7r 2                 ; Set program end to program start (empty program)
0012B7r 2  A9 00          lda #<BAS_PRG_START
0012B9r 2  85 12          sta BAS_PRGEND
0012BBr 2  A9 08          lda #>BAS_PRG_START
0012BDr 2  85 13          sta BAS_PRGEND + 1
0012BFr 2                 ; Write end marker
0012BFr 2  A0 00          ldy #LINE_NEXT
0012C1r 2  A9 00          lda #$00
0012C3r 2  91 12          sta (BAS_PRGEND),y
0012C5r 2  C8             iny
0012C6r 2  91 12          sta (BAS_PRGEND),y
0012C8r 2                 ; Clear variables
0012C8r 2  20 rr rr       jsr BasCmdClr
0012CBr 2  64 17          stz BAS_FLAGS
0012CDr 2  4C rr rr       jmp BasMainLoop
0012D0r 2               
0012D0r 2               ; --- LIST ---
0012D0r 2               BasCmdList:
0012D0r 2                 ; Start at beginning of program
0012D0r 2  A9 00          lda #<BAS_PRG_START
0012D2r 2  85 0E          sta BAS_TMP1
0012D4r 2  A9 08          lda #>BAS_PRG_START
0012D6r 2  85 0F          sta BAS_TMP1 + 1
0012D8r 2               
0012D8r 2               @ListLoop:
0012D8r 2                 ; Check if at end of program (TMP1 == PRGEND)
0012D8r 2  A5 0E          lda BAS_TMP1
0012DAr 2  C5 12          cmp BAS_PRGEND
0012DCr 2  D0 06          bne @ListNotEnd
0012DEr 2  A5 0F          lda BAS_TMP1 + 1
0012E0r 2  C5 13          cmp BAS_PRGEND + 1
0012E2r 2  F0 42          beq @ListDone
0012E4r 2               @ListNotEnd:
0012E4r 2               
0012E4r 2                 ; Check for Ctrl+C break
0012E4r 2  20 rr rr       jsr BasCheckBreak
0012E7r 2               
0012E7r 2                 ; Print line number
0012E7r 2  A0 02          ldy #LINE_NUM
0012E9r 2  B1 0E          lda (BAS_TMP1),y
0012EBr 2  85 0A          sta BAS_ACC
0012EDr 2  C8             iny
0012EEr 2  B1 0E          lda (BAS_TMP1),y
0012F0r 2  85 0B          sta BAS_ACC + 1
0012F2r 2  20 rr rr       jsr BasPrintInt
0012F5r 2               
0012F5r 2                 ; Print space
0012F5r 2  A9 20          lda #CH_SPACE
0012F7r 2  20 rr rr       jsr Chrout
0012FAr 2               
0012FAr 2                 ; Detokenize and print the payload
0012FAr 2                 ; Set TXTPTR to payload
0012FAr 2  18             clc
0012FBr 2  A5 0E          lda BAS_TMP1
0012FDr 2  69 04          adc #LINE_PAYLOAD
0012FFr 2  85 04          sta BAS_TXTPTR
001301r 2  A5 0F          lda BAS_TMP1 + 1
001303r 2  69 00          adc #$00
001305r 2  85 05          sta BAS_TXTPTR + 1
001307r 2               
001307r 2  20 rr rr       jsr BasDetokenize
00130Ar 2               
00130Ar 2                 ; Print CRLF
00130Ar 2  20 rr rr       jsr BasPrintCRLF
00130Dr 2               
00130Dr 2                 ; Advance to next line by scanning for null terminator
00130Dr 2  A0 04          ldy #LINE_PAYLOAD
00130Fr 2               @ListScan:
00130Fr 2  B1 0E          lda (BAS_TMP1),y
001311r 2  F0 03          beq @ListScanDone
001313r 2  C8             iny
001314r 2  80 F9          bra @ListScan
001316r 2               @ListScanDone:
001316r 2  C8             iny                            ; Past null
001317r 2  98             tya
001318r 2  18             clc
001319r 2  65 0E          adc BAS_TMP1
00131Br 2  85 0E          sta BAS_TMP1
00131Dr 2  A9 00          lda #$00
00131Fr 2  65 0F          adc BAS_TMP1 + 1
001321r 2  85 0F          sta BAS_TMP1 + 1
001323r 2  4C rr rr       jmp @ListLoop
001326r 2               
001326r 2               @ListDone:
