0013CBr 2                 ; Not this entry — keep searching
0013CBr 2  80 EF          bra @NextSearch
0013CDr 2               
0013CDr 2               @NextFound:
0013CDr 2                 ; Add step to variable
0013CDr 2  BD 83 05       lda BAS_FORSTK + 3,x           ; step lo
0013D0r 2  85 0C          sta BAS_AUX
0013D2r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
0013D5r 2  85 0D          sta BAS_AUX + 1
0013D7r 2               
0013D7r 2  A4 21          ldy BAS_TEMP                   ; var offset
0013D9r 2  18             clc
0013DAr 2  B9 00 04       lda BAS_VARS,y
0013DDr 2  65 0C          adc BAS_AUX
0013DFr 2  99 00 04       sta BAS_VARS,y
0013E2r 2  85 0A          sta BAS_ACC
0013E4r 2  B9 01 04       lda BAS_VARS + 1,y
0013E7r 2  65 0D          adc BAS_AUX + 1
0013E9r 2  99 01 04       sta BAS_VARS + 1,y
0013ECr 2  85 0B          sta BAS_ACC + 1
0013EEr 2               
0013EEr 2                 ; Load limit into AUX for comparison
0013EEr 2  BD 81 05       lda BAS_FORSTK + 1,x           ; limit lo
0013F1r 2  85 0C          sta BAS_AUX
0013F3r 2  BD 82 05       lda BAS_FORSTK + 2,x           ; limit hi
0013F6r 2  85 0D          sta BAS_AUX + 1
0013F8r 2               
0013F8r 2                 ; Check if loop is done:
0013F8r 2                 ; If step > 0: done when var > limit (AUX)
0013F8r 2                 ; If step < 0: done when var < limit (AUX)
0013F8r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
0013FBr 2  30 07          bmi @NextStepNeg
0013FDr 2               
0013FDr 2                 ; Step positive: compare var (ACC) vs limit (AUX)
0013FDr 2                 ; Done if ACC > AUX (i.e., AUX < ACC)
0013FDr 2  20 rr rr       jsr BasCmpAuxAcc
001400r 2  30 37          bmi @NextDone                  ; AUX < ACC means var > limit
001402r 2  80 07          bra @NextLoop                  ; Continue loop
001404r 2               
001404r 2               @NextStepNeg:
001404r 2                 ; Step negative: done if var < limit
001404r 2                 ; Done if ACC < AUX (i.e., AUX > ACC)
001404r 2  20 rr rr       jsr BasCmpAuxAcc
001407r 2  F0 02          beq @NextLoop
001409r 2  10 2E          bpl @NextDone                  ; AUX > ACC means var < limit
00140Br 2               
00140Br 2               @NextLoop:
00140Br 2                 ; Continue loop — restore to saved body start
00140Br 2                 ; Keep the FOR entry on the stack (FORSP stays where it is)
00140Br 2  BD 85 05       lda BAS_FORSTK + 5,x           ; body_line lo
00140Er 2  85 06          sta BAS_CURLINE
