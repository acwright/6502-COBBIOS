00130Br 2  20 rr rr       jsr BasExpr
00130Er 2  A6 21          ldx BAS_TEMP
001310r 2  A5 0A          lda BAS_ACC
001312r 2  9D 00 04       sta BAS_VARS,x
001315r 2  A5 0B          lda BAS_ACC + 1
001317r 2  9D 01 04       sta BAS_VARS + 1,x
00131Ar 2               
