0022E6r 2               @end:
0022E6r 2  A9 FF                lda     #$FF
0022E8r 2  8D 69 03             sta     BAS_CURLIN
0022EBr 2  8D 6A 03             sta     BAS_CURLIN+1
0022EEr 2  4C rr rr             jmp     BasReadyLoop
0022F1r 2               @synErrPlp:
0022F1r 2  28                   plp
0022F2r 2               @synErr:
0022F2r 2  4C rr rr             jmp     SynErr
0022F5r 2               
0022F5r 2               ; ---------------------------------------------------------------------------
0022F5r 2               ; Statement: CONT -- resume execution from saved OLDTEXT/OLDLIN.
0022F5r 2               ; ---------------------------------------------------------------------------
0022F5r 2               BasCmdCont:
0022F5r 2  20 rr rr             jsr     ChrGot
0022F8r 2  D0 21                bne     @synErr
0022FAr 2  AD 6E 03             lda     BAS_OLDTEXT+1
0022FDr 2  D0 05                bne     @canCont
0022FFr 2  A2 10                ldx     #ERR_CANTCONT
002301r 2  4C rr rr             jmp     BasErrorVec
002304r 2               @canCont:
002304r 2  AD 6D 03             lda     BAS_OLDTEXT
002307r 2  85 04                sta     TXTPTR
002309r 2  AD 6E 03             lda     BAS_OLDTEXT+1
00230Cr 2  85 05                sta     TXTPTR+1
00230Er 2  AD 6B 03             lda     BAS_OLDLIN
002311r 2  8D 69 03             sta     BAS_CURLIN
002314r 2  AD 6C 03             lda     BAS_OLDLIN+1
002317r 2  8D 6A 03             sta     BAS_CURLIN+1
00231Ar 2  60                   rts
00231Br 2               @synErr:
00231Br 2  4C rr rr             jmp     SynErr
00231Er 2               
00231Er 2               ; ---------------------------------------------------------------------------
00231Er 2               ; Statement: RESTORE -- DATAPTR := TXTTAB - 1.
00231Er 2               ; ---------------------------------------------------------------------------
00231Er 2               BasCmdRestore:
00231Er 2  38                   sec
00231Fr 2  AD 5D 03             lda     BAS_TXTTAB
