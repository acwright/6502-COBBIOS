001119r 2  24 00 46 00  
00111Dr 2  15 06 33 06    .byte MN_CPX,AM_ABS, MN_SBC,AM_ABS, MN_INC,AM_ABS, MN_BBS,AM_ZPR  ; $EC-$EF
001121r 2  1B 06 04 0E  
