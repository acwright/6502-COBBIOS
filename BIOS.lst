000824r 2  D0 40          bne @CmpSetTrue
000826r 2  A5 0B          lda BAS_ACC + 1
000828r 2  C5 0D          cmp BAS_AUX + 1
00082Ar 2  D0 3A          bne @CmpSetTrue
00082Cr 2  80 3F          bra @CmpSetFalse
00082Er 2               
00082Er 2               @CmpLT:
