000CA2r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_FREE
000CA5r 2  38             sec
000CA6r 2  AD 8F 03       lda BAS_ARYTOP
000CA9r 2  E9 01          sbc #$01
000CABr 2  85 0A          sta BAS_ACC
000CADr 2  AD 90 03       lda BAS_ARYTOP + 1
