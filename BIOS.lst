00104Dr 2  C9 3A        : cmp #CH_COLON
00104Fr 2  D0 03          bne :+
001051r 2  4C rr rr       jmp @PrintNewline              ; PRINT: — newline then next statement
001054r 2               :
001054r 2               
001054r 2               @PrintLoop:
001054r 2  20 rr rr       jsr BasSkipSpaces
001057r 2  20 rr rr       jsr BasGetTokChar
00105Ar 2  D0 03          bne :+
00105Cr 2  4C rr rr       jmp @PrintEnd                  ; End of line
00105Fr 2  C9 3A        : cmp #CH_COLON
001061r 2  D0 03          bne :+
001063r 2  4C rr rr       jmp @PrintEnd
001066r 2               :
001066r 2               
001066r 2                 ; String literal?
001066r 2  C9 22          cmp #CH_QUOTE
001068r 2  D0 03          bne :+
00106Ar 2  4C rr rr       jmp @PrintString
00106Dr 2               :
00106Dr 2               
00106Dr 2                 ; CHR(n) — output character directly
00106Dr 2  C9 AF          cmp #TOK_CHR
00106Fr 2  D0 03          bne :+
001071r 2  4C rr rr       jmp @PrintChr
001074r 2               :
001074r 2               
001074r 2                 ; TAB(n) — tab to column n
001074r 2  C9 BB          cmp #TOK_TAB
001076r 2  D0 03          bne :+
001078r 2  4C rr rr       jmp @PrintTab
00107Br 2               :
00107Br 2               
00107Br 2                 ; HEX(n) — print value as $xxxx hex
00107Br 2  C9 BC          cmp #TOK_HEX
00107Dr 2  D0 03          bne :+
00107Fr 2  4C rr rr       jmp @PrintHex
001082r 2               :
001082r 2               
001082r 2                 ; Otherwise evaluate expression and print number
001082r 2  20 rr rr       jsr BasExpr
001085r 2  20 rr rr       jsr BasPrintInt
001088r 2  4C rr rr       jmp @PrintSep
00108Br 2               
00108Br 2               @PrintString:
00108Br 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
00108Er 2               @PrintStrCh:
00108Er 2  20 rr rr       jsr BasGetTokChar
001091r 2  D0 03          bne :+
001093r 2  4C rr rr       jmp @PrintEnd                  ; Unterminated string
001096r 2  C9 22        : cmp #CH_QUOTE
001098r 2  F0 08          beq @PrintStrEnd
00109Ar 2  20 rr rr       jsr Chrout
00109Dr 2  20 rr rr       jsr BasAdvTxtPtr
0010A0r 2  80 EC          bra @PrintStrCh
0010A2r 2               @PrintStrEnd:
0010A2r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip closing quote
0010A5r 2  4C rr rr       jmp @PrintSep
0010A8r 2               
0010A8r 2               @PrintChr:
0010A8r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_CHR
0010ABr 2  A9 28          lda #CH_LPAREN
0010ADr 2  20 rr rr       jsr BasExpectChar
0010B0r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
0010B3r 2  A9 29          lda #CH_RPAREN
0010B5r 2  20 rr rr       jsr BasExpectChar
0010B8r 2  A5 0A          lda BAS_ACC                    ; Output low byte as character
0010BAr 2  20 rr rr       jsr VideoChroutRaw             ; Raw output — no control-code interception
0010BDr 2  4C rr rr       jmp @PrintSep
0010C0r 2               
0010C0r 2               @PrintTab:
0010C0r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_TAB
0010C3r 2  A9 28          lda #CH_LPAREN
0010C5r 2  20 rr rr       jsr BasExpectChar
0010C8r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
0010CBr 2  A9 29          lda #CH_RPAREN
0010CDr 2  20 rr rr       jsr BasExpectChar
0010D0r 2               @TabLoop:
0010D0r 2  AD 07 03       lda VID_CURSOR_X               ; Current column
0010D3r 2  C5 0A          cmp BAS_ACC                    ; Already at or past target?
0010D5r 2  B0 40          bcs @PrintSep                  ; Yes — done
0010D7r 2  A9 20          lda #CH_SPACE
0010D9r 2  20 rr rr       jsr Chrout
0010DCr 2  80 F2          bra @TabLoop
0010DEr 2               
0010DEr 2               @PrintHex:
0010DEr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_HEX
0010E1r 2  A9 28          lda #CH_LPAREN
0010E3r 2  20 rr rr       jsr BasExpectChar
0010E6r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
0010E9r 2  A9 29          lda #CH_RPAREN
0010EBr 2  20 rr rr       jsr BasExpectChar
0010EEr 2  A9 24          lda #'$'
0010F0r 2  20 rr rr       jsr Chrout                     ; Output '$' prefix
0010F3r 2  A5 0B          lda BAS_ACC + 1                ; High byte first
0010F5r 2  20 rr rr       jsr @HexOutByte
0010F8r 2  A5 0A          lda BAS_ACC                    ; Low byte
0010FAr 2  20 rr rr       jsr @HexOutByte
0010FDr 2  80 18          bra @PrintSep
0010FFr 2               
0010FFr 2               @HexOutByte:
0010FFr 2                 ; Output byte in A as two hex digits
0010FFr 2  48             pha
001100r 2  4A             lsr
001101r 2  4A             lsr
001102r 2  4A             lsr
001103r 2  4A             lsr                            ; High nibble
001104r 2  20 rr rr       jsr @HexOutNibble
001107r 2  68             pla
001108r 2  29 0F          and #$0F                       ; Low nibble
00110Ar 2               @HexOutNibble:
00110Ar 2  C9 0A          cmp #$0A
00110Cr 2  90 04          bcc @HexDigit
00110Er 2  69 36          adc #('A' - $0A - 1)          ; Carry is set from cmp
001110r 2  80 02          bra @HexPrint
001112r 2               @HexDigit:
001112r 2  09 30          ora #'0'
001114r 2               @HexPrint:
001114r 2  4C rr rr       jmp Chrout                     ; Output and return
001117r 2               
001117r 2               @PrintSep:
001117r 2  20 rr rr       jsr BasSkipSpaces
00111Ar 2  20 rr rr       jsr BasGetTokChar
00111Dr 2  C9 3B          cmp #CH_SEMICOL
00111Fr 2  F0 06          beq @PrintSemicolon
001121r 2  C9 2C          cmp #CH_COMMA
001123r 2  F0 14          beq @PrintComma
001125r 2                 ; No separator — done, print newline
001125r 2  80 20          bra @PrintNewline
001127r 2               
001127r 2               @PrintSemicolon:
001127r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ';'
00112Ar 2                 ; Check if end of statement (suppress newline)
00112Ar 2  20 rr rr       jsr BasSkipSpaces
00112Dr 2  20 rr rr       jsr BasGetTokChar
001130r 2  F0 18          beq @PrintDone                 ; End of line — suppress newline
001132r 2  C9 3A          cmp #CH_COLON
001134r 2  F0 14          beq @PrintDone                 ; Colon — suppress newline
001136r 2  4C rr rr       jmp @PrintLoop
001139r 2               
001139r 2               @PrintComma:
001139r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
00113Cr 2                 ; Print separator spaces
00113Cr 2  A9 20          lda #CH_SPACE
00113Er 2  20 rr rr       jsr Chrout
001141r 2  20 rr rr       jsr Chrout
001144r 2  4C rr rr       jmp @PrintLoop
001147r 2               
001147r 2               @PrintNewline:
001147r 2  20 rr rr       jsr BasPrintCRLF
00114Ar 2               @PrintDone:
00114Ar 2               @PrintEnd:
00114Ar 2  60             rts
