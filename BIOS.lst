0006D3r 2  4C rr rr       jmp BasMathNeg
0006D6r 2               @MulDone:
0006D6r 2  60             rts
0006D7r 2               
0006D7r 2               ; BasMathDiv — ACC = AUX / ACC, remainder in BAS_SCRATCH2
0006D7r 2               ; 16-bit signed division
0006D7r 2               BasMathDiv:
0006D7r 2                 ; Check for division by zero
0006D7r 2  A5 0A          lda BAS_ACC
0006D9r 2  05 0B          ora BAS_ACC + 1
0006DBr 2  D0 05          bne @DivNotZero
0006DDr 2  A9 06          lda #ERR_DIV_ZERO
0006DFr 2  4C rr rr       jmp BasError
0006E2r 2               
0006E2r 2               @DivNotZero:
0006E2r 2                 ; Determine result sign
0006E2r 2  A5 0D          lda BAS_AUX + 1
0006E4r 2  45 0B          eor BAS_ACC + 1
0006E6r 2  85 20          sta BAS_SIGN
0006E8r 2               
0006E8r 2                 ; Save remainder sign (same as dividend) on CPU stack
0006E8r 2  A5 0D          lda BAS_AUX + 1
0006EAr 2  48             pha
0006EBr 2               
0006EBr 2                 ; Make both positive
0006EBr 2  A5 0D          lda BAS_AUX + 1
0006EDr 2  10 0D          bpl @DivAuxPos
0006EFr 2  38             sec
0006F0r 2  A9 00          lda #$00
0006F2r 2  E5 0C          sbc BAS_AUX
0006F4r 2  85 0C          sta BAS_AUX
0006F6r 2  A9 00          lda #$00
0006F8r 2  E5 0D          sbc BAS_AUX + 1
0006FAr 2  85 0D          sta BAS_AUX + 1
0006FCr 2               @DivAuxPos:
0006FCr 2  A5 0B          lda BAS_ACC + 1
0006FEr 2  10 03          bpl @DivAccPos
000700r 2  20 rr rr       jsr BasMathNeg
000703r 2               @DivAccPos:
000703r 2                 ; AUX = dividend, ACC = divisor
000703r 2                 ; Remainder in SCRATCH2
000703r 2  64 1E          stz BAS_SCRATCH2
000705r 2  64 1F          stz BAS_SCRATCH2 + 1
000707r 2               
000707r 2  A2 10          ldx #16
000709r 2               
000709r 2               @DivLoop:
000709r 2                 ; Shift dividend left into remainder
000709r 2  06 0C          asl BAS_AUX
00070Br 2  26 0D          rol BAS_AUX + 1
00070Dr 2  26 1E          rol BAS_SCRATCH2
00070Fr 2  26 1F          rol BAS_SCRATCH2 + 1
000711r 2               
000711r 2                 ; Try subtract divisor from remainder
000711r 2  38             sec
000712r 2  A5 1E          lda BAS_SCRATCH2
000714r 2  E5 0A          sbc BAS_ACC
000716r 2  85 1C          sta BAS_SCRATCH
000718r 2  A5 1F          lda BAS_SCRATCH2 + 1
00071Ar 2  E5 0B          sbc BAS_ACC + 1
00071Cr 2               
00071Cr 2  90 08          bcc @DivNoSub
00071Er 2               
00071Er 2                 ; Subtraction succeeded — set quotient bit
00071Er 2  85 1F          sta BAS_SCRATCH2 + 1
000720r 2  A5 1C          lda BAS_SCRATCH
000722r 2  85 1E          sta BAS_SCRATCH2
