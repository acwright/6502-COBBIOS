000C62r 2  20 rr rr       jsr BasCmdLocate
000C65r 2  80 40          bra @ExecCheckMore
000C67r 2               @JmpColor:
000C67r 2  20 rr rr       jsr BasAdvTxtPtr
000C6Ar 2  20 rr rr       jsr BasCmdColor
000C6Dr 2  80 38          bra @ExecCheckMore
000C6Fr 2               @JmpSound:
000C6Fr 2  20 rr rr       jsr BasAdvTxtPtr
000C72r 2  20 rr rr       jsr BasCmdSound
000C75r 2  80 30          bra @ExecCheckMore
000C77r 2               @JmpVol:
000C77r 2  20 rr rr       jsr BasAdvTxtPtr
000C7Ar 2  20 rr rr       jsr BasCmdVol
000C7Dr 2  80 28          bra @ExecCheckMore
000C7Fr 2               @JmpTime:
000C7Fr 2  20 rr rr       jsr BasAdvTxtPtr
000C82r 2  20 rr rr       jsr BasCmdTime
000C85r 2  80 20          bra @ExecCheckMore
000C87r 2               @JmpDate:
000C87r 2  20 rr rr       jsr BasAdvTxtPtr
000C8Ar 2  20 rr rr       jsr BasCmdDate
000C8Dr 2  80 18          bra @ExecCheckMore
000C8Fr 2               @JmpWait:
