001335r 2  20 rr rr       jsr BasGetTokChar
001338r 2  C9 2C          cmp #CH_COMMA
00133Ar 2  D0 0D          bne @PokeErr
00133Cr 2  20 rr rr       jsr BasAdvTxtPtr
