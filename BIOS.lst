0007CCr 2  20 rr rr       jsr BasExprCmp
0007CFr 2                 ; NOT: 0 -> 1, nonzero -> 0
0007CFr 2  A5 0A          lda BAS_ACC
0007D1r 2  05 0B          ora BAS_ACC + 1
