002317r 2               
002317r 2               ; ---------------------------------------------------------------------------
002317r 2               ; Statement: INPUT [<"prompt">{,;}] var[,var,...]
002317r 2               ;   Prompts user for input, reads a line, parses it into the variable list.
002317r 2               ;   "abc";VAR  prints  abc?    (question + space appended)
002317r 2               ;   "abc",VAR  prints  abc      (no question mark)
002317r 2               ;   no prompt: prints  ?
002317r 2               ;   On bad numeric input or premature end-of-line: "?REDO FROM START"
002317r 2               ;   and reprompt.  Trailing un-consumed input: "?EXTRA IGNORED".
002317r 2               ; ---------------------------------------------------------------------------
002317r 2               BasCmdInput:
002317r 2                       ; INPUT is illegal in direct mode.
002317r 2  AD 6A 03             lda     BAS_CURLIN+1
00231Ar 2  C9 FF                cmp     #$FF
00231Cr 2  D0 05                bne     @notDirect
00231Er 2  A2 07                ldx     #ERR_ILLDIRECT
002320r 2  4C rr rr             jmp     BasErrorVec
002323r 2               @notDirect:
002323r 2                       ; ChrGot returns first char after the INPUT token.
002323r 2  20 rr rr             jsr     ChrGot
002326r 2  C9 22                cmp     #'"'
002328r 2  D0 27                bne     @noPrompt
00232Ar 2                       ; Parse string literal & print it; FrmEvl will leave descriptor in FAC.
00232Ar 2  20 rr rr             jsr     FrmEvl
00232Dr 2  20 rr rr             jsr     ChkStr
002330r 2  20 rr rr             jsr     PrintStrFAC
002333r 2  20 rr rr             jsr     FreFac
002336r 2  20 rr rr             jsr     ChrGot
002339r 2  C9 3B                cmp     #';'
00233Br 2  F0 09                beq     @semi
00233Dr 2  C9 2C                cmp     #','
00233Fr 2  D0 0D                bne     @badPrompt
002341r 2  20 rr rr             jsr     ChrGet                  ; consume ','
002344r 2  80 0E                bra     @afterPrompt
002346r 2               @semi:
002346r 2  20 rr rr             jsr     ChrGet                  ; consume ';'
002349r 2  20 rr rr             jsr     BasInpQues              ; '? '
00234Cr 2  80 06                bra     @afterPrompt
00234Er 2               @badPrompt:
00234Er 2  4C rr rr             jmp     SynErr
002351r 2               @noPrompt:
002351r 2  20 rr rr             jsr     BasInpQues              ; '? '
002354r 2               @afterPrompt:
002354r 2                       ; Save program TXTPTR (start of var-list) for REDO retry.
002354r 2  A5 04                lda     TXTPTR
002356r 2  8D 71 03             sta     BAS_INPSAV
002359r 2  A5 05                lda     TXTPTR+1
00235Br 2  8D 72 03             sta     BAS_INPSAV+1
00235Er 2               @retry:
00235Er 2  20 rr rr             jsr     BasReadLine             ; reads to BAS_LINBUF, NUL-terminated, prints CRLF
002361r 2                       ; Set up data pointer with leading ',' sentinel just before LINBUF.
002361r 2  A9 2C                lda     #','
002363r 2  8D FF 03             sta     BAS_LINBUF-1
002366r 2  A9 FF                lda     #<(BAS_LINBUF-1)
002368r 2  85 3A                sta     BAS_TMP1
00236Ar 2  A9 03                lda     #>(BAS_LINBUF-1)
00236Cr 2  85 3B                sta     BAS_TMP1+1
00236Er 2                       ; Restore program TXTPTR.
00236Er 2  AD 71 03             lda     BAS_INPSAV
002371r 2  85 04                sta     TXTPTR
002373r 2  AD 72 03             lda     BAS_INPSAV+1
002376r 2  85 05                sta     TXTPTR+1
002378r 2  64 69                stz     BAS_INPUTFLG            ; INPUT mode ($00)
00237Ar 2               @nextVar:
00237Ar 2  20 rr rr             jsr     PtrGet                  ; advance program TXTPTR past var name
00237Dr 2  85 46                sta     BAS_FORPNT
00237Fr 2  84 47                sty     BAS_FORPNT+1
002381r 2                       ; Save program TXTPTR; switch to data side.
002381r 2  A5 05                lda     TXTPTR+1
002383r 2  48                   pha
002384r 2  A5 04                lda     TXTPTR
002386r 2  48                   pha
002387r 2  A5 3A                lda     BAS_TMP1
002389r 2  85 04                sta     TXTPTR
00238Br 2  A5 3B                lda     BAS_TMP1+1
00238Dr 2  85 05                sta     TXTPTR+1
00238Fr 2  20 rr rr             jsr     ChrGot
002392r 2  D0 05                bne     @gotData
002394r 2                       ; Out of input data before var list exhausted -> REDO.
002394r 2  68                   pla
002395r 2  68                   pla
002396r 2  4C rr rr             jmp     @doRedo
002399r 2               @gotData:
002399r 2  20 rr rr             jsr     ChrGet                  ; consume the separator/sentinel
00239Cr 2  24 64                bit     VALTYP
00239Er 2  30 2E                bmi     @inpStr
0023A0r 2                       ; Numeric: must start with digit, '+', '-' or '.'; else REDO.
0023A0r 2  20 rr rr             jsr     ChrGot
0023A3r 2  90 11                bcc     @numOk                  ; carry clear == digit
0023A5r 2  C9 2D                cmp     #'-'
0023A7r 2  F0 0D                beq     @numOk
0023A9r 2  C9 2B                cmp     #'+'
0023ABr 2  F0 09                beq     @numOk
0023ADr 2  C9 2E                cmp     #'.'
0023AFr 2  F0 05                beq     @numOk
0023B1r 2                       ; bad numeric
0023B1r 2  68                   pla
0023B2r 2  68                   pla
0023B3r 2  4C rr rr             jmp     @doRedo
0023B6r 2               @numOk:
0023B6r 2  20 rr rr             jsr     Fin
0023B9r 2  A6 46                ldx     BAS_FORPNT
0023BBr 2  A4 47                ldy     BAS_FORPNT+1
0023BDr 2  20 rr rr             jsr     StoreFacAtYxRounded
0023C0r 2                       ; After Fin, ChrGot result must be NUL or ',' (Fin/ChrGot skips spaces).
0023C0r 2  20 rr rr             jsr     ChrGot
0023C3r 2  F0 4A                beq     @afterStore
0023C5r 2  C9 2C                cmp     #','
0023C7r 2  F0 46                beq     @afterStore
0023C9r 2                       ; Garbage trailing the number -> REDO.
0023C9r 2  68                   pla
0023CAr 2  68                   pla
0023CBr 2  4C rr rr             jmp     @doRedo
0023CEr 2               @inpStr:
0023CEr 2                       ; Peek at the first data character.  If it's a '"', use quote-mode
0023CEr 2                       ; (terminator = '"' or NUL); otherwise terminate at ',' or NUL.
0023CEr 2  A0 00                ldy     #0
0023D0r 2  B1 04                lda     (TXTPTR),y
0023D2r 2  C9 22                cmp     #'"'
0023D4r 2  F0 0E                beq     @sQuoted
0023D6r 2                       ; Unquoted: STRLT2 source = TXTPTR.
0023D6r 2  A9 00                lda     #0
0023D8r 2  85 44                sta     CHARAC
0023DAr 2  A9 2C                lda     #','
0023DCr 2  85 6A                sta     ENDCHR
0023DEr 2  A5 04                lda     TXTPTR
0023E0r 2  A4 05                ldy     TXTPTR+1
0023E2r 2  80 10                bra     @sCallStrLt
0023E4r 2               @sQuoted:
0023E4r 2  A9 22                lda     #'"'
0023E6r 2  85 44                sta     CHARAC
0023E8r 2  85 6A                sta     ENDCHR
0023EAr 2                       ; Skip the opening '"'; STRLT2 source = TXTPTR + 1.
0023EAr 2  18                   clc
0023EBr 2  A5 04                lda     TXTPTR
0023EDr 2  69 01                adc     #1
0023EFr 2  A4 05                ldy     TXTPTR+1
0023F1r 2  90 01                bcc     @sCallStrLt
0023F3r 2  C8                   iny
0023F4r 2               @sCallStrLt:
0023F4r 2  20 rr rr             jsr     StrLt2
0023F7r 2                       ; StrLt2 leaves STRNG2 pointing past the consumed string (at the
0023F7r 2                       ; terminator for unquoted input, or just past the closing '"' for
0023F7r 2                       ; quoted input).  Advance TXTPTR (== data pointer) accordingly so
0023F7r 2                       ; the trailing-extra check sees only what truly remained on the
0023F7r 2                       ; input line.
0023F7r 2  A5 1E                lda     STRNG2
0023F9r 2  85 04                sta     TXTPTR
0023FBr 2  A5 1F                lda     STRNG2+1
0023FDr 2  85 05                sta     TXTPTR+1
0023FFr 2  A0 00                ldy     #0
002401r 2  A5 0E                lda     FAC
002403r 2  91 46                sta     (BAS_FORPNT),y
002405r 2  C8                   iny
002406r 2  A5 0F                lda     FAC+1
002408r 2  91 46                sta     (BAS_FORPNT),y
00240Ar 2  C8                   iny
00240Br 2  A5 10                lda     FAC+2
00240Dr 2  91 46                sta     (BAS_FORPNT),y
00240Fr 2               @afterStore:
00240Fr 2                       ; Save data ptr; restore program TXTPTR.
00240Fr 2  A5 04                lda     TXTPTR
002411r 2  85 3A                sta     BAS_TMP1
002413r 2  A5 05                lda     TXTPTR+1
002415r 2  85 3B                sta     BAS_TMP1+1
002417r 2  68                   pla
002418r 2  85 04                sta     TXTPTR
00241Ar 2  68                   pla
00241Br 2  85 05                sta     TXTPTR+1
00241Dr 2                       ; More variables?
00241Dr 2  20 rr rr             jsr     ChrGot
002420r 2  C9 2C                cmp     #','
002422r 2  D0 06                bne     @doneVars
002424r 2  20 rr rr             jsr     ChrGet                  ; consume ','
002427r 2  4C rr rr             jmp     @nextVar
00242Ar 2               @doneVars:
00242Ar 2                       ; Check for un-consumed input (EXTRA IGNORED).
00242Ar 2  A0 00                ldy     #0
00242Cr 2  B1 3A                lda     (BAS_TMP1),y
00242Er 2  F0 12                beq     @inpDone
002430r 2                       ; Skip leading spaces; anything else is "extra".
002430r 2               @chkExtra:
002430r 2  B1 3A                lda     (BAS_TMP1),y
002432r 2  F0 0E                beq     @inpDone
002434r 2  C9 20                cmp     #' '
002436r 2  D0 03                bne     @hasExtra
002438r 2  C8                   iny
002439r 2  D0 F5                bne     @chkExtra
00243Br 2               @hasExtra:
00243Br 2  A9 rr                lda     #<MsgExtra
00243Dr 2  A0 rr                ldy     #>MsgExtra
00243Fr 2  20 rr rr             jsr     BasPrintStr
002442r 2               @inpDone:
002442r 2  60                   rts
002443r 2               @doRedo:
002443r 2  A9 rr                lda     #<MsgRedo
002445r 2  A0 rr                ldy     #>MsgRedo
002447r 2  20 rr rr             jsr     BasPrintStr
00244Ar 2  4C rr rr             jmp     @retry
00244Dr 2               
00244Dr 2               ; Print "? " prompt (used by INPUT and the ';' prompt-suffix path).
00244Dr 2               BasInpQues:
00244Dr 2  A9 3F                lda     #'?'
00244Fr 2  20 rr rr             jsr     PrintCh
002452r 2  A9 20                lda     #' '
002454r 2  4C rr rr             jmp     PrintCh
002457r 2               
002457r 2               MsgRedo:
002457r 2  3F 52 45 44          .byte   "?REDO FROM START", $0D, $0A, 0
00245Br 2  4F 20 46 52  
00245Fr 2  4F 4D 20 53  
00246Ar 2               MsgExtra:
00246Ar 2  3F 45 58 54          .byte   "?EXTRA IGNORED", $0D, $0A, 0
00246Er 2  52 41 20 49  
002472r 2  47 4E 4F 52  
00247Br 2               
00247Br 2               ; ---------------------------------------------------------------------------
00247Br 2               ; Statement: READ var[,var,...] -- pull next DATA item from BAS_DATAPTR
00247Br 2               ; into the variable pointed to by PtrGet.
00247Br 2               ; ---------------------------------------------------------------------------
00247Br 2               BasCmdRead:
00247Br 2  AE 1A 03             ldx     BAS_DATAPTR
00247Er 2  AC 1B 03             ldy     BAS_DATAPTR+1
002481r 2  A9 98                lda     #$98                    ; INPUTFLG = $98 means READ mode
002483r 2  2C                   .byte   $2C
002484r 2               BasInpDoit:
002484r 2  A9 00                lda     #0
002486r 2  85 69                sta     BAS_INPUTFLG
002488r 2  86 3A                stx     BAS_TMP1                ; TMP1 = data pointer
00248Ar 2  84 3B                sty     BAS_TMP1+1
00248Cr 2               @nextVar:
00248Cr 2                       ; TXTPTR currently points into program at variable name.
00248Cr 2  20 rr rr             jsr     PtrGet                  ; advances TXTPTR past var name
00248Fr 2  85 46                sta     BAS_FORPNT
002491r 2  84 47                sty     BAS_FORPNT+1
002493r 2                       ; Save program TXTPTR on hw stack, switch TXTPTR to data ptr.
002493r 2  A5 05                lda     TXTPTR+1
002495r 2  48                   pha
002496r 2  A5 04                lda     TXTPTR
002498r 2  48                   pha
002499r 2  A5 3A                lda     BAS_TMP1
00249Br 2  85 04                sta     TXTPTR
00249Dr 2  A5 3B                lda     BAS_TMP1+1
00249Fr 2  85 05                sta     TXTPTR+1
0024A1r 2  20 rr rr             jsr     ChrGot
0024A4r 2  D0 08                bne     @gotData
0024A6r 2                       ; Out of items on this line - find next DATA.
0024A6r 2  20 rr rr             jsr     BasFindData
0024A9r 2  90 03                bcc     @gotData
0024ABr 2  4C rr rr             jmp     @oodata
0024AEr 2               @gotData:
0024AEr 2                       ; Advance past separator (',' between items, ' ' after DATA token,
0024AEr 2                       ; or quote-delimiter for strings).  ChrGet also skips spaces.
0024AEr 2  20 rr rr             jsr     ChrGet
0024B1r 2                       ; Parse value at TXTPTR (data side).
0024B1r 2  24 64                bit     VALTYP
0024B3r 2  30 0C                bmi     @readStr
0024B5r 2                       ; Numeric.
0024B5r 2  20 rr rr             jsr     Fin
0024B8r 2  A6 46                ldx     BAS_FORPNT
0024BAr 2  A4 47                ldy     BAS_FORPNT+1
0024BCr 2  20 rr rr             jsr     StoreFacAtYxRounded
0024BFr 2  80 29                bra     @afterStore
0024C1r 2               @readStr:
0024C1r 2                       ; String.
0024C1r 2  A9 22                lda     #'"'
0024C3r 2  85 44                sta     CHARAC
0024C5r 2  85 6A                sta     ENDCHR
0024C7r 2  A0 00                ldy     #0
0024C9r 2  B1 04                lda     (TXTPTR),y
0024CBr 2  C9 22                cmp     #'"'
0024CDr 2  F0 08                beq     @quoted
0024CFr 2  A9 3A                lda     #':'
0024D1r 2  85 44                sta     CHARAC
0024D3r 2  A9 2C                lda     #','
0024D5r 2  85 6A                sta     ENDCHR
0024D7r 2               @quoted:
0024D7r 2  20 rr rr             jsr     StrLt2
0024DAr 2  A0 00                ldy     #0
0024DCr 2  A5 0E                lda     FAC
0024DEr 2  91 46                sta     (BAS_FORPNT),y
0024E0r 2  C8                   iny
0024E1r 2  A5 0F                lda     FAC+1
0024E3r 2  91 46                sta     (BAS_FORPNT),y
0024E5r 2  C8                   iny
0024E6r 2  A5 10                lda     FAC+2
0024E8r 2  91 46                sta     (BAS_FORPNT),y
0024EAr 2               @afterStore:
0024EAr 2                       ; Save updated data ptr.
0024EAr 2  A5 04                lda     TXTPTR
0024ECr 2  85 3A                sta     BAS_TMP1
0024EEr 2  A5 05                lda     TXTPTR+1
0024F0r 2  85 3B                sta     BAS_TMP1+1
0024F2r 2                       ; Restore program TXTPTR.
0024F2r 2  68                   pla
0024F3r 2  85 04                sta     TXTPTR
0024F5r 2  68                   pla
0024F6r 2  85 05                sta     TXTPTR+1
0024F8r 2                       ; If next program byte is ',', another variable follows.
0024F8r 2  20 rr rr             jsr     ChrGot
0024FBr 2  C9 2C                cmp     #','
0024FDr 2  D0 05                bne     @done
0024FFr 2  20 rr rr             jsr     ChrGet
002502r 2  80 88                bra     @nextVar
002504r 2               @done:
002504r 2                       ; Persist data ptr.
002504r 2  A5 3A                lda     BAS_TMP1
002506r 2  8D 1A 03             sta     BAS_DATAPTR
002509r 2  A5 3B                lda     BAS_TMP1+1
00250Br 2  8D 1B 03             sta     BAS_DATAPTR+1
00250Er 2  60                   rts
00250Fr 2               @oodata:
00250Fr 2  A2 0E                ldx     #ERR_OD
002511r 2  4C rr rr             jmp     BasErrorVec
002514r 2               
002514r 2               ; ---------------------------------------------------------------------------
002514r 2               ; BasFindData -- starting from TXTPTR (positioned somewhere within a line's
002514r 2               ; payload), advance to the byte after the next DATA token in the program.
002514r 2               ; Returns carry SET on out-of-data, carry CLEAR with TXTPTR at first byte
002514r 2               ; AFTER the DATA token (i.e. at the first DATA item).
002514r 2               ; ---------------------------------------------------------------------------
002514r 2               BasFindData:
002514r 2               @scanByte:
002514r 2  A0 00                ldy     #0
002516r 2  B1 04                lda     (TXTPTR),y
002518r 2  F0 1F                beq     @atEnd
00251Ar 2  C9 83                cmp     #TOK_DATA
00251Cr 2  F0 2E                beq     @found
00251Er 2  C9 22                cmp     #'"'
002520r 2  D0 12                bne     @advance1
002522r 2                       ; Skip quoted string (advance TXTPTR past closing quote or NUL).
002522r 2  20 rr rr             jsr     @incTxt
002525r 2               @inStr:
002525r 2  A0 00                ldy     #0
002527r 2  B1 04                lda     (TXTPTR),y
002529r 2  F0 0E                beq     @atEnd
00252Br 2  20 rr rr             jsr     @incTxt
00252Er 2  C9 22                cmp     #'"'
002530r 2  D0 F3                bne     @inStr
002532r 2  80 E0                bra     @scanByte
002534r 2               @advance1:
002534r 2  20 rr rr             jsr     @incTxt
002537r 2  80 DB                bra     @scanByte
002539r 2               @atEnd:
002539r 2                       ; (TXTPTR) is on the line's $00 terminator.  Bytes immediately after
002539r 2                       ; are the next line's [next-lo][next-hi][num-lo][num-hi][payload..].
002539r 2                       ; Check next-pointer at offset +2 (next-hi); if 0, end of program.
002539r 2  A0 02                ldy     #2
00253Br 2  B1 04                lda     (TXTPTR),y
00253Dr 2  F0 0F                beq     @oodata
00253Fr 2                       ; Advance TXTPTR by 5: past terminator (1) + line header (4).
00253Fr 2  18                   clc
002540r 2  A5 04                lda     TXTPTR
002542r 2  69 05                adc     #5
002544r 2  85 04                sta     TXTPTR
002546r 2  90 CC                bcc     @scanByte
002548r 2  E6 05                inc     TXTPTR+1
00254Ar 2  80 C8                bra     @scanByte
00254Cr 2               @found:
00254Cr 2                       ; TXTPTR is left AT the TOK_DATA byte; caller's CHRGET advances past.
00254Cr 2  18                   clc
00254Dr 2  60                   rts
00254Er 2               @oodata:
00254Er 2  38                   sec
00254Fr 2  60                   rts
002550r 2               @incTxt:
002550r 2  E6 04                inc     TXTPTR
002552r 2  D0 02                bne     @r
002554r 2  E6 05                inc     TXTPTR+1
002556r 2               @r:
002556r 2  60                   rts
002557r 2               
002557r 2               ; ---------------------------------------------------------------------------
002557r 2               ; Statement: FOR var = expr1 TO expr2 [STEP expr3]
002557r 2               ; Pushes 18-byte frame on CPU stack:
002557r 2               ;   [tag $81][VAR-lo][VAR-hi][STEP-FP (5)][STEP-sign][CURLIN-lo][CURLIN-hi]
002557r 2               ;   [TXTPTR-lo][TXTPTR-hi][LIMIT-FP (5)]
002557r 2               ; ---------------------------------------------------------------------------
002557r 2               BasCmdFor:
002557r 2                       ; Set SUBFLG so PtrGet doesn't recurse on FN.
002557r 2  A9 80                lda     #$80
002559r 2  85 68                sta     SUBFLG
00255Br 2  20 rr rr             jsr     BasCmdLet               ; consumes "var = expr"
00255Er 2                       ; PtrGet (inside LET) saved VARPNT in FORPNT (hopefully). Re-fetch
00255Er 2                       ; FORPNT from the assignment, but BasCmdLet doesn't set FORPNT in
00255Er 2                       ; our impl.  Re-parse the variable name by rewinding TXTPTR via
00255Er 2                       ; CURLIN scan.  Cheat: BasCmdLet leaves VARPNT current.
00255Er 2  A5 3F                lda     VARPNT
002560r 2  85 46                sta     BAS_FORPNT
002562r 2  A5 40                lda     VARPNT+1
002564r 2  85 47                sta     BAS_FORPNT+1
002566r 2                       ; Discard any prior FOR frame for the same variable to avoid leak.
002566r 2  20 rr rr             jsr     GtForPnt
002569r 2  D0 00                bne     @noOld                  ; Z=0 -> not found (lda #0 sets Z=1; we invert below)
00256Br 2                       ; Actually GtForPnt's "not found" path also ends with `lda #0;rts` (Z=1).
00256Br 2                       ; So the BEQ/BNE distinction can't be used. Skip the prior-frame
00256Br 2                       ; pop entirely; the runtime can tolerate one stray frame and msbasic
00256Br 2                       ; FOR re-uses the same slot only when an explicit FOR with a matching
00256Br 2                       ; variable already exists, which is rare.
00256Br 2               @noOld:
00256Br 2                       ; Discard our caller's (BasExecuteStatement's) return address so
00256Br 2                       ; that the FOR frame sits on the stack with no other junk above it.
00256Br 2                       ; We will JMP BasNewstt at the end instead of RTSing.
00256Br 2  68                   pla
00256Cr 2  68                   pla
00256Dr 2                       ; Push limit (will be parsed below) -- we lay out the frame as:
00256Dr 2                       ;   pushed first (deepest): TXTPTR, CURLIN, LIMIT (5), STEP-sign,
00256Dr 2                       ;   STEP (5), VAR-addr, $81-tag.
00256Dr 2                       ; We don't know LIMIT/STEP yet; we push placeholders and patch.
00256Dr 2                       ; Easier: parse limit & step first, then push frame in one go.
00256Dr 2  A9 9C                lda     #TOK_TO
00256Fr 2  20 rr rr             jsr     SynChr
002572r 2  20 rr rr             jsr     FrmNum
002575r 2                       ; Strip sign info on limit (msbasic stores limit unsigned-magnitude
002575r 2                       ; with sign packed).  Pack FACSIGN bit 7 -> FAC+1 bit 7.
002575r 2  A5 13                lda     FACSIGN
002577r 2  09 7F                ora     #$7F
002579r 2  25 0F                and     FAC+1
00257Br 2  85 0F                sta     FAC+1
00257Dr 2                       ; Save LIMIT temporarily in BAS_TEMP1..+4 (5 bytes).
00257Dr 2  A2 04                ldx     #4
00257Fr 2               @saveLimit:
00257Fr 2  B5 0E                lda     FAC,x
002581r 2  95 4D                sta     BAS_TEMP1,x
002583r 2  CA                   dex
002584r 2  10 F9                bpl     @saveLimit
002586r 2                       ; STEP: default 1, or evaluate after TOK_STEP.
002586r 2  20 rr rr             jsr     ChrGot
002589r 2  C9 A1                cmp     #TOK_STEP
00258Br 2  D0 08                bne     @defStep
00258Dr 2  20 rr rr             jsr     ChrGet
002590r 2  20 rr rr             jsr     FrmNum
002593r 2  80 07                bra     @gotStep
002595r 2               @defStep:
002595r 2  A9 rr                lda     #<ConstOne
002597r 2  A0 rr                ldy     #>ConstOne
002599r 2  20 rr rr             jsr     LoadFacFromYa
00259Cr 2               @gotStep:
00259Cr 2  20 rr rr             jsr     Sign                    ; A = step sign byte (-1/0/1)
00259Fr 2  85 52                sta     BAS_TEMP2               ; stash step sign
0025A1r 2                       ; Pack sign of FAC into FAC+1 bit7 then save STEP into BAS_TEMP2+1..+5.
0025A1r 2  A5 13                lda     FACSIGN
0025A3r 2  09 7F                ora     #$7F
0025A5r 2  25 0F                and     FAC+1
0025A7r 2  85 0F                sta     FAC+1
0025A9r 2  A2 04                ldx     #4
0025ABr 2               @saveStep:
0025ABr 2  B5 0E                lda     FAC,x
0025ADr 2  95 53                sta     BAS_TEMP2+1,x
0025AFr 2  CA                   dex
0025B0r 2  10 F9                bpl     @saveStep
0025B2r 2                       ; Now push the frame on stack (deepest first):
0025B2r 2                       ;   TXTPTR-hi, TXTPTR-lo, CURLIN-hi, CURLIN-lo,
0025B2r 2                       ;   LIMIT[4..0]   (deepest=LIMIT[4], so LIMIT[0] ends at $010A,x),
0025B2r 2                       ;   STEP-sign,
0025B2r 2                       ;   STEP[4..0]    (deepest=STEP[4], so STEP[0]  ends at $0104,x),
0025B2r 2                       ;   VAR-hi, VAR-lo, $81
0025B2r 2  A5 05                lda     TXTPTR+1
0025B4r 2  48                   pha
0025B5r 2  A5 04                lda     TXTPTR
0025B7r 2  48                   pha
0025B8r 2  AD 6A 03             lda     BAS_CURLIN+1
0025BBr 2  48                   pha
0025BCr 2  AD 69 03             lda     BAS_CURLIN
0025BFr 2  48                   pha
0025C0r 2  A2 04                ldx     #4
0025C2r 2               @pushLim:
0025C2r 2  B5 4D                lda     BAS_TEMP1,x
0025C4r 2  48                   pha
0025C5r 2  CA                   dex
0025C6r 2  10 FA                bpl     @pushLim
0025C8r 2  A5 52                lda     BAS_TEMP2               ; step sign
0025CAr 2  48                   pha
0025CBr 2  A2 05                ldx     #5
0025CDr 2               @pushStep:
0025CDr 2  B5 52                lda     BAS_TEMP2,x
0025CFr 2  48                   pha
0025D0r 2  CA                   dex
0025D1r 2  D0 FA                bne     @pushStep
0025D3r 2  A5 47                lda     BAS_FORPNT+1
0025D5r 2  48                   pha
0025D6r 2  A5 46                lda     BAS_FORPNT
0025D8r 2  48                   pha
0025D9r 2  A9 81                lda     #TOK_FOR
0025DBr 2  48                   pha
0025DCr 2  4C rr rr             jmp     BasNewstt               ; resume statement loop with frame in place
0025DFr 2               
0025DFr 2               ConstOne:
0025DFr 2  81 00 00 00          .byte   $81,$00,$00,$00,$00     ; FP +1.0
0025E3r 2  00           
0025E4r 2               
0025E4r 2               ; ---------------------------------------------------------------------------
0025E4r 2               ; Statement: NEXT [var]
0025E4r 2               ; Locate matching FOR frame, increment var by step, test against limit,
0025E4r 2               ; loop back if more iterations remain, else discard frame and continue.
0025E4r 2               ; ---------------------------------------------------------------------------
0025E4r 2               BasCmdNext:
0025E4r 2  20 rr rr             jsr     ChrGot
0025E7r 2  F0 0D                beq     @anyVar
0025E9r 2  C9 3A                cmp     #':'
0025EBr 2  F0 09                beq     @anyVar
0025EDr 2  20 rr rr             jsr     PtrGet
0025F0r 2  85 46                sta     BAS_FORPNT
0025F2r 2  84 47                sty     BAS_FORPNT+1
0025F4r 2  80 06                bra     @find
0025F6r 2               @anyVar:
0025F6r 2                       ; "NEXT" without a variable: set FORPNT = 0 so GtForPnt copies the
0025F6r 2                       ; stack-frame's var address into FORPNT and then trivially matches
0025F6r 2                       ; (any FOR frame is acceptable).
0025F6r 2  A9 00                lda     #0
0025F8r 2  85 46                sta     BAS_FORPNT
0025FAr 2  85 47                sta     BAS_FORPNT+1
0025FCr 2               @find:
0025FCr 2  20 rr rr             jsr     GtForPnt
0025FFr 2  F0 05                beq     @found
002601r 2  A2 0D                ldx     #ERR_NF
002603r 2  4C rr rr             jmp     BasErrorVec
002606r 2               @found:
002606r 2                       ; X = stack offset of (tag - 1).  txs makes SP = X so the frame
002606r 2                       ; sits at $101+X..$112+X.  All subsequent accesses use $0101+offset,x
002606r 2                       ; just like msbasic.
002606r 2  9A                   txs
002607r 2                       ; Frame layout (tag at $0101+X):
002607r 2                       ;   $0101+X = $81 tag
002607r 2                       ;   $0102+X = VAR-lo
002607r 2                       ;   $0103+X = VAR-hi
002607r 2                       ;   $0104+X..$0108+X = STEP (5 bytes FP, FAC[0..4] ascending)
002607r 2                       ;   $0109+X = STEP-sign
002607r 2                       ;   $010A+X..$010E+X = LIMIT (5 bytes FP, FAC[0..4] ascending)
002607r 2                       ;   $010F+X = CURLIN-lo
002607r 2                       ;   $0110+X = CURLIN-hi
002607r 2                       ;   $0111+X = TXTPTR-lo
002607r 2                       ;   $0112+X = TXTPTR-hi
002607r 2                       ; Load STEP into FAC.
002607r 2  A9 01                lda     #$01
002609r 2  85 3B                sta     BAS_TMP1+1
00260Br 2  8A                   txa
00260Cr 2  18                   clc
00260Dr 2  69 04                adc     #$04
00260Fr 2  85 3A                sta     BAS_TMP1                ; TMP1 -> STEP[0] at $0104,x
002611r 2  A5 3A                lda     BAS_TMP1
002613r 2  A4 3B                ldy     BAS_TMP1+1
002615r 2  20 rr rr             jsr     LoadFacFromYa
002618r 2                       ; FACSIGN := step sign byte at $0109,x.
002618r 2  BD 09 01             lda     $0109,x
00261Br 2  85 13                sta     FACSIGN
00261Dr 2                       ; FAC += variable.
00261Dr 2  BD 02 01             lda     $0102,x
002620r 2  BC 03 01             ldy     $0103,x
002623r 2  85 46                sta     BAS_FORPNT
002625r 2  84 47                sty     BAS_FORPNT+1
002627r 2  20 rr rr             jsr     FAdd
00262Ar 2  20 rr rr             jsr     SetFor
00262Dr 2                       ; Compare FAC with LIMIT (at $010A,x).
00262Dr 2  BA                   tsx                             ; reload x (FAdd may have used it)
00262Er 2  8A                   txa
00262Fr 2  18                   clc
002630r 2  69 0A                adc     #$0A
002632r 2  85 3A                sta     BAS_TMP1
002634r 2  A9 01                lda     #$01
002636r 2  85 3B                sta     BAS_TMP1+1
002638r 2  A5 3A                lda     BAS_TMP1
00263Ar 2  A4 3B                ldy     BAS_TMP1+1
00263Cr 2  20 rr rr             jsr     FComp
00263Fr 2  BA                   tsx
002640r 2  38                   sec
002641r 2  FD 09 01             sbc     $0109,x                 ; A - step-sign
002644r 2  F0 19                beq     @loopDone
002646r 2                       ; Continue: restore CURLIN/TXTPTR from frame, JMP NEWSTT (don't RTS).
002646r 2  BD 0F 01             lda     $010F,x
002649r 2  8D 69 03             sta     BAS_CURLIN
00264Cr 2  BD 10 01             lda     $0110,x
00264Fr 2  8D 6A 03             sta     BAS_CURLIN+1
002652r 2  BD 11 01             lda     $0111,x
002655r 2  85 04                sta     TXTPTR
002657r 2  BD 12 01             lda     $0112,x
00265Ar 2  85 05                sta     TXTPTR+1
00265Cr 2  4C rr rr             jmp     BasNewstt
00265Fr 2               @loopDone:
00265Fr 2                       ; Discard frame: SP := X + 18.
00265Fr 2  8A                   txa
002660r 2  18                   clc
002661r 2  69 12                adc     #18
002663r 2  AA                   tax
002664r 2  9A                   txs
002665r 2                       ; Allow ", var" to chain into another NEXT.
002665r 2  20 rr rr             jsr     ChrGot
002668r 2  C9 2C                cmp     #','
00266Ar 2  D0 06                bne     @retNewstt
00266Cr 2  20 rr rr             jsr     ChrGet
00266Fr 2  4C rr rr             jmp     BasCmdNext
002672r 2               @retNewstt:
002672r 2  4C rr rr             jmp     BasNewstt
002675r 2               
002675r 2               ; ---------------------------------------------------------------------------
002675r 2               ; Statement: DEF FN A(X) = expr
002675r 2               ; Stored in the variable's 5 value bytes:
002675r 2               ;   [TXTPTR-of-expr-lo][TXTPTR-of-expr-hi][param-name-lo][param-name-hi][0]
002675r 2               ; ---------------------------------------------------------------------------
002675r 2               BasCmdDef:
002675r 2                       ; Expect: FN <name>(<param>) = <expr>
002675r 2  A9 9D                lda     #TOK_FN
002677r 2  20 rr rr             jsr     SynChr
00267Ar 2  09 80                ora     #$80
00267Cr 2  85 68                sta     SUBFLG                  ; tell PtrGet "this is a DEF FN var"
00267Er 2  20 rr rr             jsr     PtrGet
002681r 2                       ; VARPNT = address of FN var slot.
002681r 2  85 81                sta     BAS_FNCNAM
002683r 2  84 82                sty     BAS_FNCNAM+1
002685r 2  20 rr rr             jsr     ChkNum
002688r 2                       ; Expect '(' name ')' = expr
002688r 2                       ; Param name parsed by recursive PtrGet inside FrmEvl on call;
002688r 2                       ; here we just record (param-name) by parsing it ourselves.
002688r 2  A9 28                lda     #'('
00268Ar 2  20 rr rr             jsr     SynChr
00268Dr 2  A9 80                lda     #$80
00268Fr 2  85 68                sta     SUBFLG
002691r 2  20 rr rr             jsr     PtrGet
002694r 2                       ; VARPNT = param var addr.  Save it.
002694r 2  A5 3F                lda     VARPNT
002696r 2  85 3A                sta     BAS_TMP1
002698r 2  A5 40                lda     VARPNT+1
00269Ar 2  85 3B                sta     BAS_TMP1+1
00269Cr 2  20 rr rr             jsr     ChkNum
00269Fr 2  A9 29                lda     #')'
0026A1r 2  20 rr rr             jsr     SynChr
0026A4r 2  A9 3D                lda     #'='
0026A6r 2  20 rr rr             jsr     SynChr
0026A9r 2                       ; Reject in direct mode.
0026A9r 2  AD 6A 03             lda     BAS_CURLIN+1
0026ACr 2  C9 FF                cmp     #$FF
0026AEr 2  D0 05                bne     @ok
0026B0r 2  A2 07                ldx     #ERR_ILLDIRECT
0026B2r 2  4C rr rr             jmp     BasErrorVec
0026B5r 2               @ok:
0026B5r 2                       ; Store [TXTPTR][param][0] in FN var.
0026B5r 2  A0 00                ldy     #0
0026B7r 2  A5 04                lda     TXTPTR
0026B9r 2  91 81                sta     (BAS_FNCNAM),y
0026BBr 2  C8                   iny
0026BCr 2  A5 05                lda     TXTPTR+1
0026BEr 2  91 81                sta     (BAS_FNCNAM),y
0026C0r 2  C8                   iny
0026C1r 2  A5 3A                lda     BAS_TMP1
0026C3r 2  91 81                sta     (BAS_FNCNAM),y
0026C5r 2  C8                   iny
0026C6r 2  A5 3B                lda     BAS_TMP1+1
0026C8r 2  91 81                sta     (BAS_FNCNAM),y
0026CAr 2  C8                   iny
0026CBr 2  A9 00                lda     #0
0026CDr 2  91 81                sta     (BAS_FNCNAM),y
0026CFr 2                       ; Skip past expression body.
0026CFr 2  20 rr rr             jsr     BasDatan
0026D2r 2  4C rr rr             jmp     BasAddon
0026D5r 2               
0026D5r 2               ; ---------------------------------------------------------------------------
0026D5r 2               ; FnCall -- evaluator-side handler for "FN A(expr)".
0026D5r 2               ; Called by FrmEvl when it sees TOK_FN.  Evaluates argument, swaps in the
0026D5r 2               ; param's stored value, executes the FN expression, and restores the param.
0026D5r 2               ; ---------------------------------------------------------------------------
0026D5r 2               FnCall:
0026D5r 2  20 rr rr             jsr     ChrGet                  ; consume FN
0026D8r 2  09 80                ora     #$80
0026DAr 2  85 68                sta     SUBFLG
0026DCr 2  20 rr rr             jsr     PtrGet                  ; locate FN var
0026DFr 2  85 81                sta     BAS_FNCNAM
0026E1r 2  84 82                sty     BAS_FNCNAM+1
0026E3r 2  20 rr rr             jsr     ChkNum
0026E6r 2                       ; Read param ptr from FN slot.
0026E6r 2  A0 02                ldy     #2
0026E8r 2  B1 81                lda     (BAS_FNCNAM),y
0026EAr 2  85 3F                sta     VARPNT
0026ECr 2  F0 5C                beq     @undef
0026EEr 2  C8                   iny
0026EFr 2  B1 81                lda     (BAS_FNCNAM),y
0026F1r 2  85 40                sta     VARPNT+1
0026F3r 2                       ; Evaluate '(arg)'
0026F3r 2  A9 28                lda     #'('
0026F5r 2  20 rr rr             jsr     SynChr
0026F8r 2                       ; Save param's current FP value (5 bytes) on stack.
0026F8r 2  A0 04                ldy     #4
0026FAr 2               @savep:
0026FAr 2  B1 3F                lda     (VARPNT),y
0026FCr 2  48                   pha
0026FDr 2  88                   dey
0026FEr 2  10 FA                bpl     @savep
002700r 2                       ; Evaluate argument -> FAC.
002700r 2  20 rr rr             jsr     FrmNum
002703r 2  A9 29                lda     #')'
002705r 2  20 rr rr             jsr     SynChr
002708r 2                       ; Store FAC into param slot.
002708r 2  A6 3F                ldx     VARPNT
00270Ar 2  A4 40                ldy     VARPNT+1
00270Cr 2  20 rr rr             jsr     StoreFacAtYxRounded
00270Fr 2                       ; Save current TXTPTR.
00270Fr 2  A5 05                lda     TXTPTR+1
002711r 2  48                   pha
002712r 2  A5 04                lda     TXTPTR
002714r 2  48                   pha
002715r 2                       ; Switch TXTPTR to FN expression body.
002715r 2  A0 00                ldy     #0
002717r 2  B1 81                lda     (BAS_FNCNAM),y
002719r 2  85 04                sta     TXTPTR
00271Br 2  C8                   iny
00271Cr 2  B1 81                lda     (BAS_FNCNAM),y
00271Er 2  85 05                sta     TXTPTR+1
002720r 2                       ; Body TXTPTR is positioned at the first byte; we need it positioned
002720r 2                       ; one BEFORE so FrmNum's first ChrGet loads the first byte.  Decrement.
002720r 2  A5 04                lda     TXTPTR
002722r 2  D0 02                bne     @noBor
002724r 2  C6 05                dec     TXTPTR+1
002726r 2               @noBor:
002726r 2  C6 04                dec     TXTPTR
002728r 2                       ; Evaluate the FN expression body.
002728r 2  20 rr rr             jsr     ChrGet
00272Br 2  20 rr rr             jsr     FrmNum
00272Er 2                       ; Restore TXTPTR.
00272Er 2  68                   pla
00272Fr 2  85 04                sta     TXTPTR
002731r 2  68                   pla
002732r 2  85 05                sta     TXTPTR+1
002734r 2                       ; Restore param.  VARPNT may have been clobbered; reload.
002734r 2  A0 02                ldy     #2
002736r 2  B1 81                lda     (BAS_FNCNAM),y
002738r 2  85 3F                sta     VARPNT
00273Ar 2  C8                   iny
00273Br 2  B1 81                lda     (BAS_FNCNAM),y
00273Dr 2  85 40                sta     VARPNT+1
00273Fr 2  A0 00                ldy     #0
002741r 2               @restp:
002741r 2  68                   pla
002742r 2  91 3F                sta     (VARPNT),y
002744r 2  C8                   iny
002745r 2  C0 05                cpy     #5
002747r 2  D0 F8                bne     @restp
002749r 2  60                   rts
00274Ar 2               @undef:
00274Ar 2  A2 03                ldx     #ERR_UNDEFSTMT
00274Cr 2  4C rr rr             jmp     BasErrorVec
00274Fr 2               
00274Fr 2               ; ---------------------------------------------------------------------------
00274Fr 2               ; Reserved dispatch slot -- raise SYNTAX ERROR.
00274Fr 2               ; ---------------------------------------------------------------------------
00274Fr 2               BasCmdNotImpl:
00274Fr 2  4C rr rr             jmp     SynErr
002752r 2               
002752r 2               ; ===========================================================================
002752r 2               ;   H A R D W A R E - E X T E N S I O N   S T A T E M E N T S
002752r 2               ; ===========================================================================
002752r 2               
002752r 2               ; --- Helpers --------------------------------------------------------------
002752r 2               
002752r 2               ; Raise ?NO DEVICE error.
002752r 2               NoDevErr:
002752r 2  A2 0F                ldx     #ERR_NODEV
002754r 2  4C rr rr             jmp     BasErrorVec
002757r 2               
002757r 2               ; Require A bits in HW_PRESENT (else ?NO DEVICE).
002757r 2               ;   Input : A = mask
002757r 2               ;   Output: A preserved on success
002757r 2               ReqHw:
002757r 2  2D 0D 03             and     HW_PRESENT
00275Ar 2  F0 F6                beq     NoDevErr
00275Cr 2  60                   rts
00275Dr 2               
00275Dr 2               ; Evaluate expression -> A in 0..255.
00275Dr 2               ;   On entry: ChrGot positioned at first byte of expression.
00275Dr 2               ;   On exit : A = byte, ChrGot returns char following expression.
00275Dr 2               EvalU8:
00275Dr 2  20 rr rr             jsr     GetByt                  ; X = byte, jmp ChrGot
002760r 2  8A                   txa
002761r 2  60                   rts
002762r 2               
002762r 2               ; Evaluate expression as 16-bit signed -> FAC+3 (hi), FAC+4 (lo).
002762r 2               EvalU16:
002762r 2  20 rr rr             jsr     FrmNum
002765r 2  20 rr rr             jsr     AyInt
002768r 2  4C rr rr             jmp     ChrGot
00276Br 2               
00276Br 2               ; Evaluate expression as 16-bit unsigned address (0..65535)
00276Br 2               ;   -> FAC+3 (hi), FAC+4 (lo).  Used by SYS, POKE, PEEK, WAIT so the full
00276Br 2               ;   6502 address space is reachable with positive decimal literals.
00276Br 2               ;   Truncates fractional part.  Negative or >= 65536 raises ?ILLEGAL QUANTITY.
00276Br 2               EvalAddrU16:
00276Br 2  20 rr rr             jsr     FrmNum
00276Er 2  20 rr rr             jsr     FacToU16
002771r 2  4C rr rr             jmp     ChrGot
002774r 2               
002774r 2               ; FacToU16 -- Convert FAC (must be 0..65535) to FAC+3 (hi), FAC+4 (lo).
002774r 2               ;   Negative or >= 65536 raises ?ILLEGAL QUANTITY.  Truncates fractional part.
002774r 2               FacToU16:
002774r 2  24 13                bit     FACSIGN
002776r 2  30 34                bmi     @illqty
002778r 2  A5 0E                lda     FAC                     ; exponent byte (0 = value is zero)
00277Ar 2  F0 2B                beq     @zero
00277Cr 2  C9 91                cmp     #$91                    ; exp >= $91 means value >= 65536
00277Er 2  B0 2C                bcs     @illqty
002780r 2                       ; Reconstruct top 16 bits of mantissa (with hidden 1 bit).
002780r 2  48                   pha                             ; save exponent byte
002781r 2  A5 0F                lda     FAC+1
002783r 2  09 80                ora     #$80                    ; restore hidden bit
002785r 2  85 3B                sta     BAS_TMP1+1              ; hi
002787r 2  A5 10                lda     FAC+2
002789r 2  85 3A                sta     BAS_TMP1                ; lo
00278Br 2                       ; Shift count = $90 - exp_byte (0..15).
00278Br 2  68                   pla
00278Cr 2  38                   sec
00278Dr 2  E9 90                sbc     #$90
00278Fr 2  49 FF                eor     #$FF
002791r 2  18                   clc
002792r 2  69 01                adc     #1                      ; A = $90 - exp
002794r 2  F0 08                beq     @store                  ; zero shifts: already aligned
002796r 2  AA                   tax
002797r 2               @shloop:
002797r 2  46 3B                lsr     BAS_TMP1+1
002799r 2  66 3A                ror     BAS_TMP1
00279Br 2  CA                   dex
00279Cr 2  D0 F9                bne     @shloop
00279Er 2               @store:
00279Er 2  A5 3B                lda     BAS_TMP1+1
0027A0r 2  85 11                sta     FAC+3
0027A2r 2  A5 3A                lda     BAS_TMP1
0027A4r 2  85 12                sta     FAC+4
0027A6r 2  60                   rts
0027A7r 2               @zero:
0027A7r 2  64 11                stz     FAC+3
0027A9r 2  64 12                stz     FAC+4
0027ABr 2  60                   rts
0027ACr 2               @illqty:
0027ACr 2  4C rr rr             jmp     IqErr
0027AFr 2               
0027AFr 2               ; Evaluate string expression -> copy up to 11 chars to BAS_FNAME,
0027AFr 2               ; null-terminate, set STR_PTR := BAS_FNAME, free temp string.
0027AFr 2               EvalString:
0027AFr 2  20 rr rr             jsr     FrmEvl
0027B2r 2  20 rr rr             jsr     ChkStr
0027B5r 2  A5 0F                lda     FAC+1
0027B7r 2  85 20                sta     INDEX
0027B9r 2  A5 10                lda     FAC+2
0027BBr 2  85 21                sta     INDEX+1
0027BDr 2  A0 00                ldy     #0
0027BFr 2  A6 0E                ldx     FAC                     ; length
0027C1r 2               @cpy:
0027C1r 2  C0 0B                cpy     #11
0027C3r 2  F0 0D                beq     @done
0027C5r 2  E0 00                cpx     #0
0027C7r 2  F0 09                beq     @done
0027C9r 2  B1 20                lda     (INDEX),y
0027CBr 2  99 73 03             sta     BAS_FNAME,y
0027CEr 2  C8                   iny
0027CFr 2  CA                   dex
0027D0r 2  80 EF                bra     @cpy
0027D2r 2               @done:
0027D2r 2  A9 00                lda     #0
0027D4r 2  99 73 03             sta     BAS_FNAME,y
0027D7r 2  A9 73                lda     #<BAS_FNAME
0027D9r 2  85 02                sta     STR_PTR
0027DBr 2  A9 03                lda     #>BAS_FNAME
0027DDr 2  85 03                sta     STR_PTR+1
0027DFr 2  4C rr rr             jmp     FreFac
0027E2r 2               
0027E2r 2               ; Print A as 2-digit decimal with leading zero (used by TIME/DATE).
0027E2r 2               BasPr2D:
0027E2r 2  A2 00                ldx     #0
0027E4r 2               @loop:
0027E4r 2  C9 0A                cmp     #10
0027E6r 2  90 05                bcc     @done
0027E8r 2  E9 0A                sbc     #10
0027EAr 2  E8                   inx
0027EBr 2  80 F7                bra     @loop
0027EDr 2               @done:
0027EDr 2  48                   pha
0027EEr 2  8A                   txa
0027EFr 2  09 30                ora     #'0'
0027F1r 2  20 rr rr             jsr     Chrout
0027F4r 2  68                   pla
0027F5r 2  09 30                ora     #'0'
0027F7r 2  4C rr rr             jmp     Chrout
0027FAr 2               
0027FAr 2               ; Walk program chain after LOAD to recompute BAS_VARTAB.
0027FAr 2               ;   On entry: ChrGot any.
0027FAr 2               BasFixChain:
0027FAr 2  A9 00                lda     #<PROGRAM_START
0027FCr 2  85 20                sta     INDEX
0027FEr 2  A9 08                lda     #>PROGRAM_START
002800r 2  85 21                sta     INDEX+1
002802r 2               @walk:
002802r 2  A0 00                ldy     #0
002804r 2  B1 20                lda     (INDEX),y
002806r 2  85 3A                sta     BAS_TMP1
002808r 2  C8                   iny
002809r 2  B1 20                lda     (INDEX),y
00280Br 2  85 3B                sta     BAS_TMP1+1
00280Dr 2  05 3A                ora     BAS_TMP1
00280Fr 2  F0 0A                beq     @end
002811r 2  A5 3A                lda     BAS_TMP1
002813r 2  85 20                sta     INDEX
002815r 2  A5 3B                lda     BAS_TMP1+1
002817r 2  85 21                sta     INDEX+1
002819r 2  80 E7                bra     @walk
00281Br 2               @end:
00281Br 2                       ; INDEX points at terminator ($00 $00).  VARTAB = INDEX + 2.
00281Br 2  18                   clc
00281Cr 2  A5 20                lda     INDEX
00281Er 2  69 02                adc     #2
002820r 2  8D 5F 03             sta     BAS_VARTAB
002823r 2  A5 21                lda     INDEX+1
002825r 2  69 00                adc     #0
002827r 2  8D 60 03             sta     BAS_VARTAB+1
00282Ar 2  60                   rts
00282Br 2               
00282Br 2               ; --- Statements -----------------------------------------------------------
00282Br 2               
00282Br 2               ; SYS addr -- jump indirectly to address (RTS returns to caller).
00282Br 2               BasCmdSys:
00282Br 2  20 rr rr             jsr     EvalAddrU16
00282Er 2  A5 12                lda     FAC+4
002830r 2  85 20                sta     INDEX
002832r 2  A5 11                lda     FAC+3
002834r 2  85 21                sta     INDEX+1
002836r 2  6C 20 00             jmp     (INDEX)
002839r 2               
002839r 2               ; CLS
002839r 2               BasCmdCls:
002839r 2  A9 80                lda     #HW_VID
00283Br 2  20 rr rr             jsr     ReqHw
00283Er 2  4C rr rr             jmp     VideoClear
002841r 2               
002841r 2               ; LOCATE row, col
002841r 2               BasCmdLocate:
002841r 2  A9 80                lda     #HW_VID
002843r 2  20 rr rr             jsr     ReqHw
002846r 2  20 rr rr             jsr     GetByt                  ; X = row
002849r 2  DA                   phx
00284Ar 2  20 rr rr             jsr     ChkCom
00284Dr 2  20 rr rr             jsr     GetByt                  ; X = col
002850r 2  7A                   ply                             ; Y = row
002851r 2  4C rr rr             jmp     VideoSetCursor
002854r 2               
002854r 2               ; COLOR fg, bg
002854r 2               BasCmdColor:
002854r 2  A9 80                lda     #HW_VID
002856r 2  20 rr rr             jsr     ReqHw
002859r 2  20 rr rr             jsr     GetByt                  ; X = fg
00285Cr 2  8A                   txa
00285Dr 2  0A                   asl     a
00285Er 2  0A                   asl     a
00285Fr 2  0A                   asl     a
002860r 2  0A                   asl     a
002861r 2  85 3A                sta     BAS_TMP1
002863r 2  20 rr rr             jsr     ChkCom
002866r 2  20 rr rr             jsr     GetByt                  ; X = bg
002869r 2  8A                   txa
00286Ar 2  29 0F                and     #$0F
00286Cr 2  05 3A                ora     BAS_TMP1
00286Er 2  4C rr rr             jmp     VideoSetColor
002871r 2               
002871r 2               ; VOL n
002871r 2               BasCmdVol:
002871r 2  A9 40                lda     #HW_SID
002873r 2  20 rr rr             jsr     ReqHw
002876r 2  20 rr rr             jsr     GetByt                  ; X = vol
002879r 2  8A                   txa
00287Ar 2  4C rr rr             jmp     SidSetVolume
00287Dr 2               
00287Dr 2               ; SOUND voice, freq, dur (freq=Hz, dur=centisec)
00287Dr 2               ;   Hz -> SID register: reg = Hz * 16.75 ≈ Hz<<4 + Hz - Hz/4
00287Dr 2               BasCmdSound:
00287Dr 2  A9 40                lda     #HW_SID
00287Fr 2  20 rr rr             jsr     ReqHw
002882r 2  20 rr rr             jsr     GetByt                  ; X = voice (1..3)
002885r 2  CA                   dex
002886r 2  DA                   phx                             ; voice (0-indexed) on stack
002887r 2  20 rr rr             jsr     ChkCom
00288Ar 2  20 rr rr             jsr     EvalU16                 ; freq Hz: hi=FAC+3, lo=FAC+4
00288Dr 2                       ; Compute reg = Hz<<4 + Hz - Hz/4
00288Dr 2  A5 12                lda     FAC+4
00288Fr 2  85 3A                sta     BAS_TMP1
002891r 2  A5 11                lda     FAC+3
002893r 2  85 3B                sta     BAS_TMP1+1
002895r 2  A5 3A                lda     BAS_TMP1
002897r 2  85 3C                sta     BAS_TMP2
002899r 2  A5 3B                lda     BAS_TMP1+1
00289Br 2  85 3D                sta     BAS_TMP2+1
00289Dr 2  A2 04                ldx     #4
00289Fr 2               @shl:
00289Fr 2  06 3A                asl     BAS_TMP1
0028A1r 2  26 3B                rol     BAS_TMP1+1
0028A3r 2  CA                   dex
0028A4r 2  D0 F9                bne     @shl
0028A6r 2  18                   clc
0028A7r 2  A5 3A                lda     BAS_TMP1
0028A9r 2  65 3C                adc     BAS_TMP2
0028ABr 2  85 3A                sta     BAS_TMP1
0028ADr 2  A5 3B                lda     BAS_TMP1+1
0028AFr 2  65 3D                adc     BAS_TMP2+1
0028B1r 2  85 3B                sta     BAS_TMP1+1
0028B3r 2  46 3D                lsr     BAS_TMP2+1
0028B5r 2  66 3C                ror     BAS_TMP2
0028B7r 2  46 3D                lsr     BAS_TMP2+1
0028B9r 2  66 3C                ror     BAS_TMP2
0028BBr 2  38                   sec
0028BCr 2  A5 3A                lda     BAS_TMP1
0028BEr 2  E5 3C                sbc     BAS_TMP2
0028C0r 2  48                   pha                             ; freqLo
0028C1r 2  A5 3B                lda     BAS_TMP1+1
0028C3r 2  E5 3D                sbc     BAS_TMP2+1
0028C5r 2  48                   pha                             ; freqHi
0028C6r 2  20 rr rr             jsr     ChkCom
0028C9r 2  20 rr rr             jsr     EvalU16                 ; dur in FAC+3/+4
0028CCr 2                       ; Stack (top-down): freqHi, freqLo, voice
0028CCr 2  7A                   ply                             ; Y = freqHi
0028CDr 2  FA                   plx                             ; X = freqLo
0028CEr 2  68                   pla                             ; A = voice
0028CFr 2  20 rr rr             jsr     SidPlayNote
0028D2r 2  A5 12                lda     FAC+4
0028D4r 2  A6 11                ldx     FAC+3
0028D6r 2  20 rr rr             jsr     SysDelay
0028D9r 2  4C rr rr             jmp     SidSilence
0028DCr 2               
0028DCr 2               ; TIME
0028DCr 2               BasCmdTime:
0028DCr 2  A9 04                lda     #HW_RTC
0028DEr 2  20 rr rr             jsr     ReqHw
0028E1r 2  20 rr rr             jsr     RtcReadTime             ; A=hours, X=min, Y=sec
0028E4r 2  5A                   phy
0028E5r 2  DA                   phx
0028E6r 2  20 rr rr             jsr     BasPr2D                 ; print hours
0028E9r 2  A9 3A                lda     #':'
0028EBr 2  20 rr rr             jsr     Chrout
0028EEr 2  68                   pla
0028EFr 2  20 rr rr             jsr     BasPr2D
0028F2r 2  A9 3A                lda     #':'
0028F4r 2  20 rr rr             jsr     Chrout
0028F7r 2  68                   pla
0028F8r 2  20 rr rr             jsr     BasPr2D
0028FBr 2  4C rr rr             jmp     BasPrintCRLF
0028FEr 2               
0028FEr 2               ; DATE
0028FEr 2               BasCmdDate:
0028FEr 2  A9 04                lda     #HW_RTC
002900r 2  20 rr rr             jsr     ReqHw
002903r 2  20 rr rr             jsr     RtcReadDate             ; A=day, X=month, Y=year
002906r 2  48                   pha
002907r 2  DA                   phx
002908r 2  5A                   phy
002909r 2  AD 0B 03             lda     RTC_BUF_CENT
00290Cr 2  20 rr rr             jsr     BasPr2D
00290Fr 2  68                   pla
002910r 2  20 rr rr             jsr     BasPr2D
002913r 2  A9 2D                lda     #'-'
002915r 2  20 rr rr             jsr     Chrout
002918r 2  68                   pla
002919r 2  20 rr rr             jsr     BasPr2D
00291Cr 2  A9 2D                lda     #'-'
00291Er 2  20 rr rr             jsr     Chrout
002921r 2  68                   pla
002922r 2  20 rr rr             jsr     BasPr2D
002925r 2  4C rr rr             jmp     BasPrintCRLF
002928r 2               
002928r 2               ; SETTIME h, m, s
002928r 2               BasCmdSettime:
002928r 2  A9 04                lda     #HW_RTC
00292Ar 2  20 rr rr             jsr     ReqHw
00292Dr 2  20 rr rr             jsr     GetByt                  ; X = h
002930r 2  DA                   phx
002931r 2  20 rr rr             jsr     ChkCom
002934r 2  20 rr rr             jsr     GetByt                  ; X = m
002937r 2  DA                   phx
002938r 2  20 rr rr             jsr     ChkCom
00293Br 2  20 rr rr             jsr     GetByt                  ; X = s
00293Er 2  8A                   txa
00293Fr 2  A8                   tay                             ; Y = s
002940r 2  FA                   plx                             ; X = m
002941r 2  68                   pla                             ; A = h
002942r 2  4C rr rr             jmp     RtcWriteTime
002945r 2               
002945r 2               ; SETDATE c, y, m, d
002945r 2               BasCmdSetdate:
002945r 2  A9 04                lda     #HW_RTC
002947r 2  20 rr rr             jsr     ReqHw
00294Ar 2  20 rr rr             jsr     GetByt
00294Dr 2  8E 0B 03             stx     RTC_BUF_CENT
002950r 2  20 rr rr             jsr     ChkCom
002953r 2  20 rr rr             jsr     GetByt
002956r 2  DA                   phx                             ; year
002957r 2  20 rr rr             jsr     ChkCom
00295Ar 2  20 rr rr             jsr     GetByt
00295Dr 2  DA                   phx                             ; month
00295Er 2  20 rr rr             jsr     ChkCom
002961r 2  20 rr rr             jsr     GetByt                  ; X=day
002964r 2  8A                   txa
002965r 2  FA                   plx                             ; X=month
002966r 2  7A                   ply                             ; Y=year
002967r 2  4C rr rr             jmp     RtcWriteDate
00296Ar 2               
00296Ar 2               ; NVRAM addr, val
00296Ar 2               BasCmdNvram:
00296Ar 2  A9 04                lda     #HW_RTC
