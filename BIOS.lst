000000r 2               ;
000000r 2               ;   $00-$03   Kernal reserved
000000r 2               ;   $04-$23   BASIC primary workspace
000000r 2               ;   $24-$39   Kernal reserved
000000r 2               ;   $3A-$FF   BASIC spill (FP scratch in later phases)
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BAS_TXTPTR      := $04          ; $04-$05  ChrGet / parse pointer
000000r 2               BAS_CURLINE     := $06          ; $06-$07  Pointer to current executing line
000000r 2               BAS_LINNUM      := $08          ; $08-$09  Parsed line number / scratch (= LINNUM)
000000r 2               
000000r 2               ; ----- Floating-point primary block ($0A-$1B, contiguous) -------------------
000000r 2               ; The MSBASIC float code accesses these via ZP,X with one label as the
000000r 2               ; immediate base (e.g. EXPSGN,X / SHIFTSIGNEXT,X / TMPEXP,X), so this entire
000000r 2               ; block MUST stay contiguous in this exact order.  See msbasic-master/
000000r 2               ; zeropage.s for the reference layout.
000000r 2               BAS_TMPEXP      := $0A          ; $0A      TMPEXP / INDX (alias)
000000r 2               BAS_INDX        := $0A          ; $0A      (alias of TMPEXP per msbasic SMALL)
000000r 2               BAS_EXPON       := $0B          ; $0B      EXPON
000000r 2               BAS_LOWTR       := $0C          ; $0C      LOWTR
000000r 2               BAS_EXPSGN      := $0D          ; $0D      EXPSGN  (== FAC-1 scratch byte)
000000r 2               BAS_FAC         := $0E          ; $0E-$12  FAC  (5 bytes)
000000r 2               BAS_FACSIGN     := $13          ; $13      FACSIGN  (== FAC+5)
000000r 2               BAS_SERLEN      := $14          ; $14      SERLEN
000000r 2               BAS_SHIFTSGN    := $15          ; $15      SHIFTSIGNEXT (== ARG-1 scratch)
000000r 2               BAS_ARG         := $16          ; $16-$1A  ARG  (5 bytes)
000000r 2               BAS_ARGSIGN     := $1B          ; $1B      ARGSIGN  (== ARG+5)
000000r 2               ; ----------------------------------------------------------------------------
000000r 2               
000000r 2               BAS_STRNG1      := $1C          ; $1C-$1D  STRNG1 (= SGNCPR; +1 = FACEXTENSION)
000000r 2               BAS_STRNG2      := $1E          ; $1E-$1F  STRNG2
000000r 2               
000000r 2               BAS_INDEX       := $20          ; $20-$21  General index pointer (line walk + msbasic INDEX)
000000r 2               BAS_DEST        := $22          ; $22-$23  Destination pointer (msbasic DEST)
000000r 2               
000000r 2               ; ----- Spill area: $3A-$67 --------------------------------------------------
000000r 2               BAS_TMP1        := $3A          ; $3A-$3B  General-purpose 16-bit pointer
000000r 2               BAS_TMP2        := $3C          ; $3C-$3D  General-purpose 16-bit pointer
000000r 2               BAS_TMP3        := $3E          ; $3E      Spill scratch byte
000000r 2               BAS_VARPNT      := $3F          ; $3F-$40  Current variable address
000000r 2               BAS_QUOTEFLG    := $41          ; $41      Tokenizer quote-state
000000r 2               BAS_DETOKY      := $42          ; $42      Saved Y across detokenize calls
000000r 2               
000000r 2               ; FP-only scratch registers (single bytes unless noted)
000000r 2               BAS_ARGEXT      := $43          ; ARGEXTENSION
000000r 2               BAS_CHARAC      := $44          ; CHARAC (string-quote/end char tracker)
000000r 2               BAS_CPRMASK     := $45          ; CPRMASK (FComp result mask)
000000r 2               BAS_FORPNT      := $46          ; $46-$47  FORPNT
000000r 2               BAS_RESULT      := $48          ; $48-$4C  RESULT  (5-byte FMult accumulator)
000000r 2               BAS_TEMP1       := $4D          ; $4D-$51  TEMP1  (5-byte FP scratch)
000000r 2               BAS_TEMP2       := $52          ; $52-$56  TEMP2  (5-byte FP scratch)
000000r 2               BAS_TEMP3       := $57          ; $57-$5B  TEMP3  (5-byte FP scratch)
000000r 2               BAS_RNDSEED     := $5C          ; $5C-$60  RNDSEED (5-byte FP value)
000000r 2               BAS_KWPTR       := $61          ; $61-$62  Keyword-table walker pointer
000000r 2               
000000r 2               ; ----- Variable / array / string-heap workspace ($63-$85) -----------------
000000r 2               BAS_DIMFLG      := $63          ; DIM-mode flag (nonzero = called from DIM)
000000r 2               BAS_VALTYP      := $64          ; $64-$65  Value type ($00=numeric, $FF=string)
000000r 2               BAS_EOLPNTR     := $66          ; Array scratch: dim count / pointer
000000r 2               BAS_DATAFLG     := $67          ; GetSpa: GC retry flag
000000r 2               BAS_SUBFLG      := $68          ; PtrGet: $40 from GETARYPT, $80 from DEF FN
000000r 2               BAS_INPUTFLG    := $69          ; INPUT/READ flag
000000r 2               BAS_ENDCHR      := $6A          ; StrLt2 secondary terminator
000000r 2               BAS_TEMPPT      := $6B          ; Top-of-temp-string-stack pointer
000000r 2               BAS_LASTPT      := $6C          ; $6C-$6D  Last temp descriptor allocated
000000r 2               BAS_TEMPST      := $6E          ; $6E-$76  Temp descriptor stack (3 * 3 bytes)
000000r 2               BAS_HIGHDS      := $77          ; $77-$78  Bltu dest end+1
000000r 2               BAS_HIGHTR      := $79          ; $79-$7A  Bltu source end+1
000000r 2               BAS_VARNAM      := $7B          ; $7B-$7C  Variable name pair (with type bits)
000000r 2               BAS_DSCPTR      := $7D          ; $7D-$7E  String descriptor pointer
000000r 2               BAS_DSCLEN      := $7F          ; $7F-$80  String descriptor length / GC scratch
000000r 2               BAS_FNCNAM      := $81          ; $81-$82  GC: highest-string descriptor ptr
000000r 2               BAS_Z52         := $83          ; GC scratch byte
000000r 2               BAS_FRESPC      := $84          ; $84-$85  Free-string-space pointer
000000r 2               ; ----------------------------------------------------------------------------
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Symbol aliases used by the inlined MSBASIC FP code.  These let the ported
000000r 2               ; routines keep their original names without a global rename pass.
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               FAC             := BAS_FAC
000000r 2               FAC_LAST        := BAS_FAC + 4
000000r 2               FACSIGN         := BAS_FACSIGN
000000r 2               ARG             := BAS_ARG
000000r 2               ARG_LAST        := BAS_ARG + 4
000000r 2               ARGSIGN         := BAS_ARGSIGN
000000r 2               INDEX           := BAS_INDEX
000000r 2               DEST            := BAS_DEST
000000r 2               STRNG1          := BAS_STRNG1
000000r 2               STRNG2          := BAS_STRNG2
000000r 2               SGNCPR          := BAS_STRNG1            ; aliased as in msbasic zeropage.s
000000r 2               FACEXTENSION    := BAS_STRNG1 + 1        ; aliased as in msbasic zeropage.s
000000r 2               TXTPTR          := BAS_TXTPTR
000000r 2               LINNUM          := BAS_LINNUM
000000r 2               CURLIN          := BAS_CURLIN            ; non-ZP ($0369) — only used by InPrt
000000r 2               VARPNT          := BAS_VARPNT
000000r 2               ARGEXTENSION    := BAS_ARGEXT
000000r 2               EXPON           := BAS_EXPON
000000r 2               EXPSGN          := BAS_EXPSGN
000000r 2               LOWTR           := BAS_LOWTR
000000r 2               INDX            := BAS_INDX
000000r 2               TMPEXP          := BAS_TMPEXP
000000r 2               SERLEN          := BAS_SERLEN
000000r 2               SHIFTSIGNEXT    := BAS_SHIFTSGN
000000r 2               CHARAC          := BAS_CHARAC
000000r 2               CPRMASK         := BAS_CPRMASK
000000r 2               FORPNT          := BAS_FORPNT
000000r 2               RESULT          := BAS_RESULT
000000r 2               RESULT_LAST     := BAS_RESULT + 4
000000r 2               TEMP1           := BAS_TEMP1
000000r 2               TEMP2           := BAS_TEMP2
000000r 2               TEMP3           := BAS_TEMP3
000000r 2               RNDSEED         := BAS_RNDSEED
000000r 2               
000000r 2               ; ----- Aliases used by ported msbasic var/array/string code ----------------
000000r 2               DIMFLG          := BAS_DIMFLG
000000r 2               VALTYP          := BAS_VALTYP
000000r 2               EOLPNTR         := BAS_EOLPNTR
000000r 2               DATAFLG         := BAS_DATAFLG
000000r 2               SUBFLG          := BAS_SUBFLG
000000r 2               INPUTFLG        := BAS_INPUTFLG
000000r 2               ENDCHR          := BAS_ENDCHR
000000r 2               TEMPPT          := BAS_TEMPPT
000000r 2               LASTPT          := BAS_LASTPT
000000r 2               TEMPST          := BAS_TEMPST
000000r 2               HIGHDS          := BAS_HIGHDS
000000r 2               HIGHTR          := BAS_HIGHTR
000000r 2               VARNAM          := BAS_VARNAM
000000r 2               DSCPTR          := BAS_DSCPTR
000000r 2               DSCLEN          := BAS_DSCLEN
000000r 2               FNCNAM          := BAS_FNCNAM
000000r 2               Z52             := BAS_Z52
000000r 2               FRESPC          := BAS_FRESPC
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Constants required by the ported FP code.
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               BYTES_FP        = 5
000000r 2               MANTISSA_BYTES  = 4
000000r 2               MAX_EXPON       = 10
000000r 2               STACK2          = $0100             ; Fout output buffer base (bottom of stack page)
000000r 2               
000000r 2               ; Variable / array layout constants (CONFIG_2 / CBM2-class equivalents).
000000r 2               BYTES_PER_VARIABLE = 7              ; 2 name + 5 value (numeric or descriptor)
000000r 2               BYTES_PER_ELEMENT  = 5              ; numeric array element size
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Aliases for the runtime pointers that live in $035D+ (defined in BIOS.inc).
000000r 2               ; The msbasic var/array/string code references them by these short names.
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               TXTTAB          := BAS_TXTTAB
000000r 2               VARTAB          := BAS_VARTAB
000000r 2               ARYTAB          := BAS_ARYTAB
000000r 2               STREND          := BAS_STREND
000000r 2               FRETOP          := BAS_FRETOP
000000r 2               MEMSIZ          := BAS_MEMSIZ
000000r 2               
000000r 2               ; ERR_OVERFLOW / ERR_DIVZERO already defined below; alias zerodiv:
000000r 2               ERR_ZERODIV     = 6                 ; matches ERR_DIVZERO
000000r 2               
000000r 2               ; Fin parses these as numeric-prefix tokens.  Final token assignments are
000000r 2               ; wired up when the expression evaluator goes live; until then $00 is fine
000000r 2               ; (will not appear in tokenised input).
000000r 2               TOKEN_PLUS      = $00
000000r 2               TOKEN_MINUS     = $00
000000r 2               
000000r 2               ; Rnd(0) source: 6 stable but variable bytes from kernel vars (IRQ_PTR/BRK_PTR
000000r 2               ; etc.).  Just needs to exist — used only when Rnd is called with arg 0.
000000r 2               ENTROPY         = $0300
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   R A M   L A Y O U T   ( B A S I C   W O R K S P A C E )
000000r 2               ;
000000r 2               ;   $0400-$04FF   Input line buffer (256 bytes)
000000r 2               ;   $0500-$05FF   Tokenized line scratch (256 bytes)
000000r 2               ;
000000r 2               ;   GOSUB / FOR stacks live elsewhere; $0500-$05FF doubles as the
000000r 2               ;   tokenization scratch buffer.  $0600-$07FF overlaps FS_SECTOR_BUF and
000000r 2               ;   is left untouched here.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BAS_LINBUF      := $0400        ; Raw input line  (NUL-terminated)
000000r 2               BAS_TOKBUF      := $0500        ; Tokenized scratch buffer (NUL-terminated)
000000r 2               
000000r 2               BAS_LINBUF_MAX  = 200           ; Max accepted input length (bytes)
000000r 2               BAS_TOKBUF_MAX  = 250           ; Max tokenized payload bytes
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   P R O G R A M   S T O R A G E
000000r 2               ;
000000r 2               ;   Lines at $0800+ : [next-lo][next-hi][num-lo][num-hi][tokens...][$00]
000000r 2               ;   End-of-program  : a "next-pointer" of $0000.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BAS_PRG_START   = $0800
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   T O K E N   E Q U A T E S
000000r 2               ;
000000r 2               ;   Tokens are assigned sequentially starting at $80.  KEEP THE TABLE BELOW
000000r 2               ;   IN SYNC WITH THESE EQUATES.  If you reorder or insert keywords, renumber.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               TOK_BASE        = $80
000000r 2               
000000r 2               TOK_END         = $80
000000r 2               TOK_FOR         = $81
000000r 2               TOK_NEXT        = $82
000000r 2               TOK_DATA        = $83
000000r 2               TOK_INPUT       = $84
000000r 2               TOK_DIM         = $85
000000r 2               TOK_READ        = $86
000000r 2               TOK_LET         = $87
000000r 2               TOK_GOTO        = $88
000000r 2               TOK_RUN         = $89
000000r 2               TOK_IF          = $8A
000000r 2               TOK_RESTORE     = $8B
000000r 2               TOK_GOSUB       = $8C
000000r 2               TOK_RETURN      = $8D
000000r 2               TOK_REM         = $8E
000000r 2               TOK_STOP        = $8F
000000r 2               TOK_ON          = $90
000000r 2               TOK_WAIT        = $91
000000r 2               TOK_LOAD        = $92
000000r 2               TOK_SAVE        = $93
000000r 2               TOK_DEF         = $94
000000r 2               TOK_POKE        = $95
000000r 2               TOK_PRINT       = $96
000000r 2               TOK_CONT        = $97
000000r 2               TOK_LIST        = $98
000000r 2               TOK_CLR         = $99
000000r 2               TOK_NEW         = $9A
000000r 2               TOK_TAB         = $9B
000000r 2               TOK_TO          = $9C
000000r 2               TOK_FN          = $9D
000000r 2               TOK_SPC         = $9E
000000r 2               TOK_THEN        = $9F
000000r 2               TOK_NOT         = $A0
000000r 2               TOK_STEP        = $A1
000000r 2               TOK_AND         = $A2
000000r 2               TOK_OR          = $A3
000000r 2               TOK_ELSE        = $A4
000000r 2               TOK_SYS         = $A5
000000r 2               TOK_DIR         = $A6
000000r 2               TOK_DEL         = $A7
000000r 2               TOK_CLS         = $A8
000000r 2               TOK_LOCATE      = $A9
000000r 2               TOK_COLOR       = $AA
000000r 2               TOK_SOUND       = $AB
000000r 2               TOK_VOL         = $AC
000000r 2               TOK_TIME        = $AD
000000r 2               TOK_DATE        = $AE
000000r 2               TOK_SETTIME     = $AF
000000r 2               TOK_SETDATE     = $B0
000000r 2               TOK_NVRAM       = $B1
000000r 2               TOK_PAUSE       = $B2
000000r 2               TOK_BANK        = $B3
000000r 2               TOK_BRK         = $B4
000000r 2               TOK_MEM         = $B5
000000r 2               TOK_SGN         = $B6
000000r 2               TOK_INT         = $B7
000000r 2               TOK_ABS         = $B8
000000r 2               TOK_FRE         = $B9
000000r 2               TOK_POS         = $BA
000000r 2               TOK_SQR         = $BB
000000r 2               TOK_RND         = $BC
000000r 2               TOK_LOG         = $BD
000000r 2               TOK_EXP         = $BE
000000r 2               TOK_COS         = $BF
000000r 2               TOK_SIN         = $C0
000000r 2               TOK_TAN         = $C1
000000r 2               TOK_ATN         = $C2
000000r 2               TOK_PEEK        = $C3
000000r 2               TOK_LEN         = $C4
000000r 2               TOK_STRSTR      = $C5           ; STR$
000000r 2               TOK_VAL         = $C6
000000r 2               TOK_ASC         = $C7
000000r 2               TOK_CHRSTR      = $C8           ; CHR$
000000r 2               TOK_LEFTSTR     = $C9           ; LEFT$
000000r 2               TOK_RIGHTSTR    = $CA           ; RIGHT$
000000r 2               TOK_MIDSTR      = $CB           ; MID$
000000r 2               TOK_JOY         = $CC
000000r 2               TOK_INKEY       = $CD
000000r 2               TOK_HEX         = $CE
000000r 2               TOK_MIN         = $CF
000000r 2               TOK_MAX         = $D0
000000r 2               TOK_FPTEST      = $D1           ; debug only - removed in final cleanup
000000r 2               TOK_VARTEST     = $D2           ; debug only - removed in final cleanup
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   E R R O R   C O D E S
000000r 2               ; =============================================================================
000000r 2               
000000r 2               ERR_SYNTAX      = 0
000000r 2               ERR_OVERFLOW    = 1
000000r 2               ERR_OUTOFMEM    = 2
000000r 2               ERR_UNDEFSTMT   = 3
000000r 2               ERR_BADSUBSCR   = 4
000000r 2               ERR_REDIM       = 5
000000r 2               ERR_DIVZERO     = 6
000000r 2               ERR_ILLDIRECT   = 7
000000r 2               ERR_TYPEMISM    = 8
000000r 2               ERR_LONGSTR     = 9
000000r 2               ERR_FORMULA     = 10
000000r 2               ERR_ILLQUAN     = 11
000000r 2               ERR_RG          = 12            ; RETURN without GOSUB
000000r 2               ERR_NF          = 13            ; NEXT without FOR
000000r 2               ERR_OD          = 14            ; OUT OF DATA
000000r 2               ERR_NODEV       = 15
000000r 2               ERR_CANTCONT    = 16
000000r 2               
000000r 2               ; Aliases used by ported msbasic code.
000000r 2               ERR_BADSUBS     = ERR_BADSUBSCR
000000r 2               ERR_REDIMD      = ERR_REDIM
000000r 2               ERR_FRMCPX      = ERR_FORMULA
000000r 2               ERR_MEMFULL     = ERR_OUTOFMEM
000000r 2               ERR_STRLONG     = ERR_LONGSTR
000000r 2               ERR_ILLQTY      = ERR_ILLQUAN
000000r 2               
000000r 2               ; =============================================================================
000000r 2               ;   B A S E N T R Y   -   $C000
000000r 2               ;
000000r 2               ;   First byte of segment.  Reached from:
000000r 2               ;     * Kernal cold-boot path
000000r 2               ;     * Monitor 'X' command (warm re-entry)
000000r 2               ;
000000r 2               ;   Cold-vs-warm detection: BAS_WARM holds $A5 once cold init has run.
000000r 2               ;   Re-entry skips banner and goes straight to the OK prompt.
000000r 2               ; =============================================================================
000000r 2               
000000r 2               BasEntry:
000000r 2  A2 FF                ldx     #$FF                    ; reset stack on (re)entry
000002r 2  9A                   txs
000003r 2  D8                   cld
000004r 2               
000004r 2  AD 6F 03             lda     BAS_WARM
000007r 2  C9 A5                cmp     #$A5
000009r 2  F0 08                beq     @Warm
00000Br 2               
00000Br 2  20 rr rr             jsr     BasColdInit
00000Er 2  20 rr rr             jsr     BasBanner
000011r 2  80 00                bra     BasReadyLoop
000013r 2               
000013r 2               @Warm:
000013r 2                       ; Warm restart - skip banner; the OK printer will lead with CRLF.
000013r 2               
000013r 2               ; -----------------------------------------------------------------------------
000013r 2               ; BasReadyLoop - REPL: print OK, read a line, dispatch.
000013r 2               ; -----------------------------------------------------------------------------
000013r 2               BasReadyLoop:
000013r 2  20 rr rr             jsr     BasPrintOK
000016r 2               @nextline:
000016r 2  20 rr rr             jsr     BasReadLine             ; fills BAS_LINBUF, NUL-terminated
000019r 2  20 rr rr             jsr     BasProcessLine
00001Cr 2  80 F8                bra     @nextline
00001Er 2               
00001Er 2               ; =============================================================================
00001Er 2               ;   B a s C o l d I n i t
00001Er 2               ; =============================================================================
00001Er 2               ; Initialise BASIC runtime variables.  Called once on first entry.
00001Er 2               ; =============================================================================
00001Er 2               BasColdInit:
00001Er 2                       ; TXTTAB / MEMSIZ are constants for our memory map.
00001Er 2  A9 00                lda     #<BAS_PRG_START
000020r 2  8D 5D 03             sta     BAS_TXTTAB
000023r 2  A9 08                lda     #>BAS_PRG_START
000025r 2  8D 5E 03             sta     BAS_TXTTAB+1
000028r 2               
000028r 2  A9 00                lda     #<$8000
00002Ar 2  8D 67 03             sta     BAS_MEMSIZ
00002Dr 2  A9 80                lda     #>$8000
00002Fr 2  8D 68 03             sta     BAS_MEMSIZ+1
000032r 2               
000032r 2                       ; Auto-detect a pre-loaded program at $0800: if the first word looks
000032r 2                       ; like a valid next-pointer (high byte in [$08, $80)), walk the chain
000032r 2                       ; to compute end-of-program.  Otherwise install an empty program.
000032r 2  AD 01 08             lda     BAS_PRG_START+1         ; high byte of first next-ptr
000035r 2  C9 08                cmp     #$08
000037r 2  90 33                bcc     @InstallEmpty
000039r 2  C9 80                cmp     #$80
00003Br 2  B0 2F                bcs     @InstallEmpty
00003Dr 2               
00003Dr 2                       ; Walk the chain to find the end-marker (next-ptr = 0).
00003Dr 2  A9 00                lda     #<BAS_PRG_START
00003Fr 2  85 3A                sta     BAS_TMP1
000041r 2  A9 08                lda     #>BAS_PRG_START
000043r 2  85 3B                sta     BAS_TMP1+1
000045r 2               @WalkLoop:
000045r 2  A0 01                ldy     #1
000047r 2  B1 3A                lda     (BAS_TMP1),y
000049r 2  F0 10                beq     @WalkDone               ; end-marker reached
00004Br 2  A0 00                ldy     #0
00004Dr 2  B1 3A                lda     (BAS_TMP1),y
00004Fr 2  48                   pha
000050r 2  A0 01                ldy     #1
000052r 2  B1 3A                lda     (BAS_TMP1),y
000054r 2  85 3B                sta     BAS_TMP1+1
000056r 2  68                   pla
000057r 2  85 3A                sta     BAS_TMP1
000059r 2  80 EA                bra     @WalkLoop
00005Br 2               @WalkDone:
00005Br 2                       ; BAS_TMP1 points at the end-marker; VARTAB = TMP1 + 2.
00005Br 2  18                   clc
00005Cr 2  A5 3A                lda     BAS_TMP1
00005Er 2  69 02                adc     #2
000060r 2  8D 5F 03             sta     BAS_VARTAB
000063r 2  A5 3B                lda     BAS_TMP1+1
000065r 2  69 00                adc     #0
000067r 2  8D 60 03             sta     BAS_VARTAB+1
00006Ar 2  80 12                bra     @InitFinalize
00006Cr 2               
00006Cr 2               @InstallEmpty:
00006Cr 2                       ; Write [00][00] end-marker at $0800; VARTAB = $0802.
00006Cr 2  A9 00                lda     #0
00006Er 2  8D 00 08             sta     BAS_PRG_START
000071r 2  8D 01 08             sta     BAS_PRG_START+1
000074r 2  A9 02                lda     #<(BAS_PRG_START+2)
000076r 2  8D 5F 03             sta     BAS_VARTAB
000079r 2  A9 08                lda     #>(BAS_PRG_START+2)
00007Br 2  8D 60 03             sta     BAS_VARTAB+1
00007Er 2               
00007Er 2               @InitFinalize:
00007Er 2                       ; ARYTAB = STREND = VARTAB; FRETOP = MEMSIZ.
00007Er 2  AD 5F 03             lda     BAS_VARTAB
000081r 2  8D 61 03             sta     BAS_ARYTAB
000084r 2  8D 63 03             sta     BAS_STREND
000087r 2  AD 60 03             lda     BAS_VARTAB+1
00008Ar 2  8D 62 03             sta     BAS_ARYTAB+1
00008Dr 2  8D 64 03             sta     BAS_STREND+1
000090r 2  AD 67 03             lda     BAS_MEMSIZ
000093r 2  8D 65 03             sta     BAS_FRETOP
000096r 2  AD 68 03             lda     BAS_MEMSIZ+1
000099r 2  8D 66 03             sta     BAS_FRETOP+1
00009Cr 2               
00009Cr 2                       ; CURLIN = $FFFF (direct mode marker).
00009Cr 2  A9 FF                lda     #$FF
00009Er 2  8D 69 03             sta     BAS_CURLIN
0000A1r 2  8D 6A 03             sta     BAS_CURLIN+1
0000A4r 2               
0000A4r 2                       ; Clear CONT state and pending-key.
0000A4r 2  9C 6B 03             stz     BAS_OLDLIN
0000A7r 2  9C 6C 03             stz     BAS_OLDLIN+1
0000AAr 2  9C 6D 03             stz     BAS_OLDTEXT
0000ADr 2  9C 6E 03             stz     BAS_OLDTEXT+1
0000B0r 2  9C 1A 03             stz     BAS_DATAPTR
0000B3r 2  9C 1B 03             stz     BAS_DATAPTR+1
0000B6r 2  9C 1C 03             stz     BAS_STOPLINE
0000B9r 2  9C 1D 03             stz     BAS_STOPLINE+1
0000BCr 2  9C 1E 03             stz     BAS_STOPTXT
0000BFr 2  9C 1F 03             stz     BAS_STOPTXT+1
0000C2r 2  9C 0E 03             stz     BAS_PENDKEY
0000C5r 2               
0000C5r 2  64 41                stz     BAS_QUOTEFLG
0000C7r 2               
0000C7r 2                       ; Variable/array/string runtime state.
0000C7r 2  64 63                stz     BAS_DIMFLG
0000C9r 2  64 64                stz     BAS_VALTYP
0000CBr 2  64 65                stz     BAS_VALTYP+1
0000CDr 2  64 67                stz     BAS_DATAFLG
0000CFr 2  64 68                stz     BAS_SUBFLG
0000D1r 2  64 69                stz     BAS_INPUTFLG
0000D3r 2                       ; Temp-string descriptor stack: TEMPPT = TEMPST.
0000D3r 2  A9 6E                lda     #BAS_TEMPST
0000D5r 2  85 6B                sta     BAS_TEMPPT
0000D7r 2               
0000D7r 2                       ; Initialise Rnd seed from the embedded constant.
0000D7r 2  A2 04                ldx     #4
0000D9r 2               @SeedCopy:
0000D9r 2  BD rr rr             lda     RndSeedInit,x
0000DCr 2  95 5C                sta     RNDSEED,x
0000DEr 2  CA                   dex
0000DFr 2  10 F8                bpl     @SeedCopy
0000E1r 2               
0000E1r 2                       ; Mark warm-start magic.
0000E1r 2  A9 A5                lda     #$A5
0000E3r 2  8D 6F 03             sta     BAS_WARM
0000E6r 2  60                   rts
0000E7r 2               
0000E7r 2               ; =============================================================================
0000E7r 2               ;   B a s B a n n e r
0000E7r 2               ; =============================================================================
0000E7r 2               BasBanner:
0000E7r 2  A9 rr                lda     #<MsgBanner
0000E9r 2  A0 rr                ldy     #>MsgBanner
0000EBr 2  20 rr rr             jsr     BasPrintStr
0000EEr 2                       ; Print "<n> BYTES FREE" line.
0000EEr 2  38                   sec
0000EFr 2  AD 67 03             lda     BAS_MEMSIZ
0000F2r 2  ED 5F 03             sbc     BAS_VARTAB
0000F5r 2  A8                   tay
0000F6r 2  AD 68 03             lda     BAS_MEMSIZ+1
0000F9r 2  ED 60 03             sbc     BAS_VARTAB+1
0000FCr 2  20 rr rr             jsr     GivAyf
0000FFr 2                       ; Print the byte count left-aligned: Fout always emits a leading
0000FFr 2                       ; sign character (' ' for positive, '-' for negative).  For the
0000FFr 2                       ; banner we skip that leading space so the number lines up with
0000FFr 2                       ; the left edge of the title above it.
0000FFr 2  20 rr rr             jsr     Fout                    ; (Y,A) -> NUL-terminated buffer
000102r 2  85 20                sta     INDEX
000104r 2  84 21                sty     INDEX+1
000106r 2  A0 00                ldy     #0
000108r 2  B1 20                lda     (INDEX),y
00010Ar 2  C9 20                cmp     #' '
00010Cr 2  D0 01                bne     @bnLoop
00010Er 2  C8                   iny                             ; skip the positive-sign space
00010Fr 2               @bnLoop:
00010Fr 2  B1 20                lda     (INDEX),y
000111r 2  F0 06                beq     @bnDone
000113r 2  20 rr rr             jsr     PrintCh
000116r 2  C8                   iny
000117r 2  D0 F6                bne     @bnLoop
000119r 2               @bnDone:
000119r 2  A9 rr                lda     #<MsgBytesFreeNL
00011Br 2  A0 rr                ldy     #>MsgBytesFreeNL
00011Dr 2  4C rr rr             jmp     BasPrintStr
000120r 2               
000120r 2               ; =============================================================================
000120r 2               ;   B a s P r i n t O K
000120r 2               ; =============================================================================
000120r 2               BasPrintOK:
000120r 2  20 rr rr             jsr     BasPrintCRLF
000123r 2  A9 rr                lda     #<MsgOK
000125r 2  A0 rr                ldy     #>MsgOK
000127r 2  4C rr rr             jmp     BasPrintStr
00012Ar 2               
00012Ar 2               ; =============================================================================
00012Ar 2               ;   B a s P r i n t S t r
00012Ar 2               ; =============================================================================
00012Ar 2               ; Print a NUL-terminated string via Chrout.
00012Ar 2               ; Input  : A=lo, Y=hi  (string address)
00012Ar 2               ; Clobbers : A, Y  (X preserved)
00012Ar 2               ; =============================================================================
00012Ar 2               BasPrintStr:
00012Ar 2  85 3A                sta     BAS_TMP1
00012Cr 2  84 3B                sty     BAS_TMP1+1
00012Er 2  A0 00                ldy     #0
000130r 2               @Loop:
000130r 2  B1 3A                lda     (BAS_TMP1),y
000132r 2  F0 06                beq     @Done
000134r 2  20 rr rr             jsr     Chrout
000137r 2  C8                   iny
000138r 2  D0 F6                bne     @Loop
00013Ar 2               @Done:
00013Ar 2  60                   rts
00013Br 2               
00013Br 2               ; =============================================================================
00013Br 2               ;   B a s P r i n t C R L F
00013Br 2               ; =============================================================================
00013Br 2               BasPrintCRLF:
00013Br 2  A9 0D                lda     #$0D
00013Dr 2  20 rr rr             jsr     Chrout
000140r 2  A9 0A                lda     #$0A
000142r 2  4C rr rr             jmp     Chrout
000145r 2               
000145r 2               ; =============================================================================
000145r 2               ;   B a s R e a d L i n e
000145r 2               ; =============================================================================
000145r 2               ; Read a line of input into BAS_LINBUF, NUL-terminated.  Echoes characters
000145r 2               ; manually (does not use Chrin's auto-echo).  Supports CR, BS ($08), ESC
000145r 2               ; ($1B = cancel and restart line).  Caps stored length at BAS_LINBUF_MAX
000145r 2               ; (extra characters are silently dropped from the buffer but still echoed
000145r 2               ; -- acceptable truncation behavior).
000145r 2               ;
000145r 2               ; Output : BAS_LINBUF holds the raw line, terminated with $00.
000145r 2               ; =============================================================================
000145r 2               BasReadLine:
000145r 2  A0 00                ldy     #0
000147r 2               @Loop:
000147r 2  20 rr rr             jsr     BasReadKey              ; A = next key, blocking
00014Ar 2  C9 0D                cmp     #$0D
00014Cr 2  F0 30                beq     @Done
00014Er 2  C9 08                cmp     #$08
000150r 2  F0 19                beq     @Backspace
000152r 2  C9 1B                cmp     #$1B
000154r 2  F0 21                beq     @Cancel
000156r 2  C9 20                cmp     #$20                    ; reject control codes below space
000158r 2  90 ED                bcc     @Loop
00015Ar 2  C9 7F                cmp     #$7F                    ; reject DEL and 8-bit
00015Cr 2  B0 E9                bcs     @Loop
00015Er 2                       ; Printable - store and echo.
00015Er 2  C0 C8                cpy     #BAS_LINBUF_MAX
000160r 2  B0 E5                bcs     @Loop                   ; full - drop quietly
000162r 2  99 00 04             sta     BAS_LINBUF,y
000165r 2  C8                   iny
000166r 2  20 rr rr             jsr     Chrout
000169r 2  80 DC                bra     @Loop
00016Br 2               
00016Br 2               @Backspace:
00016Br 2  C0 00                cpy     #0
00016Dr 2  F0 D8                beq     @Loop                   ; nothing to erase
00016Fr 2  88                   dey
000170r 2  A9 08                lda     #$08                    ; video / serial driver erases on BS
000172r 2  20 rr rr             jsr     Chrout
000175r 2  80 D0                bra     @Loop
000177r 2               
000177r 2               @Cancel:
000177r 2  20 rr rr             jsr     BasPrintCRLF
00017Ar 2  A0 00                ldy     #0
00017Cr 2  80 C9                bra     @Loop
00017Er 2               
00017Er 2               @Done:
00017Er 2  A9 00                lda     #0
000180r 2  99 00 04             sta     BAS_LINBUF,y
000183r 2  20 rr rr             jsr     BasPrintCRLF
000186r 2  60                   rts
000187r 2               
000187r 2               ; =============================================================================
000187r 2               ;   B a s R e a d K e y
000187r 2               ; =============================================================================
000187r 2               ; Spin until a key is available in the input buffer; return it in A
000187r 2               ; (no echo).
000187r 2               ; =============================================================================
000187r 2               BasReadKey:
000187r 2               @Wait:
000187r 2  20 rr rr             jsr     BufferSize
00018Ar 2  F0 FB                beq     @Wait
00018Cr 2  4C rr rr             jmp     ReadBuffer              ; tail-call: returns A=byte
00018Fr 2               
00018Fr 2               ; =============================================================================
00018Fr 2               ;   B a s P r o c e s s L i n e
00018Fr 2               ; =============================================================================
00018Fr 2               ; Triage BAS_LINBUF after reading: empty, numbered (insert/replace/delete),
00018Fr 2               ; or immediate command.
00018Fr 2               ; =============================================================================
00018Fr 2               BasProcessLine:
00018Fr 2  A2 00                ldx     #0
000191r 2               @SkipSpaces:
000191r 2  BD 00 04             lda     BAS_LINBUF,x
000194r 2  F0 07                beq     @Empty
000196r 2  C9 20                cmp     #' '
000198r 2  D0 04                bne     @HasContent
00019Ar 2  E8                   inx
00019Br 2  80 F4                bra     @SkipSpaces
00019Dr 2               @Empty:
00019Dr 2  60                   rts                             ; nothing to do; caller will reprompt
00019Er 2               
00019Er 2               @HasContent:
00019Er 2  C9 30                cmp     #'0'
0001A0r 2  90 1A                bcc     @Immediate
0001A2r 2  C9 3A                cmp     #'9'+1
0001A4r 2  B0 16                bcs     @Immediate
0001A6r 2               
0001A6r 2               ; --- Numbered line -----------------------------------------------------------
0001A6r 2  20 rr rr             jsr     BasParseLineNum         ; consumes digits at BAS_LINBUF+X
0001A9r 2                       ; X now points to first non-digit; allow exactly one optional space.
0001A9r 2  BD 00 04             lda     BAS_LINBUF,x
0001ACr 2  C9 20                cmp     #' '
0001AEr 2  D0 01                bne     @TokenizeRest
0001B0r 2  E8                   inx
0001B1r 2               @TokenizeRest:
0001B1r 2  20 rr rr             jsr     BasCrunch               ; tokenize from BAS_LINBUF+X to BAS_TOKBUF
0001B4r 2  B0 03                bcs     @StoreLine              ; carry set = success
0001B6r 2  4C rr rr             jmp     BasErrSyntax
0001B9r 2               
0001B9r 2               @StoreLine:
0001B9r 2  4C rr rr             jmp     BasStoreLine            ; insert/replace/delete by line number
0001BCr 2               
0001BCr 2               @Immediate:
0001BCr 2                       ; Immediate (no line number) - tokenize whole line and dispatch.
0001BCr 2  A2 00                ldx     #0
0001BEr 2  20 rr rr             jsr     BasCrunch
0001C1r 2  B0 03                bcs     @ImmDispatch
0001C3r 2  4C rr rr             jmp     BasErrSyntax
0001C6r 2               @ImmDispatch:
0001C6r 2  20 rr rr             jsr     BasDispatchImmediate
0001C9r 2  4C rr rr             jmp     BasPrintOK              ; MS BASIC: OK only after immediate
0001CCr 2               
0001CCr 2               ; =============================================================================
0001CCr 2               ;   B a s P a r s e L i n e N u m
0001CCr 2               ; =============================================================================
0001CCr 2               ; Parse decimal digits at BAS_LINBUF,X into BAS_LINNUM (16-bit).
0001CCr 2               ; X advances past the digits.  Saturates at $FFFF on overflow.
0001CCr 2               ; =============================================================================
0001CCr 2               BasParseLineNum:
0001CCr 2  64 08                stz     BAS_LINNUM
0001CEr 2  64 09                stz     BAS_LINNUM+1
0001D0r 2               @Loop:
0001D0r 2  BD 00 04             lda     BAS_LINBUF,x
0001D3r 2  C9 30                cmp     #'0'
0001D5r 2  90 35                bcc     @Done
0001D7r 2  C9 3A                cmp     #'9'+1
0001D9r 2  B0 31                bcs     @Done
0001DBr 2                       ; Multiply LINNUM by 10.
0001DBr 2  48                   pha
0001DCr 2  06 08                asl     BAS_LINNUM              ; *2
0001DEr 2  26 09                rol     BAS_LINNUM+1
0001E0r 2  A5 08                lda     BAS_LINNUM
0001E2r 2  85 3A                sta     BAS_TMP1
0001E4r 2  A5 09                lda     BAS_LINNUM+1
0001E6r 2  85 3B                sta     BAS_TMP1+1
0001E8r 2  06 08                asl     BAS_LINNUM              ; *4
0001EAr 2  26 09                rol     BAS_LINNUM+1
0001ECr 2  06 08                asl     BAS_LINNUM              ; *8
0001EEr 2  26 09                rol     BAS_LINNUM+1
0001F0r 2  18                   clc                             ; *8 + *2 = *10
0001F1r 2  A5 08                lda     BAS_LINNUM
0001F3r 2  65 3A                adc     BAS_TMP1
0001F5r 2  85 08                sta     BAS_LINNUM
0001F7r 2  A5 09                lda     BAS_LINNUM+1
0001F9r 2  65 3B                adc     BAS_TMP1+1
0001FBr 2  85 09                sta     BAS_LINNUM+1
0001FDr 2                       ; Add digit value.
0001FDr 2  68                   pla
0001FEr 2  29 0F                and     #$0F
000200r 2  18                   clc
000201r 2  65 08                adc     BAS_LINNUM
000203r 2  85 08                sta     BAS_LINNUM
000205r 2  90 02                bcc     @NoCarry
000207r 2  E6 09                inc     BAS_LINNUM+1
000209r 2               @NoCarry:
000209r 2  E8                   inx
00020Ar 2  80 C4                bra     @Loop
00020Cr 2               @Done:
00020Cr 2  60                   rts
00020Dr 2               
00020Dr 2               ; =============================================================================
00020Dr 2               ;   B a s C r u n c h
00020Dr 2               ; =============================================================================
00020Dr 2               ; Tokenize BAS_LINBUF starting at offset X into BAS_TOKBUF.
00020Dr 2               ;
00020Dr 2               ; Tokenization rules:
00020Dr 2               ;   - Outside quoted strings, lowercase a-z are folded to uppercase.
00020Dr 2               ;   - Outside quoted strings, alphabetic runs are matched against the
00020Dr 2               ;     keyword table; on a match the token byte is emitted in place of the
00020Dr 2               ;     keyword characters.
00020Dr 2               ;   - Inside double quotes, characters are copied verbatim until the
00020Dr 2               ;     closing quote (or end of line).
00020Dr 2               ;   - After a REM token, the rest of the line is copied verbatim.
00020Dr 2               ;   - Disallowed punctuation (@, &, [, ], {, }, |, \, `, ~) raises
00020Dr 2               ;     ?SYNTAX ERROR via carry-clear return.
00020Dr 2               ;
00020Dr 2               ; Output : BAS_TOKBUF holds the tokenized line, NUL-terminated.
00020Dr 2               ; Returns: carry SET on success, carry CLEAR on syntax error.
00020Dr 2               ; Clobbers: A, X, Y, BAS_TMP1/TMP2/TMP3.
00020Dr 2               ; =============================================================================
00020Dr 2               BasCrunch:
00020Dr 2                       ; X = src index, Y = dst index
00020Dr 2  A0 00                ldy     #0
00020Fr 2  64 41                stz     BAS_QUOTEFLG
000211r 2               @Scan:
000211r 2  C0 FA                cpy     #BAS_TOKBUF_MAX
000213r 2  B0 0A                bcs     @Overflow
000215r 2  BD 00 04             lda     BAS_LINBUF,x
000218r 2  D0 07                bne     @NotEnd
00021Ar 2                       ; End of input.
00021Ar 2  99 00 05             sta     BAS_TOKBUF,y            ; A=0
00021Dr 2  38                   sec
00021Er 2  60                   rts
00021Fr 2               @Overflow:
00021Fr 2                       ; Tokenized line too long; treat as syntax error.
00021Fr 2  18                   clc
000220r 2  60                   rts
000221r 2               
000221r 2               @NotEnd:
000221r 2  C9 22                cmp     #'"'
000223r 2  F0 56                beq     @Quote
000225r 2                       ; Lowercase to uppercase outside quotes.
000225r 2  C9 61                cmp     #'a'
000227r 2  90 06                bcc     @CheckAlpha
000229r 2  C9 7B                cmp     #'z'+1
00022Br 2  B0 02                bcs     @CheckAlpha
00022Dr 2  29 DF                and     #$DF
00022Fr 2               @CheckAlpha:
00022Fr 2                       ; Alphabetic? Try keyword match.
00022Fr 2  C9 41                cmp     #'A'
000231r 2  90 3A                bcc     @NotAlpha
000233r 2  C9 5B                cmp     #'Z'+1
000235r 2  B0 36                bcs     @NotAlpha
000237r 2                       ; Alpha - try matching a keyword starting at BAS_LINBUF,x.
000237r 2  20 rr rr             jsr     BasMatchKeyword         ; returns C set (A=token, X advanced) or C clear
00023Ar 2  90 1D                bcc     @CopyAlpha
00023Cr 2                       ; Match: emit token byte.
00023Cr 2  99 00 05             sta     BAS_TOKBUF,y
00023Fr 2  C8                   iny
000240r 2  C9 8E                cmp     #TOK_REM
000242r 2  D0 CD                bne     @Scan
000244r 2                       ; After REM: copy the remainder verbatim.
000244r 2               @RemCopy:
000244r 2  C0 FA                cpy     #BAS_TOKBUF_MAX
000246r 2  B0 D7                bcs     @Overflow
000248r 2  BD 00 04             lda     BAS_LINBUF,x
00024Br 2  F0 07                beq     @TermAndExit
00024Dr 2  99 00 05             sta     BAS_TOKBUF,y
000250r 2  C8                   iny
000251r 2  E8                   inx
000252r 2  80 F0                bra     @RemCopy
000254r 2               @TermAndExit:
000254r 2  99 00 05             sta     BAS_TOKBUF,y            ; A=0
000257r 2  38                   sec
000258r 2  60                   rts
000259r 2               
000259r 2               @CopyAlpha:
000259r 2                       ; No keyword match - copy a single alpha char (re-uppercase here, since
000259r 2                       ; BasMatchKeyword returns the original LINBUF byte).
000259r 2  BD 00 04             lda     BAS_LINBUF,x
00025Cr 2  C9 61                cmp     #'a'
00025Er 2  90 06                bcc     @CASto
000260r 2  C9 7B                cmp     #'z'+1
000262r 2  B0 02                bcs     @CASto
000264r 2  29 DF                and     #$DF
000266r 2               @CASto:
000266r 2  99 00 05             sta     BAS_TOKBUF,y
000269r 2  C8                   iny
00026Ar 2  E8                   inx
00026Br 2  80 A4                bra     @Scan
00026Dr 2               
00026Dr 2               @NotAlpha:
00026Dr 2                       ; Punctuation / digit / space.  Validate against the disallowed set.
00026Dr 2  20 rr rr             jsr     BasValidPunct
000270r 2  90 07                bcc     @SyntaxFail
000272r 2  99 00 05             sta     BAS_TOKBUF,y
000275r 2  C8                   iny
000276r 2  E8                   inx
000277r 2  80 98                bra     @Scan
000279r 2               @SyntaxFail:
000279r 2  18                   clc
00027Ar 2  60                   rts
00027Br 2               
00027Br 2               @Quote:
00027Br 2                       ; Copy opening quote, then everything up to closing quote (or end).
00027Br 2  99 00 05             sta     BAS_TOKBUF,y
00027Er 2  C8                   iny
00027Fr 2  E8                   inx
000280r 2               @QuoteLoop:
000280r 2  C0 FA                cpy     #BAS_TOKBUF_MAX
000282r 2  B0 9B                bcs     @Overflow
000284r 2  BD 00 04             lda     BAS_LINBUF,x
000287r 2  F0 CB                beq     @TermAndExit
000289r 2  99 00 05             sta     BAS_TOKBUF,y
00028Cr 2  C8                   iny
00028Dr 2  E8                   inx
00028Er 2  C9 22                cmp     #'"'
000290r 2  D0 EE                bne     @QuoteLoop
000292r 2  4C rr rr             jmp     @Scan
000295r 2               
000295r 2               ; =============================================================================
000295r 2               ;   B a s V a l i d P u n c t
000295r 2               ; =============================================================================
000295r 2               ; Verify A is an acceptable non-keyword character.
000295r 2               ; Carry SET = OK, carry CLEAR = illegal.
000295r 2               ; Allowed: anything in $20-$7E EXCEPT @, &, [, ], {, }, |, \, `, ~.
000295r 2               ; =============================================================================
000295r 2               BasValidPunct:
000295r 2  C9 40                cmp     #'@'
000297r 2  F0 26                beq     @Bad
000299r 2  C9 26                cmp     #'&'
00029Br 2  F0 22                beq     @Bad
00029Dr 2  C9 5B                cmp     #'['
00029Fr 2  F0 1E                beq     @Bad
0002A1r 2  C9 5D                cmp     #']'
0002A3r 2  F0 1A                beq     @Bad
0002A5r 2  C9 7B                cmp     #'{'
0002A7r 2  F0 16                beq     @Bad
0002A9r 2  C9 7D                cmp     #'}'
0002ABr 2  F0 12                beq     @Bad
0002ADr 2  C9 7C                cmp     #'|'
0002AFr 2  F0 0E                beq     @Bad
0002B1r 2  C9 5C                cmp     #'\'
0002B3r 2  F0 0A                beq     @Bad
0002B5r 2  C9 60                cmp     #'`'
0002B7r 2  F0 06                beq     @Bad
0002B9r 2  C9 7E                cmp     #'~'
0002BBr 2  F0 02                beq     @Bad
0002BDr 2  38                   sec
0002BEr 2  60                   rts
0002BFr 2               @Bad:
0002BFr 2  18                   clc
0002C0r 2  60                   rts
0002C1r 2               
0002C1r 2               ; =============================================================================
0002C1r 2               ;   B a s M a t c h K e y w o r d
0002C1r 2               ; =============================================================================
0002C1r 2               ; Try to match a keyword from KeywordTbl starting at BAS_LINBUF,X.
0002C1r 2               ;
0002C1r 2               ; On match  : carry SET, A = token byte, X advanced past the matched
0002C1r 2               ;             keyword characters in BAS_LINBUF.
0002C1r 2               ; On miss   : carry CLEAR, X unchanged, A = original character at LINBUF,X.
0002C1r 2               ;
0002C1r 2               ; Match algorithm:
0002C1r 2               ;   - Walk KeywordTbl, comparing characters (folding LINBUF lowercase to
0002C1r 2               ;     uppercase) to each keyword in turn.  A keyword's last byte has bit 7
0002C1r 2               ;     set; the byte after the table's final keyword is $00.
0002C1r 2               ;   - Token value = TOK_BASE + (index of keyword in table).
0002C1r 2               ; =============================================================================
0002C1r 2               BasMatchKeyword:
0002C1r 2                       ; Save initial X for rollback on miss; preserve caller's Y (BasCrunch
0002C1r 2                       ; uses Y as the TOKBUF destination index).
0002C1r 2  86 3E                stx     BAS_TMP3
0002C3r 2  5A                   phy
0002C4r 2                       ; Walk the keyword table via a 16-bit ZP pointer (BAS_KWPTR), since
0002C4r 2                       ; the table is larger than 256 bytes.  Y is held at 0 throughout and
0002C4r 2                       ; we advance BAS_KWPTR byte-by-byte instead of relying on Y.
0002C4r 2  A9 rr                lda     #<KeywordTbl
0002C6r 2  85 61                sta     BAS_KWPTR
0002C8r 2  A9 rr                lda     #>KeywordTbl
0002CAr 2  85 62                sta     BAS_KWPTR+1
0002CCr 2  A9 80                lda     #TOK_BASE
0002CEr 2  85 3A                sta     BAS_TMP1                ; current candidate token
0002D0r 2  A0 00                ldy     #0
0002D2r 2               @KeywordLoop:
0002D2r 2                       ; Restore X to start of input keyword.
0002D2r 2  A6 3E                ldx     BAS_TMP3
0002D4r 2               @CharLoop:
0002D4r 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
0002D6r 2  F0 3B                beq     @NoMatch                ; reached table terminator
0002D8r 2  48                   pha
0002D9r 2  29 7F                and     #$7F
0002DBr 2  85 3C                sta     BAS_TMP2                ; expected char (uppercase)
0002DDr 2                       ; Read input char and uppercase it.
0002DDr 2  BD 00 04             lda     BAS_LINBUF,x
0002E0r 2  C9 61                cmp     #'a'
0002E2r 2  90 06                bcc     @InpCmp
0002E4r 2  C9 7B                cmp     #'z'+1
0002E6r 2  B0 02                bcs     @InpCmp
0002E8r 2  29 DF                and     #$DF
0002EAr 2               @InpCmp:
0002EAr 2  C5 3C                cmp     BAS_TMP2
0002ECr 2  D0 0C                bne     @CharMismatch
0002EEr 2  68                   pla                             ; restore raw table byte
0002EFr 2                       ; Match - is this the last char of the keyword?
0002EFr 2  30 1C                bmi     @WholeMatch             ; bit 7 set -> full keyword matched
0002F1r 2                       ; Advance both pointers and continue.
0002F1r 2  E6 61                inc     BAS_KWPTR
0002F3r 2  D0 02                bne     @CharNoCarry
0002F5r 2  E6 62                inc     BAS_KWPTR+1
0002F7r 2               @CharNoCarry:
0002F7r 2  E8                   inx
0002F8r 2  80 DA                bra     @CharLoop
0002FAr 2               
0002FAr 2               @CharMismatch:
0002FAr 2  68                   pla
0002FBr 2                       ; Skip ahead to start of next keyword in table.  Walk byte-by-byte
0002FBr 2                       ; until we consume a byte with bit 7 set (last char of this keyword)
0002FBr 2                       ; or hit the $00 terminator.
0002FBr 2               @SkipKeyword:
0002FBr 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
0002FDr 2  F0 14                beq     @NoMatch                ; hit table terminator
0002FFr 2  E6 61                inc     BAS_KWPTR
000301r 2  D0 02                bne     @SkipNoCarry
000303r 2  E6 62                inc     BAS_KWPTR+1
000305r 2               @SkipNoCarry:
000305r 2  C9 80                cmp     #$80                    ; carry set iff loaded byte >= $80
000307r 2  90 F2                bcc     @SkipKeyword
000309r 2                       ; Fall through: byte had bit 7 set => end of keyword.
000309r 2               @AdvanceTok:
000309r 2  E6 3A                inc     BAS_TMP1
00030Br 2  80 C5                bra     @KeywordLoop
00030Dr 2               
00030Dr 2               @WholeMatch:
00030Dr 2                       ; X points at the LAST matched char in input; advance past it.
00030Dr 2  E8                   inx
00030Er 2  A5 3A                lda     BAS_TMP1
000310r 2  7A                   ply                             ; restore caller's Y
000311r 2  38                   sec
000312r 2  60                   rts
000313r 2               
000313r 2               @NoMatch:
000313r 2  A6 3E                ldx     BAS_TMP3                ; restore caller's X
000315r 2  7A                   ply                             ; restore caller's Y
000316r 2  BD 00 04             lda     BAS_LINBUF,x
000319r 2  18                   clc
00031Ar 2  60                   rts
00031Br 2               
00031Br 2               ; =============================================================================
00031Br 2               ;   B a s S t o r e L i n e
00031Br 2               ; =============================================================================
00031Br 2               ; Insert or replace BAS_LINNUM in the program with the tokenized payload in
00031Br 2               ; BAS_TOKBUF.  If BAS_TOKBUF is empty, delete the existing line.
00031Br 2               ;
00031Br 2               ; Algorithm:
00031Br 2               ;   1. Find existing line number (or insertion point).
00031Br 2               ;   2. If exact match, delete that line (close the gap, decrement VARTAB).
00031Br 2               ;   3. If payload non-empty, splice in [next][num][payload][$00].
00031Br 2               ;   4. Relink all next-pointers.
00031Br 2               ; =============================================================================
00031Br 2               BasStoreLine:
00031Br 2                       ; Locate insertion point.  BAS_INDEX <- pointer; carry set = exact match.
00031Br 2  20 rr rr             jsr     BasFindLine
00031Er 2               
00031Er 2  90 03                bcc     @NoExisting
000320r 2                       ; Line exists - delete it first.
000320r 2  20 rr rr             jsr     BasDeleteAtIndex
000323r 2               @NoExisting:
000323r 2                       ; If tokbuf is empty, we're done (delete-only operation).
000323r 2  AD 00 05             lda     BAS_TOKBUF
000326r 2  D0 04                bne     @InsertNew
000328r 2  20 rr rr             jsr     BasRelink
00032Br 2  60                   rts
00032Cr 2               
00032Cr 2               @InsertNew:
00032Cr 2  20 rr rr             jsr     BasInsertAtIndex
00032Fr 2  90 04                bcc     @NoMem
000331r 2  20 rr rr             jsr     BasRelink
000334r 2  60                   rts
000335r 2               @NoMem:
000335r 2  A9 02                lda     #ERR_OUTOFMEM
000337r 2  4C rr rr             jmp     BasError
00033Ar 2               
00033Ar 2               ; =============================================================================
00033Ar 2               ;   B a s F i n d L i n e
00033Ar 2               ; =============================================================================
00033Ar 2               ; Locate BAS_LINNUM in the program list.
00033Ar 2               ;
00033Ar 2               ; On entry : BAS_LINNUM = target line number.
00033Ar 2               ; On exit  : BAS_INDEX = pointer to start of either the matching line or the
00033Ar 2               ;            first line whose number > target (or end-marker).
00033Ar 2               ;            Carry SET if exact match, CLEAR otherwise.
00033Ar 2               ; =============================================================================
00033Ar 2               BasFindLine:
00033Ar 2  AD 5D 03             lda     BAS_TXTTAB
00033Dr 2  85 20                sta     BAS_INDEX
00033Fr 2  AD 5E 03             lda     BAS_TXTTAB+1
000342r 2  85 21                sta     BAS_INDEX+1
000344r 2               @Loop:
000344r 2  A0 01                ldy     #1
000346r 2  B1 20                lda     (BAS_INDEX),y
000348r 2  F0 25                beq     @NotFound               ; end-marker (next-hi = 0)
00034Ar 2               
00034Ar 2                       ; Compare line numbers: (INDEX+2/+3) vs LINNUM.
00034Ar 2  A0 03                ldy     #3
00034Cr 2  B1 20                lda     (BAS_INDEX),y
00034Er 2  C5 09                cmp     BAS_LINNUM+1
000350r 2  90 0D                bcc     @Advance                ; line < target
000352r 2  D0 1B                bne     @TooHigh                ; line > target -> insertion point
000354r 2  88                   dey
000355r 2  B1 20                lda     (BAS_INDEX),y
000357r 2  C5 08                cmp     BAS_LINNUM
000359r 2  90 04                bcc     @Advance
00035Br 2  D0 12                bne     @TooHigh
00035Dr 2                       ; Exact match.
00035Dr 2  38                   sec
00035Er 2  60                   rts
00035Fr 2               
00035Fr 2               @Advance:
00035Fr 2                       ; Follow next-pointer.
00035Fr 2  A0 00                ldy     #0
000361r 2  B1 20                lda     (BAS_INDEX),y
000363r 2  48                   pha
000364r 2  A0 01                ldy     #1
000366r 2  B1 20                lda     (BAS_INDEX),y
000368r 2  85 21                sta     BAS_INDEX+1
00036Ar 2  68                   pla
00036Br 2  85 20                sta     BAS_INDEX
00036Dr 2  80 D5                bra     @Loop
00036Fr 2               
00036Fr 2               @NotFound:
00036Fr 2               @TooHigh:
00036Fr 2  18                   clc
000370r 2  60                   rts
000371r 2               
000371r 2               ; =============================================================================
000371r 2               ;   B a s D e l e t e A t I n d e x
000371r 2               ; =============================================================================
000371r 2               ; Delete the line whose start is at BAS_INDEX.
000371r 2               ; Closes the gap by copying [next-line .. VARTAB-1] down to (BAS_INDEX...)
000371r 2               ; and decrements VARTAB by the deleted size.
000371r 2               ; =============================================================================
000371r 2               BasDeleteAtIndex:
000371r 2                       ; BAS_TMP1 = next-line address (read from current line's next ptr).
000371r 2  A0 00                ldy     #0
000373r 2  B1 20                lda     (BAS_INDEX),y
000375r 2  85 3A                sta     BAS_TMP1
000377r 2  C8                   iny
000378r 2  B1 20                lda     (BAS_INDEX),y
00037Ar 2  85 3B                sta     BAS_TMP1+1
00037Cr 2               
00037Cr 2                       ; gap-size = TMP1 - INDEX  (positive)
00037Cr 2                       ; Copy from TMP1 to INDEX, byte by byte, until TMP1 reaches VARTAB.
00037Cr 2                       ; BAS_DEST = INDEX (write cursor); BAS_TMP2 = src cursor (= TMP1).
00037Cr 2  A5 20                lda     BAS_INDEX
00037Er 2  85 22                sta     BAS_DEST
000380r 2  A5 21                lda     BAS_INDEX+1
000382r 2  85 23                sta     BAS_DEST+1
000384r 2               
000384r 2               @CopyLoop:
000384r 2                       ; Done when TMP1 == VARTAB.
000384r 2  A5 3A                lda     BAS_TMP1
000386r 2  CD 5F 03             cmp     BAS_VARTAB
000389r 2  A5 3B                lda     BAS_TMP1+1
00038Br 2  ED 60 03             sbc     BAS_VARTAB+1
00038Er 2  B0 14                bcs     @CopyDone
000390r 2               
000390r 2  A0 00                ldy     #0
000392r 2  B1 3A                lda     (BAS_TMP1),y
000394r 2  91 22                sta     (BAS_DEST),y
000396r 2               
000396r 2  E6 3A                inc     BAS_TMP1
000398r 2  D0 02                bne     @IncDest
00039Ar 2  E6 3B                inc     BAS_TMP1+1
00039Cr 2               @IncDest:
00039Cr 2  E6 22                inc     BAS_DEST
00039Er 2  D0 E4                bne     @CopyLoop
0003A0r 2  E6 23                inc     BAS_DEST+1
0003A2r 2  80 E0                bra     @CopyLoop
0003A4r 2               
0003A4r 2               @CopyDone:
0003A4r 2                       ; VARTAB = DEST.
0003A4r 2  A5 22                lda     BAS_DEST
0003A6r 2  8D 5F 03             sta     BAS_VARTAB
0003A9r 2  A5 23                lda     BAS_DEST+1
0003ABr 2  8D 60 03             sta     BAS_VARTAB+1
0003AEr 2                       ; Mirror to ARYTAB/STREND (vars/arrays empty after edit; keep them
0003AEr 2                       ; tracking VARTAB).
0003AEr 2  8D 62 03             sta     BAS_ARYTAB+1
0003B1r 2  8D 64 03             sta     BAS_STREND+1
0003B4r 2  AD 5F 03             lda     BAS_VARTAB
0003B7r 2  8D 61 03             sta     BAS_ARYTAB
0003BAr 2  8D 63 03             sta     BAS_STREND
0003BDr 2  60                   rts
0003BEr 2               
0003BEr 2               ; =============================================================================
0003BEr 2               ;   B a s I n s e r t A t I n d e x
0003BEr 2               ; =============================================================================
0003BEr 2               ; Splice a new line ([next-placeholder][num-lo][num-hi][payload][$00]) in
0003BEr 2               ; at BAS_INDEX, shifting following bytes upward.
0003BEr 2               ;
0003BEr 2               ; On entry : BAS_INDEX = insertion address, BAS_LINNUM = line number,
0003BEr 2               ;            BAS_TOKBUF = NUL-terminated payload (non-empty).
0003BEr 2               ; On exit  : Carry SET on success, CLEAR if not enough memory.
0003BEr 2               ;            VARTAB / ARYTAB / STREND advanced to new end-of-program.
0003BEr 2               ; =============================================================================
0003BEr 2               BasInsertAtIndex:
0003BEr 2                       ; Compute payload length L (excluding NUL): scan TOKBUF.
0003BEr 2  A0 00                ldy     #0
0003C0r 2               @LenScan:
0003C0r 2  B9 00 05             lda     BAS_TOKBUF,y
0003C3r 2  F0 03                beq     @LenDone
0003C5r 2  C8                   iny
0003C6r 2  D0 F8                bne     @LenScan
0003C8r 2               @LenDone:
0003C8r 2                       ; Total line size = 4 (header) + L + 1 (terminator) = L + 5.
0003C8r 2                       ; Store size in BAS_TMP3 (assumes <= 250+5 = 255, fits in one byte).
0003C8r 2  98                   tya
0003C9r 2  18                   clc
0003CAr 2  69 05                adc     #5
0003CCr 2  85 3E                sta     BAS_TMP3                ; line size in bytes (<=255)
0003CEr 2               
0003CEr 2                       ; Memory check: VARTAB + size <= MEMSIZ.
0003CEr 2  18                   clc
0003CFr 2  AD 5F 03             lda     BAS_VARTAB
0003D2r 2  65 3E                adc     BAS_TMP3
0003D4r 2  85 3A                sta     BAS_TMP1
0003D6r 2  AD 60 03             lda     BAS_VARTAB+1
0003D9r 2  69 00                adc     #0
0003DBr 2  85 3B                sta     BAS_TMP1+1
0003DDr 2  A5 3A                lda     BAS_TMP1
0003DFr 2  CD 67 03             cmp     BAS_MEMSIZ
0003E2r 2  A5 3B                lda     BAS_TMP1+1
0003E4r 2  ED 68 03             sbc     BAS_MEMSIZ+1
0003E7r 2  90 02                bcc     @SizeOK
0003E9r 2  18                   clc                             ; out of memory
0003EAr 2  60                   rts
0003EBr 2               @SizeOK:
0003EBr 2                       ; Shift bytes [INDEX .. VARTAB-1] up by TMP3.
0003EBr 2                       ; Copy from high-to-low to avoid overlap clobber.
0003EBr 2                       ; src  = VARTAB-1
0003EBr 2                       ; dst  = VARTAB-1 + TMP3
0003EBr 2  AD 5F 03             lda     BAS_VARTAB
0003EEr 2  38                   sec
0003EFr 2  E9 01                sbc     #1
0003F1r 2  85 3A                sta     BAS_TMP1                ; src
0003F3r 2  AD 60 03             lda     BAS_VARTAB+1
0003F6r 2  E9 00                sbc     #0
0003F8r 2  85 3B                sta     BAS_TMP1+1
0003FAr 2  18                   clc
0003FBr 2  A5 3A                lda     BAS_TMP1
0003FDr 2  65 3E                adc     BAS_TMP3
0003FFr 2  85 22                sta     BAS_DEST                ; dst
000401r 2  A5 3B                lda     BAS_TMP1+1
000403r 2  69 00                adc     #0
000405r 2  85 23                sta     BAS_DEST+1
000407r 2               @Shift:
000407r 2                       ; Stop when TMP1 < INDEX (i.e. INDEX-1 reached -> done).
000407r 2  A5 3A                lda     BAS_TMP1
000409r 2  C5 20                cmp     BAS_INDEX
00040Br 2  A5 3B                lda     BAS_TMP1+1
00040Dr 2  E5 21                sbc     BAS_INDEX+1
00040Fr 2  90 18                bcc     @ShiftDone
000411r 2               
000411r 2  A0 00                ldy     #0
000413r 2  B1 3A                lda     (BAS_TMP1),y
000415r 2  91 22                sta     (BAS_DEST),y
000417r 2               
000417r 2                       ; dec TMP1
000417r 2  A5 3A                lda     BAS_TMP1
000419r 2  D0 02                bne     @T1NoBorrow
00041Br 2  C6 3B                dec     BAS_TMP1+1
00041Dr 2               @T1NoBorrow:
00041Dr 2  C6 3A                dec     BAS_TMP1
00041Fr 2                       ; dec DEST
00041Fr 2  A5 22                lda     BAS_DEST
000421r 2  D0 02                bne     @DNoBorrow
000423r 2  C6 23                dec     BAS_DEST+1
000425r 2               @DNoBorrow:
000425r 2  C6 22                dec     BAS_DEST
000427r 2  80 DE                bra     @Shift
000429r 2               
000429r 2               @ShiftDone:
000429r 2                       ; Write new line header at BAS_INDEX.
000429r 2  A0 00                ldy     #0
00042Br 2  A9 FF                lda     #$FF                    ; placeholder next-ptr (Relink fixes)
00042Dr 2  91 20                sta     (BAS_INDEX),y
00042Fr 2  C8                   iny
000430r 2  91 20                sta     (BAS_INDEX),y
000432r 2  C8                   iny
000433r 2  A5 08                lda     BAS_LINNUM
000435r 2  91 20                sta     (BAS_INDEX),y
000437r 2  C8                   iny
000438r 2  A5 09                lda     BAS_LINNUM+1
00043Ar 2  91 20                sta     (BAS_INDEX),y
00043Cr 2  C8                   iny
00043Dr 2               
00043Dr 2                       ; Copy payload from BAS_TOKBUF (NUL terminator included).
00043Dr 2  A2 00                ldx     #0
00043Fr 2               @PayloadCopy:
00043Fr 2  BD 00 05             lda     BAS_TOKBUF,x
000442r 2  91 20                sta     (BAS_INDEX),y
000444r 2  F0 04                beq     @PayloadDone
000446r 2  E8                   inx
000447r 2  C8                   iny
000448r 2  80 F5                bra     @PayloadCopy
00044Ar 2               @PayloadDone:
00044Ar 2                       ; Update VARTAB.
00044Ar 2  18                   clc
00044Br 2  AD 5F 03             lda     BAS_VARTAB
00044Er 2  65 3E                adc     BAS_TMP3
000450r 2  8D 5F 03             sta     BAS_VARTAB
000453r 2  AD 60 03             lda     BAS_VARTAB+1
000456r 2  69 00                adc     #0
000458r 2  8D 60 03             sta     BAS_VARTAB+1
00045Br 2                       ; Mirror to ARYTAB/STREND.
00045Br 2  AD 5F 03             lda     BAS_VARTAB
00045Er 2  8D 61 03             sta     BAS_ARYTAB
000461r 2  8D 63 03             sta     BAS_STREND
000464r 2  AD 60 03             lda     BAS_VARTAB+1
000467r 2  8D 62 03             sta     BAS_ARYTAB+1
00046Ar 2  8D 64 03             sta     BAS_STREND+1
00046Dr 2               
00046Dr 2  38                   sec
00046Er 2  60                   rts
00046Fr 2               
00046Fr 2               ; =============================================================================
00046Fr 2               ;   B a s R e l i n k
00046Fr 2               ; =============================================================================
00046Fr 2               ; Walk the program list and rewrite every next-pointer to the address of
00046Fr 2               ; the following line (computed by scanning forward to the line's NUL
00046Fr 2               ; terminator).  Stops when a next-pointer's high byte is already 0
00046Fr 2               ; (the [00][00] end-marker, which is left untouched).
00046Fr 2               ; =============================================================================
00046Fr 2               BasRelink:
00046Fr 2  AD 5D 03             lda     BAS_TXTTAB
000472r 2  85 20                sta     BAS_INDEX
000474r 2  AD 5E 03             lda     BAS_TXTTAB+1
000477r 2  85 21                sta     BAS_INDEX+1
000479r 2               @Loop:
000479r 2  A0 01                ldy     #1
00047Br 2  B1 20                lda     (BAS_INDEX),y
00047Dr 2  F0 2B                beq     @Done                   ; end-marker reached
00047Fr 2               
00047Fr 2                       ; Find the NUL terminator at INDEX + Y for some Y >= 4.
00047Fr 2  A0 04                ldy     #4
000481r 2               @Scan:
000481r 2  B1 20                lda     (BAS_INDEX),y
000483r 2  F0 03                beq     @Found
000485r 2  C8                   iny
000486r 2  D0 F9                bne     @Scan
000488r 2               @Found:
000488r 2  C8                   iny                             ; one past NUL = next line address
000489r 2                       ; next = INDEX + Y
000489r 2  98                   tya
00048Ar 2  18                   clc
00048Br 2  65 20                adc     BAS_INDEX
00048Dr 2  85 3A                sta     BAS_TMP1
00048Fr 2  A5 21                lda     BAS_INDEX+1
000491r 2  69 00                adc     #0
000493r 2  85 3B                sta     BAS_TMP1+1
000495r 2               
000495r 2                       ; Write new next-pointer at (INDEX),0/1.
000495r 2  A0 00                ldy     #0
000497r 2  A5 3A                lda     BAS_TMP1
000499r 2  91 20                sta     (BAS_INDEX),y
00049Br 2  C8                   iny
00049Cr 2  A5 3B                lda     BAS_TMP1+1
00049Er 2  91 20                sta     (BAS_INDEX),y
0004A0r 2               
0004A0r 2                       ; Advance INDEX = TMP1.
0004A0r 2  A5 3A                lda     BAS_TMP1
0004A2r 2  85 20                sta     BAS_INDEX
0004A4r 2  A5 3B                lda     BAS_TMP1+1
0004A6r 2  85 21                sta     BAS_INDEX+1
0004A8r 2  80 CF                bra     @Loop
0004AAr 2               @Done:
0004AAr 2  60                   rts
0004ABr 2               
0004ABr 2               ; =============================================================================
0004ABr 2               ;   B a s D i s p a t c h I m m e d i a t e
0004ABr 2               ; =============================================================================
0004ABr 2               ; Execute a tokenized line (BAS_TOKBUF) in immediate mode by entering the
0004ABr 2               ; statement loop (BasNewstt) with TXTPTR pointing one byte before the first
0004ABr 2               ; tokenized byte.  Re-anchors the CPU stack so that FOR / GOSUB frames
0004ABr 2               ; stored on the stack can be located by the scanners.
0004ABr 2               ; =============================================================================
0004ABr 2               BasDispatchImmediate:
0004ABr 2                       ; Write a ':' sentinel just before BAS_TOKBUF so NEWSTT's initial
0004ABr 2                       ; (TXTPTR),y read takes the @nextStmt path and CHRGETs the first token.
0004ABr 2  A9 3A                lda     #':'
0004ADr 2  8D FF 04             sta     BAS_TOKBUF-1
0004B0r 2  A9 FF                lda     #<(BAS_TOKBUF-1)
0004B2r 2  85 04                sta     TXTPTR
0004B4r 2  A9 04                lda     #>(BAS_TOKBUF-1)
0004B6r 2  85 05                sta     TXTPTR+1
0004B8r 2  9C 70 03             stz     BAS_POSX
0004BBr 2                       ; Direct mode: CURLIN = $FFFF (msbasic convention).
0004BBr 2  A9 FF                lda     #$FF
0004BDr 2  8D 69 03             sta     BAS_CURLIN
0004C0r 2  8D 6A 03             sta     BAS_CURLIN+1
0004C3r 2                       ; Reset CPU stack so FOR / GOSUB frame scanners have a clean baseline.
0004C3r 2  A2 FF                ldx     #$FF
0004C5r 2  9A                   txs
0004C6r 2  4C rr rr             jmp     BasNewstt
0004C9r 2               
0004C9r 2               ; =============================================================================
0004C9r 2               ;   B a s C m d N e w
0004C9r 2               ; =============================================================================
0004C9r 2               ; Reset program storage to empty: write [00][00] at $0800 and reset the
0004C9r 2               ; runtime pointers.
0004C9r 2               ; =============================================================================
0004C9r 2               BasCmdNew:
0004C9r 2  9C 00 08             stz     BAS_PRG_START
0004CCr 2  9C 01 08             stz     BAS_PRG_START+1
0004CFr 2  A9 02                lda     #<(BAS_PRG_START+2)
0004D1r 2  8D 5F 03             sta     BAS_VARTAB
0004D4r 2  8D 61 03             sta     BAS_ARYTAB
0004D7r 2  8D 63 03             sta     BAS_STREND
0004DAr 2  A9 08                lda     #>(BAS_PRG_START+2)
0004DCr 2  8D 60 03             sta     BAS_VARTAB+1
0004DFr 2  8D 62 03             sta     BAS_ARYTAB+1
0004E2r 2  8D 64 03             sta     BAS_STREND+1
0004E5r 2  AD 67 03             lda     BAS_MEMSIZ
0004E8r 2  8D 65 03             sta     BAS_FRETOP
0004EBr 2  AD 68 03             lda     BAS_MEMSIZ+1
0004EEr 2  8D 66 03             sta     BAS_FRETOP+1
0004F1r 2  60                   rts
0004F2r 2               
0004F2r 2               ; =============================================================================
0004F2r 2               ;   B a s C m d L i s t
0004F2r 2               ; =============================================================================
0004F2r 2               ; Print every stored line in order.  Each line: decimal line number, single
0004F2r 2               ; space, detokenized payload, CRLF.
0004F2r 2               ; =============================================================================
0004F2r 2               BasCmdList:
0004F2r 2  AD 5D 03             lda     BAS_TXTTAB
0004F5r 2  85 20                sta     BAS_INDEX
0004F7r 2  AD 5E 03             lda     BAS_TXTTAB+1
0004FAr 2  85 21                sta     BAS_INDEX+1
0004FCr 2               @LineLoop:
0004FCr 2  A0 01                ldy     #1
0004FEr 2  B1 20                lda     (BAS_INDEX),y
000500r 2  F0 3D                beq     @Done                   ; end-marker
000502r 2                       ; Print line number.
000502r 2  A0 02                ldy     #2
000504r 2  B1 20                lda     (BAS_INDEX),y
000506r 2  85 08                sta     BAS_LINNUM
000508r 2  C8                   iny
000509r 2  B1 20                lda     (BAS_INDEX),y
00050Br 2  85 09                sta     BAS_LINNUM+1
00050Dr 2  20 rr rr             jsr     BasPrintLineNum
000510r 2  A9 20                lda     #' '
000512r 2  20 rr rr             jsr     Chrout
000515r 2               
000515r 2                       ; Detokenize from offset 4 to the NUL terminator.
000515r 2  A0 04                ldy     #4
000517r 2               @DetokLoop:
000517r 2  B1 20                lda     (BAS_INDEX),y
000519r 2  F0 12                beq     @LineEnd
00051Br 2  30 06                bmi     @Token
00051Dr 2  20 rr rr             jsr     Chrout
000520r 2  C8                   iny
000521r 2  80 F4                bra     @DetokLoop
000523r 2               @Token:
000523r 2  84 42                sty     BAS_DETOKY
000525r 2  20 rr rr             jsr     BasPrintKeyword         ; preserves nothing useful
000528r 2  A4 42                ldy     BAS_DETOKY
00052Ar 2  C8                   iny
00052Br 2  80 EA                bra     @DetokLoop
00052Dr 2               @LineEnd:
00052Dr 2  20 rr rr             jsr     BasPrintCRLF
000530r 2                       ; Advance INDEX via next-pointer.
000530r 2  A0 00                ldy     #0
000532r 2  B1 20                lda     (BAS_INDEX),y
000534r 2  48                   pha
000535r 2  C8                   iny
000536r 2  B1 20                lda     (BAS_INDEX),y
000538r 2  85 21                sta     BAS_INDEX+1
00053Ar 2  68                   pla
00053Br 2  85 20                sta     BAS_INDEX
00053Dr 2  80 BD                bra     @LineLoop
00053Fr 2               @Done:
00053Fr 2  60                   rts
000540r 2               
000540r 2               ; =============================================================================
000540r 2               ;   B a s P r i n t L i n e N u m
000540r 2               ; =============================================================================
000540r 2               ; Print BAS_LINNUM (16-bit unsigned) as decimal (no leading zeros, no sign).
000540r 2               ; Clobbers : A, X, Y, BAS_TMP1.
000540r 2               ; =============================================================================
000540r 2               BasPrintLineNum:
000540r 2                       ; Repeated-subtraction divide by powers of ten.
000540r 2                       ; Suppress leading zeros via flag in BAS_TMP3.
000540r 2  64 3E                stz     BAS_TMP3                ; printed-something flag
000542r 2  64 3C                stz     BAS_TMP2                ; current-digit accumulator
000544r 2               
000544r 2  A5 08                lda     BAS_LINNUM
000546r 2  85 3A                sta     BAS_TMP1
000548r 2  A5 09                lda     BAS_LINNUM+1
00054Ar 2  85 3B                sta     BAS_TMP1+1
00054Cr 2               
00054Cr 2  A2 00                ldx     #0
00054Er 2               @PowerLoop:
00054Er 2                       ; Subtract powers[X], counting iterations to get digit.
00054Er 2  A0 00                ldy     #0                      ; digit counter
000550r 2               @Sub:
000550r 2  38                   sec
000551r 2  A5 3A                lda     BAS_TMP1
000553r 2  FD rr rr             sbc     PowersOfTenLo,x
000556r 2  A8                   tay                             ; temp save
000557r 2  A5 3B                lda     BAS_TMP1+1
000559r 2  FD rr rr             sbc     PowersOfTenHi,x
00055Cr 2  90 08                bcc     @SubDone
00055Er 2  85 3B                sta     BAS_TMP1+1
000560r 2  84 3A                sty     BAS_TMP1
000562r 2                       ; reuse Y for digit count via a scratch?  Use BAS_TMP2.
000562r 2  E6 3C                inc     BAS_TMP2
000564r 2  80 EA                bra     @Sub
000566r 2               @SubDone:
000566r 2                       ; Digit is in BAS_TMP2.
000566r 2  A5 3C                lda     BAS_TMP2
000568r 2  05 3E                ora     BAS_TMP3                ; if any prior digit OR this digit nonzero, print
00056Ar 2  F0 0B                beq     @SkipDigit
00056Cr 2  A5 3C                lda     BAS_TMP2
00056Er 2  09 30                ora     #'0'
000570r 2  20 rr rr             jsr     Chrout
000573r 2  A9 01                lda     #1
000575r 2  85 3E                sta     BAS_TMP3
000577r 2               @SkipDigit:
000577r 2  64 3C                stz     BAS_TMP2
000579r 2  E8                   inx
00057Ar 2  E0 04                cpx     #4                      ; ten-thousands, thousands, hundreds, tens
00057Cr 2  D0 08                bne     @ResetAndLoop
00057Er 2                       ; Final ones digit is in TMP1 (0-9).
00057Er 2  A5 3A                lda     BAS_TMP1
000580r 2  09 30                ora     #'0'
000582r 2  20 rr rr             jsr     Chrout
000585r 2  60                   rts
000586r 2               @ResetAndLoop:
000586r 2  80 C6                bra     @PowerLoop
000588r 2               
000588r 2               PowersOfTenLo:
000588r 2  10 E8 64 0A          .byte   <10000, <1000, <100, <10
00058Cr 2               PowersOfTenHi:
00058Cr 2  27 03 00 00          .byte   >10000, >1000, >100, >10
000590r 2               
000590r 2               ; =============================================================================
000590r 2               ;   B a s C m d P r i n t
000590r 2               ; =============================================================================
000590r 2               ; Immediate-mode PRINT.  X on entry = offset into BAS_TOKBUF where the
000590r 2               ; PRINT token sits.  Items separated by ';' (no separator) or ',' (advance
000590r 2               ; to next 14-column print zone).  Trailing ';' or ',' suppresses CRLF.
000590r 2               ;
000590r 2               ; Special-cased token: HEX(n) -> emit "$XXXX" hex form (does not call
000590r 2               ; FrmEvl; consumes the token + parens here).
000590r 2               ; =============================================================================
000590r 2               BasCmdPrint:
000590r 2                       ; TXTPTR is positioned with ChrGot returning TOK_PRINT.  Advance
000590r 2                       ; past the token; col counter is reset by the dispatcher's outer loop.
000590r 2  20 rr rr             jsr     ChrGet                  ; consume PRINT token
000593r 2               
000593r 2               BasPrLoop:
000593r 2  20 rr rr             jsr     ChrGot
000596r 2  D0 03 4C rr          jeq     BasPrEndNl
00059Ar 2  rr           
00059Br 2  C9 3A                cmp     #':'
00059Dr 2  D0 03 4C rr          jeq     BasPrEndNl
0005A1r 2  rr           
0005A2r 2  C9 A4                cmp     #TOK_ELSE
0005A4r 2  D0 03 4C rr          jeq     BasPrEndNl
0005A8r 2  rr           
0005A9r 2  C9 3B                cmp     #';'
0005ABr 2  D0 03 4C rr          jeq     BasPrSep
0005AFr 2  rr           
0005B0r 2  C9 2C                cmp     #','
0005B2r 2  D0 03 4C rr          jeq     BasPrComma
0005B6r 2  rr           
0005B7r 2  C9 CE                cmp     #TOK_HEX
0005B9r 2  D0 17                bne     @chkTab
0005BBr 2                       ; HEX(n) in PRINT context: emit "$XXXX".
0005BBr 2  20 rr rr             jsr     ChrGet                  ; consume HEX
0005BEr 2  20 rr rr             jsr     ChkOpn
0005C1r 2  20 rr rr             jsr     FrmEvl
0005C4r 2  20 rr rr             jsr     ChkNum
0005C7r 2  20 rr rr             jsr     ChkCls
0005CAr 2  20 rr rr             jsr     AyInt
0005CDr 2  20 rr rr             jsr     PrintHex16
0005D0r 2  80 6A                bra     BasPrAfter
0005D2r 2               @chkTab:
0005D2r 2  C9 9B                cmp     #TOK_TAB
0005D4r 2  D0 2D                bne     @chkSpc
0005D6r 2  20 rr rr             jsr     ChrGet                  ; consume TAB
0005D9r 2  20 rr rr             jsr     ChkOpn
0005DCr 2  20 rr rr             jsr     FrmNum
0005DFr 2  20 rr rr             jsr     ChkCls
0005E2r 2  20 rr rr             jsr     AyInt
0005E5r 2  A5 11                lda     FAC+3                   ; column count must fit in a byte
0005E7r 2  D0 53                bne     BasPrAfter
0005E9r 2  A5 12                lda     FAC+4
0005EBr 2  CD 70 03             cmp     BAS_POSX
0005EEr 2  90 4C                bcc     BasPrAfter              ; already at/past target column
0005F0r 2  38                   sec
0005F1r 2  ED 70 03             sbc     BAS_POSX
0005F4r 2  A8                   tay
0005F5r 2  F0 45                beq     BasPrAfter
0005F7r 2               @tabLoop:
0005F7r 2  5A                   phy
0005F8r 2  A9 20                lda     #' '
0005FAr 2  20 rr rr             jsr     PrintCh
0005FDr 2  7A                   ply
0005FEr 2  88                   dey
0005FFr 2  D0 F6                bne     @tabLoop
000601r 2  80 39                bra     BasPrAfter
000603r 2               @chkSpc:
000603r 2  C9 9E                cmp     #TOK_SPC
000605r 2  D0 23                bne     @expr
000607r 2  20 rr rr             jsr     ChrGet                  ; consume SPC
00060Ar 2  20 rr rr             jsr     ChkOpn
00060Dr 2  20 rr rr             jsr     FrmNum
000610r 2  20 rr rr             jsr     ChkCls
000613r 2  20 rr rr             jsr     AyInt
000616r 2  A5 11                lda     FAC+3
000618r 2  D0 22                bne     BasPrAfter
00061Ar 2  A4 12                ldy     FAC+4
00061Cr 2  F0 1E                beq     BasPrAfter
00061Er 2               @spcLoop:
00061Er 2  5A                   phy
00061Fr 2  A9 20                lda     #' '
000621r 2  20 rr rr             jsr     PrintCh
000624r 2  7A                   ply
000625r 2  88                   dey
000626r 2  D0 F6                bne     @spcLoop
000628r 2  80 12                bra     BasPrAfter
00062Ar 2               @expr:
00062Ar 2  20 rr rr             jsr     FrmEvl
00062Dr 2  24 64                bit     VALTYP
00062Fr 2  30 05                bmi     @prStr
000631r 2  20 rr rr             jsr     PrintNum
000634r 2  80 06                bra     BasPrAfter
000636r 2               @prStr:
000636r 2  20 rr rr             jsr     PrintStrFAC
000639r 2  20 rr rr             jsr     FreFac
00063Cr 2               BasPrAfter:
00063Cr 2  20 rr rr             jsr     ChrGot
00063Fr 2  D0 03 4C rr          jeq     BasPrEndNl
000643r 2  rr           
000644r 2  C9 3A                cmp     #':'
000646r 2  D0 03 4C rr          jeq     BasPrEndNl
00064Ar 2  rr           
00064Br 2  C9 A4                cmp     #TOK_ELSE
00064Dr 2  D0 03 4C rr          jeq     BasPrEndNl
000651r 2  rr           
000652r 2  C9 3B                cmp     #';'
000654r 2  D0 03 4C rr          jeq     BasPrSep
000658r 2  rr           
000659r 2  C9 2C                cmp     #','
00065Br 2  D0 03 4C rr          jeq     BasPrComma
00065Fr 2  rr           
000660r 2  4C rr rr             jmp     SynErr
000663r 2               BasPrSep:
000663r 2  20 rr rr             jsr     ChrGet                  ; consume ;
000666r 2  20 rr rr             jsr     ChrGot
000669r 2  F0 40                beq     BasPrEndNoNl            ; trailing ; -> no CRLF
00066Br 2  C9 3A                cmp     #':'
00066Dr 2  F0 3C                beq     BasPrEndNoNl
00066Fr 2  4C rr rr             jmp     BasPrLoop
000672r 2               BasPrComma:
000672r 2  20 rr rr             jsr     ChrGet
000675r 2                       ; Pad to next multiple of 14 (MS-BASIC 14-column zone).
000675r 2                       ; col_mod = BAS_POSX mod 14; if 0 already at zone, else emit (14-col_mod) spaces.
000675r 2  AD 70 03             lda     BAS_POSX
000678r 2  85 3A                sta     BAS_TMP1
00067Ar 2               @modA:
00067Ar 2  A5 3A                lda     BAS_TMP1
00067Cr 2  C9 0E                cmp     #14
00067Er 2  90 07                bcc     @modB
000680r 2  38                   sec
000681r 2  E9 0E                sbc     #14
000683r 2  85 3A                sta     BAS_TMP1
000685r 2  80 F3                bra     @modA
000687r 2               @modB:
000687r 2  C9 00                cmp     #0
000689r 2  F0 0D                beq     @padDone
00068Br 2               @padSp:
00068Br 2  A9 20                lda     #' '
00068Dr 2  20 rr rr             jsr     PrintCh
000690r 2  E6 3A                inc     BAS_TMP1
000692r 2  A5 3A                lda     BAS_TMP1
000694r 2  C9 0E                cmp     #14
000696r 2  D0 F3                bne     @padSp
000698r 2               @padDone:
000698r 2  20 rr rr             jsr     ChrGot
00069Br 2  F0 0E                beq     BasPrEndNoNl
00069Dr 2  C9 3A                cmp     #':'
00069Fr 2  F0 0A                beq     BasPrEndNoNl
0006A1r 2  4C rr rr             jmp     BasPrLoop
0006A4r 2               BasPrEndNl:
0006A4r 2  20 rr rr             jsr     BasPrintCRLF
0006A7r 2  9C 70 03             stz     BAS_POSX
0006AAr 2  60                   rts
0006ABr 2               BasPrEndNoNl:
0006ABr 2  60                   rts
0006ACr 2               
0006ACr 2               ; ---------------------------------------------------------------------------
0006ACr 2               ; PrintCh -- emit A through Chrout, maintaining BAS_POSX (CR resets it).
0006ACr 2               ; ---------------------------------------------------------------------------
0006ACr 2               PrintCh:
0006ACr 2  C9 0D                cmp     #$0D
0006AEr 2  F0 0C                beq     @cr
0006B0r 2  C9 0A                cmp     #$0A
0006B2r 2  F0 08                beq     @cr
0006B4r 2  48                   pha
0006B5r 2  EE 70 03             inc     BAS_POSX
0006B8r 2  68                   pla
0006B9r 2  4C rr rr             jmp     Chrout
0006BCr 2               @cr:
0006BCr 2  9C 70 03             stz     BAS_POSX
0006BFr 2  4C rr rr             jmp     Chrout
0006C2r 2               
0006C2r 2               ; ---------------------------------------------------------------------------
0006C2r 2               ; PrintNum -- emit FAC as ASCII via Fout, tracking column.
0006C2r 2               ; ---------------------------------------------------------------------------
0006C2r 2               PrintNum:
0006C2r 2  20 rr rr             jsr     Fout                    ; (Y,A) = NUL-terminated buffer
0006C5r 2  85 20                sta     INDEX
0006C7r 2  84 21                sty     INDEX+1
0006C9r 2  A0 00                ldy     #0
0006CBr 2               @loop:
0006CBr 2  B1 20                lda     (INDEX),y
0006CDr 2  F0 06                beq     @done
0006CFr 2  20 rr rr             jsr     PrintCh
0006D2r 2  C8                   iny
0006D3r 2  D0 F6                bne     @loop
0006D5r 2               @done:
0006D5r 2  60                   rts
0006D6r 2               
0006D6r 2               ; ---------------------------------------------------------------------------
0006D6r 2               ; PrintStrFAC -- emit string-descriptor at FAC..FAC+2.
0006D6r 2               ; ---------------------------------------------------------------------------
0006D6r 2               PrintStrFAC:
0006D6r 2  A5 0F                lda     FAC+1
0006D8r 2  85 20                sta     INDEX
0006DAr 2  A5 10                lda     FAC+2
0006DCr 2  85 21                sta     INDEX+1
0006DEr 2  A0 00                ldy     #0
0006E0r 2               @loop:
0006E0r 2  C4 0E                cpy     FAC
0006E2r 2  F0 08                beq     @done
0006E4r 2  B1 20                lda     (INDEX),y
0006E6r 2  20 rr rr             jsr     PrintCh
0006E9r 2  C8                   iny
0006EAr 2  80 F4                bra     @loop
0006ECr 2               @done:
0006ECr 2  60                   rts
0006EDr 2               
0006EDr 2               ; ---------------------------------------------------------------------------
0006EDr 2               ; PrintHex16 -- emit FAC+3,FAC+4 (lo,hi) as "$XXXX".
0006EDr 2               ; ---------------------------------------------------------------------------
0006EDr 2               PrintHex16:
0006EDr 2  A9 24                lda     #'$'
0006EFr 2  20 rr rr             jsr     PrintCh
0006F2r 2  A5 11                lda     FAC+3
0006F4r 2  20 rr rr             jsr     PrintHexByte
0006F7r 2  A5 12                lda     FAC+4
0006F9r 2                       ; fall through
0006F9r 2               PrintHexByte:
0006F9r 2  48                   pha
0006FAr 2  4A                   lsr     a
0006FBr 2  4A                   lsr     a
0006FCr 2  4A                   lsr     a
0006FDr 2  4A                   lsr     a
0006FEr 2  20 rr rr             jsr     @nib
000701r 2  68                   pla
000702r 2  29 0F                and     #$0F
000704r 2               @nib:
000704r 2  C9 0A                cmp     #10
000706r 2  90 02                bcc     @dig
000708r 2  69 06                adc     #'A'-'9'-2              ; +'A'-10-1 (carry already set)
00070Ar 2               @dig:
00070Ar 2  69 30                adc     #'0'
00070Cr 2  4C rr rr             jmp     PrintCh
00070Fr 2               
00070Fr 2               ; =============================================================================
00070Fr 2               ;   B a s P r i n t K e y w o r d
00070Fr 2               ; =============================================================================
00070Fr 2               ; Print the keyword whose token byte is in A (bit 7 set).
00070Fr 2               ; Walks the keyword table to find entry (A - TOK_BASE) and prints its chars.
00070Fr 2               ; =============================================================================
00070Fr 2               BasPrintKeyword:
00070Fr 2  38                   sec
000710r 2  E9 80                sbc     #TOK_BASE               ; A = index
000712r 2  AA                   tax
000713r 2                       ; Walk via 16-bit BAS_KWPTR since the table is > 256 bytes.
000713r 2  A9 rr                lda     #<KeywordTbl
000715r 2  85 61                sta     BAS_KWPTR
000717r 2  A9 rr                lda     #>KeywordTbl
000719r 2  85 62                sta     BAS_KWPTR+1
00071Br 2  A0 00                ldy     #0
00071Dr 2               @FindLoop:
00071Dr 2  E0 00                cpx     #0
00071Fr 2  F0 0F                beq     @PrintIt
000721r 2                       ; Skip current keyword: walk byte-by-byte until we consume a byte
000721r 2                       ; whose bit 7 is set (last char of the keyword).
000721r 2               @Skip:
000721r 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
000723r 2  E6 61                inc     BAS_KWPTR
000725r 2  D0 02                bne     @SkipNoCarry
000727r 2  E6 62                inc     BAS_KWPTR+1
000729r 2               @SkipNoCarry:
000729r 2  C9 80                cmp     #$80                    ; C set iff loaded byte >= $80
00072Br 2  90 F4                bcc     @Skip
00072Dr 2               @SkipEnd:
00072Dr 2  CA                   dex
00072Er 2  80 ED                bra     @FindLoop
000730r 2               @PrintIt:
000730r 2               @PrintLoop:
000730r 2  B1 61                lda     (BAS_KWPTR),y           ; Y == 0
000732r 2  E6 61                inc     BAS_KWPTR
000734r 2  D0 02                bne     @PrintNoCarry
000736r 2  E6 62                inc     BAS_KWPTR+1
000738r 2               @PrintNoCarry:
000738r 2  48                   pha
000739r 2  29 7F                and     #$7F
00073Br 2  20 rr rr             jsr     Chrout
00073Er 2  68                   pla
00073Fr 2  10 EF                bpl     @PrintLoop
000741r 2  60                   rts
000742r 2               
000742r 2               ; =============================================================================
000742r 2               ;   E R R O R   H A N D L I N G
000742r 2               ; =============================================================================
000742r 2               
000742r 2               BasErrSyntax:
000742r 2  A9 00                lda     #ERR_SYNTAX
000744r 2                       ; fall through
000744r 2               
000744r 2               ; BasError - print "?<msg> ERROR[ IN nnnn]" and return to the REPL.
000744r 2               ;   Input: A = error code (index into ErrorMessages).
000744r 2               ;   Resets the stack, prints, and jumps to BasReadyLoop.
000744r 2               BasError:
000744r 2  85 3E                sta     BAS_TMP3                ; stash code (stack reset wipes A on stack)
000746r 2  A2 FF                ldx     #$FF
000748r 2  9A                   txs
000749r 2  20 rr rr             jsr     BasPrintCRLF
00074Cr 2  A9 3F                lda     #'?'
00074Er 2  20 rr rr             jsr     Chrout
000751r 2  A5 3E                lda     BAS_TMP3
000753r 2                       ; A = error code; print the matching message.
000753r 2  20 rr rr             jsr     BasPrintErrorMsg
000756r 2                       ; Append " ERROR" and (if not direct mode) line number.
000756r 2  A9 rr                lda     #<MsgErrorWord
000758r 2  A0 rr                ldy     #>MsgErrorWord
00075Ar 2  20 rr rr             jsr     BasPrintStr
00075Dr 2  AD 6A 03             lda     BAS_CURLIN+1
000760r 2  C9 FF                cmp     #$FF
000762r 2  F0 14                beq     @NoLine
000764r 2  A9 rr                lda     #<MsgInWord
000766r 2  A0 rr                ldy     #>MsgInWord
000768r 2  20 rr rr             jsr     BasPrintStr
00076Br 2  AD 69 03             lda     BAS_CURLIN
00076Er 2  85 08                sta     BAS_LINNUM
000770r 2  AD 6A 03             lda     BAS_CURLIN+1
000773r 2  85 09                sta     BAS_LINNUM+1
000775r 2  20 rr rr             jsr     BasPrintLineNum
000778r 2               @NoLine:
000778r 2                       ; Mark direct mode and bounce back to REPL.
000778r 2  A9 FF                lda     #$FF
00077Ar 2  8D 69 03             sta     BAS_CURLIN
00077Dr 2  8D 6A 03             sta     BAS_CURLIN+1
000780r 2  4C rr rr             jmp     BasReadyLoop
000783r 2               
000783r 2               ; BasPrintErrorMsg - print message #A from the error-message table.
000783r 2               ;   Each message is NUL-terminated; the table is a sequence of those.
000783r 2               BasPrintErrorMsg:
000783r 2  AA                   tax
000784r 2  A9 rr                lda     #<ErrorMessages
000786r 2  85 3A                sta     BAS_TMP1
000788r 2  A9 rr                lda     #>ErrorMessages
00078Ar 2  85 3B                sta     BAS_TMP1+1
00078Cr 2               @Skip:
00078Cr 2  E0 00                cpx     #0
00078Er 2  F0 17                beq     @Print
000790r 2                       ; Walk past one message (advance until NUL, then one more).
000790r 2               @SkipLoop:
000790r 2  A0 00                ldy     #0
000792r 2  B1 3A                lda     (BAS_TMP1),y
000794r 2  F0 08                beq     @SkipDone
000796r 2  E6 3A                inc     BAS_TMP1
000798r 2  D0 F6                bne     @SkipLoop
00079Ar 2  E6 3B                inc     BAS_TMP1+1
00079Cr 2  80 F2                bra     @SkipLoop
00079Er 2               @SkipDone:
00079Er 2  E6 3A                inc     BAS_TMP1
0007A0r 2  D0 02                bne     @SkippedHi
0007A2r 2  E6 3B                inc     BAS_TMP1+1
0007A4r 2               @SkippedHi:
0007A4r 2  CA                   dex
0007A5r 2  80 E5                bra     @Skip
0007A7r 2               @Print:
0007A7r 2  A5 3A                lda     BAS_TMP1
0007A9r 2  A4 3B                ldy     BAS_TMP1+1
0007ABr 2  4C rr rr             jmp     BasPrintStr
0007AEr 2               
0007AEr 2               
0007AEr 2               ; =============================================================================
0007AEr 2               ;   F L O A T I N G - P O I N T   R U N T I M E
0007AEr 2               ;
0007AEr 2               ;   Externals required by the inlined MSBASIC FP code:
0007AEr 2               ;     ChrGet   - advance TXTPTR and load next non-space tokenized char
0007AEr 2               ;                (used by Fin; never exercised by the FP tests).
0007AEr 2               ;     BasErrorVec    - error vector; X = error code
0007AEr 2               ;     IqErr    - "?ILLEGAL QUANTITY" entry
0007AEr 2               ;     STROUT   - print NUL-terminated string at (A=lo, Y=hi)
0007AEr 2               ;     QtIn    - the literal " IN " string (used only by InPrt)
0007AEr 2               ; =============================================================================
0007AEr 2               
0007AEr 2               ; --- ChrGet / ChrGot --------------------------------------------------------
0007AEr 2               ; Real implementation (ROM, not ZP self-modifying).  Increments TXTPTR and
0007AEr 2               ; returns the next non-space byte at (TXTPTR) in A, with carry CLEAR if the
0007AEr 2               ; byte is a digit '0'-'9'.  ChrGot re-reads the current byte without
0007AEr 2               ; advancing first.  Both clobber only A and flags.
0007AEr 2               ;
0007AEr 2               ; Side effects on flags after the routine returns:
0007AEr 2               ;   Z=1  if A == $00 or A is a tokenized/keyword byte that wraps to zero
0007AEr 2               ;        (used by callers checking end-of-statement).
0007AEr 2               ;   C=0  if A is a digit ('0'-'9'); else C=1.
0007AEr 2               ;
0007AEr 2               ; Implementation matches msbasic-master/chrget.s.
0007AEr 2               ChrGet:
0007AEr 2  E6 04                inc     TXTPTR
0007B0r 2  D0 02                bne     ChrGot
0007B2r 2  E6 05                inc     TXTPTR+1
0007B4r 2               ChrGot:
0007B4r 2  B2 04                lda     (TXTPTR)
0007B6r 2  C9 3A                cmp     #':'
0007B8r 2  B0 0A                bcs     @out
0007BAr 2  C9 20                cmp     #' '
0007BCr 2  F0 F0                beq     ChrGet
0007BEr 2  38                   sec
0007BFr 2  E9 30                sbc     #'0'
0007C1r 2  38                   sec
0007C2r 2  E9 D0                sbc     #$D0                    ; restore A; sets C=0 iff digit
0007C4r 2               @out:
0007C4r 2  60                   rts
0007C5r 2               
0007C5r 2               ; --- Error trampolines ------------------------------------------------------
0007C5r 2               ; The MSBASIC convention is "ldx #code / jmp ERROR".  Our BasError takes
0007C5r 2               ; the code in A, so translate.
0007C5r 2               BasErrorVec:
0007C5r 2  8A                   txa
0007C6r 2  4C rr rr             jmp     BasError
0007C9r 2               
0007C9r 2               IqErr:
0007C9r 2  A2 0B                ldx     #ERR_ILLQUAN
0007CBr 2  4C rr rr             jmp     BasErrorVec
0007CEr 2               
0007CEr 2               ; --- String output ----------------------------------------------------------
0007CEr 2               ; FP code calls STROUT with (A=lo, Y=hi).  BasPrintStr matches that ABI.
0007CEr 2               STROUT          := BasPrintStr
0007CEr 2               
0007CEr 2               ; --- "IN " literal (referenced by InPrt) ----------------------------------
0007CEr 2               QtIn:
0007CEr 2  20 49 4E 20          .byte   " IN ",0
0007D2r 2  00           
0007D3r 2               
0007D3r 2               ; --- Shared RTS targets used by branches in the FP code --------------------
0007D3r 2               ; The original MSBASIC defines Rts3 in poke.s (which we don't include).
0007D3r 2               ; Provide a single shared RTS landing pad here.
0007D3r 2               Rts3:
0007D3r 2  60                   rts
0007D4r 2               
0007D4r 2               ; =============================================================================
0007D4r 2               ;   F L O A T I N G - P O I N T   R U N T I M E   ( P h a s e   2 )
0007D4r 2               ;
0007D4r 2               ;   Inline-ported from msbasic-master/{float,trig,rnd}.s.  Symbol aliases for
0007D4r 2               ;   FAC, ARG, INDEX, etc. are defined at the top of this file.  External hooks
0007D4r 2               ;   (ChrGet, BasErrorVec, IqErr, STROUT, QtIn) are stubbed below.
0007D4r 2               ; =============================================================================
0007D4r 2               
0007D4r 2               ; ===== from msbasic-master/float.s =====
0007D4r 2               ; (.segment removed - inlined into BASIC)
0007D4r 2               
0007D4r 2               TEMP1X = TEMP1+(5-BYTES_FP)
0007D4r 2               
0007D4r 2               ; ----------------------------------------------------------------------------
0007D4r 2               ; ADD 0.5 TO FAC
0007D4r 2               ; ----------------------------------------------------------------------------
0007D4r 2               FAddH:
0007D4r 2  A9 rr                lda     #<ConHalf
0007D6r 2  A0 rr                ldy     #>ConHalf
0007D8r 2  4C rr rr             jmp     FAdd
0007DBr 2               
0007DBr 2               ; ----------------------------------------------------------------------------
0007DBr 2               ; FAC = (Y,A) - FAC
0007DBr 2               ; ----------------------------------------------------------------------------
0007DBr 2               FSub:
0007DBr 2  20 rr rr             jsr     LoadArgFromYa
0007DEr 2               
