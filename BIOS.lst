0029E1r 2  A9 08                lda     #>PROGRAM_START
0029E3r 2  85 2B                sta     XFER_PTR+1
0029E5r 2  20 rr rr             jsr     XModemLoad
0029E8r 2  4C rr rr             jmp     BasFixChain
