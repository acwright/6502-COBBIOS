001DD8r 2  C3           
001DD9r 2  4D 45 4D 00    .byte "MEM",    $00, TOK_MEM
001DDDr 2  C2           
001DDEr 2  53 59 53 00    .byte "SYS",    $00, TOK_SYS
001DE2r 2  9E           
